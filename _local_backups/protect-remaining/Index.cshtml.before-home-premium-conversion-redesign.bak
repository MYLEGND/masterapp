@inject ProtectWebsite.Services.Booking.IPublicBookingResolver PublicBookingResolver

@{
    ViewData["Title"] = "Home";
    ViewData["PageKey"] = "home";
    var segs = (Context?.Request?.Path.Value ?? string.Empty).Split('/', StringSplitOptions.RemoveEmptyEntries);
    var agentSlug = (segs.Length >= 2 && segs[0].Equals("a", StringComparison.OrdinalIgnoreCase)) ? segs[1] : null;
    var bookingConfig = PublicBookingResolver.Resolve(agentSlug);
    var bookingLink = bookingConfig.Enabled
        ? bookingConfig.FallbackUrl ?? bookingConfig.EmbedUrl ?? "#"
        : "#";
    ViewData["SeoTitle"] = "Life Insurance, Mortgage Protection & Family Coverage";
    ViewData["SeoDescription"] = "Protect your income, family, and future with personalized life insurance, mortgage protection, final expense, and coverage planning options.";
}


@functions {
    private static Microsoft.AspNetCore.Html.IHtmlContent Icon(string name)
    {
        var svg = name switch
        {
            "shield" => "<svg viewBox='0 0 24 24'><path d='M12 3l7 3v5c0 5-3.2 8.5-7 10-3.8-1.5-7-5-7-10V6l7-3z'/><path d='M9 12l2 2 4-5'/></svg>",
            "family" => "<svg viewBox='0 0 24 24'><path d='M16 11a4 4 0 1 0-8 0'/><path d='M4 21a8 8 0 0 1 16 0'/><path d='M18 8a3 3 0 0 1 3 3'/><path d='M3 11a3 3 0 0 1 3-3'/></svg>",
            "income" => "<svg viewBox='0 0 24 24'><path d='M4 7h16v10H4z'/><path d='M8 11h.01'/><path d='M16 13h.01'/><path d='M12 9v6'/><path d='M10 11h4'/></svg>",
            "file" => "<svg viewBox='0 0 24 24'><path d='M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z'/><path d='M14 3v5h5'/><path d='M9 14l2 2 4-4'/></svg>",
            "target" => "<svg viewBox='0 0 24 24'><circle cx='12' cy='12' r='8'/><circle cx='12' cy='12' r='4'/><path d='M12 2v3'/><path d='M12 19v3'/><path d='M2 12h3'/><path d='M19 12h3'/></svg>",
            "compass" => "<svg viewBox='0 0 24 24'><circle cx='12' cy='12' r='9'/><path d='M15 9l-2 5-5 2 2-5 5-2z'/></svg>",
            "legacy" => "<svg viewBox='0 0 24 24'><path d='M4 20h16'/><path d='M6 20V9l6-5 6 5v11'/><path d='M9 20v-6h6v6'/></svg>",
            "clock" => "<svg viewBox='0 0 24 24'><circle cx='12' cy='12' r='9'/><path d='M12 7v5l3 2'/></svg>",
            "check" => "<svg viewBox='0 0 24 24'><path d='M20 6L9 17l-5-5'/></svg>",
            "arrow" => "<svg viewBox='0 0 24 24'><path d='M5 12h14'/><path d='M13 6l6 6-6 6'/></svg>",
            "question" => "<svg viewBox='0 0 24 24'><circle cx='12' cy='12' r='9'/><path d='M9.5 9a2.7 2.7 0 0 1 5 1.4c0 1.8-2.5 2.2-2.5 4'/><path d='M12 18h.01'/></svg>",
            _ => "<svg viewBox='0 0 24 24'><path d='M20 6L9 17l-5-5'/></svg>"
        };

        return new Microsoft.AspNetCore.Html.HtmlString(svg);
    }
}


<style>
:root {
    --bg: #ffffff;
    --ink: #0f172a;
    --muted: rgba(15, 23, 42, 0.72);
    --muted-2: rgba(15, 23, 42, 0.58);
    --surface: #0f172a;
    --surface-soft: #111c32;
    --ink-light: #e8edf7;
    --gold: #a68023;
    --gold-strong: #c79931;
    --gold-border: rgba(199, 153, 49, 0.72);
    --gold-border-soft: rgba(199, 153, 49, 0.50);
    --shadow: 0 16px 46px rgba(0, 0, 0, 0.12);
    --shadow-soft: 0 12px 28px rgba(0, 0, 0, 0.10);
    --radius: 16px;
    --radius-lg: 20px;
}

body {
    background: var(--bg) !important;
    font-family: 'Inter', system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
    color: var(--ink);
}

.page-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 20px 88px;
}

.section {
    padding: 48px 0;
}

.section-head {
    text-align: center;
    margin-bottom: 24px;
}

.section-title {
    margin: 0;
    font-size: clamp(1.9rem, 3vw, 2.3rem);
    font-weight: 900;
    letter-spacing: 0.02em;
    color: var(--ink);
    position: relative;
}
.section-title::after{
    content:"";
    display:block;
    width: 88px;
    height: 2px;
    margin: 10px auto 0;
    background: linear-gradient(90deg, rgba(199,153,49,0), var(--gold-strong), rgba(199,153,49,0));
}

.section-sub {
    margin: 10px auto 0;
    max-width: 820px;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.7;
}

.page-intro {
    max-width: 920px;
    margin: 20px auto 10px;
    text-align: center;
}

.page-intro-kicker {
    margin: 0;
    font-size: .82rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: var(--gold-strong);
    font-weight: 900;
}

.page-intro-title {
    margin: 8px 0 10px;
    font-size: clamp(2rem, 4vw, 2.7rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--ink);
    line-height: 1.02;
}

.page-intro-title .accent {
    color: var(--gold-strong);
}

.page-intro-sub {
    margin: 0 auto;
    max-width: 760px;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.7;
}

.grid-3 {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
}

.grid-2 {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
}

@@media (max-width: 992px) {
    .grid-3 { grid-template-columns: 1fr; }
    .grid-2 { grid-template-columns: 1fr; }
}

.shell-dark {
    background: var(--surface) !important;
    color: var(--ink-light) !important;
    border: 1.5px solid var(--gold-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    position: relative;
    overflow: hidden;
}

.shell-dark::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(800px 320px at 18% 0%, rgba(166,128,35,0.18), transparent 60%),
                radial-gradient(520px 220px at 100% 0%, rgba(166,128,35,0.12), transparent 68%);
}

.shell-dark > * { position: relative; z-index: 1; }

.card, .stat, .faq, .proof-card, .process-card {
    background: var(--surface-soft);
    color: var(--ink-light);
    border: 1.2px solid var(--gold-strong);
    border-radius: var(--radius);
    padding: 16px 16px;
    box-shadow: 0 14px 30px rgba(0,0,0,0.16);
}

.card h3, .proof-card h3, .process-card h4 { margin: 0 0 6px; color: var(--gold-strong); }
.card p, .proof-card p, .process-card p { margin: 0; color: #ffffff; line-height: 1.7; }

.pill-title {
    font-size: .8rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    color: rgba(248, 250, 252, 0.78);
    font-weight: 900;
    margin: 0 0 8px;
}

.btn {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: 999px;
    font-weight: 900;
    transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease, background .16s ease, color .16s ease;
    user-select: none;
    white-space: nowrap;
    padding: 12px 18px;
    border: 1.4px solid transparent;
}

.btn-primary {
    background: linear-gradient(180deg, var(--gold-strong), var(--gold));
    color: #fff;
    border-color: var(--gold-border);
    box-shadow: 0 16px 34px rgba(0,0,0,0.20);
}
.btn-primary:hover { transform: translateY(-2px); color: #fff; }

.btn-secondary {
    background: #fff;
    color: var(--ink);
    border-color: var(--gold-strong);
    border-width: 1.8px;
    box-shadow: 0 12px 26px rgba(0,0,0,0.14);
}
.btn-secondary:hover {
    transform: translateY(-2px);
    color: var(--ink); /* keep text dark on hover */
    background: #fff;  /* prevent white-to-light flip */
}

.badge-bar {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-radius: 999px;
    border: 1.2px solid rgba(232,237,247,0.25);
    background: rgba(255,255,255,0.08);
    color: var(--ink-light);
    font-weight: 800;
    font-size: .95rem;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.10);
}

.hero-grid {
    display: grid;
    grid-template-columns: 1.1fr;
    gap: 20px;
}

.hero h1 {
    margin: 0 0 12px;
    font-size: clamp(2.2rem, 3.8vw, 2.9rem);
    line-height: 1.08;
    color: #dfe6f0;
    font-weight: 900;
}

.hero h1 .hero-emphasis {
    color: #f2cd75;
}

.hero p.lead {
    margin: 0 0 14px;
    color: rgba(248,250,252,0.80);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 760px;
}

.hero-benefits {
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 10px;
}

.hero-benefits li {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    color: rgba(248,250,252,0.82);
    font-weight: 700;
    line-height: 1.4;
}

.hero-benefits .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gold);
    margin-top: 6px;
}

.cta-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 14px;
}

.micro-note {
    margin-top: 8px;
    color: rgba(248,250,252,0.72);
    font-size: .95rem;
    font-weight: 700;
}

@@media (max-width: 576px){
    .cta-row { gap: 12px; }
    .cta-row > a { width: 100%; justify-content: center; }
    .hero h1 { font-size: clamp(1.9rem, 6vw, 2.3rem); line-height: 1.12; }
    .hero p.lead { font-size: 1rem; line-height: 1.6; }
}

.trust-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
}

.stat {
    text-align: center;
    background: var(--surface);
    border: 1.2px solid var(--gold-strong);
    border-radius: var(--radius);
    padding: 14px 12px;
    box-shadow: 0 12px 28px rgba(0,0,0,0.14);
}

.stat .value { display: block; font-size: 1.4rem; font-weight: 900; color: var(--gold-strong); }
.stat .label { color: rgba(232,237,247,0.82); font-weight: 700; margin-top: 4px; }

.proof-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
}

.proof-quote {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--ink);
}

.rating-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(199,153,49,0.20);
    color: #f8fafc;
    font-weight: 800;
    font-size: .95rem;
}

.process {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
}
@@media (max-width: 992px) { .process { grid-template-columns: 1fr; } }

.process-card h4 { margin: 0 0 6px; font-size: 1.1rem; font-weight: 900; }
.process-card .badge-num {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    background: rgba(166,128,35,0.16);
    color: var(--ink);
    font-weight: 900;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
}

.faq {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
}
@@media (max-width: 992px) { .faq { grid-template-columns: 1fr; } }

.faq h4 { margin: 0 0 6px; font-size: 1.05rem; font-weight: 900; color: #f8fafc; }
.faq p { margin: 0; color: #f1f5f9; line-height: 1.6; }

.cta-banner {
    padding: 28px 20px;
    text-align: center;
}

.cta-banner h3 { margin: 0 0 10px; font-size: 1.6rem; font-weight: 900; }
.cta-banner p { margin: 0 0 14px; color: rgba(232,237,247,0.8); }

.trust-note {
    font-size: .95rem;
    color: rgba(255,255,255,0.66);
}

a.btn:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }

/* --- Signature Experience section --- */
.experience {
    margin-top: 8px;
    padding: 58px 24px;
    background: var(--surface) !important;
    background-color: var(--surface) !important;
    border: 1.8px solid var(--gold-border);
    border-radius: 22px;
    box-shadow: 0 22px 46px rgba(0,0,0,0.18);
    position: relative;
    overflow: hidden;
}
.experience::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
        radial-gradient(820px 340px at 12% 0%, rgba(199,153,49,0.16), transparent 60%),
        radial-gradient(640px 260px at 88% 0%, rgba(199,153,49,0.12), transparent 70%);
}
.experience::after{
    content:"";
    position:absolute;
    inset:0;
    background: linear-gradient(180deg, rgba(0,0,0,0.18), rgba(0,0,0,0.10));
    pointer-events:none;
}
.experience > * { position: relative; z-index: 1; }
.experience h2 {
    margin: 0 0 14px;
    font-size: clamp(2rem, 3.8vw, 2.6rem);
    font-weight: 900;
    letter-spacing: -0.01em;
    color: #dfe6f0;
}
.experience p.lead {
    margin: 0 0 16px;
    color: rgba(232,237,247,0.88);
    font-size: 1.07rem;
    line-height: 1.75;
    max-width: 900px;
}
.experience-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
    margin-top: 12px;
}
.experience-card {
    background: var(--surface-soft);
    border: 1.3px solid var(--gold-strong);
    border-radius: 16px;
    padding: 14px 14px;
    color: #f8fafc;
    box-shadow: 0 12px 30px rgba(0,0,0,0.18);
}
.experience-card h4 {
    margin: 0 0 6px;
    font-size: 1.05rem;
    font-weight: 900;
    color: #fff;
}
.experience-card p {
    margin: 0;
    color: rgba(232,237,247,0.82);
    line-height: 1.6;
}
@@media (max-width: 768px) {
    .experience { padding: 46px 18px; }
}

.read-at-your-pace {
    padding-top: 28px;
}

.collapsible-stack {
    display: grid;
    gap: 14px;
}

.collapsible-panel {
    background: linear-gradient(180deg, #0f172a 0%, #0c1427 100%);
    border: 1.6px solid var(--gold-border);
    border-radius: 20px;
    box-shadow: 0 18px 40px rgba(0,0,0,0.16);
    overflow: hidden;
}

.collapsible-panel[open] {
    border-color: var(--gold-strong);
    box-shadow: 0 22px 48px rgba(0,0,0,0.22);
}

.collapsible-panel > summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    transition: background .18s ease;
}

.collapsible-panel > summary::-webkit-details-marker {
    display: none;
}

.collapsible-panel > summary::marker {
    content: "";
}

.collapsible-panel > summary:hover,
.collapsible-panel > summary:focus-visible {
    background: rgba(255,255,255,0.03);
    outline: none;
}

.collapsible-copy {
    min-width: 0;
}

.collapsible-kicker {
    margin: 0 0 6px;
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    color: rgba(248,250,252,0.72);
    font-weight: 900;
}

.collapsible-title {
    margin: 0;
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    font-weight: 900;
    color: #f8fafc;
    letter-spacing: -0.01em;
}

.collapsible-preview {
    margin: 6px 0 0;
    color: rgba(232,237,247,0.78);
    line-height: 1.6;
    max-width: 760px;
}

.collapsible-toggle {
    width: 42px;
    height: 42px;
    flex: 0 0 auto;
    border-radius: 999px;
    border: 1.2px solid rgba(199,153,49,0.48);
    background: rgba(255,255,255,0.06);
    position: relative;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
}

.collapsible-toggle::before,
.collapsible-toggle::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: 14px;
    height: 2px;
    background: var(--gold-strong);
    border-radius: 999px;
    transform: translate(-50%, -50%);
    transition: transform .18s ease, opacity .18s ease;
}

.collapsible-toggle::after {
    transform: translate(-50%, -50%) rotate(90deg);
}

.collapsible-panel[open] .collapsible-toggle::after {
    opacity: 0;
}

.collapsible-panel[open] > summary {
    border-bottom: 1px solid rgba(199,153,49,0.22);
}

.collapsible-body {
    padding: 18px 20px 20px;
}

.collapsible-body .grid-3,
.collapsible-body .process,
.collapsible-body .faq,
.collapsible-body .trust-strip {
    margin-top: 0;
}

.collapsible-body .cta-row {
    margin-top: 18px;
}

.collapsible-body .card,
.collapsible-body .stat,
.collapsible-body .process-card {
    height: 100%;
}

.faq-stack {
    display: grid;
    gap: 12px;
}

@@media (max-width: 768px) {
    .collapsible-panel > summary {
        align-items: flex-start;
        padding: 16px 16px;
    }

    .collapsible-body {
        padding: 16px;
    }

    .collapsible-preview {
        max-width: none;
    }

    .collapsible-toggle {
        width: 38px;
        height: 38px;
    }
}


.home-protection-links {
    display: flex;
    flex-wrap: wrap;
    gap: .65rem;
    justify-content: center;
    margin: 1rem auto 1.4rem;
    max-width: 980px;
}

.home-protection-links a {
    border: 1px solid rgba(215, 180, 106, .35);
    border-radius: 999px;
    color: #d7b46a;
    padding: .5rem .85rem;
    text-decoration: none;
    font-size: .92rem;
    background: rgba(255,255,255,.035);
}

.home-protection-links a:hover {
    background: rgba(215, 180, 106, .12);
    color: #f3d58a;
}



/* --- Conversion visual upgrade pass --- */
.visual-icon {
    width: 42px;
    height: 42px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(199,153,49,0.14);
    border: 1px solid rgba(199,153,49,0.55);
    color: #f2cd75;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 12px 26px rgba(0,0,0,0.18);
    flex: 0 0 auto;
}
.visual-icon svg {
    width: 22px;
    height: 22px;
    stroke: currentColor;
    stroke-width: 2.1;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
}
.hero-grid {
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, .75fr);
    align-items: center;
}
.hero-visual-card {
    background: linear-gradient(180deg, rgba(17,28,50,0.98), rgba(10,18,34,0.98));
    border: 1.5px solid rgba(199,153,49,0.72);
    border-radius: 22px;
    padding: 18px;
    box-shadow: 0 22px 44px rgba(0,0,0,0.24);
}
.snapshot-head {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
}
.snapshot-head h3 {
    margin: 0;
    color: #f8fafc;
    font-size: 1.1rem;
    font-weight: 900;
}
.snapshot-head p {
    margin: 2px 0 0;
    color: rgba(232,237,247,0.72);
    font-size: .9rem;
}
.snapshot-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
}
.snapshot-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 11px 12px;
    border-radius: 14px;
    background: rgba(255,255,255,0.055);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(248,250,252,0.88);
    font-weight: 800;
}
.snapshot-check {
    width: 24px;
    height: 24px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(199,153,49,0.20);
    color: #f2cd75;
    flex: 0 0 auto;
}
.snapshot-check svg {
    width: 15px;
    height: 15px;
    stroke: currentColor;
    stroke-width: 2.6;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
}
.snapshot-foot {
    margin-top: 14px;
    padding: 12px;
    border-radius: 16px;
    background: rgba(199,153,49,0.11);
    border: 1px solid rgba(199,153,49,0.30);
    color: rgba(248,250,252,0.82);
    font-weight: 800;
    font-size: .92rem;
    line-height: 1.45;
}
.icon-title-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
}
.icon-title-row h3,
.icon-title-row h4 {
    margin-top: 0;
}
.card .visual-icon,
.experience-card .visual-icon,
.process-card .visual-icon,
.stat .visual-icon {
    margin-bottom: 10px;
}
.collapsible-summary-title {
    display: flex;
    align-items: center;
    gap: 12px;
}
.collapsible-summary-title .visual-icon {
    width: 38px;
    height: 38px;
    border-radius: 13px;
}
.collapsible-summary-title .visual-icon svg {
    width: 20px;
    height: 20px;
}
.card, .stat, .proof-card, .process-card, .experience-card {
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
}
.card:hover, .stat:hover, .proof-card:hover, .process-card:hover, .experience-card:hover {
    transform: translateY(-3px);
    border-color: #f2cd75;
    box-shadow: 0 18px 38px rgba(0,0,0,0.22);
}
.hero-benefits li {
    background: rgba(255,255,255,0.045);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 14px;
    padding: 10px 11px;
}
.hero-benefits .dot {
    width: 22px;
    height: 22px;
    margin-top: 0;
    background: rgba(199,153,49,0.18);
    border: 1px solid rgba(199,153,49,0.48);
    position: relative;
    flex: 0 0 auto;
}
.hero-benefits .dot::after {
    content: "✓";
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: #f2cd75;
    font-size: 13px;
    font-weight: 900;
}
@@media (max-width: 992px) {
    .hero-grid {
        grid-template-columns: 1fr;
    }
    .hero-visual-card {
        margin-top: 6px;
    }
}

</style>

<div class="page-wrap">

    <div class="page-intro">
        <div class="page-intro-title"> <span class="accent">Legend™ Legacy Protection</span></div>
    </div>

    <!-- HERO -->
    <section class="section shell-dark hero" style="padding: 34px 24px;">
        <div class="hero-grid">
            <div>
                <div class="badge-bar" style="margin-bottom:14px;">
                    <span class="snapshot-check">@Icon("shield")</span>
                    Protection planning made simple
                </div>
                <h1>Protect your income, family, and momentum with a <span class="hero-emphasis">clean plan.</span></h1>
                <p class="lead">See what is exposed, what is already protected, and what needs to be fixed first—without pressure or confusion.</p>

                <ul class="hero-benefits">
                    <li><span class="dot"></span>Know what you have, what’s missing, and what deserves attention first.</li>
                    <li><span class="dot"></span>Protect income, mortgage, family stability, and long-term goals.</li>
                    <li><span class="dot"></span>Compare options with licensed professionals and documented next steps.</li>
                    <li><span class="dot"></span>Keep your plan organized as life, income, debts, and goals change.</li>
                </ul>

                <div class="cta-row">
                    <a asp-controller="RiskAssessment" asp-action="Index" class="btn btn-primary" data-cta="hero_start_assessment" data-lead-trigger="true" data-lead-interest="assessment">Start Assessment</a>
                    <a href="@bookingLink" target="_blank" rel="noopener" class="btn btn-secondary" data-cta="hero_book_call">Book a Call</a>
                </div>
                <div class="micro-note">No obligation. Start with clarity, then decide what makes sense.</div>
            </div>

            <aside class="hero-visual-card" aria-label="Protection snapshot">
                <div class="snapshot-head">
                    <span class="visual-icon">@Icon("file")</span>
                    <div>
                        <h3>Protection Snapshot</h3>
                        <p>A simple view of what needs attention.</p>
                    </div>
                </div>
                <ul class="snapshot-list">
                    <li><span class="snapshot-check">@Icon("check")</span> Income protection reviewed</li>
                    <li><span class="snapshot-check">@Icon("check")</span> Mortgage and debt exposure checked</li>
                    <li><span class="snapshot-check">@Icon("check")</span> Family coverage gaps identified</li>
                    <li><span class="snapshot-check">@Icon("check")</span> Beneficiaries and ownership organized</li>
                    <li><span class="snapshot-check">@Icon("check")</span> Next steps documented clearly</li>
                </ul>
                <div class="snapshot-foot">Built for people who want protection handled with clarity, structure, and stewardship.</div>
            </aside>
        </div>
    </section>

    <!-- SIGNATURE CLIENT EXPERIENCE (must sit immediately after hero) -->
    <section class="experience section" style="padding-top: 0;">
        <h2>The Legend Client Experience</h2>
        <p class="lead">Built to be calm, documented, and decisive. We don’t just quote policies—we run a protection playbook that feels nothing like the industry norm.</p>
        <div class="experience-grid">
            <div class="experience-card">
                <span class="visual-icon">@Icon("file")</span>
                <h4>Documented decisions</h4>
                <p>Clear options, real numbers, and full transparency—so every decision is easy to understand later.</p>
            </div>
            <div class="experience-card">
                <span class="visual-icon">@Icon("clock")</span>
                <h4>Compliance-first pace</h4>
                <p>Your details are organized and easy to review without pressure, surprises, or rushed decisions.</p>
            </div>
            <div class="experience-card">
                <span class="visual-icon">@Icon("target")</span>
                <h4>Carrier-agnostic curation</h4>
                <p>We evaluate the right carriers for your situation, then align options to your cash flow and runway.</p>
            </div>
            <div class="experience-card">
                <span class="visual-icon">@Icon("legacy")</span>
                <h4>Ongoing stewardship</h4>
                <p>Your plan stays updated as income, debts, family, and goals shift.</p>
            </div>
        </div>
    </section>

    <section class="section read-at-your-pace">
        <div class="section-head">
            <h2 class="section-title">Explore At Your Pace</h2>
            <div class="home-protection-links" aria-label="Protection planning options">
                <a href="/Quote/Life">Life Insurance Review</a>
                <a href="/Quote/Mortgage-Protection">Mortgage Protection</a>
                <a href="/Quote/Term-Life">Term Life</a>
                <a href="/Quote/Whole-Life">Whole Life</a>
                <a href="/Quote/Final-Expense">Final Expense</a>
                <a href="/Quote/Disability">Disability Insurance</a>
            </div>
            <p class="section-sub">Everything below is organized into collapsible sections, so clients can open only what they want to read.</p>
        </div>

        <div class="collapsible-stack">
            <details class="collapsible-panel">
                <summary>
                    <div class="collapsible-copy">
                        <p class="collapsible-kicker">Trust Markers</p>
                        <div class="collapsible-summary-title"><span class="visual-icon">@Icon("shield")</span><h3 class="collapsible-title">Why clients trust the process</h3></div>
                        <p class="collapsible-preview">Faith-based guidance, timely pacing, broader-picture alignment, and a structured process.</p>
                    </div>
                    <span class="collapsible-toggle" aria-hidden="true"></span>
                </summary>
                <div class="collapsible-body">
                    <div class="trust-strip">
                        <div class="stat">
                            <span class="value">Faith Based</span>
                            <span class="label">Client-first, relationship-driven planning</span>
                        </div>
                        <div class="stat">
                            <span class="value">Timely</span>
                            <span class="label">Structured planning without being rushed</span>
                        </div>
                        <div class="stat">
                            <span class="value">Alignment</span>
                            <span class="label">Built to work alongside your broader financial picture</span>
                        </div>
                        <div class="stat">
                            <span class="value">Structured</span>
                            <span class="label">Built with structure, clarity, and accountability</span>
                        </div>
                    </div>
                </div>
            </details>

            <details class="collapsible-panel">
                <summary>
                    <div class="collapsible-copy">
                        <p class="collapsible-kicker">Outcomes</p>
                        <div class="collapsible-summary-title"><span class="visual-icon">@Icon("compass")</span><h3 class="collapsible-title">What you gain</h3></div>
                        <p class="collapsible-preview">Clarity, protection, and legacy planning delivered without jargon or pressure.</p>
                    </div>
                    <span class="collapsible-toggle" aria-hidden="true"></span>
                </summary>
                <div class="collapsible-body">
                    <div class="grid-3">
                        <div class="card">
                            <span class="visual-icon">@Icon("compass")</span>
                            <p class="pill-title">Clarity</p>
                            <h3>Know exactly where you stand.</h3>
                            <p>We map accounts, obligations, and coverage so you see gaps and priorities on one page.</p>
                        </div>
                        <div class="card">
                            <span class="visual-icon">@Icon("shield")</span>
                            <p class="pill-title">Protection</p>
                            <h3>Protect income and family stability.</h3>
                            <p>Right-size life, disability, and health strategies around your real cash flow and risks.</p>
                        </div>
                        <div class="card">
                            <span class="visual-icon">@Icon("legacy")</span>
                            <p class="pill-title">Legacy</p>
                            <h3>Keep what you build intact.</h3>
                            <p>Beneficiaries, ownership, and transfer structure that survive surprises, not just good intentions.</p>
                        </div>
                    </div>
                </div>
            </details>

            <details class="collapsible-panel">
                <summary>
                    <div class="collapsible-copy">
                        <p class="collapsible-kicker">Delivery</p>
                        <div class="collapsible-summary-title"><span class="visual-icon">@Icon("file")</span><h3 class="collapsible-title">How we deliver</h3></div>
                        <p class="collapsible-preview">Planning, protection, and long-term structure built around real life and real cash flow.</p>
                    </div>
                    <span class="collapsible-toggle" aria-hidden="true"></span>
                </summary>
                <div class="collapsible-body">
                    <div class="grid-3">
                        <div class="card">
                            <p class="pill-title">Planning</p>
                            <h3>Financial organization</h3>
                            <p>Clear inventory, priorities, and a documented action path so you stay in control.</p>
                        </div>
                        <div class="card">
                            <p class="pill-title">Protection</p>
                            <h3>Coverage built on reality</h3>
                            <p>We tailor life, disability, and health to your income, debts, dependents, and runway.</p>
                        </div>
                        <div class="card">
                            <p class="pill-title">Legacy</p>
                            <h3>Long-term structure</h3>
                            <p>Ownership, beneficiaries, and coordination with your estate and legal professionals for clean transfer.</p>
                        </div>
                    </div>
                </div>
            </details>

            <details class="collapsible-panel">
                <summary>
                    <div class="collapsible-copy">
                        <p class="collapsible-kicker">Process</p>
                        <div class="collapsible-summary-title"><span class="visual-icon">@Icon("arrow")</span><h3 class="collapsible-title">Simple, fast process</h3></div>
                        <p class="collapsible-preview">Three clean steps: assess, design, and implement without noise or confusion.</p>
                    </div>
                    <span class="collapsible-toggle" aria-hidden="true"></span>
                </summary>
                <div class="collapsible-body">
                    <div class="process">
                        <div class="process-card">
                            <div class="badge-num">1</div>
                            <h4>Assess</h4>
                            <p>We gather your facts, goals, and risks in one clean assessment.</p>
                        </div>
                        <div class="process-card">
                            <div class="badge-num">2</div>
                            <h4>Design</h4>
                            <p>We walk you through your options clearly, so you understand what you’re choosing and why it makes sense.</p>
                        </div>
                        <div class="process-card">
                            <div class="badge-num">3</div>
                            <h4>Implement</h4>
                            <p>We place the coverage, document it, and keep it updated, so you stay protected as life moves.</p>
                        </div>
                    </div>
                    <div class="cta-row" style="justify-content:center;">
                        <a asp-controller="RiskAssessment" asp-action="Index" class="btn btn-primary" data-cta="hero_start_assessment" data-lead-trigger="true" data-lead-interest="assessment">Start Assessment</a>
                        <a href="@bookingLink" target="_blank" rel="noopener" class="btn btn-secondary" data-cta="footer_book_call">Book a Call</a>
                    </div>
                </div>
            </details>

            <details class="collapsible-panel">
                <summary>
                    <div class="collapsible-copy">
                        <p class="collapsible-kicker">Questions</p>
                        <div class="collapsible-summary-title"><span class="visual-icon">@Icon("question")</span><h3 class="collapsible-title">Frequently asked questions</h3></div>
                        <p class="collapsible-preview">Open the common questions clients usually want answered before they move forward.</p>
                    </div>
                    <span class="collapsible-toggle" aria-hidden="true"></span>
                </summary>
                <div class="collapsible-body">
                    <div class="faq">
                        <div class="card">
                            <h4>What happens in the assessment?</h4>
                            <p>We collect your goals, income, obligations, and current coverage. You get a clear gap analysis and next steps.</p>
                        </div>
                        <div class="card">
                            <h4>Is this just insurance?</h4>
                            <p>No. We start with organization and risk clarity, then tailor coverage. Planning and protection move together.</p>
                        </div>
                        <div class="card">
                            <h4>Is there pressure to buy?</h4>
                            <p>No. You see options, tradeoffs, and costs. You choose the path that makes the most sense for you.</p>
                        </div>
                        <div class="card">
                            <h4>How fast do I see a plan?</h4>
                            <p>You’ll receive your plan in a timely, well-structured way, without anything being rushed or overlooked.</p>
                        </div>
                        <div class="card">
                            <h4>Can you work with my CPA/attorney?</h4>
                            <p>Yes. We structure everything clearly so your CPA or attorney can review it, and we help keep everything aligned so nothing conflicts or gets missed.</p>
                        </div>
                    </div>
                </div>
            </details>

            <details class="collapsible-panel">
                <summary>
                    <div class="collapsible-copy">
                        <p class="collapsible-kicker">Next Step</p>
                        <div class="collapsible-summary-title"><span class="visual-icon">@Icon("check")</span><h3 class="collapsible-title">Ready when you are</h3></div>
                        <p class="collapsible-preview">Start with a clean assessment or book time with a licensed professional when you want to move forward.</p>
                    </div>
                    <span class="collapsible-toggle" aria-hidden="true"></span>
                </summary>
                <div class="collapsible-body">
                    <div class="shell-dark cta-banner">
                        <h3>Ready to lock in clarity and protection?</h3>
                        <p>Start with a clean assessment or talk with a licensed professional.</p>
                        <div class="cta-row" style="justify-content:center;">
                            <a asp-controller="RiskAssessment" asp-action="Index" class="btn btn-primary" data-cta="hero_start_assessment" data-lead-trigger="true" data-lead-interest="assessment">Start Assessment</a>
                            <a href="@bookingLink" target="_blank" rel="noopener" class="btn btn-secondary" data-cta="footer_book_call">Book a Call</a>
                        </div>
                    </div>
                </div>
            </details>
        </div>
    </section>

</div>
