                                    <select asp-for="Senior.Retirement.ReceiveSocialSecurity" class="form-select">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label>What does that amount to each month?</label>
                                    <input asp-for="Senior.Retirement.SocialSecurityMonthlyAmount" type="number" step="0.01" class="form-control" />
                                </div>
                                <div class="field"></div>
                            </div>

                            <div class="row three">
                                <div class="field">
                                    <label>If you qualify for a company pension, what is the monthly amount?</label>
                                    <input asp-for="Senior.Retirement.CompanyPensionMonthlyAmount" type="number" step="0.01" class="form-control" />
                                </div>
                                <div class="field">
                                    <label>Does your pension have survivor benefits for your spouse?</label>
                                    <select asp-for="Senior.Retirement.PensionHasSurvivorBenefitsForSpouse" class="form-select">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
