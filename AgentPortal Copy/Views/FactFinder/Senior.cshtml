                                <div class="field"></div>
                            </div>
                        </div>

                        <div class="block">
                            <div class="block-title">Assets — Numbers</div>

                            <div class="mini-title">Non-Liquid Assets</div>
                            <div class="row two">
                                <div class="field"><label>Non-Qualified Annuities</label><input asp-for="Senior.Retirement.NonLiquidAssets.NonQualifiedAnnuities" type="number" step="0.01" class="form-control" /></div>
                                <div class="field"><label>Life Insurance Cash Value</label><input asp-for="Senior.Retirement.NonLiquidAssets.LifeInsuranceCashValue" type="number" step="0.01" class="form-control" /></div>
                            </div>
                            <div class="row two">
                                <div class="field"><label>Qualified IRAs and Annuities</label><input asp-for="Senior.Retirement.NonLiquidAssets.QualifiedIRAsAndAnnuities" type="number" step="0.01" class="form-control" /></div>
                                <div class="field"><label>Other Investments (CDs)</label><input asp-for="Senior.Retirement.NonLiquidAssets.OtherInvestments_CDs" type="number" step="0.01" class="form-control" /></div>
                            </div>
                            <div class="row two">
                                <div class="field"><label>Real Estate (excluding Primary Residence)</label><input asp-for="Senior.Retirement.NonLiquidAssets.RealEstateExcludingPrimaryResidence" type="number" step="0.01" class="form-control" /></div>
                                <div class="field"><label>Value Primary Residence</label><input asp-for="Senior.Retirement.NonLiquidAssets.ValuePrimaryResidence" type="number" step="0.01" class="form-control" /></div>
                            </div>

                            <div class="mini-title">Liquid Assets</div>
                            <div class="row two">
                                <div class="field"><label>Checking Account</label><input asp-for="Senior.Retirement.LiquidAssets.Checking" type="number" step="0.01" class="form-control" /></div>
                                <div class="field"><label>Savings Account</label><input asp-for="Senior.Retirement.LiquidAssets.Savings" type="number" step="0.01" class="form-control" /></div>
                            </div>
                            <div class="row two">
                                <div class="field"><label>Money Markets</label><input asp-for="Senior.Retirement.LiquidAssets.MoneyMarkets" type="number" step="0.01" class="form-control" /></div>
                                <div class="field"><label>Mutual Funds</label><input asp-for="Senior.Retirement.LiquidAssets.MutualFunds" type="number" step="0.01" class="form-control" /></div>
                            </div>
                            <div class="row two">
                                <div class="field"><label>Stocks, Bonds or Other</label><input asp-for="Senior.Retirement.LiquidAssets.StocksBondsOrOther" type="number" step="0.01" class="form-control" /></div>
                                <div class="field"></div>
                            </div>

                            <div class="row two">
                                <div class="field">
                                    <label>Are you aware of how required minimum distributions (RMDs) work?</label>
                                    <select asp-for="Senior.Retirement.AwareHowRMDsWork" class="form-select">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
