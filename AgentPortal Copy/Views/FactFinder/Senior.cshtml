@* Views/FactFinder/Senior.cshtml *@
@model AgentPortal.Models.FactFinderViewModel

@{
    ViewData["Title"] = "Senior Fact Finder";

    // ✅ CRITICAL: "Prepopulated" means on FIRST LOAD (GET) we show ONLY ONE card in every repeater.
    // If the page is being re-rendered after a POST (validation failure, etc.), we render ALL items so data is not lost.
    var isPost = string.Equals(ViewContext?.HttpContext?.Request?.Method, "POST", StringComparison.OrdinalIgnoreCase);
}

<style>
    :root{
        --navy-900: #0b1529;
        --navy-800: #0f1d38;
        --navy-700: #162445;
        --gold: #a68023;
        --gold-dark:#8f6f1e;
        --ink:#f8fafc;
        --muted: #cbd5e1;
        --line: rgba(166,128,35,.55);
        --bg: var(--navy-900);
        --soft:#0f1d38;
        --card:#0f1d38;
        --shadow: 0 18px 38px rgba(0,0,0,.32);
        --radius: 18px;
    }

    body { background-color: var(--bg); color: var(--ink); }

    .ff-shell{
        max-width: 980px;
        width: 100%;
        margin: 0 auto;
        padding: 0 14px 30px 14px;
        color: var(--ink);
    }

    .success-message{
        background: #e9f7ef;
        border: 1px solid #bfe5cf;
        color: #135b2c;
        padding: 12px 14px;
        border-radius: 12px;
        margin-top: 14px;
        font-weight: 800;
    }

    .ff-title{
        margin-top: 18px;
        margin-bottom: 8px;
        text-align:center;
    }

    .ff-title h1{
        font-weight: 950;
        font-size: clamp(2.0rem, 3.2vw, 2.6rem);
        color: var(--ink);
        letter-spacing: .5px;
        margin: 0;
    }

    .required-note{
        text-align:center;
        color: var(--muted);
        margin: 0 0 14px 0;
    }

    .req{ color:#dc3545; font-weight: 900; margin-left: 2px; }

    /* Progress */
    .ff-progress-wrap{
        background: var(--soft);
        border: 1.5px solid var(--gold);
        border-radius: var(--radius);
        padding: 12px 14px;
        box-shadow: var(--shadow);
        margin-bottom: 14px;
        color: var(--ink);
    }

    .ff-progress-top{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 12px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .ff-step-pill{
        background: var(--navy-800);
        border: 1.2px solid var(--gold);
        border-radius: 999px;
        padding: 6px 10px;
        font-weight: 950;
        color: var(--ink);
        font-size: .9rem;
        white-space: nowrap;
    }

    .ff-progress{
        height: 10px;
        border-radius: 999px;
        background: var(--navy-700);
        overflow:hidden;
        border: 1px solid var(--gold);
    }

    #ffProgressBarSenior{
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, var(--gold), var(--gold-dark));
        border-radius: 999px;
        transition: width .25s ease;
    }

    /* Steps */
    .wizard-step{ display:none; }
    .wizard-step.active{ display:block; }

    /* Cards */
    .section-card{
        background: #fff;
        border: 1.6px solid var(--gold);
        border-radius: var(--radius);
        padding: 16px 16px;
        box-shadow: var(--shadow);
        margin-bottom: 14px;
        color: var(--navy-900);
    }

    .section-title{
        font-weight: 950;
        color: var(--navy-900);
        font-size: 1.15rem;
        margin-bottom: 4px;
    }

    .subtle{
        color: var(--navy-900);
        font-weight: 700;
        margin-bottom: 12px;
    }

    /* Two-column main layout (you used this in markup) */
    .grid.two{
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        align-items: start;
    }

    @@media (max-width: 980px){
        .grid.two{ grid-template-columns: 1fr; }
    }

    /* Vertical blocks */
    .stack{
        display:flex;
        flex-direction: column;
        gap: 14px;
    }

    .block{
        background: var(--navy-800);
        border: 1.3px solid var(--gold);
        border-radius: 16px;
        padding: 14px;
        color: var(--ink);
    }

    .block label,
    .block .field label,
    .block .block-title,
    .block .mini-title,
    .block .subtle{
        color: #fff !important;
    }

    .block label,
    .block .field label,
    .block .block-title{
        color: var(--ink) !important;
    }

    .block-title{
        font-weight: 950;
        color: var(--ink);
        font-size: 1.05rem;
        margin-bottom: 10px;
        letter-spacing: .2px;
    }

    .mini-title{
        font-weight: 950;
        color: var(--ink);
        margin-top: 12px;
        margin-bottom: 8px;
        opacity: .92;
    }

    /* Rows */
    .row.one{
        display:grid;
        grid-template-columns: 1fr;
        gap: 12px;
        margin-bottom: 10px;
    }

    .row.two{
        display:grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 10px;
    }

    .row.three{
        display:grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-bottom: 10px;
    }

    .row.four{
        display:grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: 10px;
        margin-bottom: 10px;
    }

    .row.five{
        display:grid;
        grid-template-columns: 1.1fr .9fr .6fr .9fr 1.1fr;
        gap: 10px;
        margin-bottom: 10px;
    }

    @@media (max-width: 980px){
        .row.one, .row.two, .row.three, .row.four, .row.five{ grid-template-columns: 1fr; }
    }

    .field label{
        display:block;
        font-weight: 900;
        color: var(--navy-900);
        margin-bottom: 6px;
        font-size: .92rem;
    }

    /* White container text clarity */
    .section-card .field label,
    .section-card .section-title,
    .section-card .subtle,
    .section-card .table-like label{
        color: var(--navy-900) !important;
    }

.table-like{
    background:#fff;
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 14px;
    padding: 10px;
    margin-bottom: 10px;
    position: relative;
    color: var(--navy-900);
}

/* Force white text inside navy blocks */
.block label,
.block .field label,
.block .block-title,
.block .mini-title,
.block .subtle{
    color: #fff !important;
}

/* Override for white tables inside blocks */
.table-like label,
.table-like .field label{
    color: var(--navy-900) !important;
}

.ack-text{
    color: var(--navy-900) !important;
}

    /* GOLD INPUTS */
    input.form-control,
    textarea.form-control,
    select.form-select{
        border: 1.6px solid var(--gold) !important;
        border-radius: 12px !important;
        padding: 10px 12px !important;
        background: #fff !important;
        color: #0b1529 !important;
        font-weight: 700;
        box-shadow: none !important;
        outline: none !important;
    }

    input.form-control:focus,
    textarea.form-control:focus,
    select.form-select:focus{
        border-color: var(--gold) !important;
        box-shadow: 0 0 0 .22rem rgba(166,128,35,.25) !important;
    }

    textarea.form-control{ resize: vertical; }

    .checkline{
        display:flex;
        align-items:center;
        gap: 10px;
        background: var(--navy-800);
        border: 1.2px solid var(--gold);
        border-radius: 12px;
        padding: 10px 12px;
        margin-bottom: 10px;
        font-weight: 800;
        color: var(--ink);
    }

    .checkline input[type="checkbox"]{
        width: 18px;
        height: 18px;
        accent-color: var(--gold);
    }

    /* Table-like rows */
    .table-like{
        background:#fff;
        border: 1px solid rgba(0,0,0,.06);
        border-radius: 14px;
        padding: 10px;
        margin-bottom: 10px;
    }

    /* Buttons */
    .wizard-actions{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 12px;
        margin-top: 12px;
        flex-wrap: wrap;
    }

    .btn{
        border-radius: 999px !important;
        font-weight: 950 !important;
        letter-spacing: .2px;
        padding: 10px 16px !important;
    }

    .btn-gold{
        background: linear-gradient(180deg, var(--gold), var(--gold-dark)) !important;
        border: 1px solid rgba(0,0,0,.06) !important;
        color: #fff !important;
        box-shadow: 0 12px 26px rgba(166,128,35,.25);
    }

    .btn-gold:hover{ filter: brightness(1.02); }

    .btn-ghost{
        background: var(--navy-900) !important;
        border: 2px solid var(--gold) !important;
        color: #fff !important;
    }

    .btn-ghost:hover{
        border-color: var(--gold) !important;
        filter: brightness(1.05);
        box-shadow: 0 10px 20px rgba(0,0,0,.2);
    }

    /* Repeater card actions (BOTTOM LEFT like your Middle-Aged) */
    .ff-card-actions{
        display:flex;
        gap: 10px;
        justify-content:flex-start;
        margin-top: 10px;
    }

    .btn-mini{
        padding: 9px 14px !important;
        font-size: .92rem !important;
        box-shadow: none !important;
    }

    .btn-danger-pill{
        background: #dc3545 !important;
        border: 1px solid rgba(0,0,0,.06) !important;
        color: #fff !important;
    }

    .btn-danger-pill:hover{ filter: brightness(0.98); }
</style>

<div class="ff-shell">

    @if (ViewBag.Success != null)
    {
        <div class="success-message">@ViewBag.Success</div>
    }

    <div class="ff-title">
        <h1>Fact Finder - Seniors (62+)</h1>
    </div>

    <p class="required-note">
        <strong><span class="text-danger">*</span> Fields marked with a red asterisk are required.</strong>
    </p>

    <div class="ff-progress-wrap">
        <div class="ff-progress-top">
            <div class="ff-step-pill">
                Step <span id="ffStepNowSenior">1</span> of <span id="ffStepTotalSenior">4</span>
            </div>
            <div style="font-weight:900; color:var(--muted); font-size:.95rem;" id="ffStepLabelSenior">
                Priorities + Pain Points
            </div>
        </div>
        <div class="ff-progress"><div id="ffProgressBarSenior"></div></div>
    </div>

    <div id="ffSeniorApp">
        <form id="factFinderFormSenior" method="post" asp-action="Submit" asp-controller="FactFinder" novalidate>
            @Html.AntiForgeryToken()

            @* CRITICAL: tells controller which section was submitted *@
            <input type="hidden" asp-for="FormType" value="Senior" />

            <!-- =========================================================
                 STEP 1 — PRIORITIES + PAIN POINTS (VALUES FIRST)
                 ✅ Minimal identity (name required) + ALL "what needs fixing" first.
            ========================================================== -->
            <section class="wizard-step active" data-step="1" data-label="Priorities + Pain Points">

                <div class="section-card">
                    <div class="section-title">Part 1 — Priorities & Pain Points</div>
                    <div class="subtle">We start with what you want fixed and what matters most — then we’ll inventory what you have.</div>

                    <div class="stack">

                        <!-- Minimal Identity -->
                        <div class="block">
                            <div class="block-title">Quick Identity (Minimal)</div>

                            <div class="row two">
                                <div class="field">
                                    <label>Applicant Name<span class="req">*</span></label>
                                    <input asp-for="Senior.Applicant.ApplicantName" class="form-control" placeholder="Applicant Name*" required />
                                    <span asp-validation-for="Senior.Applicant.ApplicantName" class="text-danger"></span>
                                </div>
                                <div class="field">
                                    <label>Date of Birth</label>
                                    <input asp-for="Senior.Applicant.DateOfBirth" type="date" class="form-control" />
                                </div>
                            </div>

                            <div class="row two">
                                <div class="field">
                                    <label>Phone No.</label>
                                    <input asp-for="Senior.Applicant.Phone" type="tel" class="form-control" placeholder="Phone" />
                                </div>
                                <div class="field">
                                    <label>Email</label>
                                    <input asp-for="Senior.Applicant.Email" type="email" class="form-control" placeholder="Email" />
                                </div>
                            </div>
                        </div>

                        <!-- Medical Priorities (QUESTIONS FIRST) -->
                        <div class="block">
                            <div class="block-title">Medical Expenses — Priorities</div>

                            <div class="field">
                                <label>1) Many people are concerned about the high cost of healthcare. What are you doing to protect yourself?</label>
                                <textarea asp-for="Senior.Medical.ProtectYourselfPlan" class="form-control" placeholder="Type here..."></textarea>
                            </div>

                            <div class="field">
                                <label>2) Tell me about your health in the last three years.</label>
                                <textarea asp-for="Senior.Medical.HealthLastThreeYears" class="form-control"></textarea>
                            </div>

                            <div class="field">
                                <label>3) What medications are you taking currently?</label>
                                <textarea asp-for="Senior.Medical.CurrentMedications" class="form-control"></textarea>
                            </div>

                            <div class="row two">
                                <div class="field">
                                    <label>4) Is there a family history of cancer, stroke, or heart attack?</label>
                                    <select asp-for="Senior.Medical.FamilyHistoryCancerStrokeHeart" class="form-select">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                                <div class="field"></div>
                            </div>

                            <div class="field">
                                <label>What impact was there on the family? On the finances?</label>
                                <textarea asp-for="Senior.Medical.FamilyHistoryImpact" class="form-control"></textarea>
                            </div>

                            <div class="field">
                                <label>5) If you could change anything about your present coverage, what would it be?</label>
                                <textarea asp-for="Senior.Medical.ChangeAboutPresentCoverage" class="form-control"></textarea>
                            </div>

                            <div class="field">
                                <label>6) What is your strategy for covering medical expenses outside your plan’s coverage?</label>
                                <textarea asp-for="Senior.Medical.StrategyCoverOutsidePlansCoverage" class="form-control"></textarea>
                            </div>

                            <div class="row two">
                                <div class="field">
                                    <label>Would you like to learn about ways to avoid potential out-of-pocket costs?</label>
                                    <select asp-for="Senior.Medical.WouldLikeLearnAvoidOutOfPocket" class="form-select">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                                <div class="field"></div>
                            </div>
                        </div>

                        <!-- Extended Care Priorities (QUESTIONS FIRST; POLICY DETAILS LATER) -->
                        <div class="block">
                            <div class="block-title">Extended Care — Priorities</div>

                            <div class="row two">
                                <div class="field">
                                    <label>Do you have extended care coverage?</label>
                                    <select asp-for="Senior.ExtendedCare.HasExtendedCareCoverage" class="form-select">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                                <div class="field"></div>
                            </div>

                            <div class="mini-title">8) If no extended care coverage:</div>
                            <div class="row two">
                                <div class="field">
                                    <label>a) Have you ever looked into it?</label>
                                    <select asp-for="Senior.ExtendedCare.LookedIntoIt" class="form-select">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                                <div class="field"></div>
                            </div>

                            <div class="field">
                                <label>b) Why or why wasn’t it important for you to look into?</label>
                                <textarea asp-for="Senior.ExtendedCare.WhyNotImportant" class="form-control"></textarea>
                            </div>

                            <div class="field">
                                <label>c) If you decided against getting coverage, what prevented you from moving forward? (Price, benefits, health?)</label>
                                <textarea asp-for="Senior.ExtendedCare.WhatPreventedMovingForward" class="form-control"></textarea>
                            </div>

                            <div class="field">
                                <label>9) Who do you know who has needed extended or recovery care either at home or in a facility?</label>
                                <textarea asp-for="Senior.ExtendedCare.KnowSomeoneNeededCare" class="form-control"></textarea>
                            </div>

                            <div class="field">
                                <label>10) Was a spouse or other family member financially impacted by this need for care? If yes, tell me about that.</label>
                                <textarea asp-for="Senior.ExtendedCare.FinanciallyImpactedStory" class="form-control"></textarea>
                            </div>

                            <div class="field">
                                <label>11) Biggest concern regarding extended care:</label>
                                <select asp-for="Senior.ExtendedCare.BiggestConcernChoice" class="form-select">
                                    <option value="">Select one</option>
                                    <option>Remaining independent</option>
                                    <option>Having choices</option>
                                    <option>Protecting their assets</option>
                                    <option>Burdening others</option>
                                </select>
                            </div>

                            <div class="field">
                                <label>Why?</label>
                                <textarea asp-for="Senior.ExtendedCare.BiggestConcernWhy" class="form-control" style="min-height:72px;"></textarea>
                            </div>

                            <div class="field">
                                <label>12) What involvement do you see your children having should you need extended or recovery care?</label>
                                <textarea asp-for="Senior.ExtendedCare.ChildrenInvolvementView" class="form-control"></textarea>
                            </div>

                            <div class="field">
                                <label>13) What conversations has your family had about aging in place and the potential need for extended or recovery care?</label>
                                <textarea asp-for="Senior.ExtendedCare.FamilyConversationsAgingInPlace" class="form-control"></textarea>
                            </div>
                        </div>

                    </div>

                    <div class="wizard-actions">
                        <div></div>
                        <button type="button" class="btn btn-gold" data-next>Next</button>
                    </div>
                </div>
            </section>

            <!-- =========================================================
                 STEP 2 — FACTS + INVENTORY (HOUSEHOLD + COVERAGE DETAILS)
                 ✅ All the "hard facts" + tables moved here.
            ========================================================== -->
            <section class="wizard-step" data-step="2" data-label="Facts + Inventory">

                <div class="section-card">
                    <div class="section-title">Part 2 — Facts & Inventory</div>
                    <div class="subtle">Now we document household details and what you currently have.</div>

                    <div class="stack">

                        <!-- Applicant (full facts) -->
                        <div class="block">
                            <div class="block-title">Applicant (Details)</div>

                            <div class="row three">
                                <div class="field">
                                    <label>Occupation</label>
                                    <input asp-for="Senior.Applicant.Occupation" class="form-control" placeholder="Occupation" />
                                </div>
                                <div class="field">
                                    <label>Retired?</label>
                                    <select asp-for="Senior.Applicant.IsRetired" class="form-select">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label>Retired Year</label>
                                    <input asp-for="Senior.Applicant.RetiredYear" type="number" class="form-control" placeholder="Year" />
                                </div>
                            </div>

                            <div class="mini-title">Benefits</div>
                            <div class="checkline">
                                <input asp-for="Senior.Applicant.Benefit_Pension" type="checkbox" id="appBenPensionSenior" />
                                <label for="appBenPensionSenior">Pension</label>
                            </div>
                            <div class="checkline">
                                <input asp-for="Senior.Applicant.Benefit_HealthPlan" type="checkbox" id="appBenHealthSenior" />
                                <label for="appBenHealthSenior">Health Plan</label>
                            </div>
                            <div class="checkline">
                                <input asp-for="Senior.Applicant.Benefit_Other" type="checkbox" id="appBenOtherSenior" />
                                <label for="appBenOtherSenior">Other</label>
                            </div>
                            <div class="row one">
                                <div class="field">
                                    <label>Other (Explain)</label>
                                    <input asp-for="Senior.Applicant.BenefitOtherText" class="form-control" placeholder="Other benefits" />
                                </div>
                            </div>

                            <div class="mini-title">Address</div>
                            <div class="row two">
                                <div class="field">
                                    <label>Address</label>
                                    <input asp-for="Senior.Applicant.Address" class="form-control" placeholder="Address" />
                                </div>
                                <div class="field">
                                    <label>City</label>
                                    <input asp-for="Senior.Applicant.City" class="form-control" placeholder="City" />
                                </div>
                            </div>
                            <div class="row two">
                                <div class="field">
                                    <label>State</label>
                                    <input asp-for="Senior.Applicant.State" class="form-control" placeholder="State" />
                                </div>
                                <div class="field">
                                    <label>ZIP</label>
                                    <input asp-for="Senior.Applicant.Zip" class="form-control" placeholder="ZIP" />
                                </div>
                            </div>
                        </div>

                        <!-- Spouse + Kids + Emergency + Appointment -->
                        <div class="block">
                            <div class="block-title">Spouse / Household</div>

                            <div class="mini-title">Spouse</div>
                            <div class="row two">
                                <div class="field">
                                    <label>Spouse Name</label>
                                    <input asp-for="Senior.Spouse.SpouseName" class="form-control" placeholder="Spouse Name" />
                                </div>
                                <div class="field">
                                    <label>Date of Birth</label>
                                    <input asp-for="Senior.Spouse.DateOfBirth" type="date" class="form-control" />
                                </div>
                            </div>

                            <div class="row three">
                                <div class="field">
                                    <label>Occupation</label>
                                    <input asp-for="Senior.Spouse.Occupation" class="form-control" placeholder="Occupation" />
                                </div>
                                <div class="field">
                                    <label>Retired?</label>
                                    <select asp-for="Senior.Spouse.IsRetired" class="form-select">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label>Retired Year</label>
                                    <input asp-for="Senior.Spouse.RetiredYear" type="number" class="form-control" placeholder="Year" />
                                </div>
                            </div>

                            <div class="mini-title">Benefits</div>
                            <div class="checkline">
                                <input asp-for="Senior.Spouse.Benefit_Pension" type="checkbox" id="spBenPensionSenior" />
                                <label for="spBenPensionSenior">Pension</label>
                            </div>
                            <div class="checkline">
                                <input asp-for="Senior.Spouse.Benefit_HealthPlan" type="checkbox" id="spBenHealthSenior" />
                                <label for="spBenHealthSenior">Health Plan</label>
                            </div>
                            <div class="checkline">
                                <input asp-for="Senior.Spouse.Benefit_Other" type="checkbox" id="spBenOtherSenior" />
                                <label for="spBenOtherSenior">Other</label>
                            </div>
                            <div class="field">
                                <label>Other (Explain)</label>
                                <input asp-for="Senior.Spouse.BenefitOtherText" class="form-control" placeholder="Other benefits" />
                            </div>

                            <div class="row two">
                                <div class="field">
                                    <label>Email</label>
                                    <input asp-for="Senior.Spouse.Email" type="email" class="form-control" placeholder="Email" />
                                </div>
                                <div class="field">
                                    <label>Phone No.</label>
                                    <input asp-for="Senior.Spouse.Phone" type="tel" class="form-control" placeholder="Phone" />
                                </div>
                            </div>

