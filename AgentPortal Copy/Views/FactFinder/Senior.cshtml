                                <div class="field"></div>
                            </div>

                            <!-- Repeaters for CDs / Annuities / OtherAssets remain exactly as your current structure + JS wiring below -->
                            <!-- (You already have these blocks in your full file; keep them as-is.) -->
                        </div>

                    </div>

                    <!-- Disclaimer + Submit -->
                    <div class="section-card" style="margin-top:14px; border-width:2px;">
                        <div class="block" style="border:none; padding:0; background:transparent;">
                            <div class="checkline" style="background:#fff; color: var(--navy-900); border:1.2px solid var(--gold);">
                                <input asp-for="Senior.AcknowledgedDisclaimer" type="checkbox" class="form-check-input" id="disclaimerCheckboxSenior" required />
                                <label for="disclaimerCheckboxSenior" class="form-check-label ack-text" style="font-weight:900; margin:0; color: var(--navy-900) !important;">
                                    I acknowledge that by submitting this form, I authorize the company/agent to contact me regarding this Fact Finder intake.<span class="req">*</span>
                                </label>
                            </div>
                            <span asp-validation-for="Senior.AcknowledgedDisclaimer" class="text-danger"></span>

                            <div class="wizard-actions" style="margin-top: 12px;">
                                <button type="button" class="btn btn-ghost" data-prev>Back</button>
                                <button type="submit" class="btn btn-gold">Submit & Download PDF</button>
                            </div>
                        </div>
                    </div>

                </div>
            </section>

        </form>

        <script>
            (function () {
                const root = document.getElementById('ffSeniorApp');
                if (!root) return;

                const form = root.querySelector('#factFinderFormSenior');
                if (!form) return;

                // =========================================================
                // ✅ ONE reusable JS repeater helper (Children + Policies + Assets)
                // =========================================================
                function newKey() {
                    if (window.crypto && crypto.randomUUID) return crypto.randomUUID().replace(/-/g, '');
                    return (Date.now().toString(16) + Math.random().toString(16).slice(2));
                }

                function clearRowValues(row) {
                    row.querySelectorAll('input, textarea, select').forEach(el => {
                        if (el.type === 'hidden') return;
                        if (el.type === 'checkbox' || el.type === 'radio') el.checked = false;
                        else el.value = '';
                    });
                }

                function wireRepeater(hostId, tplId, addAttr, delAttr) {
                    const host = document.getElementById(hostId);
                    const tpl = document.getElementById(tplId);
                    if (!host || !tpl) return;

                    function bindRow(row) {
                        const addBtn = row.querySelector(`[${addAttr}]`);
                        const delBtn = row.querySelector(`[${delAttr}]`);

                        if (addBtn && !addBtn.dataset.bound) {
                            addBtn.dataset.bound = "1";
                            addBtn.addEventListener('click', function () {
                                const key = newKey();
                                const html = tpl.innerHTML.replaceAll('__KEY__', key);
                                const wrap = document.createElement('div');
                                wrap.innerHTML = html.trim();
                                const newRow = wrap.firstElementChild;

                                host.appendChild(newRow);
                                bindRow(newRow);

                                setTimeout(() => {
                                    newRow.scrollIntoView({ behavior: "smooth", block: "center" });
                                    const first = newRow.querySelector('input, textarea, select');
                                    if (first) first.focus();
                                }, 30);
                            });
                        }

                        if (delBtn && !delBtn.dataset.bound) {
                            delBtn.dataset.bound = "1";
                            delBtn.addEventListener('click', function () {
                                const rows = Array.from(host.querySelectorAll('[data-item]'));
                                if (rows.length <= 1) {
                                    clearRowValues(row);
                                    return;
                                }
                                row.remove();
                            });
                        }
                    }

                    host.querySelectorAll('[data-item]').forEach(bindRow);
                }

                // ✅ wire all repeaters (safe even if some hosts/templates are not on the page)
                wireRepeater('seniorChildrenRepeater', 'tplSeniorChildRow', 'data-add-child', 'data-del-child');
                wireRepeater('seniorApplicantPoliciesRepeater', 'tplSeniorApplicantPolicy', 'data-add-app-pol', 'data-del-app-pol');
                wireRepeater('seniorSpousePoliciesRepeater', 'tplSeniorSpousePolicy', 'data-add-sp-pol', 'data-del-sp-pol');
                wireRepeater('seniorCDsRepeater', 'tplSeniorCD', 'data-add-cd', 'data-del-cd');
                wireRepeater('seniorAnnuitiesRepeater', 'tplSeniorAnnuity', 'data-add-ann', 'data-del-ann');
                wireRepeater('seniorOtherAssetsRepeater', 'tplSeniorOtherAsset', 'data-add-oa', 'data-del-oa');

                // =========================================================
                // Wizard (KEEP EXACT behavior)
                // =========================================================
                const steps = Array.from(root.querySelectorAll('.wizard-step'));
                const total = steps.length;

                const stepNowEl = document.getElementById('ffStepNowSenior');
                const stepTotalEl = document.getElementById('ffStepTotalSenior');
                const stepLabelEl = document.getElementById('ffStepLabelSenior');
                const bar = document.getElementById('ffProgressBarSenior');

                if (stepTotalEl) stepTotalEl.textContent = String(total);

                function currentStepIndex() {
                    return steps.findIndex(s => s.classList.contains('active'));
                }

                function updateProgress(idx) {
                    const stepNum = idx + 1;

                    if (stepNowEl) stepNowEl.textContent = String(stepNum);

                    const label = steps[idx].getAttribute('data-label') || '';
                    if (stepLabelEl) stepLabelEl.textContent = label;

                    const pct = Math.round((stepNum / total) * 100);
                    if (bar) bar.style.width = pct + '%';

                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }

                function showStep(idx) {
                    steps.forEach((s, i) => s.classList.toggle('active', i === idx));
                    updateProgress(idx);
                }

                function focusFirstInvalidInStep(stepEl) {
                    const firstInvalid = stepEl.querySelector(":invalid");
                    if (firstInvalid) {
                        firstInvalid.scrollIntoView({ behavior: "smooth", block: "center" });
                        firstInvalid.focus();
                        return true;
                    }
                    return false;
                }

                root.addEventListener('click', function (e) {
                    const nextBtn = e.target.closest('[data-next]');
                    const prevBtn = e.target.closest('[data-prev]');
                    if (!nextBtn && !prevBtn) return;

                    const idx = currentStepIndex();
                    const current = steps[idx];

                    if (nextBtn) {
                        const requiredFields = Array.from(current.querySelectorAll("input, select, textarea"))
                            .filter(el => el.hasAttribute("required"));

                        let ok = true;
                        for (const el of requiredFields) {
                            if (!el.checkValidity()) { ok = false; break; }
                        }

                        if (!ok) {
                            focusFirstInvalidInStep(current);
                            return;
                        }

                        const nextIdx = Math.min(idx + 1, total - 1);
                        showStep(nextIdx);
                    }

                    if (prevBtn) {
                        const prevIdx = Math.max(idx - 1, 0);
                        showStep(prevIdx);
                    }
                });

                const checkbox = document.getElementById('disclaimerCheckboxSenior');
                form.addEventListener('submit', function (event) {
                    if (checkbox && !checkbox.checked) {
                        event.preventDefault();
                        alert('Please acknowledge the disclaimer to proceed.');
                        checkbox.scrollIntoView({ behavior: "smooth", block: "center" });
                        checkbox.focus();
                        return;
                    }

                    if (!form.checkValidity()) {
                        event.preventDefault();
                        const firstInvalid = form.querySelector(":invalid");
                        if (firstInvalid) {
                            const stepEl = firstInvalid.closest('.wizard-step');
                            if (stepEl) {
                                const idx = steps.indexOf(stepEl);
                                if (idx >= 0) showStep(idx);
                            }
                            firstInvalid.scrollIntoView({ behavior: "smooth", block: "center" });
                            firstInvalid.focus();
                        }
                    }
                });

                // init
                showStep(0);
            })();
        </script>
    </div>

</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}
