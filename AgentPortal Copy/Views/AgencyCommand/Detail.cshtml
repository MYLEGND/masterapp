@model AgentPortal.Models.AgentCommandDetailVm
@{
    ViewData["Title"] = Model.Agent.FullName + " | Agency Command";
}

<section class="command-hero">
    <div class="command-hero__content">
        <div>
            <p class="eyebrow">Founder • Internal Only</p>
            <h1>@Model.Agent.FullName</h1>
            <p class="lede">@Model.Agent.Email</p>
            @if (!string.IsNullOrWhiteSpace(Model.Agent.Title))
            {
                <span class="pill">@Model.Agent.Title</span>
            }
        </div>
        <div class="kpi-grid">
            <div class="kpi-card">
                <div class="kpi-label">Leads</div>
                <div class="kpi-value">@Model.Agent.LeadCount</div>
                <div class="kpi-sub">Calls Today @Model.Agent.CallsToday • This Week @Model.Agent.CallsWeek</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-label">Clients</div>
                <div class="kpi-value">@Model.Agent.ClientCount</div>
                <div class="kpi-sub">Follow-ups due @Model.Agent.FollowUpsDue</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-label">View Mode</div>
                <div class="kpi-value">Read-only</div>
                <div class="kpi-sub">Viewing as @Model.EffectiveAgentName</div>
            </div>
        </div>
    </div>
</section>

<section class="container-fluid px-0 command-body">
    <div class="row g-4">
        <div class="col-12 col-xl-4">
            <div class="panel">
                <div class="panel-head">
                    <h3>Pipeline</h3>
                    <span class="muted">Distribution</span>
                </div>
                <div class="pipeline-tags">
                    @if (Model.Pipeline.Any())
                    {
                        foreach (var slice in Model.Pipeline.OrderByDescending(p => p.Count))
                        {
                            <span class="pill subtle">@slice.Stage (@slice.Count)</span>
                        }
                    }
                    else
                    {
                        <span class="pill subtle muted">No pipeline data</span>
                    }
                </div>
            </div>

            <div class="panel">
                <div class="panel-head">
                    <h3>Follow-ups Due</h3>
                    <span class="muted">@Model.FollowUps.Count pending</span>
                </div>
                <div class="followups">
                    @if (Model.FollowUps.Any())
                    {
                        foreach (var f in Model.FollowUps)
                        {
                            <div class="followup">
                                <div>
                                    <div class="followup-name">@f.Name</div>
                                    <div class="followup-note">@f.Note</div>
                                </div>
                                <div class="followup-date">@f.DueDate?.ToString("MMM dd")</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="muted">No follow-ups due.</div>
                    }
                </div>
            </div>

<div class="panel alert">
    <div class="panel-head">
        <h4>View as Agent</h4>
    </div>
    <form asp-controller="Impersonation" asp-action="Start" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="agentId" value="@Model.Agent.AgentUserId" />
        <input type="hidden" name="returnUrl" value="@Url.Action("Index","Leads")" />
        <button type="submit" class="btn btn-gold">Enter View as Agent</button>
    </form>
    <p class="muted mt-2">Founder-only, server-side effective-agent override. Auth identity remains your own.</p>
</div>
        </div>

        <div class="col-12 col-xl-8">
            <div class="panel">
                <div class="panel-head">
                    <h3>Leads</h3>
                    <span class="muted">@Model.Leads.Count records</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-dark table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Stage</th>
                                <th>Status</th>
                                <th>Calls</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var lead in Model.Leads.OrderByDescending(l => l.CallsWeek))
                        {
                            <tr>
                                <td>
                                    <div class="row-title">@lead.Name</div>
                                    <div class="row-sub">@lead.Email</div>
                                    <div class="row-sub">@lead.Phone</div>
                                </td>
                                <td>@lead.Stage</td>
                                <td>@lead.Status</td>
                                <td>
                                    <div class="row-sub">Today: @lead.CallsToday</div>
                                    <div class="row-sub">Week: @lead.CallsWeek</div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="panel mt-4">
                <div class="panel-head">
                    <h3>Clients</h3>
                    <span class="muted">@Model.Clients.Count records</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-dark table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Status</th>
                                <th>Priority</th>
                                <th>Next Touch</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var client in Model.Clients)
                        {
                            <tr>
                                <td>
                                    <div class="row-title">@client.Name</div>
                                    <div class="row-sub">@client.Email</div>
                                </td>
                                <td>@client.Status</td>
                                <td>@client.Priority</td>
                                <td>
                                    @if (client.NextTouch.HasValue)
                                    {
                                        <span class="pill subtle">@client.NextTouch.Value.ToString("MMM dd")</span>
                                    }
                                    else
                                    {
                                        <span class="muted">—</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(client.NextNote))
                                    {
                                        <div class="row-sub">@client.NextNote</div>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        :root {
            --navy: #0b1529;
            --navy-soft: #0f172a;
            --gold: #ddb457;
            --card: #111c33;
            --muted: #94a3b8;
        }
        body { background: #0a0f1d; }
        .command-hero { padding: 28px 12px 12px 12px; color: #f8fafc; }
        .command-hero__content { background: linear-gradient(135deg, #0f172a, #0b1529 55%, #0f172a); border: 1.5px solid rgba(221,180,87,.35); box-shadow: 0 20px 50px rgba(0,0,0,.38); border-radius: 18px; padding: 26px 28px; }
        .eyebrow { letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); font-weight: 800; margin-bottom: 6px; }
        h1 { font-weight: 900; letter-spacing: 0.02em; margin: 0; }
        .lede { color: var(--muted); font-weight: 600; margin-top: 6px; }
        .pill { display: inline-flex; align-items: center; gap: 6px; padding: 6px 10px; border-radius: 999px; background: rgba(221,180,87,.14); color: #f8fafc; border: 1px solid rgba(221,180,87,.35); font-weight: 800; }
        .pill.subtle { background: rgba(255,255,255,.06); border-color: rgba(221,180,87,.2); color: #e2e8f0; }
        .pill.muted { color: var(--muted); }

        .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(200px,1fr)); gap: 12px; margin-top: 18px; }
        .kpi-card { background: #0c1a32; border: 1.2px solid rgba(221,180,87,.28); border-radius: 14px; padding: 12px 14px; }
        .kpi-label { color: var(--muted); font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; }
        .kpi-value { color: #fff; font-size: 1.8rem; font-weight: 900; }
        .kpi-sub { color: var(--muted); font-weight: 700; font-size: 0.9rem; }

        .command-body { padding: 16px 12px 40px 12px; }
        .panel { background: var(--card); color: #e2e8f0; border: 1.2px solid rgba(221,180,87,.25); border-radius: 16px; padding: 16px; box-shadow: 0 20px 48px rgba(0,0,0,.35); }
        .panel.alert { border-style: dashed; background: #0d1f3a; }
        .panel + .panel { margin-top: 18px; }
        .panel-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .panel-head h3, .panel-head h4 { margin: 0; font-weight: 900; }
        .muted { color: var(--muted); font-weight: 700; }

        .pipeline-tags { display: flex; flex-wrap: wrap; gap: 6px; }
        .followups { display: flex; flex-direction: column; gap: 10px; }
        .followup { display: flex; justify-content: space-between; gap: 10px; background: #0d1f3a; border: 1px solid rgba(221,180,87,.25); border-radius: 12px; padding: 10px; }
        .followup-name { font-weight: 800; }
        .followup-note { color: var(--muted); font-weight: 700; }
        .followup-date { color: #fff; font-weight: 900; }

        .table-dark { --bs-table-bg: #0f1c33; --bs-table-striped-bg: #0f1c33; --bs-table-border-color: rgba(221,180,87,.16); }
        .table-dark th, .table-dark td { color: #e2e8f0; border-color: rgba(221,180,87,.16); }
        .row-title { font-weight: 900; }
        .row-sub { color: var(--muted); font-weight: 700; }
    </style>
}
