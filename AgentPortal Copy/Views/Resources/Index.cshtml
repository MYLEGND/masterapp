@model List<AgentPortal.Models.ResourceFileViewModel>
@using System.Linq

@{
    ViewData["Title"] = "Resources";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var resources = (ViewData.Model as IEnumerable<AgentPortal.Models.ResourceFileViewModel>)?
        .Where(r => r is not null)
        .Select(r => new AgentPortal.Models.ResourceFileViewModel
        {
            Name = r.Name ?? "",
            File = r.File ?? "",
            Extension = r.Extension ?? ""
        })
        .ToList()
        ?? new List<AgentPortal.Models.ResourceFileViewModel>();

    var resourceJson = System.Text.Json.JsonSerializer.Serialize(
        resources.Select(r => new
        {
            r.Name,
            r.File,
            r.Extension
        }));
}

<div class="resources-page container py-4">

    <!-- HEADER -->
    <div class="resources-hero mb-4">
        <div class="hero-kicker">Legend™ Education</div>
        <h1 class="hero-title m-0">@ViewData["Title"]</h1>
        <p class="hero-sub m-0 mt-2">
            Browse or search available financial education resources.
        </p>
    </div>

    <!-- CONTROLS (NOT SIDE BY SIDE WITH PREVIEW — only controls side by side) -->
    <div class="controls-card mb-4">
        <div class="row g-3 align-items-start">
            <!-- LEFT: DROPDOWN -->
            <div class="col-12 col-lg-6">
                <label class="control-label">Browse Resources</label>
                <select id="resourceDropdown" class="form-select premium-field">
                    <option value="">Select a resource…</option>
                    @foreach (var r in resources)
                    {
                        <option value="@r.File">@r.Name</option>
                    }
                </select>
                <div class="control-help">Choose a file to preview below.</div>
            </div>

            <!-- RIGHT: SEARCH -->
            <div class="col-12 col-lg-6">
                <label class="control-label">Search Resources</label>

                <div class="search-wrap">
                    <span class="search-icon">⌕</span>
                    <input id="resourceSearch"
                           type="text"
                           class="form-control premium-field premium-input"
                           placeholder="Search by name…" />
                </div>

                <ul id="searchResults" class="search-results" style="display:none;"></ul>
                <div class="control-help">Type to filter resources instantly.</div>
            </div>
        </div>
    </div>

    <!-- RESOURCE OUTPUT (FULL WIDTH UNDER INFO) -->
    <div id="resourceContainer" class="preview-shell" style="display:none;">
        <div class="preview-head">
            <div>
                <h2 id="resourceTitle" class="preview-title m-0"></h2>
                <div id="resourceMeta" class="preview-meta"></div>
            </div>

            <a id="resourceOpen" class="preview-open" href="#" target="_blank" rel="noopener">
                Open in new tab →
            </a>
        </div>

        <div class="preview-frame">
            <div id="resourceContent" class="preview-content"></div>
        </div>
    </div>

    <!-- EMPTY STATE -->
    <div id="emptyState" class="empty-state">
        <div class="empty-chip">Preview</div>
        <div class="empty-title">Select a resource to view it here</div>
        <div class="empty-text">
            Use the dropdown or search above. The full document will embed below for easy reading.
        </div>
    </div>

</div>

<style>
:root{
    --gold:#a68023;
    --gold2:#caa74a;
    --ink:#101010;
    --muted:rgba(16,16,16,.62);
    --line:#efe6d2;
    --bg:#ffffff;
    --soft:#fbfaf8;
    --shadow: 0 14px 40px rgba(0,0,0,.07);
    --shadowSoft: 0 10px 26px rgba(0,0,0,.06);
    --r12:12px;
    --r16:16px;
    --r18:18px;
}

.resources-page{
    background: var(--bg);
}

/* HERO */
.resources-hero{
    padding: 18px 18px;
    border: 1px solid rgba(239,230,210,.85);
    border-radius: var(--r18);
    background:
        radial-gradient(900px 350px at 18% 0%, rgba(166,128,35,.10), transparent 60%),
        radial-gradient(800px 300px at 90% 10%, rgba(202,167,74,.08), transparent 55%),
        #fff;
    box-shadow: var(--shadowSoft);
}

.hero-kicker{
    display:inline-block;
    font-weight: 900;
    letter-spacing: .12em;
    text-transform: uppercase;
    font-size: .75rem;
    color: rgba(16,16,16,.72);
    padding: 6px 10px;
    border: 1px solid rgba(166,128,35,.22);
    border-radius: 999px;
    background: rgba(255,255,255,.75);
}

.hero-title{
    margin-top: 10px !important;
    font-weight: 950;
    letter-spacing: -0.02em;
    background: linear-gradient(90deg, #a68023, #caa74a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-size: clamp(1.9rem, 3vw, 2.45rem);
    line-height: 1.08;
}

.hero-sub{
    color: rgba(16,16,16,.70);
    max-width: 900px;
    line-height: 1.75;
}
.hero-sub-strong{
    font-weight: 850;
    color: rgba(16,16,16,.82);
}

/* CONTROLS CARD */
.controls-card{
    padding: 18px;
    border: 1px solid rgba(239,230,210,.9);
    border-radius: var(--r18);
    background: #fff;
    box-shadow: var(--shadowSoft);
}

.control-label{
    font-weight: 900;
    color: rgba(16,16,16,.86);
    margin-bottom: 8px;
    letter-spacing: .01em;
}
.control-help{
    margin-top: 8px;
    color: rgba(16,16,16,.55);
    font-weight: 700;
    font-size: .92rem;
}

/* INPUTS */
.premium-field{
    border: 1px solid var(--line) !important;
    border-radius: 14px !important;
    padding: .75rem .9rem !important;
    background: #fff !important;
}
.premium-field:focus{
    border-color: rgba(166,128,35,.85) !important;
    box-shadow: 0 0 0 .22rem rgba(166,128,35,.16) !important;
}

.search-wrap{
    position: relative;
}
.search-icon{
    position:absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    opacity: .55;
    font-weight: 900;
}
.premium-input{
    padding-left: 36px !important;
}

/* SEARCH RESULTS */
.search-results{
    margin: 10px 0 0;
    padding: 6px;
    list-style: none;
    border-radius: 16px;
    border: 1px solid rgba(239,230,210,.95);
    background: rgba(251,250,248,.92);
    max-height: 280px;
    overflow-y: auto;
    box-shadow: var(--shadowSoft);
}
.search-results li{
    display:flex;
    align-items:center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 10px;
    border-radius: 12px;
    cursor: pointer;
    transition: transform .10s ease, background .15s ease;
}
.search-results li:hover{
    background: rgba(166,128,35,.10);
    transform: translateY(-1px);
}
.result-name{
    font-weight: 900;
    color: rgba(16,16,16,.85);
}
.result-tag{
    font-size: .76rem;
    font-weight: 950;
    padding: 4px 8px;
    border-radius: 999px;
    border: 1px solid rgba(166,128,35,.25);
    color: rgba(166,128,35,.95);
    background: rgba(255,255,255,.75);
}

/* PREVIEW */
.preview-shell{
    border: 1px solid rgba(239,230,210,.9);
    border-radius: var(--r18);
    background: #fff;
    box-shadow: var(--shadow);
    overflow:hidden;
}

.preview-head{
    padding: 16px 18px;
    border-bottom: 1px solid rgba(239,230,210,.9);
    display:flex;
    align-items:flex-start;
    justify-content: space-between;
    gap: 12px;
    background: linear-gradient(to bottom, rgba(166,128,35,.08), transparent 70%);
}

.preview-title{
    font-weight: 950;
    letter-spacing: -0.02em;
    color: rgba(16,16,16,.92);
    font-size: 1.35rem;
}
.preview-meta{
    margin-top: 6px;
    color: rgba(16,16,16,.58);
    font-weight: 800;
    font-size: .92rem;
}

.preview-open{
    white-space: nowrap;
    text-decoration: none;
    font-weight: 950;
    color: rgba(166,128,35,.95);
    padding: 10px 12px;
    border-radius: 999px;
    border: 1px solid rgba(166,128,35,.22);
    background: rgba(255,255,255,.85);
    transition: transform .12s ease, background .15s ease;
}
.preview-open:hover{
    transform: translateY(-1px);
    background: rgba(166,128,35,.10);
}

.preview-frame{
    padding: 18px;
    background: #fff;
}

.preview-content{
    border-radius: 16px;
    border: 1px solid rgba(239,230,210,.95);
    background: #fff;
    overflow: hidden;
}

/* Embedded media */
.preview-content img,
.preview-content video,
.preview-content iframe{
    width: 100%;
    display:block;
    border: 0;
}
.preview-content iframe{
    height: min(82vh, 980px);
}
.preview-content video{
    max-height: 82vh;
}

/* EMPTY STATE */
.empty-state{
    margin-top: 16px;
    padding: 22px 18px;
    border: 1px dashed rgba(166,128,35,.35);
    border-radius: var(--r18);
    background: rgba(166,128,35,.05);
}
.empty-chip{
    display:inline-block;
    font-weight: 950;
    letter-spacing: .12em;
    text-transform: uppercase;
    font-size: .72rem;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid rgba(166,128,35,.22);
    background: rgba(255,255,255,.85);
    color: rgba(16,16,16,.70);
}
.empty-title{
    margin-top: 10px;
    font-weight: 950;
    font-size: 1.2rem;
    color: rgba(16,16,16,.88);
}
.empty-text{
    margin-top: 6px;
    color: rgba(16,16,16,.64);
    line-height: 1.7;
    max-width: 900px;
}
</style>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {

    const resources = @Html.Raw(resourceJson);

    const dropdown = document.getElementById("resourceDropdown");
    const searchInput = document.getElementById("resourceSearch");
    const searchResults = document.getElementById("searchResults");

    const container = document.getElementById("resourceContainer");
    const emptyState = document.getElementById("emptyState");

    const title = document.getElementById("resourceTitle");
    const meta = document.getElementById("resourceMeta");
    const openLink = document.getElementById("resourceOpen");
    const content = document.getElementById("resourceContent");

    function extTag(ext){
        if (!ext) return "FILE";
        return ext.replace(".","").toUpperCase();
    }

    function renderResource(r) {
        emptyState.style.display = "none";
        container.style.display = "block";

        title.textContent = r.Name;

        const url = `/resources/${r.File}`;
        openLink.href = url;

        const ext = (r.Extension || "").toLowerCase();
        meta.textContent = `Type: ${extTag(ext)} • File: ${r.File}`;

        let body = "";
        if (ext === ".pdf") {
            body = `<iframe src="${url}" loading="lazy"></iframe>`;
        }
        else if ([".png", ".jpg", ".jpeg", ".webp"].includes(ext)) {
            body = `<img src="${url}" alt="${r.Name}" loading="lazy" />`;
        }
        else if (ext === ".mp4") {
            body = `
                <video controls preload="metadata">
                    <source src="${url}" type="video/mp4">
                </video>`;
        }
        else {
            body = `
                <div style="padding:18px;">
                    <a class="preview-open" href="${url}" target="_blank" rel="noopener">Open ${r.Name} →</a>
                </div>`;
        }

        content.innerHTML = body;
    }

    // DROPDOWN
    dropdown.addEventListener("change", function () {
        const file = this.value;

        searchInput.value = "";
        searchResults.innerHTML = "";
        searchResults.style.display = "none";

        if (!file) {
            container.style.display = "none";
            emptyState.style.display = "block";
            return;
        }

        const r = resources.find(x => x.File === file);
        if (r) renderResource(r);
    });

    // SEARCH (partial match)
    searchInput.addEventListener("input", function () {
        const q = (this.value || "").trim().toLowerCase();
        searchResults.innerHTML = "";

        if (!q) {
            searchResults.style.display = "none";
            return;
        }

        const matches = resources
            .filter(r => (r.Name || "").toLowerCase().includes(q))
            .slice(0, 30);

        if (matches.length === 0){
            searchResults.style.display = "block";
            searchResults.innerHTML = `<li style="padding:12px 10px; opacity:.7;">No matches found.</li>`;
            return;
        }

        matches.forEach(r => {
            const li = document.createElement("li");

            const left = document.createElement("div");
            left.className = "result-name";
            left.textContent = r.Name;

            const right = document.createElement("div");
            right.className = "result-tag";
            right.textContent = extTag((r.Extension || "").toLowerCase());

            li.appendChild(left);
            li.appendChild(right);

            li.onclick = () => {
                renderResource(r);
                dropdown.value = r.File;
                searchResults.innerHTML = "";
                searchResults.style.display = "none";
            };

            searchResults.appendChild(li);
        });

        searchResults.style.display = "block";
    });

    // Close results if clicking away
    document.addEventListener("click", (e) => {
        const clickedInside = searchResults.contains(e.target) || searchInput.contains(e.target);
        if (!clickedInside){
            searchResults.style.display = "none";
        }
    });

});
</script>
}
