@{
    ViewData["Title"] = "Tools";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool isBusinessClient = User?.Claims?.Any(c => c.Type == "RecordType" && c.Value == "BusinessClient") == true;
    bool isAgent = User?.IsInRole("Agent") == true || User?.IsInRole("Admin") == true;
    bool showBookings = isAgent || isBusinessClient;
}

<div class="text-center mb-5">
    <h1>Legend™ Core Tools</h1>
    <p class="lead">Quick access to all your Microsoft 365 tools.</p>
</div>

<div class="container tools-container">
    <div class="row g-4 justify-content-center tools-row">

        @* List of Microsoft 365 tools *@
        @{
            var baseTools = new[]
            {
                new { Name = "Outlook", Url = "https://outlook.office.com/mail/", Icon = "outlook2.png" },
                new { Name = "SharePoint", Url = "https://www.office.com/launch/sharepoint", Icon = "sharepoint.png" },
                new { Name = "Zoom", Url = "https://zoom.us/signin#/login", Icon = "zoom.png" },
                new { Name = "Teams", Url = "https://teams.microsoft.com", Icon = "teams.png" },
                new { Name = "Power Automate", Url = "https://flow.microsoft.com", Icon = "power-automate.png" },
                new { Name = "Forms", Url = "https://forms.office.com", Icon = "forms.png" },
                new { Name = "Power Apps", Url = "https://make.powerapps.com", Icon = "powerapps.png" },
                new { Name = "Word", Url = "https://www.office.com/launch/word", Icon = "word.png" },
                new { Name = "Excel", Url = "https://www.office.com/launch/excel", Icon = "excel.png" },
                new { Name = "PowerPoint", Url = "https://www.office.com/launch/powerpoint", Icon = "powerpoint.png" },
                new { Name = "OneDrive", Url = "https://onedrive.live.com", Icon = "onedrive.png" },
                new { Name = "Viva", Url = "https://www.office.com/launch/viva", Icon = "viva.png" },
                new { Name = "Copilot", Url = "https://www.microsoft.com/en-us/ai/business", Icon = "copilot.png" }
            };
            var tools = showBookings
                ? baseTools.Concat(new[] { new { Name = "Bookings", Url = "https://outlook.office.com/bookings/", Icon = "bookings.png" } })
                : baseTools;
        }

        @foreach (var tool in tools)
        {
            <div class="col-6 col-md-3 text-center">
                <a href="@tool.Url" target="_blank" class="dashboard-tool d-flex flex-column align-items-center justify-content-center">
                    <img src="@Url.Content($"~/images/tools-icons/{tool.Icon}")" alt="@tool.Name" class="mb-2" width="70" height="70" />
                    <div class="fw-bold mt-2 text-center">@tool.Name</div>
                </a>
            </div>
        }

    </div>
</div>

<style>
    /* Page spacing so content never touches layout borders */
    .tools-container {
        padding-top: 2rem;
        padding-bottom: 3rem;
    }

    .tools-row {
        margin-bottom: 2rem;
    }

    .dashboard-tool {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1.25rem;
        border: 1px solid #a68023;
        border-radius: 12px;
        transition: transform 0.2s, box-shadow 0.2s;
        text-decoration: none;
        color: #000;
        font-weight: 600;
    }

    .dashboard-tool:hover {
        transform: translateY(-5px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
        color: #a68023;
    }

    .dashboard-tool img {
        margin-bottom: 0.5rem;
    }
</style>
