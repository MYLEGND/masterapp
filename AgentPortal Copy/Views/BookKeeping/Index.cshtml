<script>
function bkGoMonth(val){
    const url = new URL(window.location.href);
    url.searchParams.set('monthKey', val);
    url.searchParams.set('clientUserId', '@clientUserId');
    window.location.href = url.toString();
}

/* ===== Edit Entry Modal ===== */
function bkOpenEdit(btn){
    const modal = document.getElementById('bkEditModal');
    document.getElementById('editId').value = btn.dataset.id || '';
    document.getElementById('editType').value = btn.dataset.type || '0';
    document.getElementById('editDate').value = btn.dataset.date || '';
    document.getElementById('editAmount').value = btn.dataset.amount || '';
    document.getElementById('editCategory').value = btn.dataset.category || '0';
    document.getElementById('editNotes').value = (btn.dataset.notes || '').replaceAll('&quot;','"');
    modal.classList.add('show');
}
function bkCloseEdit(){
    document.getElementById('bkEditModal').classList.remove('show');
}

/* ===== Edit Recurring Modal (NEW) ===== */
function bkOpenEditRecurring(btn){
    const modal = document.getElementById('bkEditRecurringModal');
    document.getElementById('recEditId').value = btn.dataset.id || '';
    document.getElementById('recEditType').value = btn.dataset.type || '0';
    document.getElementById('recEditFrequency').value = btn.dataset.frequency || '0';
    document.getElementById('recEditName').value = (btn.dataset.name || '').replaceAll('&quot;','"');
    document.getElementById('recEditAmount').value = btn.dataset.amount || '';
    document.getElementById('recEditCategory').value = btn.dataset.category || '0';
    document.getElementById('recEditStart').value = btn.dataset.start || '';
    document.getElementById('recEditNotes').value = (btn.dataset.notes || '').replaceAll('&quot;','"');
    document.getElementById('recEditIsActive').value = (btn.dataset.active === 'true') ? 'true' : 'false';
    document.getElementById('recEditNextDueDate').value = btn.dataset.nextduedate || '';
    modal.classList.add('show');
}
function bkCloseEditRecurring(){
    document.getElementById('bkEditRecurringModal').classList.remove('show');
}

/* ===== Kebab menus (fixed popper so it never clips) ===== */
let bkOpenMenu = null;

function bkCloseOpenMenu(){
    if(!bkOpenMenu) return;
    bkOpenMenu.classList.remove('show');
    bkOpenMenu.style.top = '';
    bkOpenMenu.style.left = '';
    bkOpenMenu = null;
}

function bkPositionMenu(button, menu){
    menu.classList.add('show');

    const r = button.getBoundingClientRect();
    const mw = menu.offsetWidth || 200;
    const mh = menu.offsetHeight || 120;

    const pad = 8;
    let top = r.bottom + 8;
    let left = r.right - mw;

    const vw = window.innerWidth;
    const vh = window.innerHeight;

    if(left < pad) left = pad;
    if(left + mw > vw - pad) left = vw - mw - pad;

    if(top + mh > vh - pad) top = Math.max(pad, r.top - mh - 8);

    menu.style.top = top + 'px';
    menu.style.left = left + 'px';
}

function bkToggleKebab(btn){
    const wrap = btn.closest('[data-kebab]');
    if(!wrap) return;

    const menu = wrap.querySelector('.kebab-menu');
    if(!menu) return;

    if(bkOpenMenu === menu){
        bkCloseOpenMenu();
        return;
    }

    bkCloseOpenMenu();
    bkOpenMenu = menu;
    bkPositionMenu(btn, menu);
}

/* Left table edit */
function bkKebabEdit(editButton){
    bkCloseOpenMenu();
    bkOpenEdit(editButton);
}

/* Right table edit (recurring) */
function bkKebabEditRecurring(editButton){
    bkCloseOpenMenu();
    bkOpenEditRecurring(editButton);
}

/* Close on outside click */
document.addEventListener('click', function(e){
    const modal1 = document.getElementById('bkEditModal');
    if(modal1.classList.contains('show') && e.target === modal1) bkCloseEdit();

    const modal2 = document.getElementById('bkEditRecurringModal');
    if(modal2.classList.contains('show') && e.target === modal2) bkCloseEditRecurring();

    if(bkOpenMenu && !e.target.closest('.kebab-menu') && !e.target.closest('.kebab-btn')){
        bkCloseOpenMenu();
    }
});

/* Escape closes everything */
document.addEventListener('keydown', function(e){
    if(e.key === 'Escape'){
        bkCloseEdit();
        bkCloseEditRecurring();
        bkCloseOpenMenu();
    }
});

/* If user scrolls/resizes, close open menu (keeps it readable) */
window.addEventListener('resize', function(){
    if(!bkOpenMenu) return;
    bkCloseOpenMenu();
});
window.addEventListener('scroll', function(){
    if(!bkOpenMenu) return;
    bkCloseOpenMenu();
}, true);
</script>
