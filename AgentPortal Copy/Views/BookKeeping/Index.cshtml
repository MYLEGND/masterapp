@model AgentPortal.Models.BookKeepingIndexVm
@using Domain.Entities
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Book Keeping";

    var m = Model ?? new AgentPortal.Models.BookKeepingIndexVm();
    var clientUserId = ((string)(ViewBag.ClientUserId ?? "")).Trim();
    var workspaceName = ((string)(ViewBag.ClientDisplayName ?? "")).Trim();
    var isAgentWorkspace = string.IsNullOrWhiteSpace(clientUserId);
    var hasClientContext = !string.IsNullOrWhiteSpace(clientUserId);

    Layout = hasClientContext
        ? "~/Views/Shared/_ClientWorkspaceLayout.cshtml"
        : "~/Views/Shared/_Layout.cshtml";

    if (string.IsNullOrWhiteSpace(workspaceName))
    {
        workspaceName = isAgentWorkspace ? "My Book Keeping" : "Client Workspace";
    }

    string FriendlyEnum(string? t)
        => System.Text.RegularExpressions.Regex.Replace(t ?? "", "(?<=[a-z])(?=[A-Z])", " ");

    var categoryItems = Html.GetEnumSelectList<BookkeepingCategory>()
        .Select(i => new SelectListItem { Value = i.Value, Text = FriendlyEnum(i.Text) })
        .ToList();

    var entryTypeItems = Html.GetEnumSelectList<BookkeepingEntryType>().ToList();
    var freqItems = Html.GetEnumSelectList<RecurrenceFrequency>().ToList();

    var monthItems = m.MonthOptions ?? new List<SelectListItem>();
    var selectedMonthKey = m.SelectedMonthKey ?? "";

    // KPIs
    var incomeYtd = m.IncomeYtd;
    var expensesYtd = m.ExpensesYtd;
    var netYtd = m.NetYtd;
    var taxReserve = m.TaxReserve;

    // VM-provided recurring totals (may be 0 if backend not populating)
    var recurringMonthlyIncome = m.RecurringMonthlyIncomeTotal;
    var recurringMonthlyExpense = m.RecurringMonthlyExpensesTotal;
    var recurringMonthlyNet = m.RecurringMonthlyNet;

    // use selected month list; fallback to Recent if needed
    var recent = (m.RecentForMonth != null && m.RecentForMonth.Any())
        ? m.RecentForMonth
        : (m.Recent ?? new List<BookkeepingEntry>());
}

<style>
:root{
    --gold:#a68023;
    --ink:#0f0f12;
    --muted: rgba(15,15,18,.62);
    --border: rgba(15,15,18,.12);
    --card:#fff;
    --shadow: 0 18px 46px rgba(0,0,0,.10);
    --shadowSoft: 0 12px 28px rgba(0,0,0,.08);
    --radius: 18px;
    --good:#1f7a4a;
    --bad:#b42318;

    --ctlPadY: .56rem;
    --ctlPadX: .78rem;
    --ctlRadius: 12px;
    --ctlFont: .95rem;
}

/* ===== WIDTH TUNING (surgical) =====
   Goal: ~1 inch padding on left/right, card as wide as possible without touching edges.
   1 inch ≈ 96px, so we use clamp with a min for small screens.
*/
.bk-wrap{
    max-width: none;                 /* was 1180px */
    width: 100%;
    padding: 22px clamp(16px, 5vw, 32px) 40px;  /* ~1 inch on large screens */
    margin: 0 auto;
}

/* Keep the main card wide */
.bk-card{
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;

    /* 🔥 actually gets bigger on wide screens */
    max-width: none;
    margin: 0 auto;
    width: 100%;
}
.bk-card::before{ content:""; display:block; height: 3px; background: linear-gradient(90deg, transparent, var(--gold), transparent); opacity: .95; }

.bk-head{
    padding: 16px 18px 12px;
    border-bottom: 1px solid rgba(0,0,0,.08);
    display:flex; align-items:flex-end; justify-content:space-between; gap: 14px; flex-wrap: wrap;
    background: rgba(166,128,35,.04);
}
.bk-title{ margin:0; font-size: 1.9rem; font-weight: 950; letter-spacing: .2px; line-height: 1.1; }
.bk-sub{ margin: 6px 0 0; color: var(--muted); font-weight: 650; font-size: .98rem; }
.bk-body{ padding: 16px; }

/* Let inner panels breathe a touch more now that the container is wider */
.grid{ display:grid; grid-template-columns: 1.25fr .75fr; gap: 14px; }
@@media (max-width: 980px){ .grid{ grid-template-columns: 1fr; } }

/* KPIs (KEEP sizing) */
.kpis{ display:grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
@@media (max-width: 980px){ .kpis{ grid-template-columns: repeat(2, minmax(0, 1fr)); } }
@@media (max-width: 520px){ .kpis{ grid-template-columns: 1fr; } }

.kpi{
    border: 1px solid rgba(166,128,35,.22);
    background: linear-gradient(180deg, rgba(166,128,35,.10), rgba(255,255,255,.96));
    border-radius: 18px;
    box-shadow: var(--shadowSoft);
    padding: 14px;
}
.kpi .label{ color: var(--muted); font-weight: 800; letter-spacing: .2px; font-size: .90rem; }
.kpi .value{ font-weight: 950; font-size: 1.35rem; letter-spacing: .2px; margin-top: 6px; }
.kpi .hint{ margin-top: 4px; color: rgba(0,0,0,.55); font-weight: 650; font-size: .86rem; }

.kpi-income .value{ color: var(--good); }
.kpi-expenses .value{ color: var(--bad); }
.kpi-profit-positive .value{ color: var(--good); }
.kpi-profit-negative .value{ color: var(--bad); }
.kpi-tax .value{ color: var(--gold); }

/* Panels */
.panel{ border: 1px solid rgba(0,0,0,.12); border-radius: 18px; background:#fff; box-shadow: var(--shadowSoft); overflow:hidden; }
.panel-h{
    padding: 12px 14px;
    border-bottom: 1px solid rgba(0,0,0,.08);
    display:flex; align-items:center; justify-content:space-between; gap: 10px;
    background: rgba(166,128,35,.04);
}
.panel-title{ margin:0; font-weight: 950; letter-spacing: .2px; color: var(--ink); }
.panel-b{ padding: 12px 14px; }

.pill{ border-radius: 999px; padding: 6px 12px; font-weight: 950; border: 1px solid rgba(166,128,35,.25); background: rgba(166,128,35,.12); color: var(--gold); white-space: nowrap; }

/* Compact forms */
.form-grid{ display:grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 10px; }
@@media (max-width: 520px){ .form-grid{ grid-template-columns: 1fr; } }

.field .lbl{ font-weight: 900; color: var(--ink); letter-spacing: .2px; margin-bottom: 6px; }

.input, .select{
    width:100%;
    border: 1px solid rgba(0,0,0,.14);
    border-radius: var(--ctlRadius);
    padding: var(--ctlPadY) var(--ctlPadX);
    font-weight: 650;
    background:#fff;
    font-size: var(--ctlFont);
    line-height: 1.15;
    transition: box-shadow .14s ease, border-color .14s ease;
}
.input:focus, .select:focus{ outline:none; border-color: rgba(166,128,35,.75); box-shadow: 0 0 0 .18rem rgba(166,128,35,.14); }
input[type="date"].input{ padding-top: .50rem; padding-bottom: .50rem; }

.actions{ display:flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; }

.btnx{
    display:inline-flex; align-items:center; justify-content:center; gap: 10px;
    padding: 8px 12px;
    border-radius: 12px;
    border: 1px solid var(--border);
    background:#fff;
    color: var(--ink);
    font-weight: 900;
    text-decoration:none;
    cursor:pointer;
    box-shadow: 0 10px 20px rgba(0,0,0,.045);
    transition: transform .14s ease, box-shadow .14s ease, border-color .14s ease;
    white-space: nowrap;
}
.btnx:hover{ transform: translateY(-1px); border-color: rgba(166,128,35,.55); box-shadow: 0 14px 28px rgba(0,0,0,.075); }
.btn-solid{ border: 2px solid var(--gold); background: var(--gold); color:#fff; box-shadow: 0 14px 30px rgba(166,128,35,.18); }
.btn-solid:hover{ background: #a68023; border-color: #a68023; }
.btn-danger{ border: 1px solid rgba(180,35,24,.25); background: rgba(180,35,24,.08); color: #b42318; }
.btn-danger:hover{ border-color: rgba(180,35,24,.55); }
.btn-edit{ border: 1px solid rgba(166,128,35,.30); background: rgba(166,128,35,.08); color: var(--gold); }
.btn-edit:hover{ border-color: rgba(166,128,35,.65); }

.hr{ height: 1px; background: rgba(166,128,35,.22); margin: 12px 0; border-radius: 999px; }

.table{
    width:100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: 14px;
    border: 1px solid rgba(0,0,0,.10);
    overflow: visible;
}
.table th{ text-align:left; font-weight: 950; padding: 9px 12px; border-bottom: 1px solid rgba(0,0,0,.08); background: rgba(166,128,35,.06); }
.table td{ padding: 9px 12px; border-bottom: 1px solid rgba(0,0,0,.06); font-weight: 650; color: rgba(0,0,0,.74); vertical-align: middle; }
.table tr:last-child td{ border-bottom: 0; }

.mono{ font-variant-numeric: tabular-nums; }
.right{ text-align:right; }
.small{ font-size: .90rem; color: var(--muted); font-weight: 650; }

.amt-income{ color: var(--good); font-weight:950; }
.amt-expense{ color: var(--bad); font-weight:950; }

/* ✅ GLOBAL MONEY COLOR CODING (ALL AREAS) */
.money-inc{ color: var(--good) !important; font-weight: 950; }
.money-exp{ color: var(--bad) !important; font-weight: 950; }

.recurring-kpi{
    margin-top: 14px;
    padding: 14px;
    border-radius: 16px;
    display:flex;
    flex-direction:column;
    gap:6px;
    border: 1px solid rgba(166,128,35,.22);
    background: linear-gradient(180deg, rgba(166,128,35,.08), rgba(255,255,255,.98));
    box-shadow: var(--shadowSoft);
}

.recent-head{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 10px;
    flex-wrap: wrap;
    margin:0 0 10px;
}
.month-select{
    min-width: 180px;
    max-width: 240px;
}
@@media (max-width: 520px){
    .month-select{ width:100%; max-width: none; }
}

/* ===== Kebab menu (fixed popper to avoid clipping) ===== */
.kebab{ position: relative; display:inline-flex; justify-content:flex-end; }

.kebab-btn{
    width: 38px;
    height: 34px;
    border-radius: 12px;
    border: 1px solid rgba(0,0,0,.14);
    background:#fff;
    cursor:pointer;
    font-weight: 950;
    line-height: 0;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    box-shadow: 0 10px 20px rgba(0,0,0,.04);
    transition: transform .14s ease, box-shadow .14s ease, border-color .14s ease;
}
.kebab-btn:hover{
    transform: translateY(-1px);
    border-color: rgba(166,128,35,.55);
    box-shadow: 0 14px 28px rgba(0,0,0,.07);
}
.kebab-dots{ font-size: 18px; color: rgba(0,0,0,.78); transform: translateY(-1px); }

.kebab-menu{
    position: fixed;
    min-width: 180px;
    max-width: 240px;
    background:#fff;
    border: 1px solid rgba(0,0,0,.12);
    border-radius: 14px;
    box-shadow: 0 22px 60px rgba(0,0,0,.18);
    padding: 6px;
    display:none;
    z-index: 99999;
}
.kebab-menu.show{ display:block; }

.kebab-item{
    width:100%;
    text-align:left;
    display:flex;
    align-items:center;
    gap: 10px;
    padding: 10px 10px;
    border-radius: 12px;
    border: 0;
    background: transparent;
    cursor:pointer;
    font-weight: 900;
    color: var(--ink);
    white-space: nowrap;
}
.kebab-item:hover{ background: rgba(166,128,35,.10); }
.kebab-item.danger{ color: #b42318; }
.kebab-item.danger:hover{ background: rgba(180,35,24,.08); }
.kebab-menu form{ margin:0; }

/* ===== Modal ===== */
.modalx{
    position: fixed;
    inset: 0;
    display:none;
    align-items:center;
    justify-content:center;
    padding: 16px;
    background: rgba(0,0,0,.45);
    z-index: 9999;
}
.modalx.show{ display:flex; }
.modalx-card{
    width: 100%;
    max-width: 560px;
    background:#fff;
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.12);
    box-shadow: 0 22px 70px rgba(0,0,0,.22);
    overflow:hidden;
}
.modalx-h{
    padding: 12px 14px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 10px;
    border-bottom: 1px solid rgba(0,0,0,.08);
    background: rgba(166,128,35,.04);
}
.modalx-title{ margin:0; font-weight: 950; letter-spacing: .2px; }
.modalx-b{ padding: 14px; }
.modalx-close{
    border: 1px solid rgba(0,0,0,.14);
    background:#fff;
    border-radius: 12px;
    padding: 8px 10px;
    font-weight: 900;
    cursor:pointer;
}
</style>

<div class="bk-wrap">
    <div class="bk-card">
        <div class="bk-head">
            <div>
                <h2 class="bk-title">Book Keeping</h2>
                <p class="bk-sub">
                    @(isAgentWorkspace
                        ? $"{workspaceName} tracks your private agent bookkeeping only."
                        : $"{workspaceName} tracks the shared client bookkeeping record.")
                </p>
            </div>
            <span class="pill">Year-to-Date</span>
        </div>

        <div class="bk-body">

            <!-- KPI Row (YTD) -->
            <div class="kpis">
                <div class="kpi kpi-income">
                    <div class="label">Income (YTD)</div>
                    <div class="value mono money-inc">@incomeYtd.ToString("C")</div>
                    <div class="hint">All income entries this year</div>
                </div>

                <div class="kpi kpi-expenses">
                    <div class="label">Expenses (YTD)</div>
                    <div class="value mono money-exp">@expensesYtd.ToString("C")</div>
                    <div class="hint">Includes recurring occurrences</div>
                </div>

                <div class="kpi @(netYtd >= 0 ? "kpi-profit-positive" : "kpi-profit-negative")">
                    <div class="label">Net Profit (YTD)</div>
                    <div class="value mono @(netYtd >= 0 ? "money-inc" : "money-exp")">@netYtd.ToString("C")</div>
                    <div class="hint">Income minus expenses (all-in)</div>
                </div>

                <div class="kpi kpi-tax">
                    <div class="label">Tax Reserve (YTD)</div>
                    <div class="value mono">@taxReserve.ToString("C")</div>
                    <div class="hint">
                        Fed <span class="mono money-exp">@m.FederalIncomeTaxYtd.ToString("C")</span> •
                        SE <span class="mono money-exp">@m.SelfEmploymentTaxYtd.ToString("C")</span> •
                        AZ <span class="mono money-exp">@m.ArizonaTaxYtd.ToString("C")</span> •
                        Eff <span class="mono">@((m.EffectiveTaxRateYtd * 100m).ToString("0.0"))%</span>
                    </div>
                </div>
            </div>

            <div class="hr"></div>

            <div class="grid">

                <!-- Left: Quick Add + Recent Activity -->
                <div class="panel">
                    <div class="panel-h">
                        <h3 class="panel-title">Quick Add</h3>
                        <span class="pill">Quick entry</span>
                    </div>

                    <div class="panel-b">
                        <form asp-controller="BookKeeping" asp-action="AddEntry" method="post" novalidate>
                            <input type="hidden" name="clientUserId" value="@clientUserId" />
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="monthKey" value="@selectedMonthKey" />
                            <div asp-validation-summary="All" class="small" style="color:#b42318; font-weight:900; margin-bottom:10px;"></div>

                            <div class="form-grid">
                                <div class="field">
                                    <div class="lbl">Type</div>
                                    <select class="select" asp-for="QuickAdd.Type" asp-items="entryTypeItems"></select>
                                </div>

                                <div class="field">
                                    <div class="lbl">Date</div>
                                    <input class="input" type="date" asp-for="QuickAdd.EntryDate" />
                                </div>

                                <div class="field">
                                    <div class="lbl">Amount</div>
                                    <input class="input" asp-for="QuickAdd.Amount" type="text" inputmode="decimal" data-number-format="true" placeholder="0.00" />
                                </div>

                                <div class="field">
                                    <div class="lbl">Category</div>
                                    <select class="select" asp-for="QuickAdd.Category" asp-items="categoryItems"></select>
                                </div>

                                <div class="field" style="grid-column:1/-1;">
                                    <div class="lbl">Description / Notes</div>
                                    <input class="input" asp-for="QuickAdd.Notes" type="text" placeholder="What was this for?" />
                                    <div class="small" style="margin-top:6px;">Keep it short. Clarity beats clutter.</div>
                                </div>
                            </div>

                            <div class="actions">
                                <button class="btnx btn-solid" type="submit">Save Entry</button>
                                <a class="btnx" asp-controller="BookKeeping" asp-action="Reports" asp-route-clientUserId="@clientUserId">View Reports</a>
                            </div>
                        </form>

                        <div class="hr"></div>

                        <div class="recent-head">
                            <h3 class="panel-title" style="margin:0;">Recent Activity</h3>

                            <select class="select month-select"
                                    id="monthSelect"
                                    aria-label="Select month"
                                    onchange="bkGoMonth(this.value)">
                                @foreach (var opt in monthItems)
                                {
                                    <option value="@opt.Value" selected="@(opt.Selected ? "selected" : null)">@opt.Text</option>
                                }
                            </select>
                        </div>

                        <table class="table">
                            <thead>
                                <tr>
                                    <th style="width:110px;">Date</th>
                                    <th>Item</th>
                                    <th style="width:160px;">Category</th>
                                    <th class="right" style="width:160px;">Amount</th>
                                    <th class="right" style="width:72px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recent == null || !recent.Any())
                                {
                                    <tr>
                                        <td class="mono">—</td>
                                        <td>—</td>
                                        <td>—</td>
                                        <td class="right mono">—</td>
                                        <td></td>
                                    </tr>
                                }
                                else
                                {
                                    foreach (var x in recent)
                                    {
                                        var isExpense = (x.Type == BookkeepingEntryType.Expense);
                                        var signed = isExpense ? -x.Amount : x.Amount;

                                        <tr>
                                            <td class="mono">@x.EntryDate.ToString("MM/dd/yyyy")</td>
                                            <td>@(string.IsNullOrWhiteSpace(x.Notes) ? x.Type.ToString() : x.Notes)</td>
                                            <td>@x.Category</td>
                                            <td class="right mono @(isExpense ? "money-exp" : "money-inc")">@signed.ToString("C")</td>
                                            <td class="right">
                                                <div class="kebab" data-kebab>
                                                    <button type="button"
                                                            class="kebab-btn"
                                                            aria-label="Row actions"
                                                            onclick="bkToggleKebab(this)">
                                                        <span class="kebab-dots">⋮</span>
                                                    </button>

                                                    <div class="kebab-menu" role="menu" aria-label="Actions">
                                                        <button type="button"
                                                                class="kebab-item"
                                                                role="menuitem"
                                                                onclick="bkKebabEdit(this)"
                                                                data-id="@x.Id"
                                                                data-type="@((int)x.Type)"
                                                                data-date="@x.EntryDate.ToString("yyyy-MM-dd")"
                                                                data-amount="@x.Amount.ToString("0.##")"
                                                                data-category="@((int)x.Category)"
                                                                data-notes="@((x.Notes ?? "").Replace("\"","&quot;"))">
                                                            Edit
                                                        </button>

<form asp-controller="BookKeeping" asp-action="DeleteEntry" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="clientUserId" value="@clientUserId" />
    <input type="hidden" name="monthKey" value="@selectedMonthKey" />
    <input type="hidden" name="id" value="@x.Id" />
    <button class="kebab-item danger" type="submit" role="menuitem">
        Delete
    </button>
</form>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>

                    </div>
                </div>

                <!-- Right: Recurring -->
                <div class="panel">
                    <div class="panel-h">
                        <h3 class="panel-title">Recurring</h3>
                        <span class="pill">Sustainable</span>
                    </div>

                    <div class="panel-b">
                        <div class="small" style="margin-bottom:12px;">
                            This is where businesses quietly bleed — and where smart systems win.
                        </div>

<form asp-controller="BookKeeping" asp-action="AddRecurring" method="post" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" name="clientUserId" value="@clientUserId" />
                            <div asp-validation-summary="All" class="small" style="color:#b42318; font-weight:900; margin-bottom:10px;"></div>

                            <div class="form-grid">
                                <div class="field">
                                    <div class="lbl">Type</div>
                                    <select class="select" asp-for="AddRecurring.Type" asp-items="entryTypeItems"></select>
                                </div>

                                <div class="field">
                                    <div class="lbl">Frequency</div>
                                    <select class="select" asp-for="AddRecurring.Frequency" asp-items="freqItems"></select>
                                </div>

                                <div class="field" style="grid-column:1/-1;">
                                    <div class="lbl">Name</div>
                                    <input class="input" asp-for="AddRecurring.Name" placeholder="CRM, Rent, Phone, Retainer, etc." />
                                </div>

                                <div class="field">
                                    <div class="lbl">Amount</div>
                                    <input class="input" asp-for="AddRecurring.Amount" type="text" inputmode="decimal" data-number-format="true" placeholder="0.00" />
                                </div>

                                <div class="field">
                                    <div class="lbl">Category</div>
                                    <select class="select" asp-for="AddRecurring.Category" asp-items="categoryItems"></select>
                                </div>

                                <div class="field">
                                    <div class="lbl">Start Date</div>
                                    <input class="input" type="date" asp-for="AddRecurring.StartDate" />
                                </div>

                                <div class="field" style="grid-column:1/-1;">
                                    <div class="lbl">Notes</div>
                                    <input class="input" asp-for="AddRecurring.Notes" placeholder="Optional" />
                                </div>
                            </div>

                            <div class="actions" style="margin-top:12px;">
                                <button class="btnx btn-solid" type="submit">Add Recurring</button>
                                <a class="btnx" asp-controller="BookKeeping" asp-action="Reports" asp-route-clientUserId="@clientUserId">View Reports</a>
                            </div>
                        </form>

                        <div class="recurring-kpi">
                            <div class="label">Monthly Recurring Summary</div>
                            <div class="small">Income: <span class="mono money-inc">@recurringMonthlyIncome.ToString("C")</span></div>
                            <div class="small">Expenses: <span class="mono money-exp">@recurringMonthlyExpense.ToString("C")</span></div>
                            <div class="small">Net: <span class="mono @(recurringMonthlyNet >= 0 ? "money-inc" : "money-exp")">@recurringMonthlyNet.ToString("C")</span></div>
                        </div>

                        <div class="hr"></div>

                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th style="width:130px;">Type</th>
                                    <th class="right">Monthly</th>
                                    <th class="right" style="width:72px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (m.Recurring == null || !m.Recurring.Any())
                                {
                                    <tr>
                                        <td>—</td>
                                        <td>—</td>
                                        <td class="right mono">—</td>
