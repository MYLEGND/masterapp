@using System
@using System.Linq
@using System.Collections.Generic
@using Microsoft.AspNetCore.Html
@model AgentPortal.Models.AdvancedMarketsPageViewModel

@functions{
    string ShortCurrency(double value)
    {
        var abs = Math.Abs(value);
        if (abs < 1_000_000) return value.ToString("C0");
        if (abs < 1_000_000_000) return $"${value / 1_000_000d:0.##}M";
        if (abs < 1_000_000_000_000) return $"${value / 1_000_000_000d:0.##}B";
        return $"${value / 1_000_000_000_000d:0.##}T";
    }

    IHtmlContent MoneySpan(double value)
    {
        var full = value.ToString("C0");
        var shortForm = ShortCurrency(value);
        return new HtmlString($"<span class=\"num\" title=\"{full}\">{shortForm}</span>");
    }

    IHtmlContent NumberSpan(double value, string format)
    {
        string rendered = format switch
        {
            "percent" => value.ToString("P1"),
            "integer" => ((int)Math.Round(value)).ToString("N0"),
            "year" => $"Year {(int)Math.Round(value)}",
            "number" => value.ToString("N0"),
            _ => ShortCurrency(value)
        };
        string full = format switch
        {
            "percent" => value.ToString("P3"),
            "integer" => ((int)Math.Round(value)).ToString("N0"),
            "year" => $"Year {(int)Math.Round(value)}",
            "number" => value.ToString("N0"),
            _ => value.ToString("C0")
        };
        return new HtmlString($"<span class=\"num\" title=\"{full}\">{rendered}</span>");
    }
}
@{
    var rMaybe = Model?.Result;
    var meta = new Dictionary<AgentPortal.Models.StrategyKind,(string title,string tagline)>{
        {AgentPortal.Models.StrategyKind.DefinedBenefit,(AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.DefinedBenefit),"Large deductible retirement funding (illustrative)")},
        {AgentPortal.Models.StrategyKind.CashBalance,(AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.CashBalance),"Hybrid DB with pay/interest credits (illustrative)")},
        {AgentPortal.Models.StrategyKind.ComboDb401k,(AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.ComboDb401k),"Layered DB with 401(k)/profit sharing (illustrative)")},
        {AgentPortal.Models.StrategyKind.ExecutiveBonus162,(AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.ExecutiveBonus162),"Executive benefit using taxable bonus + policy (illustrative)")},
        {AgentPortal.Models.StrategyKind.DeferredComp,(AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.DeferredComp),"Nonqualified deferral — employer credit risk (illustrative)")},
        {AgentPortal.Models.StrategyKind.SplitDollar,(AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.SplitDollar),"Shared premium/collateral concept — heavy legal/tax review") },
        {AgentPortal.Models.StrategyKind.TaxDiversification,(AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.TaxDiversification),"Balance qualified / taxable / tax-free buckets (illustrative)")},
    };
    var selectedStrategy = Model?.Strategy?.Selected;
    var strategyLabel = selectedStrategy.HasValue ? AgentPortal.Models.AdvancedMarketsLabels.Display(selectedStrategy.Value) : "Strategy";
    var strat = selectedStrategy.HasValue && meta.TryGetValue(selectedStrategy.Value, out var matched)
        ? matched
        : meta.First().Value;
    var accumulationLabel = selectedStrategy switch
    {
        AgentPortal.Models.StrategyKind.DefinedBenefit => "Modeled projected accumulation (DB + current + outside)",
        AgentPortal.Models.StrategyKind.CashBalance => "Modeled projected accumulation (CB + current + outside)",
        AgentPortal.Models.StrategyKind.ComboDb401k => "Modeled projected accumulation (combo + current + outside)",
        AgentPortal.Models.StrategyKind.SplitDollar => "Modeled projected accumulation (split-dollar access value + current + outside)",
        AgentPortal.Models.StrategyKind.TaxDiversification => "Modeled projected accumulation (qualified + taxable + tax-free)",
        _ => "Modeled projected accumulation (strategy + current + outside)"
    };
    var legacyLabel = selectedStrategy switch
    {
        AgentPortal.Models.StrategyKind.DeferredComp => "Deferred balance at payout start (before distributions)",
        AgentPortal.Models.StrategyKind.SplitDollar => "Policy access value at exit (not death benefit)",
        AgentPortal.Models.StrategyKind.DefinedBenefit => "Modeled remaining value (illustrative, not an actuarial DB death benefit)",
        AgentPortal.Models.StrategyKind.TaxDiversification => "After-tax bucket value at retirement start (illustrative)",
        _ => "Estimated Legacy Value"
    };
}
@if (rMaybe is not { } r)
{
    <div class="placeholder">Enter inputs and click Calculate to see results.</div>
}
else
{
    var res = r; // non-null for the remainder of this block
<div class="result-shell">
    <div class="panel">
        <div class="panel-head">
            <h3>@strat.title</h3>
            <p>@strat.tagline</p>
        </div>
    </div>
    <div class="summary-grid">
        <div class="summary-card">
            <div class="label">@res.DeductionLabel</div>
            <div class="value">@MoneySpan(res.EstimatedDeduction)</div>
        </div>
        <div class="summary-card">
            <div class="label">Estimated first-year tax savings (illustrative) - Federal</div>
            <div class="value">@MoneySpan(res.FederalTaxSavings)</div>
        </div>
        <div class="summary-card">
            <div class="label">Estimated first-year tax savings (illustrative) - State</div>
            <div class="value">@MoneySpan(res.StateTaxSavings)</div>
        </div>
        <div class="summary-card">
            <div class="label">Modeled net annual cash impact</div>
            <div class="value">@MoneySpan(res.NetAnnualCost)</div>
        </div>
        <div class="summary-card">
            <div class="label">@accumulationLabel</div>
            <div class="value">@MoneySpan(res.ProjectedRetirementValue)</div>
        </div>
        <div class="summary-card">
            <div class="label">Modeled retirement draw (not actuarial pension estimate)</div>
            <div class="value">@MoneySpan(res.ProjectedRetirementIncome)</div>
        </div>
        <div class="summary-card">
            <div class="label">@legacyLabel</div>
            <div class="value">@MoneySpan(res.EstimatedLegacyValue)</div>
        </div>
        <div class="summary-card">
            <div class="label">Estimated staff cost (not discrimination-tested)</div>
            <div class="value">@MoneySpan(res.EmployeeCostImpact)</div>
        </div>
    </div>

    @if (res?.Comparison?.Count > 0)
    {
        <div class="panel">
            <div class="panel-head">
                <h3>Before vs After</h3>
                <p>Current plan vs proposed strategy</p>
            </div>
            <table class="cmp-table">
                <thead>
                    <tr>
                        <th>Metric</th>
                        <th>Current</th>
                        <th>Proposed</th>
                        <th>Net Impact <span class="info-dot" tabindex="0" data-tooltip="Net impact shows proposed minus current values, highlighting the estimated improvement or cost change from the strategy.">i</span></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var row in res.Comparison)
                {
                    <tr>
                        <td>@row.Label <span class="info-dot" tabindex="0" data-tooltip="This line compares the client’s current path to the proposed strategy for this metric.">i</span></td>
                        <td>@MoneySpan(row.Current)</td>
                        <td>@MoneySpan(row.Proposed)</td>
                        <td class="delta">@MoneySpan(row.Difference)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

        <div class="panel">
            <div class="panel-head">
            <h3>Strategy Highlights <span class="info-dot" tabindex="0" data-tooltip="Key takeaways: contribution, tax effect, and estimated cash impact for this illustration.">i</span></h3>
            <p>@strategyLabel</p>
        </div>
        <ul class="bullets">
            <li>@(res?.DeductionLabel ?? "Deduction"): @(res != null ? MoneySpan(res.EstimatedDeduction) : Html.Raw("—")) <span class="info-dot" tabindex="0" data-tooltip="Estimated deduction for this design; actual deductibility depends on final plan design, testing, and professional review.">i</span></li>
            <li>Estimated after-tax annual cost: @(res != null ? MoneySpan(res.NetAnnualCost) : Html.Raw("—")) <span class="info-dot" tabindex="0" data-tooltip="Contribution minus estimated tax savings plus modeled admin and employee costs—an estimate of real cash impact.">i</span></li>
            <li>Projected value at retirement: @(res != null ? MoneySpan(res.ProjectedRetirementValue) : Html.Raw("—")) <span class="info-dot" tabindex="0" data-tooltip="Illustrated accumulation using the assumed growth rate and savings horizon; values are hypothetical and market-dependent.">i</span></li>
            <li>Projected retirement income (@(res?.IncomeMethod ?? "modeled distribution")): @(res != null ? MoneySpan(res.ProjectedRetirementIncome) : Html.Raw("—")) <span class="info-dot" tabindex="0" data-tooltip="Estimated sustainable income derived from the projected value and distribution rate; not guaranteed.">i</span></li>
        </ul>
    </div>

    @{ var metrics = res?.StrategyMetrics ?? Enumerable.Empty<AgentPortal.Models.MetricVm>(); }
    @if (metrics.Any())
    {
        <div class="panel">
            <div class="panel-head">
                <h3>@strategyLabel details</h3>
                <p>Strategy-specific drivers</p>
            </div>
            <table class="cmp-table">
                <thead><tr><th>Item</th><th>Value</th><th>Note</th></tr></thead>
                <tbody>
                @foreach (var m in metrics)
                {
                    <tr>
                        <td>@m.Label</td>
                        <td>
                            @{
                                string fmt = m.Format?.ToLowerInvariant() ?? "currency";
                            }
                            @NumberSpan(m.Value, fmt)
                        </td>
                        <td>@m.Note</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <div class="panel">
        <div class="panel-head">
            <h3>Suitability / Red Flags</h3>
            <p>Auto-generated guidance — not compliance approval</p>
        </div>
        <ul class="flags">
            @foreach (var flag in (r?.Suitability ?? new List<AgentPortal.Models.SuitabilityFlagVm>()))
            {
                <li class="@flag.Severity">@flag.Message</li>
            }
        </ul>
    </div>

    <div class="panel">
        <div class="panel-head">
            <h3>Talking Points</h3>
            <p>Client-friendly explanation</p>
        </div>
        <ul class="bullets">
            @foreach (var tp in (r?.Summary?.TalkingPoints ?? new List<string>()))
            {
                <li>@tp</li>
            }
        </ul>
    </div>

    <div class="panel">
        <div class="panel-head">
            <h3>Assumptions</h3>
            <p>Key illustration assumptions</p>
        </div>
        <ul class="bullets">
            @foreach (var a in (r?.Summary?.Assumptions ?? new List<string>()))
            {
                <li>@a</li>
            }
        </ul>
    </div>

    @if (r?.Charts?.Count > 0)
    {
        <div class="panel">
            <div class="panel-head">
                <h3>Charts</h3>
                <p>Quick visual of tax savings and growth</p>
            </div>
            <div class="chart-grid chart-grid-structured">
                @if (r.Charts.Count >= 1)
                {
                    <div class="mini-chart" data-series='@System.Text.Json.JsonSerializer.Serialize(r.Charts[0])'>
                        <div class="chart-title">@r.Charts[0].Name</div>
                        <div class="bars"></div>
                    </div>
                }
                @if (r.Charts.Count >= 2)
                {
                    <div class="mini-chart" data-series='@System.Text.Json.JsonSerializer.Serialize(r.Charts[1])'>
                        <div class="chart-title">@r.Charts[1].Name</div>
                        <div class="bars"></div>
                    </div>
                }
            </div>
            <div class="chart-grid chart-grid-stack">
                @if (r.Charts.Count >= 3)
                {
                    <div class="mini-chart tall" data-series='@System.Text.Json.JsonSerializer.Serialize(r.Charts[2])'>
                        <div class="chart-title">@r.Charts[2].Name</div>
                        <div class="bars"></div>
                    </div>
                }
                @if (r.Charts.Count >= 4)
                {
                    <div class="mini-chart tall" data-series='@System.Text.Json.JsonSerializer.Serialize(r.Charts[3])'>
                        <div class="chart-title">@r.Charts[3].Name</div>
                        <div class="bars"></div>
                    </div>
                }
            </div>
        </div>
    }

    @if ((Model?.Result?.Warnings?.Count ?? 0) > 0)
    {
        <div class="panel warn-panel">
            <div class="panel-head">
                <h3>Illustration Warnings</h3>
                <p>Guardrails and assumptions that affected this result</p>
            </div>
            <ul class="bullets">
                @foreach (var w in (Model?.Result?.Warnings ?? new List<string>()))
                {
                    <li>@w</li>
                }
            </ul>
        </div>
    }
</div>
}
