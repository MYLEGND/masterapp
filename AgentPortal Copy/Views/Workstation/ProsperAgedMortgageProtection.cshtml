@{
    ViewData["Title"] = "Workstation — Prosper Aged Mortgage Protection";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/scripts-rebuttals.css" asp-append-version="true" />
}


<div id="mpShell" class="theme-prosper">
    <div class="mp-shell">
        <aside class="mp-side">
            <div class="side-card">
                <div class="side-head">
                    <p class="side-title">Elite Call Guide</p>
                    <p class="side-sub">Follow the path. Control the call. Close clean.</p>
                </div>

                <div class="side-tools">
                    <input id="mpSearch" class="side-search" placeholder="Search + highlight… (equity, IUL, ROP, voicemail)" />

                    <div class="side-actions">
                        <button class="btn gold" type="button" id="btnNext">Next Step</button>
                        <button class="btn" type="button" id="btnExpand">Expand All</button>
                        <button class="btn" type="button" id="btnCollapse">Collapse All</button>
                        <button class="btn dark" type="button" id="btnClear">Clear Search</button>
                    </div>
                </div>

                <div class="side-progress">
                    <div class="prog-row">
                        <div class="prog-label">Progress</div>
                        <div class="prog-pill"><span id="progDone">0</span>/<span id="progTotal">0</span></div>
                    </div>
                    <div class="prog-bar"><div class="prog-fill" id="progFill"></div></div>
                </div>

                <nav class="side-nav" id="sideNav" aria-label="Script steps"></nav>
            </div>
        </aside>

        <main class="mp-main">
            <div class="mp-hero">
                <div class="mp-hero-top">
                    <div class="hero-left">
                        <h1>Workstation — Prosper Aged Mortgage Protection</h1>
                        <p>Zero guessing. This page guides the agent from contact → qualify → present → e-app → close out.</p>
                    </div>
                    <div class="hero-actions">
                        <div class="hero-action-group">
                            <button type="button" class="btn gold hero-proposal" id="btnProposal">Proposal ▾</button>
                            <div class="proposal-menu" id="proposalMenu" hidden>
                                <div class="proposal-menu-head">
                                    <span>Saved Proposals</span>
                                    <button type="button" class="btn-mini" id="btnProposalNew">+ New</button>
                                </div>
                                <div class="proposal-menu-list" id="proposalMenuList"></div>
                            </div>
                        </div>
                    <div class="hero-action-group">
                        <button type="button" class="btn gold hero-underwrite" id="btnUnderwriting">Underwriting ▾</button>
                        <div class="proposal-menu" id="uwMenu" hidden>
                            <div class="proposal-menu-head">
                                <span>Saved Underwriting</span>
                                <button type="button" class="btn-mini" id="btnUwNew">+ New</button>
                            </div>
                                <div class="proposal-menu-list" id="uwMenuList"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="top-row">
                    <span class="pill"><span class="dot good"></span> Proceed / next</span>
                    <span class="pill"><span class="dot warn"></span> Clarify / slow down</span>
                    <span class="pill"><span class="dot bad"></span> Objection / unsure</span>
                </div>

                <div class="script-legend">
                    <span class="legend-chip say"><span class="swatch"></span> Say this</span>
                    <span class="legend-chip fill"><span class="swatch"></span> Fill this in</span>
                    <span class="legend-chip silent"><span class="swatch"></span> Do NOT read this out loud</span>
                    <span class="legend-chip note"><span class="swatch"></span> Agent direction</span>
                </div>
            </div>

            @await Html.PartialAsync("_LeadBridge", "MortgageProtection")

            <div class="focus-banner" id="focusBanner">
                <div class="left">
                    <div class="t1">Focus Mode is ON</div>
                    <div class="t2">You’re viewing one step only. Keep the call clean.</div>
                </div>
                <div class="right">
                    <button class="btn-ghost" type="button" id="btnExitFocus">Exit Focus</button>
                    <button class="btn-ghost" type="button" id="btnNextFocus">Next Step</button>
                </div>
            </div>

            <div class="card" id="mpCard">

                <details class="section" data-step="0" data-flow="verify" data-signal="bad" id="sec-hub">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">⚠️ Unsure / Objection Hub</span>
                                <span class="sub">Pause. Identify the real issue. Then route.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini bad" type="button" data-back>Back</button>
                        </div>
                    </summary>
                    <div class="body">
                        <div class="callout bad">
                            <div>
                                <span class="cue bad">STOP</span> Don’t push. Find the real hesitation.
                                <div class="hint">One calm question. No overexplaining.</div>
                            </div>
                        </div>

                        <div id="hubStop" class="script"><span class="say">Totally fair — before I keep going, let me make sure I understand what’s actually bothering you.

Is it the timing, the money side, or are you still not sure what this is meant to do for your family?</span></div>

                        <div style="height:12px"></div>

                        <div class="keyline"><strong>ROUTE BUTTONS</strong> (tap to jump)</div>
                        <div class="side-actions" style="grid-template-columns:1fr 1fr;">
                            <button class="btn" type="button" data-jump="#sec-threeins">“What is this?”</button>
                            <button class="btn" type="button" data-jump="#sec-equity">Need meaning / emotion</button>
                            <button class="btn" type="button" data-jump="#sec-options-choose">Choosing options</button>
                            <button class="btn dark" type="button" data-jump="#sec-closeout">Close out / tie-down</button>
                        </div>

                        <div style="height:12px"></div>

                        <div class="callout warn">
                            <div>
                                <span class="cue warn">RULE</span> After you answer, get a small agreement.
                                <div class="hint">“Fair enough?” then move immediately.</div>
                            </div>
                        </div>
                    </div>
                </details>

                <details class="section" data-step="1" data-flow="start" data-signal="good" id="sec-voicemail">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Voicemail Script</span>
                                <span class="sub">Short, calm, believable.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-voicemail">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>
                    <div class="body">
                        <div class="callout good">
                            <div>
                                <span class="cue good">GO</span> Leave a normal message, not a “sales voice” message.
                                <div class="hint">Goal: callback. Not a mini pitch.</div>
                            </div>
                        </div>

                        <div id="vm" class="script"><span class="say">Hi </span><span class="fill">&lt;CLIENT NAME&gt;</span><span class="say">, this is </span><span class="fill">&lt;YOUR NAME&gt;</span><span class="say">. I’m reaching out because I need to confirm one detail tied to the home on </span><span class="fill">&lt;PROPERTY ADDRESS&gt;</span><span class="say">. When you get a second, call me back at </span><span class="fill">&lt;YOUR PHONE NUMBER&gt;</span><span class="say">. Again, that’s </span><span class="fill">&lt;YOUR PHONE NUMBER&gt;</span><span class="say">. Thanks.</span></div>

                        <div style="height:12px"></div>

                        <div class="callout warn">
                            <div>
                                <span class="cue warn">STOP</span> If they call back irritated: do not defend yourself.
                                <div class="hint">First line: “Totally fair — I’ll be quick.” Then verify the homeowner.</div>
                            </div>
                        </div>

                        <div class="side-actions" style="grid-template-columns:1fr 1fr;">
                            <button class="btn" type="button" data-jump="#sec-aged">Go to Aged Lead Opener</button>
                            <button class="btn dark" type="button" data-jump="#sec-verify">Verify Current Situation</button>
                        </div>
                    </div>
                </details>

                <details class="section" data-step="2" data-flow="start" data-signal="warn" id="sec-texts">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Text Scripts</span>
                                <span class="sub">Simple, direct, respectful.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-texts">Focus</button>
                        </div>
                    </summary>

                    <div class="body">
                        <div class="callout warn">
                            <div>
                                <span class="cue warn">RULE</span> If they start asking detailed questions, move to a call.
                                <div class="hint">Text should create direction, not a long back-and-forth.</div>
                            </div>
                        </div>

                        <div class="keyline"><strong>TEXT (1)</strong> Light, simple callback text.</div>
                        <div id="txt1" class="script"><span class="fill">&lt;NAME&gt;</span><span class="say">, this is </span><span class="fill">&lt;YOUR NAME&gt;</span><span class="say"> reaching out regarding the home on </span><span class="fill">&lt;ADDRESS&gt;</span><span class="say">. I just need to confirm one detail with you. Call me when you get a second at </span><span class="fill">&lt;OFFICE NUMBER&gt;</span><span class="say">. Thanks.</span></div>

                        <div style="height:12px"></div>

                        <div class="keyline"><strong>TEXT (2)</strong> Soft re-engagement.</div>
                        <div id="txt2" class="script"><span class="fill">&lt;NAME&gt;</span><span class="say">, it’s </span><span class="fill">&lt;YOUR NAME&gt;</span><span class="say">. I’m the one assigned to walk through the household protection side tied to your home. Nothing complicated — I just need a quick conversation with you so I can point you the right way. What time today or tomorrow is best for a quick call?</span></div>

                        <div style="height:12px"></div>

                        <div class="keyline"><strong>APPT CONFIRM</strong> Confirm clearly and get acknowledgement.</div>
                        <div id="txtConfirm" class="script"><span class="say">Hey </span><span class="fill">&lt;NAME&gt;</span><span class="say">, </span><span class="fill">&lt;YOUR NAME&gt;</span><span class="say"> here. Confirming our call at </span><span class="fill">&lt;TIME&gt;</span><span class="say">. If anything changes, just let me know so I can adjust my schedule. Reply “yes” or send a thumbs up so I know you got this.</span></div>

                        <div style="height:12px"></div>

                        <div class="keyline"><strong>HAIL MARY</strong> Final nudge without sounding needy.</div>
                        <div id="txtHail" class="script"><span class="say">Hey, just tried you for our scheduled time. No worries if the timing got away from you. Do you want to reconnect later today, or would tomorrow be easier? If this is no longer relevant for you, that’s okay too — just let me know where you want to leave it.</span></div>

                        <div style="height:12px"></div>

                        <div class="callout bad">
                            <div>
                                <span class="cue bad">STOP</span> If they reply “What is this?” do not send a paragraph.
                                <div class="hint">Bring them to a quick call or use the short explanation step.</div>
                            </div>
                            <button class="btn-mini bad" type="button" data-jump="#sec-threeins">Go to Short Explanation</button>
                        </div>
                    </div>
                </details>

                <details class="section" open data-step="3" data-flow="verify" data-signal="good" id="sec-aged">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Mail-In Aged Leads</span>
                                <span class="sub">Casual, grounded, non-scripted.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-aged">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>

                    <div class="body">
                        <div class="callout good">
                            <div>
                                <span class="cue good">GO</span> Sound like a person fixing something, not a caller chasing a sale.
                                <div class="hint">Keep it natural. Keep it moving.</div>
                            </div>
                        </div>

                        <div id="agedOpen" class="script"><span class="say">Hey, </span><span class="fill">&lt;CLIENT&gt;</span><span class="say">? This is </span><span class="fill">&lt;YOUR NAME&gt;</span><span class="say">.
I wanted to catch you for a quick second, I’m with Legend Legacy Protection, and I’m assigned to the property on </span><span class="fill">&lt;ADDRESS&gt;</span><span class="say">.

I’m seeing something on my end on the form you mailed in that looks unfinished, and before I assume anything, I just wanted to check with you directly. I have your form here, and it looks like you sent in a request for legacy / mortgage protection.

Have you looked into that more or are you wanting me to give you some more information about that?

</span><span class="fill">&lt;If YES&gt;</span><span class="say"> Explain what mortgage protection is and why they filled out the form.

</span><span class="fill">&lt;If NO&gt;</span><span class="say"> Ask if they were wanting a quote.

</span><span class="fill">&lt;DON'T HAVE TIME&gt;</span><span class="say"> Ok no problem. I just have to ask a few brief questions and I can get started with your free quote.

Legacy mortgage protection is not just paying off the house in the event you get sick or, God forbid, pass away. Legacy mortgage protection is going to make sure your family home stays within the family. This way your children can raise their children in the home they themselves were raised in and continue the legacy.</span></div>

                        <div style="height:12px"></div>

                        <div class="callout bad">
                            <div>
                                <span class="cue bad">STOP</span> If they say “Yeah, I already handled that” → verify it, don’t just accept it.
                                <div class="hint">Route to current-situation verification.</div>
                            </div>
                            <button class="btn-mini bad" type="button" data-jump="#sec-verify">Go Verify Lane</button>
                        </div>

                        <div style="height:12px"></div>

                        <div class="callout warn">
                            <div>
                                <span class="cue warn">IF IMMEDIATE YES</span> Clarify the reality calmly.
                                <div class="hint">Your job is not to argue. Your job is to sort truth from assumption.</div>
                            </div>
                        </div>

                        <div id="clarify" class="script"><span class="say">Got it. So just so I’m looking at this the right way — did you actually put something in place and go through the full process, or was it something you looked at but never fully wrapped up?</span></div>
                    </div>
                </details>

                <details class="section" data-step="4" data-flow="verify" data-signal="bad" id="sec-verify">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Figure Out What They Have</span>
                                <span class="sub">Slow down. Verify reality first.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-verify">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>

                    <div class="body">
                        <div class="callout bad">
                            <div>
                                <span class="cue bad">STOP</span> Do not jump into numbers yet.
                                <div class="hint">First establish the lane: review what they have, or build from zero.</div>
                            </div>
                        </div>

                        <div class="keyline"><strong>IF THEY HAVE SOMETHING</strong> Learn what it actually is.</div>
                        <div id="haveCoverage" class="script"><span class="say">Perfect — that helps.

I’m not looking to disturb something that already works.
I just need to understand what you put in place so I can tell whether it still lines up with what you want.

What did you end up setting up?</span>
<span class="silent">GO INTO REVIEW / IMPROVEMENT LANE</span></div>

                        <div style="height:10px"></div>
                        <button class="btn gold" type="button" data-jump="#sec-replace">➡️ Jump to Review Lane</button>

                        <div style="height:16px"></div>

                        <div class="keyline"><strong>IF THEY HAVE NOTHING</strong> Reframe to family / home / stability.</div>
                        <div id="noCoverage" class="script"><span class="say">Okay, that actually helps a lot.

Then I’m not dealing with something already in place — I’m just looking at whether there’s still a gap here that matters.

Correct me if I’m wrong…I am assuming when you filled out the form that you were looking for something that would pay off the home or any financial burden if god forbid you were to pass away...Does that sound about right? Ok and who are we looking to protect in this situation?...

And who are we really trying to protect in this situation?</span>
<span class="silent">START FILLING OUT FINANCIAL INVENTORY</span>
<span class="silent">GO INTO ONE CALL CLOSE SCRIPT</span></div>

                        <div style="height:10px"></div>
                        <button class="btn gold" type="button" data-jump="#sec-occ">➡️ Jump to One Call Close</button>
                    </div>
                </details>

                <details class="section" data-step="5" data-flow="verify" data-signal="warn" id="sec-replace">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Review What They Already Have</span>
                                <span class="sub">No attacking. No “replacement” language up front.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-replace">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>

                    <div class="body">
                        <div class="callout warn">
                            <div>
                                <span class="cue warn">RULE</span> Say “review,” not “replace.”
                                <div class="hint">You are helping them think clearly, not pushing them out of something.</div>
                            </div>
                        </div>

                        <div class="callout bad">
                            <div>
                                <span class="cue bad">STOP</span> If they get protective of what they bought, ask why they chose it.
                                <div class="hint">That opens the real motive behind the decision.</div>
                            </div>
                            <button class="btn-mini bad" type="button" data-jump="#sec-options-choose">Go to Options Choice</button>
                        </div>

                        <div id="prKnown" class="script"><span class="note">If client knows carrier:</span>
<span class="say">Okay, got it.

Was there a specific reason you landed there?
I’m only asking because depending on age, health, and what you were trying to accomplish, that may or may not have been the cleanest fit.</span>
<span class="silent">GO TO REVIEW LANE</span></div>

                        <div style="height:12px"></div>

                        <div id="prUnknown" class="script"><span class="note">If client doesn’t know carrier:</span>
<span class="say">No worries.

Do you happen to have anything in a drawer, email, or bank statement that would show the company name or monthly amount?
That’ll help me make sense of what you’re actually working with.</span>
<span class="silent">GO TO REVIEW LANE</span></div>

                        <div style="height:12px"></div>

                        <div id="prReplace" class="script"><span class="say">So here’s really all I’m doing today:

I want to look at what you already have and make sure it still fits your goals, your budget, and the stage of life you’re in now.

A lot of people set something up once and never revisit it, even though their health, budget, family needs, or priorities change.

So I’m not assuming you need something different.
I just want to make sure you’re still in the most comfortable and sensible position based on what matters to you now. Fair enough?</span>

<span class="note">If they don’t have the policy info:</span>
<span class="say">If you can find the monthly draft or the company name, that’s enough for me to start making sense of it.</span>

<span class="note">Once name found:</span>
<span class="say">Okay, and do you know roughly how much benefit you have in place?</span>

<span class="silent">IF CANNOT FIND IT, CALL THE CARRIER WITH THEM OR FIND MONTHLY PAYMENT AND QUOTE</span>
<span class="silent">IF THEY HAVE IT, GET FINANCIAL INVENTORY AND FIND BETTER FIT</span></div>
                    </div>
                </details>

                <details class="section" data-step="6" data-flow="start" data-signal="warn" id="sec-book">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Booking the Appointment</span>
                                <span class="sub">Offer two paths. Keep control.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-book">Focus</button>
                        </div>
                    </summary>
                    <div class="body">
                        <div class="callout warn">
                            <div>
                                <span class="cue warn">RULE</span> Do not ask a wide-open scheduling question.
                                <div class="hint">Give two real options and guide the decision.</div>
                            </div>
                        </div>

                        <div id="book" class="script"><span class="say">Perfect.

If your spouse or another decision-maker needs to be part of it, let’s make sure we do this at a time that makes sense for both of you.

Would later today be easier, or is tomorrow the better move?
If tomorrow is better, would morning, afternoon, or evening make more sense?</span>
<span class="silent">FINALIZE TIME</span></div>

                        <div style="height:12px"></div>

                        <div class="callout bad">
                            <div>
                                <span class="cue bad">STOP</span> If they won’t commit to a time, don’t chase the calendar.
                                <div class="hint">Route back and find the real objection.</div>
                            </div>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Go to Objection Hub</button>
                        </div>
                    </div>
                </details>

                <details class="section" data-step="7" data-flow="close" data-signal="good" id="sec-occ">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Start One Call Close</span>
                                <span class="sub">Frame the process clearly and honestly.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-occ">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>
                    <div class="body">
                        <div class="callout good">
                            <div>
                                <span class="cue good">GO</span> Calm confidence. No hype.
                                <div class="hint">They need to feel process, not pressure.</div>
                            </div>
                        </div>

                        <div id="occ" class="script"><span class="say">Alright, let me make this simple so you know exactly where we’re going.

First, I’m going to ask a few straightforward health questions, because that helps me understand what type of options are realistically available to you.

After that, I’ll ask a few basic money questions so I’m not showing you something that makes no sense for your budget or for what you actually want to protect.

Then I’ll narrow it down and walk you through the options that fit best.

So the main thing I need from you as we go is honesty.
If something matters health-wise or budget-wise, I’d rather know it upfront than make bad assumptions.

Does that sound fair?

And before I go any further, who are we really trying to protect here?</span>

<span class="note">If spouse is beneficiary:</span>
<span class="say">And are you wanting something that would support your spouse if something happened to you, support you if something happened to your spouse, or are we looking at both sides together?</span></div>

                        <div style="height:12px"></div>

                        <details class="section" data-step="7A" data-flow="verify" data-signal="warn" id="sec-threeins">
                            <summary>
                                <div class="sum-left">
                                    <div class="chev">›</div>
                                    <div>
                                        <span class="title">3 Insurances on the Home (Client Unsure)</span>
                                        <span class="sub">Short explanation. Then move forward.</span>
                                    </div>
                                </div>
                                <div class="sum-actions">
                                    <button class="btn-mini bad" type="button" data-back>Back</button>
                                    <button class="btn-mini gold" type="button" data-jump="#sec-options-choose">Go Options</button>
                                </div>
                            </summary>
                            <div class="body">
                                <div class="callout warn">
                                    <div>
                                        <span class="cue warn">IF CLIENT IS UNSURE</span> Explain simply, then keep moving.
                                        <div class="hint">No lecture. No industry language pile-up.</div>
                                    </div>
                                </div>
                                <div id="threeIns" class="script"><span class="say">Sure — easiest way to think about it is this:

There’s coverage that protects the lender.
There’s coverage that protects the physical house.
Then there’s the side that protects the people living in that house if income gets interrupted because of death, illness, or a major life event.

The first two help the bank and the property.
This conversation is really about the third one — the people attached to the home.

That make sense?</span>

<span class="silent">THEN GO INTO THE FINANCIAL INVENTORY</span></div>
                            </div>
                        </details>
                    </div>
                </details>

                <details class="section" data-step="8" data-flow="close" data-signal="good" id="sec-equity">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Equity Protection</span>
                                <span class="sub">Give it meaning, not jargon.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-equity">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>
                    <div class="body">
                        <div class="callout good">
                            <div>
                                <span class="cue good">GO</span> Slow down here.
                                <div class="hint">This is where the conversation becomes real to them.</div>
                            </div>
                        </div>

                        <div id="equity" class="script"><span class="say"></span><span class="fill">&lt;NAME&gt;</span><span class="say">, still with me?

Good.

Now most people are not trying to cover every dollar of a mortgage with some giant expensive plan.
That’s not practical, and that’s usually not what families need.

What families usually need is time.
Time to breathe.
Time to grieve.
Time to make smart decisions instead of panicked decisions.

So let’s think about it realistically.

If something happened to you, the issue is not just the loss itself.
The issue is what happens in the months right after — when bills are still due, emotions are high, and the family is trying to figure out what comes next.

What we’re really trying to do is create a cushion so </span><span class="fill">&lt;BENEFICIARY&gt;</span><span class="say"> has </span><span class="fill">&lt;LOWEST MONTH OPTION&gt;</span><span class="say"> to </span><span class="fill">&lt;HIGHEST MONTH OPTION&gt;</span><span class="say"> months of breathing room instead of immediate pressure.

That gives them time to stay stable, think clearly, and decide what the healthiest next move is without being forced into a bad one.

That matters, right?</span>

<span class="note">If they plan on selling:</span>
<span class="say">Exactly. Because if the likely move would be to sell, then the goal is not to dump the home fast under pressure.
The goal is to give </span><span class="fill">&lt;BENEFICIARY&gt;</span><span class="say"> enough time to clean it up, organize things, make good decisions, and sell it from a position of strength instead of desperation.

That is really what this is protecting — not just a payment, but the flexibility and equity you’ve built.</span>

<span class="say">So the way I’d frame the choices for you is this:
we can look at roughly </span><span class="fill">&lt;MONTHS OPTION 1&gt;</span><span class="say"> months, </span><span class="fill">&lt;MONTHS OPTION 2&gt;</span><span class="say"> months, or </span><span class="fill">&lt;MONTHS OPTION 3&gt;</span><span class="say"> months of breathing room and support.</span>

<span class="note">Write at the top of the paper:</span>
<span class="silent">WHOLE LIFE / NEVER EXPIRES</span>
<span class="say">This one is built to stay with you for life, not disappear later on.</span>

<span class="note">Write under that:</span>
<span class="silent">BUILDS CASH VALUE</span>
<span class="say">And over time it builds value inside of it, so it’s not just money disappearing into a hole forever.</span>

<span class="say">And if it ever pays, it pays out in a lump sum that gives the family options, flexibility, and room to breathe.</span>

<span class="note">Then write:</span>
<span class="silent">&lt;MONTHS OPTION 1&gt;, &lt;MONTHS OPTION 2&gt;, &lt;MONTHS OPTION 3&gt;</span>

<span class="silent">NOW GIVE PRICES FOR EACH OPTION</span>

<span class="say">So out of those three, which one feels the most practical for your household without stretching things too much?</span>

<span class="note">After they pick an option:</span>
<span class="say">Perfect. If I go quiet for a second, I’m just getting everything lined up correctly on my end.</span>

<span class="silent">GO INTO APPLICATION</span>

<span class="note">After showing numbers if they say:</span>
<span class="silent">“I need to think about it” / “I’ll call you back” / “I need to talk to my wife, husband, son, financial advisor, parents”</span>

<span class="say">Got it.

Are you really deciding between the options, or are you still deciding whether you even want to put anything in place at all?</span></div>

                        <div style="height:12px"></div>

                        <div class="callout bad">
                            <div>
                                <span class="cue bad">STOP</span> If they say “I need to think” → clarify what decision they’re making.
                                <div class="hint">Don’t let the conversation drift.</div>
                            </div>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Go to Objection Hub</button>
                        </div>
                    </div>
                </details>

                <details class="section" data-step="9" data-flow="options" data-signal="warn" id="sec-living">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Household Support + Living Benefits</span>
                                <span class="sub">Keep it clear and human.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-living">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>
                    <div class="body">
                        <div class="callout warn">
                            <div>
                                <span class="cue warn">CLARIFY</span> They need to understand this helps while they’re alive too.
                                <div class="hint">Keep it practical. Do not sound like a brochure.</div>
                            </div>
                        </div>

                        <div id="living" class="script"><span class="fill">&lt;NAME&gt;</span><span class="say">, still with me?

Okay, I have the options ready.
Let me know when you’re ready to write these down.</span>

<span class="note">If term has living benefits:</span>
<span class="say">One thing I do want to make sure is clear:
this isn’t only about death.

A lot of families get hit hardest when someone is still here but can’t work because of a serious illness, stroke, cancer, heart issue, or something else that completely changes the household income.

So with this setup, if you qualified and something major happened, you could access part of the benefit while you are still living to help stabilize the household.

That’s the part a lot of people overlook, and honestly it matters just as much.

Does that make sense?</span>

<span class="note">If they want more info:</span>
<span class="say">In plain English, it’s there for the big life events that turn the household upside down — the kinds of situations where income drops but the bills do not.</span>

<span class="note">If they ask for more examples:</span>
<span class="say">Things like major cancer, heart attack, stroke, organ failure, severe chronic illness, or anything that seriously disrupts your ability to work and function normally.</span>

<span class="say">Perfect, write down </span><span class="fill">&lt;LENGTH OF TERM&gt;</span><span class="say"> year term.</span>
<span class="note">If it has living benefits, write:</span>
<span class="silent">&lt;___ PERCENT LIVING BENEFITS&gt;</span>
<span class="say">And if a major qualifying illness happened, up to </span><span class="fill">&lt;___%&gt;</span><span class="say"> of the amount could be made available while you’re still living.</span>

<span class="say">Now write down </span><span class="fill">&lt;HIGHEST OPTION&gt;</span><span class="say">, then </span><span class="fill">&lt;MIDDLE / NEXT OPTION&gt;</span><span class="say">, then </span><span class="fill">&lt;LOWEST OPTION&gt;</span><span class="say">.</span>

<span class="silent">NOW GIVE PRICES FOR EACH OPTION</span>

<span class="say">Out of those choices, which one feels the most responsible and comfortable for your budget?</span>

<span class="note">After they pick an option:</span>
<span class="say">Perfect. If I go quiet for a second, I’m just lining things up correctly on my side.</span>

<span class="silent">GO INTO APPLICATION</span>

<span class="note">After showing numbers if they say:</span>
<span class="silent">“I need to think about it” / “I’ll call you back” / “I need to talk to my wife, husband, son, financial advisor, parents”</span>

<span class="say">Got it.

Are you trying to decide between the options, or are you still deciding whether you want to move forward with anything at all?</span></div>
                    </div>
                </details>

                <details class="section" data-step="10" data-flow="options" data-signal="good" id="sec-rop">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Presenting CBO / ROP Option</span>
                                <span class="sub">Address the “wasted money” concern cleanly.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-rop">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>
                    <div class="body">
                        <div class="callout good">
                            <div>
                                <span class="cue good">GO</span> This is where you lower resistance around “what if I never use it?”
                                <div class="hint">Keep it simple: either it helps, or the money comes back.</div>
                            </div>
                        </div>

                        <div id="rop" class="script"><span class="say">The reason a lot of people like this option is because it softens the biggest mental objection most people have, which is:
“What if I pay into this and never need it?”

With this setup, if the protection is never needed during the term and you hold it the way it’s designed, the premiums come back.

So unlike a lot of things people pay for month after month and never see again, this one gives you two clean outcomes:
either it ends up helping when life goes wrong, or it comes back around if life goes right.

That’s why a lot of people feel more comfortable with it.
It doesn’t feel like dead money. It feels like protection with a built-in off-ramp.

Does that make sense?</span></div>
                    </div>
                </details>

                <details class="section" data-step="11" data-flow="options" data-signal="warn" id="sec-iul">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">IUL Pitch</span>
                                <span class="sub">Long-term logic without sounding technical.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-iul">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>

                    <div class="body">
                        <div class="callout warn">
                            <div>
                                <span class="cue warn">CLARIFY</span> Slow and steady.
                                <div class="hint">You are helping them understand permanence and flexibility.</div>
                            </div>
                        </div>

                        <div id="iul" class="script"><span class="say">Hey </span><span class="fill">&lt;NAME&gt;</span><span class="say">, quick question:

Has anyone ever explained the practical difference between something temporary and something permanent in plain English?</span>

<span class="say">The easiest way to think about it is this:

Some options are built for a window of time.
They’re less expensive up front, but they end.
Other options are built to stay with you, and over time they build value inside of them.

The reason some people prefer this IUL route is because it gives you more flexibility later.

If life goes the way you hope and years down the road you decide you don’t need it the same way anymore, it has built-up value you can access.
If life doesn’t go the way you hoped, then it’s there doing the job it was meant to do.

So it’s not just about having something in force.
It’s about not feeling like you spent years paying into something that disappears with nothing to show for it.</span>

<span class="note">If they already have a term:</span>
<span class="say">And to be clear, if you already have something temporary in place, I’m not telling you to tear it up blindly.
The first move is just making sure you would qualify for this type of option before changing anything.</span>

<span class="note">Write this down:</span>
<span class="silent">80% LIVING BENEFITS</span>
<span class="silent">BUILDS CASH VALUE</span>

<span class="say">So God willing, if life goes well and you’re at a different stage later, you have flexibility.
If life goes badly, your family is protected.
That’s why some people feel this is the more complete long-term choice.</span>

<span class="say">Perfect, now write down </span><span class="fill">&lt;HIGHEST OPTION&gt;</span><span class="say">, then </span><span class="fill">&lt;NEXT OPTION&gt;</span><span class="say">, then </span><span class="fill">&lt;LOWEST OPTION&gt;</span><span class="say">.</span>

<span class="silent">NOW GIVE PRICES FOR EACH OPTION</span>

<span class="say">Looking at those, which one feels like the best balance between protecting the household and still being comfortable month to month?</span>

<span class="note">After they pick an option:</span>
<span class="say">Perfect. If I go quiet for a moment, I’m just getting the next part lined up correctly.</span>

<span class="silent">GO INTO APPLICATION</span></div>
                    </div>
                </details>

                <details class="section" data-step="11A" data-flow="options" data-signal="bad" id="sec-options-choose">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">⚠️ Options Choice Moment</span>
                                <span class="sub">Get clarity before the call drifts.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini bad" type="button" data-back>Back</button>
                        </div>
                    </summary>
                    <div class="body">
                        <div class="callout bad">
                            <div>
                                <span class="cue bad">STOP</span> They need to say what decision they are actually making.
                                <div class="hint">This prevents vague stalling from taking over the call.</div>
                            </div>
                        </div>

                        <div id="chooseLine" class="script"><span class="say">Perfect — quick question so I know where your head is:

Are you choosing between the options, or are you still deciding whether you want to put anything in place at all?</span></div>

                        <div style="height:12px"></div>

                        <div class="side-actions" style="grid-template-columns:1fr 1fr;">
                            <button class="btn" type="button" data-jump="#sec-eapp">They chose → Start E-App</button>
                            <button class="btn dark" type="button" data-jump="#sec-hub">Not sure → Hub</button>
                        </div>
                    </div>
                </details>

                <details class="section" data-step="12" data-flow="eapp" data-signal="good" id="sec-eapp">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">E-App Guidelines</span>
                                <span class="sub">Normal tone. No awkwardness.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-eapp">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>
                    <div class="body">
                        <div class="callout good">
                            <div>
                                <span class="cue good">GO</span> When collecting sensitive info, stay calm and matter-of-fact.
                                <div class="hint">If you sound tense, they’ll feel tense.</div>
                            </div>
                        </div>

                        <div class="callout bad">
                            <div>
                                <span class="cue bad">STOP</span> If they hesitate, explain why the info is needed in plain English.
                                <div class="hint">No jargon. No pressure.</div>
                            </div>
                        </div>

                        <div id="eapp" class="script"><span class="note">Asking for DLN:</span>
<span class="say">Alright, let’s get the basics lined up correctly. Is your driver’s license from </span><span class="fill">&lt;STATE&gt;</span><span class="say">? Perfect — go ahead with that number when you’re ready.</span>

<span class="note">Asking for SSN:</span>
<span class="say">Next, they’ll need your social for the background health and identity check. Go ahead when you’re ready.</span>

<span class="note">Asking for bank info:</span>
<span class="say">And what bank do you use?</span>

<span class="silent">GOOGLE ROUTING NUMBER</span>
<span class="say">Perfect. I already have the routing number here. Let me know when you’re looking at your account and I’ll read it back to you... okay, it’s </span><span class="fill">&lt;ROUTING NUMBER&gt;</span><span class="say">.</span>
<span class="silent">WAIT FOR RESPONSE</span>

<span class="say">And now go ahead with the account number when you’re ready.</span></div>

                        <div style="height:12px"></div>
                        <button class="btn gold" type="button" data-jump="#sec-closeout">➡️ After submit → Close It Out</button>
                    </div>
                </details>

                <details class="section" data-step="13" data-flow="closeout" data-signal="good" id="sec-closeout">
                    <summary>
                        <div class="sum-left">
                            <div class="chev">›</div>
                            <div>
                                <span class="title">Close It Out</span>
                                <span class="sub">Leave them settled, clear, and confident.</span>
                            </div>
                        </div>
                        <div class="sum-actions">
                            <button class="btn-mini good" type="button" data-focus="#sec-closeout">Focus</button>
                            <button class="btn-mini bad" type="button" data-jump="#sec-hub">Unsure?</button>
                        </div>
                    </summary>
                    <div class="body">
                        <div class="callout good">
                            <div>
                                <span class="cue good">GO</span> This is retention. Do not rush it.
                                <div class="hint">You are leaving them with clarity and trust.</div>
                            </div>
                        </div>

                        <div id="closeout" class="script"><span class="say">Appreciate you staying with me through that, </span><span class="fill">&lt;CLIENT NAME&gt;</span><span class="say">.

Do you still have a pen handy?
Perfect — let’s make sure you have the important details written down clearly so nothing feels fuzzy later.</span>

<span class="note">Have them write down:</span>
<span class="silent">NAME OF THE COMPANY</span>
<span class="silent">PREMIUM PER MONTH</span>
<span class="silent">RECURRING BILL DATE</span>
<span class="silent">THEIR BENEFITS</span>
<span class="silent">YOUR NAME AND NUMBER</span>
<span class="silent">MON - SAT HOURS / SUNDAY EMERGENCIES ONLY</span>
<span class="silent">SECURITY CODE</span>

<span class="say">Make sure you save my contact too, so if anything comes up you know exactly who to reach out to.</span>

<span class="say">You’re going to receive your full packet soon, and when it comes in, don’t ignore it — look through it and make sure it matches what we just covered.

If anything looks off, or if it doesn’t arrive when expected, call me directly and I’ll help get it straightened out.</span>

<span class="say">And make sure </span><span class="fill">&lt;BENEFICIARY&gt;</span><span class="say"> has my contact as well, because if your family ever needs help navigating this later, I want them reaching the right person quickly instead of getting bounced around.</span>

<span class="say">And that security code I gave you — keep that somewhere safe. If someone ever contacts you claiming to be me or from my office and they can’t verify that code, don’t continue the conversation.</span>

<span class="say">Alright </span><span class="fill">&lt;CLIENT NAME&gt;</span><span class="say">, you’re set for today. I appreciate your time, and I’m glad we got this cleaned up the right way. Reach out if you need anything.</span></div>
                    </div>
                </details>

            </div>
        </main>
    </div>
</div>

