@{
    ViewData["Title"] = "Privacy & Data Use";
    ViewData["PageKey"] = "privacy";
    ViewData["BodyClass"] = "legal-theme";
}

<div class="legal-page-wrap">
    <section class="legal-hero">
        <p class="legal-kicker">Legend™</p>
        <h1 class="legal-title">Privacy &amp; Data Use</h1>
        <p class="legal-intro">Your trust is our priority.</p>
    </section>

    <section class="legal-card legal-prose">
        <p>
            Legend™ respects your privacy and is committed to handling your information responsibly.
        </p>
        <p>
            We collect personal information only when you voluntarily provide it, such as when you submit a form,
            request information, or communicate with us. This may include your name, phone number, email address, and
            any details you choose to share.
        </p>
        <p>
            Your information is used to:
        </p>
        <p>• respond to your inquiries</p>
        <p>• provide insurance-related information and guidance</p>
        <p>• connect you with appropriate services or licensed professionals</p>
        <p>• meet applicable legal or regulatory requirements</p>
        <p>
            We do not sell your personal information.
        </p>
        <p>
            Your information may be shared with licensed professionals, carriers, or service providers when necessary
            to assist with your request, subject to applicable privacy and data protection standards.
        </p>
        <p>
            We may use standard third-party tools (such as scheduling systems, analytics platforms, or communication
            tools) that collect limited technical data as part of their normal operation. Legend™ does not control how
            these third-party platforms store or process that data.
        </p>
        <p>
            By submitting your information, you consent to being contacted by phone, text, or email regarding your
            request. Message and data rates may apply. You can opt out of communications at any time.
        </p>
        <p class="legal-contact">
            If you have any questions about how your information is used, you can contact us at:
            <br />
            <a href="mailto:connect@mylegnd.com">connect@mylegnd.com</a>.
        </p>
        <p class="legal-updated">Last updated: April 2026</p>
    </section>
</div>
