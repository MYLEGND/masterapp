@model ParfaitApp.Models.ParfaitInternalWorkspaceSnapshotViewModel
@{
    ViewData["Title"] = "Command Center";
    Layout = "_InternalLayout";

    static string Money(int cents) => "$" + (cents / 100m).ToString("0.00");

    var storeReady = Model.HasCheckoutUrl && Model.HasMetaPixel && Model.HasMetaConnection;
    var orderAttention = Model.OpenFulfillmentCount > 0 || Model.PendingOrderCount > 0;
}

<section class="pf-command-page pf-dashboard-command">
    <header class="pf-dashboard-head">
        <div class="pf-dashboard-head-copy">
            <p class="pf-dashboard-eyebrow">Parfait Internal</p>
            <h1>Command Center</h1>
            <p class="pf-dashboard-intro">Store operations, order execution, and growth intelligence in one focused workspace.</p>
        </div>
        <div class="pf-dashboard-head-actions">
            <a class="pf-secondary-action" href="/store" target="_blank" rel="noopener">View Store</a>
            <a class="pf-secondary-action" href="/internal/analytics">Analytics</a>
            <a class="pf-secondary-action" href="/internal/settings/business-profile">Business Profile</a>
        </div>
    </header>

    <section class="pf-dashboard-kpis" aria-label="Store overview">
        <article class="pf-dashboard-kpi">
            <span>Store status</span>
            <strong>@(storeReady ? "Ready" : "Review")</strong>
            <small>@Model.BusinessType</small>
        </article>
        <article class="pf-dashboard-kpi">
            <span>Revenue</span>
            <strong>@Money(Model.RevenueCents)</strong>
            <small>@Model.PaidOrderCount paid · @Money(Model.AverageOrderValueCents) average</small>
        </article>
        <article class="pf-dashboard-kpi">
            <span>Orders</span>
            <strong>@Model.OrderCount</strong>
            <small>@Model.OpenFulfillmentCount fulfillment · @Model.PendingOrderCount pending</small>
        </article>
        <article class="pf-dashboard-kpi">
            <span>Sessions</span>
            <strong>@Model.Sessions</strong>
            <small>@Model.Purchases purchases · @Model.CheckoutToPurchaseRate.ToString("0.0")% conversion</small>
        </article>
    </section>

    <section class="pf-dashboard-workspace" aria-label="Operations">
        <div class="pf-dashboard-primary-grid">
            <article class="pf-dashboard-primary-card">
                <div class="pf-dashboard-card-topline">
                    <span>Catalog</span>
                    <strong>@Model.ActiveProductCount / @Model.ProductCount live</strong>
                </div>
                <h2>Products</h2>
                <p>Manage catalog, inventory, pricing, shipping, tax, product images, and merchandising.</p>
                <div class="pf-dashboard-card-stat">
                    <b>@Model.FeaturedProductCount</b>
                    <span>Featured products</span>
                </div>
                <a class="pf-action" href="/internal/commerce/products">Manage Products</a>
            </article>

            <article class="pf-dashboard-primary-card">
                <div class="pf-dashboard-card-topline">
                    <span>Order execution</span>
                    <strong class="@(orderAttention ? "is-attention" : "")">@Model.OpenFulfillmentCount open</strong>
                </div>
                <h2>Orders</h2>
                <p>Manage fulfillment, payments, receipts, returns, shipping details, and customer order history.</p>
                <div class="pf-dashboard-card-stat">
                    <b>@Model.PaidOrderCount</b>
                    <span>Paid orders</span>
                </div>
                <a class="pf-action" href="/internal/commerce/orders">Manage Orders</a>
            </article>
        </div>

        <aside class="pf-dashboard-operations">
            <article class="pf-dashboard-operation">
                <div>
                    <span>Analytics</span>
                    <h3>@Model.Sessions sessions</h3>
                    <p>@Model.CheckoutStarts checkout starts · @Model.Purchases purchases</p>
                </div>
                <a class="pf-secondary-action" href="/internal/analytics">Open</a>
            </article>

            <article class="pf-dashboard-operation">
                <div>
                    <span>Automations</span>
                    <h3>@Model.CustomerCount customers</h3>
                    <p>@Model.RepeatCustomerCount repeat buyers</p>
                </div>
                <a class="pf-secondary-action" href="/internal/automations">Open</a>
            </article>

            <article class="pf-dashboard-operation">
                <div>
                    <span>Business profile</span>
                    <h3>@(Model.HasMetaConnection ? "Connected" : "Needs review")</h3>
                    <p>Checkout @(Model.HasCheckoutUrl ? "saved" : "missing") · Meta @(Model.HasMetaPixel ? "configured" : "missing")</p>
                </div>
                <a class="pf-secondary-action" href="/internal/settings/business-profile">Open</a>
            </article>

            <article class="pf-dashboard-operation">
                <div>
                    <span>Team</span>
                    <h3>Protected access</h3>
                    <p>Internal roles, approvals, and access governance.</p>
                </div>
                <a class="pf-secondary-action" href="/internal/settings/team">Open</a>
            </article>
        </aside>
    </section>

    <section class="pf-dashboard-activity" aria-label="Store activity">
        <article><span>Store views</span><strong>@Model.StoreViews</strong></article>
        <article><span>Product views</span><strong>@Model.ProductViews</strong></article>
        <article><span>Add to cart</span><strong>@Model.AddToCarts</strong></article>
        <article><span>Product images</span><strong>@Model.ProductImageCount</strong></article>
    </section>
</section>
