@model ParfaitApp.Models.ParfaitInternalProfileViewModel
@{
    ViewData["Title"] = "Command Center";
    Layout = "_InternalLayout";
}

<section class="pf-panel mb-4">
    <div class="pf-kicker">Parfait Intelligence</div>
    <h1 class="pf-page-title">Command Center</h1>
    <p class="pf-page-copy mb-0">
        A private Parfait workspace for team operations, commerce, customers, marketing, content, and future analytics. This system is separate from the public website and separate from AgentPortal.
    </p>
</section>

<section class="row g-4">
    <div class="col-md-6 col-xl-4">
        <div class="pf-module-card">
            <span class="pf-status"><span class="pf-dot"></span> Foundation Ready</span>
            <h2 class="pf-module-title">Team Access</h2>
            <p class="text-muted mb-0">
                Secure Microsoft login for authorized Parfait team members using the internal system.
            </p>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="pf-module-card">
            <span class="pf-status"><span class="pf-dot"></span> Next</span>
            <h2 class="pf-module-title"><a href="/internal/commerce">Commerce</a></h2>
            <p class="text-muted mb-0">
                Products, collections, orders, inventory, and purchase activity will live here.
            </p>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="pf-module-card">
            <span class="pf-status"><span class="pf-dot"></span> Planned</span>
            <h2 class="pf-module-title"><a href="/internal/customers">Customers</a></h2>
            <p class="text-muted mb-0">
                Client accounts, order history, customer records, and customer support visibility.
            </p>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="pf-module-card">
            <span class="pf-status"><span class="pf-dot"></span> Planned</span>
            <h2 class="pf-module-title"><a href="/internal/marketing">Marketing</a></h2>
            <p class="text-muted mb-0">
                Campaign performance, Meta attribution, source tracking, and customer acquisition.
            </p>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="pf-module-card">
            <span class="pf-status"><span class="pf-dot"></span> Planned</span>
            <h2 class="pf-module-title"><a href="/internal/content">Content</a></h2>
            <p class="text-muted mb-0">
                Site content, product storytelling, creative assets, and brand presentation.
            </p>
        </div>
    </div>

    <div class="col-md-6 col-xl-4">
        <div class="pf-module-card">
            <span class="pf-status"><span class="pf-dot"></span> Planned</span>
            <h2 class="pf-module-title"><a href="/internal/analytics">Analytics</a></h2>
            <p class="text-muted mb-0">
                Future Parfait-owned reporting powered by the shared analytics and Meta infrastructure.
            </p>
        </div>
    </div>
</section>
