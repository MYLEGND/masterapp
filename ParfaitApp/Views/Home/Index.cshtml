@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<div class="home-container">

    <!-- HERO -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Welcome to Parfait</h1>
        <p class="lead mb-2">
            Build your Parfait Body. Own your power.
        </p>
        <hr class="my-3 hero-hr" />
    </div>

    <!-- LEGEND STORE CTA -->
    <div class="home-cta-row my-5">
        <a href="/store"
           class="btn-legend-store">
            Shop Parfait
        </a>
        <a class="btn-booking"
           href="https://outlook.office.com/book/Parfait1@mylegnd.com/"
           rel="noopener noreferrer"
           aria-label="Book your weekly sessions">
            Book Your Training Sessions
        </a>
    </div>

    <!-- IMAGE SECTION -->
    <section class="home-tools mb-5">
        <div class="d-flex justify-content-center">
            <img src="~/images/company-icons/parfait-home.png"
                 alt="Parfait Home"
                 class="tool-image" />
        </div>
    </section>

    <!-- =================== WEAR THE GRIND =================== -->
    <div class="section-card">
        <div class="section-badge">Wear The Grind</div>

        <p>
            <span class="accent-text">Parfait</span>
            isn’t just clothing — it’s a commitment to becoming the best version of yourself.
        </p>

        <p>
            Through <span class="accent-text">movement, mindset, and intentional living</span>, we help you take back your time, energy, and future.
            <br><em class="accent-text">Not for show. For growth.</em>
        </p>

        <hr class="section-divider">

        <p class="italic-text">
            True wellness begins when you stop chasing perfection and start honoring your body, mind, and energy.
        </p>
    </div>

    <!-- =================== BUILD YOUR PARFAIT BODY =================== -->
    <div class="section-card">
        <div class="section-badge">Build Your Parfait Body</div>

        <p>
            Your <span class="accent-text">Parfait Body</span> is more than muscle — it’s confidence you wear.
            It’s the strength you feel when your gear fits like it was made for you.
            Clothes that move with you, push you, and never hold you back.
        </p>

        <p>
            Forget fitting in — this is about <span class="accent-text">standing out</span>, owning every moment.
            <br><strong class="accent-text">Build your Parfait Body. Own your power.</strong>
        </p>

        <hr class="section-divider">

        <div class="mission-vision">
            <h3>Mission Statement</h3>
            <p>
                Parfait makes activewear that helps you feel <span class="accent-text">unstoppable</span> — because confidence is the best workout.
                We believe when you look and feel good, everything else falls into place.
            </p>

            <h3>Vision Statement</h3>
            <p>
                To redefine what activewear means by creating clothes that <span class="accent-text">empower women</span> to step into their strength,
                own their confidence, and live without limits.
            </p>
        </div>
    </div>

</div>
