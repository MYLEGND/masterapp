@{
    ViewData["Title"] = "Privacy & Data Use";
    ViewData["PageKey"] = "privacy";
    ViewData["BodyClass"] = "legal-theme";
    ViewData["ContentContainerClass"] = "container-fluid";
    ViewData["LayoutContentClass"] = "legal-layout-content";
    ViewData["SeoTitle"] = "Privacy & Data Use";
    ViewData["SeoDescription"] = "Review how Parfait handles customer privacy, order details, checkout data, and website interactions.";
}

<div class="legal-page-wrap">
    <section class="legal-hero">
        <p class="legal-kicker">Parfait</p>
        <h1 class="legal-title">Privacy &amp; Data Use</h1>
        <p class="legal-intro">Your trust matters just as much as your order.</p>
    </section>

    <section class="legal-card legal-prose">
        <p>
            Parfait respects your privacy and is committed to handling your information with care.
        </p>
        <p>
            We collect personal information only when you voluntarily provide it, such as when you place an order,
            submit a contact request, join a training inquiry, or communicate with our team. This may include your
            name, phone number, email address, shipping details, and any information you choose to share with us.
        </p>
        <p>
            Your information is used to:
        </p>
        <p>• process orders, payments, and fulfillment updates</p>
        <p>• respond to questions about products, sizing, training, and support</p>
        <p>• improve the storefront experience, product operations, and customer service</p>
        <p>• meet legal, accounting, fraud prevention, or operational requirements</p>
        <p>
            Parfait does not sell your personal information.
        </p>
        <p>
            Your information may be shared with trusted service providers when necessary to run the business well,
            including payment processors, shipping partners, analytics tools, and communications platforms that support
            checkout, delivery, and customer care.
        </p>
        <p>
            We may also use standard website technologies such as cookies, analytics, and event tracking tools to
            understand how visitors browse, shop, and interact with the site. These tools help us improve performance,
            merchandising clarity, and the overall Parfait experience.
        </p>
        <p>
            By submitting your information or completing checkout, you consent to receiving relevant order, service, or
            support communications by email, phone, or text when appropriate. Message and data rates may apply. You can
            opt out of non-essential communications at any time.
        </p>
        <p class="legal-contact">
            If you have any questions about how your information is used, you can contact us at:
            <br />
            <a href="mailto:parfait@mylegnd.com">parfait@mylegnd.com</a>.
        </p>
        <p class="legal-updated">Last updated: June 2026</p>
    </section>
</div>
