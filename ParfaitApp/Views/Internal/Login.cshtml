@{
    ViewData["Title"] = "Team Login";
    Layout = "_InternalAuthLayout";
}

<section class="pf-auth-shell">
    <div class="pf-auth-intro">
        <div class="pf-auth-brand">PARFAIT</div>
        <h1 class="pf-auth-title">Internal Access</h1>
        <p class="pf-auth-copy">Sign in with an approved @@mylegnd.com Microsoft account to open the Parfait internal workspace.</p>
    </div>

    <div class="pf-auth-card">
        <h2>Sign In</h2>
        <p>Continue with the Microsoft account already approved in Team.</p>

        <a class="pf-action pf-auth-action" href="/internal/login">Continue With Microsoft</a>
    </div>
</section>
