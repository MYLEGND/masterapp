@{
    ViewData["Title"] = "Team Login";
    Layout = "_InternalAuthLayout";
}

<section class="pf-auth-shell">
    <div class="pf-auth-intro">
        <div class="pf-auth-kicker">Parfait Internal</div>
        <div class="pf-auth-brand">PARFAIT</div>
        <h1 class="pf-auth-title">Team access now follows the same polished internal standard as the main workspace.</h1>
        <p class="pf-auth-copy">
            Sign in with your authorized @@mylegnd.com Microsoft account to enter the private command surface for commerce, growth, and analytics.
        </p>

        <div class="pf-auth-points">
            <div class="pf-auth-point">Brand hierarchy, spacing, and control styling now match the upgraded internal app shell.</div>
            <div class="pf-auth-point">Public storefront experiences remain separate from this internal access surface.</div>
        </div>
    </div>

    <div class="pf-auth-card">
        <div class="pf-kicker">Secure Entry</div>
        <h2>Team Login</h2>
        <p>Continue with the Microsoft identity already authorized for Parfait internal operations.</p>

        <a class="pf-action pf-auth-action" href="/internal/login">Continue With Microsoft</a>

        <div class="pf-auth-note">
            Public website navigation, customer checkout, and backend business logic remain separate from this internal login page.
        </div>
    </div>
</section>
