@{
    ViewData["Title"] = "Team Login";
    Layout = "_InternalAuthLayout";
}

<section style="width:100%;max-width:460px;">
    <div class="mb-4 text-center">
        <div class="h2 mb-1" style="letter-spacing:.08em;color:#9a6a50;">PARFAIT</div>
        <div class="text-muted">Internal Team Access</div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4 p-md-5">
            <h1 class="h4 mb-2">Team Login</h1>
            <p class="text-muted mb-4">Sign in with your authorized @@mylegnd.com Microsoft account.</p>

            <a class="btn btn-dark w-100" href="/internal/login">Continue with Microsoft</a>

            <p class="text-muted small mt-3 mb-0">
                Public website is separate from this internal system.
            </p>
        </div>
    </div>
</section>
