@{
    ViewData["Title"] = "Access Restricted";
    Layout = "_InternalAuthLayout";
}

<section class="pf-auth-shell">
    <div class="pf-auth-intro">
        <div class="pf-auth-kicker">Access Control</div>
        <div class="pf-auth-brand">PARFAIT</div>
        <h1 class="pf-auth-title">Access Restricted</h1>
        <p class="pf-auth-copy">This page is not assigned to your account. Ask a Full Control admin to update your Team access.</p>
    </div>

    <div class="pf-auth-card">
        <div class="pf-kicker">Restricted</div>
        <h2>Restricted</h2>
        <p>Your sign-in worked, but this route is not enabled for you.</p>
        <a class="pf-secondary-action pf-auth-action" href="/internal">Return To Internal Home</a>
    </div>
</section>
