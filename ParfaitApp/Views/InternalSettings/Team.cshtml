@model ParfaitApp.Models.ParfaitTeamManagementViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Team";
    Layout = "_InternalLayout";
    var pageGroups = Model.AssignablePages
        .GroupBy(assignablePage => new { assignablePage.Group, assignablePage.GroupOrder })
        .OrderBy(group => group.Key.GroupOrder)
        .ToList();
    var roleDefaultsJson = JsonSerializer.Serialize(Model.RoleOptions.ToDictionary(role => role.Key, role => role.DefaultPageKeys));
    var roleMetaJson = JsonSerializer.Serialize(Model.RoleOptions.ToDictionary(
        role => role.Key,
        role => new
        {
            label = role.Label,
            description = role.Description,
            canManageTeam = role.CanManageTeam
        }));
    var activeMembers = Model.Members.Count(member => member.IsActive);
    var teamManagers = Model.Members.Count(member => member.CanManageTeam);
    var pendingSignIns = Model.Members.Count(member => !member.LastSignInUtc.HasValue);
}

<section class="pf-command-page">
    <header class="pf-command-head">
        <div class="pf-command-copy">
            <div class="pf-kicker">Founder Access Control</div>
            <h1 class="pf-command-title">Team</h1>
            <p class="pf-command-text">Approve team accounts, assign roles, and control page access.</p>
        </div>
        <div class="pf-command-meta">
            <span class="pf-command-badge is-success">@activeMembers active</span>
            <span class="pf-command-badge is-info">@teamManagers with team controls</span>
            <span class="pf-command-badge is-warning">@pendingSignIns pending sign-in</span>
        </div>
    </header>

    @if (TempData["TeamStatus"] is string teamStatus)
    {
        <div class="pf-alert-success">@teamStatus</div>
    }

    @if (TempData["TeamError"] is string teamError)
    {
        <div class="alert alert-danger">@teamError</div>
    }

    <section class="pf-command-rail">
        <article class="pf-rail-card is-success pf-span-3">
            <div class="pf-rail-label">Founder Lock</div>
            <strong class="pf-rail-value">1</strong>
            <p class="pf-rail-note">Founder access stays fixed.</p>
        </article>

        <article class="pf-rail-card is-info pf-span-3">
            <div class="pf-rail-label">Approved Members</div>
            <strong class="pf-rail-value">@Model.Members.Count</strong>
            <p class="pf-rail-note">@activeMembers active.</p>
        </article>

        <article class="pf-rail-card is-info pf-span-3">
            <div class="pf-rail-label">Role Presets</div>
            <strong class="pf-rail-value">@Model.RoleOptions.Count</strong>
            <p class="pf-rail-note">Role defaults stay consistent.</p>
        </article>

        <article class="pf-rail-card is-warning pf-span-3">
            <div class="pf-rail-label">Team Controls</div>
            <strong class="pf-rail-value">@teamManagers</strong>
            <p class="pf-rail-note">Members with roster access.</p>
        </article>
    </section>

    <section class="pf-workspace-grid">
        <div class="pf-module-card pf-span-4">
            <span class="pf-status"><span class="pf-dot"></span> Founder Lock</span>
            <h2 class="pf-module-title">Primary Control</h2>
            <p class="text-muted mb-4">Founder identity and reserved access rules.</p>

            <div class="pf-founder-lock">
                <div>
                    <strong>Email</strong>
                    <span>@Model.FounderEmail</span>
                </div>
                <div>
                    <strong>Identity Lock</strong>
                    <span>@Model.FounderIdentityStatus</span>
                </div>
                <div>
                    <strong>Founder-only pages</strong>
                    <span>@(Model.FounderOnlyPages.Count == 0 ? "0 founder-only pages." : $"{Model.FounderOnlyPages.Count} founder-only page(s).")</span>
                </div>
            </div>
        </div>

        <div class="pf-module-card pf-span-8">
            <span class="pf-status"><span class="pf-dot"></span> Add Team Member</span>
            <h2 class="pf-module-title">Approve Access</h2>
            <p class="text-muted mb-4">Invite a @@mylegnd.com account and assign a starting role.</p>

            <form action="@Url.Content("~/internal/settings/team/add")" method="post" class="row g-3">
                @Html.AntiForgeryToken()

                <div class="col-md-5">
                    <label asp-for="NewMember.Email" class="form-label fw-bold">Email</label>
                    <input asp-for="NewMember.Email" class="form-control" autocomplete="email" placeholder="name@mylegnd.com" />
                    <span asp-validation-for="NewMember.Email" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="NewMember.DisplayName" class="form-label fw-bold">Display Name</label>
                    <input asp-for="NewMember.DisplayName" class="form-control" autocomplete="name" placeholder="Team member name" />
                    <span asp-validation-for="NewMember.DisplayName" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="NewMember.RoleKey" class="form-label fw-bold">Role</label>
                    <select asp-for="NewMember.RoleKey" class="form-select" data-pf-role-select>
                        @foreach (var role in Model.RoleOptions)
                        {
                            <option value="@role.Key">@role.Label</option>
                        }
                    </select>
                    <span asp-validation-for="NewMember.RoleKey" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <div class="pf-role-summary-grid">
                        @foreach (var role in Model.RoleOptions)
                        {
                            <div class="pf-role-summary-card">
                                <strong>@role.Label</strong>
                                <span>@role.Description</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-12 d-flex flex-wrap gap-2 align-items-center">
                    <button type="submit" class="pf-action">Add Team Member</button>
                    <span class="pf-team-meta" data-pf-role-copy>Choose a role to apply page access.</span>
                </div>
            </form>
        </div>
    </section>

    <section class="pf-commerce-panel">
        <div class="pf-commerce-panel-head">
            <div>
                <div class="pf-kicker">Internal Roster</div>
                <h2>Approved Team Members</h2>
            </div>
            <span>@Model.Members.Count member@(Model.Members.Count == 1 ? string.Empty : "s")</span>
        </div>

        @if (Model.Members.Count == 0)
        {
            <div class="pf-team-empty">No team members have been added yet.</div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var member in Model.Members)
                {
                    var modalId = $"teamMember{member.Id:N}";
                    var allowedSummary = member.AllowedPageTitles.Count == 0
                        ? "No page access granted yet."
                        : $"{member.AllowedPageTitles.Count} page(s) assigned";

                    <div class="col-md-6 col-xl-4">
                        <div class="pf-module-card pf-team-card">
                            <div class="pf-team-card-head">
                                <div>
                                    <span class="pf-status"><span class="pf-dot"></span> @member.StatusLabel</span>
                                    <h3 class="pf-team-card-title">@member.DisplayName</h3>
                                </div>
                                <button type="button" class="pf-secondary-action" data-pf-open="@modalId">Open Access</button>
                            </div>

                            <div class="pf-role-pill">Role: @member.RoleLabel</div>
                            <p class="pf-team-card-copy">@member.Email</p>

                            <div class="pf-team-list">
                                <div>
                                    <strong>Microsoft Sign-In</strong>
                                    <span>@member.IdentityStatusLabel</span>
                                </div>
                                <div>
                                    <strong>Allowed pages</strong>
                                    <span>@allowedSummary</span>
                                </div>
                                <div>
                                    <strong>Invite sent</strong>
                                    <span>@(member.InviteSentUtc.HasValue ? member.InviteSentUtc.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt") : "Not sent yet.")</span>
                                </div>
                                <div>
                                    <strong>Last sign-in</strong>
                                    <span>@(member.LastSignInUtc.HasValue ? member.LastSignInUtc.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt") : "Not signed in yet.")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </section>
</section>

@foreach (var member in Model.Members)
{
    var modalId = $"teamMember{member.Id:N}";

    <div class="pf-team-modal" id="@modalId" aria-hidden="true">
        <div class="pf-modal-dialog pf-modal-lg">
            <div class="pf-modal-content">
                <div class="pf-modal-header">
                    <div>
                        <div class="pf-kicker">Team Member Access</div>
                        <h2 class="modal-title">@member.DisplayName</h2>
                    </div>
                    <button type="button" class="btn-close" data-pf-close aria-label="Close"></button>
                </div>

                <div class="pf-modal-body">
                    <div class="pf-modal-grid">
                        <section class="pf-media-panel">
                            <span class="pf-status"><span class="pf-dot"></span> @member.StatusLabel</span>
                            <h3 class="pf-module-title mt-3">@member.Email</h3>
                            <div class="pf-role-pill mt-2">Role: @member.RoleLabel</div>
                            <p class="text-muted mb-4">
                                @member.RoleDescription
                            </p>

                            <div class="pf-team-list">
                                <div>
                                    <strong>Microsoft Sign-In</strong>
                                    <span>@member.IdentityStatusLabel</span>
                                </div>
                                <div>
                                    <strong>Team Controls</strong>
                                    <span>@(member.CanManageTeam ? "Can manage Team access." : "Limited to assigned pages.")</span>
                                </div>
                                <div>
                                    <strong>Invite Sent</strong>
                                    <span>@(member.InviteSentUtc.HasValue ? member.InviteSentUtc.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt") : "Not sent yet.")</span>
                                </div>
                                <div>
                                    <strong>Created</strong>
                                    <span>@member.CreatedUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                                </div>
                                <div>
                                    <strong>Last Sign-In</strong>
                                    <span>@(member.LastSignInUtc.HasValue ? member.LastSignInUtc.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt") : "Not signed in yet.")</span>
                                </div>
                            </div>
                        </section>

                        <section class="pf-editor-panel">
                            <form action="@Url.Content($"~/internal/settings/team/{member.Id}")" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="IsActive" value="false" />

                                <div class="mb-3">
                                    <label class="form-label fw-bold" for="display-@member.Id">Display Name</label>
                                    <input id="display-@member.Id"
                                           name="DisplayName"
                                           class="form-control"
                                           value="@member.DisplayName"
                                           autocomplete="name" />
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold" for="role-@member.Id">Role</label>
                                    <select id="role-@member.Id" name="RoleKey" class="form-select" data-pf-role-select>
                                        @foreach (var role in Model.RoleOptions)
                                        {
                                            <option value="@role.Key" selected="@(member.RoleKey.Equals(role.Key, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@role.Label</option>
                                        }
                                    </select>
                                    <div class="pf-role-hint" data-pf-role-copy>@member.RoleDescription</div>
                                </div>

                                <label class="pf-check mb-4">
                                    <input type="checkbox" name="IsActive" value="true" @(member.IsActive ? "checked" : null) />
                                    Active Team Member
                                </label>

                                <div class="pf-access-toolbar">
                                    <strong>Page Access</strong>
                                    <button type="button" class="pf-secondary-action" data-pf-apply-role>Apply Role Defaults</button>
                                </div>

                                <div class="pf-access-grid">
                                    @foreach (var group in pageGroups)
                                    {
                                        <div class="pf-access-group">
                                            <h3 class="pf-access-group-title">@group.Key.Group</h3>
                                            @foreach (var accessPage in group.OrderBy(item => item.Order))
                                            {
                                                var isChecked = member.AllowedPageKeys.Any(key => key.Equals(accessPage.Key, StringComparison.OrdinalIgnoreCase));

                                                <label class="pf-access-check">
                                                    <input type="checkbox" name="AllowedPageKeys" value="@accessPage.Key" @(isChecked ? "checked" : null) />
                                                    <span>
                                                        <strong>@accessPage.Title</strong>
                                                        <span>@accessPage.Description</span>
                                                    </span>
                                                </label>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="pf-modal-footer mt-4 px-0 pb-0">
                                    <button type="button" class="pf-secondary-action" data-pf-close>Cancel</button>
                                    <button type="submit" class="pf-action">Save Access</button>
                                </div>
                            </form>

                            <form action="@Url.Content($"~/internal/settings/team/{member.Id}/remove")"
                                  method="post"
                                  class="pf-danger-zone"
                                  onsubmit="return confirm('Remove this team member from Parfait internal access?');">
                                @Html.AntiForgeryToken()
                                <button type="submit">Remove Team Member</button>
                            </form>
                        </section>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const roleDefaults = @Html.Raw(roleDefaultsJson);
            const roleMeta = @Html.Raw(roleMetaJson);

            const openModal = id => {
                const modal = document.getElementById(id);
                if (!modal) return;
                modal.classList.add("is-open");
                modal.setAttribute("aria-hidden", "false");
                document.body.style.overflow = "hidden";
            };

            const closeModal = modal => {
                if (!modal) return;
                modal.classList.remove("is-open");
                modal.setAttribute("aria-hidden", "true");

                if (!document.querySelector(".pf-team-modal.is-open")) {
                    document.body.style.overflow = "";
                }
            };

            const updateRoleCopy = select => {
                const form = select.closest("form") ?? select.closest(".pf-module-card");
                const copy = form?.querySelector("[data-pf-role-copy]");
                const details = roleMeta[select.value];
                if (!copy || !details) return;
                copy.textContent = details.description;
            };

            const applyRoleDefaults = select => {
                const form = select.closest("form");
                if (!form) return;

                const defaults = roleDefaults[select.value] ?? [];
                const canManageTeam = roleMeta[select.value]?.canManageTeam === true;

                form.querySelectorAll("input[name='AllowedPageKeys']").forEach(checkbox => {
                    const shouldCheck = defaults.includes(checkbox.value);
                    checkbox.checked = shouldCheck;

                    if (checkbox.value === "/internal/settings/team" && !canManageTeam) {
                        checkbox.checked = false;
                    }
                });

                updateRoleCopy(select);
            };

            document.querySelectorAll("[data-pf-open]").forEach(button => {
                button.addEventListener("click", () => openModal(button.getAttribute("data-pf-open")));
            });

            document.querySelectorAll("[data-pf-close]").forEach(button => {
                button.addEventListener("click", () => closeModal(button.closest(".pf-team-modal")));
            });

            document.querySelectorAll(".pf-team-modal").forEach(modal => {
                modal.addEventListener("click", event => {
                    if (event.target === modal) closeModal(modal);
                });
            });

            document.addEventListener("keydown", event => {
                if (event.key !== "Escape") return;
                const modals = [...document.querySelectorAll(".pf-team-modal.is-open")];
                closeModal(modals.at(-1));
            });

            document.querySelectorAll("[data-pf-role-select]").forEach(select => {
                updateRoleCopy(select);
                select.addEventListener("change", () => updateRoleCopy(select));
            });

            document.querySelectorAll("[data-pf-apply-role]").forEach(button => {
                button.addEventListener("click", () => {
                    const form = button.closest("form");
                    const select = form?.querySelector("[data-pf-role-select]");
                    if (select) applyRoleDefaults(select);
                });
            });
        })();
    </script>
}
