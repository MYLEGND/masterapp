@model ParfaitApp.Models.ParfaitBusinessProfileViewModel
@{
    ViewData["Title"] = "Business Profile";
    Layout = "_InternalLayout";

    var checkoutTone = string.IsNullOrWhiteSpace(Model.GlobalStoreCheckoutUrl) ? "warning" : "success";
}

<section class="pf-command-page">
    <header class="pf-command-head">
        <div class="pf-command-copy">
            <h1 class="pf-command-title">Business Profile</h1>
            <p class="pf-command-text">@Model.StoreName</p>
        </div>
        <div class="pf-command-meta">
            <span class="pf-command-badge is-@checkoutTone">Checkout @(string.IsNullOrWhiteSpace(Model.GlobalStoreCheckoutUrl) ? "missing" : "ready")</span>
            <span class="pf-command-badge is-info">@Model.BusinessType</span>
            <span class="pf-command-badge is-info">Meta in Analytics</span>
        </div>
    </header>

    @if (TempData["ProfileStatus"] is string statusMessage)
    {
        <div class="pf-alert-success">@statusMessage</div>
    }

    <section class="pf-command-rail">
        <article class="pf-rail-card is-@checkoutTone pf-span-4">
            <div class="pf-rail-label">Checkout</div>
            <strong class="pf-rail-value">@(string.IsNullOrWhiteSpace(Model.GlobalStoreCheckoutUrl) ? "Pending" : "Ready")</strong>
            <p class="pf-rail-note">Global storefront checkout link.</p>
        </article>

        <article class="pf-rail-card is-info pf-span-4">
            <div class="pf-rail-label">Analytics</div>
            <strong class="pf-rail-value">Managed</strong>
            <p class="pf-rail-note">@Model.AnalyticsStatus</p>
        </article>

        <article class="pf-rail-card is-info pf-span-4">
            <div class="pf-rail-label">Domain</div>
            <strong class="pf-rail-value">Active</strong>
            <p class="pf-rail-note">@Model.DomainStatus</p>
        </article>
    </section>

    <form asp-action="BusinessProfile" asp-controller="InternalSettings" method="post">
        @Html.AntiForgeryToken()

        <section class="pf-workspace-grid">
            <section class="pf-module-card pf-span-8">
                <h2 class="pf-module-title">Store Identity</h2>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="StoreName" class="form-label fw-bold"></label>
                        <input asp-for="StoreName" class="form-control" autocomplete="organization" />
                        <span asp-validation-for="StoreName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="BusinessType" class="form-label fw-bold"></label>
                        <input asp-for="BusinessType" class="form-control" autocomplete="off" />
                        <span asp-validation-for="BusinessType" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="GlobalStoreCheckoutUrl" class="form-label fw-bold"></label>
                        <input asp-for="GlobalStoreCheckoutUrl" class="form-control" autocomplete="off" placeholder="https://square.link/u/..." />
                        <span asp-validation-for="GlobalStoreCheckoutUrl" class="text-danger small"></span>
                    </div>
                </div>
            </section>

            <aside class="pf-module-card pf-span-4">
                <h2 class="pf-module-title">Connected Surfaces</h2>
                <div class="pf-focus-list">
                    <div>
                        <span>Analytics</span>
                        <strong>@Model.AnalyticsStatus</strong>
                    </div>
                    <div>
                        <span>Trust</span>
                        <strong>@Model.TrustStatus</strong>
                    </div>
                    <div>
                        <span>Domain</span>
                        <strong>@Model.DomainStatus</strong>
                    </div>
                </div>

                <div class="pf-focus-actions mt-3">
                    <button type="submit" class="pf-action">Save Profile</button>
                    <a class="pf-secondary-action" href="/internal/analytics">Open Analytics</a>
                </div>
            </aside>
        </section>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
