@{
    var bodyClass = ViewData["BodyClass"] as string ?? "";
    var contentContainerClass = ViewData["ContentContainerClass"] as string ?? "container";
    var layoutContentClass = ViewData["LayoutContentClass"] as string ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Html.Raw(ViewData["Title"]) - Parfait</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LegendCorePlatform.styles.css" asp-append-version="true" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700&display=swap" rel="stylesheet">

    <link rel="icon" type="image/png" href="~/images/favicon/parfait-logo.png" />
    @RenderSection("Styles", required: false)
</head>

<body class="d-flex flex-column min-vh-100 @bodyClass">

<header class="site-header">
    <nav class="navbar">
        <!-- TOP ROW: LOGO LEFT, NAV LINKS RIGHT -->
        <div class="navbar-top">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index" aria-label="Parfait home">
                <span class="navbar-brand-mark" aria-hidden="true">
                    <img src="~/images/favicon/parfait-logo.png" alt="" />
                </span>
                <span class="navbar-brand-copy">
                    <span class="title-nunito-expanded">Parfait</span>
                </span>
            </a>

            <button class="nav-toggle" id="parfaitNavToggle" aria-label="Toggle navigation" aria-expanded="false">
                <span class="nav-toggle-bars"></span>
            </button>

            <div class="navbar-right">
                @{
                    var currentController =
                        (ViewContext.ActionDescriptor as Microsoft.AspNetCore.Mvc.Controllers.ControllerActionDescriptor)?.ControllerName;
                    string Active(string c) => c == currentController ? "active" : "";
                }

                <a class="nav-link @Active("Home")" asp-controller="Home" asp-action="Index">Home</a>
                <a class="nav-link @Active("TrainingPackages")" asp-controller="TrainingPackages" asp-action="Index">Training</a>
                <a class="nav-link @Active("Contact")" asp-controller="Contact" asp-action="Index">Contact</a>
                <a class="nav-link @Active("About")" asp-controller="About" asp-action="About">About Us</a>

                <!-- Store + Login (same right-side group) -->
                <a class="nav-link @Active("Store")" href="/store">Shop</a>
                <a class="nav-link nav-icon-link pf-store-cart-link" href="/store/cart" aria-label="Shopping cart">
                    <svg class="nav-icon pf-cart-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M6.5 6.5h15l-1.8 8.2a2 2 0 0 1-2 1.6H9.2a2 2 0 0 1-2-1.7L5.7 3.8H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <circle cx="9.8" cy="20" r="1.2" stroke-width="2"/>
                        <circle cx="17.6" cy="20" r="1.2" stroke-width="2"/>
                    </svg>
                    <span class="pf-cart-count" id="pfStoreCartCount">0</span>
                </a>
                <a class="nav-link nav-icon-link login-link" href="/internal/login" rel="noopener" aria-label="Team login">
                    <svg class="nav-icon pf-account-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <circle cx="12" cy="8" r="4" stroke-width="2"/>
                        <path d="M4.5 21a7.5 7.5 0 0 1 15 0" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                </a>
            </div>
        </div>
    </nav>
</header>

<div class="@contentContainerClass layout-content flex-grow-1 @layoutContentClass">
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="footer mt-auto py-3">
    <div class="container text-center">
        &copy; 2025 - MYLEGND, LLC. All rights reserved.
    <br />
    <a asp-controller="Home" asp-action="Terms" class="footer-link">Terms</a>
    <span class="footer-divider">&bull;</span>
    <a asp-controller="Home" asp-action="Privacy" class="footer-link">Privacy</a>
    </div>
</footer>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/storefront.js" asp-append-version="true"></script>
<script>
    (function () {
        const nav = document.querySelector('.navbar');
        const toggle = document.getElementById('parfaitNavToggle');
        const navRight = document.querySelector('.navbar-right');

        if (!nav || !toggle) return;

        function closeNav() {
            nav.classList.remove('mobile-open');
            toggle.setAttribute('aria-expanded', 'false');
        }

        toggle.addEventListener('click', function () {
            const isOpen = nav.classList.toggle('mobile-open');
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });

        if (navRight) {
            navRight.querySelectorAll('a, button').forEach(el => {
                el.addEventListener('click', () => closeNav());
            });
        }

        document.addEventListener('click', function (e) {
            if (!nav.classList.contains('mobile-open')) return;
            if (nav.contains(e.target) || e.target === toggle) return;
            closeNav();
        });

        window.addEventListener('resize', function () {
            if (window.innerWidth > 900) closeNav();
        });
    }());
</script>
@await RenderSectionAsync("Scripts", required:false)
<script>
    (() => {
        const updateCartCount = () => {
            const countEl = document.getElementById("pfStoreCartCount");
            if (!countEl) return;

            const store = window.ParfaitStorefront;
            const cart = store ? store.readCart() : [];
            const count = store ? store.itemCount(cart) : cart.reduce((sum, item) => sum + Number(item.quantity || 0), 0);
            countEl.textContent = count.toString();
        };

        updateCartCount();
        window.addEventListener("storage", updateCartCount);
        window.addEventListener("parfait-cart-updated", updateCartCount);
    })();
</script>
@await Html.PartialAsync("_ParfaitCommerceTracking")
</body>
</html>
