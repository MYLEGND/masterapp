@inject ParfaitApp.Services.IParfaitTeamAccessService TeamAccessService
@{
    var title = ViewData["Title"] as string ?? "Internal";
    var visiblePages = User.Identity?.IsAuthenticated == true
        ? await TeamAccessService.GetVisiblePagesAsync(User, ViewContext.HttpContext.RequestAborted)
        : Array.Empty<ParfaitApp.Models.ParfaitInternalPageDefinition>();
    var navGroups = visiblePages
        .GroupBy(navPage => new { navPage.Group, navPage.GroupOrder })
        .OrderBy(group => group.Key.GroupOrder)
        .ToList();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@title - Parfait Internal</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="~/images/favicon/parfait-logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/internal.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
    @RenderSection("Styles", required: false)
</head>

<body class="pf-internal-body">
    <div class="pf-backdrop" data-pf-nav-close></div>

    <aside class="pf-sidebar" id="pfSidebar" aria-label="Internal navigation">
        <div class="pf-sidebar-head">
            <div>
                <div class="pf-sidebar-title">PARFAIT</div>
                <div class="pf-sidebar-sub">Internal Command</div>
            </div>
            <button class="pf-close" type="button" aria-label="Close navigation" data-pf-nav-close>x</button>
        </div>

        <nav class="pf-nav">
            @foreach (var group in navGroups)
            {
                <div class="pf-nav-group">
                    <div class="pf-nav-section">@group.Key.Group</div>
                    @foreach (var navPage in group.OrderBy(item => item.Order))
                    {
                        <a class="pf-route-link" href="@navPage.Route">@navPage.Title</a>
                    }
                </div>
            }

            <div class="pf-nav-group">
                <div class="pf-nav-section">Public</div>
                <a href="/store" target="_blank" rel="noopener">View Store</a>
                <a href="/" target="_blank" rel="noopener">Public Site</a>
            </div>
        </nav>

        <div class="pf-sidebar-footer">
            Founder-managed internal access now controls which Parfait pages each approved @@mylegnd.com account can see without touching the public site wiring.
        </div>
    </aside>

    <header class="pf-header-shell">
        <div class="pf-header-card">
            <div class="pf-header-inner">
                <div class="pf-header-main">
                    <div class="pf-header-left">
                        <a class="pf-brandmark" href="/internal">
                            <span class="pf-brand-emblem">
                                <img src="~/images/favicon/parfait-logo.png"
                                     asp-append-version="true"
                                     alt="Parfait"
                                     class="pf-brand-logo" />
                            </span>
                            <span class="pf-brandline">
                                <span class="pf-brand">PARFAIT</span>
                            </span>
                        </a>

                        <button class="pf-menu-button"
                                type="button"
                                aria-label="Open internal navigation"
                                aria-controls="pfSidebar"
                                aria-expanded="false"
                                data-pf-nav-toggle>
                            <span></span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="pf-page-shell">
        <main class="pf-shell">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const body = document.body;
            const toggleButtons = document.querySelectorAll("[data-pf-nav-toggle]");
            const closers = document.querySelectorAll("[data-pf-nav-close]");
            const routeLinks = document.querySelectorAll(".pf-route-link");

            const normalizePath = value => {
                if (!value) return "/";
                return value.toLowerCase().replace(/\/+$/, "") || "/";
            };

            const currentPath = normalizePath(window.location.pathname);

            const setOpen = open => {
                body.classList.toggle("pf-nav-open", open);
                toggleButtons.forEach(button => button.setAttribute("aria-expanded", open ? "true" : "false"));
            };

            toggleButtons.forEach(button => {
                button.addEventListener("click", () => setOpen(!body.classList.contains("pf-nav-open")));
            });

            closers.forEach(button => {
                button.addEventListener("click", () => setOpen(false));
            });

            routeLinks.forEach(link => {
                const href = normalizePath(link.getAttribute("href"));
                const isInternalRoute = href.startsWith("/internal");
                if (isInternalRoute && (currentPath === href || currentPath.startsWith(href + "/"))) {
                    link.classList.add("is-active");
                }

                link.addEventListener("click", () => setOpen(false));
            });

            document.addEventListener("keydown", event => {
                if (event.key === "Escape") {
                    setOpen(false);
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
