<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Parfait Internal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --pf-ink:#211b18;
            --pf-muted:#756b65;
            --pf-brown:#9a6a50;
            --pf-brown-dark:#6f4634;
            --pf-cream:#f8f3ef;
            --pf-card:#ffffff;
            --pf-line:rgba(154,106,80,.22);
            --pf-shadow:0 26px 80px rgba(60,35,20,.10);
        }

        body {
            margin:0;
            background:
                radial-gradient(circle at 12% 0%, rgba(154,106,80,.15), transparent 34%),
                linear-gradient(180deg,#fff 0%,var(--pf-cream) 100%);
            color:var(--pf-ink);
            min-height:100vh;
        }

        .pf-topbar {
            max-width:1280px;
            margin:0 auto;
            padding:28px 28px 0;
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap:20px;
        }

        .pf-logo {
            font-size:2.1rem;
            font-weight:900;
            font-style:italic;
            letter-spacing:.1em;
            color:var(--pf-brown);
            line-height:1;
        }

        .pf-system-label {
            margin-top:8px;
            font-size:.72rem;
            font-weight:900;
            letter-spacing:.22em;
            text-transform:uppercase;
            color:var(--pf-brown-dark);
        }

        .pf-actions {
            display:flex;
            align-items:center;
            gap:10px;
            flex-wrap:wrap;
        }

        .pf-action {
            border:1px solid var(--pf-line);
            background:rgba(255,255,255,.75);
            color:var(--pf-brown-dark);
            border-radius:999px;
            padding:10px 18px;
            text-decoration:none;
            font-weight:850;
        }

        .pf-action:hover {
            background:var(--pf-brown);
            color:white;
        }

        .pf-action-danger {
            border-color:rgba(111,70,52,.35);
        }

        .pf-wrap {
            max-width:1280px;
            margin:0 auto;
            padding:58px 28px 72px;
        }

        .pf-panel {
            background:rgba(255,255,255,.82);
            border:1px solid var(--pf-line);
            border-radius:34px;
            box-shadow:var(--pf-shadow);
            padding:42px;
        }

        .pf-kicker {
            color:var(--pf-brown);
            font-size:.76rem;
            font-weight:950;
            letter-spacing:.2em;
            text-transform:uppercase;
        }

        .pf-page-title {
            font-size:clamp(2.7rem,6vw,5.7rem);
            font-weight:950;
            letter-spacing:-.075em;
            line-height:.95;
            margin:12px 0 18px;
        }

        .pf-page-copy {
            color:var(--pf-muted);
            font-size:1.2rem;
            max-width:820px;
            line-height:1.55;
        }

        .pf-module-card {
            background:var(--pf-card);
            border:1px solid var(--pf-line);
            border-radius:28px;
            padding:28px;
            height:100%;
            box-shadow:0 18px 50px rgba(60,35,20,.055);
        }

        .pf-module-title {
            font-size:1.35rem;
            font-weight:900;
            margin:8px 0 8px;
        }

        .pf-status {
            display:inline-flex;
            align-items:center;
            gap:8px;
            border-radius:999px;
            background:rgba(154,106,80,.09);
            color:var(--pf-brown-dark);
            padding:8px 13px;
            font-size:.78rem;
            font-weight:900;
            letter-spacing:.08em;
            text-transform:uppercase;
        }
        

        .pf-dot {
            width:8px;
            height:8px;
            border-radius:99px;
            background:var(--pf-brown);
        }


        .pf-mini-status {
            border: 1px solid var(--pf-line);
            border-radius: 18px;
            padding: 16px 18px;
            background: rgba(255,255,255,.72);
        }

        .pf-mini-label {
            color: var(--pf-muted);
            font-size: .78rem;
            font-weight: 850;
            letter-spacing: .08em;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .pf-mini-value {
            color: var(--pf-brown-dark);
            font-weight: 950;
            font-size: 1.05rem;
        }

        .pf-module-link {
            display: block;
            height: 100%;
            color: inherit;
            text-decoration: none;
        }

        .pf-module-link:hover .pf-module-card {
            transform: translateY(-3px);
            border-color: rgba(154,106,80,.42);
            box-shadow: 0 24px 70px rgba(60,35,20,.12);
        }

        .pf-module-card {
            transition: transform .16s ease, border-color .16s ease, box-shadow .16s ease;
        }

        @@media (max-width:768px) {
            .pf-topbar {
                align-items:flex-start;
                padding:22px 18px 0;
            }

            .pf-wrap {
                padding:34px 18px 52px;
            }

            .pf-panel {
                padding:28px 22px;
                border-radius:28px;
            }

            .pf-actions {
                justify-content:flex-end;
            }
        }
    </style>
</head>
<body>
    <header class="pf-topbar">
        <div>
            <div class="pf-logo">PARFAIT</div>
            <div class="pf-system-label">Internal System</div>
        </div>

        <div class="pf-actions">
            <a class="pf-action" href="/" target="_blank" rel="noopener">Public Site</a>
            <form action="/internal/logout" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="pf-action pf-action-danger">Logout</button>
            </form>
        </div>
    </header>

    <main class="pf-wrap">
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
