@model ParfaitApp.Models.ParfaitOrderAdminViewModel
@{
    ViewData["Title"] = "Orders";
    Layout = "_InternalLayout";

    static string Money(int cents) => "$" + (cents / 100m).ToString("0.00");
    var queueTone = Model.OpenFulfillmentCount > 0 ? "warning" : "success";
    var exceptionTone = Model.FailedOrderCount > 0 ? "danger" : Model.PendingOrderCount > 0 ? "warning" : "info";
}

<section class="pf-command-page">
    <header class="pf-command-head">
        <div class="pf-command-copy">
            <div class="pf-kicker">Commerce</div>
            <h1 class="pf-command-title">Orders</h1>
            <p class="pf-command-text">Order reporting is now cleaner and more precise: real counts first, then the live table without another bulky dashboard layer.</p>
        </div>
        <div class="pf-command-meta">
            <span class="pf-command-badge is-info">@Model.Orders.Count total</span>
            <span class="pf-command-badge is-success">@Money(Model.RevenueCents) revenue</span>
            <span class="pf-command-badge is-@queueTone">@Model.OpenFulfillmentCount open fulfillment</span>
            <span class="pf-command-badge is-@exceptionTone">@(Model.PendingOrderCount + Model.FailedOrderCount) exceptions</span>
        </div>
    </header>

    <section class="pf-command-rail">
        <article class="pf-rail-card is-info pf-span-3">
            <div class="pf-rail-label">Total Volume</div>
            <strong class="pf-rail-value">@Model.Orders.Count</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Paid Orders</span>
                    <strong>@Model.PaidOrderCount</strong>
                </div>
                <div>
                    <span>Pending</span>
                    <strong>@Model.PendingOrderCount</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-success pf-span-3">
            <div class="pf-rail-label">Revenue</div>
            <strong class="pf-rail-value">@Money(Model.RevenueCents)</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Average Order</span>
                    <strong>@Money(Model.AverageOrderValueCents)</strong>
                </div>
                <div>
                    <span>Paid Orders</span>
                    <strong>@Model.PaidOrderCount</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-@queueTone pf-span-3">
            <div class="pf-rail-label">Fulfillment Queue</div>
            <strong class="pf-rail-value">@Model.OpenFulfillmentCount</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Open Orders</span>
                    <strong>@Model.OpenFulfillmentCount</strong>
                </div>
                <div>
                    <span>Pending Payment</span>
                    <strong>@Model.PendingOrderCount</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-@exceptionTone pf-span-3">
            <div class="pf-rail-label">Exceptions</div>
            <strong class="pf-rail-value">@(Model.FailedOrderCount + Model.PendingOrderCount)</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Failed</span>
                    <strong>@Model.FailedOrderCount</strong>
                </div>
                <div>
                    <span>Pending</span>
                    <strong>@Model.PendingOrderCount</strong>
                </div>
            </div>
        </article>
    </section>

    <section class="pf-commerce-panel">
        <div class="pf-commerce-panel-head">
            <div>
                <div class="pf-kicker">Order Workspace</div>
                <h2>Recent Orders</h2>
            </div>
            <span>@Model.Orders.Count orders</span>
        </div>

        @if (Model.Orders.Count == 0)
        {
            <div class="text-muted">No orders yet.</div>
        }
        else
        {
            <div class="pf-orders-table-wrap">
                <table class="table align-middle pf-orders-table">
                    <thead>
                        <tr>
                            <th>Order</th>
                            <th>Date</th>
                            <th>Customer</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Payment</th>
                            <th>Fulfillment</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            var paymentTone = order.PaymentStatus.Contains("paid", StringComparison.OrdinalIgnoreCase)
                                ? "success"
                                : order.PaymentStatus.Contains("failed", StringComparison.OrdinalIgnoreCase)
                                    ? "danger"
                                    : "warning";
                            <tr>
                                <td>
                                    <strong>@order.OrderNumber</strong>
                                    <div class="text-muted small">@order.Source</div>
                                </td>
                                <td>@order.CreatedUtc.ToLocalTime().ToString("M/d/yyyy h:mm tt")</td>
                                <td>
                                    <strong>@order.FirstName @order.LastName</strong>
                                    <div class="text-muted small">@order.Email</div>
                                    <div class="text-muted small">@order.Phone</div>
                                </td>
                                <td>
                                    @foreach (var item in order.Items)
                                    {
                                        <div><strong>@item.Name</strong></div>
                                        <div class="text-muted small">Size @item.Size · Qty @item.Quantity · @Money(item.LineTotalCents)</div>
                                    }
                                </td>
                                <td><strong>@Money(order.TotalCents)</strong></td>
                                <td>
                                    <span class="pf-status pf-status--@paymentTone"><span class="pf-dot"></span> @order.PaymentStatus</span>
                                    @if (!string.IsNullOrWhiteSpace(order.SquarePaymentId))
                                    {
                                        <div class="text-muted small">Square: @order.SquarePaymentId</div>
                                    }
                                </td>
                                <td>@order.FulfillmentStatus</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</section>
