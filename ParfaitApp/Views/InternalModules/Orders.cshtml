@model ParfaitApp.Models.ParfaitOrderAdminViewModel
@using ParfaitApp.Models
@{
    ViewData["Title"] = "Orders";
    Layout = "_InternalLayout";

    static string Money(int cents) => "$" + (cents / 100m).ToString("0.00");
    static string MoneyField(int cents) => cents <= 0 ? "" : (cents / 100m).ToString("0.00");

    static string PaymentTone(ParfaitOrderRecord order) => order.IsFailedPayment ? "danger" : order.IsPendingPayment ? "warning" : order.IsRefundedPayment ? "info" : "success";
    static string FulfillmentTone(ParfaitOrderRecord order) => string.Equals(order.FulfillmentStatus, "Fulfilled", StringComparison.OrdinalIgnoreCase) ? "success" : string.Equals(order.FulfillmentStatus, "Shipped", StringComparison.OrdinalIgnoreCase) ? "info" : string.Equals(order.FulfillmentStatus, "Cancelled", StringComparison.OrdinalIgnoreCase) ? "danger" : "warning";
    static string ReturnTone(ParfaitOrderRecord order) => string.Equals(order.ReturnStatus, "None", StringComparison.OrdinalIgnoreCase) ? "muted" : string.Equals(order.ReturnStatus, "Refunded", StringComparison.OrdinalIgnoreCase) ? "info" : string.Equals(order.ReturnStatus, "Closed", StringComparison.OrdinalIgnoreCase) ? "success" : "warning";

    var activeQueueTone = Model.OpenFulfillmentCount > 0 ? "warning" : "success";
    var returnQueueTone = Model.ReturnQueueCount > 0 ? "warning" : "info";
    var shippedCount = Model.Orders.Count(order => string.Equals(order.FulfillmentStatus, "Shipped", StringComparison.OrdinalIgnoreCase));
    var fulfilledCount = Model.Orders.Count(order => string.Equals(order.FulfillmentStatus, "Fulfilled", StringComparison.OrdinalIgnoreCase));
}

<section class="pf-command-page pf-orders-admin">
    <header class="pf-orders-head">
        <div>
            <p class="pf-orders-eyebrow">Parfait Operations</p>
            <h1>Orders</h1>
            <p>Payment, fulfillment, returns, tracking, and receipts in one compact control surface.</p>
        </div>
        <div class="pf-orders-head-actions">
            <a class="pf-secondary-action" href="/internal/commerce/products">Products</a>
            <a class="pf-secondary-action" href="/internal/analytics">Analytics</a>
        </div>
    </header>

    @if (TempData["OrderStatus"] is string orderStatus)
    {
        <div class="pf-alert-success">@orderStatus</div>
    }

    <section class="pf-orders-kpis">
        <article class="pf-orders-kpi"><span>Orders</span><strong>@Model.Orders.Count</strong><small>@Model.PaidOrderCount paid · @Model.PendingOrderCount pending</small></article>
        <article class="pf-orders-kpi"><span>Revenue</span><strong>@Money(Model.RevenueCents)</strong><small>@Money(Model.AverageOrderValueCents) average · @Model.RefundedOrderCount refunded</small></article>
        <article class="pf-orders-kpi is-@activeQueueTone"><span>Fulfillment</span><strong>@Model.OpenFulfillmentCount</strong><small>@shippedCount shipped · @fulfilledCount fulfilled</small></article>
        <article class="pf-orders-kpi is-@returnQueueTone"><span>Returns</span><strong>@Model.ReturnQueueCount</strong><small>@Model.FailedOrderCount failed payments</small></article>
    </section>

    <section class="pf-orders-surface">
        <div class="pf-orders-surface-head">
            <div>
                <h2>Order Queue</h2>
                <p>Click any order to inspect, update, resend receipt, or review line items.</p>
            </div>
            <span>@Model.Orders.Count orders</span>
        </div>

        @if (Model.Orders.Count == 0)
        {
            <div class="text-muted">No orders yet.</div>
        }
        else
        {
            <div class="pf-orders-list">
                @foreach (var order in Model.Orders)
                {
                    var modalId = $"orderModal{order.OrderNumber}";
                    var primaryItem = order.Items.FirstOrDefault();
                    var totalUnits = order.Items.Sum(item => item.Quantity);
                    var trackingLabel = !string.IsNullOrWhiteSpace(order.TrackingNumber)
                        ? $"{(string.IsNullOrWhiteSpace(order.TrackingCarrier) ? "Tracking" : order.TrackingCarrier)} · {order.TrackingNumber}"
                        : "Tracking pending";

                    <article class="pf-order-row"
                             data-pf-open="@modalId"
                             role="button"
                             tabindex="0"
                             aria-label="Open order @order.OrderNumber">
                        <div class="pf-order-cell pf-order-identity">
                            <span>@order.Source</span>
                            <strong>@order.OrderNumber</strong>
                            <small>@order.CreatedUtc.ToLocalTime().ToString("M/d/yyyy h:mm tt")</small>
                        </div>

                        <div class="pf-order-cell pf-order-customer">
                            <span>Customer</span>
                            <strong>@order.CustomerName</strong>
                            <small>@order.Email</small>
                        </div>

                        <div class="pf-order-cell pf-order-item">
                            <img src="@(primaryItem?.ImageUrl ?? "/images/favicon/parfait-logo.png")" alt="@(primaryItem?.Name ?? "Order item")" />
                            <div>
                                <strong>@(primaryItem?.Name ?? "No line items")</strong>
                                <small>@totalUnits unit@(totalUnits == 1 ? "" : "s") · @order.Items.Count line@(order.Items.Count == 1 ? "" : "s")</small>
                            </div>
                        </div>

                        <div class="pf-order-cell pf-order-money">
                            <span>Total</span>
                            <strong>@Money(order.TotalCents)</strong>
                            <small>Net @Money(order.NetRevenueCents)</small>
                        </div>

                        <div class="pf-order-status-stack">
                            <span class="pf-status pf-status--@PaymentTone(order)"><span class="pf-dot"></span> @order.PaymentStatus</span>
                            <span class="pf-status pf-status--@FulfillmentTone(order)"><span class="pf-dot"></span> @order.FulfillmentStatus</span>
                            <span class="pf-status pf-status--@ReturnTone(order)"><span class="pf-dot"></span> Return @order.ReturnStatus</span>
                        </div>

                        <div class="pf-order-cell pf-order-receipt">
                            <a class="pf-text-link" href="@order.ReceiptUrl" target="_blank" rel="noreferrer" data-pf-stop-open>Receipt</a>
                            <small>@trackingLabel</small>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</section>

@foreach (var order in Model.Orders)
{
    var modalId = $"orderModal{order.OrderNumber}";

    <div class="pf-order-modal" id="@modalId" aria-hidden="true">
        <div class="pf-order-modal-dialog">
            <div class="pf-order-modal-shell">
                <div class="pf-order-modal-head">
                    <div>
                        <span>Order Control</span>
                        <h2>@order.OrderNumber</h2>
                    </div>
                    <button type="button" class="btn-close" data-pf-close aria-label="Close"></button>
                </div>

                <div class="pf-order-modal-body">
                    <section class="pf-order-modal-summary">
                        <article><span>Total</span><strong>@Money(order.TotalCents)</strong><small>Net @Money(order.NetRevenueCents)</small></article>
                        <article><span>Status</span><strong>@order.PaymentStatus</strong><small>@order.FulfillmentStatus · Return @order.ReturnStatus</small></article>
                        <article><span>Created</span><strong>@order.CreatedUtc.ToLocalTime().ToString("M/d/yyyy")</strong><small>@order.CreatedUtc.ToLocalTime().ToString("h:mm tt")</small></article>
                    </section>

                    <section class="pf-order-modal-grid">
                        <article class="pf-order-detail-panel">
                            <div class="pf-order-panel-head"><h3>Customer + Items</h3></div>

                            <div class="pf-order-detail-list">
                                <div><span>Customer</span><strong>@order.CustomerName</strong></div>
                                <div><span>Email</span><strong>@order.Email</strong></div>
                                <div><span>Phone</span><strong>@order.Phone</strong></div>
                                <div><span>Ship To</span><strong>@order.AddressLine1@if (!string.IsNullOrWhiteSpace(order.AddressLine2)){<text><br />@order.AddressLine2</text>}<br />@order.City, @order.State @order.PostalCode</strong></div>
                            </div>

                            <div class="pf-order-items">
                                @foreach (var item in order.Items)
                                {
                                    <article>
                                        <img src="@(item.ImageUrl ?? "/images/favicon/parfait-logo.png")" alt="@item.Name" />
                                        <div>
                                            <strong>@item.Name</strong>
                                            <span>Size @item.Size · Qty @item.Quantity · @Money(item.UnitPriceCents) each</span>
                                        </div>
                                        <b>@Money(item.LineTotalCents)</b>
                                    </article>
                                }
                            </div>
                        </article>

                        <article class="pf-order-detail-panel">
                            <div class="pf-order-panel-head"><h3>Workflow</h3></div>

                            <form method="post" action="/internal/commerce/orders/update" class="pf-order-form" data-pf-order-form>
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="OrderNumber" value="@order.OrderNumber" />

                                <div class="pf-order-form-grid">
                                    <label>Payment
                                        <select class="form-select" name="PaymentStatus">
                                            <option value="Pending" selected="@string.Equals(order.PaymentStatus, "Pending", StringComparison.OrdinalIgnoreCase)">Pending</option>
                                            <option value="Paid" selected="@string.Equals(order.PaymentStatus, "Paid", StringComparison.OrdinalIgnoreCase)">Paid</option>
                                            <option value="Failed" selected="@string.Equals(order.PaymentStatus, "Failed", StringComparison.OrdinalIgnoreCase)">Failed</option>
                                            <option value="Refunded" selected="@string.Equals(order.PaymentStatus, "Refunded", StringComparison.OrdinalIgnoreCase)">Refunded</option>
                                        </select>
                                    </label>

                                    <label>Fulfillment
                                        <select class="form-select" name="FulfillmentStatus">
                                            <option value="Unfulfilled" selected="@string.Equals(order.FulfillmentStatus, "Unfulfilled", StringComparison.OrdinalIgnoreCase)">Unfulfilled</option>
                                            <option value="Processing" selected="@string.Equals(order.FulfillmentStatus, "Processing", StringComparison.OrdinalIgnoreCase)">Processing</option>
                                            <option value="Packed" selected="@string.Equals(order.FulfillmentStatus, "Packed", StringComparison.OrdinalIgnoreCase)">Packed</option>
                                            <option value="Shipped" selected="@string.Equals(order.FulfillmentStatus, "Shipped", StringComparison.OrdinalIgnoreCase)">Shipped</option>
                                            <option value="Fulfilled" selected="@string.Equals(order.FulfillmentStatus, "Fulfilled", StringComparison.OrdinalIgnoreCase)">Fulfilled</option>
                                            <option value="On Hold" selected="@string.Equals(order.FulfillmentStatus, "On Hold", StringComparison.OrdinalIgnoreCase)">On Hold</option>
                                            <option value="Cancelled" selected="@string.Equals(order.FulfillmentStatus, "Cancelled", StringComparison.OrdinalIgnoreCase)">Cancelled</option>
                                            <option value="Returned" selected="@string.Equals(order.FulfillmentStatus, "Returned", StringComparison.OrdinalIgnoreCase)">Returned</option>
                                        </select>
                                    </label>

                                    <label>Return
                                        <select class="form-select" name="ReturnStatus">
                                            <option value="None" selected="@string.Equals(order.ReturnStatus, "None", StringComparison.OrdinalIgnoreCase)">None</option>
                                            <option value="Requested" selected="@string.Equals(order.ReturnStatus, "Requested", StringComparison.OrdinalIgnoreCase)">Requested</option>
                                            <option value="Approved" selected="@string.Equals(order.ReturnStatus, "Approved", StringComparison.OrdinalIgnoreCase)">Approved</option>
                                            <option value="Received" selected="@string.Equals(order.ReturnStatus, "Received", StringComparison.OrdinalIgnoreCase)">Received</option>
                                            <option value="Refunded" selected="@string.Equals(order.ReturnStatus, "Refunded", StringComparison.OrdinalIgnoreCase)">Refunded</option>
                                            <option value="Closed" selected="@string.Equals(order.ReturnStatus, "Closed", StringComparison.OrdinalIgnoreCase)">Closed</option>
                                        </select>
                                    </label>

                                    <label>Refunded Amount
                                        <input class="form-control pf-money-display" type="number" min="0" step="0.01" value="@MoneyField(order.RefundedCents)" />
                                        <input type="hidden" name="RefundedCents" value="@order.RefundedCents" class="pf-money-hidden" />
                                    </label>

                                    <label>Carrier <input class="form-control" name="TrackingCarrier" value="@order.TrackingCarrier" /></label>
                                    <label>Tracking <input class="form-control" name="TrackingNumber" value="@order.TrackingNumber" /></label>
                                    <label class="pf-full">Admin Notes <textarea class="form-control" name="AdminNotes" rows="3">@order.AdminNotes</textarea></label>
                                </div>

                                <div class="pf-order-actions">
                                    <a class="pf-secondary-action" href="@order.ReceiptUrl" target="_blank" rel="noreferrer">View Receipt</a>
                                    <button type="submit" class="pf-action">Save Order</button>
                                </div>
                            </form>

                            <form method="post" action="/internal/commerce/orders/receipt" class="pf-order-receipt-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="orderNumber" value="@order.OrderNumber" />
                                <button type="submit" class="pf-secondary-action">Resend Receipt</button>
                            </form>

                            <div class="pf-order-detail-list">
                                <div><span>Square Payment</span><strong>@(string.IsNullOrWhiteSpace(order.SquarePaymentId) ? "Not captured" : order.SquarePaymentId)</strong></div>
                                @if (!string.IsNullOrWhiteSpace(order.SquareError))
                                {
                                    <div><span>Square Error</span><strong>@order.SquareError</strong></div>
                                }
                            </div>
                        </article>
                    </section>
                </div>
            </div>
        </div>
    </div>
}

<script>
(() => {
    const openModal = id => {
        const modal = document.getElementById(id);
        if (!modal) return;
        modal.classList.add("is-open");
        modal.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
    };

    const closeModal = modal => {
        if (!modal) return;
        modal.classList.remove("is-open");
        modal.setAttribute("aria-hidden", "true");
        if (!document.querySelector(".pf-order-modal.is-open")) document.body.style.overflow = "";
    };

    document.querySelectorAll("[data-pf-open]").forEach(button => {
        button.addEventListener("click", event => {
            if (event.target.closest("[data-pf-stop-open]")) return;
            openModal(button.getAttribute("data-pf-open"));
        });

        button.addEventListener("keydown", event => {
            if (event.target.closest("[data-pf-stop-open]")) return;
            if (event.key !== "Enter" && event.key !== " ") return;
            event.preventDefault();
            openModal(button.getAttribute("data-pf-open"));
        });
    });

    document.querySelectorAll("[data-pf-close]").forEach(button => {
        button.addEventListener("click", () => closeModal(button.closest(".pf-order-modal")));
    });

    document.querySelectorAll(".pf-order-modal").forEach(modal => {
        modal.addEventListener("click", event => {
            if (event.target === modal) closeModal(modal);
        });
    });

    document.addEventListener("keydown", event => {
        if (event.key !== "Escape") return;
        closeModal([...document.querySelectorAll(".pf-order-modal.is-open")].at(-1));
    });
})();
</script>

<script>
(() => {
    const syncMoneyInput = input => {
        const hidden = input.parentElement?.querySelector(".pf-money-hidden");
        if (!hidden) return;
        hidden.value = Math.round(Number(input.value || 0) * 100).toString();
    };

    document.querySelectorAll(".pf-money-display").forEach(input => {
        const form = input.closest("form");
        input.addEventListener("input", () => syncMoneyInput(input));
        form?.addEventListener("submit", () => syncMoneyInput(input));
        syncMoneyInput(input);
    });
})();
</script>
