@{
    ViewData["Title"] = "Commerce";
    Layout = "_InternalLayout";
}

<section class="pf-panel mb-4">
    <div class="pf-kicker">Commerce Operations</div>
    <h1 class="pf-page-title">Commerce</h1>
    <p class="pf-page-copy">Manage the future Parfait selling engine: products, collections, inventory, orders, fulfillment, and revenue.</p>
</section>

<section class="row g-4">
    <div class="col-md-6 col-xl-4"><a class="pf-module-link" href="/internal/commerce/products"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Live Manager</span><h2 class="pf-module-title">Products</h2><p class="text-muted mb-0">Create and manage product listings, pricing, descriptions, images, and availability.</p></div></a></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Collections</h2><p class="text-muted mb-0">Organize products into drops, categories, campaigns, and featured collections.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Inventory</h2><p class="text-muted mb-0">Track stock levels, sizes, variants, reorder needs, and sold-out items.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Orders</h2><p class="text-muted mb-0">View purchases, payment status, fulfillment status, and customer order history.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Revenue</h2><p class="text-muted mb-0">Track sales, refunds, order value, revenue trends, and purchase performance.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Later</span><h2 class="pf-module-title">Fulfillment</h2><p class="text-muted mb-0">Prepare future shipping, pickup, delivery, and order completion workflows.</p></div></div>
</section>
