@model ParfaitApp.Models.ParfaitInternalWorkspaceSnapshotViewModel
@{
    ViewData["Title"] = "Commerce";
    Layout = "_InternalLayout";

    static string Money(int cents) => "$" + (cents / 100m).ToString("0.00");
    var readinessTone = Model.HasCheckoutUrl && Model.HasMetaConnection ? "success" : Model.HasCheckoutUrl || Model.HasMetaConnection ? "warning" : "danger";
    var queueTone = Model.OpenFulfillmentCount > 0 || Model.FailedOrderCount > 0 ? "warning" : "success";
}

<section class="pf-command-page">
    <header class="pf-command-head">
        <div class="pf-command-copy">
            <h1 class="pf-command-title">Commerce</h1>
            <p class="pf-command-text">Catalog, orders, revenue, and fulfillment.</p>
        </div>
        <div class="pf-command-meta">
            <span class="pf-command-badge is-success">@Model.ActiveProductCount live products</span>
            <span class="pf-command-badge is-info">@Model.OrderCount orders</span>
            <span class="pf-command-badge is-@queueTone">@Model.OpenFulfillmentCount open fulfillment</span>
            <span class="pf-command-badge is-@readinessTone">Checkout @(Model.HasCheckoutUrl ? "ready" : "missing")</span>
        </div>
    </header>

    <section class="pf-command-rail">
        <article class="pf-rail-card is-success pf-span-3">
            <div class="pf-rail-label">Catalog</div>
            <strong class="pf-rail-value">@Model.ProductCount</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Active</span>
                    <strong>@Model.ActiveProductCount</strong>
                </div>
                <div>
                    <span>Featured</span>
                    <strong>@Model.FeaturedProductCount</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-info pf-span-3">
            <div class="pf-rail-label">Order Feed</div>
            <strong class="pf-rail-value">@Model.OrderCount</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Paid</span>
                    <strong>@Model.PaidOrderCount</strong>
                </div>
                <div>
                    <span>Pending</span>
                    <strong>@Model.PendingOrderCount</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-success pf-span-3">
            <div class="pf-rail-label">Revenue</div>
            <strong class="pf-rail-value">@Money(Model.RevenueCents)</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Average Order</span>
                    <strong>@Money(Model.AverageOrderValueCents)</strong>
                </div>
                <div>
                    <span>Customers</span>
                    <strong>@Model.CustomerCount</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-@readinessTone pf-span-3">
            <div class="pf-rail-label">Store Readiness</div>
            <strong class="pf-rail-value">@(Model.HasCheckoutUrl && Model.HasMetaConnection ? "Ready" : "Needs Love")</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Checkout</span>
                    <strong>@(Model.HasCheckoutUrl ? "Saved" : "Missing")</strong>
                </div>
                <div>
                    <span>Meta</span>
                    <strong>@(Model.HasMetaConnection ? "Secure" : "Pending")</strong>
                </div>
            </div>
        </article>
    </section>

    <section class="pf-workspace-grid">
        <section class="pf-commerce-panel pf-span-8">
            <div class="pf-commerce-panel-head">
                <div>
                    <h2>Live Control</h2>
                </div>
                <div class="pf-command-board-actions">
                    <a class="pf-secondary-action" href="/internal/commerce/products">Products</a>
                    <a class="pf-secondary-action" href="/internal/commerce/orders">Orders</a>
                </div>
            </div>

            <div class="pf-focus-grid">
                <article class="pf-focus-card is-success pf-span-6">
                    <div class="pf-focus-label">Catalog Workspace</div>
                    <h3 class="pf-focus-title">Products</h3>
                    <div class="pf-focus-value">@Model.ProductCount</div>
                    <p class="pf-focus-copy">Pricing, visibility, sorting, and media.</p>
                    <div class="pf-focus-list">
                        <div>
                            <span>Active Products</span>
                            <strong>@Model.ActiveProductCount</strong>
                        </div>
                        <div>
                            <span>Product Images</span>
                            <strong>@Model.ProductImageCount</strong>
                        </div>
                    </div>
                    <div class="pf-focus-actions">
                        <a class="pf-action" href="/internal/commerce/products">Open Products</a>
                    </div>
                </article>

                <article class="pf-focus-card is-info pf-span-6">
                    <div class="pf-focus-label">Order Workspace</div>
                    <h3 class="pf-focus-title">Orders</h3>
                    <div class="pf-focus-value">@Model.OrderCount</div>
                    <p class="pf-focus-copy">Payment status and fulfillment in one view.</p>
                    <div class="pf-focus-list">
                        <div>
                            <span>Paid Orders</span>
                            <strong>@Model.PaidOrderCount</strong>
                        </div>
                        <div>
                            <span>Open Fulfillment</span>
                            <strong>@Model.OpenFulfillmentCount</strong>
                        </div>
                    </div>
                    <div class="pf-focus-actions">
                        <a class="pf-action" href="/internal/commerce/orders">Open Orders</a>
                    </div>
                </article>

                <article class="pf-focus-card is-success pf-span-6">
                    <div class="pf-focus-label">Sales Read</div>
                    <h3 class="pf-focus-title">Revenue Quality</h3>
                    <div class="pf-focus-value">@Money(Model.RevenueCents)</div>
                    <p class="pf-focus-copy">Revenue, average order, and repeat demand.</p>
                    <div class="pf-focus-list">
                        <div>
                            <span>Average Order</span>
                            <strong>@Money(Model.AverageOrderValueCents)</strong>
                        </div>
                        <div>
                            <span>Repeat Buyers</span>
                            <strong>@Model.RepeatCustomerCount</strong>
                        </div>
                    </div>
                </article>

                <article class="pf-focus-card is-@queueTone pf-span-6">
                    <div class="pf-focus-label">Exceptions</div>
                    <h3 class="pf-focus-title">Queue & Attention</h3>
                    <div class="pf-focus-value">@(Model.OpenFulfillmentCount + Model.FailedOrderCount)</div>
                    <p class="pf-focus-copy">Open work and failed payments.</p>
                    <div class="pf-focus-list">
                        <div>
                            <span>Failed Payments</span>
                            <strong>@Model.FailedOrderCount</strong>
                        </div>
                        <div>
                            <span>Pending Orders</span>
                            <strong>@Model.PendingOrderCount</strong>
                        </div>
                    </div>
                </article>
            </div>
        </section>

        <section class="pf-module-card pf-span-4">
            <h2 class="pf-module-title">Store Dependencies</h2>
            <p class="text-muted mb-3">Checkout, Meta, and shared store settings.</p>

            <div class="pf-focus-list">
                <div>
                    <span>Checkout URL</span>
                    <strong>@(Model.HasCheckoutUrl ? "Saved" : "Missing")</strong>
                </div>
                <div>
                    <span>Meta CAPI</span>
                    <strong>@(Model.HasMetaConnection ? "Secure" : "Pending")</strong>
                </div>
                <div>
                    <span>Business Type</span>
                    <strong>@Model.BusinessType</strong>
                </div>
                <div>
                    <span>Latest Order</span>
                    <strong>@(Model.LatestOrderUtc.HasValue ? Model.LatestOrderUtc.Value.ToLocalTime().ToString("MMM d") : "None yet")</strong>
                </div>
            </div>

            <div class="pf-focus-actions mt-3">
                <a class="pf-action" href="/internal/settings/business-profile">Business Profile</a>
            </div>
        </section>
    </section>
</section>
