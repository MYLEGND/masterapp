@model ParfaitApp.Models.ParfaitInternalAnalyticsViewModel
@{
    ViewData["Title"] = "Analytics";
    Layout = "_InternalLayout";

    static string Money(int cents) => "$" + (cents / 100m).ToString("0.00");
    static string Rate(decimal value) => value.ToString("0.0") + "%";
    static string ShortId(string? value, int visible = 10)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "—";

        var trimmed = value.Trim();
        return trimmed.Length <= visible ? trimmed : trimmed[..visible] + "…";
    }

    static string LocalTime(DateTime utc) => utc.ToLocalTime().ToString("M/d/yyyy h:mm tt");

    static string DwellLabel(double milliseconds)
    {
        if (milliseconds <= 0)
            return "0 sec";

        if (milliseconds >= 60000)
            return (milliseconds / 60000d).ToString("0.0") + " min";

        return (milliseconds / 1000d).ToString("0.0") + " sec";
    }

    var metaConnectUrl = Url.Action("MetaConnect", "InternalModules", new
    {
        returnUrl = Url.Action("Analytics", "InternalModules", new { preset = Model.SelectedPreset })
    }) ?? "/internal/analytics/meta-connect";
    var metaTone = Model.MetaSettings.HasActiveMetaAdsConnection
        ? "success"
        : string.IsNullOrWhiteSpace(Model.MetaSettings.MetaPixelId) ? "danger" : "warning";
    var revenueTone = Model.RevenueCents > 0 ? "success" : "warning";
    var healthIssues = Model.MetaHealth.FailureDetection.Where(issue => issue.Count > 0).Take(4).ToList();
    var purchaseBreakdown = Model.ActionBreakdowns.FirstOrDefault(action => action.Key == "purchase");
    var checkoutBreakdown = Model.ActionBreakdowns.FirstOrDefault(action => action.Key == "checkout-started");
}

<section class="pf-command-page">
    <header class="pf-command-head">
        <div class="pf-command-copy">
            <h1 class="pf-command-title">Analytics</h1>
            <p class="pf-command-text">@Model.RangeLabel</p>
        </div>
        <div class="pf-command-meta">
            <span class="pf-command-badge is-info">@Model.Sessions sessions</span>
            <span class="pf-command-badge is-success">@Model.Purchases purchases</span>
            <span class="pf-command-badge is-@revenueTone">@Money(Model.RevenueCents) revenue</span>
            <span class="pf-command-badge is-@metaTone">Meta @(Model.MetaSettings.HasActiveMetaAdsConnection ? "connected" : "pending")</span>
        </div>
    </header>

    <div class="pf-command-board-actions">
        <a class="@(Model.SelectedPreset == "today" ? "pf-action" : "pf-secondary-action")" href="@Url.Action("Analytics", "InternalModules", new { preset = "today" })">Today</a>
        <a class="@(Model.SelectedPreset == "7d" ? "pf-action" : "pf-secondary-action")" href="@Url.Action("Analytics", "InternalModules", new { preset = "7d" })">7 Days</a>
        <a class="@(Model.SelectedPreset == "30d" ? "pf-action" : "pf-secondary-action")" href="@Url.Action("Analytics", "InternalModules", new { preset = "30d" })">30 Days</a>
        <a class="@(Model.SelectedPreset == "month" ? "pf-action" : "pf-secondary-action")" href="@Url.Action("Analytics", "InternalModules", new { preset = "month" })">Month</a>
        <a class="@(Model.SelectedPreset == "year" ? "pf-action" : "pf-secondary-action")" href="@Url.Action("Analytics", "InternalModules", new { preset = "year" })">Year</a>
    </div>

    @if (TempData["AnalyticsStatus"] is string analyticsStatus)
    {
        <div class="pf-alert-success">@analyticsStatus</div>
    }

    <section class="pf-command-board">
        <div class="pf-command-board-head">
            <div>
                <h2>Performance Command Deck</h2>
            </div>
        </div>

        <div class="pf-focus-grid">
            <article class="pf-focus-card is-info pf-span-3">
                <div class="pf-focus-label">Traffic Pulse</div>
                <h3 class="pf-focus-title">Sessions</h3>
                <div class="pf-focus-value">@Model.Summary.Sessions</div>
                <div class="pf-focus-list">
                    <div>
                        <span>Page Views</span>
                        <strong>@Model.Summary.PageViews</strong>
                    </div>
                    <div>
                        <span>Visitors</span>
                        <strong>@Model.Visitors</strong>
                    </div>
                </div>
            </article>

            <article class="pf-focus-card is-success pf-span-3">
                <div class="pf-focus-label">Revenue</div>
                <h3 class="pf-focus-title">Commerce</h3>
                <div class="pf-focus-value">@Money(Model.RevenueCents)</div>
                <div class="pf-focus-list">
                    <div>
                        <span>Orders</span>
                        <strong>@Model.Orders</strong>
                    </div>
                    <div>
                        <span>AOV</span>
                        <strong>@Money(Model.AverageOrderValueCents)</strong>
                    </div>
                </div>
            </article>

            <article class="pf-focus-card is-warning pf-span-3">
                <div class="pf-focus-label">Commerce Funnel</div>
                <h3 class="pf-focus-title">Checkout</h3>
                <div class="pf-focus-value">@Rate(checkoutBreakdown?.ConversionRate ?? 0m)</div>
                <div class="pf-focus-list">
                    <div>
                        <span>Cart Abandonment</span>
                        <strong>@Model.CartAbandonmentSessions</strong>
                    </div>
                    <div>
                        <span>Purchases</span>
                        <strong>@Model.Purchases</strong>
                    </div>
                </div>
            </article>

            <article class="pf-focus-card is-@metaTone pf-span-3">
                <div class="pf-focus-label">Meta Signal</div>
                <h3 class="pf-focus-title">Pipeline</h3>
                <div class="pf-focus-value">@Model.MetaSignal.TotalSignalEvents</div>
                <div class="pf-focus-list">
                    <div>
                        <span>Server Sent</span>
                        <strong>@Model.MetaHealth.PipelineHealth.MetaServerSentCount</strong>
                    </div>
                    <div>
                        <span>Browser Sent</span>
                        <strong>@Model.MetaHealth.PipelineHealth.MetaBrowserSentCount</strong>
                    </div>
                </div>
            </article>
        </div>
    </section>

    <section class="pf-command-board">
        <div class="pf-command-board-head">
            <div>
                <h2>Analysis Modules</h2>
            </div>
        </div>

        <div class="pf-module-list">
            <button type="button" class="pf-module-row pf-analytics-trigger is-info" data-pf-open="pfAnalyticsTrafficModal">
                <div class="pf-module-row-main">
                    <h3>Traffic Overview</h3>
                    <p>Top pages, entry pages, live activity, and source volume for the Parfait storefront.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Top Pages</span>
                        <strong>@Model.Traffic.TopPages.Count</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Recent Activity</span>
                        <strong>@Model.Traffic.RecentActivity.Count</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-info" data-pf-open="pfAnalyticsPageModal">
                <div class="pf-module-row-main">
                    <h3>Page Performance</h3>
                    <p>View counts, CTA movement, and page-level conversion pace across the public site.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Tracked Pages</span>
                        <strong>@Model.PagePerformance.Rows.Count</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>CTA Rows</span>
                        <strong>@Model.CtaPerformance.Rows.Count</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-info" data-pf-open="pfAnalyticsSourceModal">
                <div class="pf-module-row-main">
                    <h3>Source Attribution</h3>
                    <p>Session source, campaign, dwell, and conversion readiness without duplicating attribution logic.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Source Rows</span>
                        <strong>@Model.Sources.Rows.Count</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Campaigns</span>
                        <strong>@Model.Traffic.TopCampaigns.Count</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-warning" data-pf-open="pfAnalyticsJourneyModal">
                <div class="pf-module-row-main">
                    <h3>Journey</h3>
                    <p>Entry flow, drop-off pressure, and conversion-adjacent pages using the shared path analysis engine.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Landing Pages</span>
                        <strong>@Model.Journey.TopLandingPages.Count</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Drop-Off Pages</span>
                        <strong>@Model.Journey.CommonDropOffPages.Count</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-warning" data-pf-open="pfAnalyticsTimeModal">
                <div class="pf-module-row-main">
                    <h3>Time On Page</h3>
                    <p>Longest dwell, shortest visits, and the pages that hold or lose attention fastest.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Page Views</span>
                        <strong>@Model.TimeOnPage.TotalPageViews</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Timing Samples</span>
                        <strong>@Model.TimeOnPage.TotalTimingSamples</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-danger" data-pf-open="pfAnalyticsExitModal">
                <div class="pf-module-row-main">
                    <h3>Exit Analysis</h3>
                    <p>Identify the exit-heavy pages and the quickest abandonment points across tracked sessions.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Exit Pages</span>
                        <strong>@Model.ExitAnalysis.TopExitPages.Count</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Quick Exits</span>
                        <strong>@Model.ExitAnalysis.QuickExitPages.Count</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-info" data-pf-open="pfAnalyticsScrollModal">
                <div class="pf-module-row-main">
                    <h3>Scroll Depth</h3>
                    <p>Review how far visitors move down each page before they stall or finish the content.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Tracked Pages</span>
                        <strong>@Model.ScrollAnalysis.Rows.Count</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Total Sessions</span>
                        <strong>@Model.Sessions</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-success" data-pf-open="pfAnalyticsLandingModal">
                <div class="pf-module-row-main">
                    <h3>Landing Pages</h3>
                    <p>See which entry pages attract, engage, and convert best inside the Parfait storefront.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Entry Rows</span>
                        <strong>@Model.LandingPages.Rows.Count</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Top Entry</span>
                        <strong>@(Model.LandingPages.Rows.FirstOrDefault()?.PageKey ?? "—")</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-info" data-pf-open="pfAnalyticsDeviceModal">
                <div class="pf-module-row-main">
                    <h3>Device Intelligence</h3>
                    <p>Device, browser, operating system, language, and timezone behavior in one inspection layer.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Devices</span>
                        <strong>@Model.Devices.Devices.Count</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Browsers</span>
                        <strong>@Model.Devices.Browsers.Count</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-@metaTone" data-pf-open="pfAnalyticsMetaModal">
                <div class="pf-module-row-main">
                    <h3>Meta Signal Intelligence</h3>
                    <p>Bridge coverage, deduplication, event ladder, friction hotspots, and recent Meta diagnostics.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Signal Events</span>
                        <strong>@Model.MetaSignal.TotalSignalEvents</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Recent Diagnostics</span>
                        <strong>@Model.MetaSignal.RecentDiagnostics.Count</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-@metaTone" data-pf-open="pfAnalyticsMetaCampaignsModal">
                <div class="pf-module-row-main">
                    <h3>Meta Campaigns</h3>
                    <p>Shared Meta Ads campaign reporting for spend, clicks, CTR, CPC, CPM, purchases, revenue, and ROAS.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Connection</span>
                        <strong>@(Model.MetaSettings.HasActiveMetaAdsConnection ? "Live" : "Pending")</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Account</span>
                        <strong>@(Model.MetaSettings.AccountName ?? Model.MetaSettings.AccountId ?? "—")</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>

            <button type="button" class="pf-module-row pf-analytics-trigger is-warning" data-pf-open="pfAnalyticsRawModal">
                <div class="pf-module-row-main">
                    <h3>Raw Event Inspector</h3>
                    <p>Review normalized event rows, order ties, attribution values, and raw JSON from the tracked funnel.</p>
                </div>
                <div class="pf-module-row-metrics">
                    <div class="pf-module-row-metric">
                        <span>Recent Events</span>
                        <strong>@Model.RecentEvents.Count</strong>
                    </div>
                    <div class="pf-module-row-metric">
                        <span>Recent Orders</span>
                        <strong>@Model.RecentOrders.Count</strong>
                    </div>
                </div>
                <div class="pf-module-row-actions">
                    <span class="pf-secondary-action">Open Module</span>
                </div>
            </button>
        </div>
    </section>

    <section class="pf-command-rail">
        <article class="pf-rail-card is-info pf-span-2">
            <div class="pf-rail-label">Visitors</div>
            <strong class="pf-rail-value">@Model.Visitors</strong>
            <p class="pf-rail-note">@Model.NewCustomers new · @Model.ReturningCustomers returning</p>
            <div class="pf-rail-grid">
                <div>
                    <span>Revenue / Visitor</span>
                    <strong>@Model.RevenuePerVisitor.ToString("C")</strong>
                </div>
                <div>
                    <span>Revenue / Session</span>
                    <strong>@Model.RevenuePerSession.ToString("C")</strong>
                </div>
            </div>
        </article>

        @foreach (var action in Model.ActionBreakdowns)
        {
            var modalId = $"pfAnalyticsModal-{action.Key}";

            <button type="button"
                    class="pf-rail-card pf-analytics-trigger is-@action.Tone pf-span-2"
                    data-pf-open="@modalId"
                    aria-haspopup="dialog"
                    aria-controls="@modalId">
                <div class="pf-rail-label">@action.Label</div>
                <strong class="pf-rail-value">@action.Count</strong>
                <p class="pf-rail-note">@action.TileNote</p>
                <div class="pf-analytics-trigger-meta">
                    <span>@action.UniqueSessions sessions</span>
                    <span>@action.UniqueVisitors visitors</span>
                    <span>Open breakdown</span>
                </div>
            </button>
        }
    </section>

    <section class="pf-workspace-grid">
        <article class="pf-module-card pf-span-6">
            <div class="pf-commerce-panel-head">
                <h2>Top Pages</h2>
                <span>@Model.PagePerformance.Rows.Count rows</span>
            </div>
            @if (Model.PagePerformance.Rows.Count == 0)
            {
                <div class="text-muted">No tracked page performance rows yet.</div>
            }
            else
            {
                <div class="pf-analytics-table-wrap">
                    <table class="table align-middle pf-analytics-table">
                        <thead>
                            <tr>
                                <th>Page</th>
                                <th>Views</th>
                                <th>CTA</th>
                                <th>Conv.</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.PagePerformance.Rows.Take(8))
                        {
                            <tr>
                                <td><strong>@row.PageKey</strong></td>
                                <td>@row.Views</td>
                                <td>@row.CtaClicks</td>
                                <td>@Rate(row.ConversionRate)</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="pf-module-card pf-span-6">
            <div class="pf-commerce-panel-head">
                <h2>Top Products</h2>
                <span>@Model.TopProducts.Count products</span>
            </div>
            @if (Model.TopProducts.Count == 0)
            {
                <div class="text-muted">No product-linked purchase activity yet.</div>
            }
            else
            {
                <div class="pf-analytics-table-wrap">
                    <table class="table align-middle pf-analytics-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Revenue</th>
                                <th>Units</th>
                                <th>Views</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.TopProducts)
                        {
                            <tr>
                                <td><strong>@row.ProductName</strong></td>
                                <td>@Money(row.RevenueCents)</td>
                                <td>@row.UnitsSold</td>
                                <td>@row.ProductViews</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="pf-module-card pf-span-6">
            <div class="pf-commerce-panel-head">
                <h2>Source Attribution</h2>
                <span>@Model.Sources.Rows.Count rows</span>
            </div>
            @if (Model.Sources.Rows.Count == 0)
            {
                <div class="text-muted">No attributed traffic rows yet.</div>
            }
            else
            {
                <div class="pf-analytics-table-wrap">
                    <table class="table align-middle pf-analytics-table">
                        <thead>
                            <tr>
                                <th>Source</th>
                                <th>Campaign</th>
                                <th>Sessions</th>
                                <th>Conv.</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.Sources.Rows.Take(8))
                        {
                            <tr>
                                <td><strong>@row.Source</strong></td>
                                <td>@(string.IsNullOrWhiteSpace(row.Campaign) ? "—" : row.Campaign)</td>
                                <td>@row.Sessions</td>
                                <td>@Rate(row.SessionConversionRate)</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="pf-module-card pf-span-6">
            <div class="pf-commerce-panel-head">
                <h2>Recent Orders</h2>
                <span>@Model.RecentOrders.Count orders</span>
            </div>
            @if (Model.RecentOrders.Count == 0)
            {
                <div class="text-muted">No tracked orders in this window.</div>
            }
            else
            {
                <div class="pf-analytics-table-wrap">
                    <table class="table align-middle pf-analytics-table">
                        <thead>
                            <tr>
                                <th>Order</th>
                                <th>Customer</th>
                                <th>Net</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.RecentOrders)
                        {
                            <tr>
                                <td>
                                    <strong>@row.OrderNumber</strong>
                                    <div class="text-muted">@LocalTime(row.CreatedUtc)</div>
                                </td>
                                <td>
                                    <strong>@row.CustomerName</strong>
                                    <div class="text-muted">@row.Email</div>
                                </td>
                                <td>@Money(row.NetRevenueCents)</td>
                                <td>@row.PaymentStatus / @row.FulfillmentStatus</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="pf-module-card pf-span-6">
            <div class="pf-commerce-panel-head">
                <h2>Live Activity</h2>
                <span>@Model.Traffic.RecentActivity.Count rows</span>
            </div>
            @if (Model.Traffic.RecentActivity.Count == 0)
            {
                <div class="text-muted">No recent storefront activity yet.</div>
            }
            else
            {
                <div class="pf-analytics-table-wrap">
                    <table class="table align-middle pf-analytics-table">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Event</th>
                                <th>Page</th>
                                <th>Outcome</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var row in Model.Traffic.RecentActivity.Take(10))
                        {
                            <tr>
                                <td>@LocalTime(row.EventUtc)</td>
                                <td><strong>@row.EventType</strong></td>
                                <td>@(row.PageKey ?? "—")</td>
                                <td>@(row.OutcomeSummary ?? "—")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="pf-module-card pf-span-6">
            <div class="pf-commerce-panel-head">
                <h2>Meta Command</h2>
                <span>@Model.MetaSettings.DatasetStatus</span>
            </div>

            <form id="pfAnalyticsMetaForm"
                  asp-action="SaveAnalyticsMetaSettings"
                  asp-controller="InternalModules"
                  asp-route-preset="@Model.SelectedPreset"
                  method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="MetaSettings.MetaPixelId" class="form-label fw-bold"></label>
                        <input asp-for="MetaSettings.MetaPixelId" class="form-control" autocomplete="off" inputmode="numeric" />
                        <span asp-validation-for="MetaSettings.MetaPixelId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MetaSettings.MetaTestEventCode" class="form-label fw-bold"></label>
                        <input asp-for="MetaSettings.MetaTestEventCode" class="form-control" autocomplete="off" />
