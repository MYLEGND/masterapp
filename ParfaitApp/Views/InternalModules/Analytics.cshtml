@model ParfaitApp.Models.ParfaitAnalyticsDashboardViewModel
@{
    ViewData["Title"] = "Analytics";
    Layout = "_InternalLayout";

    static string Money(int cents) => "$" + (cents / 100m).ToString("0.00");
    static string Percent(decimal value) => value.ToString("0.0") + "%";
}

<section class="pf-command-page">
    <header class="pf-command-head">
        <div class="pf-command-copy">
            <div class="pf-kicker">Parfait Intelligence</div>
            <h1 class="pf-command-title">Analytics</h1>
            <p class="pf-command-text">Live Parfait-owned funnel reporting now stays tight, readable, and useful instead of feeling like a second banner with more filler.</p>
        </div>
        <div class="pf-command-meta">
            <span class="pf-command-badge is-info">@Model.Sessions sessions</span>
            <span class="pf-command-badge is-success">@Model.Purchases purchases</span>
            <span class="pf-command-badge is-@(Model.RevenueCents > 0 ? "success" : "warning")">@Money(Model.RevenueCents) tracked</span>
        </div>
    </header>

    <section class="pf-command-rail">
        <article class="pf-rail-card is-info pf-span-2">
            <div class="pf-rail-label">Visitors</div>
            <strong class="pf-rail-value">@Model.Visitors</strong>
            <p class="pf-rail-note">@Model.Sessions sessions</p>
        </article>

        <article class="pf-rail-card is-info pf-span-2">
            <div class="pf-rail-label">Store Views</div>
            <strong class="pf-rail-value">@Model.StoreViews</strong>
            <p class="pf-rail-note">@Model.ProductViews product views</p>
        </article>

        <article class="pf-rail-card is-@(Model.AddToCarts > 0 ? "success" : "warning") pf-span-2">
            <div class="pf-rail-label">Add To Cart</div>
            <strong class="pf-rail-value">@Model.AddToCarts</strong>
            <p class="pf-rail-note">@Percent(Model.ProductViewToCartRate) view to cart</p>
        </article>

        <article class="pf-rail-card is-@(Model.CheckoutStarts > 0 ? "success" : "warning") pf-span-2">
            <div class="pf-rail-label">Started</div>
            <strong class="pf-rail-value">@Model.CheckoutStarts</strong>
            <p class="pf-rail-note">@Percent(Model.CartToCheckoutRate) cart to checkout</p>
        </article>

        <article class="pf-rail-card is-@(Model.Purchases > 0 ? "success" : "danger") pf-span-2">
            <div class="pf-rail-label">Purchases</div>
            <strong class="pf-rail-value">@Model.Purchases</strong>
            <p class="pf-rail-note">@Percent(Model.CheckoutToPurchaseRate) checkout to purchase</p>
        </article>

        <article class="pf-rail-card is-@(Model.RevenueCents > 0 ? "success" : "danger") pf-span-2">
            <div class="pf-rail-label">Revenue</div>
            <strong class="pf-rail-value">@Money(Model.RevenueCents)</strong>
            <p class="pf-rail-note">Tracked purchase value</p>
        </article>
    </section>

    <section class="pf-commerce-panel">
        <div class="pf-commerce-panel-head">
            <div>
                <div class="pf-kicker">Commerce Funnel</div>
                <h2>Top Products</h2>
            </div>
            <span>@Model.TopProducts.Count products</span>
        </div>

        @if (Model.TopProducts.Count == 0)
        {
            <div class="text-muted">No product-level analytics yet.</div>
        }
        else
        {
            <div class="pf-analytics-table-wrap">
                <table class="table align-middle pf-analytics-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Views</th>
                            <th>Add To Cart</th>
                            <th>Checkout</th>
                            <th>Purchases</th>
                            <th>Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.TopProducts)
                        {
                            <tr>
                                <td><strong>@product.ProductName</strong></td>
                                <td>@product.ProductViews</td>
                                <td>@product.AddToCarts</td>
                                <td>@product.CheckoutStarts</td>
                                <td>@product.Purchases</td>
                                <td><strong>@Money(product.RevenueCents)</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="pf-commerce-panel">
        <div class="pf-commerce-panel-head">
            <div>
                <div class="pf-kicker">Live Feed</div>
                <h2>Recent Funnel Activity</h2>
            </div>
            <span>@Model.RecentEvents.Count events</span>
        </div>

        @if (Model.RecentEvents.Count == 0)
        {
            <div class="text-muted">No Parfait analytics events yet.</div>
        }
        else
        {
            <div class="pf-analytics-table-wrap">
                <table class="table align-middle pf-analytics-table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Event</th>
                            <th>Product</th>
                            <th>Size</th>
                            <th>Qty</th>
                            <th>Value</th>
                            <th>Session</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RecentEvents)
                        {
                            var eventTone = item.EventType.Contains("purchase", StringComparison.OrdinalIgnoreCase)
                                ? "success"
                                : item.EventType.Contains("checkout", StringComparison.OrdinalIgnoreCase)
                                    ? "info"
                                    : item.EventType.Contains("cart", StringComparison.OrdinalIgnoreCase)
                                        ? "warning"
                                        : "info";
                            <tr>
                                <td>@item.EventUtc.ToLocalTime().ToString("M/d/yyyy h:mm tt")</td>
                                <td><span class="pf-status pf-status--@eventTone"><span class="pf-dot"></span> @item.EventType</span></td>
                                <td>@(item.ProductName ?? "—")</td>
                                <td>@(item.Size ?? "—")</td>
                                <td>@(item.Quantity?.ToString() ?? "—")</td>
                                <td>@(item.ValueCents.HasValue ? Money(item.ValueCents.Value) : "—")</td>
                                <td><span class="text-muted small">@((item.SessionId?.Length ?? 0) > 12 ? item.SessionId![..12] + "…" : item.SessionId ?? "—")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</section>
