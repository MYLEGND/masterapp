@model ParfaitApp.Models.ParfaitAnalyticsDashboardViewModel
@{
    ViewData["Title"] = "Analytics";
    Layout = "_InternalLayout";

    static string Money(int cents) => "$" + (cents / 100m).ToString("0.00");
    static string Percent(decimal value) => value.ToString("0.0") + "%";
}

<section class="pf-commerce-shell">
    <section class="pf-page-hero">
        <div class="pf-page-hero-main">
            <div class="pf-kicker">Parfait Intelligence</div>
            <h1 class="pf-page-title">Analytics</h1>
            <p class="pf-page-copy">Live Parfait-owned funnel reporting from AnalyticsEvents.</p>
        </div>

        <div class="pf-page-hero-actions">
            <a class="pf-secondary-action" href="/internal/commerce">Commerce Home</a>
            <a class="pf-secondary-action" href="/store" target="_blank" rel="noopener">View Store</a>
        </div>
    </section>

    <section class="row g-4 mb-4">
        <div class="col-md-6 col-xl-3"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Visitors</span><h2 class="pf-module-title">@Model.Visitors</h2><p class="text-muted mb-0">@Model.Sessions sessions</p></div></div>
        <div class="col-md-6 col-xl-3"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Store Views</span><h2 class="pf-module-title">@Model.StoreViews</h2><p class="text-muted mb-0">@Model.ProductViews product views</p></div></div>
        <div class="col-md-6 col-xl-3"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Add To Cart</span><h2 class="pf-module-title">@Model.AddToCarts</h2><p class="text-muted mb-0">@Percent(Model.ProductViewToCartRate) product view → cart</p></div></div>
        <div class="col-md-6 col-xl-3"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Checkout</span><h2 class="pf-module-title">@Model.CheckoutStarts</h2><p class="text-muted mb-0">@Percent(Model.CartToCheckoutRate) cart → checkout</p></div></div>
    </section>

    <section class="row g-4 mb-4">
        <div class="col-md-6 col-xl-3"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Purchases</span><h2 class="pf-module-title">@Model.Purchases</h2><p class="text-muted mb-0">@Percent(Model.CheckoutToPurchaseRate) checkout → purchase</p></div></div>
        <div class="col-md-6 col-xl-3"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Revenue</span><h2 class="pf-module-title">@Money(Model.RevenueCents)</h2><p class="text-muted mb-0">Tracked purchase value</p></div></div>
    </section>

    <section class="pf-commerce-panel mb-4">
        <div class="pf-commerce-panel-head">
            <div>
                <div class="pf-kicker">Commerce Funnel</div>
                <h2>Top Products</h2>
            </div>
            <span>@Model.TopProducts.Count products</span>
        </div>

        @if (Model.TopProducts.Count == 0)
        {
            <div class="text-muted">No product-level analytics yet.</div>
        }
        else
        {
            <div class="pf-analytics-table-wrap">
                <table class="table align-middle pf-analytics-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Views</th>
                            <th>Add To Cart</th>
                            <th>Checkout</th>
                            <th>Purchases</th>
                            <th>Revenue</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model.TopProducts)
                        {
                            <tr>
                                <td><strong>@product.ProductName</strong></td>
                                <td>@product.ProductViews</td>
                                <td>@product.AddToCarts</td>
                                <td>@product.CheckoutStarts</td>
                                <td>@product.Purchases</td>
                                <td><strong>@Money(product.RevenueCents)</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="pf-commerce-panel">
        <div class="pf-commerce-panel-head">
            <div>
                <div class="pf-kicker">Live Feed</div>
                <h2>Recent Funnel Activity</h2>
            </div>
            <span>@Model.RecentEvents.Count events</span>
        </div>

        @if (Model.RecentEvents.Count == 0)
        {
            <div class="text-muted">No Parfait analytics events yet.</div>
        }
        else
        {
            <div class="pf-analytics-table-wrap">
                <table class="table align-middle pf-analytics-table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Event</th>
                            <th>Product</th>
                            <th>Size</th>
                            <th>Qty</th>
                            <th>Value</th>
                            <th>Session</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RecentEvents)
                        {
                            <tr>
                                <td>@item.EventUtc.ToLocalTime().ToString("M/d/yyyy h:mm tt")</td>
                                <td><span class="pf-status"><span class="pf-dot"></span> @item.EventType</span></td>
                                <td>@(item.ProductName ?? "—")</td>
                                <td>@(item.Size ?? "—")</td>
                                <td>@(item.Quantity?.ToString() ?? "—")</td>
                                <td>@(item.ValueCents.HasValue ? Money(item.ValueCents.Value) : "—")</td>
                                <td><span class="text-muted small">@((item.SessionId?.Length ?? 0) > 12 ? item.SessionId![..12] + "…" : item.SessionId ?? "—")</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</section>
