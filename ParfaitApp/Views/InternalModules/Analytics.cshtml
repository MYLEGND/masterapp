@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const statusEl = document.getElementById("pfMetaConnectionStatus");
            const connectBtn = document.getElementById("pfMetaConnectButton");
            const disconnectBtn = document.getElementById("pfMetaDisconnectButton");
            const statusUrl = "@Url.Action("MetaConnectionStatus", "InternalModules")";
            const metaCampaignsUrl = "@Url.Action("MetaCampaigns", "InternalModules")";
            const disconnectUrl = "@Url.Action("MetaDisconnect", "InternalModules")";
            const token = document.querySelector("#pfAnalyticsMetaForm input[name='__RequestVerificationToken']")?.value || "";
            const metaCampaignsState = document.getElementById("pfMetaCampaignsState");
            const metaCampaignsTableWrap = document.getElementById("pfMetaCampaignsTableWrap");
            const metaCampaignsBody = document.getElementById("pfMetaCampaignsBody");
            const metaCampaignsAccount = document.getElementById("pfMetaCampaignsAccount");
            const metaCampaignsSynced = document.getElementById("pfMetaCampaignsSynced");
            const metaCampaignsCount = document.getElementById("pfMetaCampaignsCount");
            const metaCampaignsRange = document.getElementById("pfMetaCampaignsRange");

            const setStatus = (message, tone) => {
                if (!statusEl) return;
                statusEl.className = "small fw-semibold mt-3";
                statusEl.classList.add(tone === "success" ? "text-success" : tone === "danger" ? "text-danger" : "text-muted");
                statusEl.textContent = message;
            };

            const escapeHtml = value => String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll("\"", "&quot;")
                .replaceAll("'", "&#39;");

            const money = value => {
                const numeric = Number(value || 0);
                return new Intl.NumberFormat(undefined, {
                    style: "currency",
                    currency: "USD",
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                }).format(Number.isFinite(numeric) ? numeric : 0);
            };

            const integer = value => new Intl.NumberFormat().format(Number(value || 0));
            const percent = value => `${Number(value || 0).toFixed(2)}%`;

            const setMetaCampaignsState = (message, tone = "info") => {
                if (!metaCampaignsState) return;
                metaCampaignsState.className = `pf-analytics-fetch-state is-${tone}`;
                metaCampaignsState.textContent = message;
            };

            const setConnectedState = connected => {
                if (connectBtn) connectBtn.textContent = connected ? "Reconnect Meta" : "Connect Meta";
                if (disconnectBtn) disconnectBtn.style.display = connected ? "" : "none";
            };

            const formatDate = value => {
                if (!value) return "";
                try {
                    return new Date(value).toLocaleString([], { dateStyle: "medium", timeStyle: "short" });
                } catch {
                    return "";
                }
            };

            const loadStatus = async () => {
                if (!statusUrl) return;

                try {
                    const response = await fetch(statusUrl, {
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });

                    if (!response.ok) throw new Error("Unable to read Meta connection.");

                    const data = await response.json();
                    if (!data.connected) {
                        setConnectedState(false);
                        setStatus(data.message || "Meta Ads not connected for Parfait.", "warning");
                        return;
                    }

                    const account = data.accountName || data.accountId || "Meta account connected";
                    const user = data.metaUserName ? ` as ${data.metaUserName}` : "";
                    const expiry = data.accessTokenExpiresUtc ? ` · expires ${formatDate(data.accessTokenExpiresUtc)}` : "";
                    setConnectedState(true);
                    setStatus(`Connected: ${account}${user}${expiry}`, "success");
                } catch (error) {
                    console.error(error);
                    setConnectedState(false);
                    setStatus("Unable to read Meta connection.", "danger");
                }
            };

            const renderMetaCampaigns = data => {
                if (!metaCampaignsBody || !metaCampaignsTableWrap) return;

                metaCampaignsAccount && (metaCampaignsAccount.textContent = data.accountName || data.accountId || "Meta account connected");
                metaCampaignsSynced && (metaCampaignsSynced.textContent = data.syncedUtc ? formatDate(data.syncedUtc) : "—");
                metaCampaignsRange && (metaCampaignsRange.textContent = data.rangeLabel || "@Model.RangeLabel");
                metaCampaignsCount && (metaCampaignsCount.textContent = `${(data.rows || []).length} campaigns`);

                const rows = Array.isArray(data.rows) ? data.rows : [];
                if (!rows.length) {
                    metaCampaignsBody.innerHTML = "";
                    metaCampaignsTableWrap.hidden = true;
                    setMetaCampaignsState("No Meta campaign rows were returned for this range.", "warning");
                    return;
                }

                metaCampaignsBody.innerHTML = rows.map(row => `
                    <tr>
                        <td>
                            <strong>${escapeHtml(row.campaignName || "Unnamed campaign")}</strong>
                            <div class="text-muted">${escapeHtml(row.campaignId || "—")}</div>
                        </td>
                        <td>${escapeHtml(row.status || "—")}</td>
                        <td>${escapeHtml(row.objective || "—")}</td>
                        <td>${money(row.spend)}</td>
                        <td>${integer(row.impressions)}</td>
                        <td>${integer(row.reach)}</td>
                        <td>${integer(row.clicks)}</td>
                        <td>${percent(row.ctr)}</td>
                        <td>${money(row.cpc)}</td>
                        <td>${money(row.cpm)}</td>
                        <td>${Number(row.frequency || 0).toFixed(2)}</td>
                        <td>${integer(row.policiesPaid)}</td>
                        <td>${money(row.paidPremium)}</td>
                        <td>${Number(row.premiumRoas || 0).toFixed(2)}x</td>
                    </tr>
                `).join("");

                metaCampaignsTableWrap.hidden = false;
                setMetaCampaignsState("Shared Meta campaign reporting loaded.", "success");
            };

            const loadMetaCampaigns = async () => {
                if (!metaCampaignsUrl) return;

                try {
                    metaCampaignsTableWrap && (metaCampaignsTableWrap.hidden = true);
                    metaCampaignsBody && (metaCampaignsBody.innerHTML = "");
                    metaCampaignsCount && (metaCampaignsCount.textContent = "Loading");
                    setMetaCampaignsState("Loading Meta campaign reporting...", "info");

                    const response = await fetch(`${metaCampaignsUrl}?preset=@Model.SelectedPreset`, {
                        headers: { "X-Requested-With": "XMLHttpRequest" }
                    });

                    const payload = await response.json();
                    if (!response.ok) {
                        throw new Error(payload?.message || "Unable to load Meta campaigns.");
                    }

                    renderMetaCampaigns(payload);
                } catch (error) {
                    console.error(error);
                    metaCampaignsCount && (metaCampaignsCount.textContent = "Unavailable");
                    setMetaCampaignsState(error?.message || "Unable to load Meta campaigns.", "danger");
                }
            };

            const handleDisconnect = async () => {
                try {
                    const response = await fetch(disconnectUrl, {
                        method: "POST",
                        headers: {
                            "RequestVerificationToken": token,
                            "X-Requested-With": "XMLHttpRequest"
                        }
                    });

                    if (!response.ok) throw new Error("Failed to disconnect Meta Ads.");
                    await loadStatus();
                } catch (error) {
                    console.error(error);
                    setStatus(error?.message || "Failed to disconnect Meta Ads.", "danger");
                }
            };

            const showCallbackStatus = () => {
                try {
                    const url = new URL(window.location.href);
                    const meta = url.searchParams.get("meta");
                    if (!meta) return;

                    if (meta === "connected") {
                        setStatus("Meta Ads connected successfully.", "success");
                    } else if (meta === "error") {
                        setStatus(url.searchParams.get("message") || "Meta Ads connection failed.", "danger");
                    }

                    url.searchParams.delete("meta");
                    url.searchParams.delete("message");
                    window.history.replaceState({}, "", url.toString());
                } catch {
                }
            };

            const openModal = id => {
                const modal = document.getElementById(id);
                if (!modal) return;
                modal.classList.add("is-open");
                modal.setAttribute("aria-hidden", "false");
                document.body.style.overflow = "hidden";
            };

            const closeModal = modal => {
                if (!modal) return;
                modal.classList.remove("is-open");
                modal.setAttribute("aria-hidden", "true");

                if (!document.querySelector(".pf-analytics-modal.is-open")) {
                    document.body.style.overflow = "";
                }
            };

            document.querySelectorAll("[data-pf-open]").forEach(button => {
                button.addEventListener("click", () => {
                    const modalId = button.getAttribute("data-pf-open");
                    openModal(modalId);
                    if (modalId === "pfAnalyticsMetaCampaignsModal") {
                        void loadMetaCampaigns();
                    }
                });
            });

            document.querySelectorAll("[data-pf-close]").forEach(button => {
                button.addEventListener("click", () => closeModal(button.closest(".pf-analytics-modal")));
            });

            document.querySelectorAll(".pf-analytics-modal").forEach(modal => {
                modal.addEventListener("click", event => {
                    if (event.target === modal) closeModal(modal);
                });
            });

            document.addEventListener("keydown", event => {
                if (event.key !== "Escape") return;
                const modals = [...document.querySelectorAll(".pf-analytics-modal.is-open")];
                closeModal(modals.at(-1));
            });

            disconnectBtn?.addEventListener("click", handleDisconnect);
            showCallbackStatus();
            loadStatus();
        })();
    </script>
}
