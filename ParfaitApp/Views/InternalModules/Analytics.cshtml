                        <span>Connection</span>
                        <strong>@Model.MetaSettings.MetaConnectionLabel</strong>
                    </div>
                    <div>
                        <span>Pixel</span>
                        <strong>@Model.MetaSettings.MetaPixelStatus</strong>
                    </div>
                    <div>
                        <span>Dataset</span>
                        <strong>@Model.MetaSettings.DatasetStatus</strong>
                    </div>
                    <div>
                        <span>CAPI</span>
                        <strong>@Model.MetaSettings.MetaCapiStatus</strong>
                    </div>
                    <div>
                        <span>Account</span>
                        <strong>@(Model.MetaSettings.AccountName ?? Model.MetaSettings.AccountId ?? "—")</strong>
                    </div>
                    <div>
                        <span>Last Sync</span>
                        <strong>@Model.MetaSettings.LastSyncLabel</strong>
                    </div>
                </div>

                <div id="pfMetaConnectionStatus" class="small fw-semibold mt-3 @(Model.MetaSettings.HasActiveMetaAdsConnection ? "text-success" : "text-muted")">
                    @Model.MetaSettings.MetaConnectionLabel
                </div>

                <div class="pf-focus-actions mt-3">
                    <button type="submit" class="pf-action">Save Meta</button>
                    <a class="pf-secondary-action" id="pfMetaConnectButton" href="@metaConnectUrl">@(Model.MetaSettings.HasActiveMetaAdsConnection ? "Reconnect Meta" : "Connect Meta")</a>
                    <button id="pfMetaDisconnectButton"
                            type="button"
                            class="pf-secondary-action"
                            style="@(Model.MetaSettings.HasActiveMetaAdsConnection ? null : "display:none;")">
                        Disconnect
                    </button>
                </div>
            </form>
        </article>

        <article class="pf-module-card pf-span-12">
            <div class="pf-commerce-panel-head">
                <h2>Meta Diagnostics</h2>
                <span>@Model.MetaHealth.RangeLabel</span>
            </div>

            <div class="pf-focus-grid">
                <article class="pf-focus-card is-info pf-span-3">
                    <div class="pf-focus-label">Signal</div>
                    <h3 class="pf-focus-title">Recent Sends</h3>
                    <div class="pf-focus-value">@Model.MetaSignal.TotalSignalEvents</div>
                    <div class="pf-focus-list">
                        <div>
                            <span>Visitors</span>
                            <strong>@Model.MetaSignal.TotalVisitors</strong>
                        </div>
                        <div>
                            <span>High Intent</span>
                            <strong>@Model.MetaSignal.LeadReadyVisitors</strong>
                        </div>
                    </div>
                </article>

                <article class="pf-focus-card is-@(healthIssues.Count > 0 ? "warning" : "success") pf-span-3">
                    <div class="pf-focus-label">Pipeline</div>
                    <h3 class="pf-focus-title">Server Sends</h3>
                    <div class="pf-focus-value">@Model.MetaHealth.PipelineHealth.MetaServerSentCount</div>
                    <div class="pf-focus-list">
                        <div>
                            <span>Browser Events</span>
                            <strong>@Model.MetaHealth.PipelineHealth.MetaBrowserSentCount</strong>
                        </div>
                        <div>
                            <span>Dispatcher Window</span>
                            <strong>@Model.MetaHealth.DispatcherGraceMinutes min</strong>
                        </div>
                    </div>
                </article>

                <article class="pf-focus-card is-success pf-span-3">
                    <div class="pf-focus-label">Bridge</div>
