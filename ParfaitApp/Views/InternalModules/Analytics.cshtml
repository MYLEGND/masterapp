@{
    ViewData["Title"] = "Analytics";
    Layout = "_InternalLayout";
}

<section class="pf-panel mb-4">
    <div class="pf-kicker">Parfait Intelligence</div>
    <h1 class="pf-page-title">Analytics</h1>
    <p class="pf-page-copy">Future Parfait-owned reporting surface powered by shared visitor tracking, trust scoring, attribution, and Meta signal infrastructure.</p>
</section>

<section class="row g-4">
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Visitor Behavior</h2><p class="text-muted mb-0">Sessions, visitors, product views, scroll behavior, and engagement quality.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Commerce Funnel</h2><p class="text-muted mb-0">ProductViewed, AddToCart, CheckoutStarted, Purchase, revenue, and drop-off.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Meta Health</h2><p class="text-muted mb-0">Meta sent status, event match quality, CAPI dispatch, and attribution integrity.</p></div></div>
</section>
