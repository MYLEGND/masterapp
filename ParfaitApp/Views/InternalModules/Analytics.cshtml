@model ParfaitApp.Models.ParfaitInternalAnalyticsViewModel
@{
    ViewData["Title"] = "Analytics";
    Layout = "_InternalLayout";

    static string Money(int cents) => "$" + (cents / 100m).ToString("0.00");
    static string Rate(decimal value) => value.ToString("0.0") + "%";
    static string LocalTime(DateTime utc) => utc.ToLocalTime().ToString("M/d/yyyy h:mm tt");
    var analyticsReturnUrl = Url.Action("Analytics", "InternalModules", new { preset = Model.SelectedPreset }) ?? "/internal/analytics";
    var metaConnectUrl = Url.Action("MetaConnect", "InternalModules", new
    {
        returnUrl = analyticsReturnUrl
    }) ?? "/internal/analytics/meta-connect";

    var metaTone = Model.MetaSettings.HasActiveMetaAdsConnection ? "success" : "warning";
    var checkoutBreakdown = Model.ActionBreakdowns.FirstOrDefault(action => action.Key == "checkout-started");
    var purchaseBreakdown = Model.ActionBreakdowns.FirstOrDefault(action => action.Key == "purchase");
    var healthIssues = Model.MetaHealth.FailureDetection.Where(issue => issue.Count > 0).Take(6).ToList();
}

<link rel="stylesheet" href="~/css/parfait-agentportal-analytics.css" asp-append-version="true" />

<div class="container mt-4 mb-5 fa-shell parfait-analytics-shell">
    <section class="wa-command-surface mb-3">
        <div class="wa-command-dashboard">
            <div class="wa-page-header">
                <div class="wa-header-copy">
                    <div class="wa-header-kicker">Parfait · Ecommerce Performance Intelligence</div>
                    <h2 class="wa-header-title">Analytics</h2>
                    <p class="wa-header-sub">Storefront performance overview · <strong>@Model.RangeLabel</strong></p>
                </div>
                <div class="wa-header-right">
                    <div class="wa-header-rail-meta">
                        <div class="fa-env-badge">Environment: Parfait Ecommerce</div>
                        <button class="btn btn-sm wa-meta-signal-health-btn" type="button" data-bs-toggle="modal" data-bs-target="#pfMetaHealthModal">
                            Meta Signal Health
                        </button>
                    </div>
                </div>
            </div>

            <div class="control-bar">
                <div class="control-bar-group control-bar-presets">
                    <div class="control-bar-label">Quick Range</div>
                    <div class="btn-group btn-group-sm flex-shrink-0" role="group">
                        <a class="btn btn-range @(Model.SelectedPreset=="today"?"active":"")" href="@Url.Action("Analytics", "InternalModules", new { preset = "today" })">Today</a>
                        <a class="btn btn-range @(Model.SelectedPreset=="7d"?"active":"")" href="@Url.Action("Analytics", "InternalModules", new { preset = "7d" })">7 Days</a>
                        <a class="btn btn-range @(Model.SelectedPreset=="30d"?"active":"")" href="@Url.Action("Analytics", "InternalModules", new { preset = "30d" })">30 Days</a>
                        <a class="btn btn-range @(Model.SelectedPreset=="month"?"active":"")" href="@Url.Action("Analytics", "InternalModules", new { preset = "month" })">Month</a>
                        <a class="btn btn-range @(Model.SelectedPreset=="year"?"active":"")" href="@Url.Action("Analytics", "InternalModules", new { preset = "year" })">Year</a>
                    </div>
                </div>
                <div class="control-bar-group control-bar-status">
                    <div class="control-bar-label">Status</div>
                    <div class="control-bar-status-text">Shared analytics backend · ecommerce scoped</div>
                </div>
            </div>
        </div>
    </section>

    @if (TempData["AnalyticsStatus"] is string analyticsStatus)
    {
        <div class="alert alert-success">@analyticsStatus</div>
    }

    <section class="wa-command-surface wa-kpi-command-surface mb-3" aria-labelledby="wa-kpi-title">
        <div class="wa-kpi-stage-intro">
            <div>
                <div class="wa-kpi-stage-kicker">Performance Command Deck</div>
                <h3 class="wa-kpi-stage-title" id="wa-kpi-title">Core Metrics</h3>
                <p class="wa-kpi-stage-sub">Traffic, revenue, checkout movement, and Meta signal coverage.</p>
            </div>

            <div class="wa-kpi-stage-meta">
                <div class="wa-kpi-meta-dock">
                    <div class="wa-kpi-meta-copy">
                        <div class="wa-kpi-meta-kicker">Meta Ads</div>
                        <div class="wa-kpi-meta-status" id="meta-connection-status">Checking connection…</div>
                    </div>
                    <div class="wa-kpi-meta-actions hero-link-meta-actions">
                        <a class="btn btn-gold hero-link-meta-btn wa-kpi-meta-btn"
                           href="https://adsmanager.facebook.com/adsmanager/manage/campaigns"
                           id="openMetaAdsManagerLink"
                           target="_blank"
                           rel="noopener">
                            Ads Manager
                        </a>
                        <button type="button"
                                class="btn btn-outline-light hero-link-meta-btn wa-kpi-meta-btn"
                                id="meta-campaigns-open"
                                data-bs-toggle="modal"
                                data-bs-target="#pfMetaCampaignsModal">
                            Campaigns
                        </button>
                        <a class="btn btn-outline-light hero-link-meta-btn wa-kpi-meta-btn"
                           id="meta-connect-btn"
                           href="@metaConnectUrl">
                            @(Model.MetaSettings.HasActiveMetaAdsConnection ? "Reconnect Meta Ads" : "Connect Meta Ads")
                        </a>
                        <button type="button"
                                class="btn btn-outline-light hero-link-meta-btn wa-kpi-meta-btn"
                                id="meta-disconnect-btn"
                                style="display:none;">
                            Disconnect
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="wa-kpi-band wa-kpi-band-primary">
            <div class="wa-kpi-band-head">
                <div class="wa-kpi-band-label">Traffic Pulse</div>
                <div class="wa-kpi-band-copy">High-signal ecommerce readouts</div>
            </div>
            <div class="fa-kpi-grid fa-kpi-grid-primary">
                <div><div class="kpi-card kpi-card-primary"><div class="fa-kpi-title">Page Views</div><div class="fa-kpi-value">@Model.Summary.PageViews</div><div class="fa-kpi-sub">Store traffic</div></div></div>
                <div><div class="kpi-card kpi-card-primary"><div class="fa-kpi-title">Visitors</div><div class="fa-kpi-value">@Model.Visitors</div><div class="fa-kpi-sub">@Model.NewCustomers new · @Model.ReturningCustomers returning</div></div></div>
                <div><div class="kpi-card kpi-card-primary"><div class="fa-kpi-title">Sessions</div><div class="fa-kpi-value">@Model.Summary.Sessions</div><div class="fa-kpi-sub">Storefront journeys</div></div></div>
                <div><div class="kpi-card kpi-card-primary"><div class="fa-kpi-title">Purchases</div><div class="fa-kpi-value">@Model.Purchases</div><div class="fa-kpi-sub">Completed orders</div></div></div>
            </div>
        </div>

        <div class="wa-kpi-band wa-kpi-band-secondary">
            <div class="wa-kpi-band-head">
                <div class="wa-kpi-band-label">Conversion + Revenue</div>
                <div class="wa-kpi-band-copy">Commerce context and checkout health</div>
            </div>
            <div class="fa-kpi-grid fa-kpi-grid-secondary">
                <div><div class="kpi-card kpi-card-secondary kpi-card-conversion"><div class="fa-kpi-title">Revenue</div><div class="fa-kpi-value">@Money(Model.RevenueCents)</div><div class="fa-kpi-sub">Net tracked revenue</div></div></div>
                <div><div class="kpi-card kpi-card-secondary kpi-card-conversion"><div class="fa-kpi-title">Checkout Conversion</div><div class="fa-kpi-value">@Rate(checkoutBreakdown?.ConversionRate ?? 0m)</div><div class="fa-kpi-sub">Checkout started → purchase</div></div></div>
                <div><div class="kpi-card kpi-card-secondary kpi-card-context"><div class="fa-kpi-title">Average Order Value</div><div class="fa-kpi-value">@Money(Model.AverageOrderValueCents)</div><div class="fa-kpi-sub">@Model.Orders orders</div></div></div>
                <div><div class="kpi-card kpi-card-secondary kpi-card-context"><div class="fa-kpi-title">Cart Abandonment</div><div class="fa-kpi-value">@Model.CartAbandonmentSessions</div><div class="fa-kpi-sub">Sessions with checkout friction</div></div></div>
            </div>
        </div>
    </section>

    <section class="wa-command-surface wa-workbench-surface mb-4" aria-labelledby="wa-workbench-title">
        <div class="wa-workbench-intro">
            <div>
                <div class="wa-workbench-kicker">Action Workbench</div>
                <h3 class="wa-workbench-title" id="wa-workbench-title">Analysis Modules</h3>
                <p class="wa-workbench-sub">Open ecommerce intelligence layers using the same AgentPortal module system.</p>
            </div>
            <div class="wa-workbench-actions">
                <div class="wa-workbench-chip">Open any module to launch its deep dive</div>
            </div>
        </div>

        <div class="wa-module-band wa-module-band-primary">
            <div class="wa-module-band-head">
                <div class="wa-module-band-label">Priority Modules</div>
                <div class="wa-module-band-copy">Core ecommerce diagnosis and conversion reads</div>
            </div>

            <div class="fa-modules fa-modules-priority">
                <div class="fa-module fa-module-feature fa-module-signal" role="button" tabindex="0" data-bs-toggle="modal" data-bs-target="#pfMetaSignalModal">
                    <div class="fa-module-head"><div><h5>Meta Signal Intelligence</h5></div></div>
                    <div class="fa-module-meta">@Model.MetaSignal.TotalSignalEvents signal events · @Model.MetaSignal.RecentDiagnostics.Count diagnostics</div>
                    <div class="fa-trend-bar"></div>
                </div>
                <div class="fa-module fa-module-feature fa-module-behavior" role="button" tabindex="0" data-bs-toggle="modal" data-bs-target="#pfBehaviorModal">
                    <div class="fa-module-head"><div><h5>Behavior Intelligence</h5></div></div>
                    <div class="fa-module-meta">Dwell time, exits, journey and source attribution</div>
                    <div class="fa-trend-bar"></div>
                </div>
                <div class="fa-module fa-module-feature fa-module-quote" role="button" tabindex="0" data-bs-toggle="modal" data-bs-target="#pfCommerceFunnelModal">
                    <div class="fa-module-head"><div><h5>Commerce Funnel</h5></div></div>
                    <div class="fa-module-meta">Product views → add to cart → checkout → purchase</div>
                    <div class="fa-trend-bar"></div>
                </div>
                <div class="fa-module fa-module-feature" role="button" tabindex="0" data-bs-toggle="modal" data-bs-target="#pfDeviceModal">
                    <div class="fa-module-head"><div><h5>Device Intelligence</h5></div></div>
                    <div class="fa-module-meta">Device, browser, OS, language, timezone behavior</div>
                    <div class="fa-trend-bar"></div>
                </div>
                <div class="fa-module fa-module-feature fa-module-conv" role="button" tabindex="0" data-bs-toggle="modal" data-bs-target="#pfRawEventsModal">
                    <div class="fa-module-head"><div><h5>Order + Event Inspector</h5></div></div>
                    <div class="fa-module-meta">@Model.RecentEvents.Count recent events · @Model.RecentOrders.Count recent orders</div>
                    <div class="fa-trend-bar"></div>
                </div>
            </div>
        </div>

        <div class="wa-module-band wa-module-band-secondary">
            <div class="wa-module-band-head">
                <div class="wa-module-band-label">Supporting Drill-Ins</div>
                <div class="wa-module-band-copy">Traffic, products, pages, and attribution reviews</div>
            </div>

            <div class="fa-modules fa-modules-support">
                <div class="fa-module fa-module-support" role="button" tabindex="0" data-bs-toggle="modal" data-bs-target="#pfTrafficModal"><div class="fa-module-head"><div><h5>Traffic Overview</h5></div></div><div class="fa-module-meta">@Model.Traffic.TopPages.Count top pages · @Model.Traffic.RecentActivity.Count recent rows</div><div class="fa-trend-bar"></div></div>
                <div class="fa-module fa-module-support" role="button" tabindex="0" data-bs-toggle="modal" data-bs-target="#pfProductsModal"><div class="fa-module-head"><div><h5>Products Snapshot</h5></div></div><div class="fa-module-meta">@Model.TopProducts.Count product rows</div><div class="fa-trend-bar"></div></div>
                <div class="fa-module fa-module-support" role="button" tabindex="0" data-bs-toggle="modal" data-bs-target="#pfPageModal"><div class="fa-module-head"><div><h5>Page Performance</h5></div></div><div class="fa-module-meta">@Model.PagePerformance.Rows.Count pages · @Model.CtaPerformance.Rows.Count CTA rows</div><div class="fa-trend-bar"></div></div>
                <div class="fa-module fa-module-support" role="button" tabindex="0" data-bs-toggle="modal" data-bs-target="#pfSourceModal"><div class="fa-module-head"><div><h5>Source Attribution</h5></div></div><div class="fa-module-meta">@Model.Sources.Rows.Count source rows · @Model.Traffic.TopCampaigns.Count campaigns</div><div class="fa-trend-bar"></div></div>
                <div class="fa-module fa-module-support" role="button" tabindex="0" data-bs-toggle="modal" data-bs-target="#pfRecentOrdersModal"><div class="fa-module-head"><div><h5>Recent Orders</h5></div></div><div class="fa-module-meta">@Model.RecentOrders.Count tracked orders</div><div class="fa-trend-bar"></div></div>
            </div>
        </div>
    </section>

    <section class="wa-command-surface wa-health-surface wa-kpi-band-health mb-4" aria-labelledby="marketing-health-title">
        <div class="wa-health-hero">
            <div class="wa-health-copy">
                <div class="wa-health-kicker-row">
                    <div class="wa-kpi-band-label" id="marketing-health-title">Marketing Health Center</div>
                    <div class="wa-health-live-pill">Ecommerce Diagnostic Surface</div>
                </div>
                <div class="wa-health-heading">Tracking integrity, attribution clarity, and checkout-pipeline reliability</div>
                <div class="wa-health-subcopy">Production readout for storefront telemetry, Meta signal health, checkout movement, and source confidence.</div>
                <div class="wa-health-meta">
                    <span class="wa-health-pill">Range <strong>@Model.MetaHealth.RangeLabel</strong></span>
                    <span class="wa-health-pill">Failures <strong>@healthIssues.Sum(issue => issue.Count)</strong></span>
                </div>
                <div class="wa-health-focus-strip">
                    <span class="wa-health-focus-pill">Browser Tracking</span>
                    <span class="wa-health-focus-pill">Checkout Handoff</span>
                    <span class="wa-health-focus-pill">Attribution Confidence</span>
                </div>
            </div>
            <div class="wa-health-summary">
                <div class="wa-health-summary-card">
                    <div class="wa-health-score-wrap">
                        <div class="wa-health-score-label">Signal Events</div>
                        <div class="wa-health-score">@Model.MetaSignal.TotalSignalEvents</div>
                    </div>
                    <div class="wa-health-verdict">@(healthIssues.Count == 0 ? "Healthy" : "Review")</div>
                </div>
                <div class="wa-health-summary-note">Read-only. This surface does not write events or alter Meta dispatch behavior.</div>
            </div>
        </div>

        <div class="wa-health-grid">
            <div class="kpi-card kpi-card-secondary wa-health-metric is-risk"><div class="wa-health-metric-kicker">Meta Pipeline</div><div class="fa-kpi-title">Server Sent</div><div class="fa-kpi-value">@Model.MetaHealth.PipelineHealth.MetaServerSentCount</div><div class="fa-kpi-sub">CAPI events in range</div></div>
            <div class="kpi-card kpi-card-secondary wa-health-metric is-funnel"><div class="wa-health-metric-kicker">Browser Pixel</div><div class="fa-kpi-title">Browser Sent</div><div class="fa-kpi-value">@Model.MetaHealth.PipelineHealth.MetaBrowserSentCount</div><div class="fa-kpi-sub">Browser signal volume</div></div>
            <div class="kpi-card kpi-card-secondary wa-health-metric is-confirmed"><div class="wa-health-metric-kicker">Bridge</div><div class="fa-kpi-title">Owned Rows</div><div class="fa-kpi-value">@Model.MetaHealth.PipelineHealth.BridgeOwnedMetaSignalEventsLast24Hours</div><div class="fa-kpi-sub">Bridge-owned rows last 24h</div></div>
            <div class="kpi-card kpi-card-secondary wa-health-metric is-success"><div class="wa-health-metric-kicker">Analytics</div><div class="fa-kpi-title">Events 24h</div><div class="fa-kpi-value">@Model.MetaHealth.PipelineHealth.AnalyticsEventsLast24Hours</div><div class="fa-kpi-sub">Shared analytics events</div></div>
            <div class="kpi-card kpi-card-secondary wa-health-metric is-alert"><div class="wa-health-metric-kicker">Watchlist</div><div class="fa-kpi-title">Failures</div><div class="fa-kpi-value">@healthIssues.Sum(issue => issue.Count)</div><div class="fa-kpi-sub">Issues requiring review</div></div>
            <div class="kpi-card kpi-card-secondary wa-health-metric is-attribution"><div class="wa-health-metric-kicker">Meta Account</div><div class="fa-kpi-title">Connection</div><div class="fa-kpi-value" style="font-size:1.15rem;">@(Model.MetaSettings.HasActiveMetaAdsConnection ? "Live" : "Pending")</div><div class="fa-kpi-sub">@((Model.MetaSettings.AccountName ?? Model.MetaSettings.AccountId) ?? "No account")</div></div>
        </div>
    </section>
</div>

@* MODALS *@
<div class="modal fade fa-modal parfait-analytics-modal" id="pfTrafficModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Traffic Layer</div><h5 class="modal-title mb-0">Traffic Overview</h5><div class="wa-modal-subtitle">Top pages, entry pages, sources, campaigns, and recent storefront activity.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body">
        <section class="wa-modal-section">
          <div class="row row-cols-2 row-cols-lg-3 g-2 mb-3">
            <div class="col"><div class="kpi-card"><div class="fa-kpi-title">Paid Sessions</div><div class="fa-kpi-value">@Model.Traffic.PaidSessionCount</div></div></div>
            <div class="col"><div class="kpi-card"><div class="fa-kpi-title">Non-Paid Sessions</div><div class="fa-kpi-value">@Model.Traffic.NonPaidSessionCount</div></div></div>
            <div class="col"><div class="kpi-card"><div class="fa-kpi-title">Unknown Sessions</div><div class="fa-kpi-value">@Model.Traffic.UnknownSessionCount</div></div></div>
          </div>
          <div class="table-responsive"><table class="table table-sm"><thead><tr><th>Time</th><th>Event</th><th>Page</th><th>Summary</th><th>Outcome</th></tr></thead><tbody>
          @foreach (var row in Model.Traffic.RecentActivity.Take(18)) { <tr><td>@LocalTime(row.EventUtc)</td><td><strong>@row.EventType</strong></td><td>@(row.PageKey ?? "—")</td><td>@(row.ActivitySummary ?? "—")</td><td>@(row.OutcomeSummary ?? "—")</td></tr> }
          </tbody></table></div>
        </section>
      </div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfProductsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Commerce Layer</div><h5 class="modal-title mb-0">Products Snapshot</h5><div class="wa-modal-subtitle">Product revenue, units sold, and product-view activity.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body"><section class="wa-modal-section"><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Product</th><th>Revenue</th><th>Units</th><th>Views</th></tr></thead><tbody>
      @foreach (var row in Model.TopProducts) { <tr><td><strong>@row.ProductName</strong></td><td>@Money(row.RevenueCents)</td><td>@row.UnitsSold</td><td>@row.ProductViews</td></tr> }
      </tbody></table></div></section></div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfPageModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Page Layer</div><h5 class="modal-title mb-0">Page + CTA Performance</h5><div class="wa-modal-subtitle">Page views, CTA clicks, and conversion movement.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body"><section class="wa-modal-section"><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Page</th><th>Views</th><th>CTA Clicks</th><th>Conversions</th><th>Conversion</th></tr></thead><tbody>
      @foreach (var row in Model.PagePerformance.Rows.Take(24)) { <tr><td><strong>@row.PageKey</strong></td><td>@row.Views</td><td>@row.CtaClicks</td><td>@row.Leads</td><td>@Rate(row.ConversionRate)</td></tr> }
      </tbody></table></div></section></div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfSourceModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Attribution Layer</div><h5 class="modal-title mb-0">Source Attribution</h5><div class="wa-modal-subtitle">Session source, campaign, landing, engagement, and conversion readiness.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body"><section class="wa-modal-section"><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Source</th><th>Medium</th><th>Campaign</th><th>Landing</th><th>Sessions</th><th>Conversion</th></tr></thead><tbody>
      @foreach (var row in Model.Sources.Rows.Take(30)) { <tr><td><strong>@row.Source</strong></td><td>@(row.Medium ?? "—")</td><td>@(row.Campaign ?? "—")</td><td>@(row.LandingPage ?? "—")</td><td>@row.Sessions</td><td>@Rate(row.SessionConversionRate)</td></tr> }
      </tbody></table></div></section></div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfCommerceFunnelModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Commerce Funnel</div><h5 class="modal-title mb-0">Product → Cart → Checkout → Purchase</h5><div class="wa-modal-subtitle">Ecommerce action breakdowns from the existing Parfait analytics model.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body">
        <section class="wa-modal-section">
          <div class="row row-cols-2 row-cols-lg-4 g-2 mb-3">
          @foreach (var action in Model.ActionBreakdowns)
          {
              <div class="col"><div class="kpi-card"><div class="fa-kpi-title">@action.Label</div><div class="fa-kpi-value">@action.Count</div><div class="fa-kpi-sub">@action.UniqueSessions sessions · @action.UniqueVisitors visitors</div></div></div>
          }
          </div>
        </section>
      </div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfBehaviorModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Journey Read</div><h5 class="modal-title mb-0">Behavior Intelligence</h5><div class="wa-modal-subtitle">Dwell time, exits, scroll depth, landing pages, and drop-off pressure.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body"><section class="wa-modal-section"><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Page</th><th>Views</th><th>Exits</th><th>Exit Rate</th></tr></thead><tbody>
      @foreach (var row in Model.ExitAnalysis.TopExitPages.Take(24)) { <tr><td><strong>@row.PageKey</strong></td><td>@row.Views</td><td>@row.Exits</td><td>@Rate(row.ExitRate)</td></tr> }
      </tbody></table></div></section></div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfDeviceModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Device Layer</div><h5 class="modal-title mb-0">Device Intelligence</h5><div class="wa-modal-subtitle">Device, browser, operating system, language, and timezone behavior.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body"><section class="wa-modal-section"><div class="row row-cols-1 row-cols-lg-3 g-3">
        <div class="col"><div class="kpi-card"><div class="fa-kpi-title">Devices</div>@foreach (var row in Model.Devices.Devices.Take(8)) { <div>@row.Label · <strong>@row.Sessions</strong></div> }</div></div>
        <div class="col"><div class="kpi-card"><div class="fa-kpi-title">Browsers</div>@foreach (var row in Model.Devices.Browsers.Take(8)) { <div>@row.Label · <strong>@row.Events</strong></div> }</div></div>
        <div class="col"><div class="kpi-card"><div class="fa-kpi-title">Operating Systems</div>@foreach (var row in Model.Devices.OperatingSystems.Take(8)) { <div>@row.Label · <strong>@row.Sessions</strong></div> }</div></div>
      </div></section></div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfMetaSignalModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Meta Ecommerce Signal</div><h5 class="modal-title mb-0">Meta Signal Intelligence</h5><div class="wa-modal-subtitle">Bridge coverage, deduplication, event ladder, friction hotspots, and recent diagnostics.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body"><section class="wa-modal-section"><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Event</th><th>Traffic</th></tr></thead><tbody>
      @foreach (var row in Model.MetaSignal.RecentDiagnostics.Take(18)) { <tr><td><strong>@row.EventName</strong></td><td>@row.TrafficType</td></tr> }
      </tbody></table></div></section></div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfMetaCampaignsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Meta Ads</div><h5 class="modal-title mb-0">Meta Campaigns</h5><div class="wa-modal-subtitle">Spend, clicks, CTR, CPC, CPM, purchases, revenue, and ROAS.</div></div><div class="wa-modal-header-actions"><div class="wa-modal-range-chip d-none" id="meta-campaigns-account-chip">Not connected</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body"><section class="wa-modal-section"><div class="row row-cols-1 row-cols-lg-3 g-2 mb-3">
        <div class="col"><div class="kpi-card"><div class="fa-kpi-title">Account</div><div class="fa-kpi-value" id="pf-meta-campaign-account-value" style="font-size:1.1rem;">@((Model.MetaSettings.AccountName ?? Model.MetaSettings.AccountId) ?? "Not connected")</div></div></div>
        <div class="col"><div class="kpi-card"><div class="fa-kpi-title">Business</div><div class="fa-kpi-value" id="pf-meta-campaign-business-value" style="font-size:1.1rem;">@((Model.MetaSettings.BusinessName ?? Model.MetaSettings.BusinessId) ?? "—")</div></div></div>
        <div class="col"><div class="kpi-card"><div class="fa-kpi-title">Last Sync</div><div class="fa-kpi-value" id="pf-meta-campaign-sync-value" style="font-size:1.1rem;">@Model.MetaSettings.LastSyncLabel</div></div></div>
      </div></section></div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfMetaHealthModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Diagnostic Layer</div><h5 class="modal-title mb-0">Meta Signal Health Dashboard</h5><div class="wa-modal-subtitle">Read-only visibility into bridge coverage, dispatcher execution, and authority outcomes.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body"><section class="wa-modal-section"><div class="table-responsive"><table class="table table-sm"><thead><tr><th>When</th><th>Event</th><th>Source</th><th>Status</th></tr></thead><tbody>
      @foreach (var row in Model.MetaHealth.RecentEvents.Take(20)) { <tr><td>@LocalTime(row.CreatedUtc)</td><td><strong>@row.EventName</strong></td><td>@row.SourceLabel</td><td>@row.DispatcherStatus / @row.MetaServerStatus</td></tr> }
      </tbody></table></div></section></div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfRecentOrdersModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Orders</div><h5 class="modal-title mb-0">Recent Orders</h5><div class="wa-modal-subtitle">Latest tracked orders in the selected analytics window.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body"><section class="wa-modal-section"><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Order</th><th>Customer</th><th>Net</th><th>Status</th></tr></thead><tbody>
      @foreach (var row in Model.RecentOrders) { <tr><td><strong>@row.OrderNumber</strong><div class="text-muted">@LocalTime(row.CreatedUtc)</div></td><td><strong>@row.CustomerName</strong><div class="text-muted">@row.Email</div></td><td>@Money(row.NetRevenueCents)</td><td>@row.PaymentStatus / @row.FulfillmentStatus</td></tr> }
      </tbody></table></div></section></div>
    </div>
  </div>
</div>

<div class="modal fade fa-modal parfait-analytics-modal" id="pfRawEventsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable wa-modal-dialog">
    <div class="modal-content wa-modal-shell">
      <div class="modal-header wa-modal-header"><div class="wa-modal-header-main"><div class="wa-modal-header-copy"><div class="wa-modal-kicker">Raw Inspector</div><h5 class="modal-title mb-0">Recent Analytics Events</h5><div class="wa-modal-subtitle">Normalized event rows from the Parfait ecommerce funnel.</div></div></div><button type="button" class="btn-close btn-close-white wa-modal-close" data-bs-dismiss="modal"></button></div>
      <div class="modal-body wa-modal-body"><section class="wa-modal-section"><div class="table-responsive"><table class="table table-sm"><thead><tr><th>Time</th><th>Event</th><th>Page</th><th>Product</th><th>Value</th></tr></thead><tbody>
      @foreach (var row in Model.RecentEvents.Take(30)) { <tr><td>@LocalTime(row.EventUtc)</td><td><strong>@row.EventType</strong></td><td>@(row.PageKey ?? "—")</td><td>@(row.ProductName ?? "—")</td><td>@(row.ValueCents.HasValue ? Money(row.ValueCents.Value) : "—")</td></tr> }
      </tbody></table></div></section></div>
    </div>
  </div>
</div>

<form id="meta-disconnect-form" method="post" class="d-none">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <script src="~/js/parfait-agentportal-analytics.js" asp-append-version="true"></script>
}
