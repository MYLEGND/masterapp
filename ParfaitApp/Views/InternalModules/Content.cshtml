@model ParfaitApp.Models.ParfaitInternalWorkspaceSnapshotViewModel
@{
    ViewData["Title"] = "Content";
    Layout = "_InternalLayout";

    var mediaTone = Model.ProductImageCount > 0 ? "info" : "warning";
}

<section class="pf-command-page">
    <header class="pf-command-head">
        <div class="pf-command-copy">
            <h1 class="pf-command-title">Content</h1>
            <p class="pf-command-text">Product count, featured assortment, and image coverage.</p>
        </div>
        <div class="pf-command-meta">
            <span class="pf-command-badge is-info">@Model.ProductCount products</span>
            <span class="pf-command-badge is-success">@Model.FeaturedProductCount featured</span>
            <span class="pf-command-badge is-@mediaTone">@Model.ProductImageCount images</span>
        </div>
    </header>

    <section class="pf-command-rail">
        <article class="pf-rail-card is-info pf-span-4">
            <div class="pf-rail-label">Catalog Layer</div>
            <strong class="pf-rail-value">@Model.ProductCount</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Live Products</span>
                    <strong>@Model.ActiveProductCount</strong>
                </div>
                <div>
                    <span>Business Type</span>
                    <strong>@Model.BusinessType</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-success pf-span-4">
            <div class="pf-rail-label">Featured Focus</div>
            <strong class="pf-rail-value">@Model.FeaturedProductCount</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Orders Backing Story</span>
                    <strong>@Model.OrderCount</strong>
                </div>
                <div>
                    <span>Store Views</span>
                    <strong>@Model.StoreViews</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-@mediaTone pf-span-4">
            <div class="pf-rail-label">Media Coverage</div>
            <strong class="pf-rail-value">@Model.ProductImageCount</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Featured Items</span>
                    <strong>@Model.FeaturedProductCount</strong>
                </div>
                <div>
                    <span>Visitors</span>
                    <strong>@Model.Visitors</strong>
                </div>
            </div>
        </article>
    </section>

    <section class="pf-command-board">
        <div class="pf-command-board-head">
            <div>
                <h2>Catalog Storytelling</h2>
                <p>Catalog presentation across featured products and media.</p>
            </div>
            <div class="pf-command-board-actions">
                <a class="pf-secondary-action" href="/internal/commerce/products">Products</a>
            </div>
        </div>

        <div class="pf-focus-grid">
            <article class="pf-focus-card is-info pf-span-4">
                <div class="pf-focus-label">What Exists</div>
                <h3 class="pf-focus-title">Product Library</h3>
                <div class="pf-focus-value">@Model.ProductCount</div>
                <p class="pf-focus-copy">Total catalog and live assortment.</p>
                <div class="pf-focus-list">
                    <div>
                        <span>Active Products</span>
                        <strong>@Model.ActiveProductCount</strong>
                    </div>
                    <div>
                        <span>Business Type</span>
                        <strong>@Model.BusinessType</strong>
                    </div>
                </div>
            </article>

            <article class="pf-focus-card is-success pf-span-4">
                <div class="pf-focus-label">What Leads</div>
                <h3 class="pf-focus-title">Featured Mix</h3>
                <div class="pf-focus-value">@Model.FeaturedProductCount</div>
                <p class="pf-focus-copy">Featured assortment ready for storefront placement.</p>
                <div class="pf-focus-list">
                    <div>
                        <span>Orders</span>
                        <strong>@Model.OrderCount</strong>
                    </div>
                    <div>
                        <span>Purchases</span>
                        <strong>@Model.Purchases</strong>
                    </div>
                </div>
            </article>

            <article class="pf-focus-card is-@mediaTone pf-span-4">
                <div class="pf-focus-label">What Shows</div>
                <h3 class="pf-focus-title">Image Coverage</h3>
                <div class="pf-focus-value">@Model.ProductImageCount</div>
                <p class="pf-focus-copy">Photo coverage across the catalog.</p>
                <div class="pf-focus-list">
                    <div>
                        <span>Store Views</span>
                        <strong>@Model.StoreViews</strong>
                    </div>
                    <div>
                        <span>Visitors</span>
                        <strong>@Model.Visitors</strong>
                    </div>
                </div>
            </article>
        </div>
    </section>
</section>
