@{
    ViewData["Title"] = "Content";
    Layout = "_InternalLayout";
}

<section class="pf-page-hero">
    <div class="pf-page-hero-main">
        <div class="pf-kicker">Brand Control</div>
        <h1 class="pf-page-title">Content</h1>
        <p class="pf-page-copy">Products, collections, creative assets, and brand storytelling all route through this workspace.</p>
    </div>
</section>

<section class="row g-4">
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Product Content</h2><p class="text-muted mb-0">Manage product names, descriptions, fit notes, care details, and brand copy.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Creative Assets</h2><p class="text-muted mb-0">Organize photos, videos, banners, campaign visuals, and product media.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Site Content</h2><p class="text-muted mb-0">Prepare future editable homepage, training, store, and brand sections.</p></div></div>
</section>
