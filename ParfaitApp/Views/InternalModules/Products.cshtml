<script>
    (() => {
        const modalSelector = ".pf-product-modal, .pf-image-editor-modal";
        const openModalSelector = ".pf-product-modal.is-open, .pf-image-editor-modal.is-open";

        const syncBodyOverflow = () => {
            document.body.style.overflow = document.querySelector(openModalSelector) ? "hidden" : "";
        };

        const openModal = id => {
            const modal = document.getElementById(id);
            if (!modal) return;
            modal.classList.add("is-open");
            modal.setAttribute("aria-hidden", "false");
            syncBodyOverflow();
        };

        const closeModal = modal => {
            if (!modal) return;
            modal.classList.remove("is-open");
            modal.setAttribute("aria-hidden", "true");
            syncBodyOverflow();
        };

        document.addEventListener("click", event => {
            const openTrigger = event.target.closest("[data-pf-open]");
            if (openTrigger) {
                openModal(openTrigger.getAttribute("data-pf-open"));
                return;
            }

            const closeTrigger = event.target.closest("[data-pf-close]");
            if (closeTrigger) {
                closeModal(closeTrigger.closest(modalSelector));
                return;
            }

            if (event.target.matches(modalSelector)) {
                closeModal(event.target);
            }
        });

        document.addEventListener("keydown", event => {
            if (event.key !== "Escape") return;
            const modals = [...document.querySelectorAll(openModalSelector)];
            closeModal(modals.at(-1));
        });

        window.pfModalUi = {
            openModal,
            closeModal,
            syncBodyOverflow
        };
    })();
</script>

<script>
    (() => {
        const slugify = value => (value || "")
            .trim()
            .toUpperCase()
            .replace(/[^A-Z0-9]+/g, "-")
            .replace(/^-+|-+$/g, "")
            .slice(0, 10) || "PARFAIT";

        const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
        const inventoryTemplate = document.getElementById("pfInventoryRowTemplate");
        const discountTemplate = document.getElementById("pfDiscountRowTemplate");
        const saveStates = new WeakMap();
        const liveFieldSelector = 'input[type="text"], input[type="number"], textarea';

        const getFormState = form => {
            let state = saveStates.get(form);
            if (!state) {
                state = {
                    timer: 0,
                    statusTimer: 0,
                    saving: false,
                    queued: false,
                    queuedRefresh: false
                };
                saveStates.set(form, state);
            }

            return state;
        };

        const syncMoneyInput = input => {
            const hidden = input.parentElement?.querySelector(".pf-money-hidden");
            if (!hidden) return;

            hidden.value = Math.round(Number(input.value || 0) * 100).toString();
        };

        const syncMoneyWithin = root => {
            root.querySelectorAll(".pf-money-display").forEach(syncMoneyInput);
        };

        const updateInventoryRow = row => {
            if (!row) return;

            const enabled = row.querySelector("[data-pf-enabled]")?.checked ?? false;
            const stock = Number(row.querySelector("[data-pf-stock]")?.value || 0);
            const threshold = Math.max(1, Number(row.querySelector("[data-pf-low-stock]")?.value || 1));
            const status = row.querySelector("[data-pf-inventory-status]");

            let tone = "is-success";
            let label = "Ready";

            if (!enabled) {
                tone = "is-muted";
                label = "Hidden";
            } else if (stock <= 0) {
                tone = "is-danger";
                label = "Sold Out";
            } else if (stock <= threshold) {
                tone = "is-warning";
                label = `${stock} Left`;
            } else {
                tone = "is-success";
                label = `${stock} Ready`;
            }

            row.classList.remove("is-success", "is-warning", "is-danger", "is-info", "is-muted");
            row.classList.add(tone);

            if (status) {
                status.classList.remove("is-success", "is-warning", "is-danger", "is-info", "is-muted");
                status.classList.add(tone);
                status.textContent = label;
            }
        };

        const reindexCollection = container => {
            if (!container) return;

            const prefix = container.getAttribute("data-pf-collection");
            const rows = [...container.querySelectorAll("[data-pf-repeat-item]")];

            rows.forEach((row, index) => {
                row.querySelectorAll("[data-field]").forEach(field => {
                    const property = field.getAttribute("data-field");
                    field.name = `${prefix}[${index}].${property}`;
                });

                const orderInput = row.querySelector("[data-pf-order]");
                if (orderInput) {
                    orderInput.value = ((index + 1) * 10).toString();
                }

                if (row.hasAttribute("data-pf-inventory-row")) {
                    updateInventoryRow(row);
                }
            });
        };

        const addRow = (targetId, template) => {
            const container = document.getElementById(targetId);
            if (!container || !template) return null;

            const fragment = template.content.cloneNode(true);
            container.appendChild(fragment);
            reindexCollection(container);
            return container;
        };

        const renderSaveState = (form, message = "", tone = "") => {
            const target = form?.querySelector("[data-pf-save-status]");
            if (!target) return;

            const state = getFormState(form);
            window.clearTimeout(state.statusTimer);

            target.textContent = message;
            target.className = "pf-inline-save-status";

            if (tone) {
                target.classList.add(`is-${tone}`);
            }

            if (!message) {
                return;
            }

            state.statusTimer = window.setTimeout(() => {
                if (!document.body.contains(target)) return;
                target.textContent = "";
                target.className = "pf-inline-save-status";
            }, 1800);
        };

        const normalizeFormBeforeSave = form => {
            syncMoneyWithin(form);
            form.querySelectorAll("[data-pf-collection]").forEach(reindexCollection);
        };

        const parseHtml = html => new DOMParser().parseFromString(html, "text/html");

        const replaceProductSummaryFromHtml = (productId, html) => {
            const doc = parseHtml(html);
            const currentSummary = document.querySelector(`[data-pf-product-summary="${productId}"]`);
            const nextSummary = doc.querySelector(`[data-pf-product-summary="${productId}"]`);

            if (!currentSummary || !nextSummary) {
                return false;
            }

            currentSummary.replaceWith(nextSummary);
            return true;
        };

        const replaceProductUiFromHtml = (productId, html, { openModalId } = {}) => {
            let replaced = false;
            const doc = parseHtml(html);

            if (replaceProductSummaryFromHtml(productId, html)) {
                replaced = true;
            }

            const currentStack = document.querySelector(`[data-pf-product-stack="${productId}"]`);
            const nextStack = doc.querySelector(`[data-pf-product-stack="${productId}"]`);
            if (currentStack && nextStack) {
                currentStack.replaceWith(nextStack);
                initializeRoot(nextStack);
                replaced = true;
            }

            if (replaced && openModalId) {
                window.pfModalUi?.openModal(openModalId);
            }

            window.pfModalUi?.syncBodyOverflow();
            return replaced;
        };

        const submitRequest = async (url, body) => {
            const response = await fetch(url, {
                method: "POST",
                headers: {
                    "X-Requested-With": "XMLHttpRequest"
                },
                credentials: "same-origin",
                body
            });

            const payload = await response.text();
            if (!response.ok) {
                throw new Error(payload || "Request failed.");
            }

            return payload;
        };

        const submitFormRequest = form => submitRequest(form.action, new FormData(form));

        const submitProductForm = async (form, { refresh = false } = {}) => {
            if (!form.checkValidity()) {
                renderSaveState(form);
                return false;
            }

            const state = getFormState(form);
            if (state.saving) {
                state.queued = true;
                state.queuedRefresh = state.queuedRefresh || refresh;
                return false;
            }

            state.saving = true;
            window.clearTimeout(state.timer);
            normalizeFormBeforeSave(form);
            renderSaveState(form, "Saving", "saving");

            const productId = form.getAttribute("data-pf-product-id");

            try {
                const html = await submitFormRequest(form);

                if (refresh && productId) {
                    const replaced = replaceProductUiFromHtml(productId, html, { openModalId: `editProduct${productId}` });
                    if (!replaced) {
                        window.location.reload();
                        return true;
                    }

                    const freshForm = document.querySelector(`[data-pf-product-stack="${productId}"] [data-pf-product-edit-form]`);
                    renderSaveState(freshForm, "Saved", "success");
                } else {
                    if (productId) {
                        replaceProductSummaryFromHtml(productId, html);
                    }
                    renderSaveState(form, "Saved", "success");
                }

                return true;
            } catch (error) {
                console.error(error);
                renderSaveState(form, "Save failed", "error");
                return false;
            } finally {
                state.saving = false;

                const queued = state.queued;
                const queuedRefresh = state.queuedRefresh;
                state.queued = false;
                state.queuedRefresh = false;

                if (queued && document.body.contains(form)) {
                    submitProductForm(form, { refresh: queuedRefresh });
                }
            }
        };

        const scheduleAutoSave = form => {
            if (!form?.matches("[data-pf-product-edit-form]") || !form.checkValidity()) {
                return;
            }

            const state = getFormState(form);
            window.clearTimeout(state.timer);
            renderSaveState(form, "Saving", "saving");
            state.timer = window.setTimeout(() => submitProductForm(form), 850);
        };

        const submitRefreshForm = async (form, productId, openModalId) => {
            try {
                const html = await submitFormRequest(form);
                const replaced = replaceProductUiFromHtml(productId, html, { openModalId });
                if (!replaced) {
                    window.location.reload();
                }
            } catch (error) {
                console.error(error);
                window.location.reload();
            }
        };

        const postProductAction = async (productId, url, values, openModalId) => {
            const stack = document.querySelector(`[data-pf-product-stack="${productId}"]`);
            const token = stack?.querySelector('input[name="__RequestVerificationToken"]')?.value;

            if (!token) {
                window.location.reload();
                return;
            }

            const formData = new FormData();
            formData.append("__RequestVerificationToken", token);

            Object.entries(values).forEach(([key, value]) => {
                if (Array.isArray(value)) {
                    value.forEach(item => formData.append(key, item));
                    return;
                }

                formData.append(key, value);
            });

            try {
                const html = await submitRequest(url, formData);
                const replaced = replaceProductUiFromHtml(productId, html, { openModalId });
                if (!replaced) {
                    window.location.reload();
                }
            } catch (error) {
                console.error(error);
                window.location.reload();
            }
        };

        const initAccordion = section => {
            if (section.dataset.pfAccordionBound === "true") return;
            section.dataset.pfAccordionBound = "true";

            section.addEventListener("toggle", () => {
                if (!section.open) return;

                const container = section.closest("form");
                container?.querySelectorAll("[data-pf-accordion]").forEach(other => {
                    if (other !== section) {
                        other.open = false;
                    }
                });
            });
        };

        const initPhotoGrid = grid => {
            if (grid.dataset.pfBound === "true") return;
            grid.dataset.pfBound = "true";

            let draggingTile = null;
            let startOrder = "";

            const currentOrder = () => [...grid.querySelectorAll("[data-pf-photo-tile]")]
                .map(tile => tile.getAttribute("data-pf-image-id"))
                .filter(Boolean)
                .join(",");

            const clearDropTargets = () => {
                grid.querySelectorAll(".is-drop-target").forEach(item => item.classList.remove("is-drop-target"));
            };

            grid.addEventListener("dragstart", event => {
                const tile = event.target.closest("[data-pf-photo-tile]");
                if (!tile) return;

                draggingTile = tile;
                startOrder = currentOrder();
                tile.classList.add("is-dragging");

                if (event.dataTransfer) {
                    event.dataTransfer.effectAllowed = "move";
                    event.dataTransfer.setData("text/plain", tile.getAttribute("data-pf-image-id") || "");
                }
            });

            grid.addEventListener("dragend", async event => {
                const tile = event.target.closest("[data-pf-photo-tile]");
                if (!tile) return;

                tile.classList.remove("is-dragging");
                clearDropTargets();

                const endOrder = currentOrder();
                draggingTile = null;

                if (!endOrder || endOrder === startOrder) {
                    return;
                }

                const productId = grid.getAttribute("data-pf-product-id");
                const sortUrl = grid.getAttribute("data-pf-sort-url");
                const token = grid.closest("[data-pf-product-stack]")?.querySelector('input[name="__RequestVerificationToken"]')?.value;

                if (!productId || !sortUrl || !token) {
                    return;
                }

                const formData = new FormData();
                formData.append("__RequestVerificationToken", token);
                formData.append("productId", productId);
                endOrder.split(",").forEach(id => formData.append("imageIds", id));

                try {
                    await submitRequest(sortUrl, formData);
                    const form = grid.closest("[data-pf-product-stack]")?.querySelector("[data-pf-product-edit-form]");
                    renderSaveState(form, "Photo order saved", "success");
                } catch (error) {
                    console.error(error);
                    window.location.reload();
                }
            });

            grid.addEventListener("dragover", event => {
                event.preventDefault();
                if (!draggingTile) return;

                const target = event.target.closest("[data-pf-photo-tile]");
                if (!target || target === draggingTile) return;

                clearDropTargets();
                target.classList.add("is-drop-target");

                const rect = target.getBoundingClientRect();
                const insertAfter = event.clientY > rect.top + (rect.height / 2);

                if (insertAfter) {
                    target.after(draggingTile);
                } else {
                    target.before(draggingTile);
                }
            });

            grid.addEventListener("drop", event => {
                event.preventDefault();
                clearDropTargets();
            });
        };

        const initAdjustPanel = panel => {
            if (panel.dataset.pfBound === "true") return;
            panel.dataset.pfBound = "true";

            const stage = panel.querySelector("[data-pf-adjust-stage]");
            const img = panel.querySelector("[data-pf-adjust-img]");
            const posX = panel.querySelector("[data-pf-pos-x]");
            const posY = panel.querySelector("[data-pf-pos-y]");
            const zoomInput = panel.querySelector("[data-pf-adjust-zoom]");
            const zoomHidden = panel.querySelector("[data-pf-zoom]");

            if (!stage || !img || !posX || !posY || !zoomInput || !zoomHidden) return;

            let x = Number(stage.getAttribute("data-start-x") || 50);
            let y = Number(stage.getAttribute("data-start-y") || 50);
            let zoom = Number(stage.getAttribute("data-start-zoom") || 1);
            let dragging = false;
            let lastClientX = 0;
            let lastClientY = 0;

            const render = () => {
                img.style.objectPosition = `${x}% ${y}%`;
                img.style.transformOrigin = `${x}% ${y}%`;
                img.style.transform = `scale(${zoom})`;
                posX.value = Math.round(x).toString();
                posY.value = Math.round(y).toString();
                zoomHidden.value = zoom.toString();
            };

            stage.addEventListener("pointerdown", event => {
                dragging = true;
                lastClientX = event.clientX;
                lastClientY = event.clientY;
                stage.classList.add("is-dragging");
                stage.setPointerCapture(event.pointerId);
            });

            stage.addEventListener("pointermove", event => {
                if (!dragging) return;

                const rect = stage.getBoundingClientRect();
                const deltaX = event.clientX - lastClientX;
                const deltaY = event.clientY - lastClientY;

                x = clamp(x - (deltaX / rect.width) * 100, 0, 100);
                y = clamp(y - (deltaY / rect.height) * 100, 0, 100);

                lastClientX = event.clientX;
                lastClientY = event.clientY;

                render();
            });

            const releasePointer = event => {
                dragging = false;
                stage.classList.remove("is-dragging");
                if (stage.hasPointerCapture(event.pointerId)) {
                    stage.releasePointerCapture(event.pointerId);
                }
            };

            stage.addEventListener("pointerup", releasePointer);
            stage.addEventListener("pointercancel", releasePointer);

            zoomInput.addEventListener("input", () => {
                zoom = Number(zoomInput.value || 1);
                render();
            });

            render();
        };

        function initializeRoot(root = document) {
            syncMoneyWithin(root);

            root.querySelectorAll("[data-pf-product-form]").forEach(form => {
                form.querySelectorAll("[data-pf-collection]").forEach(reindexCollection);
                form.querySelectorAll("[data-pf-inventory-row]").forEach(updateInventoryRow);
            });

            root.querySelectorAll("[data-pf-photo-grid]").forEach(initPhotoGrid);
            root.querySelectorAll("[data-pf-adjust-panel]").forEach(initAdjustPanel);
            root.querySelectorAll("[data-pf-accordion]").forEach(initAccordion);
        }

        document.addEventListener("click", event => {
            const addButton = event.target.closest("[data-pf-add-row]");
            if (addButton) {
                const type = addButton.getAttribute("data-pf-add-row");
                const target = addButton.getAttribute("data-pf-target");
                const container = addRow(target, type === "inventory" ? inventoryTemplate : discountTemplate);
                const form = addButton.closest("form");

                if (container && form?.matches("[data-pf-product-edit-form]")) {
                    scheduleAutoSave(form);
                }
                return;
            }

            const removeButton = event.target.closest("[data-pf-remove-row]");
            if (removeButton) {
                const row = removeButton.closest("[data-pf-repeat-item]");
                const container = removeButton.closest("[data-pf-collection]");
                const form = removeButton.closest("form");

                if (!row || !container) return;
                row.remove();
                reindexCollection(container);

                if (form?.matches("[data-pf-product-edit-form]")) {
                    scheduleAutoSave(form);
                }
                return;
            }

            const generateButton = event.target.closest("[data-pf-generate-code]");
            if (generateButton) {
                const row = generateButton.closest("[data-pf-repeat-item]");
                const form = generateButton.closest("form");
                const nameInput = form?.querySelector('input[name="Name"]');
                const codeInput = row?.querySelector('[data-field="Code"]');
                const amountInput = row?.querySelector('[data-field="Amount"]');

                if (!codeInput) return;

                const prefix = slugify(nameInput?.value || "PARFAIT");
                const suffix = Math.random().toString(36).toUpperCase().replace(/[^A-Z0-9]/g, "").slice(0, 6);
                codeInput.value = `${prefix}-${suffix}`;

                if (amountInput && !amountInput.value.trim()) {
                    amountInput.value = "10";
                }

                if (form?.matches("[data-pf-product-edit-form]")) {
                    scheduleAutoSave(form);
                }
                return;
            }

            const deleteImageButton = event.target.closest("[data-pf-delete-image]");
            if (deleteImageButton) {
                const productId = deleteImageButton.closest("[data-pf-product-modal]")?.getAttribute("data-pf-product-id");
                const imageId = deleteImageButton.getAttribute("data-pf-delete-image");

                if (!productId || !imageId || !window.confirm("Delete this photo?")) {
                    return;
                }

                postProductAction(
                    productId,
                    "/internal/commerce/products/images/delete",
                    { productId, imageId },
                    `editProduct${productId}`);
                return;
            }

            const primaryImageButton = event.target.closest("[data-pf-primary-image]");
            if (primaryImageButton) {
                const productId = primaryImageButton.closest("[data-pf-product-modal]")?.getAttribute("data-pf-product-id");
                const imageId = primaryImageButton.getAttribute("data-pf-primary-image");

                if (!productId || !imageId) {
                    return;
                }

                postProductAction(
                    productId,
                    "/internal/commerce/products/images/primary",
                    { productId, imageId },
                    `editProduct${productId}`);
            }
        });

        document.addEventListener("input", event => {
            if (event.target.matches(".pf-money-display")) {
                syncMoneyInput(event.target);
            }

            const productForm = event.target.closest("[data-pf-product-form]");
            if (productForm && event.target.matches('input[name="Name"]')) {
                const slugInput = productForm.querySelector('input[name="Slug"]');
                if (slugInput && !slugInput.value.trim()) {
                    slugInput.value = (event.target.value || "")
                        .trim()
                        .toLowerCase()
                        .replace(/[^a-z0-9]+/g, "-")
                        .replace(/^-+|-+$/g, "");
                }
            }

            const inventoryRow = event.target.closest("[data-pf-inventory-row]");
            if (inventoryRow) {
                updateInventoryRow(inventoryRow);
            }

            const form = event.target.closest("[data-pf-product-edit-form]");
            if (!form || !event.target.matches(liveFieldSelector)) {
                return;
            }

            scheduleAutoSave(form);
        });

        document.addEventListener("change", event => {
            const target = event.target;

            if (target.matches("[data-pf-upload-input]")) {
                const form = target.closest("[data-pf-upload-form]");
                const productId = form?.getAttribute("data-pf-product-id");

                if (!form || !productId || !target.files?.length) {
                    return;
                }

                submitRefreshForm(form, productId, `editProduct${productId}`);
                target.value = "";
                return;
            }

            const inventoryRow = target.closest("[data-pf-inventory-row]");
            if (inventoryRow) {
                updateInventoryRow(inventoryRow);
            }

            const form = target.closest("[data-pf-product-edit-form]");
            if (!form || target.matches(liveFieldSelector)) {
                return;
            }

            scheduleAutoSave(form);
        });

        document.addEventListener("submit", event => {
            const form = event.target;

            if (form.matches("[data-pf-product-edit-form]")) {
                event.preventDefault();

                if (!form.reportValidity()) {
                    return;
                }

                submitProductForm(form, { refresh: true });
                return;
            }

            if (form.matches("[data-pf-image-editor-form]")) {
                event.preventDefault();
                const productId = form.getAttribute("data-pf-product-id");
                if (!productId) {
                    return;
                }

                submitRefreshForm(form, productId, `editProduct${productId}`);
            }
        });

        initializeRoot(document);
    })();
</script>
