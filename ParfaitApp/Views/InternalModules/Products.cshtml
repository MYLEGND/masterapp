@model ParfaitApp.Models.ParfaitProductAdminViewModel
@using ParfaitApp.Models
@{
    ViewData["Title"] = "Products";
    Layout = "_InternalLayout";

    var newProduct = Model.NewProduct ?? new ParfaitProductEditorViewModel();
    if (newProduct.InventoryBySize.Count == 0)
    {
        newProduct.InventoryBySize = ParfaitProductCatalogDefaults.CreateDefaultInventory();
    }

    static string Money(int cents) => "$" + (cents / 100m).ToString("0.00");
    static string MoneyField(int cents) => cents <= 0 ? "" : (cents / 100m).ToString("0.00");
    static string CountLabel(int count, string singular, string? plural = null)
    {
        plural ??= singular + "s";
        return $"{count} {(count == 1 ? singular : plural)}";
    }

    static string ImageDisplayStyle(string? fit, int positionX, int positionY, decimal zoom)
    {
        var safeFit = string.Equals(fit, "contain", StringComparison.OrdinalIgnoreCase) ? "contain" : "cover";
        var safeZoom = zoom <= 0 ? 1.0m : zoom;
        return $"object-fit:{safeFit}; object-position:{positionX}% {positionY}%; transform-origin:{positionX}% {positionY}%; transform:scale({safeZoom.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)});";
    }

    static string Preview(string? value, int maxLength = 160)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "No description saved.";
        }

        var trimmed = value.Trim();
        return trimmed.Length <= maxLength
            ? trimmed
            : trimmed[..(maxLength - 3)] + "...";
    }

    static string ToneClass(string tone) => tone switch
    {
        "danger" => "is-danger",
        "warning" => "is-warning",
        "info" => "is-info",
        "muted" => "is-muted",
        _ => "is-success"
    };

    static bool IsStandardSize(string? size) =>
        !string.IsNullOrWhiteSpace(size)
        && ParfaitProductCatalogDefaults.StandardSizes.Contains(
            ParfaitProductCatalogDefaults.NormalizeSize(size),
            StringComparer.OrdinalIgnoreCase);
}

<section class="pf-command-page pf-products-admin">
    <header class="pf-command-head">
        <div class="pf-command-copy">
            <h1 class="pf-command-title">Products</h1>
            <p class="pf-command-text">Catalog, stock, sale pricing, and promo control.</p>
        </div>
        <div class="pf-command-meta">
            <span class="pf-command-badge is-success">@Model.ActiveProductCount live</span>
            <span class="pf-command-badge is-info">@Model.Products.Sum(product => product.TotalTrackedStock) tracked units</span>
            <span class="pf-command-badge is-warning">@Model.Products.Sum(product => product.ActiveDiscountCount) active codes</span>
        </div>
    </header>

    @if (TempData["ProductStatus"] is string statusMessage)
    {
        <div class="pf-alert-success">@statusMessage</div>
    }

    <section class="pf-command-rail">
        <article class="pf-rail-card is-success pf-span-4">
            <div class="pf-rail-label">Live Catalog</div>
            <strong class="pf-rail-value">@Model.ActiveProductCount</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Total Products</span>
                    <strong>@Model.Products.Count</strong>
                </div>
                <div>
                    <span>Featured</span>
                    <strong>@Model.FeaturedProductCount</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-info pf-span-4">
            <div class="pf-rail-label">Tracked Stock</div>
            <strong class="pf-rail-value">@Model.Products.Sum(product => product.TotalTrackedStock)</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Low Stock Sizes</span>
                    <strong>@Model.Products.Sum(product => product.LowStockSizeCount)</strong>
                </div>
                <div>
                    <span>Sold Out Sizes</span>
                    <strong>@Model.Products.Sum(product => product.SoldOutSizeCount)</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-warning pf-span-4">
            <div class="pf-rail-label">Promo Codes</div>
            <strong class="pf-rail-value">@Model.Products.Sum(product => product.ActiveDiscountCount)</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Sale Products</span>
                    <strong>@Model.Products.Count(product => product.HasSalePrice)</strong>
                </div>
                <div>
                    <span>Images</span>
                    <strong>@Model.TotalImageCount</strong>
                </div>
            </div>
        </article>
    </section>

    <section class="pf-commerce-panel">
        <div class="pf-commerce-panel-head">
            <div>
                <h2>Product Management</h2>
            </div>
            <span>@Model.Products.Count products</span>
        </div>

        <details class="pf-add-product">
            <summary>Add Product</summary>

            <form method="post" action="/internal/commerce/products" class="pf-product-create-form" data-pf-product-form>
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@newProduct.Id" />
                <input type="hidden" name="PriceLabel" value="Auto" />

                <details class="pf-product-accordion" open data-pf-accordion>
                    <summary>
                        <div class="pf-product-accordion-copy">
                            <strong>Core Setup</strong>
                            <span>6 fields</span>
                        </div>
                    </summary>
                    <div class="pf-product-accordion-body">
                        <div class="pf-product-create-grid">
                            <label>Name <input class="form-control" name="Name" value="@newProduct.Name" required /></label>
                            <label>Slug <input class="form-control" name="Slug" value="@newProduct.Slug" required /></label>
                            <label>Price <input class="form-control pf-money-display" type="number" min="0" step="0.01" value="@MoneyField(newProduct.PriceCents)" /><input type="hidden" name="PriceCents" value="@newProduct.PriceCents" class="pf-money-hidden" /></label>
                            <label>Compare At <input class="form-control pf-money-display" type="number" min="0" step="0.01" value="@MoneyField(newProduct.CompareAtPriceCents)" /><input type="hidden" name="CompareAtPriceCents" value="@newProduct.CompareAtPriceCents" class="pf-money-hidden" /></label>
                            <label>Badge <input class="form-control" name="Badge" value="@newProduct.Badge" /></label>
                            <label>Sort <input class="form-control" name="DisplayOrder" type="number" value="@(newProduct.DisplayOrder == 0 ? 100 : newProduct.DisplayOrder)" /></label>
                        </div>

                        <label class="pf-full">Description <textarea class="form-control" name="Description" rows="4" required>@newProduct.Description</textarea></label>
                    </div>
                </details>

                <details class="pf-product-accordion" data-pf-accordion>
                    <summary>
                        <div class="pf-product-accordion-copy">
                            <strong>Size Inventory</strong>
                            <span>@newProduct.InventoryBySize.Count sizes</span>
                        </div>
                    </summary>
                    <div class="pf-product-accordion-body">
                        <section class="pf-product-section">
                            <div class="pf-product-section-tools">
                                <span class="pf-command-badge is-info">Auto tracked</span>
                                <button type="button" class="pf-secondary-action pf-mini-action" data-pf-add-row="inventory" data-pf-target="createInventoryRows">Add Size</button>
                            </div>

                            <div class="pf-variant-list" id="createInventoryRows" data-pf-collection="InventoryBySize">
                                @for (var index = 0; index < newProduct.InventoryBySize.Count; index++)
                                {
                                    var size = newProduct.InventoryBySize[index];
                                    var isStandard = IsStandardSize(size.Size);
                                    <div class="pf-variant-row @ToneClass(size.StatusTone)" data-pf-repeat-item data-pf-inventory-row>
                                        <input type="hidden" name="InventoryBySize[@index].Id" data-field="Id" value="@size.Id" />
                                        <input type="hidden" name="InventoryBySize[@index].DisplayOrder" data-field="DisplayOrder" value="@((index + 1) * 10)" data-pf-order />

                                        <label>Size <input class="form-control" name="InventoryBySize[@index].Size" data-field="Size" value="@size.Size" required /></label>
                                        <label>Units <input class="form-control" name="InventoryBySize[@index].StockQuantity" data-field="StockQuantity" type="number" min="0" value="@size.StockQuantity" data-pf-stock /></label>
                                        <label>Low Stock At <input class="form-control" name="InventoryBySize[@index].LowStockThreshold" data-field="LowStockThreshold" type="number" min="1" value="@size.LowStockThreshold" data-pf-low-stock /></label>
                                        <label class="pf-check"><input type="checkbox" name="InventoryBySize[@index].IsEnabled" data-field="IsEnabled" value="true" @(size.IsEnabled ? "checked" : "") data-pf-enabled /> Enabled</label>
                                        <div class="pf-variant-status">
                                            <span class="pf-command-badge @ToneClass(size.StatusTone)" data-pf-inventory-status>@size.StatusLabel</span>
                                            @if (isStandard)
                                            {
                                                <small>Core size</small>
                                            }
                                        </div>
                                        @if (!isStandard)
                                        {
                                            <button type="button" class="pf-row-remove" data-pf-remove-row>Remove</button>
                                        }
                                    </div>
                                }
                            </div>
                        </section>
                    </div>
                </details>

                <details class="pf-product-accordion" data-pf-accordion>
                    <summary>
                        <div class="pf-product-accordion-copy">
                            <strong>Discount Codes</strong>
                            <span>@newProduct.DiscountCodes.Count codes</span>
                        </div>
                    </summary>
                    <div class="pf-product-accordion-body">
                        <section class="pf-product-section">
                            <div class="pf-product-section-tools">
                                <span class="pf-command-badge is-warning">Product level</span>
                                <button type="button" class="pf-secondary-action pf-mini-action" data-pf-add-row="discount" data-pf-target="createDiscountRows">Add Code</button>
                            </div>

                            <div class="pf-discount-list" id="createDiscountRows" data-pf-collection="DiscountCodes">
                                @for (var index = 0; index < newProduct.DiscountCodes.Count; index++)
                                {
                                    var code = newProduct.DiscountCodes[index];
                                    <div class="pf-discount-row" data-pf-repeat-item>
                                        <input type="hidden" name="DiscountCodes[@index].Id" data-field="Id" value="@code.Id" />
                                        <label>Code <input class="form-control" name="DiscountCodes[@index].Code" data-field="Code" value="@code.Code" /></label>
                                        <label>Type
                                            <select class="form-select" name="DiscountCodes[@index].DiscountType" data-field="DiscountType">
                                                <option value="Percent" selected="@string.Equals(code.DiscountType, "Percent", StringComparison.OrdinalIgnoreCase)">Percent</option>
                                                <option value="Fixed" selected="@string.Equals(code.DiscountType, "Fixed", StringComparison.OrdinalIgnoreCase)">Fixed</option>
                                            </select>
                                        </label>
                                        <label>Amount <input class="form-control" name="DiscountCodes[@index].Amount" data-field="Amount" type="number" min="0" step="0.01" value="@(code.Amount > 0 ? code.Amount.ToString("0.##") : "10")" /></label>
                                        <label>Usage Limit <input class="form-control" name="DiscountCodes[@index].UsageLimit" data-field="UsageLimit" type="number" min="0" value="@code.UsageLimit" /></label>
                                        <label class="pf-check"><input type="checkbox" name="DiscountCodes[@index].IsActive" data-field="IsActive" value="true" @(code.IsActive ? "checked" : "") /> Active</label>
                                        <div class="pf-discount-actions">
                                            <button type="button" class="pf-text-button" data-pf-generate-code>Generate</button>
                                            <button type="button" class="pf-row-remove" data-pf-remove-row>Remove</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </section>
                    </div>
                </details>

                <div class="pf-product-create-actions">
                    <label class="pf-check"><input type="checkbox" name="IsActive" value="true" @(newProduct.IsActive ? "checked" : "") /> Active</label>
                    <label class="pf-check"><input type="checkbox" name="IsFeatured" value="true" @(newProduct.IsFeatured ? "checked" : "") /> Featured</label>
                    <button type="submit" class="pf-action">Create Product</button>
                </div>
            </form>
        </details>

        <div class="pf-product-summary-list mt-3">
            @foreach (var product in Model.Products)
            {
                var orderedImages = product.Images.OrderBy(image => image.DisplayOrder).ToList();
                var primaryImage = orderedImages.FirstOrDefault(image => image.IsPrimary) ?? orderedImages.FirstOrDefault();
                var primaryUrl = primaryImage?.ImageUrl ?? "/images/favicon/parfait-logo.png";
                var modalId = $"editProduct{product.Id}";
                var liveSizeCount = product.InventoryBySize.Count(size => size.IsEnabled);
                var inventoryNotes = new List<string>();
                if (product.TotalTrackedStock > 0)
                {
                    inventoryNotes.Add($"{product.TotalTrackedStock} tracked");
                }
                if (product.LowStockSizeCount > 0)
                {
                    inventoryNotes.Add($"{product.LowStockSizeCount} low stock");
                }
                if (product.SoldOutSizeCount > 0)
                {
                    inventoryNotes.Add($"{product.SoldOutSizeCount} sold out");
                }
                if (inventoryNotes.Count == 0)
                {
                    inventoryNotes.Add("All ready");
                }

                var priceNote = product.HasSalePrice
                    ? $"Save {Money(product.CompareAtPriceCents - product.PriceCents)}"
                    : string.IsNullOrWhiteSpace(product.Badge) ? "Core catalog" : product.Badge;
                var promoCountLabel = product.ActiveDiscountCount > 0
                    ? CountLabel(product.ActiveDiscountCount, "active code")
                    : "No active codes";
                var promoDetail = product.HasSalePrice
                    ? $"Compare at {Money(product.CompareAtPriceCents)}"
                    : "No sale pricing";

                <article class="pf-product-summary-card @ToneClass(product.InventoryTone)" data-pf-product-summary="@product.Id">
                    <div class="pf-product-summary-main">
                        <img src="@primaryUrl" alt="@product.Name" />
                        <div class="pf-product-summary-copy">
                            <h3>@product.Name</h3>
                            <span>@product.Slug</span>
                            <p>@Preview(product.Description, 128)</p>
                        </div>
                    </div>

                    <div class="pf-product-summary-metrics">
                        <div class="pf-product-summary-metric">
                            <span>Price</span>
                            <strong>@Money(product.PriceCents)</strong>
                            <small>@priceNote</small>
                        </div>

                        <div class="pf-product-summary-metric">
                            <span>Inventory</span>
                            <strong>@CountLabel(liveSizeCount, "live size")</strong>
                            <small>@string.Join(" • ", inventoryNotes)</small>
                        </div>

                        <div class="pf-product-summary-metric">
                            <span>Promo</span>
                            <strong>@promoCountLabel</strong>
                            <small>@promoDetail</small>
                        </div>
                    </div>

                    <div class="pf-product-summary-side">
                        <div class="pf-product-summary-pills">
                            <span class="pf-command-badge @ToneClass(product.InventoryTone)">@product.InventoryLabel</span>
                            <span class="pf-pill @(product.IsActive ? "is-live" : "is-muted")">@(product.IsActive ? "Live" : "Hidden")</span>
                            <span class="pf-pill @(product.IsFeatured ? "is-live" : "is-muted")">@(product.IsFeatured ? "Featured" : "Standard")</span>
                        </div>

                        <div class="pf-product-summary-meta">
                            <span>@CountLabel(orderedImages.Count, "photo")</span>
                            <span>Sort @product.DisplayOrder</span>
                        </div>

                        <button type="button" class="pf-secondary-action" data-pf-open="@modalId">Edit Product</button>
                    </div>
                </article>
            }
        </div>
    </section>
</section>

@foreach (var product in Model.Products)
{
    var orderedImages = product.Images.OrderBy(image => image.DisplayOrder).ToList();
    var primaryImage = orderedImages.FirstOrDefault(image => image.IsPrimary) ?? orderedImages.FirstOrDefault();
    var primaryUrl = primaryImage?.ImageUrl ?? "/images/favicon/parfait-logo.png";
    var modalId = $"editProduct{product.Id}";
    var inventoryTargetId = $"{modalId}InventoryRows";
    var discountTargetId = $"{modalId}DiscountRows";

    <div class="pf-product-modal-stack" data-pf-product-stack="@product.Id">
        <div class="pf-product-modal" id="@modalId" aria-hidden="true" data-pf-product-modal data-pf-product-id="@product.Id">
            <div class="pf-modal-dialog pf-modal-xl">
                <div class="pf-modal-content">
                    <div class="pf-modal-header">
                        <div>
                            <h2 class="modal-title" id="@modalId-title">@product.Name</h2>
                        </div>
                        <button type="button" class="btn-close" data-pf-close aria-label="Close"></button>
                    </div>

                    <div class="pf-modal-body">
                        <div class="pf-modal-grid">
                            <section class="pf-media-panel">
                                <div class="pf-primary-preview">
                                    <img src="@primaryUrl" alt="@product.Name" style="@ImageDisplayStyle(primaryImage?.ObjectFit, primaryImage?.ObjectPositionX ?? 50, primaryImage?.ObjectPositionY ?? 50, primaryImage?.Zoom ?? 1.0m)" />
                                </div>

                                <form method="post"
                                      action="/internal/commerce/products/images/upload"
                                      enctype="multipart/form-data"
                                      class="pf-upload-box"
                                      data-pf-upload-form
                                      data-pf-product-id="@product.Id">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.Id" />
                                    <label>
                                        Upload Photos
                                        <input type="file" name="images" accept="image/*" multiple data-pf-upload-input />
                                    </label>
                                </form>

                                <div class="pf-photo-grid"
                                     data-pf-photo-grid
                                     data-pf-product-id="@product.Id"
                                     data-pf-sort-url="/internal/commerce/products/images/reorder">
                                    @foreach (var image in orderedImages)
                                    {
                                        var editorId = $"imageEditor{image.Id}";

                                        <article class="pf-photo-tile"
                                                 draggable="true"
                                                 title="Drag to reorder"
                                                 data-pf-photo-tile
                                                 data-pf-image-id="@image.Id">
                                            <div class="pf-photo-thumb">
                                                <img src="@image.ImageUrl" alt="@image.AltText" style="@ImageDisplayStyle(image.ObjectFit, image.ObjectPositionX, image.ObjectPositionY, image.Zoom)" />
                                                @if (image.IsPrimary)
                                                {
                                                    <span class="pf-photo-chip">Primary</span>
                                                }
                                                <button type="button"
                                                        class="pf-photo-delete"
                                                        data-pf-delete-image="@image.Id"
                                                        aria-label="Delete image">
                                                    <span aria-hidden="true">&times;</span>
                                                </button>
                                            </div>

                                            <div class="pf-photo-tile-actions">
                                                <button type="button" class="pf-text-button pf-photo-action" data-pf-open="@editorId">Edit</button>
                                                @if (image.IsPrimary)
                                                {
                                                    <span class="pf-photo-action is-current">Primary</span>
                                                }
                                                else
                                                {
                                                    <button type="button"
                                                            class="pf-text-button pf-photo-action"
                                                            data-pf-primary-image="@image.Id">
                                                        Primary
                                                    </button>
                                                }
                                            </div>
                                        </article>
                                    }
                                </div>
                            </section>

                            <section class="pf-editor-panel">
                                <form method="post"
                                      action="/internal/commerce/products"
                                      class="pf-product-edit-form"
                                      data-pf-product-form
                                      data-pf-product-edit-form
                                      data-pf-product-id="@product.Id">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Id" value="@product.Id" />
                                <input type="hidden" name="PriceLabel" value="Auto" />

                                <details class="pf-product-accordion" open data-pf-accordion>
                                    <summary>
                                        <div class="pf-product-accordion-copy">
                                            <strong>Core Setup</strong>
                                            <span>6 fields</span>
                                        </div>
                                    </summary>
                                    <div class="pf-product-accordion-body">
                                        <div class="pf-editor-grid">
                                            <label>Name <input class="form-control" name="Name" value="@product.Name" required /></label>
                                            <label>Slug <input class="form-control" name="Slug" value="@product.Slug" required /></label>
                                            <label>Price <input class="form-control pf-money-display" type="number" min="0" step="0.01" value="@MoneyField(product.PriceCents)" /><input type="hidden" name="PriceCents" value="@product.PriceCents" class="pf-money-hidden" /></label>
                                            <label>Compare At <input class="form-control pf-money-display" type="number" min="0" step="0.01" value="@MoneyField(product.CompareAtPriceCents)" /><input type="hidden" name="CompareAtPriceCents" value="@product.CompareAtPriceCents" class="pf-money-hidden" /></label>
                                            <label>Badge <input class="form-control" name="Badge" value="@product.Badge" /></label>
                                            <label>Sort <input class="form-control" name="DisplayOrder" type="number" value="@product.DisplayOrder" /></label>
                                            <label class="pf-full">Description <textarea class="form-control" name="Description" rows="5" required>@product.Description</textarea></label>
                                        </div>
                                    </div>
                                </details>

                                <details class="pf-product-accordion" data-pf-accordion>
                                    <summary>
                                        <div class="pf-product-accordion-copy">
                                            <strong>Size Inventory</strong>
                                            <span>@product.InventoryBySize.Count sizes</span>
                                        </div>
                                    </summary>
                                    <div class="pf-product-accordion-body">
                                        <section class="pf-product-section">
                                            <div class="pf-product-section-tools">
                                                <span class="pf-command-badge is-info">@product.TotalTrackedStock units</span>
                                                <button type="button" class="pf-secondary-action pf-mini-action" data-pf-add-row="inventory" data-pf-target="@inventoryTargetId">Add Size</button>
                                            </div>

                                            <div class="pf-variant-list" id="@inventoryTargetId" data-pf-collection="InventoryBySize">
                                                @for (var index = 0; index < product.InventoryBySize.Count; index++)
                                                {
                                                    var size = product.InventoryBySize[index];
                                                    var isStandard = IsStandardSize(size.Size);
                                                    <div class="pf-variant-row @ToneClass(size.StatusTone)" data-pf-repeat-item data-pf-inventory-row>
                                                        <input type="hidden" name="InventoryBySize[@index].Id" data-field="Id" value="@size.Id" />
                                                        <input type="hidden" name="InventoryBySize[@index].DisplayOrder" data-field="DisplayOrder" value="@((index + 1) * 10)" data-pf-order />

                                                        <label>Size <input class="form-control" name="InventoryBySize[@index].Size" data-field="Size" value="@size.Size" required /></label>
                                                        <label>Units <input class="form-control" name="InventoryBySize[@index].StockQuantity" data-field="StockQuantity" type="number" min="0" value="@size.StockQuantity" data-pf-stock /></label>
                                                        <label>Low Stock At <input class="form-control" name="InventoryBySize[@index].LowStockThreshold" data-field="LowStockThreshold" type="number" min="1" value="@size.LowStockThreshold" data-pf-low-stock /></label>
                                                        <label class="pf-check"><input type="checkbox" name="InventoryBySize[@index].IsEnabled" data-field="IsEnabled" value="true" @(size.IsEnabled ? "checked" : "") data-pf-enabled /> Enabled</label>
                                                        <div class="pf-variant-status">
                                                            <span class="pf-command-badge @ToneClass(size.StatusTone)" data-pf-inventory-status>@size.StatusLabel</span>
                                                            @if (isStandard)
                                                            {
                                                                <small>Core size</small>
                                                            }
                                                        </div>
                                                        @if (!isStandard)
                                                        {
                                                            <button type="button" class="pf-row-remove" data-pf-remove-row>Remove</button>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        </section>
                                    </div>
                                </details>

                                <details class="pf-product-accordion" data-pf-accordion>
                                    <summary>
                                        <div class="pf-product-accordion-copy">
                                            <strong>Discount Codes</strong>
                                            <span>@product.DiscountCodes.Count codes</span>
                                        </div>
                                    </summary>
                                    <div class="pf-product-accordion-body">
                                        <section class="pf-product-section">
                                            <div class="pf-product-section-tools">
                                                <span class="pf-command-badge @(product.ActiveDiscountCount > 0 ? "is-warning" : "is-muted")">@product.ActiveDiscountCount active</span>
                                                <button type="button" class="pf-secondary-action pf-mini-action" data-pf-add-row="discount" data-pf-target="@discountTargetId">Add Code</button>
                                            </div>

                                            <div class="pf-discount-list" id="@discountTargetId" data-pf-collection="DiscountCodes">
                                                @for (var index = 0; index < product.DiscountCodes.Count; index++)
                                                {
                                                    var code = product.DiscountCodes[index];
                                                    <div class="pf-discount-row" data-pf-repeat-item>
                                                        <input type="hidden" name="DiscountCodes[@index].Id" data-field="Id" value="@code.Id" />
                                                        <label>Code <input class="form-control" name="DiscountCodes[@index].Code" data-field="Code" value="@code.Code" /></label>
                                                        <label>Type
                                                            <select class="form-select" name="DiscountCodes[@index].DiscountType" data-field="DiscountType">
                                                                <option value="Percent" selected="@string.Equals(code.DiscountType, "Percent", StringComparison.OrdinalIgnoreCase)">Percent</option>
                                                                <option value="Fixed" selected="@string.Equals(code.DiscountType, "Fixed", StringComparison.OrdinalIgnoreCase)">Fixed</option>
                                                            </select>
                                                        </label>
                                                        <label>Amount <input class="form-control" name="DiscountCodes[@index].Amount" data-field="Amount" type="number" min="0" step="0.01" value="@(code.Amount > 0 ? code.Amount.ToString("0.##") : "10")" /></label>
                                                        <label>Usage Limit <input class="form-control" name="DiscountCodes[@index].UsageLimit" data-field="UsageLimit" type="number" min="0" value="@code.UsageLimit" /></label>
                                                        <label class="pf-check"><input type="checkbox" name="DiscountCodes[@index].IsActive" data-field="IsActive" value="true" @(code.IsActive ? "checked" : "") /> Active</label>
                                                        <div class="pf-discount-actions">
                                                            <button type="button" class="pf-text-button" data-pf-generate-code>Generate</button>
                                                            <button type="button" class="pf-row-remove" data-pf-remove-row>Remove</button>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </section>
                                    </div>
                                </details>

                                    <div class="pf-product-flags">
                                        <label><input type="checkbox" name="IsActive" value="true" @(product.IsActive ? "checked" : "") /> Active</label>
                                        <label><input type="checkbox" name="IsFeatured" value="true" @(product.IsFeatured ? "checked" : "") /> Featured</label>
                                    </div>

                                    <div class="pf-inline-save-status" data-pf-save-status aria-live="polite"></div>
                                    <button type="submit" class="pf-action">Save Product</button>
                                </form>

                                <form method="post" action="/internal/commerce/products/delete" class="pf-danger-zone">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@product.Id" />
                                    <button type="submit">Delete Product</button>
                                </form>
                            </section>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @foreach (var image in orderedImages)
        {
            var editorId = $"imageEditor{image.Id}";

            <div class="pf-image-editor-modal" id="@editorId" aria-hidden="true">
                <div class="pf-modal-dialog pf-modal-lg">
                    <form method="post"
                          action="/internal/commerce/products/images/display"
                          class="modal-content pf-image-editor-form"
                          data-pf-adjust-panel
                          data-pf-image-editor-form
                          data-pf-product-id="@product.Id">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@product.Id" />
                        <input type="hidden" name="imageId" value="@image.Id" />
                        <input type="hidden" name="objectFit" value="cover" />
                        <input type="hidden" name="objectPositionX" value="@image.ObjectPositionX" data-pf-pos-x />
                        <input type="hidden" name="objectPositionY" value="@image.ObjectPositionY" data-pf-pos-y />
                        <input type="hidden" name="zoom" value="@image.Zoom" data-pf-zoom />

                        <div class="pf-modal-header">
                            <div>
                                <h2 class="modal-title">@product.Name</h2>
                            </div>
                            <button type="button" class="btn-close" data-pf-close aria-label="Close"></button>
                        </div>

                        <div class="pf-modal-body">
                            <div class="pf-adjust-stage"
                                 data-pf-adjust-stage
                                 data-start-x="@image.ObjectPositionX"
                                 data-start-y="@image.ObjectPositionY"
                                 data-start-zoom="@image.Zoom">
                                <img src="@image.ImageUrl"
                                     alt="@image.AltText"
                                     draggable="false"
                                     data-pf-adjust-img
                                     style="@ImageDisplayStyle(image.ObjectFit, image.ObjectPositionX, image.ObjectPositionY, image.Zoom)" />
                                <span>Drag Image To Position</span>
                            </div>

                            <label class="pf-adjust-zoom-label">
                                Zoom
                                <input type="range" min="1" max="2.5" step="0.05" value="@image.Zoom" data-pf-adjust-zoom />
                            </label>
                        </div>

                        <div class="pf-modal-footer">
                            <button type="button" class="pf-secondary-action" data-pf-close>Cancel</button>
                            <button type="submit" class="pf-action">Save Image Position</button>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
}

