        <input type="hidden" data-field="Id" value="" />
        <input type="hidden" data-field="DisplayOrder" value="0" data-pf-order />
        <label>Size <input class="form-control" data-field="Size" value="" required /></label>
        <label>Units <input class="form-control" data-field="StockQuantity" type="number" min="0" value="0" data-pf-stock /></label>
        <label>Low Stock At <input class="form-control" data-field="LowStockThreshold" type="number" min="1" value="3" data-pf-low-stock /></label>
        <label class="pf-check"><input type="checkbox" data-field="IsEnabled" value="true" checked data-pf-enabled /> Enabled</label>
