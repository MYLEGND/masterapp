@model ParfaitApp.Models.ParfaitProductAdminViewModel
@{
    ViewData["Title"] = "Products";
    Layout = "_InternalLayout";

    static string Money(int cents) => "$" + (cents / 100m).ToString("0.00");
}

<section class="pf-commerce-shell pf-products-admin">
    <header class="pf-commerce-head">
        <div>
            <div class="pf-kicker">Commerce</div>
            <h1>Products</h1>
            <p>Compact product control for catalog visibility, pricing, photos, and public storefront presentation.</p>
        </div>

        <div class="pf-commerce-head-actions">
            <a class="pf-secondary-action" href="/store" target="_blank" rel="noopener">View Store</a>
        </div>
    </header>

    @if (TempData["ProductStatus"] is string statusMessage)
    {
        <div class="pf-alert-success">@statusMessage</div>
    }

    <details class="pf-commerce-panel pf-add-product">
        <summary>Add Product</summary>

        <form method="post" action="/internal/commerce/products" class="pf-product-create-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Guid.NewGuid().ToString("N")" />
            <input type="hidden" name="PriceLabel" value="Auto" />

            <div class="pf-product-create-grid">
                <label>Name <input class="form-control" name="Name" required /></label>
                <label>Slug <input class="form-control" name="Slug" required /></label>
                <label>Price <input class="form-control pf-price-dollars" type="number" min="0" step="0.01" /><input type="hidden" name="PriceCents" class="pf-price-cents" /></label>
                <label>Badge <input class="form-control" name="Badge" value="Parfait" /></label>
                <label>Sort <input class="form-control" name="DisplayOrder" type="number" value="100" /></label>
            </div>

            <label class="pf-full">Description <textarea class="form-control" name="Description" rows="2" required></textarea></label>

            <div class="pf-product-create-actions">
                <label class="pf-check"><input type="checkbox" name="IsActive" value="true" checked /> Active</label>
                <label class="pf-check"><input type="checkbox" name="IsFeatured" value="true" /> Featured</label>
                <button type="submit" class="pf-action">Create Product</button>
            </div>
        </form>
    </details>

    <section class="pf-commerce-panel">
        <div class="pf-commerce-panel-head">
            <div>
                <div class="pf-kicker">Catalog Workspace</div>
                <h2>Product Inventory</h2>
            </div>
            <span>@Model.Products.Count products</span>
        </div>

        <div class="pf-product-table-wrap">
            <table class="pf-product-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Featured</th>
                        <th>Photos</th>
                        <th>Sort</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var product in Model.Products)
                {
                    var orderedImages = product.Images.OrderBy(i => i.DisplayOrder).ToList();
                    var primaryImage = orderedImages.FirstOrDefault(i => i.IsPrimary) ?? orderedImages.FirstOrDefault();
                    var primaryUrl = primaryImage?.ImageUrl ?? "/images/favicon/parfait-logo.png";
                    var modalId = $"editProduct{product.Id}";

                    <tr>
                        <td>
                            <div class="pf-product-main-cell">
                                <img src="@primaryUrl" alt="@product.Name" />
                                <div>
                                    <strong>@product.Name</strong>
                                    <span>@product.Slug</span>
                                    <p>@product.Description</p>
                                </div>
                            </div>
                        </td>
                        <td><strong>@Money(product.PriceCents)</strong></td>
                        <td><span class="pf-pill @(product.IsActive ? "is-live" : "is-muted")">@(product.IsActive ? "Live" : "Hidden")</span></td>
                        <td><span class="pf-pill @(product.IsFeatured ? "is-live" : "is-muted")">@(product.IsFeatured ? "Yes" : "No")</span></td>
                        <td>@orderedImages.Count</td>
                        <td>@product.DisplayOrder</td>
                        <td class="pf-table-actions">
                            <button type="button" class="pf-secondary-action" data-pf-open="@modalId">Edit</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
</section>

@foreach (var product in Model.Products)
{
    var orderedImages = product.Images.OrderBy(i => i.DisplayOrder).ToList();
    var primaryImage = orderedImages.FirstOrDefault(i => i.IsPrimary) ?? orderedImages.FirstOrDefault();
    var primaryUrl = primaryImage?.ImageUrl ?? "/images/favicon/parfait-logo.png";
    var modalId = $"editProduct{product.Id}";

    <div class="pf-product-modal" id="@modalId" aria-hidden="true">
        <div class="pf-modal-dialog pf-modal-xl">
            <div class="pf-modal-content">
                <div class="pf-modal-header">
                    <div>
                        <div class="pf-kicker">Edit Product</div>
                        <h2 class="modal-title" id="@modalId-title">@product.Name</h2>
                    </div>
                    <button type="button" class="btn-close" data-pf-close aria-label="Close"></button>
                </div>

                <div class="pf-modal-body">
                    <div class="pf-modal-grid">
                        <section class="pf-media-panel">
                            <div class="pf-primary-preview">
                                <img src="@primaryUrl" alt="@product.Name" />
                            </div>

                            <form method="post" action="/internal/commerce/products/images/upload" enctype="multipart/form-data" class="pf-upload-box">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.Id" />
                                <label>
                                    Upload Photos
                                    <input type="file" name="images" accept="image/*" multiple onchange="this.form.submit()" />
                                </label>
                            </form>

                            <div class="pf-photo-grid">
                                @foreach (var image in orderedImages)
                                {
                                    var editorId = $"imageEditor{image.Id}";

                                    <article class="pf-photo-tile">
                                        <img src="@image.ImageUrl" alt="@image.AltText" />
                                        <div>
                                            <strong>@(image.IsPrimary ? "Primary" : "Photo")</strong>
                                            <span>Order @image.DisplayOrder</span>
                                        </div>

                                        <button type="button" class="pf-text-button" data-pf-open="@editorId">
                                            Edit Image
                                        </button>

                                        <div class="pf-photo-actions">
                                            <form method="post" action="/internal/commerce/products/images/move">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@product.Id" />
                                                <input type="hidden" name="imageId" value="@image.Id" />
                                                <input type="hidden" name="direction" value="up" />
                                                <button type="submit">↑</button>
                                            </form>

                                            <form method="post" action="/internal/commerce/products/images/move">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@product.Id" />
                                                <input type="hidden" name="imageId" value="@image.Id" />
                                                <input type="hidden" name="direction" value="down" />
                                                <button type="submit">↓</button>
                                            </form>

                                            <form method="post" action="/internal/commerce/products/images/primary">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@product.Id" />
                                                <input type="hidden" name="imageId" value="@image.Id" />
                                                <button type="submit">Primary</button>
                                            </form>

                                            <form method="post" action="/internal/commerce/products/images/delete">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@product.Id" />
                                                <input type="hidden" name="imageId" value="@image.Id" />
                                                <button type="submit">Delete</button>
                                            </form>
                                        </div>
                                    </article>
                                }
                            </div>
                        </section>

                        <section class="pf-editor-panel">
                            <form method="post" action="/internal/commerce/products" class="pf-product-edit-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Id" value="@product.Id" />
                                <input type="hidden" name="PriceLabel" value="Auto" />

                                <div class="pf-editor-grid">
                                    <label>Name <input class="form-control" name="Name" value="@product.Name" required /></label>
                                    <label>Slug <input class="form-control" name="Slug" value="@product.Slug" required /></label>
                                    <label class="pf-full">Description <textarea class="form-control" name="Description" rows="5" required>@product.Description</textarea></label>
                                    <label>Price <input class="form-control pf-price-dollars" type="number" min="0" step="0.01" value="@((product.PriceCents / 100m).ToString("0.00"))" /><input type="hidden" name="PriceCents" value="@product.PriceCents" class="pf-price-cents" /></label>
                                    <label>Badge <input class="form-control" name="Badge" value="@product.Badge" /></label>
                                    <label>Sort <input class="form-control" name="DisplayOrder" type="number" value="@product.DisplayOrder" /></label>
                                </div>

                                <div class="pf-product-flags">
                                    <label><input type="checkbox" name="IsActive" value="true" @(product.IsActive ? "checked" : "") /> Active</label>
                                    <label><input type="checkbox" name="IsFeatured" value="true" @(product.IsFeatured ? "checked" : "") /> Featured</label>
                                </div>

                                <button type="submit" class="pf-action">Save Product</button>
                            </form>

                            <form method="post" action="/internal/commerce/products/delete" class="pf-danger-zone">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@product.Id" />
                                <button type="submit">Delete Product</button>
                            </form>
                        </section>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @foreach (var image in orderedImages)
    {
        var editorId = $"imageEditor{image.Id}";

        <div class="pf-image-editor-modal" id="@editorId" aria-hidden="true">
            <div class="pf-modal-dialog pf-modal-lg">
                <form method="post" action="/internal/commerce/products/images/display" class="modal-content pf-image-editor-form" data-pf-adjust-panel>
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@product.Id" />
                    <input type="hidden" name="imageId" value="@image.Id" />
                    <input type="hidden" name="objectFit" value="cover" />
                    <input type="hidden" name="objectPositionX" value="@image.ObjectPositionX" data-pf-pos-x />
                    <input type="hidden" name="objectPositionY" value="@image.ObjectPositionY" data-pf-pos-y />
                    <input type="hidden" name="zoom" value="@image.Zoom" data-pf-zoom />

                    <div class="pf-modal-header">
                        <div>
                            <div class="pf-kicker">Image Editor</div>
                            <h2 class="modal-title">@product.Name</h2>
                        </div>
                        <button type="button" class="btn-close" data-pf-close aria-label="Close"></button>
                    </div>

                    <div class="pf-modal-body">
                        <div class="pf-adjust-stage"
                             data-pf-adjust-stage
                             data-start-x="@image.ObjectPositionX"
                             data-start-y="@image.ObjectPositionY"
                             data-start-zoom="@image.Zoom">
                            <img src="@image.ImageUrl"
                                 alt="@image.AltText"
                                 draggable="false"
                                 data-pf-adjust-img
                                 style="object-fit:cover; object-position:@image.ObjectPositionX% @image.ObjectPositionY%; transform:scale(@image.Zoom.ToString("0.##")); transform-origin:center;" />
                            <span>Drag Image To Position</span>
                        </div>

                        <label class="pf-adjust-zoom-label">
                            Zoom
                            <input type="range" min="1" max="2.5" step="0.05" value="@image.Zoom" data-pf-adjust-zoom />
                        </label>
                    </div>

                    <div class="pf-modal-footer">
                        <button type="button" class="pf-secondary-action" data-pf-close>Cancel</button>
                        <button type="submit" class="pf-action">Save Image Position</button>
                    </div>
                </form>
            </div>
        </div>
    }
}

<style>
    .pf-products-admin {
        --pf-products-line: rgba(146,105,80,.42);
        --pf-products-strong: #926950;
        --pf-products-soft: #faf7f4;
    }

    .pf-add-product summary {
        cursor: pointer;
        color: var(--pf-brown);
        font-size: .76rem;
        font-weight: 950;
        letter-spacing: .14em;
        text-transform: uppercase;
    }

    .pf-product-create-form,
    .pf-product-edit-form {
        display: grid;
        gap: 12px;
        margin-top: 14px;
    }

    .pf-product-create-grid,
    .pf-editor-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .pf-product-create-form label,
    .pf-product-edit-form label {
        color: var(--pf-black);
        font-size: .72rem;
        font-weight: 950;
        letter-spacing: .1em;
        text-transform: uppercase;
    }

    .pf-full {
        grid-column: 1 / -1;
    }

    .pf-product-create-actions,
    .pf-product-flags {
        display: flex;
        align-items: center;
        gap: 14px;
        flex-wrap: wrap;
    }

    .pf-check,
    .pf-product-flags label {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        margin: 0;
        color: var(--pf-black);
        font-size: .72rem;
        font-weight: 950;
        letter-spacing: .1em;
        text-transform: uppercase;
    }

    .pf-product-table-wrap {
        overflow-x: auto;
    }

    .pf-product-table {
        width: 100%;
        min-width: 1040px;
        border-collapse: separate;
        border-spacing: 0 8px;
    }

    .pf-product-table th {
        padding: 0 12px 6px;
        color: var(--pf-brown);
        font-size: .68rem;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .pf-product-table td {
        background: #fff;
        border-top: 1.5px solid var(--pf-products-line);
        border-bottom: 1.5px solid var(--pf-products-line);
        padding: 10px 12px;
        vertical-align: middle;
        color: var(--pf-black);
        font-size: .9rem;
        font-weight: 800;
    }

    .pf-product-table td:first-child {
        border-left: 1.5px solid var(--pf-products-line);
        border-radius: 16px 0 0 16px;
    }

    .pf-product-table td:last-child {
        border-right: 1.5px solid var(--pf-products-line);
        border-radius: 0 16px 16px 0;
    }

    .pf-product-main-cell {
        display: grid;
        grid-template-columns: 72px minmax(0, 1fr);
        gap: 12px;
        align-items: center;
        min-width: 360px;
    }

    .pf-product-main-cell img {
        width: 72px;
        height: 72px;
        border-radius: 14px;
        object-fit: cover;
        border: 1.5px solid var(--pf-products-line);
        background: #fff;
    }

    .pf-product-main-cell strong {
        display: block;
        font-size: 1rem;
        font-weight: 950;
        letter-spacing: -.025em;
    }

    .pf-product-main-cell span,
    .pf-product-table td span {
        display: block;
        color: var(--pf-muted);
        font-size: .76rem;
        font-weight: 750;
    }

    .pf-product-main-cell p {
        max-width: 560px;
        margin: 3px 0 0;
        color: var(--pf-muted);
        font-size: .82rem;
        font-weight: 650;
        line-height: 1.25;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pf-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 30px;
        padding: 6px 10px;
        border: 1.5px solid var(--pf-products-line);
        border-radius: 999px;
        color: var(--pf-brown);
        background: #fff;
        font-size: .66rem;
        font-weight: 950;
        letter-spacing: .12em;
        text-transform: uppercase;
    }

    .pf-pill.is-live {
        border-color: var(--pf-products-strong);
        color: var(--pf-brown);
    }

    .pf-pill.is-muted {
        color: var(--pf-muted);
    }

    .pf-table-actions {
        text-align: right;
        white-space: nowrap;
    }

    .pf-product-modal {
        position: fixed;
        inset: 0;
        z-index: 1900;
        display: none;

        align-items: flex-start;
        justify-content: center;

        overflow-y: auto;
        padding: 24px;

        background: rgba(17,17,17,.42);
    }

    .pf-image-editor-modal {
        position: fixed;
        inset: 0;
        z-index: 2000;
        display: none;

        align-items: center;
        justify-content: center;

        padding: 24px;

        background: rgba(17,17,17,.42);
    }

    .pf-product-modal.is-open,
    .pf-image-editor-modal.is-open {
        display: flex;
    }

    .pf-image-editor-modal {
        z-index: 2000;
    }

    .pf-modal-dialog {
        width: min(100%, 980px);
        height: calc(100vh - 48px);
        display: flex;
    }

    .pf-modal-xl {
        width: min(100%, 1180px);
    }

    .pf-modal-lg {
        width: min(100%, 780px);
    }

    .pf-modal-content {
        width: 100%;
        height: 100%;

        display: flex;
        flex-direction: column;

        background: #fff;
    }

    .pf-product-modal .pf-modal-content,
    .pf-image-editor-modal .pf-modal-content {
        border: 1.5px solid var(--pf-products-strong);
        border-radius: 24px;
        background: #fff;
        box-shadow: 0 24px 80px rgba(47,33,26,.2);
    }

    .pf-product-modal .pf-modal-header,
    .pf-image-editor-modal .pf-modal-header {
        border-bottom: 1.5px solid var(--pf-products-line);
        padding: 16px 18px;
    }

    .pf-product-modal .modal-title,
    .pf-image-editor-modal .modal-title {
        margin: 3px 0 0;
        color: var(--pf-black);
        font-size: clamp(1.7rem, 3vw, 2.4rem);
        font-weight: 950;
        font-style: italic;
        letter-spacing: -.06em;
        line-height: .95;
    }

    .pf-product-modal .pf-modal-body,
    .pf-image-editor-modal .pf-modal-body {
        flex: 1 1 auto;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 16px;
    }

    .pf-modal-grid {
        display: grid;
        grid-template-columns: minmax(320px, .9fr) minmax(420px, 1.1fr);
        gap: 16px;
        align-items: start;
    }

    .pf-media-panel,
    .pf-editor-panel {
        border: 1.5px solid var(--pf-products-line);
        border-radius: 20px;
        padding: 12px;
        background: #fff;
    }

    .pf-primary-preview {
        aspect-ratio: 1 / 1;
        overflow: hidden;
        border: 1.5px solid var(--pf-products-line);
        border-radius: 18px;
        background: #fff;
    }

    .pf-primary-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .pf-upload-box label {
        width: 100%;
        min-height: 46px;
        margin: 10px 0;
        border: 1.5px dashed var(--pf-products-strong);
        border-radius: 16px;
        display: grid;
        place-items: center;
        cursor: pointer;
        color: var(--pf-brown);
        font-size: .74rem;
        font-weight: 950;
        letter-spacing: .12em;
        text-transform: uppercase;
        background: var(--pf-products-soft);
    }

    .pf-upload-box input {
        display: none;
    }

    .pf-photo-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .pf-photo-tile {
        border: 1.5px solid var(--pf-products-line);
        border-radius: 16px;
        padding: 8px;
        background: #fff;
    }

    .pf-photo-tile > img {
        width: 100%;
        aspect-ratio: 1 / 1;
        border-radius: 12px;
        object-fit: cover;
        border: 1.5px solid var(--pf-products-line);
        background: #fff;
    }

    .pf-photo-tile strong {
        display: block;
        margin-top: 7px;
        font-size: .82rem;
        font-weight: 950;
    }

    .pf-photo-tile span {
        color: var(--pf-muted);
        font-size: .72rem;
        font-weight: 750;
    }

    .pf-text-button {
        width: 100%;
        margin-top: 8px;
        min-height: 34px;
        border: 1.5px solid var(--pf-products-strong);
        border-radius: 12px;
        background: var(--pf-products-soft);
        color: var(--pf-brown);
        font-size: .68rem;
        font-weight: 950;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .pf-photo-actions {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 6px;
        margin-top: 7px;
    }

    .pf-photo-actions button,
    .pf-danger-zone button {
        width: 100%;
        min-height: 32px;
        border: 1.5px solid var(--pf-products-line);
        border-radius: 12px;
        background: #fff;
        color: var(--pf-brown);
        font-size: .66rem;
        font-weight: 950;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .pf-danger-zone {
        margin-top: 14px;
        padding-top: 14px;
        border-top: 1.5px solid var(--pf-products-line);
    }

    .pf-danger-zone button {
        border-color: #9b1c1c;
        color: #9b1c1c;
    }

    .pf-editor-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .pf-image-editor-modal {
        z-index: 2000;
    }

    .pf-adjust-stage {
        position: relative;
        width: min(100%, 620px);
        margin: 0 auto;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        border: 1.5px solid var(--pf-products-strong);
        border-radius: 20px;
        background:
            linear-gradient(90deg, rgba(146,105,80,.24) 1px, transparent 1px),
            linear-gradient(180deg, rgba(146,105,80,.24) 1px, transparent 1px),
            #fff;
        background-size: 33.333% 33.333%;
        cursor: grab;
        user-select: none;
        touch-action: none;
    }

    .pf-adjust-stage img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        pointer-events: none;
    }

    .pf-adjust-stage span {
        position: absolute;
        left: 12px;
        bottom: 12px;
        border-radius: 999px;
        background: #fff;
        border: 1.5px solid var(--pf-products-line);
        color: var(--pf-brown);
        padding: 6px 9px;
        font-size: .62rem;
        font-weight: 950;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .pf-adjust-zoom-label {
        width: min(100%, 620px);
        margin: 12px auto 0;
        color: var(--pf-brown);
        font-size: .68rem;
        font-weight: 950;
        letter-spacing: .1em;
        text-transform: uppercase;
        display: grid;
        gap: 8px;
    }

    .pf-adjust-zoom-label input {
        width: 100%;
        accent-color: var(--pf-products-strong);
    }

    .pf-image-editor-modal .pf-modal-footer {
        border-top: 1.5px solid var(--pf-products-line);
        padding: 12px 16px;
    }

    @@media (max-width: 1100px) {
        .pf-product-create-grid,
        .pf-editor-grid,
        .pf-modal-grid {
            grid-template-columns: 1fr;
        }

        .pf-product-table {
            min-width: 920px;
        }
    }

    @@media (max-width: 720px) {
        .pf-photo-grid {
            grid-template-columns: 1fr;
        }
    }
</style>


<script>
    (() => {
        const openModal = id => {
            const modal = document.getElementById(id);
            if (!modal) return;
            modal.classList.add("is-open");
            modal.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
        };

        const closeModal = modal => {
            if (!modal) return;
            modal.classList.remove("is-open");
            modal.setAttribute("aria-hidden", "true");

            if (!document.querySelector(".pf-product-modal.is-open, .pf-image-editor-modal.is-open")) {
                document.body.style.overflow = "";
            }
        };

        document.querySelectorAll("[data-pf-open]").forEach(button => {
            button.addEventListener("click", () => openModal(button.getAttribute("data-pf-open")));
        });

        document.querySelectorAll("[data-pf-close]").forEach(button => {
            button.addEventListener("click", () => closeModal(button.closest(".pf-product-modal, .pf-image-editor-modal")));
        });

        document.querySelectorAll(".pf-product-modal, .pf-image-editor-modal").forEach(modal => {
            modal.addEventListener("click", event => {
                if (event.target === modal) closeModal(modal);
            });
        });

        document.addEventListener("keydown", event => {
            if (event.key !== "Escape") return;
            const modals = [...document.querySelectorAll(".pf-image-editor-modal.is-open, .pf-product-modal.is-open")];
            closeModal(modals.at(-1));
        });
    })();
</script>

<script>
    (() => {
        document.querySelectorAll(".pf-price-dollars").forEach(input => {
            const form = input.closest("form");
            const cents = form?.querySelector(".pf-price-cents");

            const sync = () => {
                if (!cents) return;
                cents.value = Math.round(Number(input.value || 0) * 100).toString();
            };

            input.addEventListener("input", sync);
            form?.addEventListener("submit", sync);
            sync();
        });
    })();
</script>

<script>
    (() => {
        const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

        document.querySelectorAll("[data-pf-adjust-panel]").forEach(panel => {
            const stage = panel.querySelector("[data-pf-adjust-stage]");
            const img = panel.querySelector("[data-pf-adjust-img]");
            const posX = panel.querySelector("[data-pf-pos-x]");
            const posY = panel.querySelector("[data-pf-pos-y]");
            const zoomInput = panel.querySelector("[data-pf-adjust-zoom]");
            const zoomHidden = panel.querySelector("[data-pf-zoom]");

            if (!stage || !img || !posX || !posY || !zoomInput || !zoomHidden) return;

            let x = Number(stage.getAttribute("data-start-x") || 50);
            let y = Number(stage.getAttribute("data-start-y") || 50);
            let zoom = Number(stage.getAttribute("data-start-zoom") || 1);
            let dragging = false;
            let lastClientX = 0;
            let lastClientY = 0;

            const render = () => {
                img.style.objectPosition = `${x}% ${y}%`;
                img.style.transform = `scale(${zoom})`;
                posX.value = Math.round(x).toString();
                posY.value = Math.round(y).toString();
                zoomHidden.value = zoom.toString();
            };

            stage.addEventListener("pointerdown", event => {
                dragging = true;
                lastClientX = event.clientX;
                lastClientY = event.clientY;
                stage.setPointerCapture(event.pointerId);
            });

            stage.addEventListener("pointermove", event => {
                if (!dragging) return;

                const rect = stage.getBoundingClientRect();
                const deltaX = event.clientX - lastClientX;
                const deltaY = event.clientY - lastClientY;

                x = clamp(x - (deltaX / rect.width) * 100, 0, 100);
                y = clamp(y - (deltaY / rect.height) * 100, 0, 100);

                lastClientX = event.clientX;
                lastClientY = event.clientY;

                render();
            });

            stage.addEventListener("pointerup", event => {
                dragging = false;
                stage.releasePointerCapture(event.pointerId);
            });

            zoomInput.addEventListener("input", () => {
                zoom = Number(zoomInput.value || 1);
                render();
            });

            render();
        });
    })();
</script>
