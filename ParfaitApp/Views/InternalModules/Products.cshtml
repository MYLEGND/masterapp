<script>
    (() => {
        const openModal = id => {
            const modal = document.getElementById(id);
            if (!modal) return;
            modal.classList.add("is-open");
            modal.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
        };

        const closeModal = modal => {
            if (!modal) return;
            modal.classList.remove("is-open");
            modal.setAttribute("aria-hidden", "true");

            if (!document.querySelector(".pf-product-modal.is-open, .pf-image-editor-modal.is-open")) {
                document.body.style.overflow = "";
            }
        };

        document.querySelectorAll("[data-pf-open]").forEach(button => {
            button.addEventListener("click", () => openModal(button.getAttribute("data-pf-open")));
        });

        document.querySelectorAll("[data-pf-close]").forEach(button => {
            button.addEventListener("click", () => closeModal(button.closest(".pf-product-modal, .pf-image-editor-modal")));
        });

        document.querySelectorAll(".pf-product-modal, .pf-image-editor-modal").forEach(modal => {
            modal.addEventListener("click", event => {
                if (event.target === modal) closeModal(modal);
            });
        });

        document.addEventListener("keydown", event => {
            if (event.key !== "Escape") return;
            const modals = [...document.querySelectorAll(".pf-image-editor-modal.is-open, .pf-product-modal.is-open")];
            closeModal(modals.at(-1));
        });
    })();
</script>

<script>
    (() => {
        const syncMoneyInput = input => {
            const hidden = input.parentElement?.querySelector(".pf-money-hidden");
            if (!hidden) return;

            hidden.value = Math.round(Number(input.value || 0) * 100).toString();
        };

        document.querySelectorAll(".pf-money-display").forEach(input => {
            const form = input.closest("form");
            input.addEventListener("input", () => syncMoneyInput(input));
            form?.addEventListener("submit", () => syncMoneyInput(input));
            syncMoneyInput(input);
        });
    })();
</script>

<script>
    (() => {
        const slugify = value => (value || "")
            .trim()
            .toUpperCase()
            .replace(/[^A-Z0-9]+/g, "-")
            .replace(/^-+|-+$/g, "")
            .slice(0, 10) || "PARFAIT";

        const inventoryTemplate = document.getElementById("pfInventoryRowTemplate");
        const discountTemplate = document.getElementById("pfDiscountRowTemplate");

        const updateInventoryRow = row => {
            if (!row) return;

            const enabled = row.querySelector("[data-pf-enabled]")?.checked ?? false;
            const track = row.querySelector("[data-pf-track]")?.checked ?? false;
            const stock = Number(row.querySelector("[data-pf-stock]")?.value || 0);
            const threshold = Math.max(1, Number(row.querySelector("[data-pf-low-stock]")?.value || 1));
            const status = row.querySelector("[data-pf-inventory-status]");

            let tone = "is-success";
            let label = "Available";

            if (!enabled) {
                tone = "is-muted";
                label = "Hidden";
            } else if (!track) {
                tone = "is-info";
                label = "Available";
            } else if (stock <= 0) {
                tone = "is-danger";
                label = "Sold Out";
            } else if (stock <= threshold) {
                tone = "is-warning";
                label = `${stock} Left`;
            } else {
                tone = "is-success";
                label = `${stock} Ready`;
            }

            row.classList.remove("is-success", "is-warning", "is-danger", "is-info", "is-muted");
            row.classList.add(tone);

            if (status) {
                status.classList.remove("is-success", "is-warning", "is-danger", "is-info", "is-muted");
                status.classList.add(tone);
                status.textContent = label;
            }
        };

        const reindexCollection = container => {
            if (!container) return;

            const prefix = container.getAttribute("data-pf-collection");
            const rows = [...container.querySelectorAll("[data-pf-repeat-item]")];

            rows.forEach((row, index) => {
                row.querySelectorAll("[data-field]").forEach(field => {
                    const property = field.getAttribute("data-field");
                    field.name = `${prefix}[${index}].${property}`;
                });

                const orderInput = row.querySelector("[data-pf-order]");
                if (orderInput) {
                    orderInput.value = ((index + 1) * 10).toString();
                }

                if (row.hasAttribute("data-pf-inventory-row")) {
                    updateInventoryRow(row);
                }
            });
        };

        const addRow = (targetId, template) => {
            const container = document.getElementById(targetId);
            if (!container || !template) return;

            const fragment = template.content.cloneNode(true);
            container.appendChild(fragment);
            reindexCollection(container);
        };

        const wireRowRemoval = root => {
            root.addEventListener("click", event => {
                const removeButton = event.target.closest("[data-pf-remove-row]");
                if (!removeButton) return;

                const row = removeButton.closest("[data-pf-repeat-item]");
                const container = removeButton.closest("[data-pf-collection]");
                if (!row || !container) return;

                row.remove();
                reindexCollection(container);
            });
        };

        document.querySelectorAll("[data-pf-product-form]").forEach(form => {
            const nameInput = form.querySelector('input[name="Name"]');
            const slugInput = form.querySelector('input[name="Slug"]');

            nameInput?.addEventListener("input", () => {
                if (!slugInput || slugInput.value.trim().length > 0) return;
                slugInput.value = (nameInput.value || "")
                    .trim()
                    .toLowerCase()
                    .replace(/[^a-z0-9]+/g, "-")
                    .replace(/^-+|-+$/g, "");
            });

            form.querySelectorAll("[data-pf-collection]").forEach(reindexCollection);

            form.addEventListener("change", event => {
                const row = event.target.closest("[data-pf-inventory-row]");
                if (row) {
                    updateInventoryRow(row);
                }
            });

            form.addEventListener("input", event => {
                const row = event.target.closest("[data-pf-inventory-row]");
                if (row) {
                    updateInventoryRow(row);
                }
            });

            form.addEventListener("click", event => {
                const addButton = event.target.closest("[data-pf-add-row]");
                if (addButton) {
                    const type = addButton.getAttribute("data-pf-add-row");
                    const target = addButton.getAttribute("data-pf-target");
                    addRow(target, type === "inventory" ? inventoryTemplate : discountTemplate);
                    return;
                }

                const generateButton = event.target.closest("[data-pf-generate-code]");
                if (!generateButton) return;

                const row = generateButton.closest("[data-pf-repeat-item]");
                const codeInput = row?.querySelector('[data-field="Code"]');
                if (!codeInput) return;

                const prefix = slugify(nameInput?.value || "PARFAIT");
                const suffix = Math.random().toString(36).toUpperCase().replace(/[^A-Z0-9]/g, "").slice(0, 6);
                codeInput.value = `${prefix}-${suffix}`;
            });

            wireRowRemoval(form);
        });
    })();
</script>

<script>
    (() => {
        const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

        document.querySelectorAll("[data-pf-adjust-panel]").forEach(panel => {
            const stage = panel.querySelector("[data-pf-adjust-stage]");
            const img = panel.querySelector("[data-pf-adjust-img]");
            const posX = panel.querySelector("[data-pf-pos-x]");
            const posY = panel.querySelector("[data-pf-pos-y]");
            const zoomInput = panel.querySelector("[data-pf-adjust-zoom]");
            const zoomHidden = panel.querySelector("[data-pf-zoom]");

            if (!stage || !img || !posX || !posY || !zoomInput || !zoomHidden) return;

            let x = Number(stage.getAttribute("data-start-x") || 50);
            let y = Number(stage.getAttribute("data-start-y") || 50);
            let zoom = Number(stage.getAttribute("data-start-zoom") || 1);
            let dragging = false;
            let lastClientX = 0;
            let lastClientY = 0;

            const render = () => {
                img.style.objectPosition = `${x}% ${y}%`;
                img.style.transform = `scale(${zoom})`;
                posX.value = Math.round(x).toString();
                posY.value = Math.round(y).toString();
                zoomHidden.value = zoom.toString();
            };

            stage.addEventListener("pointerdown", event => {
                dragging = true;
                lastClientX = event.clientX;
                lastClientY = event.clientY;
                stage.setPointerCapture(event.pointerId);
            });

            stage.addEventListener("pointermove", event => {
                if (!dragging) return;

                const rect = stage.getBoundingClientRect();
                const deltaX = event.clientX - lastClientX;
                const deltaY = event.clientY - lastClientY;

                x = clamp(x - (deltaX / rect.width) * 100, 0, 100);
                y = clamp(y - (deltaY / rect.height) * 100, 0, 100);

                lastClientX = event.clientX;
                lastClientY = event.clientY;

                render();
            });

            stage.addEventListener("pointerup", event => {
                dragging = false;
                stage.releasePointerCapture(event.pointerId);
            });

            zoomInput.addEventListener("input", () => {
                zoom = Number(zoomInput.value || 1);
                render();
            });

            render();
        });
    })();
</script>
