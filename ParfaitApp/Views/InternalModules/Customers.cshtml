@{
    ViewData["Title"] = "Customers";
    Layout = "_InternalLayout";
}

<section class="pf-page-hero">
    <div class="pf-page-hero-main">
        <div class="pf-kicker">Customer System</div>
        <h1 class="pf-page-title">Customers</h1>
        <p class="pf-page-copy">Customer accounts, order history, support, segments, and engagement are managed from here.</p>
    </div>
</section>

<section class="row g-4">
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Client Accounts</h2><p class="text-muted mb-0">Future customer login, account profile, saved info, and order access.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Order History</h2><p class="text-muted mb-0">View customer purchase history, repeat buyers, and customer value.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Planned</span><h2 class="pf-module-title">Support</h2><p class="text-muted mb-0">Handle questions, returns, requests, and customer service records.</p></div></div>
    <div class="col-md-6 col-xl-4"><div class="pf-module-card"><span class="pf-status"><span class="pf-dot"></span> Later</span><h2 class="pf-module-title">Segments</h2><p class="text-muted mb-0">Group customers by behavior, purchases, campaign source, and engagement.</p></div></div>
</section>
