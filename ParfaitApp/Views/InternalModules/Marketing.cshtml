@model ParfaitApp.Models.ParfaitInternalWorkspaceSnapshotViewModel
@{
    ViewData["Title"] = "Marketing";
    Layout = "_InternalLayout";

    var metaTone = Model.HasMetaConnection ? "success" : Model.HasMetaPixel ? "warning" : "danger";
    var analyticsTone = Model.HasAnalyticsTraffic ? "success" : "warning";
}

<section class="pf-command-page">
    <header class="pf-command-head">
        <div class="pf-command-copy">
            <h1 class="pf-command-title">Marketing</h1>
            <p class="pf-command-text">Meta command, traffic, and creative readiness.</p>
        </div>
        <div class="pf-command-meta">
            <span class="pf-command-badge is-@metaTone">Meta @(Model.HasMetaConnection ? "secure" : "pending")</span>
            <span class="pf-command-badge is-@analyticsTone">@Model.Sessions sessions</span>
            <span class="pf-command-badge is-info">@Model.FeaturedProductCount featured</span>
        </div>
    </header>

    <section class="pf-command-rail">
        <article class="pf-rail-card is-@metaTone pf-span-4">
            <div class="pf-rail-label">Meta Readiness</div>
            <strong class="pf-rail-value">@(Model.HasMetaConnection ? "Live" : "Pending")</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Pixel Stored</span>
                    <strong>@(Model.HasMetaPixel ? "Yes" : "No")</strong>
                </div>
                <div>
                    <span>CAPI</span>
                    <strong>@(Model.HasMetaConnection ? "Secure" : "Pending")</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-@analyticsTone pf-span-4">
            <div class="pf-rail-label">Traffic Feed</div>
            <strong class="pf-rail-value">@Model.Sessions</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Visitors</span>
                    <strong>@Model.Visitors</strong>
                </div>
                <div>
                    <span>Purchases</span>
                    <strong>@Model.Purchases</strong>
                </div>
            </div>
        </article>

        <article class="pf-rail-card is-info pf-span-4">
            <div class="pf-rail-label">Creative Surface</div>
            <strong class="pf-rail-value">@Model.FeaturedProductCount</strong>
            <div class="pf-rail-grid">
                <div>
                    <span>Featured</span>
                    <strong>@Model.FeaturedProductCount</strong>
                </div>
                <div>
                    <span>Images</span>
                    <strong>@Model.ProductImageCount</strong>
                </div>
            </div>
        </article>
    </section>

    <section class="pf-command-board">
        <div class="pf-command-board-head">
            <div>
                <h2>Signal, Traffic, Story</h2>
                <p>Connection status, traffic, and storefront presentation.</p>
            </div>
        <div class="pf-command-board-actions">
            <a class="pf-secondary-action" href="/internal/analytics">Analytics</a>
            <a class="pf-secondary-action" href="/internal/marketing/automations">Automations</a>
            <a class="pf-secondary-action" href="/internal/settings/business-profile">Business Profile</a>
        </div>
        </div>

        <div class="pf-focus-grid">
            <article class="pf-focus-card is-@metaTone pf-span-4">
                <div class="pf-focus-label">Signal Setup</div>
                <h3 class="pf-focus-title">Meta Connection</h3>
                <div class="pf-focus-value">@(Model.HasMetaConnection ? "Secure" : "Pending")</div>
                <p class="pf-focus-copy">@Model.MetaConnectionLabel</p>
                <div class="pf-focus-list">
                    <div>
                        <span>Pixel Status</span>
                        <strong>@(Model.HasMetaPixel ? "Stored" : "Missing")</strong>
                    </div>
                    <div>
                        <span>CAPI Status</span>
                        <strong>@Model.MetaCapiStatus</strong>
                    </div>
                </div>
                <div class="pf-focus-actions">
                    <a class="pf-action" href="/internal/analytics">Open Analytics</a>
                </div>
            </article>

            <article class="pf-focus-card is-@analyticsTone pf-span-4">
                <div class="pf-focus-label">Traffic Quality</div>
                <h3 class="pf-focus-title">Analytics Feed</h3>
                <div class="pf-focus-value">@Model.Sessions</div>
                <p class="pf-focus-copy">Traffic, store views, and cart activity.</p>
                <div class="pf-focus-list">
                    <div>
                        <span>Store Views</span>
                        <strong>@Model.StoreViews</strong>
                    </div>
                    <div>
                        <span>Add To Cart</span>
                        <strong>@Model.AddToCarts</strong>
                    </div>
                </div>
                <div class="pf-focus-actions">
                    <a class="pf-action" href="/internal/analytics">Open Analytics</a>
                </div>
            </article>

            <article class="pf-focus-card is-info pf-span-4">
                <div class="pf-focus-label">Store Story</div>
                <h3 class="pf-focus-title">Creative Read</h3>
                <div class="pf-focus-value">@Model.ProductImageCount</div>
                <p class="pf-focus-copy">Featured products and image coverage.</p>
                <div class="pf-focus-list">
                    <div>
                        <span>Featured Products</span>
                        <strong>@Model.FeaturedProductCount</strong>
                    </div>
                    <div>
                        <span>Products</span>
                        <strong>@Model.ProductCount</strong>
                    </div>
                </div>
                <div class="pf-focus-actions">
                    <a class="pf-action" href="/internal/content">Open Content</a>
                </div>
            </article>
        </div>
    </section>
</section>
