@{
    ViewData["Title"] = "Marketing";
    Layout = "_InternalLayout";
}

<section class="pf-panel mb-4">
    <div class="pf-kicker">Growth Engine</div>
    <h1 class="pf-page-title">Marketing</h1>
    <p class="pf-page-copy">Future campaign command center for Meta attribution, traffic quality, creative performance, and customer acquisition.</p>
</section>

