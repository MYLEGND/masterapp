@{
    ViewData["Title"] = "Contact Us";
    ViewData["PageKey"] = "contact";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var contactEmail = (ViewData["ContactEmail"] as string ?? "parfait@mylegnd.com").Trim();
    var subject = Uri.EscapeDataString("Parfait Inquiry");
    var body = Uri.EscapeDataString("Hi Parfait,\n\nName:\nBest number:\nQuestion:\n\nThank you!");
    var mailto = $"mailto:{contactEmail}?subject={subject}&body={body}";
    var serializedEmail = System.Text.Json.JsonSerializer.Serialize(contactEmail);
}

<div class="contact-clarity">
    <div class="contact-clarity__card" aria-label="Contact Parfait">
        <div class="contact-clarity__header">
            <div class="contact-clarity__brand-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M3.75 7.5 12 13.5l8.25-6" />
                    <rect x="3.75" y="5.25" width="16.5" height="13.5" rx="2.5" />
                </svg>
            </div>

            <div class="contact-clarity__header-copy">
                <h1 class="contact-clarity__title">Contact Us</h1>
                <p class="contact-clarity__subtitle">Questions, support, and next steps.</p>
            </div>
        </div>

        <div class="contact-clarity__inbox">
            <span class="contact-clarity__inbox-label">Email</span>
            <a class="contact-clarity__email" href="@mailto">@contactEmail</a>
        </div>

        <div class="contact-clarity__actions">
            <a class="contact-clarity__button contact-clarity__button--primary"
               href="@mailto"
               data-cta="contact_email">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M4 6.75h16v10.5H4z" />
                    <path d="m5 8 7 5 7-5" />
                </svg>
                <span>Email</span>
            </a>

            <button class="contact-clarity__button contact-clarity__button--secondary"
                    type="button"
                    id="copyEmailBtn"
                    data-email="@contactEmail"
                    data-cta="contact_copy_email"
                    aria-label="Copy email address">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <rect x="8" y="8" width="10" height="10" rx="2" />
                    <path d="M6.5 15.5h-1a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1" />
                </svg>
                <span>Copy</span>
            </button>
        </div>
    </div>
</div>

<script>
(() => {
    const btn = document.getElementById('copyEmailBtn');
    if (!btn) return;

    const email = btn.dataset.email || @Html.Raw(serializedEmail);
    const label = btn.querySelector('span');
    const defaultLabel = label?.textContent || 'Copy';

    const setCopiedState = () => {
        if (label) label.textContent = 'Copied';
        btn.classList.add('is-copied');

        window.setTimeout(() => {
            if (label) label.textContent = defaultLabel;
            btn.classList.remove('is-copied');
        }, 1400);
    };

    const legacyCopy = (value) => {
        const area = document.createElement('textarea');
        area.value = value;
        area.setAttribute('readonly', '');
        area.style.position = 'fixed';
        area.style.top = '-9999px';
        area.style.left = '-9999px';
        document.body.appendChild(area);
        area.focus();
        area.select();
        area.setSelectionRange(0, area.value.length);
        let copied = false;
        try { copied = document.execCommand('copy'); } catch (err) { copied = false; }
        document.body.removeChild(area);
        return copied;
    };

    btn.addEventListener('click', async () => {
        if (!email) return;

        try {
            if (navigator.clipboard && window.isSecureContext) {
                await navigator.clipboard.writeText(email);
                setCopiedState();
                return;
            }
        } catch (err) {
        }

        if (legacyCopy(email)) {
            setCopiedState();
            return;
        }

        window.prompt('Copy email address:', email);
    });
})();
</script>

<style>
.contact-clarity{
    --contact-cocoa:#6f4b3b;
    --contact-cocoa-deep:#4d3429;
    --contact-cocoa-ink:#2b1c16;
    --contact-cream:#f6ede3;
    --contact-border:rgba(179,131,97,.34);
    --contact-text:#fff9f5;
    --contact-muted:#e8d7ca;
    max-width: 760px;
    margin: 0 auto;
    padding: 2.2rem 1rem 4rem;
}

.contact-clarity__card{
    padding: clamp(1.25rem, 3vw, 1.9rem);
    border-radius: 30px;
    border: 1px solid var(--contact-border);
    background:
        radial-gradient(circle at top right, rgba(246,237,227,.12), transparent 20%),
        linear-gradient(180deg, rgba(111,75,59,.98), rgba(77,52,41,1));
    box-shadow:
        0 30px 76px rgba(43, 28, 22, .2),
        inset 0 1px 0 rgba(255,255,255,.04);
    color: var(--contact-text);
}

.contact-clarity__header{
    display:grid;
    grid-template-columns:auto minmax(0, 1fr);
    gap:1rem;
    align-items:center;
    margin-bottom:1.15rem;
}

.contact-clarity__brand-mark{
    width:64px;
    height:64px;
    border-radius:20px;
    border:1px solid var(--contact-border);
    background:linear-gradient(180deg, rgba(246,237,227,.16), rgba(246,237,227,.06));
    display:grid;
    place-items:center;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.05);
}

.contact-clarity__brand-mark svg{
    width:28px;
    height:28px;
    fill:none;
    stroke:var(--contact-cream);
    stroke-width:1.8;
    stroke-linecap:round;
    stroke-linejoin:round;
}

.contact-clarity__title{
    margin:0;
    color:var(--contact-text);
    font-size:clamp(2.2rem, 4vw, 3.3rem);
    line-height:1;
    letter-spacing:-.05em;
}

.contact-clarity__subtitle{
    margin:.38rem 0 0;
    color:var(--contact-muted);
    font-size:1rem;
    line-height:1.5;
}

.contact-clarity__inbox{
    margin-bottom:1rem;
    padding:1.15rem 1.2rem;
    border-radius:24px;
    border:1px solid rgba(255,255,255,.08);
    background:linear-gradient(180deg, rgba(43,28,22,.34), rgba(77,52,41,.48));
}

.contact-clarity__inbox-label{
    display:block;
    margin-bottom:.4rem;
    color:var(--contact-cream);
    font-size:.8rem;
    font-weight:900;
    letter-spacing:.18em;
    text-transform:uppercase;
}

.contact-clarity__email{
    color:var(--contact-text);
    font-size:clamp(1.55rem, 3vw, 2.4rem);
    font-weight:900;
    letter-spacing:-.04em;
    text-decoration:none;
    word-break:break-word;
}

.contact-clarity__email:hover{
    color:#ffffff;
}

.contact-clarity__actions{
    display:grid;
    grid-template-columns:repeat(2, minmax(0, 1fr));
    gap:.85rem;
}

.contact-clarity__button{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:.7rem;
    min-height:60px;
    padding:0 1rem;
    border-radius:18px;
    border:1px solid var(--contact-border);
    font-size:1rem;
    font-weight:900;
    letter-spacing:-.02em;
    text-decoration:none;
    transition:transform .16s ease, background-color .16s ease, color .16s ease, border-color .16s ease;
    cursor:pointer;
}

.contact-clarity__button svg{
    width:20px;
    height:20px;
    fill:none;
    stroke:currentColor;
    stroke-width:1.85;
    stroke-linecap:round;
    stroke-linejoin:round;
}

.contact-clarity__button:hover{
    transform:translateY(-1px);
}

.contact-clarity__button--primary{
    background:linear-gradient(180deg, #f6ede3, #e6cfbe);
    color:var(--contact-cocoa-ink);
}

.contact-clarity__button--secondary{
    background:rgba(255,255,255,.04);
    color:var(--contact-text);
}

.contact-clarity__button--secondary.is-copied{
    background:rgba(246,237,227,.16);
    color:#fff9f5;
    border-color:rgba(246,237,227,.42);
}

@@media (max-width: 640px){
    .contact-clarity{
        padding: 1.3rem .85rem 3rem;
    }

    .contact-clarity__card{
        padding: 1rem;
        border-radius: 24px;
    }

    .contact-clarity__header{
        grid-template-columns:1fr;
    }

    .contact-clarity__brand-mark{
        width:58px;
        height:58px;
        border-radius:18px;
    }

    .contact-clarity__actions{
        grid-template-columns:1fr;
    }
}

@@media (prefers-reduced-motion: reduce){
    .contact-clarity__button{
        transition:none;
    }
}
</style>
