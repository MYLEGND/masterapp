@{
    ViewData["Title"] = "Contact";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="contact-wrap">

    <!-- HERO -->
    <div class="hero">
        <h1 class="title">Contact Parfait</h1>
        <p class="sub">
            Questions about training packages, subscriptions, or the mission?
            Tap below and send us an email — from <span class="accent">any provider you use</span>.
        </p>
        <hr class="hero-hr" />
    </div>

    <!-- CARD -->
    <section class="card" aria-label="Contact card">
        <div class="badge">Get in touch</div>

        <div class="card-body">

            <div class="identity">
                <div class="logo-ring" aria-hidden="true">
                    <div class="logo-dot"></div>
                </div>

                <div class="identity-text">
                    <div class="brand">Parfait</div>
                    <div class="tagline">Build your Parfait Body. Own your power.</div>
                </div>
            </div>

            <div class="divider"></div>

            <div class="info">
                <div class="row">
                    <div class="label">Email</div>
                    <div class="value">
                        <a class="link" href="mailto:parfait@mylegnd.com?subject=Parfait%20Inquiry&body=Hi%20Parfait%2C%0A%0AName%3A%0AQuestion%3A%0A%0AThank%20you%21">
                            parfait@mylegnd.com
                        </a>
                    </div>
                </div>

                <!-- Optional: if you want phone later, uncomment and set number -->
                @*
                <div class="row">
                    <div class="label">Phone</div>
                    <div class="value">
                        <a class="link" href="tel:+16025551234">(602) 555-1234</a>
                    </div>
                </div>
                *@
            </div>

            <div class="actions">
                <a class="btn primary"
                   href="mailto:parfait@mylegnd.com?subject=Parfait%20Inquiry&body=Hi%20Parfait%2C%0A%0AName%3A%0AQuestion%3A%0A%0AThank%20you%21">
                    Email Parfait
                </a>

                <button class="btn ghost" type="button" id="copyEmailBtn" aria-label="Copy email address">
                    Copy Email
                </button>
            </div>

            <p class="fineprint">
                This opens your email app (Gmail, Apple Mail, Outlook, etc.). No forms, no friction.
            </p>

            <div class="micro">
                <span class="pill">Fast reply</span>
                <span class="pill">Training questions</span>
                <span class="pill">Subscriptions</span>
            </div>

        </div>
    </section>

</div>

<style>
:root{
    --gold:#926950;
    --gold-soft: rgba(146,105,80,0.18);
    --gold-soft-2: rgba(146,105,80,0.10);
    --ink:#0f0f10;
    --muted:#6a6a6a;
    --card:#ffffff;
    --bg:#fbfaf9;

    --radius: 22px;
    --shadow: 0 18px 55px rgba(0,0,0,0.10);
    --shadow-soft: 0 12px 26px rgba(0,0,0,0.08);
}

*{ -webkit-tap-highlight-color: transparent; }
html{ scroll-behavior: smooth; }
body{ -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

/* Wrapper */
.contact-wrap{
    padding: 2.25rem 1rem 3.25rem;
    max-width: 1050px;
    margin: 0 auto;
    font-family: 'Inter', sans-serif;
    color: var(--ink);
}

/* HERO */
.hero{
    text-align: center;
    margin-bottom: 2.2rem;
}

.kicker{
    display:inline-flex;
    align-items:center;
    gap: 8px;
    padding: 7px 13px;
    border-radius: 999px;
    border: 1px solid rgba(146,105,80,0.28);
    background: rgba(146,105,80,0.06);
    color: var(--gold);
    font-weight: 900;
    letter-spacing: .9px;
    text-transform: uppercase;
    font-size: .82rem;
}

.title{
    margin: .85rem 0 .4rem;
    font-weight: 950;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.03em;
}

.sub{
    max-width: 840px;
    margin: 0 auto;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.75;
}

.accent{ color: var(--gold); font-weight: 950; }

.hero-hr{
    border: none;
    height: 2px;
    width: min(860px, 92%);
    margin: 1.1rem auto 0;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    border-radius: 999px;
    opacity: .95;
}

/* CARD */
.card{
    position: relative;
    margin: 0 auto;
    border-radius: var(--radius);
    overflow: hidden;

    /* keep it from becoming a football field on desktop */
    max-width: 760px;

    background:
        radial-gradient(1200px 500px at 10% -10%, rgba(146,105,80,0.16), transparent 55%),
        radial-gradient(900px 420px at 110% 0%, rgba(146,105,80,0.10), transparent 55%),
        linear-gradient(180deg, #ffffff 0%, #ffffff 50%, var(--bg) 100%);

    border: 1.5px solid rgba(146,105,80,0.35);
    box-shadow: var(--shadow);
}

.card::before{
    content:"";
    position:absolute;
    inset: 10px;
    border-radius: calc(var(--radius) - 10px);
    border: 1px solid rgba(15,15,16,0.06);
    pointer-events:none;
}

.badge{
    position: absolute;
    top: 16px;
    right: 16px;
    padding: 8px 12px;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(146,105,80,1), rgba(146,105,80,0.92));
    color: #fff;
    font-weight: 950;
    letter-spacing: .9px;
    text-transform: uppercase;
    font-size: .76rem;
    box-shadow: 0 10px 22px rgba(146,105,80,0.25);
}

.card-body{
    padding: clamp(22px, 4vw, 34px);
}

/* Identity */
.identity{
    display: flex;
    gap: 14px;
    align-items: center;
}

.logo-ring{
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: rgba(146,105,80,0.10);
    border: 1px solid rgba(146,105,80,0.28);
    display: grid;
    place-items: center;
    box-shadow: 0 10px 22px var(--gold-soft);
}

.logo-dot{
    width: 18px;
    height: 18px;
    border-radius: 6px;
    background: var(--gold);
    box-shadow: 0 8px 18px rgba(146,105,80,0.30);
}

.identity-text .brand{
    font-family: 'Georgia', serif;
    font-size: 1.6rem;
    font-weight: 950;
    letter-spacing: .02em;
}

.tagline{
    color: var(--muted);
    margin-top: 3px;
    font-size: 1rem;
    line-height: 1.5;
}

.divider{
    height: 1px;
    background: rgba(15,15,16,0.08);
    margin: 18px 0 18px;
}

/* Info rows */
.info{
    display: grid;
    gap: 12px;
    margin-bottom: 18px;
}

.row{
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 12px;
    align-items: center;
    padding: 10px 12px;
    border-radius: 14px;
    background: rgba(255,255,255,0.7);
    border: 1px solid rgba(15,15,16,0.06);
}

.label{
    font-weight: 950;
    color: rgba(15,15,16,0.72);
    text-transform: uppercase;
    letter-spacing: .95px;
    font-size: .78rem;
}

.value{
    font-size: 1.05rem;
    font-weight: 900;
    min-width: 0;
}

/* Email link (theme gold) */
.link{
    color: var(--gold);
    text-decoration: none;
    border-bottom: 2px solid rgba(146,105,80,0.28);
    padding-bottom: 2px;
    overflow-wrap: anywhere;
    word-break: break-word;
}
.link:hover{
    border-bottom-color: rgba(146,105,80,0.55);
}

/* Actions */
.actions{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

.btn{
    appearance: none;
    cursor: pointer;
    text-decoration: none;
    font-weight: 950;
    border-radius: 16px;
    padding: 14px 14px;
    text-align: center;
    transition: transform .16s ease, box-shadow .16s ease, background .16s ease, border-color .16s ease;
    user-select: none;
    line-height: 1.1;
    border: none;
}

.btn:active{ transform: translateY(0px) scale(0.99); }

.btn.primary{
    background: linear-gradient(180deg, rgba(146,105,80,1), rgba(146,105,80,0.92));
    color: #fff;
    box-shadow: 0 12px 26px rgba(146,105,80,0.22);
}

.btn.primary:hover{
    transform: translateY(-2px);
    box-shadow: 0 18px 36px rgba(146,105,80,0.22);
}

.btn.ghost{
    background: #fff;
    color: var(--ink);
    border: 2px solid rgba(146,105,80,0.40);
    box-shadow: var(--shadow-soft);
}

.btn.ghost:hover{
    transform: translateY(-2px);
    border-color: rgba(146,105,80,0.55);
    box-shadow: 0 16px 34px rgba(0,0,0,0.10);
}

/* Focus states (theme gold) */
.btn:focus-visible,
.link:focus-visible{
    outline: 3px solid rgba(146,105,80,0.28);
    outline-offset: 3px;
    border-radius: 12px;
}

/* Fineprint + pills */
.fineprint{
    margin: 14px 0 0;
    color: var(--muted);
    font-size: .92rem;
    line-height: 1.6;
    text-align: center;
}

.micro{
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
}

.pill{
    border: 1px solid rgba(146,105,80,0.25);
    background: rgba(146,105,80,0.06);
    color: rgba(15,15,16,0.82);
    padding: 7px 10px;
    border-radius: 999px;
    font-weight: 850;
    font-size: .82rem;
}

/* Copied flash (theme gold) */
.btn.copied{
    background: rgba(146,105,80,0.08);
    border-color: rgba(146,105,80,0.45);
}

/* Mobile polish */
@@media (max-width: 576px){
    .contact-wrap{ padding: 1.9rem 1rem 3rem; }
    .row{ grid-template-columns: 88px 1fr; }
    .actions{ grid-template-columns: 1fr; }
    .badge{ top: 12px; right: 12px; }
    .logo-ring{ width: 52px; height: 52px; border-radius: 16px; }
    .btn{ padding: 15px 14px; } /* slightly more thumb-friendly */
}

/* Reduce motion */
@@media (prefers-reduced-motion: reduce){
    *{ transition: none !important; scroll-behavior: auto !important; }
}
</style>

<script>
(() => {
  const btn = document.getElementById('copyEmailBtn');
  if (!btn) return;

  const email = 'parfait@mylegnd.com';

  const setCopiedUI = () => {
    const original = btn.textContent;
    btn.textContent = 'Copied ✓';
    btn.classList.add('copied');
    btn.setAttribute('aria-live', 'polite');

    setTimeout(() => {
      btn.textContent = original;
      btn.classList.remove('copied');
    }, 1200);
  };

  const legacyCopy = (text) => {
    const ta = document.createElement('textarea');
    ta.value = text;
    ta.setAttribute('readonly', '');
    ta.style.position = 'fixed';
    ta.style.top = '-9999px';
    ta.style.left = '-9999px';
    ta.style.opacity = '0';

    document.body.appendChild(ta);
    ta.focus();
    ta.select();
    ta.setSelectionRange(0, ta.value.length); // iOS

    let ok = false;
    try { ok = document.execCommand('copy'); } catch (e) { ok = false; }

    document.body.removeChild(ta);
    return ok;
  };

  btn.addEventListener('click', async () => {
    // Modern clipboard (best case: https + permission)
    try {
      if (navigator.clipboard && window.isSecureContext) {
        await navigator.clipboard.writeText(email);
        setCopiedUI();
        return;
      }
    } catch (e) { /* fall through */ }

    // Fallback for iOS/Safari/non-secure contexts
    const ok = legacyCopy(email);
    if (ok) {
      setCopiedUI();
    } else {
      window.prompt('Copy email:', email);
    }
  });
})();
</script>
