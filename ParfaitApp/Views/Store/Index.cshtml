@model ParfaitApp.Models.ParfaitStorefrontViewModel
@{
    ViewData["Title"] = "ShopParfait Store";
}

<section class="sp-collection-hero">
    <h1>PARFAIT COLLECTION</h1>
</section>

<section class="sp-product-grid" aria-label="ShopParfait products">
    @foreach (var product in Model.Products)
    {
        <article class="sp-product">
            <a class="sp-product-image-link" href="/store/product/@product.Slug" aria-label="View @product.Name">
                <img src="@product.PrimaryImageUrl" alt="@product.Name" class="sp-product-image" style="object-fit:@product.PrimaryImageObjectFit; object-position:@product.PrimaryImageObjectPositionX% @product.PrimaryImageObjectPositionY%; transform:scale(@product.PrimaryImageZoom.ToString("0.##")); transform-origin:center;" />
            </a>

            <div class="sp-product-info">
                <h2>@product.Name</h2>
                <div class="sp-product-price">@product.PriceLabel</div>

                <select class="sp-product-select" aria-label="Select size for @product.Name">
                    <option>XS</option>
                    <option>S</option>
                    <option>M</option>
                    <option>L</option>
                    <option>XL</option>
                </select>

                <a class="sp-product-button" href="/store/product/@product.Slug">
                    View Options
                </a>
            </div>
        </article>
    }
</section>

<style>
    body {
        background: #fff;
    }

    .sp-collection-hero {
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;

        width: 100vw;

        padding: 1.05rem 1rem .95rem;

        border-bottom: 1.5px solid #9a6a50;

        background: #f7f7f7;
        text-align: center;
    }

    .sp-collection-hero h1 {
        margin: 0;

        color: #000;

        font-size: clamp(2.8rem, 6.2vw, 4.8rem);

        font-weight: 400;
        font-style: italic;

        letter-spacing: -.055em;
        line-height: .92;
    }

    .sp-product-grid {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 2.15rem clamp(1.5rem, 2.5vw, 3rem) 5rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        column-gap: .75rem;
        row-gap: 2.2rem;
    }

    .sp-product {
        min-width: 0;
        text-align: center;
    }

    .sp-product-image-link {
        display: block;
        width: 100%;
        aspect-ratio: 1.18 / 1;
        overflow: hidden;
        background: #f4f4f4;
        text-decoration: none;
    }

    .sp-product-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .sp-product-info {
        padding: 1.35rem 0 0;
    }

    .sp-product-info h2 {
        margin: 0 0 .55rem;
        color: #000;
        font-size: clamp(1.35rem, 2vw, 1.85rem);
        font-weight: 400;
        letter-spacing: -.035em;
        line-height: 1.08;
    }

    .sp-product-price {
        margin-bottom: 1rem;
        color: #000;
        font-size: 1.02rem;
        font-weight: 400;
    }

    .sp-product-select {
        width: 100%;
        height: 56px;
        margin: 0 0 .55rem;
        padding: 0 1rem;
        border: 0;
        border-radius: 999px;
        background: #f5f5f5;
        color: #000;
        font-size: 1rem;
        outline: none;
    }

    .sp-product-button {
        width: 100%;
        min-height: 56px;
        border: 4px solid #bd8200;
        border-radius: 999px;
        background: #fff;
        color: #bd8200;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 400;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background .16s ease, color .16s ease;
    }

    .sp-product-button:hover {
        background: #bd8200;
        color: #fff;
    }

    @@media (max-width: 980px) {
        .sp-product-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .sp-product-grid {
            grid-template-columns: 1fr;
            padding-inline: 1rem;
        }

        .sp-product-image-link {
            aspect-ratio: 1 / 1;
        }
    }
</style>
