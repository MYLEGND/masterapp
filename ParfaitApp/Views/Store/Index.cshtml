@model ParfaitApp.Models.ParfaitStorefrontViewModel
@{
    ViewData["Title"] = "Collection";
    ViewData["BodyClass"] = "sp-body";
    ViewData["ContentContainerClass"] = "container-fluid";
    ViewData["LayoutContentClass"] = "sp-layout-content";

    static string ImageDisplayStyle(string? fit, int positionX, int positionY, decimal zoom)
    {
        var safeFit = string.Equals(fit, "contain", StringComparison.OrdinalIgnoreCase) ? "contain" : "cover";
        var safeZoom = zoom <= 0 ? 1.0m : zoom;
        return $"object-fit:{safeFit}; object-position:{positionX}% {positionY}%; transform-origin:{positionX}% {positionY}%; transform:scale({safeZoom.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)});";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/storefront.css" asp-append-version="true" />
}

<section class="sp-store-page">
    <div class="sp-shell sp-shell--wide">
        <header class="sp-store-hero sp-store-hero--collection">
            <h1>Parfait Collection</h1>
        </header>

        <section class="sp-shop-grid" aria-label="Parfait products">
            @foreach (var product in Model.Products)
            {
                <article class="sp-shop-card">
                    <a class="sp-shop-media" href="/store/product/@product.Slug" aria-label="View @product.Name">
                        @if (!string.IsNullOrWhiteSpace(product.Badge))
                        {
                            <span class="sp-shop-badge">@product.Badge</span>
                        }
                        <img src="@product.PrimaryImageUrl"
                             alt="@product.Name"
                             style="@ImageDisplayStyle(product.PrimaryImageObjectFit, product.PrimaryImageObjectPositionX, product.PrimaryImageObjectPositionY, product.PrimaryImageZoom)" />
                    </a>

                    <div class="sp-shop-content">
                        <div class="sp-shop-copy">
                            <h2>@product.Name</h2>
                        </div>

                        <div class="sp-shop-meta">
                            <div class="sp-shop-price-stack">
                                @if (product.HasDisplaySalePrice)
                                {
                                    <div class="sp-shop-compare-price">@product.DisplayCompareAtPriceLabel</div>
                                }
                                <div class="sp-shop-price">@product.DisplayPriceLabel</div>
                            </div>
                        </div>

                        <div class="sp-shop-actions">
                            <a class="sp-button sp-button--primary sp-shop-link" href="/store/product/@product.Slug">View Product</a>
                        </div>
                    </div>
                </article>
            }
        </section>
    </div>
</section>
