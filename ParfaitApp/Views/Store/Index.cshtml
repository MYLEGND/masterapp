@model ParfaitApp.Models.ParfaitStorefrontViewModel
@{
    ViewData["Title"] = "ShopParfait Store";
}

<section class="sp-store-hero">
    <div class="sp-store-kicker">@Model.StoreName</div>
    <h1>@Model.Headline</h1>
    <p>@Model.Subheadline</p>
</section>

<section class="sp-store-grid" aria-label="ShopParfait products">
    @foreach (var product in Model.Products)
    {
        <article class="sp-product-card">
            <div class="sp-product-image-wrap">
                <img src="@product.ImageUrl" alt="@product.Name" class="sp-product-image" />
                <span class="sp-product-badge">@product.Badge</span>
            </div>

            <div class="sp-product-body">
                <h2>@product.Name</h2>
                <p>@product.Description</p>
                <div class="sp-product-footer">
                    <span>@product.PriceLabel</span>
                    <a href="/store/product/@product.Slug">View</a>
                </div>
            </div>
        </article>
    }
</section>

<style>
    .sp-store-hero {
        max-width: 1180px;
        margin: 3rem auto 2rem;
        padding: clamp(2rem, 5vw, 4rem);
        border-radius: 34px;
        background:
            radial-gradient(circle at 12% 0%, rgba(214,176,106,.24), transparent 34%),
            linear-gradient(180deg, #fffaf6, #f6eee8);
        border: 1px solid rgba(169,113,85,.22);
        box-shadow: 0 24px 70px rgba(47,33,26,.12);
        text-align: center;
    }

    .sp-store-kicker {
        color: #7d4f3e;
        font-size: .78rem;
        font-weight: 950;
        letter-spacing: .22em;
        text-transform: uppercase;
    }

    .sp-store-hero h1 {
        max-width: 880px;
        margin: .8rem auto 1rem;
        font-size: clamp(2.4rem, 6vw, 5rem);
        font-weight: 950;
        letter-spacing: -.075em;
        line-height: .94;
        color: #2f211a;
    }

    .sp-store-hero p {
        max-width: 760px;
        margin: 0 auto;
        color: #746861;
        font-size: 1.12rem;
        line-height: 1.6;
    }

    .sp-store-grid {
        max-width: 1180px;
        margin: 0 auto 5rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.35rem;
    }

    .sp-product-card {
        min-height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border-radius: 28px;
        background: #fff;
        border: 1px solid rgba(169,113,85,.22);
        box-shadow: 0 18px 50px rgba(47,33,26,.09);
    }

    .sp-product-image-wrap {
        position: relative;
        aspect-ratio: 1 / 1;
        background: linear-gradient(180deg, #fcfaf8, #f6eee8);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .sp-product-image {
        width: 72%;
        height: 72%;
        object-fit: contain;
    }

    .sp-product-badge {
        position: absolute;
        top: 1rem;
        left: 1rem;
        border-radius: 999px;
        padding: .45rem .75rem;
        background: rgba(214,176,106,.18);
        border: 1px solid rgba(169,113,85,.24);
        color: #7d4f3e;
        font-size: .7rem;
        font-weight: 950;
        letter-spacing: .1em;
        text-transform: uppercase;
    }

    .sp-product-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 1.35rem;
    }

    .sp-product-body h2 {
        font-size: 1.25rem;
        font-weight: 950;
        letter-spacing: -.035em;
        color: #2f211a;
        margin: 0 0 .55rem;
    }

    .sp-product-body p {
        color: #746861;
        line-height: 1.5;
        margin: 0;
        flex: 1;
    }

    .sp-product-footer {
        margin-top: 1.4rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .sp-product-footer span {
        color: #2f211a;
        font-weight: 950;
    }

    .sp-product-footer a {
        border-radius: 999px;
        padding: .7rem 1rem;
        text-decoration: none;
        font-weight: 950;
        color: #fff;
        background: linear-gradient(180deg, #d6b06a, #a97155);
    }

    @@media (max-width: 980px) {
        .sp-store-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 640px) {
        .sp-store-hero {
            margin: 1.5rem 1rem 1rem;
        }

        .sp-store-grid {
            margin: 0 1rem 3rem;
            grid-template-columns: 1fr;
        }
    }
</style>
