@{
    ViewData["Title"] = "Checkout";
    ViewData["BodyClass"] = "sp-body";
    ViewData["ContentContainerClass"] = "container-fluid";
    ViewData["LayoutContentClass"] = "sp-layout-content";

    var appId = ViewBag.SquareApplicationId as string;
    var locationId = ViewBag.SquareLocationId as string;
    var environment = ViewBag.SquareEnvironment as string ?? "Sandbox";
    var squareScript = environment.Equals("Production", StringComparison.OrdinalIgnoreCase)
        ? "https://web.squarecdn.com/v1/square.js"
        : "https://sandbox.web.squarecdn.com/v1/square.js";

    var appIdJson = System.Text.Json.JsonSerializer.Serialize(appId ?? "");
    var locationIdJson = System.Text.Json.JsonSerializer.Serialize(locationId ?? "");
}

@section Styles {
    <link rel="stylesheet" href="~/css/storefront.css" asp-append-version="true" />
}

<section class="sp-store-page sp-store-page--checkout">
    <div class="sp-shell">
        <header class="sp-store-hero sp-store-hero--compact sp-store-hero--transaction">
            <h1>Complete Your Order</h1>
        </header>

        @Html.AntiForgeryToken()

        <div class="sp-checkout-grid">
            <section class="sp-surface sp-checkout-card sp-checkout-form-card">
                <div class="sp-checkout-section">
                    <div class="sp-checkout-section-head">
                        <h2>Contact Information</h2>
                    </div>

                    <div class="sp-field-grid">
                        <label class="sp-field">
                            <span>First Name</span>
                            <input id="firstName" autocomplete="given-name" required />
                        </label>
                        <label class="sp-field">
                            <span>Last Name</span>
                            <input id="lastName" autocomplete="family-name" required />
                        </label>
                        <label class="sp-field">
                            <span>Email</span>
                            <input id="email" type="email" autocomplete="email" required />
                        </label>
                        <label class="sp-field">
                            <span>Phone</span>
                            <input id="phone" autocomplete="tel" required />
                        </label>
                    </div>
                </div>

                <div class="sp-checkout-section">
                    <div class="sp-checkout-section-head">
                        <h2>Shipping Address</h2>
                    </div>

                    <div class="sp-field-grid">
                        <label class="sp-field">
                            <span>Address Line 1</span>
                            <input id="addressLine1" autocomplete="address-line1" required />
                        </label>
                        <label class="sp-field">
                            <span>Address Line 2</span>
                            <input id="addressLine2" autocomplete="address-line2" />
                        </label>
                    </div>

                    <div class="sp-field-grid sp-field-grid--triple">
                        <label class="sp-field">
                            <span>City</span>
                            <input id="city" autocomplete="address-level2" required />
                        </label>
                        <label class="sp-field">
                            <span>State</span>
                            <input id="state" autocomplete="address-level1" maxlength="2" required />
                        </label>
                        <label class="sp-field">
                            <span>ZIP</span>
                            <input id="postalCode" autocomplete="postal-code" required />
                        </label>
                    </div>
                </div>

                <div class="sp-checkout-section sp-checkout-section--payment">
                    <div class="sp-checkout-section-head">
                        <h2>Payment</h2>
                    </div>

                    <div id="card-container" class="sp-card-container"></div>
                </div>

                <div class="sp-checkout-submit-row">
                    <button id="spPayButton" class="sp-button sp-button--primary" type="button">
                        Complete Purchase
                    </button>
                </div>

                <div id="spCheckoutError" class="sp-checkout-error"></div>
            </section>

            <aside class="sp-surface sp-checkout-card sp-order-review">
                <div class="sp-summary-head">
                    <h2>Order Review</h2>
                    <a class="sp-inline-link" href="/store/cart">Edit Cart</a>
                </div>

                <div class="sp-discount-panel">
                    <label class="sp-field">
                        <span>Promo Code</span>
                        <div class="sp-discount-entry">
                            <input id="spCheckoutDiscountCode" autocomplete="off" placeholder="Enter code" />
                            <button type="button" class="sp-button sp-button--secondary" id="spCheckoutApplyDiscount">Apply</button>
                            <button type="button" class="sp-button sp-button--ghost" id="spCheckoutClearDiscount">Clear</button>
                        </div>
                    </label>
                </div>

                <div id="spCheckoutSummary"></div>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <script src="@squareScript"></script>
    <script>
        (() => {
            const store = window.ParfaitStorefront;
            const appId = @Html.Raw(appIdJson);
            const locationId = @Html.Raw(locationIdJson);
            const payButton = document.getElementById("spPayButton");
            const errorHost = document.getElementById("spCheckoutError");
            const summaryHost = document.getElementById("spCheckoutSummary");
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            const discountInput = document.getElementById("spCheckoutDiscountCode");
            const applyDiscountButton = document.getElementById("spCheckoutApplyDiscount");
            const clearDiscountButton = document.getElementById("spCheckoutClearDiscount");

            if (!store || !payButton || !errorHost || !summaryHost || !discountInput) {
                return;
            }

            let latestQuote = null;
            let card = null;
            let syncMessage = "";

            const fields = {
                firstName: document.getElementById("firstName"),
                lastName: document.getElementById("lastName"),
                email: document.getElementById("email"),
                phone: document.getElementById("phone"),
                addressLine1: document.getElementById("addressLine1"),
                addressLine2: document.getElementById("addressLine2"),
                city: document.getElementById("city"),
                state: document.getElementById("state"),
                postalCode: document.getElementById("postalCode")
            };

            const requiredFields = [
                "firstName", "lastName", "email", "phone",
                "addressLine1", "city", "state", "postalCode"
            ];

            const quoteItems = cart => cart.map(item => ({
                id: item.id,
                size: item.size,
                quantity: item.quantity
            }));

            const syncCartWithQuote = quote => {
                const current = store.readCart();
                const next = [];
                let changed = false;

                current.forEach(entry => {
                    const quoted = quote.items.find(item => item.key === entry.key);
                    if (!quoted || Number(quoted.quantity || 0) <= 0) {
                        changed = true;
                        return;
                    }

                    const nextQuantity = Number(quoted.quantity || 0);
                    if (Number(entry.quantity || 0) !== nextQuantity) {
                        changed = true;
                    }

                    next.push({
                        ...entry,
                        quantity: nextQuantity,
                        priceCents: Number(quoted.unitPriceCents || entry.priceCents || 0),
                        compareAtPriceCents: Number(quoted.compareAtPriceCents || entry.compareAtPriceCents || 0),
                        imageUrl: quoted.imageUrl || entry.imageUrl,
                        name: quoted.name || entry.name,
                        slug: quoted.slug || entry.slug,
                        badge: quoted.badge || entry.badge,
                        size: quoted.size || entry.size
                    });
                });

                if (changed) {
                    store.writeCart(next);
                }

                return changed;
            };

            const renderSummary = quote => {
                latestQuote = quote;
                discountInput.value = store.readDiscountCode();

                if (!quote?.items?.length || !quote.items.some(item => Number(item.quantity || 0) > 0)) {
                    summaryHost.innerHTML = `
                        <div class="sp-cart-empty">
                            <h2>Your cart is empty</h2>
                            <div class="sp-checkout-review-actions">
                                <a class="sp-button sp-button--primary" href="/store">Back to Shop</a>
                            </div>
                        </div>
                    `;
                    payButton.disabled = true;
                    payButton.classList.add("is-disabled");
                    return;
                }

                const itemsHtml = quote.items
                    .filter(item => Number(item.quantity || 0) > 0)
                    .map(item => `
                        <div class="sp-review-item">
                            <img src="${item.imageUrl || "/images/favicon/parfait-logo.png"}" alt="${item.name || "Product"}" />
                            <div class="sp-review-item-body">
                                <div class="sp-review-item-top">
                                    <div>
                                        <h3>${item.name || "Product"}</h3>
                                        <p>Size ${item.size || "N/A"} · Qty ${item.quantity || 1}</p>
                                    </div>
                                    <strong class="sp-review-item-total">${store.money(Number(item.lineTotalCents) || 0)}</strong>
                                </div>
                                <div class="sp-cart-item-flags">
                                    <span class="sp-stock-pill is-${item.availabilityTone || "success"}">${item.availabilityLabel || "Available"}</span>
                                    ${item.compareAtPriceCents > item.unitPriceCents ? `<span class="sp-cart-compare-price">${store.money(Number(item.compareAtPriceCents) || 0)}</span>` : ""}
                                </div>
                                ${item.issue ? `<p class="sp-cart-issue">${item.issue}</p>` : ""}
                            </div>
                        </div>
                    `).join("");

                summaryHost.innerHTML = `
                    <div class="sp-review-items">${itemsHtml}</div>
                    <div class="sp-review-totals">
                    <div class="sp-review-line sp-review-line--subtotal"><span>Subtotal</span><strong>${store.money(quote.subtotalCents || 0)}</strong></div>
                    ${(quote.discountCents || 0) > 0
                        ? `<div class="sp-review-line sp-review-line--discount"><span>${quote.discountCode && quote.discountLabel ? `${quote.discountCode} · ${quote.discountLabel}` : (quote.discountLabel || quote.discountCode || "Discount")}</span><strong>-${store.money(quote.discountCents || 0)}</strong></div>`
                        : ""}
                    <div class="sp-review-line sp-review-line--shipping"><span>Shipping</span><strong>${store.money(quote.shippingCents || 0)}</strong></div>
                    <div class="sp-review-line sp-review-line--tax"><span>Tax</span><strong>${store.money(quote.taxCents || 0)}</strong></div>
                    <div class="sp-review-line sp-review-line--total sp-review-total"><span>Total</span><strong>${store.money(quote.totalCents || 0)}</strong></div>
                    </div>
                `;

                if (quote.isValid) {
                    payButton.disabled = false;
                    payButton.classList.remove("is-disabled");
                } else {
                    payButton.disabled = true;
                    payButton.classList.add("is-disabled");
                }
            };

            const getCustomer = () => ({
                firstName: fields.firstName.value.trim(),
                lastName: fields.lastName.value.trim(),
                email: fields.email.value.trim(),
                phone: fields.phone.value.trim(),
                addressLine1: fields.addressLine1.value.trim(),
                addressLine2: fields.addressLine2.value.trim(),
                city: fields.city.value.trim(),
                state: fields.state.value.trim(),
                postalCode: fields.postalCode.value.trim()
            });

            const validateCustomer = () => {
                for (const key of requiredFields) {
                    if (!fields[key] || !fields[key].value.trim()) {
                        fields[key]?.focus();
                        const label = fields[key]?.closest("label")?.querySelector("span")?.textContent?.trim() || "Field";
                        return `${label} is required.`;
                    }
                }

                const emailValue = fields.email.value;
                if (emailValue.indexOf(String.fromCharCode(64)) < 0 || emailValue.indexOf(".") < 0) {
                    fields.email.focus();
                    return "Enter a valid email address.";
                }

                return "";
            };

            const requestQuote = async () => {
                const cart = store.readCart();
                if (!cart.length) {
                    renderSummary({ items: [], isValid: false, subtotalCents: 0, totalCents: 0, discountCents: 0 });
                    errorHost.textContent = "";
                    return null;
                }

                const response = await fetch("/store/checkout/quote", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": tokenInput?.value || ""
                    },
                    body: JSON.stringify({
                        discountCode: store.readDiscountCode(),
                        items: quoteItems(cart)
                    })
                });

                const text = await response.text();
                const quote = text ? JSON.parse(text) : {};
                const changed = quote?.items ? syncCartWithQuote(quote) : false;

                if (changed) {
                    syncMessage = "Checkout updated to current stock.";
                    return null;
                }

                renderSummary(quote);
                errorHost.textContent = syncMessage || quote.error || quote.messages?.[0] || "";
                syncMessage = "";
                return quote;
            };

            async function startSquare() {
                const firstQuote = await requestQuote();

                if (!window.Square) throw new Error("Square.js failed to load.");
                if (!appId || !locationId) throw new Error("Square Application ID or Location ID is missing.");

                const payments = window.Square.payments(appId, locationId);
                card = await payments.card();
                await card.attach("#card-container");

                payButton.addEventListener("click", async () => {
                    payButton.disabled = true;
                    payButton.classList.add("is-disabled");
                    errorHost.textContent = "";

                    try {
                        const customerError = validateCustomer();
                        if (customerError) throw new Error(customerError);

                        const quote = await requestQuote();
                        if (!quote || !quote.isValid) {
                            throw new Error("Checkout totals changed. Review the updated cart before paying.");
                        }

                        const result = await card.tokenize();
                        if (result.status !== "OK") throw new Error("Unable to tokenize payment card.");

                        const payload = {
                            sourceId: result.token,
                            discountCode: store.readDiscountCode(),
                            customer: getCustomer(),
                            items: quote.items
                                .filter(item => Number(item.quantity || 0) > 0)
                                .map(item => ({
                                    id: item.id,
                                    size: item.size,
                                    quantity: item.quantity
                                }))
                        };

                        const response = await fetch("/store/checkout/pay", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                                "RequestVerificationToken": tokenInput?.value || ""
                            },
                            body: JSON.stringify(payload)
                        });

                        const text = await response.text();
                        const data = text ? JSON.parse(text) : {};

                        if (!response.ok || !data.success) {
                            throw new Error(data.error || "Payment failed.");
                        }

                        store.clearCart();
                        store.clearDiscountCode();
                        window.location.href = data.redirectUrl || "/store/success";
                    } catch (error) {
                        errorHost.textContent = error.message || "Payment failed.";
                        if (latestQuote?.isValid) {
                            payButton.disabled = false;
                            payButton.classList.remove("is-disabled");
                        }
                    }
                });

                if (!firstQuote?.isValid) {
                    payButton.disabled = true;
                    payButton.classList.add("is-disabled");
                }
            }

            applyDiscountButton?.addEventListener("click", () => {
                store.writeDiscountCode(discountInput.value);
            });

            clearDiscountButton?.addEventListener("click", () => {
                discountInput.value = "";
                store.clearDiscountCode();
            });

            discountInput.addEventListener("keydown", event => {
                if (event.key === "Enter") {
                    event.preventDefault();
                    store.writeDiscountCode(discountInput.value);
                }
            });

            window.addEventListener("parfait-cart-updated", () => {
                requestQuote().catch(error => {
                    errorHost.textContent = error.message || "Checkout could not refresh.";
                });
            });

            startSquare().catch(error => {
                errorHost.textContent = error.message || "Square checkout failed to initialize.";
                payButton.disabled = true;
                payButton.classList.add("is-disabled");
            });
        })();
    </script>
}
