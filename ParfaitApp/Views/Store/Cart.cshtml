@{
    ViewData["Title"] = "Cart";
    ViewData["BodyClass"] = "sp-body";
    ViewData["ContentContainerClass"] = "container-fluid";
    ViewData["LayoutContentClass"] = "sp-layout-content";
}

@section Styles {
    <link rel="stylesheet" href="~/css/storefront.css" asp-append-version="true" />
}

<section class="sp-store-page">
    <div class="sp-shell">
        <header class="sp-store-hero sp-store-hero--compact">
            <h1>Your Cart</h1>
        </header>

        @Html.AntiForgeryToken()

        <div class="sp-cart-layout">
            <section class="sp-surface sp-cart-panel">
                <div class="sp-panel-heading sp-panel-heading--stacked">
                    <span>Items In Cart</span>
                    <strong id="spCartItemCount">0</strong>
                </div>

                <div class="sp-discount-panel">
                    <label class="sp-field">
                        <span>Discount Code</span>
                        <div class="sp-discount-entry">
                            <input id="spDiscountCode" autocomplete="off" placeholder="Enter code" />
                            <button type="button" class="sp-button sp-button--secondary" id="spApplyDiscount">Apply</button>
                            <button type="button" class="sp-button sp-button--ghost" id="spClearDiscount">Clear</button>
                        </div>
                    </label>
                </div>

                <div id="spCartStatus" class="sp-cart-status" hidden></div>
                <div id="spCartItems" class="sp-cart-items"></div>
            </section>

            <aside class="sp-surface sp-cart-summary-panel">
                <div class="sp-panel-heading">
                    <span>Order Summary</span>
                </div>

                <div class="sp-summary-stack">
                    <div class="sp-summary-line">
                        <span>Subtotal</span>
                        <strong id="spCartSubtotal">$0.00</strong>
                    </div>

                    <div class="sp-summary-line" id="spCartDiscountRow" hidden>
                        <span id="spCartDiscountLabel">Discount</span>
                        <strong id="spCartDiscountValue">$0.00</strong>
                    </div>

                    <div class="sp-summary-line">
                        <span>Shipping</span>
                        <strong id="spCartShipping">$0.00</strong>
                    </div>

                    <div class="sp-summary-line">
                        <span>Tax</span>
                        <strong id="spCartTax">$0.00</strong>
                    </div>

                    <div class="sp-summary-total">
                        <span>Total</span>
                        <strong id="spCartTotal">$0.00</strong>
                    </div>
                </div>

                <div class="sp-cart-summary-actions">
                    <a class="sp-button sp-button--primary" id="spCheckoutLink" href="/store/checkout">Secure Checkout</a>
                    <a class="sp-button sp-button--ghost" href="/store">Back To Shop</a>
                </div>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const store = window.ParfaitStorefront;
            const itemsHost = document.getElementById("spCartItems");
            const subtotalHost = document.getElementById("spCartSubtotal");
            const totalHost = document.getElementById("spCartTotal");
            const countHost = document.getElementById("spCartItemCount");
            const checkoutLink = document.getElementById("spCheckoutLink");
            const statusHost = document.getElementById("spCartStatus");
            const discountInput = document.getElementById("spDiscountCode");
            const applyDiscountButton = document.getElementById("spApplyDiscount");
            const clearDiscountButton = document.getElementById("spClearDiscount");
            const shippingHost = document.getElementById("spCartShipping");
            const taxHost = document.getElementById("spCartTax");
            const discountRow = document.getElementById("spCartDiscountRow");
            const discountLabel = document.getElementById("spCartDiscountLabel");
            const discountValue = document.getElementById("spCartDiscountValue");
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');

            if (!store || !itemsHost || !subtotalHost || !totalHost || !countHost || !checkoutLink || !statusHost || !discountInput || !shippingHost || !taxHost) {
                return;
            }

            let statusMessage = "";

            const productUrl = item => item.slug ? `/store/product/${item.slug}` : "/store";
            const quoteItems = cart => cart.map(item => ({
                id: item.id,
                size: item.size,
                quantity: item.quantity
            }));

            const setStatus = (message, tone = "warning") => {
                if (!message) {
                    statusHost.hidden = true;
                    statusHost.textContent = "";
                    statusHost.className = "sp-cart-status";
                    return;
                }

                statusHost.hidden = false;
                statusHost.textContent = message;
                statusHost.className = `sp-cart-status is-${tone}`;
            };

            const syncCartWithQuote = quote => {
                const current = store.readCart();
                const next = [];
                let changed = false;

                current.forEach(entry => {
                    const quoted = quote.items.find(item => item.key === entry.key);
                    if (!quoted || Number(quoted.quantity || 0) <= 0) {
                        changed = true;
                        return;
                    }

                    const nextQuantity = Number(quoted.quantity || 0);
                    if (Number(entry.quantity || 0) !== nextQuantity) {
                        changed = true;
                    }

                    next.push({
                        ...entry,
                        quantity: nextQuantity,
                        priceCents: Number(quoted.unitPriceCents || entry.priceCents || 0),
                        compareAtPriceCents: Number(quoted.compareAtPriceCents || entry.compareAtPriceCents || 0),
                        imageUrl: quoted.imageUrl || entry.imageUrl,
                        name: quoted.name || entry.name,
                        slug: quoted.slug || entry.slug,
                        badge: quoted.badge || entry.badge,
                        size: quoted.size || entry.size
                    });
                });

                if (changed) {
                    store.writeCart(next);
                }

                return changed;
            };

            const renderQuote = quote => {
                const visibleItems = (quote.items || []).filter(item => Number(item.quantity || 0) > 0);

                countHost.textContent = String(quote.itemCount || 0);
                subtotalHost.textContent = store.money(quote.subtotalCents || 0);
                shippingHost.textContent = store.money(quote.shippingCents || 0);
                taxHost.textContent = store.money(quote.taxCents || 0);
                totalHost.textContent = store.money(quote.totalCents || 0);

                if ((quote.discountCents || 0) > 0 && discountRow && discountLabel && discountValue) {
                    discountRow.hidden = false;
                    discountLabel.textContent = quote.discountCode && quote.discountLabel
                        ? `${quote.discountCode} · ${quote.discountLabel}`
                        : (quote.discountLabel || quote.discountCode || "Discount");
                    discountValue.textContent = `-${store.money(quote.discountCents || 0)}`;
                } else if (discountRow) {
                    discountRow.hidden = true;
                }

                discountInput.value = store.readDiscountCode();

                if (!visibleItems.length) {
                    checkoutLink.classList.add("is-disabled");
                    checkoutLink.setAttribute("aria-disabled", "true");
                    itemsHost.innerHTML = `
                        <div class="sp-cart-empty">
                            <h2>Your cart is empty</h2>
                            <div class="sp-empty-actions">
                                <a class="sp-button sp-button--primary" href="/store">Back To Shop</a>
                            </div>
                        </div>
                    `;
                    return;
                }

                if (quote.isValid) {
                    checkoutLink.classList.remove("is-disabled");
                    checkoutLink.removeAttribute("aria-disabled");
                } else {
                    checkoutLink.classList.add("is-disabled");
                    checkoutLink.setAttribute("aria-disabled", "true");
                }

                itemsHost.innerHTML = visibleItems.map(item => `
                    <article class="sp-cart-item">
                        <a class="sp-cart-media" href="${productUrl(item)}" aria-label="View ${item.name || "product"}">
                            <img src="${item.imageUrl || "/images/favicon/parfait-logo.png"}" alt="${item.name || "Product"}" />
                        </a>
                        <div class="sp-cart-body">
                            <div class="sp-cart-top">
                                <div>
                                    <a class="sp-cart-title" href="${productUrl(item)}">${item.name || "Product"}</a>
                                    <p class="sp-cart-meta">Size ${item.size || "N/A"} · ${store.money(Number(item.unitPriceCents) || 0)} each</p>
                                    <div class="sp-cart-item-flags">
                                        <span class="sp-stock-pill is-${item.availabilityTone || "success"}">${item.availabilityLabel || "Available"}</span>
                                        ${item.compareAtPriceCents > item.unitPriceCents ? `<span class="sp-cart-compare-price">${store.money(Number(item.compareAtPriceCents) || 0)}</span>` : ""}
                                    </div>
                                    ${item.issue ? `<p class="sp-cart-issue">${item.issue}</p>` : ""}
                                </div>
                                <div class="sp-cart-line-total">${store.money(Number(item.lineTotalCents) || 0)}</div>
                            </div>

                            <div class="sp-cart-controls">
                                <div class="sp-qty-control" aria-label="Quantity controls">
                                    <button type="button" class="sp-qty-button" data-action="decrease" data-key="${item.key}" aria-label="Decrease quantity">−</button>
                                    <span class="sp-qty-count">${Number(item.quantity) || 1}</span>
                                    <button type="button" class="sp-qty-button" data-action="increase" data-key="${item.key}" aria-label="Increase quantity">+</button>
                                </div>

                                <button type="button" class="sp-text-button" data-action="remove" data-key="${item.key}">Remove</button>
                            </div>
                        </div>
                    </article>
                `).join("");
            };

            const renderEmpty = () => {
                countHost.textContent = "0";
                subtotalHost.textContent = store.money(0);
                shippingHost.textContent = store.money(0);
                taxHost.textContent = store.money(0);
                totalHost.textContent = store.money(0);
                discountRow.hidden = true;
                checkoutLink.classList.add("is-disabled");
                checkoutLink.setAttribute("aria-disabled", "true");
                itemsHost.innerHTML = `
                    <div class="sp-cart-empty">
                        <h2>Your cart is empty</h2>
                        <div class="sp-empty-actions">
                            <a class="sp-button sp-button--primary" href="/store">Back To Shop</a>
                        </div>
                    </div>
                `;
            };

            const requestQuote = async () => {
                const cart = store.readCart();

                if (!cart.length) {
                    setStatus("");
                    renderEmpty();
                    return;
                }

                try {
                    const response = await fetch("/store/checkout/quote", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "RequestVerificationToken": tokenInput?.value || ""
                        },
                        body: JSON.stringify({
                            discountCode: store.readDiscountCode(),
                            items: quoteItems(cart)
                        })
                    });

                    const text = await response.text();
                    const quote = text ? JSON.parse(text) : {};
                    const changed = quote?.items ? syncCartWithQuote(quote) : false;

                    if (changed) {
                        statusMessage = "Cart adjusted to available stock.";
                        return;
                    }

                    renderQuote(quote);
                    setStatus(
                        statusMessage || quote.error || quote.messages?.[0] || "",
                        quote.isValid ? "success" : "warning");
                    statusMessage = "";
                } catch {
                    renderEmpty();
                    setStatus("We could not refresh the cart right now.", "danger");
                }
            };

            itemsHost.addEventListener("click", event => {
                const button = event.target.closest("[data-action]");
                if (!button) return;

                const { action, key } = button.dataset;
                const cart = store.readCart();
                const item = cart.find(entry => entry.key === key);
                if (!item) return;

                if (action === "increase") {
                    store.updateQuantity(key, Number(item.quantity || 0) + 1);
                } else if (action === "decrease") {
                    store.updateQuantity(key, Number(item.quantity || 0) - 1);
                } else if (action === "remove") {
                    store.removeItem(key);
                }
            });

            applyDiscountButton?.addEventListener("click", () => {
                store.writeDiscountCode(discountInput.value);
            });

            clearDiscountButton?.addEventListener("click", () => {
                discountInput.value = "";
                store.clearDiscountCode();
            });

            discountInput.addEventListener("keydown", event => {
                if (event.key === "Enter") {
                    event.preventDefault();
                    store.writeDiscountCode(discountInput.value);
                }
            });

            window.addEventListener("parfait-cart-updated", requestQuote);
            requestQuote();
        })();
    </script>
}
