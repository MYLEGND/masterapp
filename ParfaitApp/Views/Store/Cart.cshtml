@{
    ViewData["Title"] = "Cart";
    ViewData["BodyClass"] = "sp-body";
    ViewData["ContentContainerClass"] = "container-fluid";
    ViewData["LayoutContentClass"] = "sp-layout-content";
}

@section Styles {
    <link rel="stylesheet" href="~/css/storefront.css" asp-append-version="true" />
}

<section class="sp-store-page">
    <div class="sp-shell">
        <header class="sp-store-hero sp-store-hero--compact">
            <h1>Your Cart</h1>
        </header>

        <div class="sp-cart-layout">
            <section class="sp-surface sp-cart-panel">
                <div class="sp-panel-heading sp-panel-heading--stacked">
                    <span>Items In Cart</span>
                    <strong id="spCartItemCount">0</strong>
                </div>

                <div id="spCartItems" class="sp-cart-items"></div>
            </section>

            <aside class="sp-surface sp-cart-summary-panel">
                <div class="sp-panel-heading">
                    <span>Order Summary</span>
                </div>

                <div class="sp-summary-stack">
                    <div class="sp-summary-line">
                        <span>Subtotal</span>
                        <strong id="spCartSubtotal">$0.00</strong>
                    </div>

                    <div class="sp-summary-line">
                        <span>Shipping</span>
                        <strong>Calculated later</strong>
                    </div>

                    <div class="sp-summary-line">
                        <span>Tax</span>
                        <strong>Calculated later</strong>
                    </div>

                    <div class="sp-summary-total">
                        <span>Total</span>
                        <strong id="spCartTotal">$0.00</strong>
                    </div>
                </div>

                <div class="sp-cart-summary-actions">
                    <a class="sp-button sp-button--primary" id="spCheckoutLink" href="/store/checkout">Secure Checkout</a>
                    <a class="sp-button sp-button--ghost" href="/store">Back To Shop</a>
                </div>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const store = window.ParfaitStorefront;
            const itemsHost = document.getElementById("spCartItems");
            const subtotalHost = document.getElementById("spCartSubtotal");
            const totalHost = document.getElementById("spCartTotal");
            const countHost = document.getElementById("spCartItemCount");
            const checkoutLink = document.getElementById("spCheckoutLink");

            if (!store || !itemsHost || !subtotalHost || !totalHost || !countHost || !checkoutLink) {
                return;
            }

            const productUrl = item => item.slug ? `/store/product/${item.slug}` : "/store";

            const render = () => {
                const cart = store.readCart();
                const itemCount = store.itemCount(cart);
                const subtotal = store.subtotal(cart);

                countHost.textContent = itemCount.toString();
                subtotalHost.textContent = store.money(subtotal);
                totalHost.textContent = store.money(subtotal);

                if (!cart.length) {
                    checkoutLink.classList.add("is-disabled");
                    checkoutLink.setAttribute("aria-disabled", "true");
                    itemsHost.innerHTML = `
                        <div class="sp-cart-empty">
                            <h2>Your cart is empty</h2>
                            <div class="sp-empty-actions">
                                <a class="sp-button sp-button--primary" href="/store">Back To Shop</a>
                            </div>
                        </div>
                    `;
                    return;
                }

                checkoutLink.classList.remove("is-disabled");
                checkoutLink.removeAttribute("aria-disabled");

                itemsHost.innerHTML = cart.map(item => `
                    <article class="sp-cart-item">
                        <a class="sp-cart-media" href="${productUrl(item)}" aria-label="View ${item.name || "product"}">
                            <img src="${item.imageUrl || "/images/favicon/parfait-logo.png"}" alt="${item.name || "Product"}" />
                        </a>
                        <div class="sp-cart-body">
                            <div class="sp-cart-top">
                                <div>
                                    <a class="sp-cart-title" href="${productUrl(item)}">${item.name || "Product"}</a>
                                    <p class="sp-cart-meta">Size ${item.size || "N/A"} · ${store.money(Number(item.priceCents) || 0)} each</p>
                                </div>
                                <div class="sp-cart-line-total">${store.money((Number(item.priceCents) || 0) * (Number(item.quantity) || 0))}</div>
                            </div>

                            <div class="sp-cart-controls">
                                <div class="sp-qty-control" aria-label="Quantity controls">
                                    <button type="button" class="sp-qty-button" data-action="decrease" data-key="${item.key}" aria-label="Decrease quantity">−</button>
                                    <span class="sp-qty-count">${Number(item.quantity) || 1}</span>
                                    <button type="button" class="sp-qty-button" data-action="increase" data-key="${item.key}" aria-label="Increase quantity">+</button>
                                </div>

                                <button type="button" class="sp-text-button" data-action="remove" data-key="${item.key}">Remove</button>
                            </div>
                        </div>
                    </article>
                `).join("");
            };

            itemsHost.addEventListener("click", event => {
                const button = event.target.closest("[data-action]");
                if (!button) return;

                const { action, key } = button.dataset;
                const cart = store.readCart();
                const item = cart.find(entry => entry.key === key);
                if (!item) return;

                if (action === "increase") {
                    store.updateQuantity(key, Number(item.quantity || 0) + 1);
                } else if (action === "decrease") {
                    store.updateQuantity(key, Number(item.quantity || 0) - 1);
                } else if (action === "remove") {
                    store.removeItem(key);
                }

                render();
            });

            window.addEventListener("parfait-cart-updated", render);
            render();
        })();
    </script>
}
