@{
    ViewData["Title"] = "Order Confirmed";
}

<section style="min-height:65vh;padding:5rem 1.5rem;text-align:center;background:linear-gradient(180deg,#fff,#fbf8f5);">
    <div style="max-width:760px;margin:0 auto;background:#fff;border:1.5px solid rgba(146,105,80,.25);border-radius:32px;padding:3rem;box-shadow:0 24px 70px rgba(53,37,28,.12);">
        <p style="color:#926950;font-weight:900;letter-spacing:.22em;text-transform:uppercase;">Parfait Order</p>
        <h1 style="font-size:clamp(2.5rem,6vw,5rem);font-weight:800;font-style:italic;letter-spacing:-.06em;">Order Confirmed</h1>
        <p>Your payment was processed securely through Square.</p>
        <a href="/store" style="display:inline-flex;margin-top:1rem;padding:.9rem 1.4rem;border-radius:999px;background:#bd8200;color:#fff;text-decoration:none;font-weight:900;">Back to Shop</a>
    </div>
</section>
