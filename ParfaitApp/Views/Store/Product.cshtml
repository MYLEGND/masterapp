@model ParfaitApp.Models.ParfaitStoreProductViewModel
@{
    ViewData["Title"] = Model.Name;
    ViewData["BodyClass"] = "sp-body";
    ViewData["ContentContainerClass"] = "container-fluid";
    ViewData["LayoutContentClass"] = "sp-layout-content";

    static string ImageDisplayStyle(string? fit, int positionX, int positionY, decimal zoom)
    {
        var safeFit = string.Equals(fit, "contain", StringComparison.OrdinalIgnoreCase) ? "contain" : "cover";
        var safeZoom = zoom <= 0 ? 1.0m : zoom;
        return $"object-fit:{safeFit}; object-position:{positionX}% {positionY}%; transform-origin:{positionX}% {positionY}%; transform:scale({safeZoom.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)});";
    }

    var images = Model.Images.OrderBy(image => image.DisplayOrder).ToList();
    var selectedImage = Model.PrimaryImage ?? images.FirstOrDefault();
    var galleryCount = Math.Max(images.Count, 1);
    var defaultSize = Model.DefaultSize;
    var description = Model.Description?.Trim() ?? "";
    const string featuresMarker = "Features:";
    const string careMarker = "Care Instructions:";
    var featuresIndex = description.IndexOf(featuresMarker, StringComparison.OrdinalIgnoreCase);
    var careIndex = description.IndexOf(careMarker, StringComparison.OrdinalIgnoreCase);
    var narrativeEnd = featuresIndex >= 0
        ? featuresIndex
        : careIndex >= 0
            ? careIndex
            : description.Length;
    var narrative = description[..Math.Max(narrativeEnd, 0)].Trim();
    var firstSentenceBreak = narrative.IndexOf(". ", StringComparison.Ordinal);
    var storyLead = firstSentenceBreak >= 0
        ? narrative[..(firstSentenceBreak + 1)].Trim()
        : narrative;
    var storyCopy = firstSentenceBreak >= 0 && firstSentenceBreak + 2 < narrative.Length
        ? narrative[(firstSentenceBreak + 2)..].Trim()
        : "";
    var featuresStart = featuresIndex >= 0 ? featuresIndex + featuresMarker.Length : -1;
    var featuresEnd = careIndex > featuresIndex ? careIndex : description.Length;
    var featuresBlock = featuresStart >= 0 && featuresEnd >= featuresStart
        ? description[featuresStart..featuresEnd].Trim()
        : "";
    var featureItems = (featuresBlock.Contains('•') ? featuresBlock.Split('•') : [featuresBlock])
        .Select(item => item.Trim().TrimStart('-', '*', ' '))
        .Where(item => !string.IsNullOrWhiteSpace(item))
        .ToList();
    var careStart = careIndex >= 0 ? careIndex + careMarker.Length : -1;
    var careCopy = careStart >= 0 && careStart <= description.Length
        ? description[careStart..].Trim()
        : "";
    var defaultAvailabilityLabel = defaultSize is null
        ? Model.AvailabilityLabel
        : !defaultSize.CanPurchase
            ? $"No {defaultSize.Size} In Stock"
            : defaultSize.IsLowStock
                ? $"{defaultSize.StockQuantity} {defaultSize.Size} Left"
                : $"{defaultSize.StockQuantity} {defaultSize.Size} In Stock";
    var sizePayload = Model.Sizes
        .OrderBy(size => size.DisplayOrder)
        .Select(size => new
        {
            size.Size,
            size.StockQuantity,
            size.CanPurchase,
            size.StatusTone
        })
        .ToList();
    var displayPriceCents = Model.DisplayPriceCents > 0 || Model.HasDisplaySalePrice
        ? Model.DisplayPriceCents
        : Model.PriceCents;
    var hasPrice = Model.PriceCents > 0;
    var priceMajor = Math.Abs(displayPriceCents / 100).ToString();
    var priceMinor = Math.Abs(displayPriceCents % 100).ToString("00");
}

@section Styles {
    <link rel="stylesheet" href="~/css/storefront.css" asp-append-version="true" />
}

<section class="sp-store-page">
    <div class="sp-shell sp-product-shell">
        <section class="sp-gallery-panel sp-surface" aria-label="@Model.Name product gallery">
            <div class="sp-gallery-stage">
                @if (images.Count > 1)
                {
                    <button type="button" class="sp-gallery-arrow sp-gallery-arrow--prev" id="spGalleryPrev" aria-label="Previous product image">&lt;</button>
                    <button type="button" class="sp-gallery-arrow sp-gallery-arrow--next" id="spGalleryNext" aria-label="Next product image">&gt;</button>
                }

                <div class="sp-gallery-frame">
                    <img id="spMainProductImage"
                         class="sp-gallery-main-image"
                         src="@(selectedImage?.ImageUrl ?? Model.PrimaryImageUrl)"
                         alt="@(selectedImage?.AltText ?? Model.Name)"
                         style="@ImageDisplayStyle(selectedImage?.ObjectFit ?? Model.PrimaryImageObjectFit, selectedImage?.ObjectPositionX ?? Model.PrimaryImageObjectPositionX, selectedImage?.ObjectPositionY ?? Model.PrimaryImageObjectPositionY, selectedImage?.Zoom ?? Model.PrimaryImageZoom)" />
                </div>

                @if (images.Count > 1)
                {
                    <div class="sp-gallery-toolbar">
                        <span class="sp-gallery-counter" id="spGalleryCounter">1 / @galleryCount</span>
                    </div>
                }
            </div>

            @if (images.Count > 1)
            {
                <div class="sp-product-thumbs" aria-label="Product images">
                    @for (var i = 0; i < images.Count; i++)
                    {
                        var image = images[i];
                        var isActive = image.Id == selectedImage?.Id;

                        <button type="button"
                                class="sp-product-thumb-button @(isActive ? "is-active" : "")"
                                aria-label="View image @(i + 1) for @Model.Name"
                                data-index="@i"
                                data-image-url="@image.ImageUrl"
                                data-image-alt="@(string.IsNullOrWhiteSpace(image.AltText) ? Model.Name : image.AltText)"
                                data-image-fit="@image.ObjectFit"
                                data-image-x="@image.ObjectPositionX"
                                data-image-y="@image.ObjectPositionY"
                                data-image-zoom="@image.Zoom.ToString("0.##")">
                            <img src="@image.ImageUrl"
                                 alt="@(string.IsNullOrWhiteSpace(image.AltText) ? Model.Name : image.AltText)"
                                 style="@ImageDisplayStyle(image.ObjectFit, image.ObjectPositionX, image.ObjectPositionY, image.Zoom)" />
                        </button>
                    }
                </div>
            }
        </section>

        <section class="sp-product-info-panel sp-surface">
            <a class="sp-back-link sp-product-back-link" href="/store">← Back to collection</a>
            @if (!string.IsNullOrWhiteSpace(Model.Badge))
            {
                <div class="sp-product-kicker sp-product-badge">@Model.Badge</div>
            }
            <h1 class="sp-product-title">@Model.Name</h1>

            <div class="sp-product-price-stack sp-product-price-row">
                @if (hasPrice && Model.HasDisplaySalePrice)
                {
                    <div class="sp-product-compare-price">@Model.DisplayCompareAtPriceLabel</div>
                }
                @if (hasPrice)
                {
                    <div class="sp-product-price sp-product-price-value" aria-label="@Model.DisplayPriceLabel">
                        <span class="sp-product-price-currency">$</span>
                        <span class="sp-product-price-major">@priceMajor</span>
                        <span class="sp-product-price-minor">.@priceMinor</span>
                    </div>
                }
                else
                {
                    <div class="sp-product-price-note">@Model.DisplayPriceLabel</div>
                }
                @if (hasPrice && Model.HasDisplaySalePrice)
                {
                    <div class="sp-product-savings">@Model.DisplaySavingsLabel</div>
                }
            </div>

            <div class="sp-product-stock-strip sp-product-availability-row">
                <span class="sp-stock-pill is-@Model.AvailabilityTone" id="spProductAvailability">@defaultAvailabilityLabel</span>
            </div>

            <div class="sp-product-story" aria-label="Product details">
                @if (!string.IsNullOrWhiteSpace(storyLead))
                {
                    <p class="sp-product-story-lead">@storyLead</p>
                }

                @if (!string.IsNullOrWhiteSpace(storyCopy))
                {
                    <p class="sp-product-story-copy">@storyCopy</p>
                }

                @if (featureItems.Count > 0)
                {
                    <section class="sp-product-story-section sp-product-story-section--features">
                        <div class="sp-product-story-label">Features</div>
                        <ul class="sp-product-feature-list" aria-label="Product feature highlights">
                            @foreach (var feature in featureItems)
                            {
                                <li class="sp-product-feature-item">
                                    <span class="sp-product-feature-marker" aria-hidden="true"></span>
                                    <span class="sp-product-feature-text">@feature</span>
                                </li>
                            }
                        </ul>
                    </section>
                }

                @if (!string.IsNullOrWhiteSpace(careCopy))
                {
                    <section class="sp-product-story-section sp-product-story-section--care">
                        <div class="sp-product-story-label">Care</div>
                        <p class="sp-product-care-copy">@careCopy</p>
                    </section>
                }
            </div>

            <div class="sp-product-size-row">
                <label class="sp-size-label" for="productSize">Size</label>
                <select id="productSize" class="sp-product-select">
                    @foreach (var size in Model.Sizes.OrderBy(size => size.DisplayOrder))
                    {
                        <option value="@size.Size"
                                selected="@(defaultSize?.Size == size.Size)">
                            @size.Size
                        </option>
                    }
                </select>
            </div>

            <div class="sp-product-actions">
                @if (Model.PriceCents > 0)
                {
                    <button type="button"
                            class="sp-button sp-button--primary sp-product-button"
                            id="spAddToCart"
                            data-default-label="Add to Cart"
                            data-product-id="@Model.Id"
                            data-product-name="@Model.Name"
                            data-product-slug="@Model.Slug"
                            data-product-price-cents="@Model.PriceCents"
                            data-product-compare-price-cents="@(Model.HasDisplaySalePrice ? Model.DisplayCompareAtPriceCents : 0)"
                            data-product-price-label="@Model.DisplayPriceLabel"
                            data-product-badge="@Model.Badge"
                            data-product-image="@(selectedImage?.ImageUrl ?? Model.PrimaryImageUrl)"
                            @(defaultSize?.CanPurchase == true ? null : "disabled")>
                        @(defaultSize?.CanPurchase == true ? "Add to Cart" : "Sold Out")
                    </button>
                    <a class="sp-button sp-button--ghost" href="/store/cart">View Cart</a>
                }
                else
                {
                    <button type="button" class="sp-button sp-button--ghost" disabled>Coming Soon</button>
                }
            </div>
        </section>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const store = window.ParfaitStorefront;
            const mainImage = document.getElementById("spMainProductImage");
            const buttons = [...document.querySelectorAll(".sp-product-thumb-button")];
            const prevButton = document.getElementById("spGalleryPrev");
            const nextButton = document.getElementById("spGalleryNext");
            const counter = document.getElementById("spGalleryCounter");
            const addButton = document.getElementById("spAddToCart");
            const sizeSelect = document.getElementById("productSize");
            const availability = document.getElementById("spProductAvailability");
            const sizes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                sizePayload,
                new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

            let activeIndex = Math.max(0, buttons.findIndex(button => button.classList.contains("is-active")));

            const renderImage = index => {
                if (!buttons.length || !mainImage) return;

                const safeIndex = ((index % buttons.length) + buttons.length) % buttons.length;
                const button = buttons[safeIndex];
                activeIndex = safeIndex;

                mainImage.src = button.dataset.imageUrl || "";
                mainImage.alt = button.dataset.imageAlt || "@Model.Name";
                mainImage.style.objectFit = button.dataset.imageFit || "cover";
                mainImage.style.objectPosition = `${button.dataset.imageX || "50"}% ${button.dataset.imageY || "50"}%`;
                mainImage.style.transformOrigin = `${button.dataset.imageX || "50"}% ${button.dataset.imageY || "50"}%`;
                mainImage.style.transform = `scale(${button.dataset.imageZoom || "1"})`;

                if (addButton) {
                    addButton.dataset.productImage = button.dataset.imageUrl || addButton.dataset.productImage || "";
                }

                buttons.forEach(item => item.classList.remove("is-active"));
                button.classList.add("is-active");

                if (counter) {
                    counter.textContent = `${safeIndex + 1} / ${buttons.length}`;
                }
            };

            const setAvailability = sizeValue => {
                const current = sizes.find(size => size.size === sizeValue) || sizes[0];
                if (!current || !availability || !addButton) return;

                availability.classList.remove("is-success", "is-warning", "is-danger", "is-info", "is-muted");
                availability.classList.add(`is-${current.statusTone}`);
                availability.textContent = !current.canPurchase
                    ? `No ${current.size} In Stock`
                    : current.statusTone === "warning"
                        ? `${current.stockQuantity} ${current.size} Left`
                        : `${current.stockQuantity} ${current.size} In Stock`;

                addButton.disabled = !current.canPurchase;
                addButton.textContent = current.canPurchase
                    ? addButton.dataset.defaultLabel || "Add to Cart"
                    : "Sold Out";
            };

            buttons.forEach((button, index) => {
                button.addEventListener("click", () => renderImage(Number(button.dataset.index || index)));
            });

            prevButton?.addEventListener("click", () => renderImage(activeIndex - 1));
            nextButton?.addEventListener("click", () => renderImage(activeIndex + 1));

            document.addEventListener("keydown", event => {
                if (!buttons.length) return;
                if (event.key === "ArrowLeft") {
                    renderImage(activeIndex - 1);
                } else if (event.key === "ArrowRight") {
                    renderImage(activeIndex + 1);
                }
            });

            if (buttons.length) {
                renderImage(activeIndex);
            }

            sizeSelect?.addEventListener("change", () => setAvailability(sizeSelect.value));
            if (sizeSelect) {
                setAvailability(sizeSelect.value);
            }

            addButton?.addEventListener("click", () => {
                if (!store || !sizeSelect || addButton.disabled) return;

                const size = sizeSelect.value || "@(defaultSize?.Size ?? "XS")";
                const key = `${addButton.dataset.productId}:${size}`;

                store.addItem({
                    key,
                    id: addButton.dataset.productId,
                    name: addButton.dataset.productName,
                    slug: addButton.dataset.productSlug,
                    priceCents: Number(addButton.dataset.productPriceCents || 0),
                    compareAtPriceCents: Number(addButton.dataset.productComparePriceCents || 0),
                    priceLabel: addButton.dataset.productPriceLabel,
                    imageUrl: addButton.dataset.productImage,
                    badge: addButton.dataset.productBadge,
                    size,
                    quantity: 1
                });

                addButton.textContent = "Added to Cart";
                setTimeout(() => {
                    setAvailability(sizeSelect.value);
                }, 1200);
            });
        })();
    </script>
}
