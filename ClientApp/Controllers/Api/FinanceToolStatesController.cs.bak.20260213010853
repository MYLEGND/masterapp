using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using Infrastructure.Data;
using Domain.Entities;
using System.Security.Claims;

namespace ClientApp.Controllers.Api;

[ApiController]
[Route("api/finance-tool-states")]
[Authorize]
public class FinanceToolStatesController : ControllerBase
{
    private readonly MasterAppDbContext _db;

    public FinanceToolStatesController(MasterAppDbContext db)
    {
        _db = db;
    }

    public record SaveDto(string ToolKey, string StateJson);

    private static bool IsAgent(string upn)
        => (upn ?? "").Trim().ToLowerInvariant().EndsWith("@mylegnd.com");

    private static string NormUpn(string? v)
        => (v ?? "").Trim().ToLowerInvariant();

    private static string NormKey(string? v)
        => (v ?? "").Trim().ToLowerInvariant();

    private string GetUserUpn()
    {
        return NormUpn(
            User.FindFirstValue("preferred_username")
         ?? User.FindFirstValue(ClaimTypes.Upn)
         ?? User.FindFirstValue(ClaimTypes.Email)
         ?? User.Identity?.Name
        );
    }

    private async Task<Guid?> GetEffectiveClientProfileId()
    {
        var upn = GetUserUpn();
        if (string.IsNullOrWhiteSpace(upn)) return null;

        // Agent "view as client" mode via cookie
        if (IsAgent(upn)
            && Request.Cookies.TryGetValue("impClientProfileId", out var raw)
            && Guid.TryParse(raw, out var g))
        {
            var clientUserId = await _db.ClientProfiles
                .AsNoTracking()
                .Where(p => p.Id == g)
                .Select(p => NormUpn(p.ClientUserId))
                .FirstOrDefaultAsync();

            if (string.IsNullOrWhiteSpace(clientUserId)) return null;

            var owns = await _db.AgentClients
                .AsNoTracking()
                .AnyAsync(a =>
                    NormUpn(a.AgentUpn) == upn &&
                    NormUpn(a.ClientUserId) == clientUserId);

            if (!owns) return null;

            return g;
        }

        // Normal client mode: map signed-in user to profile by Email (normalized)
        return await _db.ClientProfiles
            .AsNoTracking()
            .Where(c => NormUpn(c.Email) == upn)
            .Select(c => (Guid?)c.Id)
            .FirstOrDefaultAsync();
    }

    // GET api/finance-tool-states/{toolKey}
    [HttpGet("{toolKey}")]
    public async Task<IActionResult> Get(string toolKey)
    {
        var clientProfileId = await GetEffectiveClientProfileId();
        if (clientProfileId == null) return Forbid();

        var key = NormKey(toolKey);
        if (string.IsNullOrWhiteSpace(key)) return BadRequest("ToolKey required");

        var row = await _db.FinanceToolStates
            .AsNoTracking()
            .FirstOrDefaultAsync(x => x.ClientProfileId == clientProfileId && NormKey(x.ToolKey) == key);

        // Never "forget": if missing, return empty shell, do not delete anything
        return Ok(row ?? new FinanceToolState
        {
            ToolKey = key,
            ClientProfileId = clientProfileId,
            StateJson = "{}"
        });
    }

    // POST api/finance-tool-states
    [HttpPost]
    public async Task<IActionResult> Save([FromBody] SaveDto dto)
    {
        var clientProfileId = await GetEffectiveClientProfileId();
        if (clientProfileId == null) return Forbid();

        var key = NormKey(dto.ToolKey);
        if (string.IsNullOrWhiteSpace(key)) return BadRequest("ToolKey required");

        var row = await _db.FinanceToolStates
            .FirstOrDefaultAsync(x => x.ClientProfileId == clientProfileId && NormKey(x.ToolKey) == key);

        if (row == null)
        {
            row = new FinanceToolState
            {
                Id = Guid.NewGuid(),
                ClientProfileId = clientProfileId,
                ClientUserId = GetUserUpn(), // legacy column kept populated
                ToolKey = key
            };
            _db.FinanceToolStates.Add(row);
        }
        else
        {
            // enforce canonical tool key once a row exists
            row.ToolKey = key;
        }

        row.StateJson = dto.StateJson ?? "{}";
        row.UpdatedUtc = DateTime.UtcNow;

        await _db.SaveChangesAsync();
        return Ok();
    }
}
