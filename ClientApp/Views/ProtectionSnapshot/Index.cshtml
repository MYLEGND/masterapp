@model ClientApp.Models.ProtectionSnapshotViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Protection Snapshot";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var defaultStateJson = JsonSerializer.Serialize(Model.DefaultState);
}

@Html.AntiForgeryToken()

<style>
    /* Dark navy + gold theme, page-scoped */
    :root {
        --ps-navy: #040914;
        --ps-navy-2: #0a1323;
        --ps-ink: #0b1529;
        --ps-ink-muted: #3a4960;
        --ps-gold: #c5921f;
        --ps-gold-bright: #e4c066;
        --ps-border: #c5921f;
    }
    .snapshot-page {
        background: #ffffff !important;
        color: #0b1529 !important;
        padding: 24px 18px 32px;
        border: 2px solid var(--ps-border);
        border-radius: 18px;
        box-shadow: 0 18px 36px rgba(0,0,0,0.22);
    }
    .snapshot-page h1, .snapshot-page h2, .snapshot-page h3, .snapshot-page h4 {
        color: var(--ps-ink) !important;
    }
    .snapshot-page p, .snapshot-page small, .snapshot-page span {
        color: #fdfdfd !important;
    }
    .snapshot-card,
    .snapshot-journey-card,
    .snapshot-role-card,
    .snapshot-start-card,
    .snapshot-step {
        background: #0a1323 !important;
        color: #fdfdfd !important;
        border: 1.8px solid var(--ps-border) !important;
        box-shadow: 0 20px 50px rgba(0,0,0,0.35) !important;
    }
    .snapshot-card-head h2,
    .snapshot-card-head p { color: #e4c066 !important; }
    .snapshot-hero {
        background: radial-gradient(circle at 18% 22%, rgba(228,192,102,0.24), transparent 38%), var(--ps-navy-2) !important;
        color: #fdfdfd !important;
        border: 2px solid var(--ps-border) !important;
        box-shadow: 0 26px 70px rgba(0,0,0,0.45) !important;
    }
    .snapshot-kicker,
    .snapshot-pill,
    .snapshot-journey-btn,
    .snapshot-journey-btn-primary,
    .snapshot-mode-toggle {
        color: var(--ps-ink) !important;
        border-color: var(--ps-border) !important;
    }
    .snapshot-pill { background: rgba(197,146,31,0.22) !important; }
    .snapshot-pill.snapshot-pill-agent { background: rgba(32,181,145,0.26) !important; }
    .snapshot-journey-btn { background: transparent !important; }
    .snapshot-journey-btn-primary,
    .snapshot-mode-toggle {
        background: linear-gradient(90deg, var(--ps-gold), var(--ps-gold-bright)) !important;
        color: #070f1d !important;
        font-weight: 800 !important;
        border: 1px solid var(--ps-border) !important;
        box-shadow: 0 10px 24px rgba(0,0,0,0.35) !important;
    }
    .snapshot-card .snapshot-start-step strong,
    .snapshot-card .snapshot-library-title { color: var(--ps-ink); }
    .snapshot-card .snapshot-start-step span { color: var(--ps-ink-muted); }
    .snapshot-choice,
    .snapshot-toggle-card,
    .snapshot-chip {
        background: #070f1d !important;
        color: var(--ps-ink) !important;
        border: 1.6px solid var(--ps-border) !important;
    }
    .snapshot-choice.active,
    .snapshot-chip.active,
    .snapshot-toggle-card input:checked + span {
        background: linear-gradient(90deg, rgba(228,192,102,0.32), rgba(197,146,31,0.34)) !important;
        border-color: var(--ps-gold-bright) !important;
        color: var(--ps-ink) !important;
    }
    .snapshot-field input,
    .snapshot-field select,
    .snapshot-slider-grid input,
    .snapshot-two-col input,
    .snapshot-three-col input,
    .snapshot-three-col select {
        background: #050b16 !important;
        color: var(--ps-ink) !important;
        border: 1.6px solid var(--ps-border) !important;
        box-shadow: inset 0 1px 5px rgba(0,0,0,0.55) !important;
    }
    .snapshot-field input:focus,
    .snapshot-field select:focus,
    .snapshot-slider-grid input:focus,
    .snapshot-two-col input:focus,
    .snapshot-three-col input:focus,
    .snapshot-three-col select:focus {
        outline: 2px solid var(--ps-border) !important;
        box-shadow: 0 0 0 3px rgba(228,192,102,0.25) !important;
    }
    .snapshot-field input::placeholder { color: rgba(226,232,240,0.78) !important; }
    .snapshot-chip-label { color: var(--ps-ink) !important; }
    .snapshot-library-group { border-top: 1px solid rgba(197,146,31,0.45) !important; }
    .snapshot-score-ring { border-color: var(--ps-border) !important; }
    .snapshot-save-status { color: var(--ps-ink) !important; }
    .snapshot-journey-progress-track { background: rgba(255,255,255,0.12) !important; }
    .snapshot-journey-progress-track span { background: linear-gradient(90deg, var(--ps-gold), var(--ps-gold-bright)) !important; }
</style>
<div class="snapshot-page"
     id="protectionSnapshotPage"
     data-client-profile-id="@Model.ClientProfileId"
     data-client-user-id="@Model.ClientUserId"
    data-is-business-client="@(Model.IsBusinessClient ? "true" : "false")"
    data-is-agent-view="@(Model.IsAgentView ? "true" : "false")"
     data-default-state='@defaultStateJson'>

    <section class="snapshot-hero">
        <div class="snapshot-hero-copy">
            <div class="snapshot-kicker">Interactive Planning</div>
            <h1>Protection Snapshot</h1>
            <p>
                @if (Model.IsAgentView)
                {
                    <text>Client-owned setup. Use this snapshot in read-only review mode to identify protection gaps and servicing opportunities.</text>
                }
                else
                {
                    <text>Client setup workspace. Select what you currently have in place so your agent can review gaps and recommend next steps.</text>
                }
            </p>
            <div class="snapshot-meta-row">
                <span class="snapshot-pill">@Model.ClientDisplayName</span>
                @if (Model.Age.HasValue)
                {
                    <span class="snapshot-pill">Age @Model.Age</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.MaritalStatus))
                {
                    <span class="snapshot-pill">@Model.MaritalStatus</span>
                }
                @if (Model.IsAgentView)
                {
                    <span class="snapshot-pill snapshot-pill-agent">Agent view</span>
                }
            </div>
        </div>

        <div class="snapshot-hero-score">
            <div class="snapshot-score-ring" id="snapshotScoreRing">
                <div>
                    <span class="snapshot-score-label">Readiness</span>
                    <strong id="snapshotScoreValue">0</strong>
                    <small id="snapshotScoreTone">Loading…</small>
                </div>
            </div>
            <div class="snapshot-save-status" id="snapshotSaveStatus">Loading shared snapshot…</div>
        </div>
    </section>

    <div class="snapshot-layout">
        <section class="snapshot-main">
            <div class="snapshot-card snapshot-journey-card" id="snapshotJourneyCard">
                <div class="snapshot-journey-top">
                    <div>
                        <div class="snapshot-kicker">Guided learning journey</div>
                        <h2 id="snapshotJourneyTitle" class="mb-1">Step 1</h2>
                        <p id="snapshotJourneyLesson" class="mb-0">We will walk this one section at a time in plain language.</p>
                    </div>
                    <button type="button" class="snapshot-mode-toggle" id="snapshotModeToggle" aria-pressed="true">Guided mode: ON</button>
                </div>

                <div class="snapshot-journey-progress-track" aria-hidden="true">
                    <span id="snapshotJourneyProgress"></span>
                </div>

                <div class="snapshot-journey-meta">
                    <span class="snapshot-pill" id="snapshotJourneyStepPill">Step 1 of 1</span>
                    <span class="snapshot-pill" id="snapshotJourneyTipPill">@(Model.IsAgentView ? "Agent review mode: client inputs are read-only." : "Tip: complete each step before moving on.")</span>
                </div>

                <div class="snapshot-journey-actions">
                    <button type="button" class="snapshot-journey-btn" id="snapshotJourneyBack">Back</button>
                    <button type="button" class="snapshot-journey-btn snapshot-journey-btn-primary" id="snapshotJourneyNext">Next</button>
                </div>
            </div>

            <div class="snapshot-card snapshot-role-card">
                <div class="snapshot-card-head">
                    <h2>How this page is used</h2>
                    <p>Clear ownership so the process stays simple and actionable.</p>
                </div>
                <div class="snapshot-start-grid">
                    <div class="snapshot-start-step">
                        <strong>Client responsibility</strong>
                        <span>Complete selections based on what is currently in force. Keep this snapshot updated as life changes.</span>
                    </div>
                    <div class="snapshot-start-step">
                        <strong>Agent responsibility</strong>
                        <span>Review submitted inputs, find gaps/opportunities, and drive recommendations and follow-up plan.</span>
                    </div>
                </div>
            </div>

            <div class="snapshot-card snapshot-start-card snapshot-step"
                 data-step-title="Start Here"
                 data-step-lesson="Learn the 4-part order first: protect people, property, work, then legal transfer.">
                <div class="snapshot-card-head">
                    <h2>Start Here (Plain Language)</h2>
                    <p>If insurance feels confusing, use this order: your people, your home and cars, your income, and your legal plan.</p>
                </div>
                <div class="snapshot-start-grid">
                    <div class="snapshot-start-step"><strong>1) Protect people</strong><span>Life and disability coverage keep income and goals intact after unexpected events.</span></div>
                    <div class="snapshot-start-step"><strong>2) Protect property</strong><span>Home/renters and auto insurance shield daily assets from loss and liability.</span></div>
                    <div class="snapshot-start-step"><strong>3) Protect work</strong><span>Business and professional liability reduce exposure from claims and lawsuits.</span></div>
                    <div class="snapshot-start-step"><strong>4) Protect transfer</strong><span>Beneficiaries and legal documents ensure assets pass with clarity.</span></div>
                </div>
            </div>

            <div class="snapshot-card snapshot-step"
                 data-step-title="Household Position"
                 data-step-lesson="Define your current life stage and exposure basics so recommendations fit your real situation.">
                <div class="snapshot-card-head">
                    <h2>Household Position</h2>
                    <p>Set the current stage so recommendations stay aligned with this season of life.</p>
                </div>

                <div class="snapshot-stage-grid" id="householdStageGroup">
                    <button type="button" class="snapshot-choice" data-field="householdStage" data-value="Foundation">Foundation</button>
                    <button type="button" class="snapshot-choice" data-field="householdStage" data-value="Growth">Growth</button>
                    <button type="button" class="snapshot-choice" data-field="householdStage" data-value="Protection Peak">Protection Peak</button>
                    <button type="button" class="snapshot-choice" data-field="householdStage" data-value="Legacy">Legacy</button>
                </div>

                <div class="snapshot-two-col">
                    <label class="snapshot-field">
                        <span>Primary goal</span>
                        <select id="primaryGoal">
                            <option value="Protect income">Protect income</option>
                            <option value="Strengthen household safety">Strengthen household safety</option>
                            <option value="Reduce risk exposure">Reduce risk exposure</option>
                            <option value="Preserve assets">Preserve assets</option>
                            <option value="Transfer legacy clearly">Transfer legacy clearly</option>
                        </select>
                    </label>

                    <label class="snapshot-field">
                        <span>Dependents supported</span>
                        <input id="dependentsCount" type="number" min="0" max="12" value="0" />
                    </label>
                </div>

                <div class="snapshot-three-col">
                    <label class="snapshot-field">
                        <span>Housing status</span>
                        <select id="housingStatus">
                            <option value="Own">Own</option>
                            <option value="Rent">Rent</option>
                            <option value="Live with family">Live with family</option>
                            <option value="Other">Other</option>
                        </select>
                    </label>

                    <label class="snapshot-field snapshot-toggle-inline">
                        <span>Own or run a business</span>
                        <input id="ownsBusiness" type="checkbox" />
                    </label>

                    <label class="snapshot-field snapshot-toggle-inline">
                        <span>Drive for business/work tasks</span>
                        <input id="drivesForWork" type="checkbox" />
                    </label>
                </div>
            </div>

            <div class="snapshot-card snapshot-step"
                 data-step-title="Protection Foundation"
                 data-step-lesson="Answer core people-protection questions first, then tune emergency and income protection levels.">
                <div class="snapshot-card-head">
                    <h2>Protection Foundation</h2>
                    <p>Track what is already in place and quickly expose the most important gaps.</p>
                </div>

                <div class="snapshot-toggle-grid">
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasLifeInsurance" /><span>Life insurance in place<small>Supports loved ones if income is lost.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasDisabilityCoverage" /><span>Disability income protection<small>Helps replace income if unable to work.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasMortgageProtection" /><span>Mortgage protection<small>Helps keep housing payments covered if income stops.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasEquityProtection" /><span>Equity protection plan<small>Protects built home/business equity from major liability events.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasLongTermCarePlan" /><span>Long-term care strategy<small>Plans for care costs later in life.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasBusinessDisabilityCoverage" /><span>Business disability coverage<small>Supports business continuity if an owner/key person is disabled.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasEstateDocuments" /><span>Estate documents prepared</span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasEmergencyContacts" /><span>Emergency contacts documented</span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasSharedDocumentVault" /><span>Shared document vault organized</span></label>
                </div>

                <div class="snapshot-slider-grid">
                    <label class="snapshot-field">
                        <span>Emergency fund months</span>
                        <input id="emergencyFundMonths" type="number" min="0" max="24" step="1" placeholder="0" />
                    </label>

                    <label class="snapshot-field">
                        <span>Income protection years</span>
                        <input id="incomeProtectionYears" type="number" min="0" max="40" step="1" placeholder="0" />
                    </label>
                </div>

                <div class="snapshot-chip-section">
                    <span class="snapshot-chip-label">Coverage library (single source of truth)</span>

                    <div class="snapshot-library-group">
                        <div class="snapshot-library-title">Personal &amp; Family Protection</div>
                        <div class="snapshot-chip-wrap snapshot-chip-wrap-wide" id="foundationProtectionLibraryPersonal">
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Life">Life</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Disability">Disability</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Long-Term Care">Long-Term Care</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Health">Health</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Critical Illness">Critical Illness</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Accident">Accident</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Dental & Vision">Dental &amp; Vision</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Travel">Travel</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Pet">Pet</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Identity Theft">Identity Theft</button>
                        </div>
                    </div>

                    <div class="snapshot-library-group">
                        <div class="snapshot-library-title">Property, Vehicle &amp; Asset Protection</div>
                        <div class="snapshot-chip-wrap snapshot-chip-wrap-wide" id="foundationProtectionLibraryProperty">
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Mortgage Protection">Mortgage Protection</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Equity Protection">Equity Protection</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Home">Home</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Condo">Condo</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Renters">Renters</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Flood">Flood</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Earthquake">Earthquake</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Auto">Auto</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Umbrella">Umbrella</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Motorcycle / RV / Boat">Motorcycle / RV / Boat</button>
                        </div>
                    </div>

                    <div class="snapshot-library-group">
                        <div class="snapshot-library-title">Business Protection (Business Clients)</div>
                        <div class="snapshot-chip-wrap snapshot-chip-wrap-wide" id="foundationProtectionLibraryBusiness">
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Business Disability">Business Disability</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="General Liability">General Liability</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Professional Liability">Professional Liability</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Business Owners Policy (BOP)">Business Owners Policy (BOP)</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Business Interruption">Business Interruption</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Commercial Property">Commercial Property</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Commercial Auto">Commercial Auto</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Workers' Comp">Workers' Comp</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Cyber">Cyber</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="EPLI">EPLI</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Directors & Officers (D&O)">Directors &amp; Officers (D&amp;O)</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Key Person">Key Person</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Buy-Sell Funding">Buy-Sell Funding</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Surety Bond">Surety Bond</button>
                        </div>
                    </div>

                    <div class="snapshot-library-group">
                        <div class="snapshot-library-title">Legal &amp; Transfer Planning</div>
                        <div class="snapshot-chip-wrap snapshot-chip-wrap-wide" id="foundationProtectionLibraryLegal">
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Will">Will</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Trust">Trust</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Power of Attorney">Power of Attorney</button>
                            <button type="button" class="snapshot-chip" data-list-field="protectionNeeds" data-value="Healthcare Directive">Healthcare Directive</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="snapshot-card snapshot-step"
                 data-step-title="Property, Auto & Liability"
                 data-step-lesson="Map day-to-day asset and lawsuit risk so home, auto, and liability coverage work together.">
                <div class="snapshot-card-head">
                    <h2>Property, Auto &amp; Liability Protection</h2>
                    <p>Map coverage around home, vehicles, and legal liability so your full risk picture is protected.</p>
                </div>

                <div class="snapshot-toggle-grid snapshot-toggle-grid-3">
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasHomeInsurance" /><span>Home insurance<small>Protects dwelling and liability as a homeowner.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasRentersInsurance" /><span>Renters insurance<small>Protects belongings and personal liability for renters.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasAutoInsurance" /><span>Auto insurance<small>Protects vehicles and auto-related liability.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasUmbrellaCoverage" /><span>Umbrella liability<small>Adds extra liability limits above base policies.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasGeneralLiability" /><span>General liability<small>Core business liability protection for claims.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasProfessionalLiability" /><span>Professional liability<small>Protects advice/service-based risk.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasCyberCoverage" /><span>Cyber liability<small>Supports breach, ransomware, and data incidents.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasWorkersComp" /><span>Workers' comp<small>Helps with employee injury/illness claims.</small></span></label>
                    <label class="snapshot-toggle-card"><input type="checkbox" id="hasCommercialAuto" /><span>Commercial auto<small>For vehicles used in business operations.</small></span></label>
                </div>

                <div class="snapshot-three-col">
                    <label class="snapshot-field snapshot-toggle-inline">
                        <span>Have employees</span>
                        <input id="hasEmployees" type="checkbox" />
                    </label>

                    <label class="snapshot-field snapshot-toggle-inline">
                        <span>Give professional advice/services</span>
                        <input id="givesProfessionalAdvice" type="checkbox" />
                    </label>

                    <label class="snapshot-field snapshot-toggle-inline">
                        <span>Store customer/client data</span>
                        <input id="handlesCustomerData" type="checkbox" />
                    </label>
                </div>
            </div>

            <div class="snapshot-card snapshot-step"
                 data-step-title="Legal & Legacy"
                 data-step-lesson="Confirm legal docs and beneficiaries so decisions and transfers happen the way you intend.">
                <div class="snapshot-card-head">
                    <h2>Legal, Beneficiaries &amp; Legacy</h2>
                    <p>Keep estate and transfer readiness visible so nothing mission-critical gets missed.</p>
                </div>

                <div class="snapshot-three-col">
                    <label class="snapshot-field snapshot-toggle-inline">
                        <span>Will in place</span>
                        <input id="hasWillInPlace" type="checkbox" />
                    </label>

                    <label class="snapshot-field snapshot-toggle-inline">
                        <span>Trust in place</span>
                        <input id="hasTrustInPlace" type="checkbox" />
                    </label>

                    <label class="snapshot-field">
                        <span>Legal documents</span>
                        <select id="legalDocsStatus">
                            <option value="Not started">Not started</option>
                            <option value="In progress">In progress</option>
                            <option value="Complete">Complete</option>
                        </select>
                    </label>

                    <label class="snapshot-field">
                        <span>Beneficiaries</span>
                        <select id="beneficiariesStatus">
                            <option value="Needs review">Needs review</option>
                            <option value="Partially updated">Partially updated</option>
                            <option value="Current">Current</option>
                        </select>
                    </label>

                    <label class="snapshot-field">
                        <span>Legacy plan</span>
                        <select id="legacyPlanStatus">
                            <option value="Needs review">Needs review</option>
                            <option value="In progress">In progress</option>
                            <option value="Clear and documented">Clear and documented</option>
                        </select>
                    </label>
                </div>
            </div>

            <div class="snapshot-card snapshot-step"
                 data-step-title="Priority Focus & Events"
                 data-step-lesson="Select current priorities and life changes so planning stays relevant and not generic.">
                <div class="snapshot-card-head">
