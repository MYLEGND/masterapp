    .snapshot-mode-toggle,
    .snapshot-journey-btn-primary {
        background: linear-gradient(180deg,#f8e2a8,#c89a35) !important;
        color: #1e1305 !important;
        border: 1px solid rgba(201,155,54,.62) !important;
    }

    .snapshot-journey-btn {
        background: #102544 !important;
        color: #e9f0ff !important;
        border: 1px solid rgba(201,155,54,.44) !important;
    }

    /* Requested gold text tone update */
    .snapshot-page .snapshot-kicker,
    .snapshot-page h1,
    .snapshot-page h2,
    .snapshot-page h3,
    .snapshot-page h4,
    .snapshot-page .snapshot-library-title,
    .snapshot-page .snapshot-score-label,
    .snapshot-page .snapshot-chip-label,
    .snapshot-page .snapshot-pill {
        color: #b4891f !important;
    }

    @@media (max-width: 1100px) {
        .snapshot-layout,
        .snapshot-hero {
            grid-template-columns: 1fr;
        }

        .snapshot-page {
            padding-left: .75rem;
            padding-right: .75rem;
        }

        .snapshot-stage-grid,
        .snapshot-chip-wrap,
        .snapshot-chip-wrap-wide,
        .snapshot-toggle-grid,
        .snapshot-toggle-grid-3 {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .snapshot-sticky {
            position: static;
        }
    }

    @@media (max-width: 760px) {
        .snapshot-two-col,
        .snapshot-three-col,
        .snapshot-slider-grid,
        .snapshot-toggle-grid,
        .snapshot-start-grid,
        .snapshot-toggle-grid-3,
        .snapshot-stage-grid,
        .snapshot-chip-wrap,
        .snapshot-chip-wrap-wide {
            grid-template-columns: 1fr;
        }

        .snapshot-card,
        .snapshot-hero {
            padding: 1rem;
        }

        .snapshot-score-ring {
            width: 150px;
            height: 150px;
        }
    }
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const root = document.getElementById("protectionSnapshotPage");
    if (!root) return;

    const toolId = "ProtectionSnapshot";
    const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value || "";
    const clientProfileId = root.dataset.clientProfileId || "";
    const clientUserId = root.dataset.clientUserId || "";
    const isBusinessClient = (root.dataset.isBusinessClient || "").toLowerCase() === "true";
    const isAgentView = (root.dataset.isAgentView || "").toLowerCase() === "true";
    const defaults = JSON.parse(root.dataset.defaultState || "{}");

    const stageButtons = Array.from(root.querySelectorAll('[data-field="householdStage"]'));
    const chipButtons = Array.from(root.querySelectorAll("[data-list-field]"));
    const scoreRing = document.getElementById("snapshotScoreRing");
    const scoreValue = document.getElementById("snapshotScoreValue");
    const scoreTone = document.getElementById("snapshotScoreTone");
    const saveStatus = document.getElementById("snapshotSaveStatus");
    const summaryList = document.getElementById("snapshotSummaryList");
    const nextSteps = document.getElementById("snapshotNextSteps");
    const journeyTitle = document.getElementById("snapshotJourneyTitle");
    const journeyLesson = document.getElementById("snapshotJourneyLesson");
    const journeyProgress = document.getElementById("snapshotJourneyProgress");
    const journeyStepPill = document.getElementById("snapshotJourneyStepPill");
    const journeyTipPill = document.getElementById("snapshotJourneyTipPill");
    const modeToggle = document.getElementById("snapshotModeToggle");
    const backStepButton = document.getElementById("snapshotJourneyBack");
    const nextStepButton = document.getElementById("snapshotJourneyNext");
    const stepCards = Array.from(root.querySelectorAll(".snapshot-step"));
    const mainColumn = root.querySelector(".snapshot-main");

    const inputs = {
        primaryGoal: document.getElementById("primaryGoal"),
        housingStatus: document.getElementById("housingStatus"),
        dependentsCount: document.getElementById("dependentsCount"),
        hasLifeInsurance: document.getElementById("hasLifeInsurance"),
        hasDisabilityCoverage: document.getElementById("hasDisabilityCoverage"),
        hasMortgageProtection: document.getElementById("hasMortgageProtection"),
        hasEquityProtection: document.getElementById("hasEquityProtection"),
        hasLongTermCarePlan: document.getElementById("hasLongTermCarePlan"),
        hasBusinessDisabilityCoverage: document.getElementById("hasBusinessDisabilityCoverage"),
        hasEstateDocuments: document.getElementById("hasEstateDocuments"),
        hasEmergencyContacts: document.getElementById("hasEmergencyContacts"),
        hasSharedDocumentVault: document.getElementById("hasSharedDocumentVault"),
        ownsBusiness: document.getElementById("ownsBusiness"),
        hasEmployees: document.getElementById("hasEmployees"),
        drivesForWork: document.getElementById("drivesForWork"),
        givesProfessionalAdvice: document.getElementById("givesProfessionalAdvice"),
        handlesCustomerData: document.getElementById("handlesCustomerData"),
        hasHomeInsurance: document.getElementById("hasHomeInsurance"),
        hasRentersInsurance: document.getElementById("hasRentersInsurance"),
        hasAutoInsurance: document.getElementById("hasAutoInsurance"),
        hasUmbrellaCoverage: document.getElementById("hasUmbrellaCoverage"),
        hasGeneralLiability: document.getElementById("hasGeneralLiability"),
        hasProfessionalLiability: document.getElementById("hasProfessionalLiability"),
        hasCyberCoverage: document.getElementById("hasCyberCoverage"),
        hasWorkersComp: document.getElementById("hasWorkersComp"),
        hasCommercialAuto: document.getElementById("hasCommercialAuto"),
        emergencyFundMonths: document.getElementById("emergencyFundMonths"),
        incomeProtectionYears: document.getElementById("incomeProtectionYears"),
        legalDocsStatus: document.getElementById("legalDocsStatus"),
        beneficiariesStatus: document.getElementById("beneficiariesStatus"),
        legacyPlanStatus: document.getElementById("legacyPlanStatus"),
        hasWillInPlace: document.getElementById("hasWillInPlace"),
        hasTrustInPlace: document.getElementById("hasTrustInPlace"),
        reviewCadence: document.getElementById("reviewCadence"),
        lastReviewUtc: document.getElementById("lastReviewUtc"),
        nextReviewUtc: document.getElementById("nextReviewUtc"),
        agentFollowUpFocus: document.getElementById("agentFollowUpFocus"),
        clientNotes: document.getElementById("clientNotes")
    };

    const businessOnlyToggleIds = [
        "ownsBusiness",
        "hasEmployees",
        "givesProfessionalAdvice",
        "handlesCustomerData",
        "hasGeneralLiability",
        "hasProfessionalLiability",
        "hasCyberCoverage",
        "hasWorkersComp",
        "hasCommercialAuto",
        "hasBusinessDisabilityCoverage"
    ];

    const businessOnlyProtectionNeeds = new Set([
        "Business Disability",
        "General Liability",
        "Professional Liability",
        "Business Owners Policy (BOP)",
        "Business Interruption",
        "Commercial Property",
        "Commercial Auto",
        "Workers' Comp",
        "Cyber",
        "EPLI",
        "Directors & Officers (D&O)",
        "Key Person",
        "Buy-Sell Funding",
        "Surety Bond"
    ]);

    let state = normalizeState(defaults);
    let saveTimer = 0;
    let hasLoadedFromServer = false;
    let guidedMode = true;
    let currentStepIndex = 0;

    function normalizeList(value) {
        return Array.isArray(value)
            ? value.filter(Boolean).map(item => String(item).trim()).filter(Boolean)
            : [];
    }

    function sanitizeForClientType(snapshot) {
        if (isBusinessClient) return snapshot;

        snapshot.ownsBusiness = false;
        snapshot.hasEmployees = false;
        snapshot.givesProfessionalAdvice = false;
        snapshot.handlesCustomerData = false;
        snapshot.hasGeneralLiability = false;
        snapshot.hasProfessionalLiability = false;
        snapshot.hasCyberCoverage = false;
        snapshot.hasWorkersComp = false;
        snapshot.hasCommercialAuto = false;
        snapshot.hasBusinessDisabilityCoverage = false;
        snapshot.protectionNeeds = (snapshot.protectionNeeds || []).filter(item => !businessOnlyProtectionNeeds.has(item));
        return snapshot;
    }

    function applyClientTypeVisibility() {
        if (isBusinessClient) return;

        businessOnlyToggleIds.forEach(id => {
            const input = document.getElementById(id);
            const card = input?.closest(".snapshot-toggle-card") || input?.closest(".snapshot-field");
            if (card) card.classList.add("snapshot-hidden-by-type");
        });

        chipButtons.forEach(button => {
            if (button.dataset.listField !== "protectionNeeds") return;
            if (businessOnlyProtectionNeeds.has(button.dataset.value || "")) {
                button.classList.add("snapshot-hidden-by-type");
            }
        });
    }

    function applyRoleMode() {
        if (!isAgentView) return;

        guidedMode = false;

        const readonlySelectors = [
            '[data-field="householdStage"]',
            '[data-list-field]',
            'input:not([type="hidden"]):not([name="__RequestVerificationToken"])',
            'select',
            'textarea'
        ];

        readonlySelectors.forEach(selector => {
            root.querySelectorAll(selector).forEach(element => {
                element.setAttribute("disabled", "disabled");
                element.setAttribute("aria-disabled", "true");
            });
        });

        [modeToggle, backStepButton, nextStepButton].forEach(button => {
            if (!button) return;
            button.setAttribute("disabled", "disabled");
            button.setAttribute("aria-disabled", "true");
        });

        saveStatus.textContent = "Agent review mode (read-only): client-owned inputs";
    }

    function normalizeState(raw) {
        const source = raw && typeof raw === "object" ? raw : {};
        return sanitizeForClientType({
            householdStage: String(source.householdStage || defaults.householdStage || "Foundation"),
            primaryGoal: String(source.primaryGoal || defaults.primaryGoal || "Protect income"),
            housingStatus: String(source.housingStatus || defaults.housingStatus || "Own"),
            dependentsCount: Number.isFinite(Number(source.dependentsCount)) ? Math.max(0, Number(source.dependentsCount)) : Number(defaults.dependentsCount || 0),
            emergencyFundMonths: Number.isFinite(Number(source.emergencyFundMonths)) ? Math.max(0, Number(source.emergencyFundMonths)) : Number(defaults.emergencyFundMonths || 0),
            incomeProtectionYears: Number.isFinite(Number(source.incomeProtectionYears)) ? Math.max(0, Number(source.incomeProtectionYears)) : Number(defaults.incomeProtectionYears || 0),
            legalDocsStatus: String(source.legalDocsStatus || defaults.legalDocsStatus || "Not started"),
            beneficiariesStatus: String(source.beneficiariesStatus || defaults.beneficiariesStatus || "Needs review"),
            legacyPlanStatus: String(source.legacyPlanStatus || defaults.legacyPlanStatus || "Needs review"),
            reviewCadence: String(source.reviewCadence || defaults.reviewCadence || "Semiannual"),
            hasLifeInsurance: !!source.hasLifeInsurance,
            hasDisabilityCoverage: !!source.hasDisabilityCoverage,
            hasMortgageProtection: !!source.hasMortgageProtection,
            hasEquityProtection: !!source.hasEquityProtection,
            hasLongTermCarePlan: !!source.hasLongTermCarePlan,
            hasBusinessDisabilityCoverage: !!source.hasBusinessDisabilityCoverage,
            hasEstateDocuments: !!source.hasEstateDocuments,
            hasEmergencyContacts: !!source.hasEmergencyContacts,
            hasSharedDocumentVault: !!source.hasSharedDocumentVault,
            ownsBusiness: !!source.ownsBusiness,
            hasEmployees: !!source.hasEmployees,
            drivesForWork: !!source.drivesForWork,
            givesProfessionalAdvice: !!source.givesProfessionalAdvice,
            handlesCustomerData: !!source.handlesCustomerData,
            hasHomeInsurance: !!source.hasHomeInsurance,
            hasRentersInsurance: !!source.hasRentersInsurance,
            hasAutoInsurance: !!source.hasAutoInsurance,
            hasUmbrellaCoverage: !!source.hasUmbrellaCoverage,
            hasGeneralLiability: !!source.hasGeneralLiability,
            hasProfessionalLiability: !!source.hasProfessionalLiability,
            hasCyberCoverage: !!source.hasCyberCoverage,
            hasWorkersComp: !!source.hasWorkersComp,
            hasCommercialAuto: !!source.hasCommercialAuto,
            hasWillInPlace: !!source.hasWillInPlace,
            hasTrustInPlace: !!source.hasTrustInPlace,
            priorityFocusAreas: normalizeList(source.priorityFocusAreas?.length ? source.priorityFocusAreas : defaults.priorityFocusAreas),
            protectionNeeds: normalizeList(source.protectionNeeds?.length ? source.protectionNeeds : defaults.protectionNeeds),
            recentLifeEvents: normalizeList(source.recentLifeEvents),
            agentFollowUpFocus: String(source.agentFollowUpFocus || ""),
            clientNotes: String(source.clientNotes || ""),
            lastReviewUtc: source.lastReviewUtc ? String(source.lastReviewUtc).slice(0, 10) : "",
            nextReviewUtc: source.nextReviewUtc ? String(source.nextReviewUtc).slice(0, 10) : ""
        });
    }

    function computeScore(snapshot) {
        let total = 0;
        total += snapshot.hasLifeInsurance ? 16 : 0;
        total += snapshot.hasDisabilityCoverage ? 14 : 0;
        total += snapshot.hasMortgageProtection ? 9 : 0;
        total += snapshot.hasEquityProtection ? 8 : 0;
        total += snapshot.hasLongTermCarePlan ? 10 : 0;
        total += snapshot.hasBusinessDisabilityCoverage ? 8 : 0;
        total += snapshot.hasEstateDocuments ? 12 : 0;
        total += snapshot.hasEmergencyContacts ? 8 : 0;
        total += snapshot.hasSharedDocumentVault ? 8 : 0;
        total += snapshot.hasHomeInsurance ? 6 : 0;
        total += snapshot.hasRentersInsurance ? 4 : 0;
        total += snapshot.hasAutoInsurance ? 6 : 0;
        total += snapshot.hasUmbrellaCoverage ? 6 : 0;
        total += snapshot.hasGeneralLiability ? 6 : 0;
        total += snapshot.hasProfessionalLiability ? 6 : 0;
        total += snapshot.hasCyberCoverage ? 5 : 0;
        total += snapshot.hasWorkersComp ? 4 : 0;
        total += snapshot.hasCommercialAuto ? 4 : 0;
        total += Math.min(snapshot.emergencyFundMonths, 6) * 3;
        total += Math.min(snapshot.incomeProtectionYears, 12) * 2;
        total += snapshot.hasWillInPlace ? 5 : 0;
        total += snapshot.hasTrustInPlace ? 5 : 0;
        total += snapshot.legalDocsStatus === "Complete" ? 8 : snapshot.legalDocsStatus === "In progress" ? 4 : 0;
        total += snapshot.beneficiariesStatus === "Current" ? 7 : snapshot.beneficiariesStatus === "Partially updated" ? 3 : 0;
        total += snapshot.legacyPlanStatus === "Clear and documented" ? 7 : snapshot.legacyPlanStatus === "In progress" ? 3 : 0;
        return Math.max(0, Math.min(100, total));
    }

    function buildNextSteps(snapshot) {
        const steps = [];
        if (!snapshot.hasLifeInsurance) steps.push("Review life insurance alignment with household obligations and income needs.");
        if (!snapshot.hasDisabilityCoverage) steps.push("Evaluate disability income protection so a work interruption does not disrupt the plan.");
        if (snapshot.housingStatus === "Own" && !snapshot.hasMortgageProtection) steps.push("Review mortgage protection options to keep housing payments covered during disruption.");
        if (snapshot.housingStatus === "Own" && !snapshot.hasEquityProtection) steps.push("Review equity protection strategy to preserve built home equity from major claims.");
        if (snapshot.housingStatus === "Own" && !snapshot.hasHomeInsurance) steps.push("Confirm homeowners coverage and liability limits for your property.");
        if (snapshot.housingStatus === "Rent" && !snapshot.hasRentersInsurance) steps.push("Add renters insurance to protect belongings and personal liability.");
        if (!snapshot.hasAutoInsurance) steps.push("Review auto policy limits and uninsured/underinsured protection.");
        if (snapshot.ownsBusiness && !snapshot.hasBusinessDisabilityCoverage) steps.push("Add business disability/overhead coverage for continuity if an owner or key person cannot work.");
        if (snapshot.ownsBusiness && !snapshot.hasGeneralLiability) steps.push("Add general liability coverage for core business claim protection.");
        if (snapshot.givesProfessionalAdvice && !snapshot.hasProfessionalLiability) steps.push("Evaluate professional liability for advice/service-related errors claims.");
        if (snapshot.handlesCustomerData && !snapshot.hasCyberCoverage) steps.push("Add cyber liability planning for breach and ransomware response costs.");
        if (snapshot.hasEmployees && !snapshot.hasWorkersComp) steps.push("Review workers' comp requirements and employee injury protection.");
        if (snapshot.drivesForWork && !snapshot.hasCommercialAuto) steps.push("Review commercial auto exposure for work-related driving.");
        if (snapshot.emergencyFundMonths < 3) steps.push("Increase liquid emergency reserves to at least a 3-month baseline.");
        if (snapshot.legalDocsStatus === "Not started") steps.push("Start core legal documents so decision authority is clear before a crisis.");
        if (!snapshot.hasWillInPlace) steps.push("Create or update a will so distributions and guardianship instructions are documented.");
        if (!snapshot.hasTrustInPlace) steps.push("Evaluate trust setup for probate efficiency and controlled distribution.");
        if (snapshot.beneficiariesStatus !== "Current") steps.push("Update beneficiaries across policies and accounts to match current intent.");
        if (!steps.length) steps.push("Keep the review cadence active and use life events to trigger mid-cycle updates.");
        return steps.slice(0, 4);
    }

    function scoreToneFor(score) {
        if (score >= 75) return "Strong position";
        if (score >= 50) return "Good progress";
        return "Needs attention";
    }

    function renderSummary(snapshot) {
        const score = computeScore(snapshot);
        const angle = Math.round((score / 100) * 360);
        scoreRing.style.background = `conic-gradient(var(--snapshot-gold-strong) ${angle}deg, rgba(139,100,22,.12) ${angle}deg)`;
        scoreValue.textContent = String(score);
        scoreTone.textContent = scoreToneFor(score);

        const focusLabel = snapshot.priorityFocusAreas.length ? snapshot.priorityFocusAreas.join(", ") : "No priority focus selected yet";
        const protectionLabel = snapshot.protectionNeeds.length ? snapshot.protectionNeeds.join(", ") : "No protection lines selected yet";
        const lifeEventsLabel = snapshot.recentLifeEvents.length ? snapshot.recentLifeEvents.join(", ") : "No life events selected";
        const reviewLabel = snapshot.nextReviewUtc ? `${snapshot.reviewCadence} • target ${snapshot.nextReviewUtc}` : snapshot.reviewCadence;

        summaryList.innerHTML = [
            { title: snapshot.householdStage, detail: `Current stage • ${snapshot.primaryGoal}` },
            { title: focusLabel, detail: "Priority focus areas" },
            { title: protectionLabel, detail: "Insurance lines currently in review" },
            { title: lifeEventsLabel, detail: "Life events influencing planning" },
            { title: reviewLabel, detail: "Review rhythm" }
        ].map(item => `
            <div class="snapshot-summary-item">
                <strong>${escapeHtml(item.title)}</strong>
                <span>${escapeHtml(item.detail)}</span>
            </div>`).join("");

        nextSteps.innerHTML = buildNextSteps(snapshot)
            .map(step => `<li>${escapeHtml(step)}</li>`)
            .join("");

        renderJourney();
    }

    function getJourneyCompletion(snapshot) {
        const sections = [
            true,
            !!snapshot.householdStage && !!snapshot.primaryGoal && !!snapshot.housingStatus,
            [
                snapshot.hasLifeInsurance,
                snapshot.hasDisabilityCoverage,
                snapshot.hasMortgageProtection,
                snapshot.hasEquityProtection,
                snapshot.hasLongTermCarePlan,
                snapshot.hasBusinessDisabilityCoverage,
                snapshot.hasEstateDocuments,
                snapshot.hasEmergencyContacts,
                snapshot.hasSharedDocumentVault,
                snapshot.emergencyFundMonths > 0,
                snapshot.incomeProtectionYears > 0
            ].filter(Boolean).length >= 3,
            [
                snapshot.hasHomeInsurance,
                snapshot.hasRentersInsurance,
                snapshot.hasAutoInsurance,
                snapshot.hasUmbrellaCoverage,
                snapshot.hasGeneralLiability,
                snapshot.hasProfessionalLiability,
                snapshot.hasCyberCoverage,
                snapshot.hasWorkersComp,
                snapshot.hasCommercialAuto
            ].some(Boolean),
            snapshot.hasWillInPlace
                || snapshot.hasTrustInPlace
                || snapshot.legalDocsStatus !== "Not started"
                || snapshot.beneficiariesStatus === "Current"
                || snapshot.legacyPlanStatus === "Clear and documented",
            snapshot.priorityFocusAreas.length > 0
                || snapshot.protectionNeeds.length > 0
                || snapshot.recentLifeEvents.length > 0,
            !!snapshot.reviewCadence
                || !!snapshot.nextReviewUtc
                || !!snapshot.agentFollowUpFocus
                || !!snapshot.clientNotes
        ];

        const total = Math.max(1, stepCards.length);
        const completed = sections.slice(0, total).filter(Boolean).length;
        const percent = Math.round((completed / total) * 100);
        return { completed, total, percent };
    }

    function renderJourney() {
        if (!stepCards.length || !mainColumn) return;

        const completion = getJourneyCompletion(state);

        if (guidedMode) {
            mainColumn.classList.add("guided-mode");
            stepCards.forEach((card, index) => {
                card.classList.toggle("is-step-active", index === currentStepIndex);
            });

            const activeCard = stepCards[currentStepIndex];
            const title = activeCard?.dataset.stepTitle || `Step ${currentStepIndex + 1}`;
            const lesson = activeCard?.dataset.stepLesson || "Complete this section to keep moving.";
            const totalSteps = stepCards.length;
            const stepPercent = Math.round(((currentStepIndex + 1) / totalSteps) * 100);
            const displayCompletionPercent = Math.max(completion.percent, stepPercent);
            const displayCompletedSteps = Math.max(completion.completed, currentStepIndex + 1);

            if (journeyTitle) journeyTitle.textContent = title;
            if (journeyLesson) journeyLesson.textContent = lesson;
            if (journeyProgress) journeyProgress.style.width = `${stepPercent}%`;
            if (journeyStepPill) journeyStepPill.textContent = `Step ${currentStepIndex + 1} of ${totalSteps} • Completed ${displayCompletedSteps}/${completion.total}`;
            if (journeyTipPill) journeyTipPill.textContent = displayCompletionPercent >= 100
                ? "Great work: journey complete. Keep it current as life changes."
                : `Progress ${stepPercent}% • completion ${displayCompletionPercent}%`;
            if (modeToggle) {
                modeToggle.textContent = "Guided mode: ON";
                modeToggle.setAttribute("aria-pressed", "true");
            }

            if (backStepButton) backStepButton.disabled = currentStepIndex === 0;
            if (nextStepButton) {
                nextStepButton.textContent = currentStepIndex >= totalSteps - 1 ? "Finish" : "Next";
            }
        } else {
            mainColumn.classList.remove("guided-mode");
            stepCards.forEach(card => card.classList.remove("is-step-active"));
            if (journeyTitle) journeyTitle.textContent = "All sections unlocked";
            if (journeyLesson) journeyLesson.textContent = "Use free browse mode to move anywhere while your updates still autosave.";
            if (journeyProgress) journeyProgress.style.width = `${completion.percent}%`;
            if (journeyStepPill) journeyStepPill.textContent = `${completion.completed}/${completion.total} sections complete`;
            if (journeyTipPill) journeyTipPill.textContent = `Completion ${completion.percent}% • free browse mode`;
            if (modeToggle) {
                modeToggle.textContent = "Guided mode: OFF";
                modeToggle.setAttribute("aria-pressed", "false");
            }
            if (backStepButton) backStepButton.disabled = true;
            if (nextStepButton) nextStepButton.textContent = "Browse";
        }
    }

    function escapeHtml(value) {
        return String(value ?? "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/\"/g, "&quot;")
            .replace(/'/g, "&#39;");
    }

    function syncInputs(snapshot) {
        stageButtons.forEach(button => button.classList.toggle("is-active", button.dataset.value === snapshot.householdStage));

        inputs.primaryGoal.value = snapshot.primaryGoal;
        inputs.housingStatus.value = snapshot.housingStatus;
        inputs.dependentsCount.value = snapshot.dependentsCount;
        inputs.hasLifeInsurance.checked = snapshot.hasLifeInsurance;
        inputs.hasDisabilityCoverage.checked = snapshot.hasDisabilityCoverage;
        inputs.hasMortgageProtection.checked = snapshot.hasMortgageProtection;
        inputs.hasEquityProtection.checked = snapshot.hasEquityProtection;
        inputs.hasLongTermCarePlan.checked = snapshot.hasLongTermCarePlan;
        inputs.hasBusinessDisabilityCoverage.checked = snapshot.hasBusinessDisabilityCoverage;
        inputs.hasEstateDocuments.checked = snapshot.hasEstateDocuments;
        inputs.hasEmergencyContacts.checked = snapshot.hasEmergencyContacts;
        inputs.hasSharedDocumentVault.checked = snapshot.hasSharedDocumentVault;
        inputs.ownsBusiness.checked = snapshot.ownsBusiness;
        inputs.hasEmployees.checked = snapshot.hasEmployees;
        inputs.drivesForWork.checked = snapshot.drivesForWork;
        inputs.givesProfessionalAdvice.checked = snapshot.givesProfessionalAdvice;
        inputs.handlesCustomerData.checked = snapshot.handlesCustomerData;
        inputs.hasHomeInsurance.checked = snapshot.hasHomeInsurance;
        inputs.hasRentersInsurance.checked = snapshot.hasRentersInsurance;
        inputs.hasAutoInsurance.checked = snapshot.hasAutoInsurance;
        inputs.hasUmbrellaCoverage.checked = snapshot.hasUmbrellaCoverage;
        inputs.hasGeneralLiability.checked = snapshot.hasGeneralLiability;
        inputs.hasProfessionalLiability.checked = snapshot.hasProfessionalLiability;
        inputs.hasCyberCoverage.checked = snapshot.hasCyberCoverage;
        inputs.hasWorkersComp.checked = snapshot.hasWorkersComp;
        inputs.hasCommercialAuto.checked = snapshot.hasCommercialAuto;
        inputs.emergencyFundMonths.value = snapshot.emergencyFundMonths;
        inputs.incomeProtectionYears.value = snapshot.incomeProtectionYears;
        inputs.legalDocsStatus.value = snapshot.legalDocsStatus;
        inputs.beneficiariesStatus.value = snapshot.beneficiariesStatus;
        inputs.legacyPlanStatus.value = snapshot.legacyPlanStatus;
        inputs.hasWillInPlace.checked = snapshot.hasWillInPlace;
        inputs.hasTrustInPlace.checked = snapshot.hasTrustInPlace;
        inputs.reviewCadence.value = snapshot.reviewCadence;
        inputs.lastReviewUtc.value = snapshot.lastReviewUtc;
        inputs.nextReviewUtc.value = snapshot.nextReviewUtc;
        inputs.agentFollowUpFocus.value = snapshot.agentFollowUpFocus;
        inputs.clientNotes.value = snapshot.clientNotes;

        chipButtons.forEach(button => {
            const field = button.dataset.listField;
            const value = button.dataset.value;
            button.classList.toggle("is-active", Array.isArray(snapshot[field]) && snapshot[field].includes(value));
        });

        renderSummary(snapshot);
    }

    function collectState() {
        return normalizeState({
            householdStage: state.householdStage,
            primaryGoal: inputs.primaryGoal.value,
            housingStatus: inputs.housingStatus.value,
            dependentsCount: Number(inputs.dependentsCount.value || 0),
            hasLifeInsurance: inputs.hasLifeInsurance.checked,
            hasDisabilityCoverage: inputs.hasDisabilityCoverage.checked,
            hasMortgageProtection: inputs.hasMortgageProtection.checked,
            hasEquityProtection: inputs.hasEquityProtection.checked,
            hasLongTermCarePlan: inputs.hasLongTermCarePlan.checked,
            hasBusinessDisabilityCoverage: inputs.hasBusinessDisabilityCoverage.checked,
            hasEstateDocuments: inputs.hasEstateDocuments.checked,
            hasEmergencyContacts: inputs.hasEmergencyContacts.checked,
            hasSharedDocumentVault: inputs.hasSharedDocumentVault.checked,
            ownsBusiness: inputs.ownsBusiness.checked,
            hasEmployees: inputs.hasEmployees.checked,
            drivesForWork: inputs.drivesForWork.checked,
            givesProfessionalAdvice: inputs.givesProfessionalAdvice.checked,
            handlesCustomerData: inputs.handlesCustomerData.checked,
            hasHomeInsurance: inputs.hasHomeInsurance.checked,
            hasRentersInsurance: inputs.hasRentersInsurance.checked,
            hasAutoInsurance: inputs.hasAutoInsurance.checked,
            hasUmbrellaCoverage: inputs.hasUmbrellaCoverage.checked,
            hasGeneralLiability: inputs.hasGeneralLiability.checked,
            hasProfessionalLiability: inputs.hasProfessionalLiability.checked,
            hasCyberCoverage: inputs.hasCyberCoverage.checked,
            hasWorkersComp: inputs.hasWorkersComp.checked,
            hasCommercialAuto: inputs.hasCommercialAuto.checked,
            emergencyFundMonths: Number(inputs.emergencyFundMonths.value || 0),
            incomeProtectionYears: Number(inputs.incomeProtectionYears.value || 0),
            legalDocsStatus: inputs.legalDocsStatus.value,
            beneficiariesStatus: inputs.beneficiariesStatus.value,
            legacyPlanStatus: inputs.legacyPlanStatus.value,
            hasWillInPlace: inputs.hasWillInPlace.checked,
            hasTrustInPlace: inputs.hasTrustInPlace.checked,
            reviewCadence: inputs.reviewCadence.value,
            priorityFocusAreas: state.priorityFocusAreas,
            protectionNeeds: state.protectionNeeds,
            recentLifeEvents: state.recentLifeEvents,
            agentFollowUpFocus: inputs.agentFollowUpFocus.value,
            clientNotes: inputs.clientNotes.value,
            lastReviewUtc: inputs.lastReviewUtc.value,
            nextReviewUtc: inputs.nextReviewUtc.value
        });
    }

    function queueSave(message) {
        if (isAgentView) {
            saveStatus.textContent = "Agent review mode (read-only): no edits are saved here.";
            return;
        }
        window.clearTimeout(saveTimer);
        saveStatus.textContent = message || "Changes pending…";
        saveTimer = window.setTimeout(saveState, 700);
    }

    async function saveState() {
        if (isAgentView) return;
        state = collectState();
        renderSummary(state);
        saveStatus.textContent = "Saving shared snapshot…";

        try {
            const response = await fetch("/api/finance-state/save", {
                method: "POST",
                credentials: "include",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": antiForgeryToken
                },
                body: JSON.stringify({
                    clientProfileId,
                    clientUserId,
                    toolId,
                    jsonState: JSON.stringify(state)
                })
            });

            if (!response.ok) {
                throw new Error(await response.text() || `Save failed (${response.status})`);
            }

            saveStatus.textContent = hasLoadedFromServer
                ? "Shared snapshot saved"
                : "Initial snapshot saved";
            hasLoadedFromServer = true;
        } catch (error) {
            console.error(error);
            saveStatus.textContent = "Save failed — please try again";
        }
    }

    async function loadState() {
        try {
            const params = new URLSearchParams({ clientProfileId, clientUserId, toolId });
            const response = await fetch(`/api/finance-state/load?${params.toString()}`, {
                credentials: "include"
            });

            if (!response.ok) {
                throw new Error(await response.text() || `Load failed (${response.status})`);
            }

            const payload = await response.json();
            const loaded = payload?.jsonState ? JSON.parse(payload.jsonState) : {};
            state = normalizeState(loaded);
            hasLoadedFromServer = !!payload?.found;
            syncInputs(state);
            if (isAgentView) {
                saveStatus.textContent = "Agent review mode (read-only): viewing client-submitted snapshot";
                return;
            }
            saveStatus.textContent = payload?.found
                ? "Shared snapshot loaded"
                : "No saved snapshot yet — your updates will save automatically";
        } catch (error) {
            console.error(error);
            state = normalizeState(defaults);
            syncInputs(state);
            if (isAgentView) {
                saveStatus.textContent = "Agent review mode (read-only): default snapshot shown";
                return;
            }
            saveStatus.textContent = "Using default snapshot — save will retry automatically";
        }
    }

    stageButtons.forEach(button => button.addEventListener("click", () => {
        state.householdStage = button.dataset.value || "Foundation";
        syncInputs(state);
        queueSave();
    }));

    chipButtons.forEach(button => button.addEventListener("click", () => {
        const field = button.dataset.listField;
        const value = button.dataset.value;
        const current = new Set(Array.isArray(state[field]) ? state[field] : []);
        if (current.has(value)) current.delete(value); else current.add(value);
        state[field] = Array.from(current);
        syncInputs(state);
        queueSave();
    }));

    inputs.housingStatus?.addEventListener("change", () => {
        if (inputs.housingStatus.value === "Own") {
            inputs.hasRentersInsurance.checked = false;
        }
        if (inputs.housingStatus.value === "Rent") {
            inputs.hasHomeInsurance.checked = false;
        }
        state = collectState();
        renderSummary(state);
        queueSave();
    });

    inputs.ownsBusiness?.addEventListener("change", () => {
        if (!inputs.ownsBusiness.checked) {
            inputs.hasEmployees.checked = false;
            inputs.hasGeneralLiability.checked = false;
            inputs.hasProfessionalLiability.checked = false;
            inputs.hasCyberCoverage.checked = false;
            inputs.hasWorkersComp.checked = false;
            inputs.hasCommercialAuto.checked = false;
            inputs.hasBusinessDisabilityCoverage.checked = false;
        }
        state = collectState();
        renderSummary(state);
        queueSave();
    });

    Object.values(inputs).forEach(input => input?.addEventListener("input", () => {
        state = collectState();
        renderSummary(state);
        queueSave();
    }));

    Object.values(inputs).forEach(input => input?.addEventListener("change", () => {
        state = collectState();
        renderSummary(state);
        queueSave();
    }));

    modeToggle?.addEventListener("click", () => {
        guidedMode = !guidedMode;
        renderJourney();
    });

    backStepButton?.addEventListener("click", () => {
        if (!guidedMode) return;
        currentStepIndex = Math.max(0, currentStepIndex - 1);
        renderJourney();
    });

    nextStepButton?.addEventListener("click", () => {
        if (!guidedMode) return;

        const atLastStep = currentStepIndex >= stepCards.length - 1;
        if (atLastStep) {
            // Finish: mark guided flow complete and switch to browse mode
            guidedMode = false;
            if (journeyTitle) journeyTitle.textContent = "All sections complete";
            if (journeyLesson) journeyLesson.textContent = "Review anything you like or exit — your changes are saved.";
            if (journeyProgress) journeyProgress.style.width = "100%";
            if (journeyStepPill) journeyStepPill.textContent = `${stepCards.length}/${stepCards.length} sections complete`;
            if (journeyTipPill) journeyTipPill.textContent = "Great work: journey complete. You can browse freely.";
            renderJourney();
            return;
        }

        currentStepIndex = Math.min(stepCards.length - 1, currentStepIndex + 1);
        renderJourney();
    });

    applyClientTypeVisibility();
    applyRoleMode();
    syncInputs(state);
    renderJourney();
    void loadState();
});
</script>
