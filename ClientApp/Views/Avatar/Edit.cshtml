@{
    ViewData["Title"] = "Profile Picture";
    var currentAvatar = (string?)ViewBag.AvatarUrl;
}

<link rel="stylesheet" href="~/css/legend-forms.css" asp-append-version="true" />
<style>
    .avatar-card {
        border-radius: 18px;
        overflow: hidden;
        border: 1.5px solid #d7dae3;
        box-shadow: 0 14px 28px rgba(15, 23, 42, .10);
        background: #fff;
    }
    .avatar-preview {
        width: 108px;
        height: 108px;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid #cbd5e1;
        display: grid;
        place-items: center;
        background: #0f172a;
        color: #f8fafc;
        font-weight: 900;
        font-size: 1.6rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.5);
    }
    .avatar-card .card-body{
        padding: 1.75rem 1.75rem 1.5rem;
        display: grid;
        gap: 1rem;
    }
    .legend-hero-body{
        row-gap: 0.5rem;
    }
</style>

<div class="legend-shell legend-form" style="max-width:820px;">
    <div class="legend-hero">
        <div class="legend-hero-bar"></div>
        <div class="legend-hero-body d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <span class="legend-kicker">Profile</span>
                <h2 class="legend-title">Profile Picture</h2>
                <p class="legend-sub">Upload a square PNG/JPG/WEBP under 3 MB.</p>
            </div>
            <a asp-controller="Home" asp-action="Index" class="legend-btn-primary" style="text-decoration:none;">Back</a>
        </div>
    </div>

    <div class="legend-card avatar-card mt-3">
        <div class="card-body">
            @if (TempData["AvatarSuccess"] is string ok)
            {
                <div class="alert alert-success">@ok</div>
            }
            @if (TempData["AvatarError"] is string err)
            {
                <div class="alert alert-danger">@err</div>
            }

            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="avatar-preview">
                    @if (!string.IsNullOrWhiteSpace(currentAvatar))
                    {
                        <img src="@currentAvatar" alt="Current avatar" style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {
                        <span>@User?.Identity?.Name?.FirstOrDefault()</span>
                    }
                </div>
            </div>

            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label for="photo" class="form-label fw-bold">Select image</label>
                    <input type="file" class="form-control" id="photo" name="photo" accept=".png,.jpg,.jpeg,.webp" required />
                </div>
                <button type="submit" class="legend-btn-primary">Save Picture</button>
            </form>
        </div>
    </div>
</div>
