}

.finance-title{
    margin-top: 10px !important;
    font-weight: 950;
    letter-spacing: .2px;
    color: var(--ink) !important;
}

.finance-subtitle{
    margin-top: 8px;
    color: var(--muted) !important;
    font-weight: 650;
    font-size: .98rem;
}

/* Dropdown wrapper */
.finance-select-wrap{
    max-width: 560px;
}

/* Dropdown styling — crisp gold border, sharp focus */
.finance-select{
    border: 2px solid var(--lineDark) !important;
    border-radius: 14px !important;
    padding: 12px 14px !important;
    font-weight: 900 !important;
    color: #f5f7fb !important;
