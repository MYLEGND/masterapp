@model ClientApp.Models.FinancialCommandCenterVm

@{
    ViewData["Title"] = "Financial Command Center";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var m = Model ?? new ClientApp.Models.FinancialCommandCenterVm();
    var notice = (ViewBag.QuickBooksNotice as string ?? "").Trim();
    var error = (ViewBag.QuickBooksError as string ?? "").Trim();
}

<style>
    :root{
        --ink:#111216;
        --muted:#5f6677;
        --line:rgba(17,18,22,.12);
        --card:#fff;
        --accent:#2f6f49;
        --danger:#b42318;
        --amber:#a76f00;
    }

    .fc-wrap{ max-width:1280px; margin:0 auto; padding:22px 18px 40px; }
    .fc-head{
        border:1px solid var(--line);
        border-radius:16px;
        background:linear-gradient(180deg, rgba(47,111,73,.08), #fff);
        box-shadow:0 16px 34px rgba(0,0,0,.08);
        padding:18px;
        display:flex;
        justify-content:space-between;
        align-items:flex-start;
        gap:12px;
        flex-wrap:wrap;
    }
    .fc-title{ margin:0; font-size:1.6rem; font-weight:900; color:var(--ink); }
    .fc-sub{ margin:6px 0 0; color:var(--muted); font-weight:600; }

    .fc-actions{ display:flex; gap:8px; flex-wrap:wrap; }
    .btnx{
        border:1px solid var(--line);
        background:#fff;
        color:var(--ink);
        border-radius:12px;
        padding:8px 12px;
        font-weight:800;
        text-decoration:none;
        cursor:pointer;
    }
    .btnx:hover{ border-color:rgba(47,111,73,.55); }
    .btn-solid{ background:var(--accent); border-color:var(--accent); color:#fff; }
    .btn-danger{ background:rgba(180,35,24,.08); border-color:rgba(180,35,24,.35); color:var(--danger); }

    .callout{
        margin-top:12px;
        border:1px solid var(--line);
        border-left-width:4px;
        border-radius:12px;
        background:#fff;
        padding:12px;
        font-weight:650;
    }
    .callout-ok{ border-left-color:var(--accent); }
    .callout-warn{ border-left-color:var(--amber); }
    .callout-err{ border-left-color:var(--danger); color:#7d1f17; }

    .kpis{
        margin-top:14px;
        display:grid;
        grid-template-columns:repeat(4, minmax(0,1fr));
        gap:10px;
    }
    @@media (max-width:1000px){ .kpis{ grid-template-columns:repeat(2, minmax(0,1fr)); } }
    @@media (max-width:560px){ .kpis{ grid-template-columns:1fr; } }

    .kpi{
        border:1px solid var(--line);
        border-radius:14px;
        background:var(--card);
        padding:12px;
    }
    .kpi .lbl{ color:var(--muted); font-size:.86rem; font-weight:800; }
    .kpi .val{ margin-top:5px; font-size:1.25rem; font-weight:900; }
    .pos{ color:#1f7a4a; }
    .neg{ color:#b42318; }

    .grid{
        margin-top:14px;
        display:grid;
        grid-template-columns:1.05fr .95fr;
        gap:12px;
    }
    @@media (max-width:1040px){ .grid{ grid-template-columns:1fr; } }

    .panel{
        border:1px solid var(--line);
        border-radius:14px;
        background:#fff;
        overflow:hidden;
    }
    .panel-h{
        padding:10px 12px;
        background:rgba(47,111,73,.06);
        border-bottom:1px solid var(--line);
        font-weight:850;
    }
    .panel-b{ padding:10px 12px; }

    .table{
        width:100%;
        border-collapse:collapse;
    }
    .table th,.table td{
        padding:8px 6px;
        border-bottom:1px solid rgba(17,18,22,.08);
        text-align:left;
        font-size:.92rem;
    }
    .table th{ font-weight:850; color:var(--muted); }
    .table tr:last-child td{ border-bottom:0; }
    .right{ text-align:right !important; }
    .mono{ font-variant-numeric:tabular-nums; }
    .empty{ color:var(--muted); font-weight:650; }
</style>

<div class="fc-wrap">
    <section class="fc-head">
        <div>
            <h2 class="fc-title">Financial Command Center</h2>
            <p class="fc-sub">@m.WorkspaceName • QuickBooks is the source of truth</p>
            @if (m.IsConnected)
            {
                <p class="fc-sub">Realm: @m.RealmId • Last Sync: @(m.LastSyncedUtc?.ToLocalTime().ToString("MM/dd/yyyy hh:mm tt") ?? "Never")</p>
            }
        </div>

        <div class="fc-actions">
            @if (m.IsQuickBooksConfigured && !m.IsConnected)
            {
                <form asp-controller="BookKeeping" asp-action="ConnectQuickBooks" method="post">
                    @Html.AntiForgeryToken()
                    <button class="btnx btn-solid" type="submit">Connect QuickBooks</button>
                </form>
            }
            @if (m.IsConnected)
            {
                <form asp-controller="BookKeeping" asp-action="RefreshQuickBooks" method="post">
                    @Html.AntiForgeryToken()
                    <button class="btnx" type="submit">Refresh Data</button>
                </form>
                <form asp-controller="BookKeeping" asp-action="DisconnectQuickBooks" method="post">
                    @Html.AntiForgeryToken()
                    <button class="btnx btn-danger" type="submit">Disconnect</button>
                </form>
            }
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(notice))
    {
        <div class="callout callout-ok">@notice</div>
    }
    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="callout callout-err">@error</div>
    }

    @if (!m.IsQuickBooksConfigured)
    {
        <div class="callout callout-warn">QuickBooks credentials are not configured in application settings.</div>
    }
    else if (!m.IsConnected)
    {
        <div class="callout callout-warn">
            This workspace is read-only and QuickBooks-powered. Connect this business client to QuickBooks to load financial intelligence.
        </div>
    }
    else
    {
        <section class="kpis">
            <article class="kpi">
                <div class="lbl">Revenue (MTD)</div>
                <div class="val mono pos">@m.RevenueMtd.ToString("C")</div>
            </article>
            <article class="kpi">
                <div class="lbl">Revenue (YTD)</div>
                <div class="val mono pos">@m.RevenueYtd.ToString("C")</div>
            </article>
            <article class="kpi">
                <div class="lbl">Expenses (MTD)</div>
                <div class="val mono neg">@m.ExpensesMtd.ToString("C")</div>
            </article>
            <article class="kpi">
                <div class="lbl">Expenses (YTD)</div>
                <div class="val mono neg">@m.ExpensesYtd.ToString("C")</div>
            </article>
            <article class="kpi">
                <div class="lbl">Net Profit (MTD)</div>
                <div class="val mono @(m.NetProfitMtd >= 0 ? "pos" : "neg")">@m.NetProfitMtd.ToString("C")</div>
            </article>
            <article class="kpi">
                <div class="lbl">Net Profit (YTD)</div>
                <div class="val mono @(m.NetProfitYtd >= 0 ? "pos" : "neg")">@m.NetProfitYtd.ToString("C")</div>
            </article>
            <article class="kpi">
                <div class="lbl">Cash Position</div>
                <div class="val mono @(m.CashPosition >= 0 ? "pos" : "neg")">@m.CashPosition.ToString("C")</div>
            </article>
            <article class="kpi">
                <div class="lbl">Chart of Accounts</div>
                <div class="val mono">@m.AccountsCount</div>
            </article>
        </section>

        <section class="grid">
            <article class="panel">
                <div class="panel-h">Top Expense Categories</div>
                <div class="panel-b">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th class="right">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (m.TopExpenseCategories.Count == 0)
                            {
                                <tr><td colspan="2" class="empty">No QuickBooks category data returned.</td></tr>
                            }
                            else
                            {
                                foreach (var x in m.TopExpenseCategories)
                                {
                                    <tr>
                                        <td>@x.Name</td>
                                        <td class="right mono neg">@x.Amount.ToString("C")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="panel">
                <div class="panel-h">Profit Trend (Monthly)</div>
                <div class="panel-b">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th class="right">Net Profit</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (m.ProfitTrend.Count == 0)
                            {
                                <tr><td colspan="2" class="empty">No QuickBooks trend data returned.</td></tr>
                            }
                            else
                            {
                                foreach (var p in m.ProfitTrend)
                                {
                                    <tr>
                                        <td>@p.MonthKey</td>
                                        <td class="right mono @(p.NetProfit >= 0 ? "pos" : "neg")">@p.NetProfit.ToString("C")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        </section>

        <section class="panel" style="margin-top:12px;">
            <div class="panel-h">Recent Transactions (QuickBooks)</div>
            <div class="panel-b">
                <table class="table">
                    <thead>
                        <tr>
                            <th style="width:120px;">Date</th>
                            <th style="width:130px;">Type</th>
                            <th>Name</th>
                            <th style="width:180px;">Account</th>
                            <th class="right" style="width:140px;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (m.RecentTransactions.Count == 0)
                        {
                            <tr><td colspan="5" class="empty">No QuickBooks transactions returned for this period.</td></tr>
                        }
                        else
                        {
                            foreach (var tx in m.RecentTransactions)
                            {
                                <tr>
                                    <td class="mono">@tx.Date.ToString("MM/dd/yyyy")</td>
                                    <td>@tx.Type</td>
                                    <td>@tx.Name</td>
                                    <td>@tx.Account</td>
                                    <td class="right mono @(tx.Amount >= 0 ? "pos" : "neg")">@tx.Amount.ToString("C")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>
