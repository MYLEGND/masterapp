@model ClientApp.Models.EditClientViewModel
@{
    ViewData["Title"] = "Update Profile";
    var childCount = Model?.Children?.Count ?? 0;
    var dobText = Model?.DOB.HasValue == true ? Model.DOB.Value.ToString("MM/dd/yyyy") : "—";
}

<style>
    :root{
        --gold:#a68023;
        --gold-strong:#c79931;
        --navy:#0b1529;
        --navy-2:#0f1d38;
    }
    body { background:#ffffff; color:#0f172a; font-family:'Inter', sans-serif; }

    .profile-shell{
        max-width:1040px;
        margin:0 auto;
        padding:14px 16px 32px;
    }
    .profile-card{
        background: var(--navy);
        color:#f8fafc;
        border:1.6px solid var(--gold);
        border-radius:14px;
        box-shadow:0 18px 36px rgba(0,0,0,.30), inset 0 0 0 1px rgba(255,255,255,.07);
        overflow:hidden;
    }
    .profile-card .card-header{
        background: var(--navy-2);
        border-bottom:1px solid rgba(166,128,35,.38);
        padding:.9rem 1.2rem;
        display:flex;
        justify-content:space-between;
        align-items:center;
        gap:1rem;
        flex-wrap:wrap;
    }
    .profile-card h2{
        margin:0;
        font-weight:900;
        letter-spacing:.4px;
        color: #c79931;
    }
    .badge{
        background: rgba(166,128,35,.16);
        border:1px solid rgba(166,128,35,.52);
        border-radius:999px;
        padding:0.25rem 0.75rem;
        font-weight:800;
        color:#f6e6b4;
        font-size:.78rem;
    }
    .legend-help{
        color:#cbd5e1;
        font-size:.86rem;
        margin:0.15rem 0 0;
    }
    .profile-card .card-body{
        padding:1.15rem 1.2rem 1.25rem;
        display:grid;
        gap:.85rem;
    }
    .avatar-block{
        display:flex;
        flex-wrap:wrap;
        gap:1rem;
        align-items:center;
        padding:0.45rem 0 0.9rem;
        border-bottom:1px solid rgba(166,128,35,.24);
        margin-bottom:0.15rem;
    }
    .avatar-preview{
        width:88px;
        height:88px;
        border-radius:50%;
        overflow:hidden;
        border:2px solid var(--gold-strong);
        display:grid;
        place-items:center;
        background: var(--navy-2);
        color:#f8fafc;
        font-weight:900;
        font-size:1.6rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.12), 0 10px 24px rgba(0,0,0,.22);
    }
    .avatar-actions{
        flex:1;
        min-width:260px;
        display:grid;
        gap:0.45rem;
    }
    .avatar-actions label{ color:#f8fafc; font-weight:800; }
    .avatar-actions input[type=file]{
        background: var(--navy-2);
        border:1.5px solid rgba(166,128,35,.62);
        border-radius:10px;
        color:#e2e8f0;
        padding:0.65rem;
    }
    .legend-btn, .legend-btn-small{
        background: var(--gold);
        color:#0b1529;
        border:1px solid var(--gold-strong);
        border-radius:10px;
        font-weight:900;
        padding:.72rem 1.05rem;
        box-shadow:0 10px 22px rgba(0,0,0,.26), inset 0 1px 0 rgba(255,255,255,.16);
        text-decoration:none;
        display:inline-flex;
        align-items:center;
        justify-content:center;
        gap:6px;
    }
    .legend-btn:hover, .legend-btn-small:hover{
        background:#ddb457;
        border-color:#ddb457;
        color:#0b1529;
        text-decoration:none;
    }
    .legend-btn.secondary{
        background: var(--navy-2);
        color:#f8fafc;
        border-color: rgba(166,128,35,.62);
        box-shadow:0 10px 22px rgba(0,0,0,.24), inset 0 1px 0 rgba(255,255,255,.10);
    }
    .legend-btn-small{
        padding:.55rem .95rem;
        border-radius:9px;
    }
    .two-col{
        display:grid;
        gap:.75rem;
        grid-template-columns:repeat(auto-fit, minmax(220px,1fr));
    }
    .label{
        font-weight:800;
        color:#f8fafc;
        margin-bottom:.22rem;
        letter-spacing:.2px;
        font-size:.9rem;
    }
    .input{
        width:100%;
        border-radius:9px;
        border:1.5px solid rgba(166,128,35,.62);
        background: var(--navy-2);
        color:#f8fafc;
        padding:.68rem .8rem;
        font-weight:700;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
    }
    .input:focus{
        outline:none;
        border-color: rgba(166,128,35,.92);
        box-shadow:0 0 0 3px rgba(166,128,35,.22);
    }
    .input[readonly], .input[disabled]{ opacity:0.75; cursor:not-allowed; }
    .validation{ font-weight:800; }
    .note{ color:#cbd5e1; font-size:0.9rem; margin:4px 0 0; }
    .form-actions{
        display:flex;
        gap:.65rem;
        flex-wrap:wrap;
        margin-top:.2rem;
    }
    .profile-card .subcard{
        border:1px solid rgba(166,128,35,.42) !important;
        background:linear-gradient(180deg, rgba(15,29,56,.88), rgba(8,18,36,.84)) !important;
        border-radius:12px;
        padding:.75rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.05);
    }
    .subcard-top{
        display:flex;
        align-items:flex-start;
        justify-content:space-between;
        gap:.7rem;
        flex-wrap:wrap;
        margin-bottom:.6rem;
    }
    .section-title{
        font-weight:950;
        letter-spacing:.25px;
        color:#f2d891;
        margin:0;
        font-size:1rem;
        line-height:1.2;
    }
    .pill{
        border-radius:999px;
        padding:5px 10px;
        font-weight:950;
        border:1px solid rgba(166,128,35,.35);
        background: rgba(166,128,35,.16);
        color:#f6e6b4;
        font-size:.8rem;
        white-space:nowrap;
    }
    .full{ grid-column:1 / -1; }
    .child-list{
        display:grid;
        gap:.55rem;
    }
    .child-card{
        border:1px solid rgba(166,128,35,.34);
        border-radius:10px;
        padding:.65rem;
        background:rgba(8,18,36,.64);
        display:grid;
        gap:.6rem;
    }
    .child-card-top{
        display:flex;
        justify-content:space-between;
        align-items:center;
        gap:.5rem;
        flex-wrap:wrap;
    }
    .child-title{
        font-weight:900;
        color:#f8fafc;
        font-size:.92rem;
    }
    .small-action{
        border:1px solid rgba(166,128,35,.62);
        border-radius:999px;
        min-height:32px;
        padding:0 .72rem;
        background:rgba(166,128,35,.14);
        color:#f2d891;
        font-weight:900;
        font-size:.82rem;
        cursor:pointer;
    }
    .small-action:hover{
        background:rgba(166,128,35,.24);
        color:#fff;
    }
</style>

<div class="profile-shell">
    <div class="profile-card">
        <div class="card-header">
            <div>
                <div class="badge">My Profile</div>
                <h2>Update account</h2>
                <p class="legend-help mb-0">Keep your contact info current; DOB is read-only and shown to your agent.</p>
            </div>
            <a class="legend-btn secondary" href="/profile">Back to profile</a>
        </div>

        <div class="card-body">
            <div class="avatar-block">
                <div class="avatar-preview">
                    <img src="@Url.Action("Current","Avatar")" alt="Current avatar" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none'; this.parentElement.textContent='A';" />
                </div>
                <div class="avatar-actions">
                    <form asp-controller="Avatar" asp-action="Upload" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <label for="photo">Profile picture</label>
                        <input type="file" id="photo" name="photo" accept=".png,.jpg,.jpeg,.webp" required />
                        <button type="submit" class="legend-btn-small mt-1">Upload photo</button>
                        <p class="legend-help mb-0">PNG/JPG/WEBP under 3 MB.</p>
                    </form>
                </div>
            </div>

            <form asp-action="Edit" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ClientUserId" />

                <div asp-validation-summary="ModelOnly" class="note-pill text-danger"
                     style="background:rgba(220,53,69,.14);border:1px solid rgba(220,53,69,.45);color:#ffecec;"></div>

                <div class="two-col">
                    <div>
                        <label asp-for="FirstName" class="label"></label>
                        <input asp-for="FirstName" class="input" autocomplete="given-name" />
                        <span asp-validation-for="FirstName" class="text-danger validation"></span>
                    </div>
                    <div>
                        <label asp-for="LastName" class="label"></label>
                        <input asp-for="LastName" class="input" autocomplete="family-name" />
                        <span asp-validation-for="LastName" class="text-danger validation"></span>
                    </div>
                    <div>
                        <label asp-for="Email" class="label"></label>
                        <input asp-for="Email" class="input" autocomplete="email" inputmode="email" />
                        <span asp-validation-for="Email" class="text-danger validation"></span>
                    </div>
                    <div>
                        <label asp-for="Phone" class="label"></label>
                        <input asp-for="Phone" class="input" autocomplete="tel" inputmode="tel" />
                        <span asp-validation-for="Phone" class="text-danger validation"></span>
                    </div>
                    <div>
                        <label asp-for="MaritalStatus" class="label">Marital status</label>
                        <select asp-for="MaritalStatus" class="input">
                            <option value="">-- Select --</option>
                            <option>Single</option>
                            <option>Married</option>
                            <option>Domestic Partnership</option>
                            <option>Divorced</option>
                            <option>Widowed</option>
                        </select>
                        <span asp-validation-for="MaritalStatus" class="text-danger validation"></span>
                    </div>
                    <div>
                        <label class="label">Date of birth</label>
                        <input class="input" value="@dobText" readonly />
                        <p class="legend-help mb-0">Contact support to correct your DOB.</p>
                    </div>
                </div>

                <div id="soCard" class="subcard" style="display:none; margin-top:12px;">
                    <div class="subcard-top">
                        <div>
                            <div class="section-title">Significant Other</div>
                            <div class="note">Required for Married / Domestic Partnership.</div>
                        </div>
                        <span class="pill">Required</span>
                    </div>

                    <div class="two-col">
                        <div>
                            <label asp-for="SignificantOtherFirstName" class="label">First name</label>
                            <input asp-for="SignificantOtherFirstName" class="input" id="SignificantOtherFirstName" />
                            <span asp-validation-for="SignificantOtherFirstName" class="text-danger validation"></span>
                        </div>
                        <div>
                            <label asp-for="SignificantOtherLastName" class="label">Last name</label>
                            <input asp-for="SignificantOtherLastName" class="input" id="SignificantOtherLastName" />
                            <span asp-validation-for="SignificantOtherLastName" class="text-danger validation"></span>
                        </div>
                        <div>
                            <label asp-for="SignificantOtherDOB" class="label">Date of birth</label>
                            <input asp-for="SignificantOtherDOB" type="date" class="input" id="SignificantOtherDOB" />
                            <span asp-validation-for="SignificantOtherDOB" class="text-danger validation"></span>
                        </div>
                        <div>
                            <label asp-for="SignificantOtherPhone" class="label">Phone</label>
                            <input asp-for="SignificantOtherPhone" class="input" />
                            <span asp-validation-for="SignificantOtherPhone" class="text-danger validation"></span>
                        </div>
                        <div class="full">
                            <label asp-for="SignificantOtherEmail" class="label">Email</label>
                            <input asp-for="SignificantOtherEmail" class="input" />
                            <span asp-validation-for="SignificantOtherEmail" class="text-danger validation"></span>
                        </div>
                    </div>
                </div>

                <div class="subcard" style="margin-top:12px;">
                    <div class="subcard-top">
                        <div>
                            <div class="section-title">Children</div>
                            <div class="note">Shared with your agent.</div>
                        </div>
                        <button type="button" class="small-action" id="addChildBtn">Add Child</button>
                    </div>

                    <div class="child-list" id="childrenList" data-next-index="@childCount">
                        @for (var i = 0; i < childCount; i++)
                        {
                            <div class="child-card" data-child-row>
                                <div class="child-card-top">
                                    <div class="child-title">Child</div>
                                    <button type="button" class="small-action" data-remove-child>Remove</button>
                                </div>
                                <input asp-for="Children[i].Id" type="hidden" data-field="Id" />
                                <div class="two-col">
                                    <div>
                                        <label asp-for="Children[i].FirstName" class="label">First name</label>
                                        <input asp-for="Children[i].FirstName" class="input" autocomplete="off" data-field="FirstName" />
                                        <span asp-validation-for="Children[i].FirstName" class="text-danger validation" data-valmsg-field="FirstName"></span>
                                    </div>
                                    <div>
                                        <label asp-for="Children[i].LastName" class="label">Last name</label>
                                        <input asp-for="Children[i].LastName" class="input" autocomplete="off" data-field="LastName" />
                                        <span asp-validation-for="Children[i].LastName" class="text-danger validation" data-valmsg-field="LastName"></span>
                                    </div>
                                    <div>
                                        <label asp-for="Children[i].DOB" class="label">Date of birth</label>
                                        <input asp-for="Children[i].DOB" type="date" class="input" data-field="DOB" />
                                        <span asp-validation-for="Children[i].DOB" class="text-danger validation" data-valmsg-field="DOB"></span>
                                    </div>
                                    <div>
                                        <label asp-for="Children[i].Phone" class="label">Phone</label>
                                        <input asp-for="Children[i].Phone" class="input" autocomplete="tel" inputmode="tel" data-field="Phone" />
                                        <span asp-validation-for="Children[i].Phone" class="text-danger validation" data-valmsg-field="Phone"></span>
                                    </div>
                                    <div>
                                        <label asp-for="Children[i].Email" class="label">Email</label>
                                        <input asp-for="Children[i].Email" class="input" autocomplete="email" inputmode="email" data-field="Email" />
                                        <span asp-validation-for="Children[i].Email" class="text-danger validation" data-valmsg-field="Email"></span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="legend-btn">Save changes</button>
                    <a class="legend-btn secondary" href="/profile">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts{
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        (() => {
            const status = document.getElementById('MaritalStatus');
            const soCard = document.getElementById('soCard');
            const soFirst = document.getElementById('SignificantOtherFirstName');
            const soLast  = document.getElementById('SignificantOtherLastName');
            const soDob   = document.getElementById('SignificantOtherDOB');
            const childrenList = document.getElementById('childrenList');
            const addChildBtn = document.getElementById('addChildBtn');

            const needsSO = (v) => {
                if (!v) return false;
                v = v.toLowerCase();
                return v === 'married' || v === 'domestic partnership';
            };

            const applySO = () => {
                const v = status ? status.value : '';
                const required = needsSO(v);
                if (soCard) soCard.style.display = required ? '' : 'none';
                if (soFirst) soFirst.required = required;
                if (soLast)  soLast.required  = required;
                if (soDob)   soDob.required   = required;
                if (!required) {
                    if (soFirst) soFirst.value = '';
                    if (soLast)  soLast.value  = '';
                    if (soDob)   soDob.value   = '';
                }
            };

            const childTemplate = (index) => `
                <div class="child-card" data-child-row>
                    <div class="child-card-top">
                        <div class="child-title">Child</div>
                        <button type="button" class="small-action" data-remove-child>Remove</button>
                    </div>
                    <input type="hidden" name="Children[${index}].Id" id="Children_${index}__Id" data-field="Id" />
                    <div class="two-col">
                        <div>
                            <label class="label" for="Children_${index}__FirstName">First name</label>
                            <input class="input" type="text" name="Children[${index}].FirstName" id="Children_${index}__FirstName" autocomplete="off" data-field="FirstName" />
                            <span class="text-danger validation" data-valmsg-for="Children[${index}].FirstName" data-valmsg-replace="true" data-valmsg-field="FirstName"></span>
                        </div>
                        <div>
                            <label class="label" for="Children_${index}__LastName">Last name</label>
                            <input class="input" type="text" name="Children[${index}].LastName" id="Children_${index}__LastName" autocomplete="off" data-field="LastName" />
                            <span class="text-danger validation" data-valmsg-for="Children[${index}].LastName" data-valmsg-replace="true" data-valmsg-field="LastName"></span>
                        </div>
                        <div>
                            <label class="label" for="Children_${index}__DOB">Date of birth</label>
                            <input class="input" type="date" name="Children[${index}].DOB" id="Children_${index}__DOB" data-field="DOB" />
                            <span class="text-danger validation" data-valmsg-for="Children[${index}].DOB" data-valmsg-replace="true" data-valmsg-field="DOB"></span>
                        </div>
                        <div>
                            <label class="label" for="Children_${index}__Phone">Phone</label>
                            <input class="input" type="tel" name="Children[${index}].Phone" id="Children_${index}__Phone" autocomplete="tel" inputmode="tel" data-field="Phone" />
                            <span class="text-danger validation" data-valmsg-for="Children[${index}].Phone" data-valmsg-replace="true" data-valmsg-field="Phone"></span>
                        </div>
                        <div>
                            <label class="label" for="Children_${index}__Email">Email</label>
                            <input class="input" type="email" name="Children[${index}].Email" id="Children_${index}__Email" autocomplete="email" inputmode="email" data-field="Email" />
                            <span class="text-danger validation" data-valmsg-for="Children[${index}].Email" data-valmsg-replace="true" data-valmsg-field="Email"></span>
                        </div>
                    </div>
                </div>`;

            const reindexChildren = () => {
                if (!childrenList) return;
                childrenList.querySelectorAll('[data-child-row]').forEach((row, index) => {
                    row.querySelectorAll('[data-field]').forEach((input) => {
                        const field = input.getAttribute('data-field');
                        input.name = `Children[${index}].${field}`;
                        input.id = `Children_${index}__${field}`;
                    });
                    row.querySelectorAll('[data-valmsg-field]').forEach((span) => {
                        const field = span.getAttribute('data-valmsg-field');
                        span.setAttribute('data-valmsg-for', `Children[${index}].${field}`);
                    });
                    row.querySelectorAll('label[for]').forEach((label) => {
                        const field = label.getAttribute('for')?.split('__').pop() || '';
                        const target = row.querySelector(`[data-field="${field}"]`);
                        if (target) label.setAttribute('for', target.id);
                    });
                });
                childrenList.dataset.nextIndex = String(childrenList.querySelectorAll('[data-child-row]').length);
            };

            if (status) {
                status.addEventListener('change', applySO);
                applySO();
            }

            addChildBtn?.addEventListener('click', () => {
                if (!childrenList) return;
                const index = Number.parseInt(childrenList.dataset.nextIndex || '0', 10);
                childrenList.insertAdjacentHTML('beforeend', childTemplate(Number.isFinite(index) ? index : 0));
                reindexChildren();
                childrenList.querySelector('[data-child-row]:last-child input[data-field="FirstName"]')?.focus();
            });

            childrenList?.addEventListener('click', (event) => {
                const removeBtn = event.target.closest('[data-remove-child]');
                if (!removeBtn) return;
                removeBtn.closest('[data-child-row]')?.remove();
                reindexChildren();
            });
        })();
    </script>
}
