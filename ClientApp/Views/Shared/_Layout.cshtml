    <style>
        :root{
            --client-gold:#a68023;
            --client-gold-bright:#ddb457;
            --client-line:rgba(166,128,35,.42);
            --client-line-strong:rgba(166,128,35,.88);
        }

        body { background: #fff; color: #000; font-family: 'Inter', sans-serif; }

        .navbar {
            background: #0b1529 !important;
            border: 1.5px solid rgba(166,128,35,.86) !important;
            padding: 1.6rem 1.8rem;
            display: flex;
            flex-wrap: wrap;
            align-items: flex-start;
            max-height: none; /* IMPORTANT: max-height was clipping on mobile */
            position: relative;
            box-shadow:
                0 18px 38px rgba(0,0,0,.28),
                inset 0 0 0 1px rgba(255,255,255,.08);
            border-radius: 18px;
            overflow: visible; /* allow dropdown menus to escape container */
            z-index: 1030;
        }

        .navbar::before{
            content:"";
            position:absolute;
            left:0;
            right:0;
            top:0;
            height:4px;
            background: linear-gradient(90deg, #a68023, #c79931 24%, #ddb457 52%, #c79931 80%, #a68023);
            border-top-left-radius: 16px;
            border-top-right-radius: 16px;
        }

        .navbar-brand img {
            height: 82px;
            width: auto;
            max-height: 82px;
            padding: 10px;
            border: 1.5px solid rgba(166,128,35,.62);
            border-radius: 14px;
            background: #0f1d38;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 10px 22px rgba(0,0,0,.24);
            filter: drop-shadow(0 8px 16px rgba(0,0,0,.18));
        }

        /* =========================================================
           CRITICAL OVERRIDE: site.css sets .navbar-left to display:grid
           which stacks things. We force flex with higher specificity.
           ========================================================= */
        /* header .navbar .navbar-left {
            display: flex !important;
            flex-direction: column;
            justify-content: center;
            margin-left: 1.5rem;
            height: 100%;
        } */

        .navbar-left .nav-rows-grid {
            display: grid;
            row-gap: 0.5rem;
        }

        .nav-context-row {
            display: flex;
            align-items: center;
            min-height: 34px;
        }

        .nav-context-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            max-width: min(100%, 430px);
            padding: 0.48rem 0.9rem;
            border-radius: 999px;
            border: 1.5px solid rgba(166,128,35,.62);
            background: #0f1d38;
            color: #f8fafc;
            font-weight: 850;
            letter-spacing: .02em;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
        }

        .nav-context-pill strong {
            font-weight: 950;
            color: #f8fafc;
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .navbar-left .nav-row {
            display: flex;
            gap: 2rem;
            align-items: center;
            flex-wrap: wrap; /* wrap when needed, but keep horizontal row behavior */
            margin: 0;
            padding: 0;
        }

        .navbar-left li { list-style: none; }

        .navbar-left .nav-link {
            font-weight: 900;
            color: #f8fafc !important;
            white-space: nowrap;
            padding: 0.7rem 1.35rem;
            border-radius: 50px;
            transition: all 0.25s ease;
            letter-spacing: 0.55px;
            border: 1.5px solid rgba(166,128,35,.62);
            background: transparent;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.10);
        }

        .navbar-left .nav-link:hover,
        .navbar-left .nav-link.active {
            color: var(--client-gold-bright) !important;
            background: rgba(166,128,35,0.14);
            border-color: rgba(166,128,35,.82);
            transform: translateY(-2px);
            box-shadow:
                0 14px 24px rgba(0,0,0,.22),
                inset 0 1px 0 rgba(255,255,255,.12);
        }

        .dropdown { position: relative; }

        .dropdown-menu-centered {
            position: absolute;
            top: 100%;
            left: 0;
            background: #ffffff;
            border: 1.5px solid rgba(166,128,35,.74);
            border-radius: 16px;
            padding: 0.5rem 0;
            display: none;
            flex-direction: column;
            min-width: 200px;
            z-index: 999;
            box-shadow: 0 20px 40px rgba(64,47,11,.12);
            backdrop-filter: blur(4px);
        }

        .dropdown-menu-centered .dropdown-item {
            padding: 0.65rem 1.25rem;
            color: #1a1a1a;
            font-weight: 800;
            text-decoration: none;
            border-radius: 14px;
            transition: all 0.25s ease;
            margin: 0 6px;
        }

        .dropdown-menu-centered .dropdown-item:hover {
            color: #a68023;
            background: #fffdf8;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(64,47,11,.10);
        }

        .dropdown:hover .dropdown-menu-centered { display: flex; }

        .navbar-right {
            display: flex;
            width: auto;
            min-width: 360px;
            justify-content: flex-end;
            gap: 8px;
            align-items: center;
            position: relative;
            flex-wrap: wrap;
            overflow: visible;
            z-index: 1031;
        }

        .nav-toggle {
            display: none;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border: 1.4px solid rgba(166,128,35,0.65);
            background: linear-gradient(160deg, #0e1a33, #0a1327);
            box-shadow: 0 10px 18px rgba(0,0,0,.26), inset 0 1px 0 rgba(255,255,255,.06);
            cursor: pointer;
            padding: 0;
            transition: transform .12s ease, box-shadow .16s ease, background .16s ease;
        }
        .nav-toggle:focus-visible { outline: 2px solid var(--client-gold-bright); outline-offset: 3px; }
        .nav-toggle:hover { transform: translateY(-1px); box-shadow: 0 12px 22px rgba(0,0,0,.28); }
        .nav-toggle-bars,
        .nav-toggle-bars::before,
        .nav-toggle-bars::after {
            display: block;
            width: 20px;
            height: 2px;
            background: #f8fafc;
            border-radius: 4px;
            position: relative;
            transition: transform .18s ease, opacity .18s ease;
        }
        .nav-toggle-bars::before,
        .nav-toggle-bars::after {
            content: "";
            position: absolute;
            left: 0;
        }
        .nav-toggle-bars::before { top: -6px; }
        .nav-toggle-bars::after { top: 6px; }
        .navbar.mobile-open .nav-toggle-bars { transform: rotate(45deg); }
        .navbar.mobile-open .nav-toggle-bars::before { transform: rotate(-90deg) translateX(-6px); }
        .navbar.mobile-open .nav-toggle-bars::after { opacity: 0; }

        .agent-pill-shell {
            order: 2;
            flex: 0 0 100%;
            display: flex;
            justify-content: flex-end;
            margin-top: 6px;
        }

        .agent-pill-chip {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.45rem 0.85rem;
            border-radius: 12px;
            border: 1.5px solid #8f6b14;
            background: #0f172a;
            color: #ffffff;
            font-weight: 850;
            letter-spacing: .02em;
            box-shadow: 0 10px 20px rgba(0,0,0,.12);
            white-space: nowrap;
            max-width: none;
            cursor: pointer;
        }

        .agent-pill-chip .agent-name {
            font-weight: 900;
            letter-spacing: .01em;
        }

        .agent-pill-chip .npn-chip {
            display: inline-flex;
            align-items: center;
            gap: .35rem;
            margin-left: .1rem;
            padding: 0.18rem 0.55rem;
            border-radius: 999px;
            border: 1px solid rgba(197,146,31,.55);
            background: rgba(197,146,31,.14);
            color: #f8f9fb;
            font-weight: 800;
            line-height: 1;
        }

        .agent-pill-chip .npn-chip .npn-label {
            font-size: .72rem;
            letter-spacing: .08em;
            text-transform: uppercase;
            opacity: .86;
        }

        .agent-pill-chip .npn-chip .npn-value {
            font-size: .78rem;
            font-weight: 900;
            letter-spacing: .02em;
        }

        .navbar-right .nav-link,
        .navbar-right .btn-link,
        .navbar-right .profile-chip {
            order: 1;
        }

        .agent-pill-menu a { font-weight: 800; }
        .agent-pill-menu .disabled { opacity: .6; }
        .agent-pill-menu {
            z-index: 9999;
            background: #0b1529;
            border: 1.6px solid #c5921f;
            border-radius: 12px;
            box-shadow: 0 16px 40px rgba(0,0,0,0.35);
        }
        .agent-pill-menu .dropdown-item {
            color: #f8fafc;
            font-weight: 800;
        }
        .agent-pill-menu .dropdown-item:hover {
            background: rgba(197,146,31,0.18);
            color: #f8fafc;
        }
        .agent-pill-menu .dropdown-divider {
            border-color: rgba(197,146,31,0.45);
        }

        /* Theme any nav dropdowns navy/white/gold so nothing renders white */
        header .navbar .dropdown-menu {
            background: #0b1529 !important;
            border: 1.6px solid #c5921f !important;
            color: #f8fafc !important;
            box-shadow: 0 16px 40px rgba(0,0,0,0.35);
            border-radius: 12px;
        }
        header .navbar .dropdown-menu .dropdown-item {
            color: #f8fafc !important;
            font-weight: 800;
        }
        header .navbar .dropdown-menu .dropdown-item:hover,
        header .navbar .dropdown-menu .dropdown-item:focus {
            background: rgba(197,146,31,0.18) !important;
            color: #f8fafc !important;
        }
        header .navbar .dropdown-menu .dropdown-divider {
            border-color: rgba(197,146,31,0.45) !important;
        }

        /* ensure any dropdown in the nav layers above everything */
        header .dropdown-menu {
            z-index: 12000;
            position: absolute;
        }

        .navbar-right .nav-link,
        .navbar-right .btn-link {
            color: #f8fafc !important;
            font-weight: 900;
            transition: all 0.25s ease;
            white-space: nowrap;
            padding: .65rem 1.1rem;
            border-radius: 30px;
            border: 1.5px solid rgba(166,128,35,.62);
            background: transparent;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.10);
        }

        .navbar-right .nav-link:hover,
        .navbar-right .btn-link:hover {
            color: var(--client-gold-bright) !important;
            background: rgba(166,128,35,0.14);
            border-color: rgba(166,128,35,.82);
            transform: translateY(-2px);
            box-shadow:
                0 14px 24px rgba(0,0,0,.22),
                inset 0 1px 0 rgba(255,255,255,.12);
        }

        .profile-chip {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 0.4rem 0.85rem;
            border-radius: 999px;
            border: 1.5px solid rgba(166,128,35,.82);
            background: #ffffff;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.86), 0 10px 20px rgba(64,47,11,.12);
            text-decoration: none;
            color: #1a1a1a;
            font-weight: 900;
            min-width: 150px;
        }

        .profile-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            overflow: hidden;
            border: 1.5px solid rgba(166,128,35,.45);
            background: linear-gradient(135deg, #0f172a, #1e293b);
            display: grid;
            place-items: center;
            color: #f8fafc;
            font-weight: 900;
            letter-spacing: .5px;
        }

        .profile-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .profile-meta {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

        .profile-name { color: #0f172a; font-weight: 900; }
        .profile-note { color: #4b5563; font-size: 0.8rem; font-weight: 800; }

        .header-psalms {
            position: absolute;
            top: 102px; /* pulled upward to sit fully inside the nav */
            left: 50%;
            transform: translateX(-50%);
            font-size: 1.32rem;
            font-weight: 900;
            color: #a68023;
            letter-spacing: 1.8px;
            text-align: center;
            font-family: 'Inter', sans-serif;
            max-width: calc(100% - 3rem);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            padding: .48rem 1.1rem;
            border-radius: 999px;
            border: 1.5px solid rgba(166,128,35,.30);
            background: #ffffff;
            box-shadow:
                0 10px 22px rgba(64,47,11,.08),
                inset 0 1px 0 rgba(255,255,255,.84);
            line-height: 1.05;
            z-index: 1200;
            cursor: pointer;
            transition: transform .15s ease, box-shadow .18s ease, background .18s ease;
        }

        .header-psalms:hover,
        .header-psalms:focus-visible {
            transform: translateX(-50%) translateY(-1px);
            box-shadow:
                0 14px 30px rgba(64,47,11,.14),
                inset 0 1px 0 rgba(255,255,255,.94);
            background: #f8fafc;
            outline: none;
        }

        .header-psalms:active {
            transform: translateX(-50%) translateY(0);
            box-shadow:
                0 8px 16px rgba(64,47,11,.12),
                inset 0 1px 0 rgba(255,255,255,.84);
            background: #f4f6fb;
        }

        .no-scroll { overflow: hidden; }

        .scripture-modal {
            position: fixed;
            inset: 0;
            background: rgba(8, 12, 24, 0.72);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .18s ease;
            z-index: 1400;
            padding: 16px;
        }

        .scripture-modal.open { opacity: 1; pointer-events: auto; }

        .scripture-card {
            width: min(760px, 96vw);
            background: #0b1529;
            color: #f8fafc;
            border-radius: 18px;
            border: 1.6px solid var(--legend-gold-deep, rgba(166,128,35,.85));
            box-shadow: 0 28px 60px rgba(0,0,0,.44);
            padding: 20px 22px 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .scripture-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
        }

        .scripture-day {
            font-size: .82rem;
            letter-spacing: 0.08em;
            color: rgba(255,255,255,.72);
            text-transform: uppercase;
        }

        .scripture-reference {
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--legend-gold-bright, #f2c573);
            letter-spacing: 0.04em;
        }

        .scripture-translation {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 10px;
            border-radius: 999px;
            border: 1px solid rgba(166,128,35,.60);
            background: rgba(255,255,255,.06);
            font-size: .85rem;
            color: #f8fafc;
            white-space: nowrap;
        }

        .scripture-close {
            background: transparent;
            color: #f8fafc;
            border: 1px solid rgba(255,255,255,.18);
            border-radius: 10px;
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            line-height: 1;
            transition: background .15s ease, transform .15s ease;
        }

        .scripture-close:hover,
        .scripture-close:focus-visible {
            background: rgba(255,255,255,.12);
            transform: translateY(-1px);
            outline: none;
        }

        .scripture-text {
            max-height: 60vh;
            overflow: auto;
            padding-right: 6px;
            line-height: 1.6;
            letter-spacing: 0.01em;
        }

        .scripture-text p { margin-bottom: 10px; color: #e2e8f0; }
        .scripture-text p:last-child { margin-bottom: 0; }

        .scripture-streak-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            border: 1px dashed rgba(166,128,35,.55);
            background: rgba(255,255,255,.04);
        }

        .scripture-streak-label {
            color: rgba(255,255,255,.76);
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            font-size: .8rem;
        }

        .scripture-streak-value {
            font-size: 1.3rem;
            font-weight: 900;
            letter-spacing: 0.04em;
        }

        .scripture-streak-note {
            color: rgba(255,255,255,.64);
            font-weight: 700;
            font-size: .85rem;
            margin-left: auto;
            white-space: nowrap;
        }
        }

        .explore-overlay{
            position: fixed;
            inset: 0;
            z-index: 1098;
            background: transparent;
            display: none;
        }
        .explore-overlay.open{ display:block; }

        .explore-trigger{
            position: fixed;
            left: 18px;
            top: 185px;
            z-index: 1100;
            width: 54px;
            height: 54px;
            border-radius: 16px;
            border: 1.6px solid rgba(166,128,35,.86);
            background: #0b1529;
            box-shadow:
                0 16px 34px rgba(0,0,0,.26),
                inset 0 0 0 1px rgba(255,255,255,.10);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .2s ease;
        }

        .explore-trigger:hover{
            transform: translateY(-2px) scale(1.01);
            border-color: rgba(166,128,35,.94);
            box-shadow:
                0 20px 42px rgba(0,0,0,.32),
                inset 0 0 0 1px rgba(255,255,255,.14);
        }

        .explore-bars{
            width: 18px;
            height: 14px;
            display: grid;
            gap: 3px;
        }

        .explore-bars span{
            display:block;
            height: 2.5px;
            border-radius: 999px;
            background: linear-gradient(90deg, #f8fafc, #ddb457);
            transition: all .2s ease;
            opacity: 1;
        }

        .explore-trigger:hover .explore-bars span{
            background: linear-gradient(90deg, #f8fafc, #efc866);
        }

        .explore-drawer{
            position: fixed;
            left: 78px;
            top: 185px;
            z-index: 1099;
            width: 320px;
            max-width: calc(100vw - 36px);
            transform: translateX(-140%);
            transition: transform .25s ease;
            pointer-events: none;
        }

        .explore-drawer.open{
            transform: translateX(0);
            pointer-events: auto;
        }

        .explore-drawer:not(.open) .explore-card{
            box-shadow:none;
        }

        .explore-card{
            background: #0b1529;
            border: 1.5px solid rgba(166,128,35,.86);
            border-radius: 18px;
            box-shadow:
                0 22px 48px rgba(0,0,0,.30),
                inset 0 0 0 1px rgba(255,255,255,.08);
            overflow: hidden;
            position: relative;
        }

        .explore-card::before{
            content:"";
            position:absolute;
            left:0;
            right:0;
            top:0;
            height:4px;
            background: linear-gradient(90deg, #a68023, #c79931 26%, #efc866 54%, #c79931 80%, #a68023);
        }

        .explore-header{
            padding: 18px 18px 12px 18px;
            border-bottom: 1px solid rgba(166,128,35,.32);
            display:flex;
            align-items:center;
            justify-content: space-between;
            gap: 10px;
            background: #0b1529;
        }

        .explore-title{
            font-weight: 1000;
            letter-spacing: 1.2px;
            color: #ddb457;
            font-size: 1rem;
            white-space: nowrap;
        }

        .explore-pill{
            font-size: .74rem;
            font-weight: 900;
            color: #ddb457;
            background: #0f1d38;
            border: 1px solid rgba(166,128,35,.42);
            padding: 6px 11px;
            border-radius: 999px;
            white-space: nowrap;
            box-shadow: inset 0 0 0 1px rgba(255,255,255,.72);
        }

        .explore-search{
            padding: 14px 18px 10px 18px;
        }

        .explore-search input{
            width:100%;
            border-radius:999px;
            border:1.5px solid rgba(166,128,35,.42);
            padding:11px 15px;
            outline:none;
            font-weight:800;
            transition:all .2s ease;
            background: #0f1d38;
            color:#f8fafc;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
        }

        .explore-search input:focus{
            border-color: rgba(166,128,35,.94);
            box-shadow: 0 0 0 4px rgba(166,128,35,.14), 0 12px 24px rgba(64,47,11,.08);
        }

        .explore-list{
            max-height: calc(100vh - 330px);
            overflow:auto;
            padding: 8px 12px 16px 12px;
        }

        .explore-item{
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap:10px;
            padding:10px 12px;
            border-radius:12px;
            text-decoration:none;
            color:#f8fafc;
            font-weight:900;
            transition:all .2s ease;
            margin:6px 6px;
            border:1px solid rgba(166,128,35,.38);
            background: #0f1d38;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
        }

        .explore-item:hover{
            color:#ddb457;
            background: rgba(166,128,35,.14);
            transform: translateY(-2px);
            border-color: rgba(166,128,35,.56);
            box-shadow: 0 14px 28px rgba(0,0,0,.24);
        }

        .explore-item span{
            display:block;
            font-size:.98rem;
            letter-spacing:.18px;
        }

        .explore-item small{
            font-weight: 900;
            white-space: nowrap;
            padding: 5px 10px;
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,.16);
            background: rgba(255,255,255,.06);
            color: #e2e8f0;
            letter-spacing: .35px;
            text-transform: uppercase;
            font-size: .67rem;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.12);
        }

        .explore-item[data-tone="home"] small{
            color:#2457c5;
            border-color:rgba(36,87,197,.28);
            background:linear-gradient(180deg, #f4f8ff, #e9f1ff);
        }

        .explore-item[data-tone="finance"] small{
            color:#0d7d73;
            border-color:rgba(13,125,115,.24);
            background:linear-gradient(180deg, #f1fcfa, #e7f8f5);
        }

        .explore-item[data-tone="ops"] small{
            color:#1f8b49;
            border-color:rgba(31,139,73,.24);
            background:linear-gradient(180deg, #f3fbf6, #e8f7ed);
        }

        .explore-item[data-tone="quote"] small{
            color:#a05d12;
            border-color:rgba(160,93,18,.24);
