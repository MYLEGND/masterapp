<!DOCTYPE html>
@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@using System.Text.Json
@using Domain.Entities
@using System.IO
@inject IHttpContextAccessor HttpContextAccessor
@inject ClientApp.Services.EffectiveClientContextService ClientContextService
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Html.Raw(ViewData["Title"]) - Legend™</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout-inline.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LegendCorePlatform.styles.css" asp-append-version="true" />

    <!-- Google Font for Psalms 23 | Proverbs 3:5-6 -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

    <link rel="icon" type="image/png" href="~/images/favicon/favicon.png" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

<header>
    <nav class="navbar navbar-expand-sm navbar-light">
        <div class="container-fluid d-flex flex-wrap align-items-start justify-content-between">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/company-icons/legend.png" asp-append-version="true" alt="Legend™" />
            </a>

            <button class="nav-toggle" id="clientNavToggle" aria-label="Toggle navigation" aria-expanded="false">
                <span class="nav-toggle-bars"></span>
            </button>

            <div class="navbar-left">
                <div class="nav-rows-grid">
                    <ul class="navbar-nav nav-row">
                        @{
                            var currentController =
                                (ViewContext.ActionDescriptor as Microsoft.AspNetCore.Mvc.Controllers.ControllerActionDescriptor)?.ControllerName;
                            string Active(string c) => c == currentController ? "active" : "";
                        }

                        @{
                            var ctx = ClientContextService.ResolveAsync(User, Context.Request.Cookies).GetAwaiter().GetResult();
                            bool isBusinessClient = false;
                            string managedClientName = "Client";
                            if (ctx?.Profile != null)
                            {
                                isBusinessClient = string.Equals(ResolveRecordType(ctx.Profile), "BusinessClient", StringComparison.OrdinalIgnoreCase);
                                managedClientName = $"{ctx.Profile.FirstName} {ctx.Profile.LastName}".Trim();
                                if (string.IsNullOrWhiteSpace(managedClientName))
                                {
                                    managedClientName = "Client";
                                }
                            }
                        }

                        <li class="nav-item"><a class="nav-link @Active("Home")" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link @Active("Finance")" asp-controller="Finance" asp-action="Index">Finance</a></li>
                        <li class="nav-item"><a class="nav-link" href="https://protect.mylegnd.com/Quote" target="_blank" rel="noopener">Insurance Quote</a></li>
                    </ul>
                    @if (ctx?.IsAgentView == true)
                    {
                        <div class="nav-context-row">
                            <span class="nav-context-pill">Managing <strong>@managedClientName</strong></span>
                        </div>
                    }
                </div>
            </div>

            <!-- Center Psalms 23 | Proverbs 3:5-6 -->
            <button type="button"
                    class="header-psalms"
                    id="psalmsTrigger"
                    aria-haspopup="dialog"
                    aria-controls="psalmsModal">
                LIFE HAC | GOD ABOVE ALL
            </button>

            <div class="navbar-right">
            @{
                    var user = HttpContextAccessor.HttpContext?.User;
                    var clientContext = ctx; // from earlier resolution
                    var agentPillName = string.IsNullOrWhiteSpace(clientContext?.AgentDisplayName)
                        ? "Your Agent"
                        : clientContext.AgentDisplayName;
                    var agentPillNpn = clientContext?.AgentNpn;
                    var showAgentPill = clientContext != null && (!string.IsNullOrWhiteSpace(agentPillName) || !string.IsNullOrWhiteSpace(agentPillNpn));
                    string? CleanToken(string? s)
                    {
                        if (string.IsNullOrWhiteSpace(s)) return null;
                        var t = s.Trim();
                        if (t.Contains("@")) return null;
                        if (t.Contains(".")) return null;
                        var parts = t.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        return parts.Length > 0 ? parts[0] : null;
                    }
                    string? Initial(string? s)
                    {
                        if (string.IsNullOrWhiteSpace(s)) return null;
                        var t = s.Trim();
                        return t.Length > 0 ? t.Substring(0, 1).ToUpperInvariant() : null;
                    }

                    var displayName = "Agent";
                    string? first = null;
                    string? last = null;
                    string? avatarUrl = null;
                    string? userId = null;

                    if (user?.Identity != null && user.Identity.IsAuthenticated)
                    {
                        first =
                            CleanToken(user.FindFirst("given_name")?.Value)
                            ?? CleanToken(user.FindFirst(ClaimTypes.GivenName)?.Value)
                            ?? CleanToken(user.FindFirst("name")?.Value);

                        last =
                            CleanToken(user.FindFirst("family_name")?.Value)
                            ?? CleanToken(user.FindFirst(ClaimTypes.Surname)?.Value);

                        displayName =
                            (!string.IsNullOrWhiteSpace(first) || !string.IsNullOrWhiteSpace(last))
                                ? string.Join(" ", new[] { first, last }.Where(x => !string.IsNullOrWhiteSpace(x)))
                                : user.FindFirst("name")?.Value
                                  ?? user.FindFirst(ClaimTypes.Name)?.Value
                                  ?? first
                                  ?? "Agent";

                        userId =
                            user.FindFirst("oid")?.Value
                            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value
                            ?? user.Identity?.Name;

                        avatarUrl =
                            user.FindFirst("picture")?.Value
                            ?? user.FindFirst("photo")?.Value
                            ?? user.FindFirst("avatar")?.Value
                            ?? user.FindFirst("avatar_url")?.Value
                            ?? user.FindFirst("profile_image")?.Value
                            ?? user.FindFirst("image")?.Value;

                    }

                    var initials = (Initial(first) ?? "") + (Initial(last) ?? "");
                    if (string.IsNullOrWhiteSpace(initials))
                    {
                        initials = Initial(displayName) ?? "A";
                    }

                    if (avatarUrl == null && !string.IsNullOrWhiteSpace(userId))
                    {
                        avatarUrl = Url.Action("Current", "Avatar");
                    }
                }

                @if (showAgentPill)
                {
                    var agentPhone = clientContext?.AgentPhone;
                    var agentEmail = clientContext?.AgentEmail;
                    <div class="dropdown agent-pill-shell" aria-label="Assigned agent">
                        <button class="agent-pill-chip dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <span class="agent-name">@agentPillName</span>
                            @if (!string.IsNullOrWhiteSpace(agentPillNpn))
                            {
                                <span class="npn-chip"><span class="npn-label">NPN</span><span class="npn-value">@agentPillNpn</span></span>
                            }
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end agent-pill-menu">
                            @if (!string.IsNullOrWhiteSpace(agentPhone))
                            {
                                <li><a class="dropdown-item" href="tel:@agentPhone">Call @agentPhone</a></li>
                                <li><a class="dropdown-item" href="sms:@agentPhone">Text @agentPhone</a></li>
                            }
                            else
                            {
                                <li><span class="dropdown-item disabled">No phone on file</span></li>
                            }
                            @if (!string.IsNullOrWhiteSpace(agentEmail))
                            {
                                <li><a class="dropdown-item" href="mailto:@agentEmail">Email @agentEmail</a></li>
                            }
                            else
                            {
                                <li><span class="dropdown-item disabled">No email on file</span></li>
                            }
                        </ul>
                    </div>
                }

                <a class="nav-link" href="https://www.mylegnd.com/store" target="_blank">Store</a>
                <div class="dropdown">
                    <button class="profile-chip dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="@displayName">
                        <div class="profile-avatar">
                            @if (!string.IsNullOrWhiteSpace(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="Profile photo" loading="lazy" />
                            }
                            else
                            {
                                <span>@initials</span>
                            }
                        </div>
                        <div class="profile-meta">
                            <span class="profile-name" style="color:#0f172a;">@displayName</span>
                            <span class="visually-hidden">Profile menu</span>
                        </div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end profile-contact-menu">
                        <li><a class="dropdown-item" href="/profile/edit">Edit Profile</a></li>
                        <li><a class="dropdown-item" href="/profile">View Profile</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item">Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>

        </div>
    </nav>
</header>

<div id="exploreOverlay" class="explore-overlay" aria-hidden="true"></div>

<button id="exploreTrigger"
        type="button"
        class="explore-trigger"
        aria-label="Open Explore"
        aria-controls="exploreDrawer"
        aria-expanded="false">
    <div class="explore-bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
    </div>
</button>

<aside id="exploreDrawer" class="explore-drawer" aria-label="Explore Panel">
    <div class="explore-card">
        <div class="explore-header">
            <div class="explore-title">EXPLORE</div>
            <div class="explore-pill">Quick Find</div>
        </div>

        <div class="explore-search">
            <input id="exploreSearch"
                   type="text"
                   placeholder="Search Explore..."
                   autocomplete="off"
                   aria-label="Search Explore" />
        </div>

        <div id="exploreList" class="explore-list">
            <a class="explore-item" data-tone="protection" asp-controller="ProtectionSnapshot" asp-action="Index">
                <span>Protection Snapshot</span>
                <small>Planning</small>
            </a>

            <a class="explore-item" data-tone="library" asp-controller="Resources" asp-action="Index">
                <span>Resources</span>
                <small>Library</small>
            </a>

            <a class="explore-item" data-tone="growth" asp-controller="Training" asp-action="Index">
                <span>Trainings</span>
                <small>Growth</small>
            </a>
        </div>
    </div>
</aside>

<div id="psalmsModal" class="scripture-modal" aria-hidden="true">
    <div class="scripture-card" role="dialog" aria-modal="true" aria-labelledby="psalmsReference" tabindex="-1">
        <div class="scripture-card-header">
            <div>
                <div class="scripture-day" id="psalmsDay"></div>
                <div class="scripture-reference" id="psalmsReference"></div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="scripture-translation" id="psalmsTranslation"></span>
                <button type="button" class="scripture-close" id="psalmsClose" aria-label="Close scripture dialog">&times;</button>
            </div>
        </div>
        <div class="scripture-streak-row">
            <span class="scripture-streak-label">Streak</span>
            <span class="scripture-streak-value" id="psalmsStreak"></span>
            <span class="scripture-streak-note" id="psalmsStreakNote"></span>
        </div>
        <div class="scripture-text" id="psalmsText"></div>
    </div>
</div>

<div class="container layout-content flex-grow-1">
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="footer mt-auto py-3">
    <div class="container text-center footer-shell">
        <div class="footer-left">
            <div class="footer-support">
                <span class="footer-support-label">Need Support?</span>
                <a href="tel:988">988 Suicide &amp; Crisis Lifeline</a>
                <a href="tel:800-799-7233">Domestic Violence Hotline</a>
                <a href="https://www.samhsa.gov/" target="_blank" rel="noopener">SAMHSA</a>
            </div>
        </div>

        <div class="footer-center">
            <div class="footer-meta">
                <span>&copy; 2025 - MYLEGND, LLC. All rights reserved.</span>
                
                <a href="https://protect.mylegnd.com/Terms" target="_blank" rel="noopener" class="footer-link">Terms</a>
                <span aria-hidden="true">•</span>
                <a href="https://protect.mylegnd.com/Privacy" target="_blank" rel="noopener" class="footer-link">Privacy</a>
            </div>
        </div>

        <div class="footer-right" aria-hidden="true">
            <div class="footer-spacer">&nbsp;</div>
        </div>
    </div>
</footer>

<script src="~/js/number-format.js" asp-append-version="true"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (function () {
        const nav = document.querySelector('.navbar');
        const toggle = document.getElementById('clientNavToggle');
        const navLeft = document.querySelector('.navbar-left');
        const navRight = document.querySelector('.navbar-right');

        if (!nav || !toggle) return;

        function closeNav() {
            nav.classList.remove('mobile-open');
            toggle.setAttribute('aria-expanded', 'false');
            // defensive: ensure nav blocks stay hidden when closed on mobile
            if (window.innerWidth <= 840) {
                if (navLeft) navLeft.style.display = 'none';
                if (navRight) navRight.style.display = 'none';
            } else {
                if (navLeft) navLeft.style.display = '';
                if (navRight) navRight.style.display = '';
            }

            const drawer = document.getElementById('exploreDrawer');
            const overlay = document.getElementById('exploreOverlay');
            const trigger = document.getElementById('exploreTrigger');
            if (drawer) drawer.classList.remove('open');
            if (overlay) overlay.classList.remove('open');
            if (trigger) trigger.setAttribute('aria-expanded', 'false');
        }

        toggle.addEventListener('click', function () {
            const isOpen = nav.classList.toggle('mobile-open');
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            if (window.innerWidth <= 840) {
                if (navLeft) navLeft.style.display = isOpen ? 'block' : 'none';
                if (navRight) navRight.style.display = isOpen ? 'block' : 'none';
            }
        });

        [navLeft, navRight].forEach(group => {
            if (!group) return;
            group.querySelectorAll('a, button:not([data-bs-toggle])').forEach(el => {
                el.addEventListener('click', () => closeNav());
            });
        });

        document.addEventListener('click', function (e) {
            if (!nav.classList.contains('mobile-open')) return;
            if (nav.contains(e.target) || e.target === toggle) return;
            if (e.target.closest('#exploreTrigger, #psalmsModal, .scripture-card')) return;
            closeNav();
        });

        window.addEventListener('resize', function () {
            if (window.innerWidth > 840) closeNav();
        });

        // On first load: ensure closed state on mobile
        closeNav();
    }());
</script>
<script>
    (function () {
        const trigger = document.getElementById('exploreTrigger');
        const drawer = document.getElementById('exploreDrawer');
        const overlay = document.getElementById('exploreOverlay');
        const search = document.getElementById('exploreSearch');
        const list = document.getElementById('exploreList');

        if (!trigger || !drawer || !overlay || !search || !list) return;

        function openDrawer() {
            drawer.classList.add('open');
            overlay.classList.add('open');
            trigger.setAttribute('aria-expanded', 'true');
            window.setTimeout(() => search.focus(), 80);
        }

        function closeDrawer() {
            drawer.classList.remove('open');
            overlay.classList.remove('open');
            trigger.setAttribute('aria-expanded', 'false');
        }

        trigger.addEventListener('click', function () {
            if (drawer.classList.contains('open')) closeDrawer();
            else openDrawer();
        });

        overlay.addEventListener('click', closeDrawer);

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeDrawer();
        });

        search.addEventListener('input', function () {
            const q = (search.value || '').trim().toLowerCase();
            list.querySelectorAll('.explore-item').forEach(function (item) {
                const txt = item.textContent.toLowerCase();
                item.style.display = txt.includes(q) ? '' : 'none';
            });
        });

        // Close drawer when an explore link is selected
        list.querySelectorAll('.explore-item').forEach(function (item) {
            item.addEventListener('click', function () {
                closeDrawer();
            });
        });
    })();
</script>

<script>
    (function () {
        const trigger = document.getElementById('psalmsTrigger');
        const modal = document.getElementById('psalmsModal');
        if (!trigger || !modal) return;

        const textEl = document.getElementById('psalmsText');
        const refEl = document.getElementById('psalmsReference');
        const translationEl = document.getElementById('psalmsTranslation');
        const dayEl = document.getElementById('psalmsDay');
        const closeEl = document.getElementById('psalmsClose');
        const cardEl = modal.querySelector('.scripture-card');
        const streakEl = document.getElementById('psalmsStreak');
        const streakNoteEl = document.getElementById('psalmsStreakNote');

        const chapters = [
            {
                reference: 'Psalm 23',
                translation: 'KJV (public domain fallback)',
                verses: [
                    'The LORD is my shepherd; I shall not want.',
                    'He maketh me to lie down in green pastures: he leadeth me beside the still waters.',
                    'He restoreth my soul: he leadeth me in the paths of righteousness for his name\'s sake.',
                    'Yea, though I walk through the valley of the shadow of death, I will fear no evil: for thou art with me; thy rod and thy staff they comfort me.',
                    'Thou preparest a table before me in the presence of mine enemies: thou anointest my head with oil; my cup runneth over.',
                    'Surely goodness and mercy shall follow me all the days of my life: and I will dwell in the house of the LORD for ever.'
                ]
            },
            {
                reference: 'Psalm 121',
                translation: 'KJV (public domain fallback)',
                verses: [
                    'I will lift up mine eyes unto the hills, from whence cometh my help.',
                    'My help cometh from the LORD, which made heaven and earth.',
                    'He will not suffer thy foot to be moved: he that keepeth thee will not slumber.',
                    'Behold, he that keepeth Israel shall neither slumber nor sleep.',
                    'The LORD is thy keeper: the LORD is thy shade upon thy right hand.',
                    'The sun shall not smite thee by day, nor the moon by night.',
                    'The LORD shall preserve thee from all evil: he shall preserve thy soul.',
                    'The LORD shall preserve thy going out and thy coming in from this time forth, and even for evermore.'
                ]
            },
            {
                reference: 'Psalm 1',
                translation: 'KJV (public domain fallback)',
                verses: [
                    'Blessed is the man that walketh not in the counsel of the ungodly, nor standeth in the way of sinners, nor sitteth in the seat of the scornful.',
                    'But his delight is in the law of the LORD; and in his law doth he meditate day and night.',
                    'And he shall be like a tree planted by the rivers of water, that bringeth forth his fruit in his season; his leaf also shall not wither; and whatsoever he doeth shall prosper.',
                    'The ungodly are not so: but are like the chaff which the wind driveth away.',
                    'Therefore the ungodly shall not stand in the judgment, nor sinners in the congregation of the righteous.',
                    'For the LORD knoweth the way of the righteous: but the way of the ungodly shall perish.'
                ]
            },
            {
                reference: 'Psalm 100',
                translation: 'KJV (public domain fallback)',
                verses: [
                    'Make a joyful noise unto the LORD, all ye lands.',
                    'Serve the LORD with gladness: come before his presence with singing.',
                    'Know ye that the LORD he is God: it is he that hath made us, and not we ourselves; we are his people, and the sheep of his pasture.',
                    'Enter into his gates with thanksgiving, and into his courts with praise: be thankful unto him, and bless his name.',
                    'For the LORD is good; his mercy is everlasting; and his truth endureth to all generations.'
                ]
            }
        ];

        function selectChapter(date) {
            const dayKey = date.toISOString().slice(0, 10);
            let hash = 0;
            for (let i = 0; i < dayKey.length; i++) {
                hash = (hash * 31 + dayKey.charCodeAt(i)) >>> 0;
            }
            const chapter = chapters[hash % chapters.length];
            return { dayKey, chapter };
        }

        function computeStreak(dayKey) {
            const todayTs = Date.parse(dayKey + 'T00:00:00Z');
            let lastDay = null;
            let lastStreak = 0;
            try {
                lastDay = localStorage.getItem('psalmsLastDay');
                const stored = parseInt(localStorage.getItem('psalmsStreak') || '0', 10);
                if (!Number.isNaN(stored)) lastStreak = stored;
            } catch (e) { /* ignore */ }

            let nextStreak = 1;
            if (lastDay) {
                const lastTs = Date.parse(lastDay + 'T00:00:00Z');
                const diffDays = Math.floor((todayTs - lastTs) / 86400000);
                if (diffDays === 0) {
                    nextStreak = Math.max(lastStreak, 1);
                } else if (diffDays === 1) {
                    nextStreak = Math.max(lastStreak, 0) + 1;
                } else {
                    nextStreak = 1;
                }
            }

            try {
                localStorage.setItem('psalmsLastDay', dayKey);
                localStorage.setItem('psalmsStreak', String(nextStreak));
            } catch (e) { /* ignore */ }

            return nextStreak;
        }

        function applyStreakVisual(streak) {
            const hue = Math.min(120, Math.max(0, streak * 6));
            const color = `hsl(${hue}, 76%, 54%)`;
            if (streakEl) {
                streakEl.textContent = `${streak} day${streak === 1 ? '' : 's'}`;
                streakEl.style.color = color;
            }
            if (streakNoteEl) {
                let note = 'Day one — let\'s roll';
                if (streak >= 7) note = 'On fire!';
                else if (streak >= 3) note = 'Keep it going';
                streakNoteEl.textContent = note;
            }
        }

        function openModal() {
            const { dayKey, chapter } = selectChapter(new Date());
            dayEl.textContent = dayKey;
            refEl.textContent = chapter.reference;
            translationEl.textContent = chapter.translation;
            textEl.innerHTML = chapter.verses.map(v => `<p>${v}</p>`).join('');
            const streak = computeStreak(dayKey);
            applyStreakVisual(streak);
            modal.classList.add('open');
            modal.setAttribute('aria-hidden', 'false');
            document.body.classList.add('no-scroll');
            cardEl?.focus({ preventScroll: true });
        }

        function closeModal() {
            modal.classList.remove('open');
            modal.setAttribute('aria-hidden', 'true');
            document.body.classList.remove('no-scroll');
            trigger.focus({ preventScroll: true });
        }

        trigger.addEventListener('click', openModal);
        closeEl?.addEventListener('click', closeModal);
        modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
        });
    })();
</script>
@await RenderSectionAsync("Scripts", required:false)
</body>
</html>

@functions {
    private string ResolveRecordType(ClientProfile profile)
    {
        var raw = profile?.CrmNotes;
        if (string.IsNullOrWhiteSpace(raw)) return "Lead";
        try
        {
            using var doc = JsonDocument.Parse(raw);
            if (doc.RootElement.TryGetProperty("recordType", out var prop) &&
                prop.ValueKind == JsonValueKind.String)
            {
                var value = (prop.GetString() ?? "").Trim();
                if (value.Equals("Business Client", StringComparison.OrdinalIgnoreCase))
                    return "BusinessClient";
                if (value.Equals("BusinessClient", StringComparison.OrdinalIgnoreCase) ||
                    value.Equals("Client", StringComparison.OrdinalIgnoreCase) ||
                    value.Equals("Lead", StringComparison.OrdinalIgnoreCase))
                    return value;
            }
        }
        catch { /* ignore parse errors */ }
        return "Lead";
    }
}
