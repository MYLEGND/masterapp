<script>
    (function () {
        const nav = document.querySelector('.navbar');
        const toggle = document.getElementById('clientNavToggle');
        const navLeft = document.querySelector('.navbar-left');
        const navRight = document.querySelector('.navbar-right');

        if (!nav || !toggle) return;

        function closeNav() {
            nav.classList.remove('mobile-open');
            toggle.setAttribute('aria-expanded', 'false');
            // defensive: ensure nav blocks stay hidden when closed on mobile
            if (window.innerWidth <= 840) {
                if (navLeft) navLeft.style.display = 'none';
                if (navRight) navRight.style.display = 'none';
            } else {
                if (navLeft) navLeft.style.display = '';
                if (navRight) navRight.style.display = '';
            }
        }

        toggle.addEventListener('click', function () {
            const isOpen = nav.classList.toggle('mobile-open');
            toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            if (window.innerWidth <= 840) {
                if (navLeft) navLeft.style.display = isOpen ? 'block' : 'none';
                if (navRight) navRight.style.display = isOpen ? 'block' : 'none';
            }
        });

        [navLeft, navRight].forEach(group => {
            if (!group) return;
            group.querySelectorAll('a, button:not([data-bs-toggle])').forEach(el => {
                el.addEventListener('click', () => closeNav());
            });
        });

        document.addEventListener('click', function (e) {
            if (!nav.classList.contains('mobile-open')) return;
            if (nav.contains(e.target) || e.target === toggle) return;
            if (e.target.closest('#exploreTrigger, #psalmsModal, .scripture-card')) return;
            closeNav();
        });

        window.addEventListener('resize', function () {
            if (window.innerWidth > 840) closeNav();
        });

        // On first load: ensure closed state on mobile
        closeNav();
    }());
</script>
<script>
    (function () {
        const trigger = document.getElementById('exploreTrigger');
        const drawer = document.getElementById('exploreDrawer');
        const overlay = document.getElementById('exploreOverlay');
        const search = document.getElementById('exploreSearch');
        const list = document.getElementById('exploreList');

        if (!trigger || !drawer || !overlay || !search || !list) return;

        function openDrawer() {
            drawer.classList.add('open');
            overlay.classList.add('open');
            trigger.setAttribute('aria-expanded', 'true');
            window.setTimeout(() => search.focus(), 80);
        }

        function closeDrawer() {
            drawer.classList.remove('open');
            overlay.classList.remove('open');
            trigger.setAttribute('aria-expanded', 'false');
        }

        trigger.addEventListener('click', function () {
            if (drawer.classList.contains('open')) closeDrawer();
            else openDrawer();
        });

        overlay.addEventListener('click', closeDrawer);

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeDrawer();
        });

        search.addEventListener('input', function () {
            const q = (search.value || '').trim().toLowerCase();
            list.querySelectorAll('.explore-item').forEach(function (item) {
                const txt = item.textContent.toLowerCase();
                item.style.display = txt.includes(q) ? '' : 'none';
            });
        });
    })();
</script>

