@model ClientApp.Models.ResourcesIndexViewModel

@{
    ViewData["Title"] = "Resources";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="resources-page container py-4">

    <div class="resources-hero mb-4">
        <div class="hero-kicker">Legend™ Education</div>
        <h1 class="hero-title m-0">@ViewData["Title"]</h1>
        <p class="hero-sub m-0 mt-2">
            Keep your policy documents close, review educational material quickly, and access important support information in one place.
        </p>
    </div>

    @if (TempData["ResourceUploadSuccess"] is string successMessage)
    {
        <div class="resource-alert resource-alert-success mb-4" role="status">@successMessage</div>
    }

    @if (TempData["ResourceUploadError"] is string errorMessage)
    {
        <div class="resource-alert resource-alert-error mb-4" role="alert">@errorMessage</div>
    }

    <section class="priority-card mb-4">
        <div class="priority-head">
            <div>
                <div class="info-kicker">Policy Vault</div>
                <h2 class="info-title mb-1">Your policy document library</h2>
                <p class="info-copy mb-0">Upload by policy type, keep files grouped by year, and filter the vault instantly by selected policy type.</p>
            </div>
        </div>

        <div class="policy-layout">
            <div class="policy-upload-panel">
                <div class="policy-family-list">
                    @foreach (var family in Model.PolicyTypeFamilies)
                    {
                        <details class="policy-family" open>
                            <summary>@family.Family</summary>
                            <div class="policy-type-lanes">
                                @foreach (var policyType in family.Types)
                                {
                                    <button type="button" class="policy-type-lane" data-pick-policy-type="@policyType">@policyType</button>
                                }
                            </div>
                        </details>
                    }
                </div>

                <form asp-controller="Resources" asp-action="UploadPolicyDocuments" method="post" enctype="multipart/form-data" id="policyUploadForm">
                    @Html.AntiForgeryToken()

                    <div class="policy-form-grid">
                        <label>
                            <span class="control-label">Policy year</span>
                            <input type="number" class="form-control premium-field" name="policyYear" min="2000" max="2100" value="@DateTime.UtcNow.Year" required />
                        </label>
                        <label>
                            <span class="control-label">Policy type</span>
                            <select id="policyTypeSelect" class="form-select premium-field" name="policyType" required>
                                @foreach (var family in Model.PolicyTypeFamilies)
                                {
                                    <optgroup label="@family.Family">
                                        @foreach (var policyType in family.Types)
                                        {
                                            <option value="@policyType">@policyType</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                        </label>
                        <label class="policy-display-name-wrap">
                            <span class="control-label">Display name</span>
                            <input id="policyDisplayName" class="form-control premium-field" type="text" name="displayName" maxlength="140" required value="@(Model.PolicyTypeFamilies.SelectMany(f => f.Types).FirstOrDefault() ?? "Policy Document")" />
                        </label>
                    </div>

                    <input id="policyFileInput" name="file" type="file" accept=".pdf,.png,.jpg,.jpeg" hidden required />

                    <div id="policyDropzone" class="policy-dropzone" tabindex="0" role="button" aria-label="Upload policy documents">
                        <div class="policy-dropzone-title">Drop policy file here</div>
                        <div class="policy-dropzone-copy">or click to browse your device</div>
                        <div id="policyUploadState" class="policy-dropzone-state">Accepted file types: PDF, PNG, JPG, JPEG</div>
                    </div>

                    <div id="policySelectedFiles" class="selected-files" hidden></div>

                    <div class="upload-actions">
                        <button type="submit" id="policyUploadButton" class="preview-open upload-submit">Upload policy</button>
                    </div>
                </form>
            </div>

            <div class="policy-library-panel">
                <div class="policy-library-head">
                    <h3 class="policy-library-title m-0">Yearly vault</h3>
                    <span class="policy-library-count">@Model.PolicyDocuments.Count file@(Model.PolicyDocuments.Count == 1 ? string.Empty : "s")</span>
                </div>

                @if (Model.PolicyDocuments.Count == 0)
                {
                    <div class="policy-empty-state">No policy documents have been uploaded yet.</div>
                }
                else
                {
                    var yearGroups = Model.PolicyDocuments
                        .OrderByDescending(x => x.PolicyYear)
                        .ThenByDescending(x => x.UploadedUtc)
                        .GroupBy(x => x.PolicyYear)
                        .ToList();

                    <div class="policy-vault-year-groups">
                        @foreach (var group in yearGroups)
                        {
                            <details class="policy-year-group" open="@(group.Key == yearGroups.First().Key)">
                                <summary>
                                    <span>@group.Key</span>
                                    <small>@group.Count() file@(group.Count() == 1 ? string.Empty : "s")</small>
                                </summary>

                                <div class="policy-list">
                                    @foreach (var document in group)
                                    {
                                        <div class="policy-item" data-policy-type="@document.PolicyType">
                                            <button type="button"
                                                    class="policy-preview-trigger"
                                                    data-name="@document.DisplayName"
                                                    data-extension="@document.Extension"
                                                    data-preview-url="@document.PreviewUrl"
                                                    data-download-url="@document.DownloadUrl"
                                                    data-meta="@document.PolicyFamily • @document.PolicyType • @document.Extension.TrimStart('.').ToUpperInvariant() • @(Math.Max(1, document.SizeBytes / 1024)) KB • Uploaded @document.UploadedUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")">
                                                <span class="policy-name">@document.DisplayName</span>
                                                <span class="policy-meta">@document.PolicyFamily • @document.PolicyType • @document.Extension.TrimStart('.').ToUpperInvariant() • @(Math.Max(1, document.SizeBytes / 1024)) KB • Uploaded @document.UploadedUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                                            </button>

                                            <div class="policy-actions">
                                                <a class="policy-action-link" href="@document.PreviewUrl" target="_blank" rel="noopener">View</a>
                                                <a class="policy-action-link" href="@document.DownloadUrl">Download</a>
                                                <form asp-controller="Resources" asp-action="DeletePolicyDocument" method="post" class="policy-delete-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="fileName" value="@document.FileName" />
                                                    <button type="submit" class="policy-delete-button">Delete</button>
                                                </form>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </details>
                        }
                    </div>

                    <div id="policyNoMatch" class="policy-empty-state" hidden>No policy documents found for this policy type.</div>
                }
            </div>
        </div>
    </section>

    <section class="controls-card mb-4">
        <div class="controls-head">
            <div>
                <div class="info-kicker">Education Library</div>
                <h2 class="info-title mb-1">Browse educational resources</h2>
                <p class="info-copy mb-0">Search or select a resource and preview it below without leaving the page.</p>
            </div>
        </div>

        <div class="row g-3 align-items-start">
            <div class="col-12 col-lg-6">
                <label class="control-label">Browse Resources</label>
                <select id="resourceDropdown" class="form-select premium-field">
                    <option value="">Select a resource…</option>
                    @foreach (var r in Model.Resources)
                    {
                        <option value="@r.File">@r.Name</option>
                    }
                </select>
                <div class="control-help">Choose a file to preview below.</div>
            </div>

            <div class="col-12 col-lg-6">
                <label class="control-label">Search Resources</label>
                <div class="search-wrap">
                    <span class="search-icon">⌕</span>
                    <input id="resourceSearch" type="text" class="form-control premium-field premium-input" placeholder="Search by name…" />
                </div>
                <ul id="searchResults" class="search-results" style="display:none;"></ul>
                <div class="control-help">Type to filter resources instantly.</div>
            </div>
        </div>
    </section>

    <div id="resourceContainer" class="preview-shell mb-4" style="display:none;">
        <div class="preview-head">
            <div>
                <h2 id="resourceTitle" class="preview-title m-0"></h2>
                <div id="resourceMeta" class="preview-meta"></div>
            </div>

            <div class="preview-actions">
                <a id="resourceDownload" class="preview-open preview-download" href="#" style="display:none;">Download</a>
                <a id="resourceOpen" class="preview-open" href="#" target="_blank" rel="noopener">Open in new tab →</a>
            </div>
        </div>

        <div class="preview-frame">
            <div id="resourceContent" class="preview-content"></div>
        </div>
    </div>

    <div id="emptyState" class="empty-state mb-4">
        <div class="empty-chip">Preview</div>
        <div class="empty-title">Select a policy document or resource to view it here</div>
        <div class="empty-text">Use the policy vault above or the educational resource tools below. Supported documents will open directly in this preview area.</div>
    </div>

    <div class="resource-grid">
        <section class="info-card">
            <div class="info-kicker">Support Resources</div>
            <h2 class="info-title">Immediate support when you need it</h2>
            <div class="support-list">
                <a class="support-item" href="tel:988">988 Suicide &amp; Crisis Lifeline <span>Call or text 988</span></a>
                <a class="support-item" href="tel:800-799-7233">National Domestic Violence Hotline <span>Call 800-799-7233</span></a>
                <a class="support-item" href="https://www.samhsa.gov/" target="_blank" rel="noopener">SAMHSA <span>Visit samhsa.gov</span></a>
            </div>
        </section>

        <section class="info-card">
            <div class="info-kicker">Life Planning Topics</div>
            <h2 class="info-title">Priority planning areas</h2>
            <div class="topic-grid">
                <div class="topic-chip">Legal Risk</div>
                <div class="topic-chip">Health Risk</div>
                <div class="topic-chip">Life Risk</div>
                <div class="topic-chip">Legacy Transfer</div>
            </div>
            <p class="info-copy mb-0">Review these areas regularly alongside your policy documents and educational materials so decisions stay coordinated and easy to revisit.</p>
        </section>
    </div>

</div>

<style>
:root{
    --gold:#c99b36;
    --gold2:#b68525;
    --gold3:#f0cf78;
    --goldSoft:rgba(201,155,54,.16);
    --ink:#e9f0ff;
    --muted:rgba(226,236,255,.78);
    --line:rgba(201,155,54,.42);
    --bg:#091427;
    --panel:#0f1f3b;
    --panel-2:#0b1a33;
    --shadow:0 24px 58px rgba(3,8,18,.45);
    --shadowSoft:0 14px 34px rgba(3,8,18,.34);
    --r18:18px;
}

.resources-page{
    background:
        radial-gradient(1200px 420px at 0% 0%, rgba(201,155,54,.12), transparent 58%),
        radial-gradient(900px 320px at 100% 0%, rgba(102,124,168,.12), transparent 56%),
        var(--bg);
    color:var(--ink);
    border-radius:18px;
    padding:12px;
}

.resources-hero,
.priority-card,
.controls-card,
.info-card,
.preview-shell{
    border:1px solid var(--line);
    border-radius:var(--r18);
    background:linear-gradient(180deg,#10213f,#0b1a33);
    box-shadow:var(--shadow);
    position:relative;
    overflow:hidden;
}

.resources-hero::before,
.priority-card::before,
.controls-card::before,
.info-card::before,
.preview-shell::before{
    content:"";
    position:absolute;
    left:0; right:0; top:0;
    height:4px;
    background:linear-gradient(90deg,var(--gold2),var(--gold3),var(--gold2));
}

.resources-hero{
    padding:22px 20px 20px;
    background:
        radial-gradient(1200px 420px at 12% 0%, rgba(240,207,120,.18), transparent 58%),
        radial-gradient(1000px 320px at 100% 0%, rgba(84,115,176,.14), transparent 56%),
        linear-gradient(180deg,#132747,#0d1f3c);
}

.hero-kicker,
.info-kicker,
.empty-chip{
    display:inline-block;
    font-weight:900;
    letter-spacing:.12em;
    text-transform:uppercase;
    font-size:.74rem;
    color:#f3d995;
}

.hero-title,
.info-title,
.preview-title,
.policy-library-title,
.policy-name,
.control-label,
.policy-year-group > summary span{
    color:var(--gold3);
    font-weight:900;
}

.hero-title{
    margin-top:10px !important;
    font-size:clamp(1.9rem,3vw,2.45rem);
    line-height:1.08;
    text-shadow:0 1px 0 rgba(34,23,5,.8);
}

.hero-sub,
.info-copy,
.control-help,
.preview-meta,
.empty-text,
.policy-dropzone-copy,
.policy-dropzone-state,
.policy-meta,
.policy-library-count,
.policy-empty-state,
.support-item span{
    color:var(--muted);
    line-height:1.7;
}

.priority-card,
.controls-card,
.info-card{ padding:20px 18px 18px; }

.priority-head,
.controls-head{ margin-bottom:16px; }

.policy-layout,
.resource-grid{
    display:grid;
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:18px;
}

.policy-family-list{
    display:grid;
    gap:10px;
    margin-bottom:14px;
    max-height:300px;
    overflow:auto;
    padding-right:2px;
}

.policy-family{
    border:1px solid var(--line);
    border-radius:12px;
    background:linear-gradient(180deg,rgba(15,31,57,.92),rgba(10,22,43,.92));
}

.policy-family > summary{
    list-style:none;
    cursor:pointer;
    padding:9px 10px;
    color:var(--gold3);
    font-weight:900;
}

.policy-family > summary::-webkit-details-marker{ display:none; }

.policy-type-lanes{ padding:0 8px 8px; display:grid; gap:7px; }

.policy-type-lane{
    text-align:left;
    border:1px solid rgba(201,155,54,.36);
    border-radius:10px;
    background:linear-gradient(180deg,#182f55,#102544);
    color:#eef4ff;
    font-weight:850;
    font-size:.82rem;
    padding:8px 10px;
}

.policy-type-lane:hover,
.policy-type-lane.active{
    border-color:rgba(240,207,120,.72);
    background:linear-gradient(180deg,#204171,#16335a);
    color:#f8df9a;
}

.policy-form-grid{ display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:12px; }
.policy-display-name-wrap{ grid-column:1/-1; }

.policy-dropzone{
    border:1.5px dashed rgba(201,155,54,.62);
    border-radius:16px;
    padding:28px 18px;
    background:
        radial-gradient(700px 180px at 50% 0%, rgba(240,207,120,.16), transparent 60%),
        linear-gradient(180deg, rgba(36,67,112,.24), rgba(15,30,55,.32));
    text-align:center;
    cursor:pointer;
    transition:border-color .15s ease, background .15s ease, transform .12s ease;
}

.policy-dropzone:hover,
.policy-dropzone:focus{
    border-color:rgba(240,207,120,.86);
    background:rgba(201,155,54,.14);
    transform:translateY(-1px);
    outline:none;
}

.policy-dropzone.is-dragover{ border-color:rgba(240,207,120,.92); }
.policy-dropzone.is-uploading{ opacity:.72; pointer-events:none; }
.policy-dropzone-title{ font-weight:950; color:var(--gold3); font-size:1.08rem; }

.selected-files{ margin-top:14px; display:grid; gap:8px; }

.selected-file{
    padding:10px 12px;
    border-radius:12px;
    background:rgba(255,255,255,.10);
    border:1px solid var(--line);
    color:#e9f1ff;
    font-weight:800;
}

.upload-actions{ margin-top:14px; display:flex; justify-content:flex-end; }

.policy-library-head{ display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }

.policy-vault-year-groups{ display:grid; gap:10px; }

.policy-year-group{
    border:1px solid rgba(201,155,54,.32);
    border-radius:12px;
    background:rgba(8,20,39,.62);
    overflow:hidden;
}

.policy-year-group > summary{
    list-style:none;
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding:10px 12px;
    cursor:pointer;
    font-weight:950;
}

.policy-year-group > summary::-webkit-details-marker{ display:none; }
.policy-year-group > summary small{ color:#d7bd7a; font-size:.76rem; font-weight:800; }

.policy-list{ padding:0 10px 10px; display:grid; gap:9px; }

.policy-item{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:14px;
    padding:14px;
    border:1px solid rgba(201,155,54,.34);
    border-radius:16px;
    background:linear-gradient(180deg, rgba(20,39,70,.95), rgba(13,29,54,.95));
    box-shadow:inset 0 1px 0 rgba(255,255,255,.08);
}

.policy-preview-trigger{ flex:1; background:transparent; border:0; padding:0; text-align:left; }
.policy-preview-trigger:hover .policy-name,
.policy-preview-trigger:focus .policy-name{ color:#ffe4a0; }

.policy-actions{ display:flex; flex-wrap:wrap; gap:8px; justify-content:flex-end; }
.policy-delete-form{ margin:0; }

.preview-open,
.policy-action-link,
.policy-delete-button{
    text-decoration:none;
    font-weight:900;
    padding:10px 12px;
    border-radius:999px;
    transition:transform .12s ease, filter .15s ease;
}

.preview-open,
.policy-action-link{
    color:#1e1305;
    border:1px solid rgba(201,155,54,.52);
    background:linear-gradient(180deg,#f8e2a8,#c89a35);
}

.upload-submit,
.preview-download{
    color:#0e0a03;
    border:1px solid rgba(240,207,120,.88);
    background:linear-gradient(180deg,#f3d78f,#c8962f);
}

.policy-delete-button{
    color:#fee2e2;
    border:1px solid #8b2020;
    background:linear-gradient(180deg,#5a1a1a,#3c1111);
}

.preview-open:hover,
.policy-action-link:hover,
.policy-delete-button:hover{ transform:translateY(-1px); filter:brightness(1.05); }

.search-wrap{ position:relative; }
.search-icon{ position:absolute; left:12px; top:50%; transform:translateY(-50%); opacity:.55; font-weight:900; }

.premium-field{
    border:1px solid rgba(201,155,54,.52) !important;
    border-radius:14px !important;
    padding:.75rem .9rem !important;
    background:#f8fbff !important;
}

.premium-field:focus{
    border-color:rgba(240,207,120,.92) !important;
    box-shadow:0 0 0 .22rem rgba(201,155,54,.22) !important;
}

/* Make policy type dropdown unmistakably a dropdown */
#policyTypeSelect{
    appearance:none;
    -webkit-appearance:none;
    -moz-appearance:none;
    padding-right:3rem !important;
    cursor:pointer;
    border:1px solid rgba(201,155,54,.72) !important;
    box-shadow:inset -36px 0 0 rgba(201,155,54,.18), inset 0 1px 0 rgba(255,255,255,.85) !important;
    background-image:
        linear-gradient(45deg, transparent 50%, #8a6518 50%),
        linear-gradient(135deg, #8a6518 50%, transparent 50%);
    background-position:calc(100% - 18px) calc(50% - 2px), calc(100% - 12px) calc(50% - 2px);
    background-size:6px 6px, 6px 6px;
    background-repeat:no-repeat;
}

#policyTypeSelect:focus{
    border-color:rgba(240,207,120,.92) !important;
    box-shadow:0 0 0 .22rem rgba(201,155,54,.22), inset -36px 0 0 rgba(201,155,54,.24) !important;
}

.premium-input{ padding-left:36px !important; }

.search-results{
    margin:10px 0 0;
    padding:6px;
    list-style:none;
    border-radius:16px;
    border:1px solid var(--line);
    background:rgba(9,21,39,.96);
    max-height:280px;
    overflow-y:auto;
    box-shadow:var(--shadowSoft);
}

.search-results li{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    padding:10px;
    border-radius:12px;
    cursor:pointer;
    color:#edf3ff;
}

.search-results li:hover{ background:rgba(201,155,54,.16); }

.result-tag,
.topic-chip{
    border:1px solid rgba(201,155,54,.35);
    color:#f0cf78;
    background:rgba(15,31,57,.90);
}

.result-tag{ font-size:.76rem; font-weight:950; padding:4px 8px; border-radius:999px; }

.preview-shell{ overflow:hidden; }

.preview-head{
    padding:16px 18px;
    border-bottom:1px solid var(--line);
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:12px;
    background:linear-gradient(180deg, rgba(201,155,54,.18), rgba(18,40,73,.16) 62%, transparent 100%);
}

.preview-actions{ display:flex; flex-wrap:wrap; gap:8px; justify-content:flex-end; }
.preview-frame{ padding:18px; }

.preview-content{
    border-radius:16px;
    border:1px solid var(--line);
    background:#fff;
    overflow:hidden;
}

.preview-content img,
.preview-content video,
.preview-content iframe{ width:100%; display:block; border:0; }

.preview-content iframe{ height:min(82vh,980px); }

.empty-state{
    padding:22px 18px;
    border:1px dashed rgba(201,155,54,.48);
    border-radius:var(--r18);
    background:rgba(17,36,65,.68);
}

.support-list{ display:grid; gap:12px; }

.support-item{
    display:flex;
    flex-direction:column;
    gap:4px;
    padding:12px 14px;
    border:1px solid var(--line);
    border-radius:14px;
    text-decoration:none;
    background:linear-gradient(180deg, rgba(17,35,64,.94), rgba(11,25,46,.94));
    color:#f0cf78;
}

.topic-grid{ display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:10px; margin:8px 0 14px; }
.topic-chip{ padding:10px 12px; border-radius:999px; font-weight:900; text-align:center; }

.resource-alert{ padding:12px 14px; border-radius:14px; font-weight:800; border:1px solid transparent; }

.resource-alert-success{
    background:rgba(10,87,44,.36);
    border-color:rgba(52,211,153,.42);
    color:#bbf7d0;
}

.resource-alert-error{
    background:rgba(127,29,29,.36);
    border-color:rgba(248,113,113,.42);
    color:#fecaca;
}

@@media (max-width: 991.98px){
    .policy-layout,
    .resource-grid{ grid-template-columns:1fr; }

    .policy-form-grid{ grid-template-columns:1fr; }
    .topic-grid{ grid-template-columns:1fr; }
}

@@media (max-width: 767.98px){
    .policy-item,
    .preview-head{ flex-direction:column; }

    .policy-actions,
    .preview-actions,
    .upload-actions{ width:100%; justify-content:stretch; }

    .policy-action-link,
    .policy-delete-button,
    .upload-submit,
    .preview-open{ width:100%; text-align:center; display:block; }
}
</style>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {
    const resources = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Resources));
    const dropdown = document.getElementById("resourceDropdown");
    const searchInput = document.getElementById("resourceSearch");
    const searchResults = document.getElementById("searchResults");
    const fileInput = document.getElementById("policyFileInput");
    const dropzone = document.getElementById("policyDropzone");
    const selectedFiles = document.getElementById("policySelectedFiles");
    const uploadState = document.getElementById("policyUploadState");
    const uploadForm = document.getElementById("policyUploadForm");
    const uploadButton = document.getElementById("policyUploadButton");
    const policyTypeSelect = document.getElementById("policyTypeSelect");
    const policyDisplayName = document.getElementById("policyDisplayName");
    const policyTypeLanes = Array.from(document.querySelectorAll("[data-pick-policy-type]"));
    const policyItems = Array.from(document.querySelectorAll(".policy-item"));
    const policyYearGroups = Array.from(document.querySelectorAll(".policy-year-group"));
    const policyNoMatch = document.getElementById("policyNoMatch");
    const container = document.getElementById("resourceContainer");
    const emptyState = document.getElementById("emptyState");
    const title = document.getElementById("resourceTitle");
    const meta = document.getElementById("resourceMeta");
    const openLink = document.getElementById("resourceOpen");
    const downloadLink = document.getElementById("resourceDownload");
    const content = document.getElementById("resourceContent");
    const policyTriggers = document.querySelectorAll(".policy-preview-trigger");
    const allowedTypes = [".pdf", ".png", ".jpg", ".jpeg"];
    let autoNameSeed = policyTypeSelect ? (policyTypeSelect.value || "") : "";

    function setActivePolicyLane(type) {
        policyTypeLanes.forEach(lane => lane.classList.toggle("active", lane.getAttribute("data-pick-policy-type") === type));
    }

    function applyPolicyTypeFilter(type) {
        if (!policyItems.length) return;

        let visibleItems = 0;
        policyYearGroups.forEach(group => {
            const items = Array.from(group.querySelectorAll(".policy-item"));
            let yearVisible = 0;

            items.forEach(item => {
                const match = !type || item.getAttribute("data-policy-type") === type;
                item.hidden = !match;
                if (match) {
                    yearVisible++;
                    visibleItems++;
                }
            });

            const countEl = group.querySelector("summary small");
            if (countEl) {
                countEl.textContent = `${yearVisible} file${yearVisible === 1 ? "" : "s"}`;
            }
            group.hidden = yearVisible === 0;
        });

        if (policyNoMatch) {
            policyNoMatch.hidden = visibleItems > 0;
        }
    }

    function applyDefaultDisplayNameFromPolicyType() {
        if (!policyTypeSelect || !policyDisplayName) return;
        const current = (policyDisplayName.value || "").trim();
        const next = (policyTypeSelect.value || "").trim();
        if (!current || current === autoNameSeed) {
            policyDisplayName.value = next;
        }
        autoNameSeed = next;
    }

    function extTag(ext) {
        if (!ext) return "FILE";
        return ext.replace(".", "").toUpperCase();
    }

    function renderEmbeddedDocument(name, extension, viewUrl, metaText, downloadUrl) {
        emptyState.style.display = "none";
        container.style.display = "block";

        title.textContent = name;
        meta.textContent = metaText || `Type: ${extTag(extension)}`;
        openLink.href = viewUrl;

        if (downloadUrl) {
            downloadLink.style.display = "inline-flex";
            downloadLink.href = downloadUrl;
        } else {
            downloadLink.style.display = "none";
            downloadLink.removeAttribute("href");
        }

        const ext = (extension || "").toLowerCase();
        let body = "";

        if (ext === ".pdf") {
            body = `<iframe src="${viewUrl}" loading="lazy"></iframe>`;
        } else if ([".png", ".jpg", ".jpeg", ".webp"].includes(ext)) {
            body = `<img src="${viewUrl}" alt="${name}" loading="lazy" />`;
        } else if (ext === ".mp4") {
            body = `<video controls preload="metadata"><source src="${viewUrl}" type="video/mp4"></video>`;
        } else {
            body = `<div style="padding:18px;"><a class="preview-open" href="${viewUrl}" target="_blank" rel="noopener">Open ${name} →</a></div>`;
        }

        content.innerHTML = body;
    }

    function renderResource(resource) {
        const url = `/resources/${resource.File}`;
        renderEmbeddedDocument(resource.Name, resource.Extension, url, `Type: ${extTag(resource.Extension)} • File: ${resource.File}`);
    }

    function renderSelectedFiles(files) {
        const entries = Array.from(files || []);

        if (entries.length === 0) {
            selectedFiles.hidden = true;
            selectedFiles.innerHTML = "";
            uploadState.textContent = "Accepted file types: PDF, PNG, JPG, JPEG";
            dropzone.classList.remove("is-error");
            return;
        }

        selectedFiles.hidden = false;
        selectedFiles.innerHTML = entries.map(file => `<div class="selected-file">${file.name}</div>`).join("");

        const invalid = entries.some(file => {
            const name = (file.name || "").toLowerCase();
            return !allowedTypes.some(ext => name.endsWith(ext));
        });

        if (invalid) {
            uploadState.textContent = "One or more files have an unsupported file type.";
            dropzone.classList.add("is-error");
            return;
        }

        dropzone.classList.remove("is-error");
        uploadState.textContent = `${entries.length} file${entries.length === 1 ? "" : "s"} ready to upload`;
    }

    dropdown.addEventListener("change", function () {
        const file = this.value;
        searchInput.value = "";
        searchResults.innerHTML = "";
        searchResults.style.display = "none";

        if (!file) {
            container.style.display = "none";
            emptyState.style.display = "block";
            return;
        }

        const resource = resources.find(x => x.File === file);
        if (resource) renderResource(resource);
    });

    searchInput.addEventListener("input", function () {
        const q = (this.value || "").trim().toLowerCase();
        searchResults.innerHTML = "";

        if (!q) {
            searchResults.style.display = "none";
            return;
        }

        const matches = resources.filter(r => (r.Name || "").toLowerCase().includes(q)).slice(0, 30);

        if (matches.length === 0) {
            searchResults.style.display = "block";
            searchResults.innerHTML = `<li style="padding:12px 10px; opacity:.7;">No matches found.</li>`;
            return;
        }

        matches.forEach(resource => {
            const li = document.createElement("li");
            const left = document.createElement("div");
            left.className = "result-name";
            left.textContent = resource.Name;

            const right = document.createElement("div");
            right.className = "result-tag";
            right.textContent = extTag((resource.Extension || "").toLowerCase());

            li.appendChild(left);
            li.appendChild(right);
            li.onclick = () => {
                renderResource(resource);
                dropdown.value = resource.File;
                searchResults.innerHTML = "";
                searchResults.style.display = "none";
            };
            searchResults.appendChild(li);
        });

        searchResults.style.display = "block";
    });

    document.addEventListener("click", (e) => {
        const clickedInside = searchResults.contains(e.target) || searchInput.contains(e.target);
        if (!clickedInside) {
            searchResults.style.display = "none";
        }
    });

    policyTriggers.forEach(trigger => {
        trigger.addEventListener("click", function () {
            renderEmbeddedDocument(
                this.dataset.name,
                this.dataset.extension,
                this.dataset.previewUrl,
                this.dataset.meta,
                this.dataset.downloadUrl);
        });
    });

    policyTypeLanes.forEach(btn => {
        btn.addEventListener("click", () => {
            const type = btn.getAttribute("data-pick-policy-type") || "";
            if (policyTypeSelect) {
                policyTypeSelect.value = type;
                applyDefaultDisplayNameFromPolicyType();
            }
            setActivePolicyLane(type);
            applyPolicyTypeFilter(type);
        });
    });

    if (policyTypeSelect) {
        policyTypeSelect.addEventListener("change", () => {
            applyDefaultDisplayNameFromPolicyType();
            setActivePolicyLane(policyTypeSelect.value);
            applyPolicyTypeFilter(policyTypeSelect.value);
        });

        applyDefaultDisplayNameFromPolicyType();
        setActivePolicyLane(policyTypeSelect.value);
        applyPolicyTypeFilter(policyTypeSelect.value);
    }

    if (dropzone && fileInput) {
        dropzone.addEventListener("click", () => fileInput.click());
        dropzone.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
                e.preventDefault();
                fileInput.click();
            }
        });

        ["dragenter", "dragover"].forEach(eventName => {
            dropzone.addEventListener(eventName, (e) => {
                e.preventDefault();
                dropzone.classList.add("is-dragover");
            });
        });

        ["dragleave", "drop"].forEach(eventName => {
            dropzone.addEventListener(eventName, (e) => {
                e.preventDefault();
                dropzone.classList.remove("is-dragover");
            });
        });

        dropzone.addEventListener("drop", (e) => {
            if (!e.dataTransfer || !e.dataTransfer.files) return;
            const dt = new DataTransfer();
            const first = e.dataTransfer.files[0];
            if (first) dt.items.add(first);
            fileInput.files = dt.files;
            renderSelectedFiles(fileInput.files);
        });

        fileInput.addEventListener("change", () => renderSelectedFiles(fileInput.files));
    }

    if (uploadForm) {
        uploadForm.addEventListener("submit", (e) => {
            if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
                e.preventDefault();
                uploadState.textContent = "Choose one file before uploading.";
                dropzone.classList.add("is-error");
                return;
            }

            const invalid = Array.from(fileInput.files).some(file => {
                const lower = (file.name || "").toLowerCase();
                return !allowedTypes.some(ext => lower.endsWith(ext));
            });

            if (invalid) {
                e.preventDefault();
                uploadState.textContent = "Only PDF, PNG, JPG, and JPEG files can be uploaded.";
                dropzone.classList.add("is-error");
                return;
            }

            dropzone.classList.remove("is-error");
            dropzone.classList.add("is-uploading");
            uploadState.textContent = "Uploading documents...";

            if (uploadButton) {
                uploadButton.textContent = "Uploading...";
                uploadButton.setAttribute("disabled", "disabled");
            }
        });
    }
});
</script>
}