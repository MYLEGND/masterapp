@{
    ViewData["Title"] = "Finance";
}

<div class="container d-flex flex-column align-items-center mt-5">

    <!-- Tool selection dropdown -->
    <div class="col-lg-6 mb-4 text-center">
        <label for="budgetDropdown" class="form-label fw-bold" style="font-size:1.2rem; color:#a68023;">
            Select a Tool
        </label>
        <select id="budgetDropdown" class="form-select mx-auto shadow-sm" 
                style="max-width:400px; border:2px solid #a68023; font-weight:600;">
            <option value="">-- Select a tool --</option>
        </select>
    </div>

    <!-- Main tools layout -->
    <div class="d-flex justify-content-center align-items-start w-100 mt-3" style="gap:20px;">

        <!-- Left tool: Action Tracker -->
        <div class="finance-action-container border border-2 border-dark p-3"
             style="width:30%; min-width:300px; max-width:400px; display:flex; flex-direction:column; 
                    height:auto; max-height:calc(100vh - 200px); overflow-y:auto; margin-top:0;">
        </div>

        <!-- Middle tool (main tool stays untouched) -->
        <div id="budget-embed" class="flex-shrink-0" style="max-width:700px;"></div>

       <!-- Right tool: Alerts (formerly Goals / Future Tool) -->
    <div class="finance-goals-container">

</div>

    </div>

</div>

<!-- JS references -->
<script src="~/js/finance-tools.js"></script>
<script src="~/js/goals.js"></script>
<script src="~/js/alerts.js"></script>

<style>
/* Premium gold theme for middle tool */
#budget-embed .networth-tool {
    border: 2px solid #a68023;
    border-radius: 12px;
    padding: 20px;
    background: linear-gradient(90deg, #f5f5f5, #f5f5f5);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
}

#budget-embed .form-control,
#budget-embed .form-label {
    color: #333;
}

#budget-embed table {
    border-radius: 8px;
    overflow: hidden;
}

#budget-embed table th {
    background-color: #a68023;
    color: #5a3b00;
    font-weight:700;
}

#budget-embed table td {
    font-weight:600;
    text-align:center;
}

@{
    ViewData["Title"] = "Finance";
}

<div class="container d-flex flex-column align-items-center mt-5">

    <!-- Tool selection dropdown -->
    <div class="col-lg-6 mb-4 text-center">
        <label for="budgetDropdown" class="form-label fw-bold" style="font-size:1.2rem; color:#a68023;">
            Select a Tool
        </label>
        <select id="budgetDropdown" class="form-select mx-auto shadow-sm" style="max-width:400px; border:2px solid #a68023; font-weight:600;">
            <option value="">-- Select a tool --</option>
        </select>
    </div>

    <!-- Main tools layout -->
    <div class="d-flex justify-content-center align-items-start w-100 mt-3" style="gap:20px;">

        <!-- Left tool: Goals -->
        <div class="finance-action-container border p-3">
            <!-- Content will be injected via Goals.js -->
        </div>

        <!-- Middle tool (main tool stays untouched) -->
        <div id="budget-embed" class="flex-shrink-0" style="max-width:700px;"></div>

        <!-- Right tool: Alerts -->
        <div class="finance-goals-container border p-3">
            <!-- Content will be injected via Alerts.js -->
        </div>

    </div>

</div>

<!-- JS files -->
<script src="~/js/Goals.js"></script>
<script src="~/js/Alerts.js"></script>
<script src="~/js/finance-tools.js"></script>

<style>
/* -------------------------------
   Side Tools (Left: Goals / Right: Alerts)
--------------------------------*/

.finance-action-container,
.finance-goals-container {
    margin-top: 0; /* align with main tool top */
    display: flex;
    flex-direction: column;
    height: 100%; 
    max-height: calc(100vh - 200px); /* prevent touching header/footer */
    overflow-y: auto;
    border: 2px solid #a68023;
    border-radius: 12px;
    padding: 20px;
    background: linear-gradient(135deg, #f9f4e8, #f2e8d1);
    box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    min-width: 300px;
    max-width: 400px;
    width: 35%;
    flex-shrink: 0;
}

/* Spacing between tools */
.finance-action-container { margin-right: 20px; }
.finance-goals-container { margin-left: 20px; }

/* Inner lists scroll nicely */
.finance-action-container #actionContainer,
.finance-goals-container #alertsList {
    flex: 1;
    overflow-y: auto;
}

/* Buttons consistent style */
.finance-action-container button,
.finance-goals-container button {
    transition: all 0.2s ease;
}

.finance-action-container button:hover,
.finance-goals-container button:hover {
    filter: brightness(0.9);
    transform: translateY(-2px);
}

/* Inputs consistent style */
.finance-action-container input,
.finance-goals-container input {
    border-radius: 6px;
    border: 1px solid #d6c48a;
    padding: 6px 8px;
}

/* Gold checkboxes for Goals / Action Tracker */
.finance-action-container .action-done {
    accent-color: #b28f35; /* gold checkmark */
    width: 22px;
    height: 22px;
    cursor: pointer;
}
</style>

