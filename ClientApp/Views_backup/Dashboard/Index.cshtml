            };
        }

        @foreach (var tool in lifeHealthTools)
        {
            <a href="@tool.Url" target="_blank" class="dashboard-tool" data-name="@tool.Name">
                <img src="@Url.Content($"~/images/company-icons/{tool.Icon}")" alt="@tool.Name" />
                <div class="fw-bold text-center mt-1 tool-name">@tool.Name</div>
                <div class="tool-desc">@tool.Desc</div>
            </a>
        }
    </div>
</div>
