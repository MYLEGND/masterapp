        <h1 class="display-4 fw-bold">Legend™ Core Dashboard</h1>
        <p class="lead mb-3">
            Your Gateway to Our Agency Individual Carriers
        </p>
        <hr class="my-3 hero-hr" />
    </div>

    <!-- SEARCH BAR -->
    <div class="text-center mb-5 search-container">
        <input type="text" id="toolSearch" class="search-input" placeholder="Search all tools..." />
        <button id="clearSearch" class="btn-clear-search">Clear Search</button>
        <div id="autocompleteList" class="autocomplete-list"></div>
    </div>

<!-- LIFE & HEALTH -->
<div class="category-container mb-5" data-category="Life & Health">
    <h3 class="text-center mb-4 fw-bold">Life & Health</h3>
    <div class="centered-tools">
        @{
            var lifeHealthTools = new[]
            {
                new { Name = "Lincoln Financial", Url = "https://www.lincolnfinancial.com/secure/producer/newbusinesssubmissiontools", Icon = "lincoln.png", Desc = "Life, Disability, Fast Underwriting, Good Product Flexibility" },
