@model AgentPortal.Models.AssistantWorkspaceViewModel?
@{
    ViewData["Title"] = "Assistant Workspace";
    var fullName = Model?.FullName ?? "Assistant";
    var status = Model?.StatusLabel ?? "Active";
}
<link rel="stylesheet" href="~/css/legend-forms.css" asp-append-version="true" />

<div class="legend-shell">
    <div class="legend-hero">
        <div class="legend-hero-bar"></div>
        <div class="legend-hero-body">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <span class="legend-kicker">Assistant Workspace</span>
                    <h1 class="legend-title">@fullName</h1>
                    <p class="legend-sub">
                        This is your workspace.You see what the agent sees — Leads and Workstation only. 
                        Work the leads. Use the tools. Get results.
                    </p>
                </div>
                <div class="text-end">
                    <div class="badge @(Model?.IsActive ?? true ? "bg-success" : "bg-secondary")" style="font-size:0.9rem;">@status</div>
                    @if (Model != null && Model.HasLoggedIn)
                    {
                        <div class="badge bg-info text-dark" style="font-size:0.85rem; margin-left:4px;">Accepted Invite</div>
                    }
                </div>
            </div>

            <div class="as-grid" style="display:grid;gap:14px;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));margin-top:18px;">
                <a class="as-card legend-section" asp-controller="Leads" asp-action="Index" style="text-decoration:none;color:var(--legend-ink);">
                    <span class="as-card-title" style="font-weight:900;display:block;margin-bottom:4px;">Leads</span>
                    <span class="as-card-copy legend-note">Manage lead pipeline, contact progress, and follow-up updates.</span>
                </a>

                <a class="as-card legend-section" asp-controller="Workstation" asp-action="Index" style="text-decoration:none;color:var(--legend-ink);">
                    <span class="as-card-title" style="font-weight:900;display:block;margin-bottom:4px;">Workstation</span>
                    <span class="as-card-copy legend-note">Access scripts, rebuttals, and active lead workflow tools.</span>
                </a>
            </div>

        </div>
    </div>
</div>
