@using System.Collections.Generic
@model AgentPortal.Models.AdvancedMarketsPageViewModel

@{
    var metaMap = new Dictionary<AgentPortal.Models.StrategyKind,(string title,string tagline)>
    {
        { AgentPortal.Models.StrategyKind.DefinedBenefit, (AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.DefinedBenefit), "Large deductible retirement funding") },
        { AgentPortal.Models.StrategyKind.CashBalance, (AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.CashBalance), "Hybrid DB with pay/interest credits") },
        { AgentPortal.Models.StrategyKind.ComboDb401k, (AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.ComboDb401k), "Layered DB with 401(k)/profit sharing") },
        { AgentPortal.Models.StrategyKind.ExecutiveBonus162, (AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.ExecutiveBonus162), "Executive benefit using life chassis") },
        { AgentPortal.Models.StrategyKind.DeferredComp, (AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.DeferredComp), "Nonqualified deferral — employer credit risk") },
        { AgentPortal.Models.StrategyKind.SplitDollar, (AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.SplitDollar), "Shared premium / collateral structure") },
        { AgentPortal.Models.StrategyKind.TaxDiversification, (AgentPortal.Models.AdvancedMarketsLabels.Display(AgentPortal.Models.StrategyKind.TaxDiversification), "Balance qualified / taxable / tax-free buckets") }
    };
    var chip = metaMap.ContainsKey(Model.Strategy.Selected)
        ? metaMap[Model.Strategy.Selected]
        : (AgentPortal.Models.AdvancedMarketsLabels.Display(Model.Strategy.Selected), "Focused illustration for the chosen strategy.");
}

<form id="ampForm" data-calc-url="@Url.Content("~/Workstation/AdvancedMarkets/Calculate")" novalidate>
    @Html.AntiForgeryToken()
    <input type="hidden" id="ampSelectedStrategy" name="Strategy.Selected" value="@Model.Strategy.Selected" />
    <input type="hidden" id="ampClientUserId" name="ClientUserId" value="" />
    <input type="hidden" id="ampClientProfileId" name="ClientProfileId" value="" />

    <div class="input-topline">
        <div class="selected-strategy-chip">
            <div class="chip-label">Selected strategy</div>
            <div class="chip-title" id="ampSelectedStrategyDisplay">@chip.Item1</div>
            <div class="chip-sub" id="ampSelectedStrategySub">@chip.Item2</div>
        </div>
        <div class="topline-controls">
            <label class="sens-inline">Sensitivity
                @{
                    var sensitivityVal = ViewData.ModelState["Strategy.Sensitivity"]?.AttemptedValue ?? Model.Strategy.Sensitivity;
                }
                <select id="ampSensitivitySelect" name="Strategy.Sensitivity" data-current="@sensitivityVal">
                    <option value="">--Select--</option>
                    <option value="Conservative">Conservative</option>
                    <option value="Base">Base</option>
                    <option value="Optimistic">Optimistic</option>
                </select>
            </label>
            <div class="tiny-note">Illustrative only — not tax/legal/actuarial advice.</div>
        </div>
    </div>

    @await Html.PartialAsync("_AdvancedMarketsInputSections", Model)
</form>
