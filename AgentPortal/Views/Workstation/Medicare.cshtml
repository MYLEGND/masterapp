<div id="toast" class="toast">Copied.</div>

<script>
(function(){
    const shell = document.getElementById('mpShell');
    const card  = document.getElementById('mpCard');
    const search = document.getElementById('mpSearch');
    const toastEl = document.getElementById('toast');

    const btnExpand   = document.getElementById('btnExpand');
    const btnCollapse = document.getElementById('btnCollapse');
    const btnClear    = document.getElementById('btnClear');
    const btnNext     = document.getElementById('btnNext');

    const btnExitFocus = document.getElementById('btnExitFocus');
    const btnNextFocus = document.getElementById('btnNextFocus');

    const sideNav = document.getElementById('sideNav');
    const progDone = document.getElementById('progDone');
    const progTotal = document.getElementById('progTotal');
    const progFill = document.getElementById('progFill');

    if(!shell || !card) return;

    const sections = Array.from(card.querySelectorAll(':scope > details.section'));
    const navStack = [];

    function toast(msg){
        if(!toastEl) return;
        toastEl.textContent = msg || 'Copied.';
        toastEl.classList.add('show');
        setTimeout(()=>toastEl.classList.remove('show'), 1100);
    }

    function signalClass(signal){
        const s = String(signal || '').toLowerCase().trim();
        if(s === 'good' || s === 'warn' || s === 'bad' || s === 'info') return s;
        return 'warn';
    }

    function applySignalClasses(){
        sections.forEach(sec=>{
            sec.classList.remove('good','warn','bad','info');
            sec.classList.add(signalClass(sec.getAttribute('data-signal')));
        });
    }

    function focusSection(id){
        sections.forEach(s => s.classList.remove('is-focus'));
        const target = document.querySelector(id);
        if(!target) return;
        target.classList.add('is-focus');
        target.open = true;
        shell.classList.add('focus-on');
        target.scrollIntoView({ behavior:'smooth', block:'start' });
        updateProgress();
        updateCurrentState();
    }

    function exitFocus(){
        shell.classList.remove('focus-on');
        sections.forEach(s => s.classList.remove('is-focus'));
        updateCurrentState();
    }

    document.querySelectorAll('[data-focus]').forEach(btn=>{
        btn.addEventListener('click', (e)=>{
            e.preventDefault();
            e.stopPropagation();
            focusSection(btn.getAttribute('data-focus'));
        });
    });

    if(btnExitFocus){
        btnExitFocus.addEventListener('click', exitFocus);
    }

    function currentIndex(){
        if(shell.classList.contains('focus-on')){
            const focusIdx = sections.findIndex(s => s.classList.contains('is-focus'));
            return focusIdx >= 0 ? focusIdx : 0;
        }
        const openIdx = sections.findIndex(s => s.open);
        return openIdx >= 0 ? openIdx : 0;
    }

    function nextStep(){
        const idx = currentIndex();
        const next = sections[idx + 1];

        if(!next){
            toast('You’re at the last step.');
            return;
        }

        next.open = true;

        if(shell.classList.contains('focus-on')){
            sections.forEach(s => s.classList.remove('is-focus'));
            next.classList.add('is-focus');
        }

        next.scrollIntoView({ behavior:'smooth', block:'start' });
        updateProgress();
        updateCurrentState();
    }

    if(btnNext) btnNext.addEventListener('click', nextStep);
    if(btnNextFocus) btnNextFocus.addEventListener('click', nextStep);

    if(btnExpand){
        btnExpand.addEventListener('click', ()=>{
            sections.forEach(s => s.open = true);
            updateProgress();
            updateCurrentState();
        });
    }

    if(btnCollapse){
        btnCollapse.addEventListener('click', ()=>{
            sections.forEach(s => s.open = false);

            const aged = document.getElementById('sec-aged');
            if(aged){
                aged.open = true;
                if(shell.classList.contains('focus-on')){
                    sections.forEach(s => s.classList.remove('is-focus'));
                    aged.classList.add('is-focus');
                }
            }

            updateProgress();
            updateCurrentState();
        });
    }

    function getAnchorSection(){
        if(shell.classList.contains('focus-on')){
            return sections.find(s => s.classList.contains('is-focus')) || null;
        }
        return sections.find(s => s.open) || sections[0] || null;
    }

    function goTo(selector, push=true){
        const target = document.querySelector(selector);
        if(!target) return;

        const current = getAnchorSection();
        if(push && current && current.id && ('#' + current.id) !== selector){
            navStack.push('#' + current.id);
        }

        target.open = true;

        if(shell.classList.contains('focus-on')){
            sections.forEach(s => s.classList.remove('is-focus'));
            if(sections.includes(target)){
                target.classList.add('is-focus');
            } else {
                const topParent = target.closest('#mpCard > details.section');
                if(topParent){
                    topParent.classList.add('is-focus');
                    topParent.open = true;
                }
            }
        }

        target.scrollIntoView({ behavior:'smooth', block:'start' });
        updateProgress();
        updateCurrentState();
    }

    document.querySelectorAll('[data-jump]').forEach(btn=>{
        btn.addEventListener('click', (e)=>{
            e.preventDefault();
            e.stopPropagation();
            goTo(btn.getAttribute('data-jump'), true);
        });
    });

    document.querySelectorAll('[data-back]').forEach(btn=>{
        btn.addEventListener('click', (e)=>{
            e.preventDefault();
            e.stopPropagation();
            const prev = navStack.pop();
            if(prev) goTo(prev, false);
            else toast('No previous step.');
        });
    });

    function buildNav(){
        if(!sideNav) return;
        sideNav.innerHTML = '';

        sections.forEach((sec, i)=>{
            const title = sec.querySelector('.title')?.textContent?.trim() || `Step ${i+1}`;
            const sub = sec.querySelector('.sub')?.textContent?.trim() || '';
            const id = sec.id || `sec-${i+1}`;
            const step = sec.getAttribute('data-step') || String(i+1);
            const signal = signalClass(sec.getAttribute('data-signal'));

            const item = document.createElement('div');
            item.className = `nav-item ${signal}`;
            item.setAttribute('data-target', `#${id}`);

            item.innerHTML = `
                <div class="nav-left">
                    <div class="nav-badge">${step}</div>
                    <div class="nav-text">
                        <div class="nav-title">${title}</div>
                        <div class="nav-sub">${sub}</div>
                    </div>
                </div>
                <div class="nav-state">
                    <div class="tick" data-tick="#${id}"></div>
                </div>
            `;

            item.addEventListener('click', ()=>{
                goTo('#' + id, true);
            });

            sideNav.appendChild(item);
        });

        if(progTotal) progTotal.textContent = String(sections.length);
        updateProgress();
    }

    function updateProgress(){
        const doneCount = sections.filter(s => s.open).length;
        if(progDone) progDone.textContent = String(doneCount);

        const pct = sections.length ? Math.round((doneCount / sections.length) * 100) : 0;
        if(progFill) progFill.style.width = pct + '%';

        document.querySelectorAll('.tick[data-tick]').forEach(t=>{
            const sel = t.getAttribute('data-tick');
            const sec = document.querySelector(sel);
            const signal = sec ? signalClass(sec.getAttribute('data-signal')) : '';

            t.classList.remove('done','warn','bad');

            if(sec && sec.open){
                t.classList.add('done');
            }else if(signal === 'bad'){
                t.classList.add('bad');
            }else if(signal === 'warn'){
                t.classList.add('warn');
            }
        });
    }

    function updateCurrentState(){
        const current = getAnchorSection();

        sections.forEach(sec => sec.classList.remove('is-current'));
        document.querySelectorAll('#sideNav .nav-item').forEach(item => item.classList.remove('is-active'));

        if(!current) return;

        current.classList.add('is-current');

        const currentSel = '#' + current.id;
        const activeNav = sideNav ? sideNav.querySelector(`.nav-item[data-target="${currentSel}"]`) : null;
        if(activeNav){
            activeNav.classList.add('is-active');
        }
    }

    sections.forEach(sec=>{
        sec.addEventListener('toggle', ()=>{
            updateProgress();
            updateCurrentState();
        });
    });

    function clearHighlights(){
        document.querySelectorAll('.script').forEach(block=>{
            if(block.dataset.raw){
                block.innerHTML = block.dataset.raw;
                delete block.dataset.raw;
            }
        });
        sections.forEach(s => s.style.display = '');
    }

    function highlightHTMLPreservingTags(html, q){
        const safe = q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        const re = new RegExp(safe, 'gi');

        return html.replace(/>([^<]+)</g, (m, text) => {
            const replaced = text.replace(re, hit => `<mark class="hit">${hit}</mark>`);
            return '>' + replaced + '<';
        });
    }

    function highlightQuery(q){
        if(!q) return;

        let anyVisible = false;

        sections.forEach(sec=>{
            const text = (sec.innerText || '').toLowerCase();
            const hit = text.includes(q.toLowerCase());
            sec.style.display = hit ? '' : 'none';
            if(hit) anyVisible = true;

            if(hit){
                sec.querySelectorAll('.script').forEach(block=>{
                    if(!block.dataset.raw) block.dataset.raw = block.innerHTML;
                    block.innerHTML = highlightHTMLPreservingTags(block.dataset.raw, q);
                });
            }
        });

        if(!anyVisible){
            sections.forEach(s => s.style.display = '');
        }
    }

    if(search){
        search.addEventListener('input', ()=>{
            const q = (search.value || '').trim();
            clearHighlights();
            if(q.length >= 2) highlightQuery(q);
            updateCurrentState();
        });
    }

    if(btnClear){
        btnClear.addEventListener('click', ()=>{
            if(search) search.value = '';
            clearHighlights();
            toast('Search cleared.');
            updateCurrentState();
        });
    }

    applySignalClasses();
    buildNav();
    updateProgress();
    updateCurrentState();
})();
</script>
