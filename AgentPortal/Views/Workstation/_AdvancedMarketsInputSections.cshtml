@model AgentPortal.Models.AdvancedMarketsPageViewModel

<div class="form-grid">
    <div class="card strategy-section" data-strategies="DefinedBenefit,CashBalance,ComboDb401k,ExecutiveBonus162,DeferredComp,SplitDollar,TaxDiversification">
        <div class="card-head">
            <h3>Client Snapshot</h3>
            <p>Core demographics and objectives</p>
        </div>
        <div class="card-body two-col">
            <label>Client name <input name="Client.ClientName" value='@(ViewData.ModelState["Client.ClientName"]?.AttemptedValue ?? "")' /></label>
            <label>Household <input name="Client.HouseholdName" value='@(ViewData.ModelState["Client.HouseholdName"]?.AttemptedValue ?? "")' /></label>
            <label>Owner age <input type="number" name="Client.OwnerAge" placeholder="50" value='@(ViewData.ModelState["Client.OwnerAge"]?.AttemptedValue ?? "")' min="18" /></label>
            <label>Spouse age <input type="number" name="Client.SpouseAge" placeholder="50" value='@(ViewData.ModelState["Client.SpouseAge"]?.AttemptedValue ?? "")' /></label>
            <label>Retirement age <input type="number" name="Client.RetirementAge" placeholder="62" value='@(ViewData.ModelState["Client.RetirementAge"]?.AttemptedValue ?? "")' /></label>
            <label>State
                @{
                    var stateVal = ViewData.ModelState["Client.State"]?.AttemptedValue ?? Model.Client.State;
                    var states = new[]{ "AL","AK","AZ","AR","CA","CO","CT","DE","FL","GA","HI","IA","ID","IL","IN","KS","KY","LA","MA","MD","ME","MI","MN","MO","MS","MT","NC","ND","NE","NH","NJ","NM","NV","NY","OH","OK","OR","PA","RI","SC","SD","TN","TX","UT","VA","VT","WA","WI","WV","WY" };
                }
                <select name="Client.State" data-current="@stateVal">
                    <option value="">--Select--</option>
                    @foreach (var st in states)
                    {
                        <option value="@st">@st</option>
                    }
                </select>
            </label>
            <label>Business type
                @{
                    var businessTypeVal = ViewData.ModelState["Client.BusinessType"]?.AttemptedValue ?? Model.Client.BusinessType;
                    var bizOpts = new[]{ "Sole Proprietorship","LLC","S Corporation","C Corporation","Partnership","Professional Corporation","Nonprofit","Other" };
                }
                <select name="Client.BusinessType" data-current="@businessTypeVal">
                    <option value="">--Select--</option>
                    @foreach (var opt in bizOpts)
                    {
                        <option value="@opt">@opt</option>
                    }
                </select>
            </label>
            <label>Income type
                @{
                    var incomeTypeVal = ViewData.ModelState["Client.IncomeType"]?.AttemptedValue ?? Model.Client.IncomeType;
                    var incomeOpts = new[]{ "W-2","1099","K-1","Business Owner Draw","Mixed","Other" };
                }
                <select name="Client.IncomeType" data-current="@incomeTypeVal">
                    <option value="">--Select--</option>
                    @foreach (var opt in incomeOpts)
                    {
                        <option value="@opt">@opt</option>
                    }
                </select>
            </label>
        </div>
    </div>

    <div class="card strategy-section" data-strategies="DefinedBenefit,CashBalance,ComboDb401k,ExecutiveBonus162,DeferredComp,SplitDollar">
        <div class="card-head">
            <h3>Business Snapshot</h3>
            <p>Entity and workforce profile</p>
        </div>
        <div class="card-body two-col">
            <label>Entity type
                @{
                    var entityTypeVal = ViewData.ModelState["Business.EntityType"]?.AttemptedValue ?? Model.Business.EntityType;
                    var entityOpts = new[]{ "LLC","S Corporation","C Corporation","Partnership","Sole Proprietorship","Professional Corporation","Nonprofit","Other" };
                }
                <select name="Business.EntityType" data-current="@entityTypeVal">
                    <option value="">--Select--</option>
                    @foreach (var opt in entityOpts)
                    {
                        <option value="@opt">@opt</option>
                    }
                </select>
            </label>
            <label>Annual business income <input type="text" class="money-input" name="Business.AnnualBusinessIncome" placeholder="2000000" value='@(ViewData.ModelState["Business.AnnualBusinessIncome"]?.AttemptedValue ?? "")' /></label>
            <label>Owner compensation <input type="text" class="money-input" name="Business.OwnerComp" placeholder="500000" value='@(ViewData.ModelState["Business.OwnerComp"]?.AttemptedValue ?? "")' /></label>
            <label>Employees (total) <input type="number" name="Business.EmployeeCount" placeholder="15" value='@(ViewData.ModelState["Business.EmployeeCount"]?.AttemptedValue ?? "")' /></label>
            <label>Eligible employees <input type="number" name="Business.EligibleEmployeeCount" placeholder="7" value='@(ViewData.ModelState["Business.EligibleEmployeeCount"]?.AttemptedValue ?? "")' /></label>
            <label>Average employee age <input type="number" name="Business.AverageEmployeeAge" placeholder="38" value='@(ViewData.ModelState["Business.AverageEmployeeAge"]?.AttemptedValue ?? "")' /></label>
            <label>Average employee comp <input type="text" class="money-input" name="Business.AverageEmployeeComp" placeholder="100000" value='@(ViewData.ModelState["Business.AverageEmployeeComp"]?.AttemptedValue ?? "")' /></label>
            <label>Owner ownership % <input type="number" step="1" name="Business.OwnershipPct" placeholder="100" value='@(ViewData.ModelState["Business.OwnershipPct"]?.AttemptedValue ?? "")' /></label>
            <label>Current plan type
                @{
                    var currentPlanVal = ViewData.ModelState["Business.CurrentPlanType"]?.AttemptedValue ?? Model.Business.CurrentPlanType;
                    var planOpts = new[]{ "None","401(k)","Safe Harbor 401(k)","SIMPLE IRA","SEP IRA","Defined Benefit","Cash Balance","Combo DB + 401(k)","Nonqualified Plan","Other" };
                }
                <select name="Business.CurrentPlanType" data-current="@currentPlanVal">
                    <option value="">--Select--</option>
                    @foreach (var opt in planOpts)
                    {
                        <option value="@opt">@opt</option>
                    }
                </select>
            </label>
            <label>Current employer retirement contributions <input type="text" class="money-input" name="Business.CurrentEmployerRetirementContributions" placeholder="25000" value='@(ViewData.ModelState["Business.CurrentEmployerRetirementContributions"]?.AttemptedValue ?? "")' /></label>
            <label>Current benefit costs <input type="text" class="money-input" name="Business.CurrentBenefitCosts" placeholder="15000" value='@(ViewData.ModelState["Business.CurrentBenefitCosts"]?.AttemptedValue ?? "")' /></label>
        </div>
    </div>

    <div class="card strategy-section" data-strategies="DefinedBenefit,CashBalance,ComboDb401k,ExecutiveBonus162,DeferredComp,SplitDollar,TaxDiversification">
        <div class="card-head">
            <h3>Tax Assumptions</h3>
            <p>Marginal rates and mode</p>
        </div>
        <div class="card-body two-col">
            <label>Federal marginal rate <input type="number" step="0.01" class="pct-input" name="Tax.FederalRate" placeholder="35" value='@(ViewData.ModelState["Tax.FederalRate"]?.AttemptedValue ?? "")' /></label>
            <label>State marginal rate <input type="number" step="0.01" class="pct-input" name="Tax.StateRate" placeholder="5" value='@(ViewData.ModelState["Tax.StateRate"]?.AttemptedValue ?? "")' /></label>
            <label>Capital gains rate <input type="number" step="0.01" class="pct-input" name="Tax.CapitalGainsRate" placeholder="15" value='@(ViewData.ModelState["Tax.CapitalGainsRate"]?.AttemptedValue ?? "")' /></label>
            <label>Future retirement tax rate <input type="number" step="0.01" class="pct-input" name="Tax.FutureTaxRate" placeholder="30" value='@(ViewData.ModelState["Tax.FutureTaxRate"]?.AttemptedValue ?? "")' /></label>
            <label>Tax mode
                @{
                    var taxModeVal = ViewData.ModelState["Tax.Mode"]?.AttemptedValue ?? Model.Tax.Mode;
                }
                <select name="Tax.Mode" data-current="@taxModeVal">
                    <option value="">--Select--</option>
                    <option value="Simplified">Simplified</option>
                    <option value="Detailed">Detailed</option>
                </select>
            </label>
        </div>
    </div>

    <div class="card strategy-section" data-strategies="DefinedBenefit,CashBalance,ComboDb401k,ExecutiveBonus162,DeferredComp,SplitDollar,TaxDiversification">
        <div class="card-head">
            <h3>Projection Assumptions</h3>
            <p>Growth and retirement illustration</p>
        </div>
        <div class="card-body two-col">
            <label>Current investable retirement assets <input type="text" class="money-input" name="Projection.CurrentAssets" placeholder="500000" value='@(ViewData.ModelState["Projection.CurrentAssets"]?.AttemptedValue ?? "")' /></label>
            <label>Annual savings outside strategy <input type="text" class="money-input" name="Projection.AnnualSavings" placeholder="20000" value='@(ViewData.ModelState["Projection.AnnualSavings"]?.AttemptedValue ?? "")' /></label>
            <label>Growth rate <input type="number" step="0.01" class="pct-input" name="Projection.GrowthRate" placeholder="6" value='@(ViewData.ModelState["Projection.GrowthRate"]?.AttemptedValue ?? "")' /></label>
            <label>Inflation rate <input type="number" step="0.01" class="pct-input" name="Projection.InflationRate" placeholder="3" value='@(ViewData.ModelState["Projection.InflationRate"]?.AttemptedValue ?? "")' /></label>
            <label>Retirement duration (years) <input type="number" name="Projection.RetirementDurationYears" placeholder="25" value='@(ViewData.ModelState["Projection.RetirementDurationYears"]?.AttemptedValue ?? "")' /></label>
            <label>Distribution rate <input type="number" step="0.001" class="pct-input" name="Projection.DistributionRate" placeholder="4.5" value='@(ViewData.ModelState["Projection.DistributionRate"]?.AttemptedValue ?? "")' /></label>
            <label>Discount rate <input type="number" step="0.01" class="pct-input" name="Projection.DiscountRate" placeholder="4" value='@(ViewData.ModelState["Projection.DiscountRate"]?.AttemptedValue ?? "")' /></label>
        </div>
    </div>

    <div class="card strategy-section" data-strategies="DefinedBenefit,ComboDb401k">
        <div class="card-head">
            <h3>Defined Benefit Inputs</h3>
            <p>Only used for defined benefit illustrations</p>
        </div>
        <div class="card-body two-col">
            <label>DB target contribution <input type="text" class="money-input" name="DefinedBenefit.TargetContribution" placeholder="100000" value='@(ViewData.ModelState["DefinedBenefit.TargetContribution"]?.AttemptedValue ?? "")' /></label>
            <label>DB target benefit <input type="text" class="money-input" name="DefinedBenefit.TargetBenefit" placeholder="500000" value='@(ViewData.ModelState["DefinedBenefit.TargetBenefit"]?.AttemptedValue ?? "")' /></label>
            <label>DB admin cost <input type="text" class="money-input" name="DefinedBenefit.AdminCost" placeholder="4000" value='@(ViewData.ModelState["DefinedBenefit.AdminCost"]?.AttemptedValue ?? "")' /></label>
            <label>DB employee cost factor <input type="number" step="0.01" class="pct-input" name="DefinedBenefit.EmployeeCostFactor" placeholder="8" value='@(ViewData.ModelState["DefinedBenefit.EmployeeCostFactor"]?.AttemptedValue ?? "")' /></label>
            <label>DB growth rate <input type="number" step="0.01" class="pct-input" name="DefinedBenefit.GrowthRate" placeholder="5" value='@(ViewData.ModelState["DefinedBenefit.GrowthRate"]?.AttemptedValue ?? "")' /></label>
            <label>DB inflation rate <input type="number" step="0.01" class="pct-input" name="DefinedBenefit.InflationRate" placeholder="3" value='@(ViewData.ModelState["DefinedBenefit.InflationRate"]?.AttemptedValue ?? "")' /></label>
            <label>Include spouse?
                @{
                    var includeSpouseVal = (ViewData.ModelState["DefinedBenefit.IncludeSpouse"]?.AttemptedValue ?? Model.DefinedBenefit.IncludeSpouse.ToString()).ToLower();
                }
                <select name="DefinedBenefit.IncludeSpouse" data-current="@includeSpouseVal">
                    <option value="false">No</option>
                    <option value="true">Yes</option>
                </select>
            </label>
            <label>Spouse age <input type="number" name="DefinedBenefit.SpouseAge" placeholder="48" value='@(ViewData.ModelState["DefinedBenefit.SpouseAge"]?.AttemptedValue ?? "")' /></label>
            <label>Spouse contribution <input type="text" class="money-input" name="DefinedBenefit.SpouseContribution" placeholder="25000" value='@(ViewData.ModelState["DefinedBenefit.SpouseContribution"]?.AttemptedValue ?? "")' /></label>
        </div>
    </div>

    <div class="card strategy-section" data-strategies="CashBalance,ComboDb401k">
        <div class="card-head">
            <h3>Cash Balance Inputs</h3>
            <p>Used for cash balance or combo modeling</p>
        </div>
        <div class="card-body two-col">
            <label>CB desired total contribution <input type="text" class="money-input" name="CashBalance.DesiredTotalContribution" placeholder="75000" value='@(ViewData.ModelState["CashBalance.DesiredTotalContribution"]?.AttemptedValue ?? "")' /></label>
            <label>CB pay credit % <input type="number" step="0.01" class="pct-input" name="CashBalance.PayCreditPct" placeholder="5" value='@(ViewData.ModelState["CashBalance.PayCreditPct"]?.AttemptedValue ?? "")' /></label>
            <label>CB interest credit % <input type="number" step="0.01" class="pct-input" name="CashBalance.InterestCreditPct" placeholder="4" value='@(ViewData.ModelState["CashBalance.InterestCreditPct"]?.AttemptedValue ?? "")' /></label>
            <label>CB admin cost <input type="text" class="money-input" name="CashBalance.AdminCost" placeholder="3000" value='@(ViewData.ModelState["CashBalance.AdminCost"]?.AttemptedValue ?? "")' /></label>
        </div>
    </div>

    <div class="card strategy-section" data-strategies="ExecutiveBonus162">
        <div class="card-head">
            <h3>Executive Bonus Inputs</h3>
            <p>Used for 162 bonus illustrations</p>
        </div>
        <div class="card-body two-col">
            <label>Exec bonus (162) annual bonus <input type="text" class="money-input" name="ExecutiveBonus.AnnualBonus" placeholder="50000" value='@(ViewData.ModelState["ExecutiveBonus.AnnualBonus"]?.AttemptedValue ?? "")' /></label>
            <label>Exec bonus years funded <input type="number" name="ExecutiveBonus.YearsFunded" placeholder="10" value='@(ViewData.ModelState["ExecutiveBonus.YearsFunded"]?.AttemptedValue ?? "")' /></label>
            <label>Exec bonus growth rate <input type="number" step="0.01" class="pct-input" name="ExecutiveBonus.PolicyGrowthRate" placeholder="6" value='@(ViewData.ModelState["ExecutiveBonus.PolicyGrowthRate"]?.AttemptedValue ?? "")' /></label>
            <label>Exec bonus death benefit multiple <input type="number" step="0.1" class="pct-input" name="ExecutiveBonus.DeathBenefitMultiple" placeholder="10" value='@(ViewData.ModelState["ExecutiveBonus.DeathBenefitMultiple"]?.AttemptedValue ?? "")' /></label>
        </div>
    </div>

    <div class="card strategy-section" data-strategies="DeferredComp">
        <div class="card-head">
            <h3>Deferred Compensation Inputs</h3>
            <p>Used for nonqualified deferral illustrations</p>
        </div>
        <div class="card-body two-col">
            <label>Deferred comp deferral amount <input type="text" class="money-input" name="DeferredComp.DeferralAmount" placeholder="50000" value='@(ViewData.ModelState["DeferredComp.DeferralAmount"]?.AttemptedValue ?? "")' /></label>
            <label>Deferred comp deferral years <input type="number" name="DeferredComp.DeferralYears" placeholder="5" value='@(ViewData.ModelState["DeferredComp.DeferralYears"]?.AttemptedValue ?? "")' /></label>
            <label>Distribution start age <input type="number" name="DeferredComp.DistributionStartAge" placeholder="60" value='@(ViewData.ModelState["DeferredComp.DistributionStartAge"]?.AttemptedValue ?? "")' /></label>
            <label>Deferred comp distribution years <input type="number" name="DeferredComp.DistributionYears" placeholder="10" value='@(ViewData.ModelState["DeferredComp.DistributionYears"]?.AttemptedValue ?? "")' /></label>
            <label>Deferred comp growth rate <input type="number" step="0.01" class="pct-input" name="DeferredComp.GrowthRate" placeholder="6" value='@(ViewData.ModelState["DeferredComp.GrowthRate"]?.AttemptedValue ?? "")' /></label>
            <label>Deferred comp current tax rate <input type="number" step="0.01" class="pct-input" name="DeferredComp.CurrentTaxRate" placeholder="35" value='@(ViewData.ModelState["DeferredComp.CurrentTaxRate"]?.AttemptedValue ?? "")' /></label>
            <label>Deferred comp future tax rate <input type="number" step="0.01" class="pct-input" name="DeferredComp.FutureTaxRate" placeholder="30" value='@(ViewData.ModelState["DeferredComp.FutureTaxRate"]?.AttemptedValue ?? "")' /></label>
        </div>
    </div>

    <div class="card strategy-section" data-strategies="SplitDollar">
        <div class="card-head">
            <h3>Split-Dollar Inputs</h3>
            <p>Heavily compliance-sensitive — legal/tax review required</p>
        </div>
        <div class="card-body two-col">
            <label>Split-dollar annual premium <input type="text" class="money-input" name="SplitDollar.AnnualPremium" placeholder="50000" value='@(ViewData.ModelState["SplitDollar.AnnualPremium"]?.AttemptedValue ?? "")' /></label>
            <label>Split-dollar funding years <input type="number" name="SplitDollar.FundingYears" placeholder="10" value='@(ViewData.ModelState["SplitDollar.FundingYears"]?.AttemptedValue ?? "")' /></label>
            <label>Split-dollar exit year <input type="number" name="SplitDollar.ExitYear" placeholder="15" value='@(ViewData.ModelState["SplitDollar.ExitYear"]?.AttemptedValue ?? "")' /></label>
            <label>Split-dollar growth rate <input type="number" step="0.01" class="pct-input" name="SplitDollar.GrowthRate" placeholder="5" value='@(ViewData.ModelState["SplitDollar.GrowthRate"]?.AttemptedValue ?? "")' /></label>
            <label>Split-dollar death benefit <input type="text" class="money-input" name="SplitDollar.DeathBenefit" placeholder="2000000" value='@(ViewData.ModelState["SplitDollar.DeathBenefit"]?.AttemptedValue ?? "")' /></label>
        </div>
    </div>

    <div class="card strategy-section" data-strategies="ComboDb401k">
        <div class="card-head">
            <h3>Combo DB + 401(k) / Profit Sharing</h3>
            <p>Used when modeling combo strategies</p>
        </div>
        <div class="card-body two-col">
            <label>Employee deferral <input type="number" step="100" name="Combo.EmployeeDeferral" placeholder="20000" value='@(ViewData.ModelState["Combo.EmployeeDeferral"]?.AttemptedValue ?? "")' /></label>
            <label>Catch-up
                @{
                    var catchUpVal = (ViewData.ModelState["Combo.CatchUp"]?.AttemptedValue ?? Model.Combo.CatchUp.ToString()).ToLower();
                }
                <select name="Combo.CatchUp" data-current="@catchUpVal">
                    <option value="false">No</option>
                    <option value="true">Yes</option>
                </select>
            </label>
            <label>Employer % <input type="number" step="0.01" class="pct-input" name="Combo.EmployerPct" placeholder="3" value='@(ViewData.ModelState["Combo.EmployerPct"]?.AttemptedValue ?? "")' /></label>
            <label>Profit sharing % <input type="number" step="0.01" class="pct-input" name="Combo.ProfitSharingPct" placeholder="6" value='@(ViewData.ModelState["Combo.ProfitSharingPct"]?.AttemptedValue ?? "")' /></label>
            <label>Safe harbor % <input type="number" step="0.01" class="pct-input" name="Combo.SafeHarborPct" placeholder="3" value='@(ViewData.ModelState["Combo.SafeHarborPct"]?.AttemptedValue ?? "")' /></label>
            <label>Target total contribution <input type="text" class="money-input" name="Combo.TargetTotal" placeholder="75000" value='@(ViewData.ModelState["Combo.TargetTotal"]?.AttemptedValue ?? "")' /></label>
            <label>Employee cost factor <input type="number" step="0.01" class="pct-input" name="Combo.EmployeeCostFactor" placeholder="8" value='@(ViewData.ModelState["Combo.EmployeeCostFactor"]?.AttemptedValue ?? "")' /></label>
            <label>Testing buffer % <input type="number" step="0.01" class="pct-input" name="Combo.TestingBufferPct" placeholder="2" value='@(ViewData.ModelState["Combo.TestingBufferPct"]?.AttemptedValue ?? "")' /></label>
        </div>
    </div>

    <div class="card strategy-section" data-strategies="TaxDiversification">
        <div class="card-head">
            <h3>Tax Diversification Inputs</h3>
            <p>Balance qualified / taxable / tax-free buckets</p>
        </div>
        <div class="card-body two-col">
            <label>Qualified assets (current) <input type="text" class="money-input" name="Client.CurrentQualifiedAssets" placeholder="900000" value='@(ViewData.ModelState["Client.CurrentQualifiedAssets"]?.AttemptedValue ?? "")' /></label>
            <label>Taxable assets (current) <input type="text" class="money-input" name="Client.CurrentTaxableAssets" placeholder="1000000" value='@(ViewData.ModelState["Client.CurrentTaxableAssets"]?.AttemptedValue ?? "")' /></label>
            <label>Tax-free assets (current) <input type="text" class="money-input" name="Client.CurrentTaxFreeAssets" placeholder="250000" value='@(ViewData.ModelState["Client.CurrentTaxFreeAssets"]?.AttemptedValue ?? "")' /></label>
            <label>Annual savings outside strategy <input type="text" class="money-input" name="Projection.AnnualSavings" placeholder="20000" value='@(ViewData.ModelState["Projection.AnnualSavings"]?.AttemptedValue ?? "")' /></label>
        </div>
    </div>
</div>
