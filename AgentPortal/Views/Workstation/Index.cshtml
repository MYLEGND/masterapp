@{
    ViewData["Title"] = ViewData["Title"] ?? "Workstation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/scripts-rebuttals.css" asp-append-version="true" />
}



<div class="scripts-shell">

    <!-- HERO -->
    <div class="scripts-hero">
        <div class="hero-bar">
            <h1 class="hero-title">Workstation Hub</h1>
            <p class="hero-sub">Jump into the right live script or rebuttal without leaving the page.</p>
        </div>

        <div class="hero-foot">
            <div class="search-wrap">
                <span class="search-ico">⌕</span>
                <input id="scriptSearch" class="search" type="text" placeholder="Search scripts or rebuttals…" autocomplete="off" />
            </div>

            <div class="hero-meta">
                <span class="pill" id="scriptCount">0 items</span>

                <span class="chip active" data-filter="all">All</span>
                <span class="chip" data-filter="rebuttal">Rebuttals</span>
            </div>
        </div>
    </div>

    <!-- REBUTTALS SECTION -->
    <section class="library-section">
        <div class="section-head">
            <h2 class="section-title">Rebuttals</h2>
            <div class="section-note">Quick objection pages and battle-tested response libraries.</div>
        </div>

        <div id="rebuttalGrid" class="grid">

            <div class="card rebuttal-card" data-title="Mortgage Protection Rebuttals objections rebuttals mortgage" data-tag="rebuttal">
                <div class="card-head">
                    <h3 class="card-title">Mortgage Protection Rebuttals</h3>
                    <span class="tag">Rebuttal</span>
                </div>
                <div class="card-body">
                    <p class="desc">
                        Fast objection handling page with button-based responses for common mortgage protection stalls.
                    </p>
                    <a class="btn-legend dark" asp-controller="Workstation" asp-action="Rebuttals">
                        Open Rebuttals →
                    </a>
                </div>
            </div>

            <div class="card rebuttal-card" data-title="Final Expense Rebuttals objections rebuttals final expense" data-tag="rebuttal">
                <div class="card-head">
                    <h3 class="card-title">Final Expense Rebuttals</h3>
                    <span class="tag">Rebuttal</span>
                </div>
                <div class="card-body">
                    <p class="desc">
                        Place your final expense objection page here once that rebuttal flow is ready to launch.
                    </p>
                    <a class="btn-legend dark" asp-controller="Workstation" asp-action="FinalExpenseRebuttals">
                        Open Rebuttals →
                    </a>
                </div>
            </div>

            <div class="card rebuttal-card" data-title="Medicare Rebuttals objections rebuttals medicare" data-tag="rebuttal">
                <div class="card-head">
                    <h3 class="card-title">Medicare Rebuttals</h3>
                    <span class="tag">Rebuttal</span>
                </div>
                <div class="card-body">
                    <p class="desc">
                        Place your Medicare rebuttal page here for common resistance, confusion, and delay objections.
                    </p>
                    <a class="btn-legend dark" asp-controller="Workstation" asp-action="MedicareRebuttals">
                        Open Rebuttals →
                    </a>
                </div>
            </div>

            <div class="card rebuttal-card" data-title="Life Insurance Rebuttals objections rebuttals life insurance" data-tag="rebuttal">
                <div class="card-head">
                    <h3 class="card-title">Life Insurance Rebuttals</h3>
                    <span class="tag">Rebuttal</span>
                </div>
                <div class="card-body">
                    <p class="desc">
                        Current shared objection layout using the same rebuttal framework until the product-specific life flow is ready.
                    </p>
                    <a class="btn-legend dark" asp-controller="Workstation" asp-action="LifeInsuranceRebuttals">
                        Open Rebuttals →
                    </a>
                </div>
            </div>

            <div class="card rebuttal-card" data-title="Disability Insurance Rebuttals objections rebuttals disability insurance" data-tag="rebuttal">
                <div class="card-head">
                    <h3 class="card-title">Disability Insurance Rebuttals</h3>
                    <span class="tag">Rebuttal</span>
                </div>
                <div class="card-body">
                    <p class="desc">
                        Current shared objection layout using the same rebuttal framework until the product-specific disability flow is ready.
                    </p>
                    <a class="btn-legend dark" asp-controller="Workstation" asp-action="DisabilityInsuranceRebuttals">
                        Open Rebuttals →
                    </a>
                </div>
            </div>

        </div>
    </section>

</div>

<script>
    (function () {
        const HUB_FILTER_KEY = 'ws_hub_filter';
        const search = document.getElementById('scriptSearch');
        const cards = Array.from(document.querySelectorAll('.rebuttal-card'));
        const count = document.getElementById('scriptCount');
        const chips = Array.from(document.querySelectorAll('.chip'));
        const rebuttalGrid = document.getElementById('rebuttalGrid');

        let activeFilter = 'all';

        function saveHubFilterState() {
            try {
                localStorage.setItem(HUB_FILTER_KEY, JSON.stringify({
                    filter: activeFilter,
                    search: search?.value || ''
                }));
            } catch {}
        }

        function setActiveFilter(value) {
            const normalized = (value || 'all').toLowerCase();
            const matchedChip = chips.find(c => ((c.getAttribute('data-filter') || '').toLowerCase() === normalized));
            activeFilter = matchedChip ? normalized : 'all';
            chips.forEach(c => c.classList.toggle('active', c === (matchedChip || chips[0])));
        }

        function restoreHubFilterState() {
            let state = null;
            try {
                state = JSON.parse(localStorage.getItem(HUB_FILTER_KEY) || 'null');
            } catch {}
            if (!state) return;
            if (search && typeof state.search === 'string') {
                search.value = state.search;
            }
            setActiveFilter(state.filter || 'all');
        }

        function updateCount(visible) {
            const n = visible.length;
            count.textContent = n + (n === 1 ? ' item' : ' items');
        }

        function ensureEmptyState(grid, className, message) {
            if(!grid) return;
            let empty = grid.querySelector('.' + className);
            const visibleCards = Array.from(grid.children).filter(x =>
                x.classList.contains('card') && x.style.display !== 'none'
            );

            if (visibleCards.length === 0) {
                if (!empty) {
                    empty = document.createElement('div');
                    empty.className = 'empty-state ' + className;
                    empty.textContent = message;
                    grid.appendChild(empty);
                }
            } else if (empty) {
                empty.remove();
            }
        }

        function filter() {
            const q = (search.value || '').toLowerCase().trim();
            const visible = [];

            cards.forEach(card => {
                const hay = (card.getAttribute('data-title') || '').toLowerCase();
                const tag = (card.getAttribute('data-tag') || '').toLowerCase();

                const matchesSearch = !q || hay.includes(q);
                const matchesTag = (activeFilter === 'all') || (tag === activeFilter);

                const show = matchesSearch && matchesTag;
                card.style.display = show ? '' : 'none';

                if (show) visible.push(card);
            });

            updateCount(visible);

            ensureEmptyState(rebuttalGrid, 'rebuttals-empty', 'No rebuttals match that search/filter.');
        }

        chips.forEach(chip => {
            chip.addEventListener('click', () => {
                setActiveFilter(chip.getAttribute('data-filter') || 'all');
                saveHubFilterState();
                filter();
            });
        });

        search.addEventListener('input', () => {
            saveHubFilterState();
            filter();
        });

        setActiveFilter(activeFilter);
        restoreHubFilterState();
        filter();
    })();
</script>
