@{
    ViewData["Title"] = "Workstation — Final Expense Rebuttals";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/scripts-rebuttals.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/workstation-home-proposal.css" asp-append-version="true" />
}


<div id="rbShell" class="theme-fe">
    <div class="rb-wrap">
        <div class="rb-hero">
            <div class="rb-hero-top">
                <div class="hero-left">
                    <h1>Workstation — Final Expense</h1>
                    <p class="hero-sub">Handle the next lead, objections, proposals, and carrier tools from one screen.</p>
                    <span id="rbCount" style="display:none">0</span>
                </div>
                <div class="hero-actions">
                    <div class="hero-action-group">
                        <button type="button" class="btn hp-proposal-trigger" id="btnProposal">Proposal ▾</button>
                        <div class="hp-proposal-menu" id="proposalMenu" hidden>
                            <div class="hp-proposal-menu-head">
                                <span>Saved Proposals</span>
                                <button type="button" class="btn-mini" id="btnProposalNew">+ New</button>
                            </div>
                            <div class="hp-proposal-menu-list" id="proposalMenuList"></div>
                        </div>
                    </div>
                    <div class="hero-action-group">
                        <button type="button" class="btn gold hero-underwrite" id="btnUnderwriting">Underwriting ▾</button>
                        <div class="proposal-menu" id="uwMenu" hidden>
                            <div class="proposal-menu-head">
                                <span>Saved Underwriting</span>
                                <button type="button" class="btn-mini" id="btnUwNew">+ New</button>
                            </div>
                            <div class="proposal-menu-list" id="uwMenuList"></div>
                        </div>
                    </div>
                    <div class="hero-action-group">
                        <button type="button" class="btn hero-zoom-btn" data-zoom-popup aria-label="Open Zoom Links">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" width="14" height="14" fill="none" aria-hidden="true"><rect width="20" height="20" rx="4" fill="#2D8CFF"/><path d="M3 7.5A1.5 1.5 0 0 1 4.5 6H12A1.5 1.5 0 0 1 13.5 7.5v5A1.5 1.5 0 0 1 12 14H4.5A1.5 1.5 0 0 1 3 12.5v-5z" fill="white"/><path d="M13.5 9l3.5-2v6l-3.5-2V9z" fill="white"/></svg>
                            Zoom Links
                        </button>
                    </div>
                    @await Html.PartialAsync("_ScriptSwitcher", "fe")
                </div>
            </div>
        </div>

        <div class="rb-link-bar">
            <a class="btn gold rb-link" href="https://hq-whl.us.auth0.com/login?state=hKFo2SAtbGV5NkRzX1BpSW1MaE52Qy1uOTdidkNuMm5MXzV0MqFupWxvZ2luo3RpZNkgODF2NXpTdHBMeGcxU0VmSVF5Y1ppOVhwWGhOTlo0SzajY2lk2SBjQ3FEb2dNbHNoUlhQWEpvck1EWmdLZEFRUGVCczlJSA&amp;client=cCqDogMlshRXPXJorMDZgKdAQPeBs9IH&amp;protocol=oauth2&amp;audience=http%3A%2F%2Fapi-whl.quility.com&amp;redirect_uri=https%3A%2F%2Fb2b-hq.quility.com&amp;scope=openid%20profile%20email&amp;response_type=code&amp;response_mode=query&amp;nonce=MGhlT1ZOcXVQcC44UlNRZER5NWFUNU1lMEgwfkR2MzlHTXVqeGpkZGlXWA%3D%3D&amp;code_challenge=mmd1hG_9XoAkIByduyMmB1n6fai45wDlZghr5abcNYw&amp;code_challenge_method=S256&amp;auth0Client=eyJuYW1lIjoiYXV0aDAtc3BhLWpzIiwidmVyc2lvbiI6IjEuMjIuNiJ9" target="_blank" rel="noopener noreferrer">Quility</a>
            <a class="btn gold rb-link" href="https://connect.integrity.com/agent/dashboard" target="_blank" rel="noopener noreferrer">Integrity Marketing</a>
            <a class="btn gold rb-link" href="https://app.ezlynx.com/auth/account/login" target="_blank" rel="noopener noreferrer">EZLynx</a>
        </div>

        @await Html.PartialAsync("_LeadBridge", "FinalExpense")

        <div class="shell">
            <div class="nav-rail-arrow nav-rail-arrow-left" id="rbNavArrow" aria-hidden="true"></div>
            <section class="nav-card">
                <div class="card-head">
                    <div>
                        <p class="card-title">Categories</p>
                        <p class="card-sub">Most common at the top. Least common at the bottom.</p>
                    </div>
                    <div class="count-pill"><span id="catCount">0</span> groups</div>
                </div>
                <div class="nav-body" id="rbNav"></div>
            </section>

            <section class="content-card">
                <div class="card-head">
                    <div>
                        <p class="card-title">Scripts</p>
                        <p class="card-sub" id="contentSub">Select a category from the left.</p>
                    </div>
                    <div class="count-pill" id="contentCount">0 scripts</div>
                </div>
                <div class="content-body" id="rbContent">
                    <div class="content-empty">
                        Click a category on the left and all objections for that category will load here.
                    </div>
                </div>
            </section>

            <section class="nav-card prosper-nav-card">
                <div class="card-head">
                    <div>
                        <p class="card-title">Final Expense Guide</p>
                        <p class="card-sub">Mirror rail for the full final expense flow.</p>
                    </div>
                    <div class="count-pill"><span id="prosperCount">0</span> steps</div>
                </div>
                <div class="nav-body" id="prosperNav">
                    <div class="content-empty small">
                        Loading Final Expense script steps…
                    </div>
                </div>
            </section>
            <div class="nav-rail-arrow nav-rail-arrow-right" id="prosperNavArrow" aria-hidden="true"></div>
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Views/Shared/_UnderwritingForm.cshtml", viewData: new ViewDataDictionary(ViewData) { { "UwSubtitle", "Underwriting Intake — Final Expense" }, { "UwProduct", "FE" } })

<div class="hp-overlay" id="proposalOverlay" hidden>
    <div class="hp-dialog" id="proposalDialog" role="dialog" aria-modal="true" aria-labelledby="proposalTitle">
        <div class="hp-dialog-head">
            <div class="hp-dialog-brand">
                <div class="hp-dialog-icon">📋</div>
                <div>
                    <div class="hp-dialog-title" id="proposalTitle">Proposal Builder</div>
                    <div class="hp-dialog-sub">Compare side-by-side options for any client</div>
                </div>
            </div>
            <button type="button" class="hp-dialog-close" data-proposal-close aria-label="Close proposal builder">×</button>
        </div>

        <form id="proposalForm" class="hp-form">
            <div class="hp-form-meta">
                <label class="hp-field">
                    <span>Proposal Name</span>
                    <input id="propName" name="propName" placeholder="Client name or label" autocomplete="off" />
                </label>
                <div class="hp-form-actions">
                    <button type="submit" class="hp-btn hp-btn-gold" id="btnSaveProposal">Save Proposal</button>
                    <button type="button" class="hp-btn hp-btn-ghost" id="btnCaptureDecision" data-bs-toggle="modal" data-bs-target="#captureDecisionModal">Capture Decision</button>
                    <button type="button" class="hp-btn hp-btn-ghost" data-proposal-close>Cancel</button>
                </div>
            </div>

            <div class="proposal-latest-decision" id="latestDecisionSummary" hidden style="margin-bottom:8px; border:1px solid rgba(166,128,35,.22); border-radius:12px; padding:10px; background:rgba(255,255,255,.04);">
                <div style="font-size:.72rem; color:#94a3b8; text-transform:uppercase; font-weight:800; letter-spacing:.04em;">Latest decision</div>
                <div style="font-weight:800; color:#f8fafc;" data-decision-title>-</div>
                <div style="font-size:.82rem; color:#cbd5e1;" data-decision-type></div>
                <div style="font-size:.9rem; color:#f8fafc;" data-decision-rationale></div>
                <div style="font-size:.72rem; color:#94a3b8;" data-decision-time></div>
            </div>

            <div class="hp-buckets">
                @for (var i = 1; i <= 3; i++)
                {
                    <div class="proposal-bucket hp-bucket" data-bucket="@i">
                        <div class="hp-bucket-head">Option @i</div>
                        <label class="hp-field">
                            <span>Insurance Carrier</span>
                            <select class="prop-carrier" id="propCarrier@i">
                                <option value="">Select carrier</option>
                                <optgroup label="Final Expense">
                                    <option>Mutual of Omaha (Living Promise)</option>
                                    <option>Royal Neighbors of America</option>
                                    <option>Americo Eagle</option>
                                    <option>Prosperity Life</option>
                                    <option>Aetna CVS / Accendo</option>
                                    <option>Transamerica Immediate/10-pay</option>
                                    <option>Liberty Bankers Life</option>
                                    <option>Kansas City Life</option>
                                    <option>Foresters PlanRight</option>
                                    <option>American Amicable</option>
                                    <option>Columbian Financial</option>
                                    <option>Great Western (GI)</option>
                                    <option>Guarantee Trust Life (GI)</option>
                                    <option>Christian Fidelity</option>
                                </optgroup>
                                <optgroup label="Life Insurance">
                                    <option>Transamerica</option>
                                    <option>Banner Life</option>
                                    <option>Pacific Life</option>
                                    <option>North American</option>
                                    <option>Protective Life</option>
                                    <option>American National</option>
                                    <option>Nationwide</option>
                                    <option>Securian</option>
                                </optgroup>
                                <optgroup label="Disability">
                                    <option>Assurity</option>
                                    <option>Principal</option>
                                    <option>Guardian</option>
                                    <option>Ohio National</option>
                                </optgroup>
                                <optgroup label="Medicare">
                                    <option>Humana</option>
                                    <option>UnitedHealthcare</option>
                                    <option>Aetna</option>
                                    <option>Cigna</option>
                                    <option>Devoted Health</option>
                                </optgroup>
                                <option>Other</option>
                            </select>
                        </label>
                        <label class="hp-field">
                            <span>Term</span>
                            <select class="prop-term" id="propTerm@i">
                                <option value="">N/A</option>
                                <option>10 Year</option>
                                <option>15 Year</option>
                                <option>20 Year</option>
                                <option>30 Year</option>
                                <option>40 Year</option>
                            </select>
                        </label>
                        <label class="hp-field">
                            <span>Type</span>
                            <select class="prop-type" id="propType@i">
                                <option value="">Select</option>
                                <option value="Level">Level</option>
                                <option value="Graded">Graded</option>
                                <option value="Guaranteed Issue">Guaranteed Issue</option>
                                <option>Term</option>
                                <option>Whole Life</option>
                                <option>IUL</option>
                                <option>Short-Term Disability</option>
                                <option>Long-Term Disability</option>
                                <option>Medicare Advantage</option>
                                <option>Medicare Supplement</option>
                            </select>
                        </label>
                        @for (var r = 1; r <= 3; r++)
                        {
                            <div class="hp-row">
                                <label class="hp-field">
                                    <span>Death Benefit @r</span>
                                    <div class="hp-currency-wrap">
                                        <span class="hp-currency-sym">$</span>
                                        <input class="prop-benefit currency-input hp-currency-input" id="propBenefit@i@r" inputmode="decimal" autocomplete="off" />
                                    </div>
                                </label>
                                <label class="hp-field">
                                    <span>Premium @r</span>
                                    <div class="hp-currency-wrap">
                                        <span class="hp-currency-sym">$</span>
                                        <input class="prop-premium currency-input hp-currency-input" id="propPremium@i@r" inputmode="decimal" autocomplete="off" />
                                        <span class="hp-currency-sfx">/mo</span>
                                    </div>
                                </label>
                            </div>
                        }
                    </div>
                }
            </div>
        </form>
    </div>
</div>




<script>
(function(){
        const categories = [
        {
            key: "opening-pushback",
            rank: 1,
            navSignal: "bad",
            name: "Opening Pushback",
            note: "Fast objections when they think this is salesy or pointless.",
            items: [
                {
                    id: "not-interested",
                    title: "I’m not interested / sounds like a sale",
                    signal: "bad",
                    script: `<Name>, makes sense. I’m the state-licensed final expense underwriter assigned to your request. My job is to make sure your family isn’t left with an $8–$12k bill. Give me 60 seconds; if it’s not useful we’re done. Fair?`
                },
                {
                    id: "already-handled",
                    title: "I already handled this",
                    signal: "warn",
                    script: `Good news if that’s true. My job is to confirm you’re not overpaying or missing benefits. I’ll verify what you have, bless it if it’s solid, or show a cheaper permanent option. Sound good?`
                },
                {
                    id: "who-are-you",
                    title: "Who are you again?",
                    signal: "info",
                    script: `I’m <your name>, state-licensed field underwriter. You asked for coverage that pays the funeral/cremation so the family isn’t fundraising. I just need DOB and beneficiary to check options.`
                },
                {
                    id: "no-appointment",
                    title: "Not doing appointments",
                    signal: "warn",
                    script: `Understood. This is a quick 10-minute benefit check, not a sales pitch. We size something small and permanent so the bill is handled. If it’s not a fit, we end the call. Fair?`
                }
            ]
        },
        {
            key: "price-budget",
            rank: 2,
            navSignal: "warn",
            name: "Price & Budget",
            note: "Fixed-income realities and keeping drafts painless.",
            items: [
                {
                    id: "too-expensive",
                    title: "It’s too expensive / I’m on fixed income",
                    signal: "warn",
                    script: `These plans are built for fixed income. Most land $30–$60/mo. I’ll set it to your comfort number and draft on your deposit date so it never bounces.`
                },
                {
                    id: "call-after-check",
                    title: "Call after I get my Social Security check",
                    signal: "info",
                    script: `I’ll anchor the draft to your Social Security deposit (1st/3rd/Wed) so you’re never short. Let’s size it now so it’s ready; it won’t draft until that date.`
                },
                {
                    id: "want-cheapest",
                    title: "Just give me the cheapest thing",
                    signal: "warn",
                    script: `I’ll keep it lean, but cheap term plans can cancel or jump at age 80. Final expense should be lifetime, price-lock. I’ll show “rock-bottom” and “never-cancels” and you pick.`
                },
                {
                    id: "rate-increase-fear",
                    title: "Rates always go up",
                    signal: "info",
                    script: `These are level-benefit whole life—price and coverage never change. The only time it moves is if you ask to raise coverage. Want me to note “no price increases” on your summary?`
                }
            ]
        },
        {
            key: "existing-coverage",
            rank: 3,
            navSignal: "info",
            name: "Existing Coverage",
            note: "Work benefits, old term, or thinking they’re covered.",
            items: [
                {
                    id: "work-insurance",
                    title: "I have insurance through work",
                    signal: "warn",
                    script: `Great while you’re working. Most work coverage ends when you retire or get sick. Final expense is portable and cannot be cancelled. Let’s set a small permanent amount so the family isn’t exposed.`
                },
                {
                    id: "old-policy",
                    title: "I already have a policy",
                    signal: "info",
                    script: `Perfect—quick review. Many older policies are term and drop at 80. I’ll verify if yours is lifetime and level. If it’s solid, I’ll say so. If not, we’ll plug the gap.`
                },
                {
                    id: "va-or-state",
                    title: "VA / state will cover me",
                    signal: "warn",
                    script: `VA burial max is usually $300–$2,000 and only in certain cases. Funeral averages $8–$12k. We’ll layer a small guaranteed policy so your family isn’t short.`
                }
            ]
        },
        {
            key: "health-qualify",
            rank: 4,
            navSignal: "good",
            name: "Health & Qualifying",
            note: "Pre-existing conditions, graded periods, and meds.",
            items: [
                {
                    id: "health-issues",
                    title: "I’m not healthy enough",
                    signal: "warn",
                    script: `That’s why these exist. Final expense is built for diabetes, COPD, heart history. Worst case we start graded 24 months, then it grows into full coverage. Let me match the carrier to your meds.`
                },
                {
                    id: "no-exams",
                    title: "I don’t want a medical exam",
                    signal: "info",
                    script: `No needles, no nurse. It’s a phone/tablet app using your prescription history and a few yes/no questions. About 10 minutes.`
                },
                {
                    id: "graded-wait",
                    title: "I don’t like a two-year wait",
                    signal: "info",
                    script: `Totally get it. The graded period protects you while carriers get comfortable with the health history. It still pays day-one for accidental and after month 25 for any cause. We’ll pick the shortest wait possible.`
                }
            ]
        },
        {
            key: "family-decision",
            rank: 5,
            navSignal: "info",
            name: "Family & Beneficiaries",
            note: "When they defer to kids or spouse.",
            items: [
                {
                    id: "need-talk-to-kids",
                    title: "I need to talk to my kids first",
                    signal: "info",
                    script: `Understandable. Kids only ask “How do we pay for it?” Let’s set an amount you’re comfortable with and I’ll text/email the summary to share. If they want tweaks, we adjust together.`
                },
                {
                    id: "spouse-not-here",
                    title: "My spouse isn’t here",
                    signal: "info",
                    script: `No problem. We can start with you, add spouse as beneficiary, and add their coverage when they’re available. That way one of you is protected today.`
                },
                {
                    id: "call-back",
                    title: "Can you call me back later?",
                    signal: "warn",
                    script: `Sure. Before we hang up, what amount felt right so I can hold it? This locks the price and health class while we reschedule, and we can change it after we talk.`
                }
            ]
        },
        {
            key: "gov-help",
            rank: 6,
            navSignal: "info",
            name: "Government / Assistance",
            note: "Medicaid, SSI, or “the state will handle it.”",
            items: [
                {
                    id: "medicaid",
                    title: "Medicaid will cover it",
                    signal: "warn",
                    script: `Medicaid can cover indigent burials but often only basic cremation and only if assets are zero. Most families still owe thousands. A small $8–$12k policy keeps control with your family.`
                },
                {
                    id: "ssi-check",
                    title: "Can you just take it from my SSI check?",
                    signal: "info",
                    script: `We set the draft date to your SSI deposit so it auto-pays. It still stays in your name and you control it—no surprises.`
                },
                {
                    id: "state-pays",
                    title: "Doesn’t the state pay a death benefit?",
                    signal: "info",
                    script: `Social Security’s lump sum is $255. Funerals run $8–$12k. This fills the gap so your family isn’t scrambling.`
                }
            ]
        },
        {
            key: "bank-trust",
            rank: 7,
            navSignal: "bad",
            name: "Bank / SSN Trust",
            note: "Payment and identity comfort.",
            items: [
                {
                    id: "no-bank",
                    title: "I’m not giving bank info",
                    signal: "bad",
                    script: `Understood. Carriers only draft after approval and you can cancel any time. Routing/account are safer than cards—banks give 5-day dispute protection. I can also set it to a prepaid bank if you prefer.`
                },
                {
                    id: "no-ssn",
                    title: "I’m not giving my SSN",
                    signal: "warn",
                    script: `SSN is how carriers run the medical/pharmacy check to approve you. It’s encrypted and only used for that approval. Without it they can’t issue coverage, but I can pause here if you’d like.`
                },
                {
                    id: "send-email",
                    title: "Can you email it and I’ll decide?",
                    signal: "info",
                    script: `I’ll email your summary, but approvals require live verification of health and identity. Let’s lock the option now; you can still cancel before it drafts. Sound fair?`
                }
            ]
        },
        {
            key: "timing",
            rank: 8,
            navSignal: "info",
            name: "Timing & Scheduling",
            note: "Busy, driving, or want to delay.",
            items: [
                {
                    id: "busy-driving",
                    title: "I’m busy / driving",
                    signal: "info",
                    script: `Safety first. I’ll grab two quick items, then we’ll schedule a 10-minute slot. Do mornings or evenings work better? I’ll text you the confirmation.`
                },
                {
                    id: "later-date",
                    title: "Call me in a few weeks",
                    signal: "warn",
                    script: `No problem. Rates are tied to age/health, so I’ll hold today’s rate and we’ll revisit on <date>. If you want, I can pre-fill everything so it’s a two-minute confirm.`
                },
                {
                    id: "not-today",
                    title: "Not deciding today",
                    signal: "info",
                    script: `Totally fine. My job is to show the safest option in your budget. I’ll outline Good/Better/Best with prices and email it. We only move forward if one fits.`
                }
            ]
        }
    ];

    const rbNav = document.getElementById("rbNav");
    const prosperNav = document.getElementById("prosperNav");
    const rbContent = document.getElementById("rbContent");
    const rbSearch = document.getElementById("rbSearch") || { value: "" };
    const rbTone = document.getElementById("rbTone") || { value: "" };
    const rbCount = document.getElementById("rbCount");
    const catCount = document.getElementById("catCount");
    const prosperCount = document.getElementById("prosperCount");
    const contentCount = document.getElementById("contentCount");
    const contentSub = document.getElementById("contentSub");
    const btnClearAll = document.getElementById("btnClearAll");
    const shellEl = document.querySelector("#rbShell .shell");
    const rbNavArrow = document.getElementById("rbNavArrow");
    const prosperNavArrow = document.getElementById("prosperNavArrow");
    const prosperUrl = '@Url.Action("FinalExpense", "Workstation")';
    const defaultProsperId = "sec-aged";

    let activeCategoryKey = null;
    let activeProsperId = defaultProsperId;
    let activePane = "prosper";
    let initializedDefaultProsper = false;
    let prosperSections = [];
    let prosperLoaded = false;
    let prosperLoadFailed = false;

    function escapeHtml(v){
        return String(v || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;");
    }

    function highlightText(text, search){
        const safe = escapeHtml(text);
        if(!search) return safe;
        const escapedSearch = search.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
        const regex = new RegExp("(" + escapedSearch + ")", "ig");
        return safe.replace(regex, '<mark class="hit">$1</mark>');
    }

    function stripHtml(html){
        const el = document.createElement("div");
        el.innerHTML = html || "";
        return (el.textContent || el.innerText || "").trim();
    }

    function getSignalLabel(signal){
        if(signal === "good") return "GO";
        if(signal === "warn") return "CLARIFY";
        if(signal === "bad") return "STOP";
        return "INFO";
    }

    function getFilteredCategories(){
        const searchVal = (rbSearch.value || "").trim().toLowerCase();
        const toneVal = rbTone.value || "";

        return categories
            .map(cat => {
                const filteredItems = cat.items.filter(item => {
                    const hay = [cat.name, cat.note, item.title, item.script].join(" ").toLowerCase();
                    const matchesSearch = !searchVal || hay.includes(searchVal);
                    const matchesTone = !toneVal || item.signal === toneVal;
                    return matchesSearch && matchesTone;
                });

                return {
                    ...cat,
                    items: filteredItems
                };
            })
            .filter(cat => cat.items.length > 0)
            .sort((a,b) => a.rank - b.rank);
    }

    function getFilteredProsperSections(){
        const searchVal = (rbSearch.value || "").trim().toLowerCase();
        const toneVal = rbTone.value || "";

        return prosperSections.filter(section => {
            const hay = [section.stepLabel, section.flowLabel, section.title, section.sub, section.searchText]
                .join(" ")
                .toLowerCase();
            const matchesSearch = !searchVal || hay.includes(searchVal);
            const matchesTone = !toneVal || section.signal === toneVal;
            return matchesSearch && matchesTone;
        });
    }

    function ensureActiveSelection(){
        const filteredCategories = getFilteredCategories();
        const filteredProsper = getFilteredProsperSections();

        if(!activeCategoryKey || !filteredCategories.some(x => x.key === activeCategoryKey)){
            activeCategoryKey = filteredCategories[0]?.key || null;
        }

        if(filteredProsper.some(x => x.id === defaultProsperId)){
            if(!initializedDefaultProsper){
                activePane = "prosper";
                activeProsperId = defaultProsperId;
                initializedDefaultProsper = true;
            } else if(activePane === "prosper" && (!activeProsperId || !filteredProsper.some(x => x.id === activeProsperId))){
                activeProsperId = defaultProsperId;
            }
        }

        if(!activeProsperId || !filteredProsper.some(x => x.id === activeProsperId)){
            activeProsperId = filteredProsper[0]?.id || null;
        }

        if(activePane === "rebuttal" && !activeCategoryKey && activeProsperId){
            activePane = "prosper";
        } else if(activePane === "prosper" && !activeProsperId && activeCategoryKey){
            activePane = "rebuttal";
        }
    }

    function renderNav(){
        const filteredCategories = getFilteredCategories();

        rbNav.innerHTML = "";
        catCount.textContent = String(filteredCategories.length);

        if(!filteredCategories.length){
            rbNav.innerHTML = `<div class="content-empty small">No rebuttal categories matched your search.</div>`;
            return;
        }

        filteredCategories.forEach(cat => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = `cat-btn ${cat.navSignal}${cat.key === activeCategoryKey ? " active" : ""}`;
            btn.innerHTML = `
                <div class="cat-top">
                    <div style="display:flex; align-items:center; gap:10px; min-width:0;">
                        <div class="cat-rank">${cat.rank}</div>
                        <div class="cat-name">${highlightText(cat.name, (rbSearch.value || "").trim())}</div>
                    </div>
                    <span class="cat-count">${cat.items.length}</span>
                </div>
                <div class="cat-note">${highlightText(cat.note, (rbSearch.value || "").trim())}</div>
            `;
            btn.addEventListener("click", function(){
                activePane = "rebuttal";
                activeCategoryKey = cat.key;
                rerenderAll();
            });
            rbNav.appendChild(btn);
        });
    }

    function renderProsperNav(){
        prosperNav.innerHTML = "";
        prosperCount.textContent = "0";

        if(!prosperLoaded && !prosperLoadFailed){
            prosperNav.innerHTML = `<div class="content-empty small">Loading Final Expense script steps…</div>`;
            return;
        }

        if(prosperLoadFailed){
            prosperNav.innerHTML = `<div class="content-empty small">Final Expense script steps could not be loaded right now.</div>`;
            return;
        }

        const filteredProsper = getFilteredProsperSections();
        prosperCount.textContent = String(filteredProsper.length);

        if(!filteredProsper.length){
            prosperNav.innerHTML = `<div class="content-empty small">No Final Expense steps matched your search.</div>`;
            return;
        }

        filteredProsper.forEach(section => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = `cat-btn ${section.signal}${section.id === activeProsperId ? " active" : ""}`;
            btn.innerHTML = `
                <div class="cat-top-single">${highlightText(section.title, (rbSearch.value || "").trim())}</div>
            `;
            btn.addEventListener("click", function(){
                activePane = "prosper";
                activeProsperId = section.id;
                rerenderAll();
            });
            prosperNav.appendChild(btn);
        });
    }

    function renderRebuttalContent(){
        const filteredCategories = getFilteredCategories();
        const activeCategory = filteredCategories.find(x => x.key === activeCategoryKey);

        if(!activeCategory){
            rbContent.innerHTML = `<div class="content-empty">Pick a rebuttal category on the left or a Final Expense step on the right.</div>`;
            rbCount.textContent = "0";
            contentCount.textContent = "0 scripts";
            contentSub.textContent = "No category selected.";
            return;
        }

        const searchVal = (rbSearch.value || "").trim();
        rbCount.textContent = String(activeCategory.items.length);
        contentCount.textContent = `${activeCategory.items.length} scripts`;
        contentSub.textContent = activeCategory.name;

        let html = `
            <div class="section-head">
                <h2 class="section-title">${highlightText(activeCategory.name, searchVal)}</h2>
                <p class="section-copy">${highlightText(activeCategory.note, searchVal)}</p>
            </div>
        `;

        activeCategory.items.forEach(item => {
            html += `
                <div class="objection ${item.signal}">
                    <div class="objection-head">
                        <h3 class="objection-title">${highlightText(item.title, searchVal)}</h3>
                        <span class="mini-tag ${item.signal}">${getSignalLabel(item.signal)}</span>
                    </div>
                    <div class="objection-body">
                        <pre class="script">${highlightText(item.script, searchVal)}</pre>
                    </div>
                </div>
            `;
        });

        rbContent.innerHTML = html;
    }

    function renderProsperContent(){
        if(!prosperLoaded && !prosperLoadFailed){
            rbContent.innerHTML = `<div class="content-empty">Loading final expense steps…</div>`;
            rbCount.textContent = "0";
            contentCount.textContent = "0 steps";
            contentSub.textContent = "Final Expense Guide";
            return;
        }

        if(prosperLoadFailed){
            rbContent.innerHTML = `<div class="content-empty">Final Expense steps could not be loaded.</div>`;
            rbCount.textContent = "0";
            contentCount.textContent = "0 steps";
            contentSub.textContent = "Final Expense Guide";
            return;
        }

        const filteredProsper = getFilteredProsperSections();
        const activeSection = filteredProsper.find(x => x.id === activeProsperId);

        if(!activeSection){
            rbContent.innerHTML = `<div class="content-empty">Pick a Final Expense step on the right to load it here.</div>`;
            rbCount.textContent = "0";
            contentCount.textContent = "0 steps";
            contentSub.textContent = "Final Expense Guide";
            return;
        }

        rbCount.textContent = "1";
        contentCount.textContent = `Step ${activeSection.step}`;
        contentSub.textContent = "Final Expense Guide";

        rbContent.innerHTML = `
            <div class="prosper-stage ${activeSection.signal}">
                <div class="prosper-stage-head">
                    <div>
                        <p class="prosper-step">${escapeHtml(activeSection.stepLabel)}</p>
                        <h2 class="prosper-title">${highlightText(activeSection.title, (rbSearch.value || "").trim())}</h2>
                        <p class="prosper-sub">${highlightText(activeSection.sub || "Selected step from the final expense guide.", (rbSearch.value || "").trim())}</p>
                    </div>
                    <span class="mini-tag ${activeSection.signal}">${getSignalLabel(activeSection.signal)}</span>
                </div>
                <div class="prosper-body">${activeSection.bodyHtml}</div>
            </div>
        `;
    }

    function renderContent(){
        if(activePane === "prosper"){
            renderProsperContent();
            return;
        }

        renderRebuttalContent();
    }

    function positionRailArrow(navEl, arrowEl, side){
        if(!navEl || !arrowEl || !shellEl){
            return;
        }

        const activeBtn = navEl.querySelector(".cat-btn.active");
        const navCard = navEl.closest(".nav-card");

        if(!activeBtn || !navCard){
            arrowEl.style.opacity = "0";
            return;
        }

        const shellRect = shellEl.getBoundingClientRect();
        const btnRect = activeBtn.getBoundingClientRect();
        const cardRect = navCard.getBoundingClientRect();
        const arrowSize = arrowEl.offsetHeight || 42;
        const top = btnRect.top - shellRect.top + ((btnRect.height - arrowSize) / 2);

        if(side === "left"){
            const left = cardRect.left - shellRect.left - 52;
            arrowEl.style.left = `${left}px`;
        } else {
            const left = cardRect.right - shellRect.left + 10;
            arrowEl.style.left = `${left}px`;
        }

        arrowEl.style.top = `${top}px`;
        arrowEl.style.opacity = "1";
    }

    function updateRailArrows(){
        positionRailArrow(rbNav, rbNavArrow, "left");
        positionRailArrow(prosperNav, prosperNavArrow, "right");
    }

    function rerenderAll(){
        ensureActiveSelection();
        renderNav();
        renderProsperNav();
        renderContent();
        updateRailArrows();
    }

    async function loadProsperSections(){
        try{
            const response = await fetch(prosperUrl, {
                credentials: "same-origin"
            });

            if(!response.ok){
                throw new Error("Unable to load Final Expense guide.");
            }

            const html = await response.text();
            const doc = new DOMParser().parseFromString(html, "text/html");
            const nodes = Array.from(doc.querySelectorAll("#mpCard > details.section"));

            prosperSections = nodes.map((node, index) => {
                const step = (node.getAttribute("data-step") || String(index + 1)).trim();
                const signal = (node.getAttribute("data-signal") || "good").trim();
                const flow = (node.getAttribute("data-flow") || "").trim();
                const title = (node.querySelector(".title")?.textContent || `Step ${step}`).trim();
                const sub = (node.querySelector(".sub")?.textContent || "").trim();
                const bodyHtml = node.querySelector(".body")?.innerHTML || "";

                return {
                    id: node.id || `prosper-step-${index + 1}`,
                    step,
                    stepLabel: `Step ${step}${flow ? " · " + flow.replace(/-/g, " ") : ""}`,
                    signal,
                    flowLabel: flow ? flow.replace(/-/g, " ") : "",
                    title,
                    sub,
                    bodyHtml,
                    searchText: stripHtml(bodyHtml)
                };
            });

            prosperLoaded = true;
            prosperLoadFailed = false;
            if(prosperSections.some(section => section.id === defaultProsperId)){
                activePane = "prosper";
                activeProsperId = defaultProsperId;
                initializedDefaultProsper = true;
            }
        } catch (error){
            prosperSections = [];
            prosperLoaded = false;
            prosperLoadFailed = true;
        }

        rerenderAll();
    }

    if(rbSearch.addEventListener){
        rbSearch.addEventListener("input", rerenderAll);
    }

    if(rbTone.addEventListener){
        rbTone.addEventListener("change", rerenderAll);
    }
    prosperNav.addEventListener("scroll", updateRailArrows);
    window.addEventListener("resize", updateRailArrows);

    if(btnClearAll){
        btnClearAll.addEventListener("click", function(){
            rbSearch.value = "";
            rbTone.value = "";
            activeCategoryKey = null;
            activeProsperId = defaultProsperId;
            activePane = "prosper";
            initializedDefaultProsper = false;
            rerenderAll();
        });
    }

    rbContent.addEventListener("click", function(event){
        const jumpBtn = event.target.closest("[data-jump]");
        if(!jumpBtn) return;

        const target = jumpBtn.getAttribute("data-jump") || "";
        if(!target.startsWith("#")) return;

        const targetId = target.slice(1);
        if(!prosperSections.some(section => section.id === targetId)) return;

        event.preventDefault();
        activePane = "prosper";
        activeProsperId = targetId;
        rerenderAll();
        rbContent.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    rerenderAll();
    loadProsperSections();
})();
</script>
