@await Html.PartialAsync("~/Views/Shared/_UnderwritingForm.cshtml", viewData: new ViewDataDictionary(ViewData) { { "UwSubtitle", "Underwriting Intake — Life Insurance" }, { "UwProduct", "LIFE" } })

<div class="proposal-overlay" id="proposalOverlay" hidden>
    <div class="proposal-dialog" id="proposalDialog" role="dialog" aria-modal="true" aria-labelledby="proposalTitle">
        <div class="uw-head">
            <div class="uw-brand">
                <img src="~/images/company-icons/protect.png" alt="Legend logo" class="uw-logo" />
                <div>
                    <div class="uw-name" id="proposalTitle">Proposal Builder</div>
                    <div class="uw-sub">Compare side-by-side options</div>
                </div>
            </div>
            <button type="button" class="uw-close" data-proposal-close aria-label="Close proposal builder">×</button>
        </div>

        <form id="proposalForm" class="proposal-form">
            <div class="proposal-meta">
                <label class="uw-field uw-span-2">Proposal Name
                    <input id="propName" name="propName" placeholder="Client name or label" />
                </label>
                <div class="proposal-actions-inline">
                    <button type="submit" class="btn gold" id="btnSaveProposal">Save Proposal</button>
                    <button type="button" class="btn btn-ghost" id="btnCaptureDecision" data-bs-toggle="modal" data-bs-target="#captureDecisionModal">Capture Decision</button>
                    <button type="button" class="btn btn-ghost" data-proposal-close>Cancel</button>
                </div>
            </div>

            <div class="proposal-latest-decision" id="latestDecisionSummary" hidden style="margin-bottom:12px; border:1px solid rgba(255,255,255,.08); border-radius:10px; padding:10px; background:#0f1629;">
                <div class="tiny text-muted">Latest decision</div>
                <div class="fw-bold" data-decision-title>-</div>
                <div class="tiny" data-decision-type></div>
                <div class="small" data-decision-rationale></div>
                <div class="tiny text-muted" data-decision-time></div>
            </div>

            <div class="proposal-buckets">
                @for (var i = 1; i <= 3; i++)
                {
                    <div class="proposal-bucket" data-bucket="@i">
                        <div class="pb-head">Option @i</div>
                        <label class="uw-field">Insurance Carrier
                            <select class="prop-carrier" id="propCarrier@i">
                                <option value="">Select carrier</option>
                                <option>Banner Life</option>
                                <option>Protective</option>
                                <option>Pacific Life</option>
                                <option>Symetra</option>
                                <option>Lincoln Financial</option>
                                <option>John Hancock</option>
                                <option>Prudential</option>
                                <option>Nationwide</option>
                                <option>Mutual of Omaha</option>
                                <option>Foresters Financial</option>
                                <option>American General (AIG/Corebridge)</option>
                                <option>Brighthouse</option>
                                <option>North American</option>
                                <option>Other</option>
                            </select>
                        </label>
                        <label class="uw-field">Term
                            <select class="prop-term" id="propTerm@i">
                                <option value="">N/A</option>
                                <option>10 Year</option>
                                <option>15 Year</option>
                                <option>20 Year</option>
                                <option>30 Year</option>
                                <option>40 Year</option>
                            </select>
                        </label>
                        <label class="uw-field">Type
                            <select class="prop-type" id="propType@i">
                                <option value="">Select</option>
                                <option value="Term">Term</option>
                                <option value="Whole Life">Whole Life</option>
                                <option value="Universal Life">Universal Life</option>
                                <option value="Indexed UL">IUL</option>
                                <option value="Final Expense">Final Expense</option>
                            </select>
                        </label>
                        @for (var r = 1; r <= 3; r++)
                        {
                            <div class="pb-row">
                                <label class="uw-field">Death Benefit @r
                                    <div class="currency-wrap">
                                        <span>$</span>
                                        <input class="prop-benefit currency-input" id="propBenefit@i@r" inputmode="decimal" />
                                    </div>
                                </label>
                                <label class="uw-field">Premium @r
                                    <div class="currency-wrap">
                                        <span>$</span>
                                        <input class="prop-premium currency-input" id="propPremium@i@r" inputmode="decimal" />
                                        <span class="suffix">/mo</span>
                                    </div>
                                </label>
                            </div>
                        }
                    </div>
                }
            </div>
        </form>
    </div>
</div>

<script>
(function(){
        const categories = [
        {
            key: "opening-pushback",
            rank: 1,
            navSignal: "bad",
            name: "Opening Pushback",
            note: "When they think this is just sales or already talked to someone.",
            items: [
                {
                    id: "not-interested",
                    title: "I’m not interested / just shopping",
                    signal: "bad",
                    script: `<Name>, got it. I’m the licensed underwriter assigned to the request you sent in for life coverage. My job is to verify income/beneficiaries and show options that fit the budget. Give me 60 seconds; if it’s not useful we stop. Fair?`
                },
                {
                    id: "already-spoke",
                    title: "I already spoke with someone",
                    signal: "warn",
                    script: `Perfect—let me double-check they sized it right. If what you have is solid I’ll say so. If there’s a gap (term ending, too small, no living benefits) I’ll show a tighter fit. Sound good?`
                },
                {
                    id: "who-are-you",
                    title: "Who are you / what company?",
                    signal: "info",
                    script: `I’m <your name>, licensed in <state>. I shop multiple carriers to match health and budget and sign off that it pays when it should. Not captive to one company.`
                },
                {
                    id: "no-appointment",
                    title: "Not booking today",
                    signal: "warn",
                    script: `No pressure. I’ll map Good/Better/Best with prices. If none fit, we’re done. If one fits, we lock it so the rate doesn’t move.`
                }
            ]
        },
        {
            key: "price-budget",
            rank: 2,
            navSignal: "warn",
            name: "Price & Budget",
            note: "Affordability, drafts, and price-locks.",
            items: [
                {
                    id: "too-expensive",
                    title: "Sounds expensive",
                    signal: "warn",
                    script: `We size to your comfort number. I’ll show a lean option and a full income replacement. You pick what fits cash flow.`
                },
                {
                    id: "rates-go-up",
                    title: "Will rates go up?",
                    signal: "info",
                    script: `We use level term or permanent—price and coverage stay fixed. The only time it changes is if you ask to add more.`
                },
                {
                    id: "cheapest-only",
                    title: "Just give me the cheapest",
                    signal: "warn",
                    script: `Cheapest can expire before you need it. I’ll show rock-bottom term and a price-locked option with living benefits. You choose.`
                },
                {
                    id: "draft-date",
                    title: "Draft after payday",
                    signal: "info",
                    script: `Yes. We anchor the draft to your payday so it never bounces. What day works best?`
                }
            ]
        },
        {
            key: "existing-coverage",
            rank: 3,
            navSignal: "info",
            name: "Existing Coverage",
            note: "Work benefits, old term, and replacement fears.",
            items: [
                {
                    id: "work-coverage",
                    title: "I have life insurance through work",
                    signal: "warn",
                    script: `Great while you’re employed. It usually ends or shrinks when you leave, retire, or get sick. We set a portable policy that stays with you and your family.`
                },
                {
                    id: "already-have-policy",
                    title: "I already have a policy",
                    signal: "info",
                    script: `Let’s verify it’s level and lasts long enough. If it ends before you do, we add a supplemental piece. If it’s perfect, I’ll say so.`
                },
                {
                    id: "no-replacement",
                    title: "I don’t want to replace mine",
                    signal: "warn",
                    script: `Not here to replace a good plan. If we can lower cost, add living benefits, or extend length without hurting you, I’ll show it; otherwise we leave yours as is.`
                }
            ]
        },
        {
            key: "health-underwriting",
            rank: 4,
            navSignal: "good",
            name: "Health & Underwriting",
            note: "Exams, nicotine, meds, approvals.",
            items: [
                {
                    id: "no-exam",
                    title: "I don’t want an exam",
                    signal: "info",
                    script: `We start with no-exam carriers that use prescription history and a few yes/no questions. If labs save you money, it’s a quick 15-minute nurse visit—your call.`
                },
                {
                    id: "health-issues",
                    title: "My health isn’t great",
                    signal: "warn",
                    script: `We place diabetes, BP, even past cancer with the right carrier. Worst case we start smaller or graded and ladder up later. Let me match you so it actually gets approved.`
                },
                {
                    id: "nicotine",
                    title: "I use nicotine / vape",
                    signal: "info",
                    script: `Some carriers treat occasional cigars/vape differently than daily smoking. I’ll code it honestly where you’re priced best so you’re not overpaying.`
                }
            ]
        },
        {
            key: "decision-makers",
            rank: 5,
            navSignal: "info",
            name: "Spouse & Decision",
            note: "Looping in spouse or partner.",
            items: [
                {
                    id: "talk-to-spouse",
                    title: "Need to talk to my spouse",
                    signal: "info",
                    script: `Absolutely. I’ll send a one-page summary with Good/Better/Best. We can hop back on together to tweak—keeps momentum without locking you in.`
                },
                {
                    id: "spouse-not-here",
                    title: "Spouse isn’t here",
                    signal: "info",
                    script: `We can pre-approve and add them as beneficiary, then add their coverage when they’re present. That locks pricing while you both decide.`
                },
                {
                    id: "spouse-covered",
                    title: "My spouse already has coverage",
                    signal: "warn",
                    script: `Great. This piece is about your income. If either of you is missing, the household loses income. We size yours so the bills stay paid either way.`
                }
            ]
        },
        {
            key: "timing-availability",
            rank: 6,
            navSignal: "info",
            name: "Timing & Availability",
            note: "Busy, driving, or pushing it out.",
            items: [
                {
                    id: "busy-call-back",
                    title: "I’m busy / at work",
                    signal: "info",
                    script: `No worries. It’s ~10 minutes to lock pricing. Mornings or evenings better? I’ll text a calendar link and hold the rate.`
                },
                {
                    id: "driving",
                    title: "I’m driving",
                    signal: "info",
                    script: `Safety first. I’ll text my credentials and a time slot. We’ll do the full review when you’re parked so nothing is missed.`
                },
                {
                    id: "later",
                    title: "Maybe next month",
                    signal: "warn",
                    script: `We can schedule for <date> and hold today’s quote. If health or age changes, the held quote protects you. Fair?`
                }
            ]
        },
        {
            key: "bank-trust",
            rank: 7,
            navSignal: "bad",
            name: "Bank / SSN Trust",
            note: "Identity and payment comfort.",
            items: [
                {
                    id: "no-ssn",
                    title: "Not giving SSN",
                    signal: "bad",
                    script: `Carriers need SSN for identity and medical/pharmacy checks to approve coverage. It’s encrypted and not used to bill. Without it they won’t issue the policy, but we can pause if you’re not comfortable.`
                },
                {
                    id: "no-bank",
                    title: "Not giving bank info",
                    signal: "warn",
                    script: `Drafts start only after approval and you can cancel anytime. Routing/account has fraud protection and dispute rights. If you prefer, we can use a secondary account.`
                },
                {
                    id: "email-first",
                    title: "Email it, I’ll decide later",
                    signal: "info",
                    script: `I’ll email the summary, but approval needs live health/ID. We can lock it now; you still get a free-look period before any draft.`
                }
            ]
        },
        {
            key: "coverage-design",
            rank: 8,
            navSignal: "info",
            name: "Coverage Purpose",
            note: "Term vs permanent, amounts, beneficiaries.",
            items: [
                {
                    id: "term-vs-perm",
                    title: "Term vs permanent",
                    signal: "info",
                    script: `Term is low cost for a set period (10/20/30 yrs). Permanent never expires and can build cash. We can blend: core permanent plus term for bigger years.`
                },
                {
                    id: "how-much",
                    title: "How much do I really need?",
                    signal: "info",
                    script: `Rule of thumb: 10–15x annual income for income replacement, or just debts + a few years of income if budget is tight. I’ll show both.`
                },
                {
                    id: "beneficiary",
                    title: "Kids are grown / use a trust",
                    signal: "info",
                    script: `You can list adults, a trust, or split percentages. This money is tax-free to beneficiaries and outside probate when set up right. I’ll note your preference on the app.`
                }
            ]
        }
    ];

    const rbNav = document.getElementById("rbNav");
    const prosperNav = document.getElementById("prosperNav");
    const rbContent = document.getElementById("rbContent");
    const rbSearch = document.getElementById("rbSearch") || { value: "" };
    const rbTone = document.getElementById("rbTone") || { value: "" };
    const rbCount = document.getElementById("rbCount");
    const catCount = document.getElementById("catCount");
    const prosperCount = document.getElementById("prosperCount");
    const contentCount = document.getElementById("contentCount");
    const contentSub = document.getElementById("contentSub");
    const btnClearAll = document.getElementById("btnClearAll");
    const shellEl = document.querySelector("#rbShell .shell");
    const rbNavArrow = document.getElementById("rbNavArrow");
    const prosperNavArrow = document.getElementById("prosperNavArrow");
    const prosperUrl = '@Url.Action("LifeInsurance", "Workstation")';
    const defaultProsperId = "sec-aged";

    let activeCategoryKey = null;
    let activeProsperId = defaultProsperId;
    let activePane = "prosper";
    let initializedDefaultProsper = false;
    let prosperSections = [];
    let prosperLoaded = false;
    let prosperLoadFailed = false;

    function escapeHtml(v){
        return String(v || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;");
    }

    function highlightText(text, search){
        const safe = escapeHtml(text);
        if(!search) return safe;
        const escapedSearch = search.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
        const regex = new RegExp("(" + escapedSearch + ")", "ig");
        return safe.replace(regex, '<mark class="hit">$1</mark>');
    }

    function stripHtml(html){
        const el = document.createElement("div");
        el.innerHTML = html || "";
        return (el.textContent || el.innerText || "").trim();
    }

    function getSignalLabel(signal){
        if(signal === "good") return "GO";
        if(signal === "warn") return "CLARIFY";
        if(signal === "bad") return "STOP";
        return "INFO";
    }

    function getFilteredCategories(){
        const searchVal = (rbSearch.value || "").trim().toLowerCase();
        const toneVal = rbTone.value || "";

        return categories
            .map(cat => {
                const filteredItems = cat.items.filter(item => {
                    const hay = [cat.name, cat.note, item.title, item.script].join(" ").toLowerCase();
                    const matchesSearch = !searchVal || hay.includes(searchVal);
                    const matchesTone = !toneVal || item.signal === toneVal;
                    return matchesSearch && matchesTone;
                });

                return {
                    ...cat,
                    items: filteredItems
                };
            })
            .filter(cat => cat.items.length > 0)
            .sort((a,b) => a.rank - b.rank);
    }

    function getFilteredProsperSections(){
        const searchVal = (rbSearch.value || "").trim().toLowerCase();
        const toneVal = rbTone.value || "";

        return prosperSections.filter(section => {
            const hay = [section.stepLabel, section.flowLabel, section.title, section.sub, section.searchText]
                .join(" ")
                .toLowerCase();
            const matchesSearch = !searchVal || hay.includes(searchVal);
            const matchesTone = !toneVal || section.signal === toneVal;
            return matchesSearch && matchesTone;
        });
    }

    function ensureActiveSelection(){
        const filteredCategories = getFilteredCategories();
        const filteredProsper = getFilteredProsperSections();

        if(!activeCategoryKey || !filteredCategories.some(x => x.key === activeCategoryKey)){
            activeCategoryKey = filteredCategories[0]?.key || null;
        }

        if(filteredProsper.some(x => x.id === defaultProsperId)){
            if(!initializedDefaultProsper){
                activePane = "prosper";
                activeProsperId = defaultProsperId;
                initializedDefaultProsper = true;
            } else if(activePane === "prosper" && (!activeProsperId || !filteredProsper.some(x => x.id === activeProsperId))){
                activeProsperId = defaultProsperId;
            }
        }

        if(!activeProsperId || !filteredProsper.some(x => x.id === activeProsperId)){
            activeProsperId = filteredProsper[0]?.id || null;
        }

        if(activePane === "rebuttal" && !activeCategoryKey && activeProsperId){
            activePane = "prosper";
        } else if(activePane === "prosper" && !activeProsperId && activeCategoryKey){
            activePane = "rebuttal";
        }
    }

    function renderNav(){
        const filteredCategories = getFilteredCategories();

        rbNav.innerHTML = "";
        catCount.textContent = String(filteredCategories.length);

        if(!filteredCategories.length){
            rbNav.innerHTML = `<div class="content-empty small">No rebuttal categories matched your search.</div>`;
            return;
        }

        filteredCategories.forEach(cat => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = `cat-btn ${cat.navSignal}${cat.key === activeCategoryKey ? " active" : ""}`;
            btn.innerHTML = `
                <div class="cat-top">
                    <div style="display:flex; align-items:center; gap:10px; min-width:0;">
                        <div class="cat-rank">${cat.rank}</div>
                        <div class="cat-name">${highlightText(cat.name, (rbSearch.value || "").trim())}</div>
                    </div>
                    <span class="cat-count">${cat.items.length}</span>
                </div>
                <div class="cat-note">${highlightText(cat.note, (rbSearch.value || "").trim())}</div>
            `;
            btn.addEventListener("click", function(){
                activePane = "rebuttal";
                activeCategoryKey = cat.key;
                rerenderAll();
            });
            rbNav.appendChild(btn);
        });
    }

    function renderProsperNav(){
        prosperNav.innerHTML = "";
        prosperCount.textContent = "0";

        if(!prosperLoaded && !prosperLoadFailed){
            prosperNav.innerHTML = `<div class="content-empty small">Loading Life Insurance script steps…</div>`;
            return;
        }

        if(prosperLoadFailed){
            prosperNav.innerHTML = `<div class="content-empty small">Life Insurance script steps could not be loaded right now.</div>`;
            return;
        }

        const filteredProsper = getFilteredProsperSections();
        prosperCount.textContent = String(filteredProsper.length);

        if(!filteredProsper.length){
            prosperNav.innerHTML = `<div class="content-empty small">No Life Insurance steps matched your search.</div>`;
            return;
        }

        filteredProsper.forEach(section => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = `cat-btn ${section.signal}${section.id === activeProsperId ? " active" : ""}`;
            btn.innerHTML = `
                <div class="cat-top-single">${highlightText(section.title, (rbSearch.value || "").trim())}</div>
            `;
            btn.addEventListener("click", function(){
                activePane = "prosper";
                activeProsperId = section.id;
                rerenderAll();
            });
            prosperNav.appendChild(btn);
        });
    }

    function renderRebuttalContent(){
        const filteredCategories = getFilteredCategories();
        const activeCategory = filteredCategories.find(x => x.key === activeCategoryKey);

        if(!activeCategory){
            rbContent.innerHTML = `<div class="content-empty">Pick a rebuttal category on the left or a Life Insurance step on the right.</div>`;
            rbCount.textContent = "0";
            contentCount.textContent = "0 scripts";
            contentSub.textContent = "No category selected.";
            return;
        }

        const searchVal = (rbSearch.value || "").trim();
        rbCount.textContent = String(activeCategory.items.length);
        contentCount.textContent = `${activeCategory.items.length} scripts`;
        contentSub.textContent = activeCategory.name;

        let html = `
            <div class="section-head">
                <h2 class="section-title">${highlightText(activeCategory.name, searchVal)}</h2>
                <p class="section-copy">${highlightText(activeCategory.note, searchVal)}</p>
            </div>
        `;

        activeCategory.items.forEach(item => {
            html += `
                <div class="objection ${item.signal}">
                    <div class="objection-head">
                        <h3 class="objection-title">${highlightText(item.title, searchVal)}</h3>
                        <span class="mini-tag ${item.signal}">${getSignalLabel(item.signal)}</span>
                    </div>
                    <div class="objection-body">
                        <pre class="script">${highlightText(item.script, searchVal)}</pre>
                    </div>
                </div>
            `;
        });

        rbContent.innerHTML = html;
    }

    function renderProsperContent(){
        if(!prosperLoaded && !prosperLoadFailed){
            rbContent.innerHTML = `<div class="content-empty">Loading life insurance steps…</div>`;
            rbCount.textContent = "0";
            contentCount.textContent = "0 steps";
            contentSub.textContent = "Life Insurance Guide";
            return;
        }

        if(prosperLoadFailed){
            rbContent.innerHTML = `<div class="content-empty">Life Insurance steps could not be loaded.</div>`;
            rbCount.textContent = "0";
            contentCount.textContent = "0 steps";
            contentSub.textContent = "Life Insurance Guide";
            return;
        }

        const filteredProsper = getFilteredProsperSections();
        const activeSection = filteredProsper.find(x => x.id === activeProsperId);

        if(!activeSection){
            rbContent.innerHTML = `<div class="content-empty">Pick a Life Insurance step on the right to load it here.</div>`;
            rbCount.textContent = "0";
            contentCount.textContent = "0 steps";
            contentSub.textContent = "Life Insurance Guide";
            return;
        }

        rbCount.textContent = "1";
        contentCount.textContent = `Step ${activeSection.step}`;
        contentSub.textContent = "Life Insurance Guide";

        rbContent.innerHTML = `
            <div class="prosper-stage ${activeSection.signal}">
                <div class="prosper-stage-head">
                    <div>
                        <p class="prosper-step">${escapeHtml(activeSection.stepLabel)}</p>
                        <h2 class="prosper-title">${highlightText(activeSection.title, (rbSearch.value || "").trim())}</h2>
                        <p class="prosper-sub">${highlightText(activeSection.sub || "Selected step from the life insurance guide.", (rbSearch.value || "").trim())}</p>
                    </div>
                    <span class="mini-tag ${activeSection.signal}">${getSignalLabel(activeSection.signal)}</span>
                </div>
                <div class="prosper-body">${activeSection.bodyHtml}</div>
            </div>
        `;
    }

    function renderContent(){
        if(activePane === "prosper"){
            renderProsperContent();
            return;
        }

        renderRebuttalContent();
    }

    function positionRailArrow(navEl, arrowEl, side){
        if(!navEl || !arrowEl || !shellEl){
            return;
        }

        const activeBtn = navEl.querySelector(".cat-btn.active");
        const navCard = navEl.closest(".nav-card");

        if(!activeBtn || !navCard){
            arrowEl.style.opacity = "0";
            return;
        }

        const shellRect = shellEl.getBoundingClientRect();
        const btnRect = activeBtn.getBoundingClientRect();
        const cardRect = navCard.getBoundingClientRect();
        const arrowSize = arrowEl.offsetHeight || 42;
        const top = btnRect.top - shellRect.top + ((btnRect.height - arrowSize) / 2);

        if(side === "left"){
            const left = cardRect.left - shellRect.left - 52;
            arrowEl.style.left = `${left}px`;
        } else {
            const left = cardRect.right - shellRect.left + 10;
            arrowEl.style.left = `${left}px`;
        }

        arrowEl.style.top = `${top}px`;
        arrowEl.style.opacity = "1";
    }

    function updateRailArrows(){
        positionRailArrow(rbNav, rbNavArrow, "left");
        positionRailArrow(prosperNav, prosperNavArrow, "right");
    }

    function rerenderAll(){
        ensureActiveSelection();
        renderNav();
        renderProsperNav();
        renderContent();
        updateRailArrows();
    }

    async function loadProsperSections(){
        try{
            const response = await fetch(prosperUrl, {
                credentials: "same-origin"
            });

            if(!response.ok){
                throw new Error("Unable to load Life Insurance guide.");
            }

            const html = await response.text();
            const doc = new DOMParser().parseFromString(html, "text/html");
            const nodes = Array.from(doc.querySelectorAll("#mpCard > details.section"));

            prosperSections = nodes.map((node, index) => {
                const step = (node.getAttribute("data-step") || String(index + 1)).trim();
                const signal = (node.getAttribute("data-signal") || "good").trim();
                const flow = (node.getAttribute("data-flow") || "").trim();
                const title = (node.querySelector(".title")?.textContent || `Step ${step}`).trim();
                const sub = (node.querySelector(".sub")?.textContent || "").trim();
                const bodyHtml = node.querySelector(".body")?.innerHTML || "";

                return {
                    id: node.id || `prosper-step-${index + 1}`,
                    step,
                    stepLabel: `Step ${step}${flow ? " · " + flow.replace(/-/g, " ") : ""}`,
                    signal,
                    flowLabel: flow ? flow.replace(/-/g, " ") : "",
                    title,
                    sub,
                    bodyHtml,
                    searchText: stripHtml(bodyHtml)
                };
            });

            prosperLoaded = true;
            prosperLoadFailed = false;
            if(prosperSections.some(section => section.id === defaultProsperId)){
                activePane = "prosper";
                activeProsperId = defaultProsperId;
                initializedDefaultProsper = true;
            }
        } catch (error){
            prosperSections = [];
            prosperLoaded = false;
            prosperLoadFailed = true;
        }

        rerenderAll();
    }

    if(rbSearch.addEventListener){
        rbSearch.addEventListener("input", rerenderAll);
    }

    if(rbTone.addEventListener){
        rbTone.addEventListener("change", rerenderAll);
    }
    prosperNav.addEventListener("scroll", updateRailArrows);
    window.addEventListener("resize", updateRailArrows);

    if(btnClearAll){
        btnClearAll.addEventListener("click", function(){
            rbSearch.value = "";
            rbTone.value = "";
            activeCategoryKey = null;
            activeProsperId = defaultProsperId;
            activePane = "prosper";
            initializedDefaultProsper = false;
            rerenderAll();
        });
    }

    rbContent.addEventListener("click", function(event){
        const jumpBtn = event.target.closest("[data-jump]");
        if(!jumpBtn) return;

        const target = jumpBtn.getAttribute("data-jump") || "";
        if(!target.startsWith("#")) return;

        const targetId = target.slice(1);
        if(!prosperSections.some(section => section.id === targetId)) return;

        event.preventDefault();
        activePane = "prosper";
        activeProsperId = targetId;
        rerenderAll();
        rbContent.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    rerenderAll();
    loadProsperSections();
})();
</script>
