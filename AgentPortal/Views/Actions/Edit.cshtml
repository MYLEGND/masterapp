@model Domain.Entities.ActionItem
@using Domain.Enums
@{
    ViewData["Title"] = "Edit Action";
}

<div class="container mt-4">
    <h3>Edit Action</h3>
    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <div class="mb-3">
            <label class="form-label">Title</label>
            <input class="form-control" name="Title" value="@Model.Title" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" name="Description" rows="3">@Model.Description</textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Due Date (UTC)</label>
            <input type="datetime-local" class="form-control" name="DueDateUtc" value="@(Model.DueDateUtc?.ToString("yyyy-MM-ddTHH:mm"))" />
        </div>
        <div class="mb-3">
            <label class="form-label">Priority</label>
            <select class="form-select" name="Priority">
@foreach (var p in Enum.GetValues<ActionPriority>())
{
    <option value="@p" selected="@(Model.Priority == p ? "selected" : null)">@p</option>
}
            </select>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-secondary" href="javascript:history.back()">Cancel</a>
        </div>
    </form>
</div>
