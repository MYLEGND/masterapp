@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@using Microsoft.AspNetCore.Mvc.Controllers
@using System.IO
@using Microsoft.EntityFrameworkCore
@using Infrastructure.Data
@inject IHttpContextAccessor HttpContextAccessor
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject MasterAppDbContext Db

@{
    var routeClientUserId = ViewContext.RouteData.Values["clientUserId"]?.ToString() ?? "";
    var queryClientUserId = Context.Request.Query["clientUserId"].ToString() ?? "";
    var bagClientUserId = (string?)ViewBag.ClientUserId ?? "";

    var clientUserId = !string.IsNullOrWhiteSpace(bagClientUserId)
        ? bagClientUserId.Trim()
        : !string.IsNullOrWhiteSpace(routeClientUserId)
            ? routeClientUserId.Trim()
            : queryClientUserId.Trim();

    var clientDisplayName =
        ((string?)ViewBag.ClientDisplayName
        ?? (string?)ViewBag.ClientName
        ?? "Client Workspace").Trim();

    var currentController =
        (ViewContext.ActionDescriptor as ControllerActionDescriptor)?.ControllerName ?? "";

    var currentAction =
        (ViewContext.ActionDescriptor as ControllerActionDescriptor)?.ActionName ?? "";

    string ActiveWorkspace(string actionName) =>
        string.Equals(currentController, "ClientWorkspace", StringComparison.OrdinalIgnoreCase) &&
        string.Equals(currentAction, actionName, StringComparison.OrdinalIgnoreCase)
            ? "active"
            : "";

    string ActiveFinance() =>
        string.Equals(currentController, "Finance", StringComparison.OrdinalIgnoreCase)
            ? "active"
            : "";

    string ActiveClientsProfile() =>
        string.Equals(currentController, "Clients", StringComparison.OrdinalIgnoreCase)
            ? "active"
            : "";

    // Agent info for transparency pill
    var agentName = "";
    var agentNpn = "";
    if (!string.IsNullOrWhiteSpace(clientUserId))
    {
        var link = Db.AgentClients
            .AsNoTracking()
            .FirstOrDefault(x => (x.ClientUserId ?? "").ToLower() == clientUserId.ToLower());

        if (link != null && !string.IsNullOrWhiteSpace(link.AgentUserId))
        {
            var profile = Db.AgentProfiles
                .AsNoTracking()
                .FirstOrDefault(x => x.AgentUserId == link.AgentUserId);

            agentName = profile?.FullName;
            if (string.IsNullOrWhiteSpace(agentName))
                agentName = string.IsNullOrWhiteSpace(link.AgentUpn) ? "Your Agent" : link.AgentUpn;

            agentNpn = profile?.Npn ?? "";
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Html.Raw(ViewData["Title"]) - Legend™</title>
    <meta http-equiv="cache-control" content="no-cache, no-store, must-revalidate" />
    <meta http-equiv="pragma" content="no-cache" />
    <meta http-equiv="expires" content="0" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AgentPortal.styles.css" asp-append-version="true" />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="~/images/favicon/favicon.png" asp-append-version="true" />

    <style>
        body { background-color: #fff; color: #000; font-family: 'Inter', sans-serif; }

