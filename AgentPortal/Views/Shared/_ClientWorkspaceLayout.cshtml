        }

        .footer-link{
            color: #a68023;
            font-weight: 600;
            text-decoration: none;
            transition: all .2s ease;
        }

        .footer-link:hover{
            color: #a68023;
            text-decoration: underline;
        }

        .layout-content { padding-top: 2rem; padding-bottom: 3rem; }

        @@media (max-width: 576px) {
            .navbar {
                padding: 1rem 1rem;
                align-items: flex-start;
            }

            .navbar-brand img {
                height: auto;
                max-height: 52px;
                filter: drop-shadow(0 4px 10px rgba(0,0,0,.25));
            }

            header .navbar .container-fluid {
                display: flex !important;
                flex-direction: column;
                align-items: stretch !important;
                gap: .75rem;
            }

            header .navbar .navbar-left {
                margin-left: 0;
                width: 100%;
            }

            header .navbar .navbar-left .nav-row {
                justify-content: center;
                gap: .5rem;
                flex-wrap: wrap;
            }

            .header-psalms {
                position: static;
                transform: none;
                top: auto;
                left: auto;
                width: 100%;
                max-width: 100%;
                margin-top: .25rem;
                text-align: center;
                font-size: 1.05rem;
                white-space: normal;
            }

            .navbar-right {
                width: 100%;
                justify-content: center;
                flex-wrap: wrap;
                min-width: 0;
            }

            .explore-trigger{
                top: 215px;
                left: 12px;
            }

            .explore-drawer{
                top: 215px;
                left: 70px;
            }
        }

        @@media (min-width: 577px) and (max-width: 992px) {
            .navbar { max-height: none; }

            header .navbar .container-fluid {
                display: flex !important;
                flex-wrap: wrap;
                align-items: center !important;
                gap: .75rem;
            }

            .header-psalms {
                position: static;
                transform: none;
                width: 100%;
                max-width: 100%;
                text-align: center;
                margin-top: .25rem;
                white-space: normal;
                font-size: 1.1rem;
            }

            header .navbar .navbar-left {
                margin-left: 0;
                flex: 1 1 520px;
            }

            header .navbar .navbar-left .nav-row {
                flex-wrap: wrap;
            }

            .navbar-right {
                flex: 0 0 auto;
            }
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">

<header>
    <nav class="navbar navbar-expand-sm navbar-light">
        <div class="container-fluid d-flex flex-wrap align-items-start justify-content-between">

            <a class="navbar-brand" asp-controller="Clients" asp-action="Index">
                <img src="~/images/company-icons/legend-protect-transparent.png" asp-append-version="true" alt="Legend™" />
            </a>

            <div class="navbar-left">
                <div class="nav-rows-grid">
                    <ul class="navbar-nav nav-row">
                        <li class="nav-item">
                            <a class="nav-link @(ActiveClientsProfile())"
                               asp-controller="Clients"
                               asp-action="Edit"
                               asp-route-clientUserId="@clientUserId">
                                Profile
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @(ActiveFinance())"
                               asp-controller="Finance"
                               asp-action="Index"
                               asp-route-clientUserId="@clientUserId">
                                Finance
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link @(ActiveWorkspace("Resources") == "active" || ActiveWorkspace("Training") == "active" ? "active" : "")">Explore More</a>
                            <div class="dropdown-menu-centered">
                                <a class="dropdown-item"
                                   asp-controller="ClientWorkspace"
                                   asp-action="Resources"
                                   asp-route-clientUserId="@clientUserId">
                                    Resources
                                </a>

                                <a class="dropdown-item"
                                   asp-controller="ClientWorkspace"
                                   asp-action="Training"
                                   asp-route-clientUserId="@clientUserId">
                                    Trainings
                                </a>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="header-psalms">
                CLIENT WORKSPACE | @clientDisplayName
            </div>

            <div class="navbar-right">
            @if (!string.IsNullOrWhiteSpace(agentName) || !string.IsNullOrWhiteSpace(agentNpn))
            {
                <div class="agent-pill" aria-label="Assigned agent">
                    <span class="agent-name">@agentName</span>
                    @if (!string.IsNullOrWhiteSpace(agentNpn))
                    {
                        <span class="npn-chip">NPN - @agentNpn</span>
                    }
                </div>
            }
            @{
                    var user = HttpContextAccessor.HttpContext?.User;
                    string? CleanToken(string? s)
                    {
                        if (string.IsNullOrWhiteSpace(s)) return null;
                        var t = s.Trim();
                        if (t.Contains("@")) return null;
                        if (t.Contains(".")) return null;
                        var parts = t.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        return parts.Length > 0 ? parts[0] : null;
                    }
                    string? Initial(string? s)
                    {
                        if (string.IsNullOrWhiteSpace(s)) return null;
                        var t = s.Trim();
                        return t.Length > 0 ? t.Substring(0, 1).ToUpperInvariant() : null;
                    }

                    var displayName = "Agent";
                    string? first = null;
                    string? last = null;
                    string? avatarUrl = null;
                    string? userId = null;

                    if (user?.Identity != null && user.Identity.IsAuthenticated)
                    {
                        first =
                            CleanToken(user.FindFirst("given_name")?.Value)
                            ?? CleanToken(user.FindFirst(ClaimTypes.GivenName)?.Value)
                            ?? CleanToken(user.FindFirst("name")?.Value);

                        last =
                            CleanToken(user.FindFirst("family_name")?.Value)
                            ?? CleanToken(user.FindFirst(ClaimTypes.Surname)?.Value);

                        userId =
                            user.FindFirst("oid")?.Value
                            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value
                            ?? user.Identity?.Name;

                        displayName =
                            user.FindFirst("name")?.Value
                            ?? user.FindFirst(ClaimTypes.Name)?.Value
                            ?? first
                            ?? "Agent";

                        avatarUrl =
                            user.FindFirst("picture")?.Value
                            ?? user.FindFirst("photo")?.Value
                            ?? user.FindFirst("avatar")?.Value
                            ?? user.FindFirst("avatar_url")?.Value
                            ?? user.FindFirst("profile_image")?.Value
                            ?? user.FindFirst("image")?.Value;
                    }

                    var initials = (Initial(first) ?? "") + (Initial(last) ?? "");
                    if (string.IsNullOrWhiteSpace(initials))
                    {
                        initials = Initial(displayName) ?? "A";
                    }

                    if (avatarUrl == null && !string.IsNullOrWhiteSpace(userId))
                    {
                        avatarUrl = Url.Action("Current", "Avatar");
                    }
                }

                <div class="workspace-actions-group">
                    <span class="workspace-badge">Managing: @clientDisplayName</span>

                    <a class="nav-link"
                       asp-controller="Clients"
                       asp-action="Index">
                        Back to Clients
                    </a>

                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline nav-link-button">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link nav-link">Logout</button>
                    </form>
                </div>

                <div class="workspace-account-group">
                    <a class="profile-chip" title="@displayName" asp-controller="Account" asp-action="ManageProfile">
                        <div class="profile-avatar">
                            @if (!string.IsNullOrWhiteSpace(avatarUrl))
                            {
                                <img src="@avatarUrl" alt="Profile photo" loading="lazy" />
                            }
                            else
                            {
                                <span>@initials</span>
                            }
                        </div>
                        <div class="profile-meta">
                            <span class="profile-name">@displayName</span>
                            <span class="visually-hidden">Edit picture</span>
                        </div>
                    </a>
                </div>
            </div>

        </div>
    </nav>
</header>

<div id="exploreOverlay" class="explore-overlay" aria-hidden="true"></div>

<button id="exploreTrigger"
        type="button"
        class="explore-trigger"
        aria-label="Open Explore"
        aria-controls="exploreDrawer"
        aria-expanded="false">
    <div class="explore-bars" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
    </div>
</button>

<aside id="exploreDrawer" class="explore-drawer" aria-label="Explore Panel">
    <div class="explore-card">
        <div class="explore-header">
            <div class="explore-title">EXPLORE</div>
            <div class="explore-pill">Quick Find</div>
        </div>

        <div class="explore-search">
            <input id="exploreSearch"
                   type="text"
                   placeholder="Search Explore..."
                   autocomplete="off"
                   aria-label="Search Explore" />
        </div>

        <div id="exploreList" class="explore-list">
            <a class="explore-item" data-tone="crm"
               asp-controller="Clients"
               asp-action="Edit"
               asp-route-clientUserId="@clientUserId">
                <span>Profile</span>
                <small>CRM</small>
            </a>

            <a class="explore-item" data-tone="finance"
               asp-controller="Finance"
               asp-action="Index"
               asp-route-clientUserId="@clientUserId">
                <span>Finance</span>
                <small>Money</small>
            </a>

            <a class="explore-item" data-tone="library"
               asp-controller="ClientWorkspace"
               asp-action="Resources"
               asp-route-clientUserId="@clientUserId">
                <span>Resources</span>
                <small>Library</small>
            </a>

            <a class="explore-item" data-tone="growth"
               asp-controller="ClientWorkspace"
               asp-action="Training"
               asp-route-clientUserId="@clientUserId">
                <span>Trainings</span>
                <small>Growth</small>
            </a>
        </div>
    </div>
</aside>

<div class="container layout-content flex-grow-1">
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="footer mt-auto py-3">
    <div class="container text-center">
        &copy; 2025 - MYLEGND, LLC. All rights reserved.
        <br />
        <a href="https://protect.mylegnd.com/Terms" target="_blank" rel="noopener" class="footer-link">Terms</a>
        <span aria-hidden="true">•</span>
        <a href="https://protect.mylegnd.com/Privacy" target="_blank" rel="noopener" class="footer-link">Privacy</a>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    // Safety net: ensure jQuery exists before validation/unobtrusive plugins run.
    if (typeof window.jQuery === "undefined") {
        document.write('<script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"><\\/script>');
    }
</script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    (function () {
        const trigger = document.getElementById('exploreTrigger');
        const drawer = document.getElementById('exploreDrawer');
        const overlay = document.getElementById('exploreOverlay');
        const search = document.getElementById('exploreSearch');
        const list = document.getElementById('exploreList');

        if (!trigger || !drawer || !overlay || !search || !list) return;

        function openDrawer() {
            drawer.classList.add('open');
            overlay.classList.add('open');
            trigger.setAttribute('aria-expanded', 'true');
            window.setTimeout(() => search.focus(), 80);
        }

        function closeDrawer() {
            drawer.classList.remove('open');
            overlay.classList.remove('open');
            trigger.setAttribute('aria-expanded', 'false');
        }

        trigger.addEventListener('click', function () {
            if (drawer.classList.contains('open')) closeDrawer();
            else openDrawer();
        });

        overlay.addEventListener('click', closeDrawer);

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeDrawer();
        });

        search.addEventListener('input', function () {
            const q = (search.value || '').trim().toLowerCase();
            list.querySelectorAll('.explore-item').forEach(function (item) {
                const txt = item.textContent.toLowerCase();
                item.style.display = txt.includes(q) ? '' : 'none';
            });
        });
    })();
</script>
@await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/app-date-format.js" asp-append-version="true"></script>
</body>
</html>
