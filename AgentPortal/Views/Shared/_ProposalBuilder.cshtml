@using Microsoft.AspNetCore.Mvc.ViewFeatures
@{
    var includeLead = ViewData["ProposalIncludeLead"] as bool? ?? true;
    var includeClient = ViewData["ProposalIncludeClient"] as bool? ?? true;
    var includeScratch = ViewData["ProposalIncludeScratch"] as bool? ?? true;
}

<div class="hp-overlay" id="proposalOverlay" hidden>
    <div class="hp-dialog" id="proposalDialog" role="dialog" aria-modal="true" aria-labelledby="proposalTitle">
        <div class="hp-dialog-head">
            <div class="hp-dialog-brand">
                <div class="hp-dialog-icon">📋</div>
                <div>
                    <div class="hp-dialog-title" id="proposalTitle">Proposal Builder</div>
                    <div class="hp-dialog-sub">Compare side-by-side options for any client</div>
                </div>
            </div>
            <button type="button" class="hp-dialog-close" data-proposal-close aria-label="Close proposal builder">×</button>
        </div>

        <form id="proposalForm" class="hp-form">
            <div class="hp-form-meta">
                <label class="hp-field">Proposal Name
                    <input id="propName" name="propName" placeholder="Client name or label" />
                </label>
                <div class="hp-form-actions">
                    <button type="submit" class="hp-btn hp-btn-gold" id="btnSaveProposal">Save Proposal</button>
                    <button type="button" class="hp-btn hp-btn-ghost" id="btnCaptureDecision" data-bs-toggle="modal" data-bs-target="#captureDecisionModal">Capture Decision</button>
                    <button type="button" class="hp-btn hp-btn-ghost" data-proposal-close>Cancel</button>
                </div>
            </div>

            <div class="proposal-latest-decision" id="latestDecisionSummary" hidden style="margin-bottom:12px; border:1px solid rgba(255,255,255,.08); border-radius:10px; padding:10px; background:#0f1629;">
                <div class="tiny text-muted">Latest decision</div>
                <div class="fw-bold" data-decision-title>-</div>
                <div class="tiny" data-decision-type></div>
                <div class="small" data-decision-rationale></div>
                <div class="tiny text-muted" data-decision-time></div>
            </div>

            <div class="hp-builder-context">
                <div class="hp-builder-context-copy">
                    <span class="hp-builder-context-label">Builder Source</span>
                    <span class="hp-builder-context-value" data-proposal-context-label>Current lead</span>
                </div>
                <div class="hp-builder-context-actions">
                    @if (includeLead)
                    {
                        <button type="button" class="hp-btn hp-btn-ghost hp-btn-mini" data-proposal-source="lead">Lead</button>
                    }
                    @if (includeClient)
                    {
                        <button type="button" class="hp-btn hp-btn-ghost hp-btn-mini" data-proposal-source="client">Use Client</button>
                    }
                    @if (includeScratch)
                    {
                        <button type="button" class="hp-btn hp-btn-ghost hp-btn-mini" data-proposal-source="scratch">Scratch</button>
                    }
                </div>
            </div>

            <div class="hp-buckets">
                @for (var i = 1; i <= 3; i++)
                {
                    <div class="hp-bucket" data-bucket="@i">
                        <div class="hp-bucket-head">Option @i</div>
                        <label class="hp-field">Insurance Carrier
                            <select class="prop-carrier" id="propCarrier@i">
                                <option value="">Select carrier</option>
                                <option>Banner Life</option>
                                <option>Protective</option>
                                <option>Pacific Life</option>
                                <option>Symetra</option>
                                <option>Lincoln Financial</option>
                                <option>John Hancock</option>
                                <option>Prudential</option>
                                <option>Nationwide</option>
                                <option>Mutual of Omaha</option>
                                <option>Foresters Financial</option>
                                <option>American General (AIG/Corebridge)</option>
                                <option>Brighthouse</option>
                                <option>North American</option>
                                <option>Other</option>
                            </select>
                        </label>
                        <label class="hp-field">Term
                            <select class="prop-term" id="propTerm@i">
                                <option value="">N/A</option>
                                <option>10 Year</option>
                                <option>15 Year</option>
                                <option>20 Year</option>
                                <option>30 Year</option>
                                <option>40 Year</option>
                            </select>
                        </label>
                        <label class="hp-field">Type
                            <select class="prop-type" id="propType@i">
                                <option value="">Select</option>
                                <option value="Term">Term</option>
                                <option value="Whole Life">Whole Life</option>
                                <option value="Universal Life">Universal Life</option>
                                <option value="Indexed UL">IUL</option>
                                <option value="Final Expense">Final Expense</option>
                            </select>
                        </label>
                        @for (var r = 1; r <= 3; r++)
                        {
                            <div class="hp-row">
                                <label class="hp-field">Death Benefit @r
                                    <div class="hp-currency-wrap">
                                        <span class="hp-currency-sym">$</span>
                                        <input class="prop-benefit currency-input hp-currency-input" id="propBenefit@i@r" inputmode="decimal" />
                                    </div>
                                </label>
                                <label class="hp-field">Premium @r
                                    <div class="hp-currency-wrap">
                                        <span class="hp-currency-sym">$</span>
                                        <input class="prop-premium currency-input hp-currency-input" id="propPremium@i@r" inputmode="decimal" />
                                        <span class="hp-currency-sfx">/mo</span>
                                    </div>
                                </label>
                            </div>
                        }
                    </div>
                }
            </div>
        </form>
    </div>
</div>
