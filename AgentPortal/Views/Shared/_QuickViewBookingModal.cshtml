<div class="modal fade qv-booking-modal-shell" id="qvBookingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered qv-booking-dialog">
        <div class="modal-content qv-booking-content">
            <div class="qv-booking-head">
                <div class="qv-booking-head-copy">
                    <div class="qv-booking-kicker">Quick View Scheduler</div>
                    <h3 class="qv-booking-title">Book Appointment</h3>
                    <p class="qv-booking-sub" id="qvBookingClientSub">Pick a date, choose a free slot, and create the appointment without leaving Quick View.</p>
                </div>
                <button type="button" class="btn btn-ghost qv-booking-close" data-bs-dismiss="modal" aria-label="Close booking modal">Close</button>
            </div>

            <div class="qv-booking-body">
                <div class="qv-booking-record">
                    <div class="qv-booking-record-label">Booking for</div>
                    <div class="qv-booking-record-name" id="qvBookingClientLabel">Current contact</div>
                </div>

                <div class="qv-booking-shell">
                    <div class="qv-booking-controls">
                        <label class="qv-booking-field">
                            <span>Date</span>
                            <input id="qvBookDate" type="date" />
                        </label>
                        <label class="qv-booking-field">
                            <span>Duration</span>
                            <select id="qvBookDuration">
                                <option value="15">15 min</option>
                                <option value="30" selected>30 min</option>
                                <option value="45">45 min</option>
                                <option value="60">60 min</option>
                            </select>
                        </label>
                    </div>

                    <input id="qvBookTime" type="hidden" />

                    <div class="qv-booking-slot-card">
                        <div class="qv-booking-slot-head">
                            <div class="qv-booking-slot-title">Available times</div>
                            <div class="qv-booking-slot-note">Free Outlook slots for the date you choose.</div>
                        </div>
                        <div id="qvBookSlots" class="qv-book-slots"></div>
                    </div>

                    <div class="qv-booking-foot">
                        <span id="qvBookStatus" class="tiny qv-booking-status" aria-live="polite"></span>
                        <button type="button" id="btnBookAppointment" class="btn btn-gold qv-booking-submit">Book Appointment</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
