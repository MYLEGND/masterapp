<div class="modal fade qv-booking-modal-shell" id="qvBookingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered qv-booking-dialog">
        <div class="modal-content qv-booking-content">
            <div class="qv-booking-head">
                <div class="qv-booking-head-copy">
                    <div class="qv-booking-kicker">Quick View Scheduler</div>
                    <h3 class="qv-booking-title">Book Appointment</h3>
                    <p class="qv-booking-sub" id="qvBookingClientSub">Pick a date, choose a free slot, and create the appointment without leaving Quick View.</p>
                </div>
                <button type="button" class="btn btn-ghost qv-booking-close" data-bs-dismiss="modal" aria-label="Close booking modal">Close</button>
            </div>

            <div class="qv-booking-body">
                <div class="qv-booking-record">
                    <div class="qv-booking-record-label">Booking for</div>
                    <div class="qv-booking-record-name" id="qvBookingClientLabel">Current contact</div>
                </div>

                <div class="qv-booking-shell">
                    <input id="qvBookTime" type="hidden" />
                    <input id="qvBookDate" type="date" class="qv-booking-date-native" />

                    <div class="qv-booking-layout">
                        <aside class="qv-booking-sidebar">
                            <div class="qv-booking-panel qv-booking-panel-calendar">
                                <div class="qv-booking-panel-head">
                                    <div class="qv-booking-panel-copy">
                                        <div class="qv-booking-panel-kicker">Choose a day</div>
                                        <div class="qv-booking-panel-title">Pick your date.</div>
                                        <div class="qv-booking-panel-note">Move month to month and choose a day.</div>
                                    </div>

                                    <label class="qv-booking-field qv-booking-field-compact">
                                        <span>Duration</span>
                                        <select id="qvBookDuration">
                                            <option value="30" selected>Loading booking services…</option>
                                        </select>
                                    </label>
                                </div>

                                <div class="qv-booking-calendar-card">
                                    <div class="qv-booking-calendar-head">
                                        <button type="button" class="btn btn-ghost qv-booking-calendar-nav" id="qvBookPrevMonth" aria-label="Show previous month">Prev</button>
                                        <div class="qv-booking-calendar-label" id="qvBookingMonthLabel">Month</div>
                                        <button type="button" class="btn btn-ghost qv-booking-calendar-nav" id="qvBookNextMonth" aria-label="Show next month">Next</button>
                                    </div>

                                    <div class="qv-booking-calendar-weekdays" aria-hidden="true">
                                        <span>Sun</span>
                                        <span>Mon</span>
                                        <span>Tue</span>
                                        <span>Wed</span>
                                        <span>Thu</span>
                                        <span>Fri</span>
                                        <span>Sat</span>
                                    </div>

                                    <div id="qvBookingCalendar" class="qv-booking-calendar-grid" role="grid" aria-label="Choose appointment date"></div>
                                </div>
                            </div>

                            <div class="qv-booking-panel qv-booking-panel-selection">
                                <div class="qv-booking-panel-kicker">Selection</div>
                                <div class="qv-booking-selection-date" id="qvBookingSelectedDateLabel">Choose a date</div>
                                <div class="qv-booking-selection-meta" id="qvBookingSelectedMeta">Available times will update as soon as you switch dates or duration.</div>
                            </div>
                        </aside>

                        <section class="qv-booking-main">
                            <div class="qv-booking-slot-card">
                                <div class="qv-booking-slot-head">
                                    <div>
                                        <div class="qv-booking-slot-title">Available times</div>
                                        <div class="qv-booking-slot-note" id="qvBookingSlotNote">Open Outlook slots for the selected day appear here automatically.</div>
                                    </div>
                                    <div class="qv-booking-slot-focus" id="qvBookingSlotFocus">Pick a date</div>
                                </div>
                                <div id="qvBookSlots" class="qv-book-slots"></div>
                            </div>

                            <div class="qv-booking-foot">
                                <span id="qvBookStatus" class="tiny qv-booking-status" aria-live="polite"></span>
                                <button type="button" id="btnBookAppointment" class="btn btn-gold qv-booking-submit">Book Appointment</button>
                            </div>
                        </section>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
