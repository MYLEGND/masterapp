@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@using AgentPortal.Security
@using System.IO
@using Microsoft.EntityFrameworkCore
@using Infrastructure.Data
@inject IHttpContextAccessor HttpContextAccessor
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject MasterAppDbContext _db
@{
    var currentController =
        (ViewContext.ActionDescriptor as Microsoft.AspNetCore.Mvc.Controllers.ControllerActionDescriptor)?.ControllerName
        ?? "";

    string Active(string c) => string.Equals(c, currentController, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    var layoutRouteClientUserId = ViewContext.RouteData.Values["clientUserId"]?.ToString() ?? "";
    var layoutQueryClientUserId = Context.Request.Query["clientUserId"].ToString() ?? "";
    var layoutClientUserId = !string.IsNullOrWhiteSpace(layoutRouteClientUserId)
        ? layoutRouteClientUserId.Trim()
        : layoutQueryClientUserId.Trim();

    var isAssistant = false;
    if (Context.Items.TryGetValue("IsAssistant", out var assistantObj) && assistantObj is bool b)
    {
        isAssistant = b;
    }
    var impersonatedAgentId = Context.Items.TryGetValue("ImpersonatedAgentOid", out var impOid) ? impOid as string : null;
    var impersonatedAgentName = Context.Items.TryGetValue("ImpersonatedAgentName", out var impName) ? impName as string : null;
    var impersonatedAgentEmail = Context.Items.TryGetValue("ImpersonatedAgentEmail", out var impEmail) ? impEmail as string : null;
    string? impersonatedDisplay = null;
    var showImpersonatedId = false;
    if (!string.IsNullOrWhiteSpace(impersonatedAgentId))
    {
        impersonatedDisplay = impersonatedAgentName ?? impersonatedAgentEmail;
        if (string.IsNullOrWhiteSpace(impersonatedDisplay))
        {
            // Derive a friendly display name from the stored AgentProfile if available.
            var prof = _db.AgentProfiles.AsNoTracking().FirstOrDefault(x => x.AgentUserId == impersonatedAgentId);
            impersonatedDisplay = prof?.FullName ?? prof?.AgentUpn ?? impersonatedAgentId;
        }
        showImpersonatedId = string.IsNullOrWhiteSpace(impersonatedDisplay) ||
                             string.Equals(impersonatedDisplay, impersonatedAgentId, StringComparison.OrdinalIgnoreCase);
    }
    var isFounder = AgentPortal.Security.FounderGuard.IsFounder(User);
    var isOnboardingPublic = string.Equals(currentController, "OnboardingPublic", StringComparison.OrdinalIgnoreCase);
    var layoutBodyClass = "d-flex flex-column min-vh-100" + (isOnboardingPublic ? " onboarding-public-only" : "");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Html.Raw(ViewData["Title"]) - Legend™</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">

    <link rel="icon" type="image/png" href="~/images/favicon/favicon.png" asp-append-version="true" />

    @RenderSection("Styles", required: false)

    <style>
        :root{
            --legend-gold:#a68023;
            --legend-gold-deep:#a68023;
            --legend-gold-bright:#ddb457;
            --legend-line:rgba(166,128,35,.36);
            --legend-line-strong:rgba(166,128,35,.88);
            --legend-shadow:0 18px 38px rgba(64,47,11,.10);
            --legend-shadow-strong:0 24px 56px rgba(64,47,11,.16);
        }

        body {
            background: #ffffff;
            color: #151109;
            font-family: 'Inter', sans-serif;
        }

        .navbar {
            background: #0b1529 !important;
            border: 1.5px solid var(--legend-gold-deep) !important;
            padding: 2rem 2rem;
            display: flex;
            flex-wrap: wrap;
            align-items: flex-start;
            max-height: none;
            position: relative;
            box-shadow:
                0 18px 38px rgba(0,0,0,.28),
                inset 0 0 0 1px rgba(255,255,255,.06);
            border-radius: 18px;
            overflow: visible;
        }

        .navbar::before{
            content:"";
            position:absolute;
            left:0;
            right:0;
            top:0;
            height:4px;
            background: linear-gradient(90deg, #a68023, #c79931 24%, #ddb457 52%, #c79931 80%, #a68023);
            border-top-left-radius: 16px;
            border-top-right-radius: 16px;
        }

        .navbar-brand.disabled-logo {
            cursor: default;
            pointer-events: none;
        }

        .navbar-brand img {
            height: 100px;
            width: auto;
            max-height: 100px;
            filter: drop-shadow(0 8px 16px rgba(64,47,11,.10));
        }

        .navbar-left {
            display: flex;
            flex-direction: column;
            justify-content: center;
            margin-left: 1.5rem;
            height: 100%;
        }

        .navbar-left .nav-rows-grid {
            display: grid;
            row-gap: 0.5rem;
        }

        .navbar-left .nav-row {
            display: flex;
            gap: 2rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .navbar-left li { list-style: none; }

        .navbar-left .nav-link {
            font-weight: 900;
            color: #f8fafc !important;
            white-space: nowrap;
            padding: 0.7rem 1.35rem;
            border-radius: 50px;
            transition: all 0.25s ease;
            letter-spacing: 0.55px;
            border: 1.5px solid transparent;
            background: transparent;
        }

        .navbar-left .nav-link:hover,
        .navbar-left .nav-link.active {
            color: var(--legend-gold-bright) !important;
            background: rgba(166,128,35,0.12);
            border-color: rgba(166,128,35,.54);
            transform: translateY(-2px);
            box-shadow:
                0 14px 24px rgba(0,0,0,.22),
                inset 0 1px 0 rgba(255,255,255,.10);
        }

        /* =========================
           RIGHT NAV (HEADER ONLY)
           ========================= */

        .navbar-right {
            display: flex;
            width: auto;
            min-width: 360px;
            justify-content: flex-end;
            gap: 6px;
            align-items: center;
            margin-left: auto;
            position: relative;
            flex-wrap: nowrap;
            overflow: visible;
        }

        .navbar-right .nav-link,
        .navbar-right .btn-link {
            color: #f8fafc !important;
            font-weight: 900;
            transition: all 0.25s ease;
            white-space: nowrap;
            padding: .65rem 1.1rem;
            border-radius: 30px;
            border: 1.5px solid rgba(166,128,35,.52);
            background: transparent;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.10);
        }

        .navbar-right .nav-link:hover,
        .navbar-right .btn-link:hover {
            color: var(--legend-gold-bright) !important;
            background: rgba(166,128,35,0.12);
            border-color: rgba(166,128,35,.74);
            transform: translateY(-2px);
            box-shadow:
                0 14px 24px rgba(0,0,0,.22),
                inset 0 1px 0 rgba(255,255,255,.12);
        }

        .profile-chip {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 0.4rem 0.75rem;
            border-radius: 999px;
            border: 1.5px solid rgba(166,128,35,.72);
            background: #0f172a;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 10px 20px rgba(0,0,0,.32);
            text-decoration: none;
            color: #f8fafc;
            font-weight: 900;
            min-width: 150px;
        }

        .profile-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            overflow: hidden;
            border: 1.5px solid rgba(166,128,35,.45);
            background: linear-gradient(135deg, #0f172a, #1e293b);
            display: grid;
            place-items: center;
            color: #f8fafc;
            font-weight: 900;
            letter-spacing: .5px;
        }

        .profile-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .profile-meta {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }
        .profile-name { color: #f8fafc; font-weight: 900; }
        .profile-note { color: #cbd5e1; font-size: 0.8rem; font-weight: 800; }
        .profile-role-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 0.22rem 0.7rem;
            border-radius: 999px;
            background: #0f172a;
            color: #f8fafc;
            border: 1.6px solid var(--legend-gold-deep);
            font-weight: 800;
            letter-spacing: .02em;
            font-size: 0.78rem;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 8px 16px rgba(0,0,0,.12);
        }
        .profile-contact-menu a {
            font-weight: 800;
            padding: 8px 14px;
        }
        .profile-contact-menu .disabled {
            pointer-events: none;
            opacity: .55;
        }
        .profile-contact-menu {
            z-index: 9999;
            background: #0b1529;
            border: 1.6px solid var(--legend-gold-deep);
            border-radius: 12px;
            box-shadow: 0 16px 40px rgba(0,0,0,0.35);
        }
        .profile-contact-menu .dropdown-item {
            color: #f8fafc;
            font-weight: 800;
        }
        .profile-contact-menu .dropdown-item:hover {
            background: rgba(166,128,35,0.18);
            color: #f8fafc;
        }
        .profile-contact-menu .dropdown-divider {
            border-color: rgba(166,128,35,0.45);
        }

        /* Ensure all header dropdowns (including bootstrap default) keep the navy / gold theme */
        header .navbar .dropdown-menu {
            background: #0b1529;
            border: 1.6px solid var(--legend-gold-deep);
            color: #f8fafc;
            box-shadow: 0 16px 40px rgba(0,0,0,0.35);
            border-radius: 12px;
        }
        header .navbar .dropdown-menu .dropdown-item {
            color: #f8fafc;
            font-weight: 800;
        }
        header .navbar .dropdown-menu .dropdown-item:hover {
            background: rgba(166,128,35,0.18);
            color: #f8fafc;
        }
        header .navbar .dropdown-menu .dropdown-divider {
            border-color: rgba(166,128,35,0.45);
        }

        .header-psalms {
            position: absolute;
            top: 112px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 1.4rem;
            font-weight: 900;
            color: var(--legend-gold-bright);
            letter-spacing: 1.8px;
            text-align: center;
            font-family: 'Inter', sans-serif;
            padding: .55rem 1.2rem;
            border-radius: 999px;
            border: 1.5px solid rgba(166,128,35,.60);
            background: #0f172a;
            box-shadow:
                0 10px 22px rgba(0,0,0,.28),
                inset 0 1px 0 rgba(255,255,255,.08);
            cursor: pointer;
            transition: transform .15s ease, box-shadow .18s ease, background .18s ease;
        }

        .header-psalms:hover,
        .header-psalms:focus-visible {
            transform: translateX(-50%) translateY(-1px);
            box-shadow:
                0 14px 30px rgba(0,0,0,.32),
                inset 0 1px 0 rgba(255,255,255,.14);
            background: #111d33;
            outline: none;
        }

        .header-psalms:active {
            transform: translateX(-50%) translateY(0);
            box-shadow:
                0 8px 16px rgba(0,0,0,.28),
                inset 0 1px 0 rgba(255,255,255,.08);
            background: #0d172b;
        }

        .no-scroll {
            overflow: hidden;
        }

        .scripture-modal {
            position: fixed;
            inset: 0;
            background: rgba(8, 12, 24, 0.72);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .18s ease;
            z-index: 9999;
            padding: 16px;
        }

        .scripture-modal.open {
            opacity: 1;
            pointer-events: auto;
        }

        .scripture-card {
            width: min(760px, 96vw);
            background: #0b1529;
            color: #f8fafc;
            border-radius: 18px;
            border: 1.6px solid var(--legend-gold-deep);
            box-shadow: 0 28px 60px rgba(0,0,0,.44);
            padding: 20px 22px 16px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .scripture-card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
        }

        .scripture-day {
            font-size: .82rem;
            letter-spacing: 0.08em;
            color: rgba(255,255,255,.72);
            text-transform: uppercase;
        }

        .scripture-reference {
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--legend-gold-bright);
            letter-spacing: 0.04em;
        }

        .scripture-translation {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 10px;
            border-radius: 999px;
            border: 1px solid rgba(166,128,35,.60);
            background: rgba(255,255,255,.06);
            font-size: .85rem;
            color: #f8fafc;
            white-space: nowrap;
        }

        .scripture-close {
            background: transparent;
            color: #f8fafc;
            border: 1px solid rgba(255,255,255,.18);
            border-radius: 10px;
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            line-height: 1;
            transition: background .15s ease, transform .15s ease;
        }

        .scripture-close:hover,
        .scripture-close:focus-visible {
            background: rgba(255,255,255,.12);
            transform: translateY(-1px);
            outline: none;
        }

        .scripture-text {
            max-height: 60vh;
            overflow: auto;
            padding-right: 6px;
            line-height: 1.6;
            letter-spacing: 0.01em;
        }

        .scripture-text p {
            margin-bottom: 10px;
            color: #e2e8f0;
        }

        .scripture-text p:last-child {
            margin-bottom: 0;
        }

        .scripture-streak-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            border: 1px dashed rgba(166,128,35,.55);
            background: rgba(255,255,255,.04);
        }

        .scripture-streak-label {
            color: rgba(255,255,255,.76);
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            font-size: .8rem;
        }

        .scripture-streak-value {
            font-size: 1.3rem;
            font-weight: 900;
            letter-spacing: 0.04em;
        }

        .scripture-streak-note {
            color: rgba(255,255,255,.64);
            font-weight: 700;
            font-size: .85rem;
            margin-left: auto;
            white-space: nowrap;
        }
        }

        /* ===== MINI TOOLS (NOW USED IN MAIN CONTENT) ===== */
        .navbar-mini-tools {
            border: 1.5px solid rgba(166,128,35,.54);
            border-radius: 14px;
            padding: 1rem 1rem;
            width: 290px;
            background: #ffffff;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 0;
            box-shadow:
                0 16px 30px rgba(64,47,11,.10),
                inset 0 0 0 1px rgba(255,255,255,.82);
            position: relative;
        }

        .navbar-mini-tools img.outlook-link {
            height: 25px;
            width: 25px;
            flex-shrink: 0;
            transition: transform 0.2s ease;
        }

        .navbar-mini-tools img.outlook-link:hover {
            transform: translateY(-2px);
        }

        /* =========================
           EXPLORE (VERTICAL DRAWER)
           ========================= */

        /* Click-away overlay */
        .explore-overlay{
            position: fixed;
            inset: 0;
            z-index: 1098;
            background: transparent;
            display: none;
        }
        .explore-overlay.open{ display:block; }

        /* 3-line trigger OUTSIDE navbar */
        .explore-trigger{
            position: fixed;
            left: 18px;
            top: 185px;
            z-index: 1100;
            width: 54px;
            height: 54px;
            border-radius: 16px;
            border: 1.6px solid var(--legend-gold-deep);
            background: #0b1529;
            box-shadow:
                0 16px 34px rgba(0,0,0,.26),
                inset 0 0 0 1px rgba(255,255,255,.10);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .2s ease;
        }

        .explore-trigger:hover{
            transform: translateY(-2px) scale(1.01);
            border-color: rgba(166,128,35,.94);
            box-shadow:
                0 20px 42px rgba(0,0,0,.32),
                inset 0 0 0 1px rgba(255,255,255,.14);
        }

        .explore-bars{
            width: 18px;
            height: 14px;
            display: grid;
            gap: 3px;
        }

        .explore-bars span{
            display:block;
            height: 2.5px;
            border-radius: 999px;
            background: linear-gradient(90deg, #f8fafc, #ddb457);
            transition: all .2s ease;
            opacity: 1;
        }

        .explore-trigger:hover .explore-bars span{
            background: linear-gradient(90deg, #f8fafc, #efc866);
        }

        /* Drawer shell */
        .explore-drawer{
            position: fixed;
            left: 78px; /* sits beside trigger */
            top: 185px;
            z-index: 1099;
            width: 320px;
            max-width: calc(100vw - 36px);

            /* CLOSED: fully hidden (no peeking) */
            transform: translateX(-140%);
            transition: transform .25s ease;
            pointer-events: none;
        }

        .explore-drawer.open{
            transform: translateX(0);
            pointer-events: auto;
        }

        /* remove shadow when closed so nothing bleeds */
        .explore-drawer:not(.open) .explore-card{
            box-shadow: none;
        }

        /* Boxed banner matching top vibe */
        .explore-card{
            background: #0b1529;
            border: 1.5px solid rgba(166,128,35,.86);
            border-radius: 18px;
            box-shadow:
                0 22px 48px rgba(0,0,0,.30),
                inset 0 0 0 1px rgba(255,255,255,.08);
            overflow: hidden;
            position: relative;
        }

        .explore-card::before{
            content:"";
            position:absolute;
            left:0;
            right:0;
            top:0;
            height:4px;
            background: linear-gradient(90deg, #a68023, #c79931 26%, #efc866 54%, #c79931 80%, #a68023);
        }

        .explore-header{
            padding: 18px 18px 12px 18px;
            border-bottom: 1px solid rgba(166,128,35,.32);
            display:flex;
            align-items:center;
            justify-content: space-between;
            gap: 10px;
            background: #0b1529;
        }

        .explore-title{
            font-weight: 1000;
            letter-spacing: 1.2px;
            color: var(--legend-gold-bright);
            font-size: 1rem;
            white-space: nowrap;
        }

        .explore-pill{
            font-size: .74rem;
            font-weight: 900;
            color: var(--legend-gold-bright);
            background: #0f1d38;
            border: 1px solid rgba(166,128,35,.42);
            padding: 6px 11px;
            border-radius: 999px;
            white-space: nowrap;
            box-shadow: inset 0 0 0 1px rgba(255,255,255,.72);
        }

        .explore-search{
            padding: 14px 18px 10px 18px;
        }

        .explore-search input{
            width: 100%;
            border-radius: 999px;
            border: 1.5px solid rgba(166,128,35,.42);
            padding: 11px 15px;
            outline: none;
            font-weight: 800;
            transition: all .2s ease;
            background: #0f1d38;
            color:#f8fafc;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
        }

        .explore-search input:focus{
            border-color: rgba(166,128,35,.94);
            box-shadow: 0 0 0 4px rgba(166,128,35,.14), 0 12px 24px rgba(64,47,11,.08);
        }

        /* Scrollable list auto-adjusts */
        .explore-list{
            max-height: calc(100vh - 330px);
            overflow: auto;
            padding: 8px 12px 16px 12px;
        }

        .explore-item{
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            text-decoration: none;
            color: #f8fafc;
            font-weight: 900;
            transition: all .2s ease;
            margin: 6px 6px;
            border: 1px solid rgba(166,128,35,.38);
            background: #0f1d38;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
        }

        .explore-item:hover{
            color: var(--legend-gold-bright);
            background: rgba(166,128,35,.14);
            transform: translateY(-2px);
            border-color: rgba(166,128,35,.56);
            box-shadow: 0 14px 28px rgba(0,0,0,.24);
        }

        .explore-item span{
            display:block;
            font-size:.98rem;
            letter-spacing:.18px;
        }

        .explore-item small{
            font-weight: 900;
            white-space: nowrap;
            padding: 5px 10px;
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,.16);
            background: rgba(255,255,255,.06);
            color: #e2e8f0;
            letter-spacing: .35px;
            text-transform: uppercase;
            font-size: .67rem;
            box-shadow: inset 0 1px 0 rgba(255,255,255,.12);
        }

        .explore-item[data-tone="crm"] small{
            color:#2457c5;
            border-color:rgba(36,87,197,.28);
            background:linear-gradient(180deg, #f4f8ff, #e9f1ff);
        }

        .explore-item[data-tone="prospect"] small{
            color:#a05d12;
            border-color:rgba(160,93,18,.26);
            background:linear-gradient(180deg, #fff7ee, #ffecd7);
        }

        .explore-item[data-tone="forms"] small{
            color:#0d7d73;
            border-color:rgba(13,125,115,.24);
            background:linear-gradient(180deg, #f1fcfa, #e7f8f5);
        }

        .explore-item[data-tone="ops"] small{
            color:#1f8b49;
            border-color:rgba(31,139,73,.24);
            background:linear-gradient(180deg, #f3fbf6, #e8f7ed);
        }

        .explore-item[data-tone="network"] small{
            color:#7a3fe0;
            border-color:rgba(122,63,224,.24);
            background:linear-gradient(180deg, #f7f4ff, #efe9ff);
        }

        .explore-item[data-tone="library"] small{
            color:#a05d12;
            border-color:rgba(160,93,18,.24);
            background:linear-gradient(180deg, #fff8ef, #fff0dd);
        }

        .explore-item[data-tone="growth"] small{
            color:#9d4edd;
            border-color:rgba(157,78,221,.24);
            background:linear-gradient(180deg, #faf4ff, #f1e6ff);
        }

        .explore-item[data-tone="utility"] small{
            color:#4f6b1b;
            border-color:rgba(79,107,27,.24);
            background:linear-gradient(180deg, #f8fbeF, #eef5df);
        }

        /* Mobile-friendly */
        @@media (max-width: 576px){
