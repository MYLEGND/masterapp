@{
    var user = HttpContextAccessor.HttpContext?.User;

    string? CleanFirstToken(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return null;
        var t = s.Trim();

        // reject junk / non-human labels
        if (string.Equals(t, "connect", StringComparison.OrdinalIgnoreCase)) return null;
        if (string.Equals(t, "unknown", StringComparison.OrdinalIgnoreCase)) return null;

        // reject emails / UPNs
        if (t.Contains("@")) return null;

        // take first word
        var first = t.Split(' ', StringSplitOptions.RemoveEmptyEntries)[0];

        // reject identifiers like "zac.owen"
        if (first.Contains(".")) return null;

        // basic sanity
        if (first.Length < 2) return null;

        return first;
    }

    string? Initial(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return null;
        var trimmed = s.Trim();
        return trimmed.Length > 0 ? trimmed.Substring(0, 1).ToUpperInvariant() : null;
    }

    var name = "Agent";
    var displayName = "Agent";
    string? first = null;
    string? last = null;
    string? avatarUrl = null;
    string? userId = null;
    string? profileTitle = null;

    Domain.Entities.AgentProfile? agentProfile = null;

    if (user?.Identity?.IsAuthenticated == true)
    {
        // Best sources for first name
        first =
            CleanFirstToken(user.FindFirst(ClaimTypes.GivenName)?.Value)
            ?? CleanFirstToken(user.FindFirst("given_name")?.Value)
            ?? CleanFirstToken(user.FindFirst("first_name")?.Value);

        last =
            CleanFirstToken(user.FindFirst(ClaimTypes.Surname)?.Value)
            ?? CleanFirstToken(user.FindFirst("family_name")?.Value)
            ?? CleanFirstToken(user.FindFirst("last_name")?.Value);

        // Build display name: prefer explicit first+last; otherwise directory display name.
        var nameClaim =
            user.FindFirst("name")?.Value
            ?? user.FindFirst(ClaimTypes.Name)?.Value;

        if (!string.IsNullOrWhiteSpace(first) || !string.IsNullOrWhiteSpace(last))
        {
            displayName = string.Join(" ", new[] { first, last }.Where(x => !string.IsNullOrWhiteSpace(x)));
        }
        else if (!string.IsNullOrWhiteSpace(nameClaim))
        {
            displayName = nameClaim.Trim();
        }
        else
        {
            displayName = first ?? "Agent";
        }

        name = first ?? "Agent";

        userId =
            user.FindFirst("oid")?.Value
            ?? user.FindFirst(ClaimTypes.NameIdentifier)?.Value
            ?? user.Identity?.Name;

        avatarUrl =
            user.FindFirst("picture")?.Value
            ?? user.FindFirst("photo")?.Value
            ?? user.FindFirst("avatar")?.Value
            ?? user.FindFirst("avatar_url")?.Value
            ?? user.FindFirst("profile_image")?.Value
            ?? user.FindFirst("image")?.Value;

        // Pull agent profile to prefer stored full name (avoids showing email)
        agentProfile = _db.AgentProfiles.AsNoTracking().FirstOrDefault(x => x.AgentUserId == userId);
        if (agentProfile != null && !string.IsNullOrWhiteSpace(agentProfile.FullName))
        {
            displayName = agentProfile.FullName.Trim();
            // derive initials from stored full name if we lack first/last
            if (string.IsNullOrWhiteSpace(first))
            {
                var parts = agentProfile.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                if (parts.Length > 0) first = parts[0];
                if (parts.Length > 1) last = parts[^1];
            }
        }
        // If display name looks like an email, fall back to the token before '@'
        if (!string.IsNullOrWhiteSpace(displayName) && displayName.Contains("@"))
        {
            var beforeAt = displayName.Split('@')[0];
            if (!string.IsNullOrWhiteSpace(beforeAt))
                displayName = beforeAt;
        }

        profileTitle = agentProfile?.Title?.Trim();
    }

    var initials = (Initial(first) ?? "") + (Initial(last) ?? "");
    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = (Initial(displayName) ?? "A");
    }

    if (string.IsNullOrWhiteSpace(profileTitle))
    {
        profileTitle = isAssistant ? "Assistant" : "Agent";
    }

    if (avatarUrl == null && !string.IsNullOrWhiteSpace(userId))
    {
        avatarUrl = Url.Action("Current", "Avatar");
    }
}

