@model IEnumerable<Domain.Entities.Blocker>
@{
    var emptyMessage = ViewData["EmptyMessage"] as string ?? "No blockers. Keep momentum by clearing risks early.";
    var relatedEntityNames = ViewData["RelatedEntityNames"] as IDictionary<string, string>;
    string RelatedKey(Domain.Enums.RelatedEntityType t, string? id)
        => $"{(int)t}:{(id ?? string.Empty).Trim().ToLowerInvariant()}";
    string RelatedTypeLabel(Domain.Enums.RelatedEntityType t) => t switch
    {
        Domain.Enums.RelatedEntityType.Lead => "Lead Card",
        Domain.Enums.RelatedEntityType.Client => "Client Card",
        _ => "Related Card"
    };
}
<table class="table table-sm table-striped mb-0">
    <thead>
        <tr>
            <th>Reason</th>
            <th>Type</th>
            <th>Related</th>
            <th>Status</th>
            <th>Unblock By</th>
        </tr>
    </thead>
    <tbody>
    @if (Model == null || !Model.Any())
    {
        <tr><td colspan="5" class="text-muted">@emptyMessage</td></tr>
    }
    else
    {
        foreach (var b in Model)
        {
            var relatedKey = RelatedKey(b.RelatedEntityType, b.RelatedEntityId);
            string? relatedName = null;
            var hasRelated = relatedEntityNames != null && relatedEntityNames.TryGetValue(relatedKey, out relatedName) && !string.IsNullOrWhiteSpace(relatedName);
            <tr>
                <td>@b.BlockerReason</td>
                <td>@b.BlockerType</td>
                <td>
                    <div>@RelatedTypeLabel(b.RelatedEntityType)</div>
                    @if (hasRelated)
                    {
                        <div class="fw-semibold">@relatedName</div>
                    }
                    <div class="text-muted small">@b.RelatedEntityId</div>
                </td>
                <td>@b.Status</td>
                <td>@(b.UnblockDueDateUtc?.ToLocalTime().ToString("MM/dd"))</td>
            </tr>
        }
    }
    </tbody>
</table>
