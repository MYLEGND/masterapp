/* ===== Business Client dual-tool mode ===== */
body.finance-dual-tools-open .layout-content {
    width: 100% !important;
    max-width: none !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    overflow: visible !important;
}

body.finance-dual-tools-open main[role="main"] {
