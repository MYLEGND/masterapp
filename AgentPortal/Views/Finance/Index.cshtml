@{
    var clientUserId =
        ((string?)ViewBag.ClientUserId)?.Trim()
        ?? (Context.Request.Query["clientUserId"].ToString() ?? "").Trim();

    Layout = string.IsNullOrWhiteSpace(clientUserId)
        ? "~/Views/Shared/_Layout.cshtml"
        : "~/Views/Shared/_ClientWorkspaceLayout.cshtml";

    ViewData["Title"] = "Finance";
}

<link rel="stylesheet" href="~/css/legend-living-balance-sheet.css" asp-append-version="true" />

<div id="financeRoot"
     data-client-profile-id="@ViewBag.ClientProfileId"
     data-client-user-id="@clientUserId"
     data-is-business-client="@(((bool?)ViewBag.IsBusinessClient == true).ToString().ToLowerInvariant())"></div>
<form id="__af" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div class="container-fluid finance-shell mt-5">

    <!-- Header / Tool selection -->
    <div class="finance-header text-center mb-4">
        <div class="finance-subtitle">Pick a tool below — your goals, alerts, and calculators stay in sync.</div>

        <div class="finance-selector-row mt-3">
            <div class="finance-select-wrap">
                <select id="budgetDropdown" class="form-select finance-select shadow-sm">
                    <option value="">-- Select a tool --</option>
                </select>
            </div>
            <button type="button" class="btn finance-toolbar-btn" id="btnToggleSupportPanels">Goals + Alerts</button>
        </div>

        <div id="wfClientSearchHost" class="finance-search-host d-none mt-3">
            <div class="finance-search-card shadow-sm">
                <label class="form-label mb-1 fw-bold text-uppercase" style="letter-spacing:0.8px;">Search client</label>
                <div class="d-flex gap-2 flex-wrap align-items-center">
                    <input id="wfClientSearch" class="form-control form-control-sm" style="min-width:240px; max-width:320px;" placeholder="Type to search clients…" autocomplete="off" />
                    <button id="wfClientSearchBtn" class="btn btn-outline-dark btn-sm" type="button">Search</button>
                    <span id="wfPlanStatus" class="text-muted small">Type to search.</span>
                </div>
                <div id="wfClientResults" class="list-group mt-2" style="max-height:240px; overflow:auto; display:none;"></div>
            </div>
        </div>
    </div>

    <!-- Main tools layout -->
    <div class="row w-100 g-4 align-items-stretch finance-tools-row mx-auto">

        <div class="col-12 d-flex">
            <div id="budget-embed" class="finance-main w-100 flex-grow-1"></div>
        </div>

    </div>

    <div class="finance-support-overlay d-none" id="financeSupportPanels" aria-hidden="true">
        <div class="finance-support-backdrop" data-support-close="true"></div>
        <div class="finance-support-modal" role="dialog" aria-modal="true" aria-label="Goals and alerts">
            <div class="finance-support-modal-head">
                <strong>Goals &amp; Alerts</strong>
                <button type="button" class="btn finance-support-close" id="btnCloseSupportPanels" aria-label="Close">Close</button>
            </div>
            <div class="finance-support-grid">
                <div class="finance-action-container finance-side-card w-100">
                    <!-- Content injected via goals.js -->
                </div>
                <div class="finance-goals-container finance-side-card w-100">
                    <!-- Content injected via alerts.js -->
                </div>
            </div>
        </div>
    </div>

</div>

<!-- JS references (keep functionality the same) -->
<script src="~/js/dp-constants.js" asp-append-version="true"></script>
<script src="~/js/dp-validators.js" asp-append-version="true"></script>
<script src="~/js/dp-engine.js" asp-append-version="true"></script>
<script src="~/js/legend-living-balance-sheet.js" asp-append-version="true"></script>
<script src="~/js/finance-tools.js" asp-append-version="true"></script>
<script>
// Ensure LegendFinancePersistence is set before finance-profile.js runs
window.LegendFinancePersistence = window.LegendFinancePersistence || {
    loadState: async (key) => {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : {};
    },
    saveState: (key, state) => {
        localStorage.setItem(key, JSON.stringify(state || {}));
        return { ok: true };
    },
    clearState: (key) => {
        localStorage.removeItem(key);
    }
};
</script>
<script src="~/js/goals.js" asp-append-version="true"></script>
<script src="~/js/alerts.js" asp-append-version="true"></script>
<script>
document.addEventListener("DOMContentLoaded", () => {
    const supportPanels = document.getElementById("financeSupportPanels");
    const toggleButton = document.getElementById("btnToggleSupportPanels");
    const closeSupport = document.getElementById("btnCloseSupportPanels");
    if (!supportPanels) return;

    const setButtonState = (isOpen) => {
        if (!toggleButton) return;
        toggleButton.textContent = isOpen ? "Hide Goals + Alerts" : "Goals + Alerts";
        toggleButton.setAttribute("aria-pressed", isOpen ? "true" : "false");
    };

    const setOpenState = (isOpen) => {
        supportPanels.classList.toggle("d-none", !isOpen);
        supportPanels.setAttribute("aria-hidden", isOpen ? "false" : "true");
        document.body.classList.toggle("finance-support-open", isOpen);
        setButtonState(isOpen);
    };

    toggleButton?.addEventListener("click", () => setOpenState(supportPanels.classList.contains("d-none")));
    closeSupport?.addEventListener("click", () => setOpenState(false));
    supportPanels.querySelector("[data-support-close='true']")?.addEventListener("click", () => setOpenState(false));
    document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setOpenState(false);
    });
    setButtonState(false);
});
</script>

<style>
/* ============================================================
   FINANCE PAGE — mostly-white premium layout
   HARD GOLD lines everywhere: #a68023
   Clean shadows. Crisp edges. No gold flooding.
   ============================================================ */

:root{
    --gold:#a68023;                    /* ✅ HARD GOLD */
    --goldSoft: rgba(166,128,35,.12);  /* subtle glow only */
    --ink:#111;
    --muted: rgba(0,0,0,.62);
    --borderSoft: rgba(0,0,0,.10);
    --card:#fff;
    --shadowA: 0 18px 55px rgba(0,0,0,0.07);
    --shadowB: 0 22px 70px rgba(0,0,0,0.09);
    --radius: 20px;
}

/* ✅ Full viewport width with elegant gutters */
.finance-shell{
    width: 100%;
    max-width: 1800px;
    padding-left: clamp(12px, 2vw, 28px);
    padding-right: clamp(12px, 2vw, 28px);
    background: #ffffff;
}

/* Make the row truly span the shell */
.finance-tools-row{
    max-width: 1800px;
}

/* ============================================================
   Header — white card + HARD GOLD border (sharp)
   ============================================================ */
.finance-header{
    position: relative;
    padding: 22px 18px 18px;
    border-radius: 18px;

    /* ✅ HARD GOLD BORDER */
    border: 2px solid var(--gold);

    background: #ffffff;
    box-shadow: var(--shadowA);
}

/* tiny gold glow on header corner (subtle) */
.finance-header:before{
    content:"";
    position:absolute;
    inset:0;
    border-radius: 18px;
    pointer-events:none;
    background:
        radial-gradient(700px 240px at 18% 0%, var(--goldSoft), transparent 58%);
}

/* kicker pill — still clean */
.finance-kicker{
    display: inline-block;
    font-weight: 900;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    font-size: .78rem;
    color: #5a3b00;
    background: rgba(166,128,35,0.08);
    border: 2px solid var(--gold); /* ✅ hard border */
    padding: 6px 12px;
    border-radius: 999px;
}

.finance-title{
    margin-top: 10px !important;
    font-weight: 950;
    letter-spacing: .2px;
    color: #131313;
}

.finance-subtitle{
    margin-top: 8px;
    color: rgba(20,20,20,0.72);
    font-weight: 650;
    font-size: .98rem;
}

/* Dropdown wrapper */
.finance-select-wrap{
    position: relative;
    width: 100%;
    max-width: 560px;
}

.finance-select-wrap::after{
    content: "";
    position: absolute;
    top: 50%;
    right: 18px;
    width: 11px;
    height: 11px;
    border-right: 2px solid #f5f7fb;
    border-bottom: 2px solid #f5f7fb;
    transform: translateY(-62%) rotate(45deg);
    pointer-events: none;
    opacity: .92;
}

/* Dropdown styling — crisp gold border, sharp focus */
.finance-select{
    width: 100%;
    border: 2px solid var(--gold) !important; /* ✅ HARD GOLD */
    border-radius: 14px !important;
    padding: 12px 44px !important;
    font-weight: 900 !important;
    color: #1a1a1a !important;
    background: #ffffff !important;
    box-shadow: 0 10px 28px rgba(0,0,0,0.06) !important;
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background-image: none !important;
    text-align: center;
    text-align-last: center;
    cursor: pointer;
    transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
}

.finance-select option{
    text-align: center;
}

/* Finance Data drawer */
.finance-data-primary:hover{
    background:#ddb457;
    border-color:#ddb457;
}
.finance-data-secondary{
    border:2px solid rgba(166,128,35,.45);
    background: #0b1529;
    color:#f8fafc;
    font-weight:800;
    padding:10px 14px;
    border-radius:12px;
}
.finance-select:hover{
    transform: translateY(-1px);
    box-shadow: 0 14px 34px rgba(0,0,0,0.08) !important;
    filter: saturate(1.02);
}
.finance-select:focus{
    outline: none !important;
    border-color: var(--gold) !important;
    box-shadow:
        0 0 0 .22rem rgba(166,128,35,0.20),
        0 16px 40px rgba(0,0,0,0.08) !important;
}

.finance-search-card{
    border: 2px solid var(--gold);
    border-radius: 14px;
    background: #ffffff;
    padding: 14px 16px;
}

/* ============================================================
   Side cards — WHITE first, HARD GOLD border (sharp)
   ============================================================ */
.finance-side-card{
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: 520px;

    border-radius: var(--radius);

    /* ✅ HARD GOLD BORDER */
    border: 2px solid var(--gold) !important;

    background: #ffffff;
    box-shadow:
        0 20px 60px rgba(0,0,0,0.08),
        inset 0 1px 0 rgba(255,255,255,0.90);

    padding: 18px;
    overflow: hidden;
}

/* subtle gold corner glow (kept tasteful) */
.finance-side-card:before{
    content:"";
    position:absolute;
    inset:0;
    border-radius: var(--radius);
    pointer-events:none;
    background:
        radial-gradient(700px 260px at 12% 0%, var(--goldSoft), transparent 62%);
}

/* subtle inner highlight border (clean) */
.finance-side-card:after{
    content:"";
    position:absolute;
    inset:0;
    border-radius: var(--radius);
    pointer-events:none;
    border: 1px solid rgba(255,255,255,0.55);
}

/* Make injected content area scroll nicely on large screens */
@@media (min-width: 1200px) {
  .finance-side-card {
    max-height: calc(100vh - 250px);
    overflow-y: auto;
    overscroll-behavior: contain;
  }
}

/* If your JS injects lists, keep them flexible */
.finance-action-container #actionContainer,
.finance-goals-container #alertsList{
    flex: 1;
    overflow-y: auto;
}

/* ============================================================
   Buttons — crisp + premium (no gold overload)
   ============================================================ */
.finance-action-container button,
.finance-goals-container button{
    border-radius: 12px !important;
    font-weight: 900 !important;
    transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
}
.finance-action-container button:hover,
.finance-goals-container button:hover{
    transform: translateY(-1px);
    box-shadow: 0 12px 26px rgba(0,0,0,0.10);
    filter: contrast(1.02);
}

/* Inputs — HARD GOLD borders everywhere */
.finance-action-container input,
.finance-goals-container input{
    border-radius: 12px !important;
    border: 2px solid var(--gold) !important; /* ✅ HARD GOLD */
    padding: 10px 12px !important;
    font-weight: 800;
    background: #ffffff;
    color: #111;
}
.finance-action-container input:focus,
.finance-goals-container input:focus{
    outline: none !important;
    box-shadow: 0 0 0 .18rem rgba(166,128,35,0.18) !important;
}

/* Gold checkboxes */
.finance-action-container .action-done{
    accent-color: var(--gold);
    width: 22px;
    height: 22px;
    cursor: pointer;
}

/* ============================================================
   Middle tool container — HARD GOLD border + white stage
   ============================================================ */
.finance-main{
    width: 100%;
    border-radius: 22px;

    /* ✅ HARD GOLD BORDER */
    border: 2px solid var(--gold);

    background: #ffffff;
    box-shadow: var(--shadowB);
    padding: 14px;
    position: relative;
    overflow: hidden;
}

/* subtle gold glow behind main stage */
.finance-main:before{
    content:"";
    position:absolute;
    inset:0;
    border-radius: 22px;
    pointer-events:none;
    background:
        radial-gradient(900px 320px at 14% 0%, var(--goldSoft), transparent 58%);
}

/* Keep tool itself styled nicely (tool markup untouched) */
#budget-embed .networth-tool{
    border: 2px solid var(--gold);      /* ✅ HARD GOLD */
    border-radius: 18px;
    padding: 22px;
    background: #ffffff;
    box-shadow: 0 14px 38px rgba(0,0,0,0.07);
}

/* Tables */
#budget-embed table{
    border-radius: 12px;
    overflow: hidden;

    /* ✅ HARD GOLD outline so the whole table reads premium */
    border: 2px solid var(--gold);
}
#budget-embed table th{
    background-color: rgba(166,128,35,0.14);
    color: #5a3b00;
    font-weight: 950;

    /* ✅ HARD GOLD separators */
    border-bottom: 2px solid var(--gold) !important;
}
#budget-embed table td{
    font-weight: 800;
    text-align: center;

    /* ✅ HARD GOLD grid lines (if bootstrap/table adds borders) */
    border-color: var(--gold) !important;
}

/* Labels + inputs in main tool */
#budget-embed .form-control{
    border: 2px solid var(--gold) !important; /* ✅ HARD GOLD */
    border-radius: 12px !important;
    font-weight: 800;
    color: #111;
    background: #fff;
}
#budget-embed .form-control:focus{
    outline: none !important;
    box-shadow: 0 0 0 .18rem rgba(166,128,35,0.18) !important;
    border-color: var(--gold) !important;
}
#budget-embed .form-label{
    color: #222;
    font-weight: 850;
}

/* Optional: crisp gold hr lines if any appear inside injected tools */
#budget-embed hr,
.finance-side-card hr{
    border-top: 2px solid var(--gold);
    opacity: 1;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@@media (max-width: 1199.98px) {
  .finance-shell{
    max-width: 1400px;
  }
}

@@media (max-width: 991.98px) {
  .finance-side-card{
    min-height: 460px;
    max-height: none;
    overflow: visible;
  }
}

@@media (max-width: 575.98px){
    .finance-shell{ margin-top: 1.25rem !important; }
    .finance-header{ padding: 18px 14px; border-radius: 16px; }
    .finance-title{ font-size: 1.35rem; }
    .finance-subtitle{ font-size: .95rem; }
    .finance-side-card{ padding: 14px; border-radius: 18px; }
    .finance-main{ padding: 12px; border-radius: 18px; }
    #budget-embed .networth-tool{ padding: 16px; border-radius: 16px; }
}

/* ============================================================
   RESTORE NAVY + UPDATED SUPPORT PANELS
   ============================================================ */
:root{
    --gold:#d1a034;
    --lineDark:#8f6c1b;
    --navyPanel:#111827;
    --navyField:#121a2b;
    --ink:#f8fafc;
    --muted:#9fb0cd;
}

.finance-selector-row{
    display: grid;
    grid-template-columns: minmax(420px, 760px) minmax(170px, 240px);
    justify-content: center;
    gap: .85rem;
    align-items: center;
