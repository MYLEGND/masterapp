@model Domain.Entities.OnboardingSubmission
@using AgentPortal.Helpers
@{
    ViewData["Title"] = "Submission — " + Model.FirstName + " " + Model.LastName;
}

<link rel="stylesheet" href="~/css/legend-forms.css" asp-append-version="true" />

<style>
    .det-shell {
        max-width: 900px;
        margin: 0 auto;
        padding: 38px 32px 48px 32px;
        background: #fff;
        border-radius: 28px;
        border: 2.5px solid #bfa14a;
        box-shadow: 0 8px 32px rgba(15,23,42,0.18);
        display: flex;
        flex-direction: column;
        gap: 32px;
    }
    .det-topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; flex-wrap: wrap; gap: 10px; }
    .det-back-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 18px; border-radius: 10px; border: 1.5px solid #e2e8f0;
        background: #fff; color: #334155; font-size: 0.82rem; font-weight: 600;
        text-decoration: none; box-shadow: 0 1px 4px rgba(15,23,42,0.06);
        transition: all 0.15s ease;
    }
    .det-back-btn:hover { border-color: #94a3b8; color: #0f172a; box-shadow: 0 2px 8px rgba(15,23,42,0.1); }
    .det-submitted-label { font-size: 0.78rem; color: #94a3b8; }
    .det-print-btn {
        background:#bfa14a; color:#14213d; border:2px solid #bfa14a; font-weight:800;
    }
    .det-print-btn:hover { background:#d6bb4a; border-color:#d6bb4a; color:#0b1529; }

    .det-hero-card {
        background: linear-gradient(120deg, #14213d 90%, #bfa14a 100%);
        border: 2.5px solid #bfa14a !important;
        border-radius: 22px;
        padding: 32px 32px 28px 32px;
        box-shadow: 0 6px 24px rgba(15,23,42,0.18);
        margin-bottom: 28px;
        display: flex; align-items: center; gap: 28px; flex-wrap: wrap;
    }
    .det-avatar {
        flex-shrink: 0; width: 80px; height: 80px; border-radius: 50%;
        background: #bfa14a;
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 2.1rem; font-weight: 900;
        box-shadow: 0 2px 12px rgba(191,161,74,0.18);
        border: 2.5px solid #fff;
    }
    .det-hero-info { flex: 1; min-width: 0; }
    .det-hero-name {
        font-size: 1.55rem;
        font-weight: 900;
        color: #fff;
        letter-spacing: 0.5px;
        text-shadow: 0 2px 8px rgba(15,23,42,0.18);
    }
    .det-hero-preferred {
        font-size: 0.93rem;
        color: #ffe082;
        margin-top: 3px;
        font-weight: 600;
    }
    .det-hero-pills { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 12px; }
    .det-pill {
        display: inline-block;
        padding: 4px 16px;
        border-radius: 99px;
        font-size: 0.82rem;
        font-weight: 800;
        box-shadow: 0 1px 4px rgba(15,23,42,0.10);
    }
    .det-pill-blue { background: #1d3557; color: #ffe082; border: 1.5px solid #bfa14a; }
    .det-pill-green { background: #dcfce7; color: #15803d; border: 1.5px solid #bfa14a; }
    .det-pill-slate { background: #fff; color: #bfa14a; border: 1.5px solid #bfa14a; }

    .det-section {
        background: #101a2b;
        border: 2.5px solid #bfa14a !important;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 4px 18px rgba(15,23,42,0.13);
        margin-bottom: 0;
    }
        .det-section-header {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 22px 34px 16px 34px;
            background: #14213d !important;
            border-bottom: 2.5px solid #bfa14a !important;
            box-shadow: 0 4px 16px rgba(191,161,74,0.13);
        }
    .det-section-icon {
        flex-shrink: 0;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        background: #bfa14a !important;
        color: #14213d !important;
        font-weight: 900;
        box-shadow: 0 1px 6px rgba(191,161,74,0.13);
    }
        .det-section-title {
            font-size: 1.13rem;
            font-weight: 900;
            color: #fff !important;
            text-transform: uppercase;
            letter-spacing: 1.1px;
            text-shadow: 0 3px 12px rgba(15,23,42,0.22);
            border-bottom: 2px solid #bfa14a;
            padding-bottom: 2px;
        }
    .det-section-body {
        padding: 26px 28px 22px 28px;
        background: transparent;
    }

    .det-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px 20px; }
    .det-field { display: flex; flex-direction: column; gap: 3px; }
    .det-field-full { grid-column: 1 / -1; }
    .det-label {
        font-size: 0.74rem;
        font-weight: 800;
        color: #ffe082;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        text-shadow: 0 1px 4px rgba(191,161,74,0.13);
    }
    .det-val {
        font-size: 1.01rem;
        font-weight: 700;
        color: #fff;
        line-height: 1.55;
        text-shadow: 0 1px 6px rgba(15,23,42,0.18);
    }
    .det-val-empty {
        font-size: 1.01rem;
        color: #bfa14a;
        font-style: italic;
        opacity: 0.7;
    }

    .det-yes { display: inline-block; padding: 2px 10px; border-radius: 99px; font-size: 0.74rem; font-weight: 700; background: #dcfce7; color: #15803d; }
    .det-no  { display: inline-block; padding: 2px 10px; border-radius: 99px; font-size: 0.74rem; font-weight: 700; background: #fee2e2; color: #b91c1c; }
    .det-na  { display: inline-block; padding: 2px 10px; border-radius: 99px; font-size: 0.74rem; font-weight: 700; background: #f1f5f9; color: #94a3b8; }

    @@media (max-width: 600px) {
        .det-grid { grid-template-columns: 1fr; }
        .det-hero-card { flex-direction: column; align-items: flex-start; }
    }
</style>

@{
    var av1 = (Model.FirstName?.Length > 0 ? Model.FirstName[0].ToString() : "").ToUpper();
    var av2 = (Model.LastName?.Length > 0 ? Model.LastName[0].ToString() : "").ToUpper();
    var addr = new[] { Model.CurrentAddress, Model.City, string.IsNullOrWhiteSpace(Model.State) ? null : $"{Model.State} {Model.Zip}" };
    var addrStr = string.Join(", ", addr.Where(x => !string.IsNullOrWhiteSpace(x)));
    var ec = string.Join(" ", new[] {
        Model.EmergencyContactName,
        string.IsNullOrWhiteSpace(Model.EmergencyContactRelationship) ? null : $"({Model.EmergencyContactRelationship})",
        string.IsNullOrWhiteSpace(Model.EmergencyContactPhone) ? null : $"\u2014 {Model.EmergencyContactPhone}"
    }.Where(x => !string.IsNullOrWhiteSpace(x)));
    var sig = string.IsNullOrWhiteSpace(Model.ElectronicSignatureName) ? null
        : Model.ElectronicSignatureName + (Model.ElectronicSignatureDate.HasValue ? $" \u2014 signed {Model.ElectronicSignatureDate.Value.ToString("MMM d, yyyy")}" : "");
}

<div class="legend-shell">
    <div class="det-shell">

        <div class="det-topbar">
            <a asp-action="Index" class="det-back-btn">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
                Back to Onboarding
            </a>
            <span class="det-submitted-label">
                Submitted @(Model.SubmittedUtc?.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt") ?? "\u2014")
            </span>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="det-back-btn" style="background:#14213d;color:#ffe082;border:2px solid #bfa14a;margin-left:auto;">
                Edit Submission
            </a>
            <a asp-action="DownloadPdf"
               asp-route-id="@Model.Id"
               target="_blank"
               rel="noopener"
               class="det-back-btn det-print-btn"
               style="margin-left:8px;">
                View PDF
            </a>
        </div>

        <div class="det-hero-card">
            <div class="det-avatar">@av1@av2</div>
            <div class="det-hero-info">
                <div class="det-hero-name">@Model.FirstName @Model.MiddleName @Model.LastName</div>
                @if (!string.IsNullOrWhiteSpace(Model.PreferredName))
                {
                    <div class="det-hero-preferred">Goes by &ldquo;@Model.PreferredName&rdquo;</div>
                }
                <div class="det-hero-pills">
                    @if (!string.IsNullOrWhiteSpace(Model.RoleType))
                    {
                        <span class="det-pill det-pill-blue">@Model.RoleType</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.JobTitle))
                    {
                        <span class="det-pill det-pill-slate">@Model.JobTitle</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Department))
                    {
                        <span class="det-pill det-pill-slate">@Model.Department</span>
                    }
                    <span class="det-pill det-pill-green">&#10003; Submitted</span>
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#eff6ff;">&#128100;</div>
                <span class="det-section-title">Personal Information</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Date of Birth</span>@Html.Raw(RazorValueHelpers.V(Model.DateOfBirth?.ToString("MMM d, yyyy")))</div>
                    <div class="det-field"><span class="det-label">Phone</span>@Html.Raw(RazorValueHelpers.V(Model.Phone))</div>
                    <div class="det-field"><span class="det-label">Email</span>@Html.Raw(RazorValueHelpers.V(Model.Email))</div>
                    <div class="det-field det-field-full"><span class="det-label">Current Address</span>@Html.Raw(RazorValueHelpers.V(addrStr))</div>
                    <div class="det-field det-field-full"><span class="det-label">Mailing Address</span>@Html.Raw(RazorValueHelpers.V(Model.MailingAddress))</div>
                    <div class="det-field det-field-full"><span class="det-label">Emergency Contact</span>@Html.Raw(RazorValueHelpers.V(ec))</div>
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#f0fdf4;">&#128188;</div>
                <span class="det-section-title">Position &amp; Work</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Role Type</span>@Html.Raw(RazorValueHelpers.V(Model.RoleType))</div>
                    <div class="det-field"><span class="det-label">Job Title</span>@Html.Raw(RazorValueHelpers.V(Model.JobTitle))</div>
                    <div class="det-field"><span class="det-label">Department</span>@Html.Raw(RazorValueHelpers.V(Model.Department))</div>
                    <div class="det-field"><span class="det-label">Manager</span>@Html.Raw(RazorValueHelpers.V(Model.Manager))</div>
                    <div class="det-field"><span class="det-label">Start Date</span>@Html.Raw(RazorValueHelpers.V(Model.StartDate?.ToString("MMM d, yyyy")))</div>
                    <div class="det-field"><span class="det-label">Work Location</span>@Html.Raw(RazorValueHelpers.V(string.IsNullOrWhiteSpace(Model.WorkLocation) ? Model.WorkState : $"{Model.WorkLocation} ({Model.WorkState})"))</div>
                    <div class="det-field"><span class="det-label">Employment Type</span>@Html.Raw(RazorValueHelpers.V(Model.EmploymentType))</div>
                    <div class="det-field"><span class="det-label">Pay Type</span>@Html.Raw(RazorValueHelpers.V(Model.PayType))</div>
                    @if (!string.IsNullOrWhiteSpace(Model.WorkNotes))
                    {
                        <div class="det-field det-field-full"><span class="det-label">Work Notes</span>@Html.Raw(RazorValueHelpers.V(Model.WorkNotes))</div>
                    }
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#fefce8;">&#128219;</div>
                <span class="det-section-title">Identity &amp; Eligibility</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Legal Name Confirmed</span>@Html.Raw(RazorValueHelpers.B(Model.LegalNameConfirmed))</div>
                    <div class="det-field"><span class="det-label">SSN Last 4</span>@Html.Raw(RazorValueHelpers.V(Model.SsnLast4))</div>
                    <div class="det-field"><span class="det-label">Driver License</span>@Html.Raw(RazorValueHelpers.V(string.IsNullOrWhiteSpace(Model.DriverLicenseNumber) ? null : $"{Model.DriverLicenseNumber} ({Model.DriverLicenseState})"))</div>
                    <div class="det-field"><span class="det-label">Work Authorization</span>@Html.Raw(RazorValueHelpers.V(Model.WorkAuthorizationStatus))</div>
                    <div class="det-field"><span class="det-label">Citizenship</span>@Html.Raw(RazorValueHelpers.V(Model.CitizenshipStatus))</div>
                    <div class="det-field"><span class="det-label">Docs Acknowledged</span>@Html.Raw(RazorValueHelpers.B(Model.EligibilityDocumentsAck))</div>
                    @if (!string.IsNullOrWhiteSpace(Model.SsnNote))
                    {
                        <div class="det-field det-field-full"><span class="det-label">SSN Note</span>@Html.Raw(RazorValueHelpers.V(Model.SsnNote))</div>
                    }
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#fdf4ff;">&#128179;</div>
                <span class="det-section-title">Tax &amp; Payroll</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Filing Status</span>@Html.Raw(RazorValueHelpers.V(Model.TaxFilingStatus))</div>
                    <div class="det-field"><span class="det-label">Federal Withholding</span>@Html.Raw(RazorValueHelpers.V(Model.FederalWithholding))</div>
                    <div class="det-field"><span class="det-label">State Withholding</span>@Html.Raw(RazorValueHelpers.V(Model.StateWithholding))</div>
                    <div class="det-field"><span class="det-label">Bank Name</span>@Html.Raw(RazorValueHelpers.V(Model.BankName))</div>
                    <div class="det-field"><span class="det-label">Account Type</span>@Html.Raw(RazorValueHelpers.V(Model.BankAccountType))</div>
                    <div class="det-field"><span class="det-label">Routing #</span>@Html.Raw(RazorValueHelpers.V(Model.BankRoutingNumber))</div>
                    <div class="det-field"><span class="det-label">Account #</span>@Html.Raw(RazorValueHelpers.V(Model.BankAccountNumber))</div>
                    <div class="det-field"><span class="det-label">Payroll Acknowledged</span>@Html.Raw(RazorValueHelpers.B(Model.PayrollAcknowledgement))</div>
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#eff6ff;">&#128203;</div>
                <span class="det-section-title">Licensing &amp; Industry</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Resident State License</span>@Html.Raw(RazorValueHelpers.V(Model.ResidentStateLicense))</div>
                    <div class="det-field"><span class="det-label">Non-Resident States</span>@Html.Raw(RazorValueHelpers.V(Model.NonResidentStates))</div>
                    <div class="det-field"><span class="det-label">Licenses Held</span>@Html.Raw(RazorValueHelpers.V(Model.LicensesHeld))</div>
                    <div class="det-field"><span class="det-label">License Numbers</span>@Html.Raw(RazorValueHelpers.V(Model.LicenseNumbers))</div>
                    <div class="det-field"><span class="det-label">Carrier Appointments</span>@Html.Raw(RazorValueHelpers.V(Model.CarrierAppointments))</div>
                    <div class="det-field"><span class="det-label">E&amp;O Coverage</span>@Html.Raw(RazorValueHelpers.V(Model.EOCoverage))</div>
                    @if (!string.IsNullOrWhiteSpace(Model.SupervisionNotes))
                    {
                        <div class="det-field det-field-full"><span class="det-label">Supervision Notes</span>@Html.Raw(RazorValueHelpers.V(Model.SupervisionNotes))</div>
                    }
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#f0fdf4;">&#9997;&#65039;</div>
                <span class="det-section-title">Agreements &amp; Acknowledgements</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Confidentiality</span>@Html.Raw(RazorValueHelpers.B(Model.ConfidentialityAck))</div>
                    <div class="det-field"><span class="det-label">Handbook / Policy</span>@Html.Raw(RazorValueHelpers.B(Model.HandbookAck))</div>
                    <div class="det-field"><span class="det-label">Technology / Device</span>@Html.Raw(RazorValueHelpers.B(Model.TechnologyAck))</div>
                    <div class="det-field"><span class="det-label">Compliance</span>@Html.Raw(RazorValueHelpers.B(Model.ComplianceAck))</div>
                    <div class="det-field"><span class="det-label">Compensation Understanding</span>@Html.Raw(RazorValueHelpers.B(Model.CompensationAck))</div>
                    <div class="det-field"><span class="det-label">Non-Solicitation</span>@Html.Raw(RazorValueHelpers.B(Model.NonSolicitAck))</div>
                    <div class="det-field"><span class="det-label">E-Sign Consent</span>@Html.Raw(RazorValueHelpers.B(Model.ElectronicSignatureAck))</div>
                    <div class="det-field"><span class="det-label">Certification of Truth</span>@Html.Raw(RazorValueHelpers.B(Model.CertificationTruthful))</div>
                    <div class="det-field det-field-full"><span class="det-label">Electronic Signature</span>@Html.Raw(RazorValueHelpers.V(sig))</div>
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#fff7ed;">&#9888;&#65039;</div>
                <span class="det-section-title">Disclosures</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Regulatory Issues</span>@Html.Raw(RazorValueHelpers.B(Model.HasRegulatoryIssues, "Yes — See Notes", "None"))</div>
                    @if (Model.HasRegulatoryIssues == true)
                    {
                        <div class="det-field det-field-full"><span class="det-label">Regulatory Notes</span>@Html.Raw(RazorValueHelpers.V(Model.RegulatoryExplanation))</div>
                    }
                    <div class="det-field"><span class="det-label">Criminal History</span>@Html.Raw(RazorValueHelpers.B(Model.HasCriminalHistory, "Yes — See Notes", "None"))</div>
                    @if (Model.HasCriminalHistory == true)
                    {
                        <div class="det-field det-field-full"><span class="det-label">Criminal Notes</span>@Html.Raw(RazorValueHelpers.V(Model.CriminalExplanation))</div>
                    }
                    <div class="det-field"><span class="det-label">Administrative Actions</span>@Html.Raw(RazorValueHelpers.B(Model.HasAdministrativeActions, "Yes — See Notes", "None"))</div>
                    @if (Model.HasAdministrativeActions == true)
                    {
                        <div class="det-field det-field-full"><span class="det-label">Administrative Notes</span>@Html.Raw(RazorValueHelpers.V(Model.AdministrativeExplanation))</div>
                    }
                    <div class="det-field"><span class="det-label">Prior Termination</span>@Html.Raw(RazorValueHelpers.B(Model.HasPriorTermination, "Yes — See Notes", "None"))</div>
                    @if (Model.HasPriorTermination == true)
                    {
                        <div class="det-field det-field-full"><span class="det-label">Termination Notes</span>@Html.Raw(RazorValueHelpers.V(Model.TerminationExplanation))</div>
                    }
                    <div class="det-field"><span class="det-label">Other Disclosures</span>@Html.Raw(RazorValueHelpers.B(Model.HasOtherDisclosures, "Yes — See Notes", "None"))</div>
                    @if (Model.HasOtherDisclosures == true)
                    {
                        <div class="det-field det-field-full"><span class="det-label">Other Notes</span>@Html.Raw(RazorValueHelpers.V(Model.OtherDisclosuresExplanation))</div>
                    }
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#f8fafc;">&#128193;</div>
                <span class="det-section-title">Document Checklist</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Government ID</span>@Html.Raw(RazorValueHelpers.B(Model.HasIdDocument, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">SSN / Tax Doc</span>@Html.Raw(RazorValueHelpers.B(Model.HasSsnDocument, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">Voided Check</span>@Html.Raw(RazorValueHelpers.B(Model.HasVoidedCheck, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">License Copy</span>@Html.Raw(RazorValueHelpers.B(Model.HasLicenseCopy, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">Certifications</span>@Html.Raw(RazorValueHelpers.B(Model.HasCertifications, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">Resume</span>@Html.Raw(RazorValueHelpers.B(Model.HasResume, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">Signed Agreements</span>@Html.Raw(RazorValueHelpers.B(Model.HasSignedAgreements, "Provided", "Missing"))</div>
                    @if (!string.IsNullOrWhiteSpace(Model.DocumentNotes))
                    {
                        <div class="det-field det-field-full"><span class="det-label">Document Notes</span>@Html.Raw(RazorValueHelpers.V(Model.DocumentNotes))</div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>
@section Scripts { }
