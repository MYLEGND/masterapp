@using AgentPortal.Helpers
@model Domain.Entities.OnboardingSubmission
@{
    Layout = null;
    var av1 = (Model.FirstName?.Length > 0 ? Model.FirstName[0].ToString() : "").ToUpper();
    var av2 = (Model.LastName?.Length > 0 ? Model.LastName[0].ToString() : "").ToUpper();
    var addr = new[] { Model.CurrentAddress, Model.City, string.IsNullOrWhiteSpace(Model.State) ? null : $"{Model.State} {Model.Zip}" };
    var addrStr = string.Join(", ", addr.Where(x => !string.IsNullOrWhiteSpace(x)));
    var ec = string.Join(" ", new[] {
        Model.EmergencyContactName,
        string.IsNullOrWhiteSpace(Model.EmergencyContactRelationship) ? null : $"({Model.EmergencyContactRelationship})",
        string.IsNullOrWhiteSpace(Model.EmergencyContactPhone) ? null : $"\u2014 {Model.EmergencyContactPhone}"
    }.Where(x => !string.IsNullOrWhiteSpace(x)));
    var sig = string.IsNullOrWhiteSpace(Model.ElectronicSignatureName) ? null
        : Model.ElectronicSignatureName + (Model.ElectronicSignatureDate.HasValue ? $" \u2014 signed {Model.ElectronicSignatureDate.Value:MMM d, yyyy}" : "");
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Onboarding Submission</title>
    <link rel="stylesheet" href="~/css/legend-forms.css" asp-append-version="true" />
    <style>
        body { font-family: 'Inter', sans-serif; background: #ffffff; color: #0f172a; margin: 0; padding: 26px; }
        .det-shell { max-width: 1160px; margin: 0 auto; }
        .det-hero-card { display: flex; gap: 16px; padding: 16px; border: 1.2px solid #d7c07a; border-radius: 12px; background: #0b1529; color: #f8fafc; align-items: center; }
        .det-avatar { width: 62px; height: 62px; border-radius: 50%; background: linear-gradient(145deg,#14213d,#0b1529); display:grid; place-items:center; color:#ffe082; font-weight:900; font-size: 1.2rem; border: 1.4px solid #d7c07a; }
        .det-hero-name { font-size: 1.35rem; font-weight: 900; }
        .det-hero-preferred { font-size: .95rem; opacity: .8; }
        .det-hero-pills { display:flex; flex-wrap:wrap; gap:8px; margin-top:6px; }
        .det-pill { display:inline-flex; align-items:center; padding:6px 10px; border-radius:999px; font-weight:800; font-size:.85rem; border:1px solid rgba(215,192,122,.7); background:rgba(255,255,255,.08); color:#f8fafc; }
        .det-section { margin-top: 18px; border: 1.2px solid #d7c07a; border-radius: 12px; overflow: hidden; }
        .det-section-header { display:flex; align-items:center; gap:10px; padding:12px 14px; background:#fbf4de; border-bottom:1px solid rgba(0,0,0,0.04); }
        .det-section-title { font-weight:900; letter-spacing:.02em; color:#0f172a; }
        .det-section-icon { width:26px; height:26px; border-radius:8px; display:grid; place-items:center; font-size: 1rem; }
        .det-section-body { padding:16px 16px 14px; }
        .det-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(240px,1fr)); gap:12px 14px; }
        .det-field { padding:10px 12px; border:1px solid #e2e8f0; border-radius:10px; background:#ffffff; }
        .det-label { display:block; font-size:.85rem; font-weight:800; color:#475569; margin-bottom:4px; }
        .det-field-full { grid-column: 1 / -1; }
        .det-policy { margin-top:10px; padding:10px 12px; border:1px solid #e2e8f0; border-radius:10px; background:#fbf4de; }
        .det-signature { margin-top:14px; padding:12px; border:1px dashed #c9b063; border-radius:10px; font-weight:800; }
    </style>
</head>
<body>
    <div class="det-shell">
        <div class="det-hero-card">
            <div class="det-avatar">@av1@av2</div>
            <div>
                <div class="det-hero-name">@Model.FirstName @Model.MiddleName @Model.LastName</div>
                @if (!string.IsNullOrWhiteSpace(Model.PreferredName))
                {
                    <div class="det-hero-preferred">Goes by “@Model.PreferredName”</div>
                }
                <div class="det-hero-pills">
                    @if (!string.IsNullOrWhiteSpace(Model.RoleType))
                    { <span class="det-pill">@Model.RoleType</span> }
                    @if (!string.IsNullOrWhiteSpace(Model.JobTitle))
                    { <span class="det-pill">@Model.JobTitle</span> }
                    @if (!string.IsNullOrWhiteSpace(Model.Department))
                    { <span class="det-pill">@Model.Department</span> }
                </div>
            </div>
            <div style="margin-left:auto; text-align:right; font-weight:800; color:#ffe082;">
                Submitted<br />
                @(Model.SubmittedUtc?.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt") ?? "—")
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#eff6ff;">&#128100;</div>
                <span class="det-section-title">Personal Information</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Date of Birth</span>@Html.Raw(RazorValueHelpers.V(Model.DateOfBirth?.ToString("MMM d, yyyy")))</div>
                    <div class="det-field"><span class="det-label">Phone</span>@Html.Raw(RazorValueHelpers.V(Model.Phone))</div>
                    <div class="det-field"><span class="det-label">Email</span>@Html.Raw(RazorValueHelpers.V(Model.Email))</div>
                    <div class="det-field det-field-full"><span class="det-label">Current Address</span>@Html.Raw(RazorValueHelpers.V(addrStr))</div>
                    <div class="det-field det-field-full"><span class="det-label">Mailing Address</span>@Html.Raw(RazorValueHelpers.V(Model.MailingAddress))</div>
                    <div class="det-field det-field-full"><span class="det-label">Emergency Contact</span>@Html.Raw(RazorValueHelpers.V(ec))</div>
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#f0fdf4;">&#128188;</div>
                <span class="det-section-title">Position &amp; Work</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Role Type</span>@Html.Raw(RazorValueHelpers.V(Model.RoleType))</div>
                    <div class="det-field"><span class="det-label">Job Title</span>@Html.Raw(RazorValueHelpers.V(Model.JobTitle))</div>
                    <div class="det-field"><span class="det-label">Department</span>@Html.Raw(RazorValueHelpers.V(Model.Department))</div>
                    <div class="det-field"><span class="det-label">Manager</span>@Html.Raw(RazorValueHelpers.V(Model.Manager))</div>
                    <div class="det-field"><span class="det-label">Start Date</span>@Html.Raw(RazorValueHelpers.V(Model.StartDate?.ToString("MMM d, yyyy")))</div>
                    <div class="det-field"><span class="det-label">Work Location</span>@Html.Raw(RazorValueHelpers.V(Model.WorkLocation))</div>
                    <div class="det-field"><span class="det-label">Employment Type</span>@Html.Raw(RazorValueHelpers.V(Model.EmploymentType))</div>
                    <div class="det-field"><span class="det-label">Pay Type</span>@Html.Raw(RazorValueHelpers.V(Model.PayType))</div>
                    <div class="det-field det-field-full"><span class="det-label">Work Notes</span>@Html.Raw(RazorValueHelpers.V(Model.WorkNotes))</div>
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#fff7ed;">&#128274;</div>
                <span class="det-section-title">Identity &amp; Eligibility</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Driver License #</span>@Html.Raw(RazorValueHelpers.V(Model.DriverLicenseNumber))</div>
                    <div class="det-field"><span class="det-label">Driver License State</span>@Html.Raw(RazorValueHelpers.V(Model.DriverLicenseState))</div>
                    <div class="det-field"><span class="det-label">Citizenship</span>@Html.Raw(RazorValueHelpers.V(Model.CitizenshipStatus))</div>
                    <div class="det-field"><span class="det-label">Work Authorization</span>@Html.Raw(RazorValueHelpers.V(Model.WorkAuthorizationStatus))</div>
                    <div class="det-field det-field-full"><span class="det-label">Eligibility Docs Ack</span>@Html.Raw(RazorValueHelpers.B(Model.EligibilityDocumentsAck, "Acknowledged", "Not provided"))</div>
                    @if (!string.IsNullOrWhiteSpace(Model.SsnNote))
                    {
                        <div class="det-field det-field-full"><span class="det-label">SSN Note</span>@Html.Raw(RazorValueHelpers.V(Model.SsnNote))</div>
                    }
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#e0f2fe;">&#128181;</div>
                <span class="det-section-title">Tax / Payroll</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Tax Filing Status</span>@Html.Raw(RazorValueHelpers.V(Model.TaxFilingStatus))</div>
                    <div class="det-field"><span class="det-label">Federal Withholding</span>@Html.Raw(RazorValueHelpers.V(Model.FederalWithholding))</div>
                    <div class="det-field"><span class="det-label">State Withholding</span>@Html.Raw(RazorValueHelpers.V(Model.StateWithholding))</div>
                    <div class="det-field"><span class="det-label">Bank Name</span>@Html.Raw(RazorValueHelpers.V(Model.BankName))</div>
                    <div class="det-field"><span class="det-label">Bank Account Type</span>@Html.Raw(RazorValueHelpers.V(Model.BankAccountType))</div>
                    <div class="det-field"><span class="det-label">Routing Number</span>@Html.Raw(RazorValueHelpers.V(Model.BankRoutingNumber))</div>
                    <div class="det-field"><span class="det-label">Account Number</span>@Html.Raw(RazorValueHelpers.V(Model.BankAccountNumber))</div>
                    <div class="det-field det-field-full"><span class="det-label">Payroll Acknowledgement</span>@Html.Raw(RazorValueHelpers.B(Model.PayrollAcknowledgement, "Acknowledged", "Not provided"))</div>
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#fef9c3;">&#128736;</div>
                <span class="det-section-title">Licensing / Industry</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Resident State License</span>@Html.Raw(RazorValueHelpers.V(Model.ResidentStateLicense))</div>
                    <div class="det-field"><span class="det-label">Non-Resident States</span>@Html.Raw(RazorValueHelpers.V(Model.NonResidentStates))</div>
                    <div class="det-field"><span class="det-label">Licenses Held</span>@Html.Raw(RazorValueHelpers.V(Model.LicensesHeld))</div>
                    <div class="det-field"><span class="det-label">License Numbers</span>@Html.Raw(RazorValueHelpers.V(Model.LicenseNumbers))</div>
                    <div class="det-field"><span class="det-label">Carrier Appointments</span>@Html.Raw(RazorValueHelpers.V(Model.CarrierAppointments))</div>
                    <div class="det-field"><span class="det-label">E&O Coverage</span>@Html.Raw(RazorValueHelpers.V(Model.EOCoverage))</div>
                    <div class="det-field"><span class="det-label">Supervision Notes</span>@Html.Raw(RazorValueHelpers.V(Model.SupervisionNotes))</div>
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#f1f5f9;">&#9881;</div>
                <span class="det-section-title">Background / Disclosures</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Regulatory Issues</span>@Html.Raw(RazorValueHelpers.B(Model.HasRegulatoryIssues, "Yes — See Notes", "None"))</div>
                    @if (Model.HasRegulatoryIssues == true)
                    { <div class="det-field det-field-full"><span class="det-label">Regulatory Notes</span>@Html.Raw(RazorValueHelpers.V(Model.RegulatoryExplanation))</div> }
                    <div class="det-field"><span class="det-label">Criminal History</span>@Html.Raw(RazorValueHelpers.B(Model.HasCriminalHistory, "Yes — See Notes", "None"))</div>
                    @if (Model.HasCriminalHistory == true)
                    { <div class="det-field det-field-full"><span class="det-label">Criminal Notes</span>@Html.Raw(RazorValueHelpers.V(Model.CriminalExplanation))</div> }
                    <div class="det-field"><span class="det-label">Administrative Actions</span>@Html.Raw(RazorValueHelpers.B(Model.HasAdministrativeActions, "Yes — See Notes", "None"))</div>
                    @if (Model.HasAdministrativeActions == true)
                    { <div class="det-field det-field-full"><span class="det-label">Administrative Notes</span>@Html.Raw(RazorValueHelpers.V(Model.AdministrativeExplanation))</div> }
                    <div class="det-field"><span class="det-label">Prior Termination</span>@Html.Raw(RazorValueHelpers.B(Model.HasPriorTermination, "Yes — See Notes", "None"))</div>
                    @if (Model.HasPriorTermination == true)
                    { <div class="det-field det-field-full"><span class="det-label">Termination Notes</span>@Html.Raw(RazorValueHelpers.V(Model.TerminationExplanation))</div> }
                    <div class="det-field"><span class="det-label">Other Disclosures</span>@Html.Raw(RazorValueHelpers.B(Model.HasOtherDisclosures, "Yes — See Notes", "None"))</div>
                    @if (Model.HasOtherDisclosures == true)
                    { <div class="det-field det-field-full"><span class="det-label">Other Notes</span>@Html.Raw(RazorValueHelpers.V(Model.OtherDisclosuresExplanation))</div> }
                </div>
            </div>
        </div>

        <div class="det-section">
            <div class="det-section-header">
                <div class="det-section-icon" style="background:#f8fafc;">&#128193;</div>
                <span class="det-section-title">Document Checklist</span>
            </div>
            <div class="det-section-body">
                <div class="det-grid">
                    <div class="det-field"><span class="det-label">Government ID</span>@Html.Raw(RazorValueHelpers.B(Model.HasIdDocument, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">SSN / Tax Doc</span>@Html.Raw(RazorValueHelpers.B(Model.HasSsnDocument, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">Voided Check</span>@Html.Raw(RazorValueHelpers.B(Model.HasVoidedCheck, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">License Copy</span>@Html.Raw(RazorValueHelpers.B(Model.HasLicenseCopy, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">Certifications</span>@Html.Raw(RazorValueHelpers.B(Model.HasCertifications, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">Resume</span>@Html.Raw(RazorValueHelpers.B(Model.HasResume, "Provided", "Missing"))</div>
                    <div class="det-field"><span class="det-label">Signed Agreements</span>@Html.Raw(RazorValueHelpers.B(Model.HasSignedAgreements, "Provided", "Missing"))</div>
                    @if (!string.IsNullOrWhiteSpace(Model.DocumentNotes))
                    { <div class="det-field det-field-full"><span class="det-label">Document Notes</span>@Html.Raw(RazorValueHelpers.V(Model.DocumentNotes))</div> }
                </div>
            </div>
        </div>

        <div class="det-signature">
            <div>Certification of truthfulness</div>
            <div>@Html.Raw(RazorValueHelpers.B(Model.CertificationTruthful, "Certified", "Not certified"))</div>
            @if (!string.IsNullOrWhiteSpace(sig))
            {
                <div style="margin-top:6px;">Signature: @sig</div>
            }
        </div>
    </div>
</body>
</html>
