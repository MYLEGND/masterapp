@model AgentPortal.Models.OnboardingDashboardViewModel
@{
    ViewData["Title"] = "Onboarding";
}

<link rel="stylesheet" href="~/css/legend-forms.css" asp-append-version="true" />

<style>
    .onb-panel-btn {
        display: flex; align-items: center; gap: 18px;
        padding: 22px 26px; background: #ffffff;
        border: 1.5px solid #e2e8f0; border-radius: 16px;
        box-shadow: 0 2px 8px rgba(15,23,42,0.06);
        text-align: left; transition: all 0.2s ease; color: #0f172a;
    }
    .onb-panel-btn:hover {
        border-color: #1e3a5f; box-shadow: 0 6px 24px rgba(15,23,42,0.12);
        transform: translateY(-2px); color: #0f172a;
    }
    .onb-panel-icon {
        flex-shrink: 0; width: 56px; height: 56px; border-radius: 14px;
        background: #eff6ff; color: #1d4ed8;
        display: flex; align-items: center; justify-content: center;
    }
    .onb-icon-green { background: #f0fdf4 !important; color: #16a34a !important; }
    .onb-panel-content { flex: 1; }
    .onb-panel-title { font-size: 1.05rem; font-weight: 700; color: #0f172a; line-height: 1.3; }
    .onb-panel-sub { font-size: 0.82rem; color: #64748b; margin-top: 3px; }
    .onb-panel-badge {
        flex-shrink: 0; min-width: 36px; height: 36px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem; font-weight: 700;
    }
    .onb-badge-blue { background: #dbeafe; color: #1d4ed8; }
    .onb-badge-green { background: #dcfce7; color: #16a34a; }
    .onb-modal-content { border: none; border-radius: 20px; overflow: hidden; box-shadow: 0 20px 60px rgba(15,23,42,0.18); }
    .onb-modal-header {
        background: #f8fafc; border-bottom: 1.5px solid #e2e8f0; padding: 22px 28px;
        display: flex; align-items: flex-start; justify-content: space-between;
    }
    .onb-modal-body { padding: 24px 28px; background: #f8fafc; }
    .onb-card-list { display: flex; flex-direction: column; gap: 14px; }
    .onb-person-card {
        display: flex; align-items: center; gap: 18px;
        background: #ffffff; border: 1.5px solid #e2e8f0; border-radius: 14px;
        padding: 18px 20px; box-shadow: 0 1px 4px rgba(15,23,42,0.05);
        transition: box-shadow 0.18s ease, border-color 0.18s ease;
    }
    .onb-person-card:hover { border-color: #94a3b8; box-shadow: 0 4px 16px rgba(15,23,42,0.09); }
    .onb-avatar {
        flex-shrink: 0; width: 48px; height: 48px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; font-weight: 700;
    }
    .onb-avatar-blue { background: #dbeafe; color: #1d4ed8; }
    .onb-avatar-green { background: #dcfce7; color: #16a34a; }
    .onb-person-info { flex: 1; min-width: 0; }
    .onb-person-name { font-size: 0.95rem; font-weight: 700; color: #0f172a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .onb-person-email { font-size: 0.8rem; color: #64748b; margin-top: 1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .onb-person-meta { display: flex; align-items: center; gap: 8px; margin-top: 6px; flex-wrap: wrap; }
    .onb-meta-pill { display: inline-block; padding: 2px 10px; background: #f1f5f9; color: #475569; border-radius: 99px; font-size: 0.72rem; font-weight: 600; }
    .onb-status-badge { display: inline-block; padding: 2px 10px; border-radius: 99px; font-size: 0.72rem; font-weight: 700; }
    .onb-status-blue { background: #dbeafe; color: #1d4ed8; }
    .onb-status-green { background: #dcfce7; color: #15803d; }
    .onb-status-red { background: #fee2e2; color: #b91c1c; }
    .onb-status-gray { background: #f1f5f9; color: #475569; }
    .onb-person-dates { display: flex; flex-direction: column; gap: 6px; min-width: 130px; flex-shrink: 0; }
    .onb-date-item { display: flex; flex-direction: column; }
    .onb-date-label { font-size: 0.68rem; color: #94a3b8; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
    .onb-date-value { font-size: 0.8rem; color: #334155; font-weight: 600; }
    .onb-person-actions { display: flex; flex-direction: column; gap: 8px; flex-shrink: 0; }
    .onb-action-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 14px; border-radius: 8px;
        font-size: 0.78rem; font-weight: 600; cursor: pointer;
        text-decoration: none; border: 1.5px solid transparent;
        transition: all 0.15s ease; background: none; white-space: nowrap;
    }
    .onb-action-resend { border-color: #3b82f6; color: #2563eb; }
    .onb-action-resend:hover { background: #eff6ff; color: #1d4ed8; }
    .onb-action-view { border-color: #3b82f6; color: #2563eb; }
    .onb-action-view:hover { background: #eff6ff; color: #1d4ed8; }
    .onb-action-delete { border-color: #f87171; color: #dc2626; }
    .onb-action-delete:hover { background: #fef2f2; color: #b91c1c; }
    .onb-empty-state { text-align: center; padding: 56px 24px; }
    .onb-empty-icon { font-size: 3rem; margin-bottom: 12px; }
    .onb-empty-title { font-size: 1rem; font-weight: 700; color: #334155; }
    .onb-empty-sub { font-size: 0.85rem; color: #94a3b8; margin-top: 4px; }
    @@media (max-width: 768px) {
        .onb-person-card { flex-wrap: wrap; }
        .onb-person-dates { min-width: 0; flex-direction: row; gap: 16px; }
        .onb-person-actions { flex-direction: row; flex-wrap: wrap; }
    }

    /* Ensure form inputs use dark text for readability */
    .legend-form input.form-control,
    .legend-form select.form-control,
    .legend-form textarea.form-control,
    .legend-form input,
    .legend-form select,
    .legend-form textarea {
        color: #0f172a !important;
    }
    .legend-form ::placeholder {
        color: #475569 !important;
    }

    /* Hard lock premium navy/gold theme */
    .legend-shell.legend-form{
        background:
            radial-gradient(1200px 420px at 0% 0%, rgba(201,155,54,.12), transparent 58%),
            radial-gradient(900px 320px at 100% 0%, rgba(102,124,168,.12), transparent 56%),
            #091427 !important;
        color:#e9f0ff !important;
        border-radius:18px;
        padding:12px;
    }

    .legend-shell.legend-form .legend-hero,
    .legend-shell.legend-form .legend-card,
    .legend-shell.legend-form .onb-panel-btn,
    .legend-shell.legend-form .onb-modal-content,
    .legend-shell.legend-form .onb-person-card,
    .legend-shell.legend-form .onb-empty-state{
        background:linear-gradient(180deg,#132747,#0d1f3c) !important;
        border:1px solid rgba(201,155,54,.44) !important;
        box-shadow:0 24px 58px rgba(3,8,18,.45) !important;
        color:#e9f0ff !important;
    }

    .legend-shell.legend-form .legend-hero,
    .legend-shell.legend-form .legend-card,
    .legend-shell.legend-form .onb-modal-content{
        position:relative;
        overflow:hidden;
    }

    .legend-shell.legend-form .legend-hero::before,
    .legend-shell.legend-form .legend-card::before,
    .legend-shell.legend-form .onb-modal-content::before{
        content:"";
        position:absolute;
        left:0; right:0; top:0;
        height:4px;
        background:linear-gradient(90deg,#b4891f,#f0cf78,#b4891f);
    }

    .legend-shell.legend-form .legend-kicker,
    .legend-shell.legend-form .legend-title,
    .legend-shell.legend-form h2,
    .legend-shell.legend-form .card-header h5,
    .legend-shell.legend-form .onb-panel-title,
    .legend-shell.legend-form .onb-empty-title,
    .legend-shell.legend-form .modal-title,
    .legend-shell.legend-form .onb-person-name,
    .legend-shell.legend-form .onb-date-value{
        color:#b4891f !important;
    }

    .legend-shell.legend-form .legend-sub,
    .legend-shell.legend-form .text-muted,
    .legend-shell.legend-form .onb-panel-sub,
    .legend-shell.legend-form .onb-empty-sub,
    .legend-shell.legend-form .onb-person-email,
    .legend-shell.legend-form .onb-date-label,
    .legend-shell.legend-form .modal-header div[style],
    .legend-shell.legend-form .alert .text-muted{
        color:#d7e2f7 !important;
    }

    .legend-shell.legend-form .card-header,
    .legend-shell.legend-form .onb-modal-header,
    .legend-shell.legend-form .onb-modal-body,
    .legend-shell.legend-form .card-body{
        background:transparent !important;
        border-color:rgba(201,155,54,.34) !important;
        color:#e9f0ff !important;
    }

    .legend-shell.legend-form .onb-panel-icon,
    .legend-shell.legend-form .onb-avatar,
    .legend-shell.legend-form .onb-panel-badge,
    .legend-shell.legend-form .onb-meta-pill,
    .legend-shell.legend-form .onb-status-badge{
        border:1px solid rgba(201,155,54,.32);
        background:rgba(18,37,67,.95) !important;
        color:#b4891f !important;
    }

    .legend-shell.legend-form input.form-control,
    .legend-shell.legend-form select.form-control,
    .legend-shell.legend-form textarea.form-control,
    .legend-shell.legend-form input,
    .legend-shell.legend-form select,
    .legend-shell.legend-form textarea{
        background:#f8fbff !important;
        color:#0f1d38 !important;
        border:1px solid rgba(201,155,54,.58) !important;
        box-shadow:none !important;
    }

    .legend-shell.legend-form .legend-btn-primary,
    .legend-shell.legend-form .onb-action-view,
    .legend-shell.legend-form .onb-action-resend{
        background:linear-gradient(180deg,#f8e2a8,#c89a35) !important;
        color:#1e1305 !important;
        border:1px solid rgba(201,155,54,.58) !important;
    }

    .legend-shell.legend-form .onb-action-delete{
        background:linear-gradient(180deg,#5a1a1a,#3c1111) !important;
        color:#fee2e2 !important;
        border:1px solid #8b2020 !important;
    }

    .legend-shell.legend-form .alert-success,
    .legend-shell.legend-form .alert-info,
    .legend-shell.legend-form .alert-danger{
        border-width:1px !important;
        box-shadow:0 14px 34px rgba(3,8,18,.24) !important;
    }

    .legend-shell.legend-form code{
        color:#f5d57f;
        background:rgba(8,21,41,.45);
        padding:.15rem .35rem;
        border-radius:6px;
    }
</style>

<div class="legend-shell legend-form">
    <div class="legend-hero">
        <div class="legend-hero-bar"></div>
        <div class="legend-hero-body">
            <span class="legend-kicker">Owner Only</span>
            <h1 class="legend-title">Onboarding Console</h1>
            <p class="legend-sub">Create invitations and review submissions. Only zac.owen@mylegnd.com can access this area.</p>
        </div>
    </div>

    <div class="mt-4">
        <h2 class="fw-bold mb-3" style="color:var(--legend-navy);">Onboarding</h2>
        <p class="text-muted" style="color:#475569 !important;">Owner-only onboarding console. Only zac.owen@mylegnd.com can see this page.</p>

@if (!string.IsNullOrWhiteSpace(Model.NewInviteLink))
{
        <div class="alert alert-success">
            <strong>Invite link created:</strong>
            <div class="small mt-1"><code>@Model.NewInviteLink</code></div>
            <div class="text-muted">Copy and share this link with the invitee. It remains valid until the invite expires.</div>
        </div>
}
@if (TempData["Info"] is string info && !string.IsNullOrWhiteSpace(info))
{
        <div class="alert alert-info" role="alert">@info</div>
}
@if (TempData["Warning"] is string warn && !string.IsNullOrWhiteSpace(warn))
{
        <div class="alert alert-danger" role="alert" style="border-left:4px solid #b91c1c;">
            <div class="fw-bold" style="color:#7f1d1d;">Email failed to send</div>
            <div>@warn</div>
        </div>
}

        <div class="card shadow-sm mb-4 legend-card">
            <div class="card-header"><h5 class="m-0">Create Onboarding Invite</h5></div>
            <div class="card-body">
                <form asp-action="CreateInvite" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div class="col-md-3">
                        <label asp-for="NewInvite.FirstName" class="form-label fw-bold"></label>
                        <input asp-for="NewInvite.FirstName" class="form-control" />
                        <span asp-validation-for="NewInvite.FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="NewInvite.LastName" class="form-label fw-bold"></label>
                        <input asp-for="NewInvite.LastName" class="form-control" />
                        <span asp-validation-for="NewInvite.LastName" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NewInvite.Email" class="form-label fw-bold"></label>
                        <input asp-for="NewInvite.Email" class="form-control" />
                        <span asp-validation-for="NewInvite.Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="NewInvite.RoleType" class="form-label fw-bold"></label>
                        <input asp-for="NewInvite.RoleType" class="form-control" placeholder="Agent/Employee/Intern" />
                        <span asp-validation-for="NewInvite.RoleType" class="text-danger"></span>
                    </div>
                    <div class="col-12 d-flex justify-content-end">
                        <button type="submit" class="legend-btn-primary">Create Invite</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="row g-4 mb-2">
            <div class="col-md-6">
                <button type="button" class="w-100 btn onb-panel-btn" data-bs-toggle="modal" data-bs-target="#invitesModal">
                    <div class="onb-panel-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
                    </div>
                    <div class="onb-panel-content">
                        <div class="onb-panel-title">Manage Invites</div>
                        <div class="onb-panel-sub">@Model.Invites.Count sent invitation@(Model.Invites.Count == 1 ? "" : "s") — click to view &amp; manage</div>
                    </div>
                    <span class="onb-panel-badge onb-badge-blue">@Model.Invites.Count</span>
                </button>
            </div>
            <div class="col-md-6">
                <button type="button" class="w-100 btn onb-panel-btn" data-bs-toggle="modal" data-bs-target="#submissionsModal">
                    <div class="onb-panel-icon onb-icon-green">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" /></svg>
                    </div>
                    <div class="onb-panel-content">
                        <div class="onb-panel-title">View Submissions</div>
                        <div class="onb-panel-sub">@Model.Submissions.Count completed form@(Model.Submissions.Count == 1 ? "" : "s") — click to review</div>
                    </div>
                    <span class="onb-panel-badge onb-badge-green">@Model.Submissions.Count</span>
                </button>
            </div>
        </div>

    </div>
</div>

<!-- INVITES MODAL -->
<div class="modal fade" id="invitesModal" tabindex="-1" aria-labelledby="invitesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content onb-modal-content">
            <div class="modal-header onb-modal-header">
                <div>
                    <h4 class="modal-title fw-bold" id="invitesModalLabel" style="color:#0f172a;">Onboarding Invites</h4>
                    <div style="color:#64748b;font-size:0.82rem;margin-top:2px;">@Model.Invites.Count invitation@(Model.Invites.Count == 1 ? "" : "s") on record</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body onb-modal-body">
@if (!Model.Invites.Any())
{
                <div class="onb-empty-state"><div class="onb-empty-icon">📭</div><div class="onb-empty-title">No invites yet</div><div class="onb-empty-sub">Create an invite above to get started.</div></div>
}
else
{
                <div class="onb-card-list">
@foreach (var invite in Model.Invites)
{
    var initials = $"{(invite.FirstName?.Length > 0 ? invite.FirstName[0].ToString() : "")}{(invite.LastName?.Length > 0 ? invite.LastName[0].ToString() : "")}".ToUpper();
    var statusClass = invite.Status switch { "Pending" or "Sent" => "onb-status-blue", "Accepted" or "Used" => "onb-status-green", "Expired" => "onb-status-red", _ => "onb-status-gray" };
                    <div class="onb-person-card">
                        <div class="onb-avatar onb-avatar-blue">@initials</div>
                        <div class="onb-person-info">
                            <div class="onb-person-name">@invite.FirstName @invite.LastName</div>
                            <div class="onb-person-email">@invite.Email</div>
                            <div class="onb-person-meta">
                                <span class="onb-meta-pill">@invite.RoleType</span>
                                <span class="onb-status-badge @statusClass">@invite.Status</span>
                            </div>
                        </div>
                        <div class="onb-person-dates">
                            <div class="onb-date-item"><span class="onb-date-label">Invited</span><span class="onb-date-value">@invite.CreatedUtc.ToLocalTime().ToString("MMM d, yyyy")</span></div>
                            <div class="onb-date-item"><span class="onb-date-label">Expires</span><span class="onb-date-value">@(invite.ExpiresUtc?.ToLocalTime().ToString("MMM d, yyyy") ?? "—")</span></div>
                        </div>
                        <div class="onb-person-actions">
                            <form asp-action="ResendInvite" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@invite.Id" />
                                <button type="submit" class="onb-action-btn onb-action-resend">✉️ Resend</button>
                            </form>
                            <form asp-action="DeleteInvite" method="post" class="d-inline" onsubmit="return confirm('Delete this invite?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@invite.Id" />
                                <button type="submit" class="onb-action-btn onb-action-delete">🗑 Delete</button>
                            </form>
                        </div>
                    </div>
}
                </div>
}
            </div>
        </div>
    </div>
</div>

<!-- SUBMISSIONS MODAL -->
<div class="modal fade" id="submissionsModal" tabindex="-1" aria-labelledby="submissionsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content onb-modal-content">
            <div class="modal-header onb-modal-header">
                <div>
                    <h4 class="modal-title fw-bold" id="submissionsModalLabel" style="color:#0f172a;">Form Submissions</h4>
                    <div style="color:#64748b;font-size:0.82rem;margin-top:2px;">@Model.Submissions.Count completed submission@(Model.Submissions.Count == 1 ? "" : "s")</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body onb-modal-body">
@if (!Model.Submissions.Any())
{
                <div class="onb-empty-state"><div class="onb-empty-icon">📂</div><div class="onb-empty-title">No submissions yet</div><div class="onb-empty-sub">Submissions will appear here once invitees complete their onboarding form.</div></div>
}
else
{
                <div class="onb-card-list">
@foreach (var sub in Model.Submissions)
{
    var subInitials = $"{(sub.FirstName?.Length > 0 ? sub.FirstName[0].ToString() : "")}{(sub.LastName?.Length > 0 ? sub.LastName[0].ToString() : "")}".ToUpper();
                    <div class="onb-person-card">
                        <div class="onb-avatar onb-avatar-green">@subInitials</div>
                        <div class="onb-person-info">
                            <div class="onb-person-name">@sub.FirstName @sub.LastName</div>
                            <div class="onb-person-email">@sub.Email</div>
                            <div class="onb-person-meta">
                                <span class="onb-meta-pill">@sub.RoleType</span>
                                <span class="onb-status-badge onb-status-green">Submitted</span>
                            </div>
                        </div>
                        <div class="onb-person-dates">
                            <div class="onb-date-item"><span class="onb-date-label">Submitted</span><span class="onb-date-value">@(sub.SubmittedUtc?.ToLocalTime().ToString("MMM d, yyyy h:mm tt") ?? "—")</span></div>
                        </div>
                        <div class="onb-person-actions">
                            <a asp-action="Details" asp-route-id="@sub.Id" class="onb-action-btn onb-action-view" target="_blank">👁 View Details</a>
                            <a asp-action="Details" asp-route-id="@sub.Id" asp-route-print="true" class="onb-action-btn onb-action-view" target="_blank">⬇ Download / Print</a>
                            <form asp-action="DeleteSubmission" method="post" class="d-inline" onsubmit="return confirm('Delete this submission?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@sub.Id" />
                                <button type="submit" class="onb-action-btn onb-action-delete">🗑 Delete</button>
                            </form>
                        </div>
                    </div>
}
                </div>
}
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
