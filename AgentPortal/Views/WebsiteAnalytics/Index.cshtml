                </thead>
                <tbody id="meta-campaigns-body">
                    <tr><td colspan="13" class="fa-loading">Loading campaigns…</td></tr>
                </tbody>
            </table>
        </div>
        </section>
      </div>
    </div>
  </div>
</div>

