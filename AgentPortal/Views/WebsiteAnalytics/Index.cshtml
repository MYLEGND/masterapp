@{
    ViewData["Title"] = "Website Analytics";
    var initialPreset = ViewData["InitialRangePreset"] as string ?? "30d";
    var initialLabel = ViewData["InitialRangeLabel"] as string ?? "Last 30 Days";
    var initialRangeFrom = ViewData["InitialRangeFrom"] as string ?? string.Empty;
    var initialRangeTo = ViewData["InitialRangeTo"] as string ?? string.Empty;
    var initialSummaryJson = ViewData["InitialSummaryJson"] as string ?? "{}";
    var initialScopeLabelRaw = ViewData["InitialScopeLabel"] as string ?? "Global";
    var initialScopeLabel = initialScopeLabelRaw.StartsWith("Agent:", StringComparison.OrdinalIgnoreCase)
        ? initialScopeLabelRaw.Substring("Agent:".Length).Trim()
        : initialScopeLabelRaw;
    var personalLink = ViewData["PersonalLink"] as string;
    var personalLinkAlt = ViewData["PersonalLinkAlt"] as string;
    var callerProfileId = ViewData["CallerProfileId"] as Guid?;
    var agentOptionsJson = ViewData["AgentOptionsJson"] as string ?? "[]";
    var canViewFounderTeamUi = (ViewData["CanViewFounderTeamUi"] as bool?) ?? false;
    var canDeleteAnalyticsLeads = (ViewData["CanDeleteAnalyticsLeads"] as bool?) ?? false;
    var initialScopeProfileId = ViewData["InitialScopeProfileId"] as Guid?;
    var isFounder = agentOptionsJson != "[]";
    var landingRoutesJson = ViewData["LandingRoutesJson"] as string ?? "[]";
    var landingRoutesBaseUrl = ViewData["LandingRoutesBaseUrl"] as string ?? string.Empty;
}

<link rel="stylesheet" href="~/css/website-analytics.css" asp-append-version="true" />

<div class="container mt-4 mb-5 fa-shell" data-initial-preset="@initialPreset" data-initial-label="@initialLabel" data-initial-from="@initialRangeFrom" data-initial-to="@initialRangeTo" data-initial-summary='@initialSummaryJson' data-initial-scope-label="@initialScopeLabel" data-initial-scope-profile-id="@initialScopeProfileId" data-caller-profile-id="@callerProfileId" data-agent-options='@agentOptionsJson' data-personal-link="@personalLink" data-can-delete-leads="@(canDeleteAnalyticsLeads ? "true" : "false")" data-landing-routes='@landingRoutesJson' data-landing-routes-base-url="@landingRoutesBaseUrl">
    <div class="wa-command-surface mb-3">
        <div class="hero-link p-4 p-md-5">
            <div class="hero-link-top">
                <div class="hero-link-intro">
                    <div class="hero-link-kicker">Shared Command Area</div>
                    <h3 class="hero-link-title">Marketing Links</h3>
                    <div class="hero-link-subtitle text-silver">Open the website, manage Meta Ads, and jump into behavior review fast.</div>
                </div>
            </div>

            <div class="hero-link-grid">
                <div class="hero-link-panel hero-link-panel-website">
                    <div class="hero-link-panel-head">
                        <div>
                            <div class="hero-link-label">Website Link</div>
                            <div class="hero-link-panel-title">Primary site link</div>
                        </div>
                        <div class="hero-link-badge">Live Link</div>
                    </div>
                    <div class="hero-link-url fw-semibold" id="growth-base-link">@personalLink</div>
                    <div class="hero-link-note">Open or copy the live site, then expand the paid landing registry to launch control pages and active test variants.</div>
                    <div class="hero-link-meta-actions hero-link-actions-inline" role="group" aria-label="Website link actions">
                        <a class="btn btn-gold" id="growth-open-base" href="@personalLink" target="_blank" rel="noopener">Open Website</a>
                        <button class="btn btn-outline-light" id="growth-copy-base" data-link="@personalLink">Copy Link</button>
                    </div>
                    <button type="button" class="btn btn-outline-light btn-sm w-100 mt-1 product-links-toggle" id="product-links-toggle" aria-expanded="false" aria-controls="product-links-section">
                        Explore Paid Landing Routes
                    </button>
                    <div class="product-links-section" id="product-links-section" hidden>
                        <div class="product-links-header">Discovered Paid Landing Routes + Test Variants</div>
                        <div class="product-links-subtitle">Landing URLs below are discovered automatically from the landing registry and use the public Protect website base URL.</div>
                        <div id="product-links-list"></div>
                        <div class="mt-2">
                            <input type="text" readonly id="product-link-display" class="product-link-display form-control form-control-sm" placeholder="Selected landing URL" aria-label="Selected landing link" />
                        </div>
                    </div>
                </div>

                <div class="hero-link-panel hero-link-panel-meta">
                    <div class="hero-link-panel-head">
                        <div>
                            <div class="hero-link-label">Meta Ads</div>
                            <div class="hero-link-panel-title">Campaign command area</div>
                        </div>
                        <div class="hero-link-badge">Campaigns</div>
                    </div>
                    <div class="text-silver hero-link-help">Review spend, open campaigns, or connect the account for shared analysis.</div>
                    <div class="small" id="meta-connection-status">Checking connection…</div>
                    <div class="hero-link-meta-actions">
                        <a class="btn btn-gold hero-link-meta-btn"
                           href="https://adsmanager.facebook.com/adsmanager/manage/campaigns" id="openMetaAdsManagerLink"
                           target="_blank"
                           rel="noopener">
                            Open Meta Ads Manager
                        </a>
                        <button type="button"
                                class="btn btn-outline-light hero-link-meta-btn"
                                id="meta-campaigns-open"
                                data-bs-toggle="modal"
                                data-bs-target="#metaCampaignsModal">
                            Campaigns
                        </button>
                        <a class="btn btn-outline-light hero-link-meta-btn"
                           id="meta-connect-btn"
                           href="/WebsiteAnalytics/meta-connect?returnUrl=/WebsiteAnalytics/Index">
                            Connect Meta Ads
                        </a>
                        <button type="button"
                                class="btn btn-outline-light hero-link-meta-btn"
                                id="meta-disconnect-btn"
                                style="display:none;">
                            Disconnect
                        </button>
                    </div>
                </div>

                <div class="hero-link-panel hero-link-panel-intel">
                    <div class="hero-link-panel-head">
                        <div>
                            <div class="hero-link-label">Behavior Intelligence</div>
                            <div class="hero-link-panel-title">Behavior + AI review</div>
                        </div>
                        <div class="hero-link-badge">AI Review</div>
                    </div>
                    <div class="text-silver hero-link-help">Launch behavior analysis fast or copy an AI review snapshot.</div>
                    <div class="hero-link-meta-actions">
                        <button type="button"
                                class="btn btn-gold hero-link-meta-btn"
                                data-bs-toggle="modal"
                                data-bs-target="#behaviorModal">
                            Open Behavior Intelligence
                        </button>
                        <button type="button"
                                class="btn btn-outline-light hero-link-meta-btn"
                                data-ai-drawer-trigger>
                            Open AI Review
                        </button>
                        <button type="button"
                                class="btn btn-outline-light hero-link-meta-btn"
                                id="ai-review-snapshot-btn"
                                data-bs-toggle="modal"
                                data-bs-target="#aiReviewSnapshotModal">
                            Copy Review Snapshot
                        </button>
                    </div>
                </div>

            </div>
        </div>

        <div class="wa-command-dashboard">
            <div class="wa-page-header">
                <div class="wa-header-copy">
                    <div class="wa-header-kicker">Legend&#8482; &middot; Performance Intelligence</div>
                    <h2 class="wa-header-title">Website Analytics</h2>
                    <p class="wa-header-sub">Your performance overview &middot; <strong><span id="fa-range-label">@initialLabel</span></strong></p>
                </div>
                <div class="wa-header-right">
                    <div class="wa-tz-chip wa-scope-chip">
                        <span class="wa-scope-chip-kicker">Viewing</span>
                        <span class="wa-scope-chip-value" id="wa-scope-label">@initialScopeLabel</span>
                    </div>
                    @if (canViewFounderTeamUi)
                    {
                    <div class="wa-scope-picker" aria-label="Analytics scope selector">
                        <div class="wa-scope-picker-head">
                            <label class="wa-scope-picker-label" for="wa-scope-select">Scope</label>
                        </div>
                        <div class="wa-scope-select-shell">
                            <select id="wa-scope-select" class="form-select form-select-sm scope-select">
                                <option value="">Global</option>
                                @if (callerProfileId.HasValue)
                                {
                                <option value="@callerProfileId.Value">Founder Personal</option>
                                }
                            </select>
                        </div>
                    </div>
                    }
                    <div class="wa-tz-chip" id="wa-tz-label"><span class="wa-tz-chip-icon">🕐</span><span id="wa-tz-text"></span></div>
                    <div class="fa-env-badge" id="fa-env-label"></div>
                    @if(canViewFounderTeamUi)
                    {
                    <button class="btn btn-sm wa-team-btn" id="team-rollup-btn" type="button" data-bs-toggle="modal" data-bs-target="#teamRollupModal">
                        Team Performance
                    </button>
                    }
                </div>
            </div>

            <div class="control-bar">
                <div class="control-bar-group control-bar-presets">
                    <div class="control-bar-label">Quick Range</div>
                    <div class="btn-group btn-group-sm flex-shrink-0" role="group" aria-label="Quick range presets">
                        <button class="btn btn-range @(initialPreset=="today"?"active":"")" data-range="today">Today</button>
                        <button class="btn btn-range @(initialPreset=="7d"?"active":"")" data-range="7d">7 Days</button>
                        <button class="btn btn-range @(initialPreset=="30d"?"active":"")" data-range="30d">30 Days</button>
                        <button class="btn btn-range @(initialPreset=="month"?"active":"")" data-range="month">Month</button>
                        <button class="btn btn-range @(initialPreset=="year"?"active":"")" data-range="year">Year</button>
                    </div>
                </div>
                <div class="control-bar-group control-bar-custom">
                    <div class="control-bar-label">Custom Window</div>
                    <div class="date-group d-flex align-items-center gap-2 flex-fill">
                        <input type="date" id="range-from" class="form-control form-control-sm flex-fill" value="@initialRangeFrom" />
                        <input type="date" id="range-to" class="form-control form-control-sm flex-fill" value="@initialRangeTo" />
                        <button class="btn btn-sm btn-range flex-shrink-0" id="apply-custom-range">Apply Range</button>
                    </div>
                </div>
                <div class="control-bar-group control-bar-status">
                    <div class="control-bar-label">Status</div>
                    <div id="fa-range-error" class="control-bar-status-text"></div>
                </div>
            </div>
        </div>
    </div>

    <form id="meta-disconnect-form" method="post" class="d-none">
      @Html.AntiForgeryToken()
    </form>

    <div class="wa-methodology-note mb-3" id="wa-methodology-note">
        <div class="wa-methodology-body">Analytics methodology updated May 15, 2026. Data before this update may include attribution, abandonment, or conversion inconsistencies. Current filtering excludes `IsInternal` and localhost traffic, but bot/test suppression is still limited.</div>
    </div>

    <section class="wa-section wa-kpi-stage" aria-labelledby="wa-kpi-title">
        <div class="wa-section-head">
            <div>
                <h3 class="wa-section-title" id="wa-kpi-title">Core Metrics</h3>
            </div>
        </div>
        <div class="fa-kpi-grid fa-kpi-grid-primary">
            <div>
                <div class="kpi-card kpi-card-primary kpi-card-clickable" data-kpi-card data-metric="pageviews" role="button" tabindex="0" aria-label="Page Views — click to view detail" title="Click to view Page Views detail">
                <div class="fa-kpi-title">Page Views <span class="kpi-card-drill-hint">↗</span></div>
                <div class="fa-kpi-value" id="kpi-pageviews">0</div>
                <div class="fa-kpi-delta" id="kpi-pv-delta"></div>
                <div class="fa-spark" id="kpi-pv-spark"></div>
            </div>
            </div>
            <div>
                <div class="kpi-card kpi-card-primary kpi-card-clickable" data-kpi-card data-metric="visitors" role="button" tabindex="0" aria-label="Unique Visitors — click to view detail" title="Click to view Unique Visitors detail">
                <div class="fa-kpi-title">Unique Visitors <span class="kpi-card-drill-hint">↗</span></div>
                <div class="fa-kpi-value" id="kpi-visitors">0</div>
                <div class="fa-kpi-delta" id="kpi-vis-delta"></div>
                <div class="fa-spark" id="kpi-vis-spark"></div>
            </div>
            </div>
            <div>
                <div class="kpi-card kpi-card-primary kpi-card-clickable" data-kpi-card data-metric="sessions" role="button" tabindex="0" aria-label="Sessions — click to view detail" title="Click to view Sessions detail">
                <div class="fa-kpi-title">Sessions <span class="kpi-card-drill-hint">↗</span></div>
                <div class="fa-kpi-value" id="kpi-sessions">0</div>
                <div class="fa-kpi-delta" id="kpi-ses-delta"></div>
                <div class="fa-spark" id="kpi-ses-spark"></div>
            </div>
            </div>
            <div>
                <div class="kpi-card kpi-card-primary kpi-card-clickable" data-kpi-card data-metric="leads" role="button" tabindex="0" aria-label="Leads — click to view detail" title="Click to view Leads detail">
                <div class="fa-kpi-title">Leads <span class="kpi-card-drill-hint">↗</span></div>
                <div class="fa-kpi-value" id="kpi-leads">0</div>
                <div class="fa-kpi-delta" id="kpi-leads-delta"></div>
                <div class="fa-spark" id="kpi-leads-spark"></div>
            </div>
            </div>
        </div>
        <div class="fa-kpi-grid fa-kpi-grid-secondary">
            <div>
                <div class="kpi-card kpi-card-secondary kpi-card-conversion">
                <div class="fa-kpi-title">Intent Conversion</div>
                <div class="fa-kpi-value" id="kpi-intent">—</div>
                <div class="fa-kpi-sub" id="kpi-intent-sub">Quote Submits / Quote Starts</div>
                <div class="fa-kpi-warning" id="kpi-intent-warning"></div>
            </div>
            </div>
            <div>
                <div class="kpi-card kpi-card-secondary kpi-card-conversion">
                <div class="fa-kpi-title">Session Conversion Rate</div>
                <div class="fa-kpi-value" id="kpi-session">0%</div>
                <div class="fa-kpi-sub">Converted Sessions / Sessions</div>
                <div class="fa-kpi-warning" id="kpi-session-warning"></div>
            </div>
            </div>
            <div>
                <div class="kpi-card kpi-card-secondary kpi-card-context">
                <div class="fa-kpi-title">Top Page</div>
                <div class="fa-kpi-value" style="font-size:1.1rem;" id="kpi-top-page">—</div>
                <div class="fa-kpi-sub">Most viewed</div>
            </div>
            </div>
            <div>
                <div class="kpi-card kpi-card-secondary kpi-card-context">
                <div class="fa-kpi-title">Top CTA</div>
                <div class="fa-kpi-value" style="font-size:1.1rem;" id="kpi-top-cta">—</div>
                <div class="fa-kpi-sub">Most clicked</div>
            </div>
        </div>
        </div>
    </section>

    <section class="wa-section wa-workbench" aria-labelledby="wa-workbench-title">
        <div class="wa-section-head">
            <div>
                <h3 class="wa-section-title" id="wa-workbench-title">Analysis Modules</h3>
            </div>
        </div>

        <div class="fa-modules fa-modules-priority">
            <div class="fa-module fa-module-feature fa-module-signal" id="mod-meta-signal" role="button" tabindex="0" aria-label="Open Meta Signal Intelligence">
                <div class="fa-module-head">
                    <div>
                        <h5>Meta Signal Intelligence</h5>
                    </div>
                </div>
                <div class="fa-module-meta" id="mod-meta-signal-meta">High-intent tiers, abandon points, and optimization readiness</div>
                <div class="fa-trend-bar"></div>
            </div>

            <div class="fa-module fa-module-feature fa-module-behavior" id="mod-behavior" role="button" tabindex="0" aria-label="Open Behavior Intelligence">
                <div class="fa-module-head">
                    <div>
                        <h5>Behavior Intelligence</h5>
                    </div>
                </div>
                <div class="fa-module-meta" id="mod-behavior-meta">Dwell time, exits, journey &amp; source attribution</div>
                <div class="fa-trend-bar"></div>
            </div>

            <div class="fa-module fa-module-feature fa-module-quote" id="mod-quote" role="button" tabindex="0" aria-label="Open Quote Funnel">
                <div class="fa-module-head">
                    <div>
                        <h5>Quote Funnel</h5>
                    </div>
                </div>
                <div class="fa-module-meta" id="mod-quote-meta">Starts → form starts → submits</div>
                <div class="fa-trend-bar"></div>
            </div>

            <div class="fa-module fa-module-feature fa-module-conv" id="mod-conv" role="button" tabindex="0" aria-label="Open Conversion Center">
                <div class="fa-module-head">
                    <div>
                        <h5>Conversion Center</h5>
                    </div>
                </div>
                <div class="fa-module-meta" id="mod-conv-meta">Lead submits & successes</div>
                <div class="fa-trend-bar"></div>
            </div>
        </div>

        <div class="fa-modules fa-modules-support">
            <div class="fa-module fa-module-support" id="mod-traffic" role="button" tabindex="0" aria-label="Open Traffic Overview">
                <div class="fa-module-head">
                    <div>
                        <h5>Traffic Overview</h5>
                    </div>
                </div>
                <div class="fa-module-meta" id="mod-traffic-meta">Views, sessions, visitors · click to drill in</div>
                <div class="fa-trend-bar"></div>
            </div>

            <div class="fa-module fa-module-support" id="mod-leads" role="button" tabindex="0" aria-label="Open Leads Snapshot">
                <div class="fa-module-head">
                    <div>
                        <h5>Leads Snapshot</h5>
                    </div>
                </div>
                <div class="fa-module-meta" id="mod-leads-meta">Recent captured leads</div>
                <div class="fa-trend-bar"></div>
            </div>

            <div class="fa-module fa-module-support" id="mod-page" role="button" tabindex="0" aria-label="Open Page Performance">
                <div class="fa-module-head">
                    <div>
                        <h5>Page Performance</h5>
                    </div>
                </div>
                <div class="fa-module-meta" id="mod-page-meta">Top pages and conversions</div>
                <div class="fa-trend-bar"></div>
            </div>

            <div class="fa-module fa-module-support" id="mod-cta" role="button" tabindex="0" aria-label="Open CTA Performance">
                <div class="fa-module-head">
                    <div>
                        <h5>CTA Performance</h5>
                    </div>
                </div>
                <div class="fa-module-meta" id="mod-cta-meta">Clicks by CTA</div>
                <div class="fa-trend-bar"></div>
            </div>

            @if(isFounder)
            {
            <div class="fa-module fa-module-support fa-module-muted" id="mod-agentperf" role="button" tabindex="0" aria-label="Open Agent Performance">
                <div class="fa-module-head">
                    <div>
                        <h5>Agent Performance</h5>
                    </div>
                </div>
                <div class="fa-module-meta" id="mod-agentperf-meta">Top performers · founder only</div>
                <div class="fa-trend-bar"></div>
            </div>
            }
        </div>
    </section>
</div>

@if (canViewFounderTeamUi)
{
<div class="modal fade" id="teamRollupModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" style="max-width:1200px;">
    <div class="modal-content" style="background:#0a1122;color:#f5f7fb;border:2px solid rgba(199,153,49,0.95);box-shadow:0 28px 72px rgba(0,0,0,.55);border-radius:18px;">
      <div class="modal-header border-0 pb-0">
        <div>
          <h4 class="modal-title fw-bold mb-1" style="color:#e6c078;">Team Performance</h4>
          <div class="text-muted small">Agency-wide rollup across all sites</div>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-3">
        <div class="row g-3 mb-3">
          <div class="col-6 col-xl-2"><div class="kpi-card team-kpi"><div class="fa-kpi-title">Page Views</div><div class="fa-kpi-value" id="team-kpi-pageviews">0</div></div></div>
          <div class="col-6 col-xl-2"><div class="kpi-card team-kpi"><div class="fa-kpi-title">Unique Visitors</div><div class="fa-kpi-value" id="team-kpi-visitors">0</div></div></div>
          <div class="col-6 col-xl-2"><div class="kpi-card team-kpi"><div class="fa-kpi-title">Sessions</div><div class="fa-kpi-value" id="team-kpi-sessions">0</div></div></div>
          <div class="col-6 col-xl-2"><div class="kpi-card team-kpi"><div class="fa-kpi-title">Leads</div><div class="fa-kpi-value" id="team-kpi-leads">0</div></div></div>
          <div class="col-6 col-xl-2"><div class="kpi-card team-kpi"><div class="fa-kpi-title">Session Conv</div><div class="fa-kpi-value" id="team-kpi-session">0%</div></div></div>
          <div class="col-6 col-xl-2"><div class="kpi-card team-kpi"><div class="fa-kpi-title">Intent Conv</div><div class="fa-kpi-value" id="team-kpi-intent">—</div></div></div>
          <div class="col-12 d-flex justify-content-end">
            <div class="text-silver small">Range: <span id="team-range-label"></span></div>
          </div>
        </div>

        <div class="row g-3 mb-4">
          <div class="col-6 col-lg-2"><div class="kpi-card subtle team-kpi"><div class="fa-kpi-title">Top Page</div><div class="fa-kpi-value" id="team-top-page">—</div></div></div>
          <div class="col-6 col-lg-2"><div class="kpi-card subtle team-kpi"><div class="fa-kpi-title">Top CTA</div><div class="fa-kpi-value" id="team-top-cta">—</div></div></div>
          <div class="col-6 col-lg-2"><div class="kpi-card subtle team-kpi"><div class="fa-kpi-title">Quote Starts</div><div class="fa-kpi-value" id="team-quote-starts">0</div></div></div>
          <div class="col-6 col-lg-2"><div class="kpi-card subtle team-kpi"><div class="fa-kpi-title">Form Starts</div><div class="fa-kpi-value" id="team-quote-form-starts">0</div></div></div>
          <div class="col-6 col-lg-2"><div class="kpi-card subtle team-kpi"><div class="fa-kpi-title">Submits</div><div class="fa-kpi-value" id="team-quote-submits">0</div></div></div>
          <div class="col-6 col-lg-2"><div class="kpi-card subtle team-kpi"><div class="fa-kpi-title">Total Conversions</div><div class="fa-kpi-value" id="team-total-conv">0</div></div></div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-lg-6">
            <div class="fa-module team-module" style="background:#0c1427;border-color:rgba(199,153,49,0.7);">
              <h6 class="text-warning">Top Pages</h6>
              <ul class="list-unstyled mb-0" id="team-top-pages-list"></ul>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="fa-module team-module" style="background:#0c1427;border-color:rgba(199,153,49,0.7);">
              <h6 class="text-warning">Top CTAs</h6>
              <ul class="list-unstyled mb-0" id="team-top-ctas-list"></ul>
            </div>
          </div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-lg-6">
            <div class="fa-module team-module" style="background:#0c1427;border-color:rgba(199,153,49,0.7);">
              <h6 class="text-warning">Top Sources</h6>
              <ul class="list-unstyled mb-0" id="team-top-sources-list"></ul>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="fa-module team-module" style="background:#0c1427;border-color:rgba(199,153,49,0.7);">
              <h6 class="text-warning">Top Campaigns</h6>
              <ul class="list-unstyled mb-0" id="team-top-campaigns-list"></ul>
            </div>
          </div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-12">
