                        <th class="text-end">CTR</th>
                        <th class="text-end">CPC</th>
                        <th class="text-end">CPM</th>
                        <th class="text-end">Meta Leads</th>
                        <th class="text-end">Website Leads</th>
                        <th class="text-end">Website Lead Gap</th>
