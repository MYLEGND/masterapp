@model List<AgentPortal.Models.ResourceFileViewModel>
@using System.Linq

@{
    ViewData["Title"] = "Resources";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var resources = (ViewData.Model as IEnumerable<AgentPortal.Models.ResourceFileViewModel>)?
        .Where(r => r is not null)
        .Select(r => new AgentPortal.Models.ResourceFileViewModel
        {
            Name = r.Name ?? "",
            File = r.File ?? "",
            Extension = r.Extension ?? ""
        })
        .ToList()
        ?? new List<AgentPortal.Models.ResourceFileViewModel>();

    var resourceJson = System.Text.Json.JsonSerializer.Serialize(
        resources.Select(r => new
        {
            r.Name,
            r.File,
            r.Extension
        }));
}

<div class="resources-page container py-4">

    <!-- HEADER -->
    <div class="resources-hero mb-4">
        <h1 class="hero-title m-0">@ViewData["Title"]</h1>
        <p class="hero-sub m-0 mt-2">
            Browse or search available financial education resources.
        </p>
    </div>

    <!-- CONTROLS (NOT SIDE BY SIDE WITH PREVIEW — only controls side by side) -->
    <div class="controls-card mb-4">
        <div class="controls-head">
            <div>
                <div class="info-kicker">Education Library</div>
                <h2 class="info-title mb-1">Browse educational resources</h2>
                <p class="info-copy mb-0">Search or select a resource and preview it below without leaving the page.</p>
            </div>
        </div>

        <div class="row g-3 align-items-start">
            <!-- LEFT: DROPDOWN -->
            <div class="col-12 col-lg-6">
                <label class="control-label">Browse Resources</label>
                <select id="resourceDropdown" class="form-select premium-field">
                    <option value="">Select a resource…</option>
                    @foreach (var r in resources)
                    {
                        <option value="@r.File">@r.Name</option>
                    }
                </select>
                <div class="control-help">Choose a file to preview below.</div>
            </div>

            <!-- RIGHT: SEARCH -->
            <div class="col-12 col-lg-6">
                <label class="control-label">Search Resources</label>

                <div class="search-wrap">
                    <span class="search-icon">⌕</span>
                    <input id="resourceSearch"
                           type="text"
                           class="form-control premium-field premium-input"
                           placeholder="Search by name…" />
                </div>

                <ul id="searchResults" class="search-results" style="display:none;"></ul>
                <div class="control-help">Type to filter resources instantly.</div>
            </div>
        </div>
    </div>

    <!-- RESOURCE OUTPUT (FULL WIDTH UNDER INFO) -->
    <div id="resourceContainer" class="preview-shell" style="display:none;">
        <div class="preview-head">
            <div>
                <h2 id="resourceTitle" class="preview-title m-0"></h2>
                <div id="resourceMeta" class="preview-meta"></div>
            </div>

            <a id="resourceOpen" class="preview-open" href="#" target="_blank" rel="noopener">
                Open in new tab →
            </a>
        </div>

        <div class="preview-frame">
            <div id="resourceContent" class="preview-content"></div>
        </div>
    </div>

    <!-- EMPTY STATE -->
    <div id="emptyState" class="empty-state">
        <div class="empty-chip">Preview</div>
        <div class="empty-title">Select a resource to view it here</div>
        <div class="empty-text">
            Use the dropdown or search above. The full document will embed below for easy reading.
        </div>
    </div>

</div>

<style>
:root{
    --gold:#b4891f;
    --gold2:#b4891f;
    --ink:#e9f0ff;
    --muted:rgba(226,236,255,.82);
    --line:rgba(201,155,54,.44);
    --bg:#091427;
    --soft:#0f1f3b;
    --shadow:0 24px 58px rgba(3,8,18,.45);
    --shadowSoft:0 14px 34px rgba(3,8,18,.34);
    --r12:12px;
    --r16:16px;
    --r18:18px;
}

.resources-page{
    background:
        radial-gradient(1200px 420px at 0% 0%, rgba(201,155,54,.12), transparent 58%),
        radial-gradient(900px 320px at 100% 0%, rgba(102,124,168,.12), transparent 56%),
        var(--bg);
    color:var(--ink);
    border-radius:18px;
    padding:12px;
}

/* HERO */
.resources-hero{
    padding:22px 20px 20px;
    border:1px solid var(--line);
    border-radius: var(--r18);
    background:
        radial-gradient(1200px 420px at 12% 0%, rgba(240,207,120,.18), transparent 58%),
        radial-gradient(1000px 320px at 100% 0%, rgba(84,115,176,.14), transparent 56%),
        linear-gradient(180deg,#132747,#0d1f3c);
    box-shadow:var(--shadow);
    position:relative;
    overflow:hidden;
}

.resources-hero::before,
.controls-card::before,
.preview-shell::before,
.empty-state::before{
    content:"";
    position:absolute;
    left:0; right:0; top:0;
    height:4px;
    background:linear-gradient(90deg,#b4891f,#f0cf78,#b4891f);
}

.hero-kicker{
    display:inline-block;
    font-weight:900;
    letter-spacing:.12em;
    text-transform: uppercase;
    font-size:.74rem;
    color:#b4891f;
}

.hero-title{
    margin-top:10px !important;
    color:#b4891f;
    font-weight:900;
    font-size:clamp(1.9rem,3vw,2.45rem);
    line-height:1.08;
    text-shadow:0 1px 0 rgba(34,23,5,.8);
}

.hero-sub{
    color:var(--muted);
    max-width:900px;
    line-height:1.75;
}

/* CONTROLS CARD */
.controls-card{
    padding:20px 18px 18px;
    border:1px solid var(--line);
    border-radius: var(--r18);
    background:linear-gradient(180deg,#132747,#0d1f3c);
    box-shadow:var(--shadow);
    position:relative;
    overflow:hidden;
}

.controls-head{ margin-bottom:16px; }

.info-kicker{
    display:inline-block;
    font-weight:900;
    letter-spacing:.12em;
    text-transform:uppercase;
    font-size:.74rem;
    color:#b4891f;
}

.info-title,
.control-label,
.preview-title,
.empty-chip,
.empty-title{
    color:#b4891f;
    font-weight:900;
}

.info-copy,
.control-help,
.preview-meta,
.empty-text{
    color:var(--muted);
}

.control-label{
    margin-bottom:8px;
    letter-spacing:.01em;
}
.control-help{
    margin-top:8px;
    font-weight:700;
    font-size:.92rem;
}

/* INPUTS */
.premium-field{
    border:1px solid rgba(201,155,54,.58) !important;
    border-radius: 14px !important;
    padding:.75rem .9rem !important;
    background:#f8fbff !important;
    color:#0f1d38 !important;
}
.premium-field:focus{
    border-color:rgba(240,207,120,.92) !important;
    box-shadow:0 0 0 .22rem rgba(201,155,54,.22) !important;
}

.search-wrap{
    position: relative;
}
.search-icon{
    position:absolute;
    left:12px;
    top:50%;
    transform: translateY(-50%);
    opacity:.55;
    font-weight:900;
}
.premium-input{
    padding-left:36px !important;
}

/* SEARCH RESULTS */
.search-results{
    margin:10px 0 0;
    padding:6px;
    list-style:none;
    border-radius:16px;
    border:1px solid var(--line);
    background:rgba(9,21,39,.96);
    max-height:280px;
    overflow-y:auto;
    box-shadow:var(--shadowSoft);
}
.search-results li{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    padding:10px;
    border-radius:12px;
    cursor:pointer;
    color:#edf3ff;
}
.search-results li:hover{
    background:rgba(201,155,54,.16);
}
.result-name{
    font-weight:900;
    color:#edf3ff;
}
.result-tag{
    font-size:.76rem;
    font-weight:950;
    padding:4px 8px;
    border-radius:999px;
    border:1px solid rgba(201,155,54,.35);
    color:#b4891f;
    background:rgba(15,31,57,.90);
}

/* PREVIEW */
.preview-shell{
    border:1px solid var(--line);
    border-radius: var(--r18);
    background:linear-gradient(180deg,#132747,#0d1f3c);
    box-shadow:var(--shadow);
    overflow:hidden;
    position:relative;
    scroll-margin-top:18px;
}

.preview-head{
    padding:16px 18px;
    border-bottom:1px solid var(--line);
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:12px;
    background:linear-gradient(180deg, rgba(201,155,54,.18), rgba(18,40,73,.16) 62%, transparent 100%);
}

.preview-title{
    letter-spacing:-0.02em;
    font-size:1.35rem;
}
.preview-meta{
    margin-top:6px;
    font-weight:800;
    font-size:.92rem;
}

.preview-open{
    white-space:nowrap;
    text-decoration:none;
    font-weight:950;
    color:#1e1305;
    padding:10px 12px;
    border-radius:999px;
    border:1px solid rgba(201,155,54,.52);
    background:linear-gradient(180deg,#f8e2a8,#c89a35);
    transition:transform .12s ease, filter .15s ease;
}
.preview-open:hover{
    transform:translateY(-1px);
    filter:brightness(1.05);
}

.preview-frame{
    padding:18px;
}

.preview-content{
    border-radius:16px;
    border:1px solid var(--line);
    background:#fff;
    overflow:hidden;
}

/* Embedded media */
.preview-content img,
.preview-content video,
.preview-content iframe{
    width: 100%;
    display:block;
    border: 0;
}
.preview-content iframe{
    height: min(82vh, 980px);
}
.preview-content video{
    max-height: 82vh;
}

/* EMPTY STATE */
.empty-state{
    margin-top:16px;
    padding:22px 18px;
    border:1px dashed rgba(201,155,54,.48);
    border-radius: var(--r18);
    background:rgba(17,36,65,.68);
    position:relative;
    overflow:hidden;
}
.empty-chip{
    display:inline-block;
    font-weight:950;
    letter-spacing:.12em;
    text-transform: uppercase;
    font-size:.72rem;
    padding:6px 10px;
    border-radius:999px;
    border:1px solid rgba(201,155,54,.55);
    background:linear-gradient(180deg, rgba(201,155,54,.22), rgba(201,155,54,.10));
}
.empty-title{
    margin-top:10px;
    font-size:1.2rem;
}
.empty-text{
    margin-top:6px;
    line-height:1.7;
    max-width:900px;
}

/* Hard lock against global site.css white-card overrides */
.resources-page .resources-hero,
.resources-page .controls-card,
.resources-page .preview-shell,
.resources-page .empty-state{
    background:linear-gradient(180deg,#132747,#0d1f3c) !important;
    border:1px solid rgba(201,155,54,.44) !important;
    box-shadow:0 24px 58px rgba(3,8,18,.45) !important;
}

.resources-page .resources-hero .hero-kicker,
.resources-page .resources-hero .hero-title,
.resources-page .controls-card .info-kicker,
.resources-page .controls-card .info-title,
.resources-page .controls-card .control-label,
.resources-page .preview-shell .preview-title,
.resources-page .empty-state .empty-chip,
.resources-page .empty-state .empty-title,
.resources-page .search-results .result-tag{
    color:#b4891f !important;
}

.resources-page .resources-hero .hero-sub,
.resources-page .controls-card .info-copy,
.resources-page .controls-card .control-help,
.resources-page .preview-shell .preview-meta,
.resources-page .empty-state .empty-text,
.resources-page .search-results .result-name,
.resources-page .search-results li{
    color:#d7e2f7 !important;
}

.resources-page .controls-card .form-select,
.resources-page .controls-card .form-control,
.resources-page .controls-card .premium-field,
.resources-page .controls-card .premium-input{
    background:#f8fbff !important;
    color:#0f1d38 !important;
    border:1px solid rgba(201,155,54,.58) !important;
}

.resources-page .controls-card .search-results{
    background:rgba(9,21,39,.96) !important;
    border:1px solid rgba(201,155,54,.44) !important;
}

.resources-page .preview-shell .preview-head{
    background:linear-gradient(180deg, rgba(201,155,54,.18), rgba(18,40,73,.16) 62%, transparent 100%) !important;
    border-bottom:1px solid rgba(201,155,54,.44) !important;
}

.resources-page .preview-shell .preview-open{
    color:#1e1305 !important;
    background:linear-gradient(180deg,#f8e2a8,#c89a35) !important;
    border:1px solid rgba(201,155,54,.52) !important;
}

@@media (max-width: 767.98px){
    .hero-title{ font-size:1.5rem; }
}
</style>

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {

    const resources = @Html.Raw(resourceJson);

    const dropdown = document.getElementById("resourceDropdown");
    const searchInput = document.getElementById("resourceSearch");
    const searchResults = document.getElementById("searchResults");

    const container = document.getElementById("resourceContainer");
    const emptyState = document.getElementById("emptyState");

    const title = document.getElementById("resourceTitle");
    const meta = document.getElementById("resourceMeta");
    const openLink = document.getElementById("resourceOpen");
    const content = document.getElementById("resourceContent");

    function scrollPreviewIntoView() {
        if (!container || container.style.display === "none") return;
        window.requestAnimationFrame(() => {
            container.scrollIntoView({ behavior: "smooth", block: "start" });
        });
    }

    function extTag(ext){
        if (!ext) return "FILE";
        return ext.replace(".","").toUpperCase();
    }

    function renderResource(r) {
        emptyState.style.display = "none";
        container.style.display = "block";

        title.textContent = r.Name;

        const url = `/resources/${r.File}`;
        openLink.href = url;

        const ext = (r.Extension || "").toLowerCase();
        meta.textContent = `Type: ${extTag(ext)} • File: ${r.File}`;

        let body = "";
        if (ext === ".pdf") {
            body = `<iframe src="${url}" loading="lazy"></iframe>`;
        }
        else if ([".png", ".jpg", ".jpeg", ".webp"].includes(ext)) {
            body = `<img src="${url}" alt="${r.Name}" loading="lazy" />`;
        }
        else if (ext === ".mp4") {
            body = `
                <video controls preload="metadata">
                    <source src="${url}" type="video/mp4">
                </video>`;
        }
        else {
            body = `
                <div style="padding:18px;">
                    <a class="preview-open" href="${url}" target="_blank" rel="noopener">Open ${r.Name} →</a>
                </div>`;
        }

        content.innerHTML = body;
        scrollPreviewIntoView();
    }

    // DROPDOWN
    dropdown.addEventListener("change", function () {
        const file = this.value;

        searchInput.value = "";
        searchResults.innerHTML = "";
        searchResults.style.display = "none";

        if (!file) {
            container.style.display = "none";
            emptyState.style.display = "block";
            return;
        }

        const r = resources.find(x => x.File === file);
        if (r) renderResource(r);
    });

    // SEARCH (partial match)
    searchInput.addEventListener("input", function () {
        const q = (this.value || "").trim().toLowerCase();
        searchResults.innerHTML = "";

        if (!q) {
            searchResults.style.display = "none";
            return;
        }

        const matches = resources
            .filter(r => (r.Name || "").toLowerCase().includes(q))
            .slice(0, 30);

        if (matches.length === 0){
            searchResults.style.display = "block";
            searchResults.innerHTML = `<li style="padding:12px 10px; opacity:.7;">No matches found.</li>`;
            return;
        }

        matches.forEach(r => {
            const li = document.createElement("li");

            const left = document.createElement("div");
            left.className = "result-name";
            left.textContent = r.Name;

            const right = document.createElement("div");
            right.className = "result-tag";
            right.textContent = extTag((r.Extension || "").toLowerCase());

            li.appendChild(left);
            li.appendChild(right);

            li.onclick = () => {
                renderResource(r);
                dropdown.value = r.File;
                searchResults.innerHTML = "";
                searchResults.style.display = "none";
            };

            searchResults.appendChild(li);
        });

        searchResults.style.display = "block";
    });

    // Close results if clicking away
    document.addEventListener("click", (e) => {
        const clickedInside = searchResults.contains(e.target) || searchInput.contains(e.target);
        if (!clickedInside){
            searchResults.style.display = "none";
        }
    });

});
</script>
}
