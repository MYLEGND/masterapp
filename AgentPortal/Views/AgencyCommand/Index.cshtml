@model AgentPortal.Models.AgencyCommandDashboardVm
@{
    ViewData["Title"] = "Agency Command";
}

<div class="agency-command-page founder-tier-page">
<section class="command-hero">
    <div class="command-hero__content">
        <div>
            <p class="eyebrow">Founder • Internal Only</p>
            <h1>Agency Command</h1>
            <p class="lede">Executive visibility across every agent. Read-only, scoped to founder identity.</p>
        </div>
        <div class="mt-2">
            <button type="button" class="btn btn-gold" id="open-rev-modal">Agency Production</button>
        </div>
        <div class="kpi-grid">
            <div class="kpi-card gold">
                <div class="kpi-label">Total Agents</div>
                <div class="kpi-value">@Model.Overall.TotalAgents</div>
            </div>
            <div class="kpi-card blue">
                <div class="kpi-label">Total Leads</div>
                <div class="kpi-value">@Model.Overall.TotalLeads</div>
                <div class="kpi-sub">Calls Today @Model.Overall.CallsToday • This Week @Model.Overall.CallsWeek</div>
            </div>
            <div class="kpi-card green">
                <div class="kpi-label">Total Clients</div>
                <div class="kpi-value">@Model.Overall.TotalClients</div>
                <div class="kpi-sub">Follow-ups due @Model.Overall.FollowUpsDue</div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("_RevenueModal", Model.Revenue)

<section class="agent-grid container-fluid px-0">
    <div class="row g-4">
        @foreach (var agent in Model.Agents)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="agent-card">
                    <div class="agent-card__header">
                        <div>
                            <p class="agent-email">@agent.Email</p>
                            <h3>@agent.FullName</h3>
                            @if (!string.IsNullOrWhiteSpace(agent.Title))
                            {
                                <span class="pill">@agent.Title</span>
                            }
                        </div>
                        <div class="agent-counts">
                            <div><span class="count-label">Leads</span><span class="count-value leads">@agent.LeadCount</span></div>
                            <div><span class="count-label">Clients</span><span class="count-value clients">@agent.ClientCount</span></div>
                        </div>
                    </div>

                    <div class="agent-card__metrics">
                        <div class="metric">
                            <div class="metric-label">Calls Today</div>
                            <div class="metric-value calls-today">@agent.CallsToday</div>
                        </div>
                        <div class="metric">
                            <div class="metric-label">Calls This Week</div>
                            <div class="metric-value calls-week">@agent.CallsWeek</div>
                        </div>
                        <div class="metric">
                            <div class="metric-label">Follow-ups Due</div>
                            <div class="metric-value followups">@agent.FollowUpsDue</div>
                        </div>
                    </div>

                    <div class="agent-card__footer">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <form asp-controller="Impersonation" asp-action="Start" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="agentId" value="@agent.AgentUserId" />
                                <input type="hidden" name="returnUrl" value="@Url.Action("Index","Leads")" />
                                <button type="submit" class="btn btn-gold">View as Agent</button>
                            </form>

                            <form asp-controller="AgencyCommand" asp-action="SetOrder" method="post" class="order-form d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="agentId" value="@agent.AgentUserId" />
                                <label class="order-label text-muted">Position</label>
                                <input class="order-input" type="number" name="order" value="@agent.DisplayOrder" min="1" placeholder="1" />
                                <button type="submit" class="btn btn-outline-light btn-sm">Save</button>
                            </form>
                        </div>
                        <span class="security-note">Founder-only</span>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
</div>

@section Styles {
    <style>
        :root {
            --navy: #0b1529;
            --navy-soft: #0f172a;
            --gold: #ddb457;
            --gold-strong: #a68023;
            --gold-deep: #7b5a14;
            --card: #0f172a;
            --muted: #94a3b8;
        }

        body { background: #0a0f1d; }

        .command-hero {
            padding: 28px 12px 8px 12px;
            color: #f8fafc;
        }
        .command-hero__content {
            background: linear-gradient(135deg, #0f172a, #0b1529 55%, #0f172a);
            border: 1.6px solid rgba(221,180,87,.55);
            box-shadow: 0 20px 50px rgba(0,0,0,.38);
            border-radius: 18px;
            padding: 26px 28px;
        }
        .eyebrow {
            letter-spacing: 0.18em;
            text-transform: uppercase;
            color: var(--gold);
            font-weight: 800;
            margin-bottom: 6px;
        }
        h1 { font-weight: 900; letter-spacing: 0.02em; margin: 0; }
        .lede { color: var(--muted); font-weight: 600; margin-top: 6px; }

        .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(180px,1fr)); gap: 12px; margin-top: 18px; }
        .kpi-card {
            background: #0c1a32;
            border: 1.6px solid rgba(221,180,87,.45);
            border-radius: 14px;
            padding: 12px 14px;
            box-shadow: 0 12px 28px rgba(0,0,0,.32);
        }
        .kpi-label { color: var(--muted); font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; }
        .kpi-value { color: #fff; font-size: 1.8rem; font-weight: 900; }
        .kpi-sub { color: var(--muted); font-weight: 700; font-size: 0.9rem; }
        .kpi-card.gold { border-color: rgba(221,180,87,.7); }
        .kpi-card.blue { border-color: rgba(59,130,246,.55); }
        .kpi-card.green { border-color: rgba(34,197,94,.55); }

        .agent-grid { padding: 14px 12px 40px 12px; }
        .agent-card {
            background: radial-gradient(140% 120% at 10% 0%, rgba(221,180,87,.06), transparent 42%),
                        linear-gradient(145deg, #0b1425, #0e1a31 55%, #0b1425);
            color: #e2e8f0;
            border: 2px solid rgba(221,180,87,.7);
            border-radius: 16px;
            padding: 18px;
            box-shadow:
                0 26px 58px rgba(0,0,0,.42),
                0 0 0 1px rgba(255,255,255,.05),
                inset 0 1px 0 rgba(255,255,255,.08);
            display: flex;
            flex-direction: column;
            gap: 12px;
            min-height: 100%;
            position: relative;
            overflow: hidden;
            backdrop-filter: blur(2px);
        }
        /* outer gilded frame */
        .agent-card::before{
            content:"";
            position:absolute;
            inset:-1px;
            background: linear-gradient(135deg,
                rgba(221,180,87,.28),
                rgba(59,130,246,.14) 42%,
                rgba(34,197,94,.12));
            z-index:0;
            opacity:.55;
            pointer-events:none;
            mask: linear-gradient(#000,#000) padding-box, linear-gradient(#000,#000);
            -webkit-mask: linear-gradient(#000,#000) padding-box, linear-gradient(#000,#000);
            mask-composite: exclude;
            -webkit-mask-composite: destination-out;
        }
        /* top rail accent */
        .agent-card::after{
            content:"";
            position:absolute;
            top:0;left:0;right:0;
            height:4px;
            background: linear-gradient(90deg, rgba(221,180,87,.95), rgba(59,130,246,.65), rgba(34,197,94,.65));
            opacity:.9;
            box-shadow:0 8px 16px rgba(0,0,0,.35);
            z-index:1;
        }
        .agent-card > * { position: relative; z-index: 2; }
        .agent-card__header {
            padding-bottom: 8px;
            border-bottom: 1px solid rgba(221,180,87,.28);
        }
        .agent-card__header { display: flex; justify-content: space-between; gap: 12px; align-items: flex-start; }
        .agent-email { color: var(--muted); margin: 0; font-weight: 700; font-size: 0.9rem; }
        .agent-card h3 { margin: 2px 0 0 0; font-weight: 900; letter-spacing: 0.01em; color: #fff; }
        .agent-counts { display: flex; flex-direction: column; gap: 6px; text-align: right; }
        .count-label { color: var(--muted); font-size: 0.8rem; font-weight: 700; }
        .count-value { display: block; font-size: 1.4rem; font-weight: 900; }
        .count-value.leads { color: #60a5fa; }
        .count-value.clients { color: #34d399; }

        .agent-card__metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
        .metric { background: #0d1f3a; padding: 10px; border-radius: 12px; border: 1px solid rgba(221,180,87,.3); box-shadow: inset 0 1px 0 rgba(255,255,255,.05); }
        .metric-label { color: var(--muted); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
        .metric-value { font-size: 1.3rem; font-weight: 900; }
        .metric-value.calls-today { color: #38bdf8; }
        .metric-value.calls-week { color: #7dd3fc; }
        .metric-value.followups { color: #fbbf24; }

        .pill { display: inline-flex; align-items: center; gap: 6px; padding: 6px 10px; border-radius: 999px; background: rgba(221,180,87,.14); color: #f8fafc; border: 1px solid rgba(221,180,87,.35); font-weight: 800; }
        .pill.subtle { background: rgba(255,255,255,.06); border-color: rgba(221,180,87,.2); color: #e2e8f0; }
        .pill.muted { color: var(--muted); }

        .agent-card__footer { display: flex; justify-content: space-between; align-items: center; gap: 10px; }
        .btn-gold {
            background: linear-gradient(160deg, #f8e2a1 0%, #e7c468 25%, #b88928 60%, #8a661a 100%);
            color: #0b1529;
            font-weight: 900;
            padding: 11px 16px;
            border-radius: 12px;
            border: 1px solid rgba(221,180,87,.9);
            box-shadow:
                0 14px 32px rgba(221,180,87,.45),
                inset 0 1px 0 rgba(255,255,255,.55),
                inset 0 -1px 0 rgba(0,0,0,.35);
            text-decoration: none;
            letter-spacing: 0.01em;
            transition: transform .08s ease, box-shadow .12s ease, filter .12s ease;
        }
        .btn-gold:hover {
            text-decoration: none;
            color: #0b1529;
            transform: translateY(-1px);
            box-shadow:
                0 18px 38px rgba(221,180,87,.55),
                inset 0 1px 0 rgba(255,255,255,.65),
                inset 0 -1px 0 rgba(0,0,0,.4);
            filter: brightness(1.04);
        }
        .btn-gold:active {
            transform: translateY(0);
            box-shadow:
                0 10px 24px rgba(221,180,87,.4),
                inset 0 1px 0 rgba(255,255,255,.4),
                inset 0 -1px 0 rgba(0,0,0,.45);
        }
        .security-note { color: var(--muted); font-weight: 700; font-size: 0.9rem; }
        .order-form { display:inline-flex; align-items:center; gap:6px; }
        .order-input { width:70px; background:#0b1425; color:#e5e7eb; border:1px solid rgba(221,180,87,.4); border-radius:8px; padding:6px 8px; }
        .order-label { font-size:0.85rem; font-weight:700; }

        /* Modal */
        .rev-modal{position:fixed;inset:0;display:none;align-items:center;justify-content:center;z-index:9999;padding:2.5vh 0;}
        .rev-modal[aria-hidden="false"]{display:flex;}
        .rev-modal__backdrop{position:absolute;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(4px);}        
        .rev-modal__panel{position:relative;z-index:2;width:min(1200px,94vw);max-height:90vh;overflow-y:auto;overflow-x:hidden;background:#0b1529;border:2px solid rgba(221,180,87,.7);border-radius:18px;box-shadow:0 28px 64px rgba(0,0,0,.45);padding:18px;overscroll-behavior:contain;-webkit-overflow-scrolling:touch;scrollbar-gutter:stable;}
        .rev-modal__header{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;color:#e5e7eb;margin-bottom:10px;}
        .rev-modal__header h2{margin:0;font-weight:900;letter-spacing:.01em;}
        .btn-close{background:transparent;border:1px solid rgba(221,180,87,.5);color:#e5e7eb;font-size:1.4rem;line-height:1;padding:6px 10px;border-radius:10px;}
        .btn-close:hover{color:#0b1529;background:#f8e2a1;}

        /* Re-use revenue styles from modal partial */
        .revenue-kpi-layout{display:grid;grid-template-columns:minmax(0,2.2fr) minmax(260px,1fr);gap:12px;padding:8px;align-items:stretch;}
        .revenue-pill-grid{display:flex;flex-direction:column;gap:12px;min-width:0;}
        .revenue-pill-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;}
        .revenue-major-stack{display:grid;grid-template-rows:1fr 1fr;gap:12px;}
        .major-card{padding:16px;border-radius:16px;border:1.6px solid rgba(221,180,87,.45);background:linear-gradient(180deg,#101d35,#0b162b);box-shadow:0 16px 34px rgba(0,0,0,.24);display:flex;flex-direction:column;justify-content:center;min-height:126px;}
        .major-card .label{font-weight:900;color:#cbd5e1;text-transform:uppercase;font-size:.8rem;letter-spacing:.05em;}
        .major-card .value{font-weight:900;font-size:2rem;line-height:1.05;}
        .major-card .note{font-weight:700;color:#9fb0ca;}
        .major-card.paid-total{border-color:rgba(34,197,94,.62);background:linear-gradient(180deg,#113122,#0b251a);}
        .major-card.paid-total .value{color:#34d399;}
        .major-card.progress-total{border-color:rgba(96,165,250,.6);background:linear-gradient(180deg,#11233f,#0b1a31);}
        .major-card.progress-total .value{color:#7dc4ff;}
        .revenue-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;padding:8px;}
        .rev-card{padding:14px;border-radius:14px;background:#0b1224;border:1.6px solid rgba(221,180,87,.45);box-shadow:0 14px 34px rgba(0,0,0,.24);min-height:126px;display:flex;flex-direction:column;justify-content:center;}        
        .rev-card .label{font-weight:800;color:#cbd5e1;text-transform:uppercase;font-size:.85rem;letter-spacing:.04em;}
        .rev-card .value{font-weight:900;font-size:1.7rem;color:#ffffff;}
        .rev-card .note{color:#94a3b8;font-weight:700;}
        .rev-card.submitted{border-color:rgba(255,191,71,.7);background:#2f2106;}
        .rev-card.submitted .value{color:#fbbf24;}
        .rev-card.issued{border-color:rgba(59,130,246,.65);background:#0c1a3a;}
        .rev-card.issued .value{color:#60a5fa;}
        .rev-card.paid{border-color:rgba(34,197,94,.65);background:#0f2b1f;}
        .rev-card.paid .value{color:#34d399;}
        @@media (max-width: 1100px){
            .revenue-kpi-layout{grid-template-columns:1fr;}
            .revenue-major-stack{grid-template-columns:1fr 1fr;grid-template-rows:none;}
        }
        @@media (max-width: 768px){
            .revenue-pill-row{grid-template-columns:1fr;}
            .revenue-major-stack{grid-template-columns:1fr;}
            .major-card .value{font-size:1.7rem;}
        }
        .agent-table{margin:14px 6px;background:#0f1629;border:1.6px solid rgba(221,180,87,.5);border-radius:16px;overflow:hidden;box-shadow:0 16px 38px rgba(0,0,0,.24);}        
        .agent-table .card-header{font-weight:900;padding:14px 18px;border-bottom:1px solid rgba(221,180,87,.35);background:#0b1529;color:#e2e8f0;}
        #topProducersAccordionModal{display:flex;flex-direction:column;gap:14px;padding:12px;}
        .accordion-item.soft-dark{border:1px solid rgba(221,180,87,.28);border-radius:16px;overflow:hidden;background:#0f172a;}
        .accordion-button.soft-dark{background:#0f172a;color:#e5e7eb;padding:14px 18px;}
        .accordion-button:focus{box-shadow:none;border-color:rgba(221,180,87,.6);}        
        .accordion-button:not(.collapsed){box-shadow:inset 0 -1px 0 rgba(221,180,87,.25);}        
        .text-ink{color:#e5e7eb!important;}
        .border-gold{border-color:rgba(221,180,87,.45)!important;}
        .text-gold{color:#fbbf24;}
        .top-prod-table thead th{color:#cbd5e1;background:#0d1425;border-color:rgba(221,180,87,.3);font-weight:800;}
        .top-prod-table tbody td{color:#e5e7eb;background:#0f182b;border-color:rgba(221,180,87,.08);}        
        .top-prod-table tbody tr:nth-child(2n) td{background:#101d33;}
        .producer-card{border:1px solid rgba(221,180,87,.26);border-radius:18px;overflow:hidden;background:linear-gradient(180deg,#0f1a2d,#0c1526 58%,#0b1324);margin-bottom:14px;box-shadow:0 18px 38px rgba(0,0,0,.28);}        
        .producer-header{background:linear-gradient(180deg,rgba(20,32,54,.98),rgba(14,24,42,.96));color:#e5e7eb;padding:14px 18px;border-bottom:1px solid rgba(221,180,87,.16);}
        .producer-summary{display:flex;justify-content:space-between;align-items:center;width:100%;gap:14px;}
        .producer-name{font-weight:900;font-size:1.05rem;letter-spacing:.01em;}
        .producer-sub{color:#a7b6d4;font-weight:700;font-size:.9rem;}
        .producer-body{background:linear-gradient(180deg,#0c1526,#101b2e);padding:16px 18px;}
        .split-card{position:relative;border:1px solid rgba(221,180,87,.24);border-radius:14px;padding:14px 14px 12px;background:linear-gradient(180deg,rgba(18,29,48,.96),rgba(13,22,38,.96));box-shadow:inset 0 1px 0 rgba(255,255,255,.04),0 12px 24px rgba(0,0,0,.18);}
        .split-card::before{content:"";position:absolute;left:0;right:0;top:0;height:3px;background:linear-gradient(90deg,rgba(221,180,87,.8),rgba(221,180,87,0));}
        .split-card.leads{border-color:rgba(59,130,246,.48);box-shadow:inset 0 1px 0 rgba(255,255,255,.04),0 12px 24px rgba(37,99,235,.12);}
        .split-card.leads::before{background:linear-gradient(90deg,rgba(96,165,250,.9),rgba(96,165,250,0));}
        .split-card.clients{border-color:rgba(34,197,94,.42);box-shadow:inset 0 1px 0 rgba(255,255,255,.04),0 12px 24px rgba(22,163,74,.12);}
        .split-card.clients::before{background:linear-gradient(90deg,rgba(52,211,153,.9),rgba(52,211,153,0));}
        .split-label{font-weight:900;color:#f6e4b2;margin-bottom:8px;text-transform:uppercase;letter-spacing:.08em;font-size:.78rem;}
        .split-values{display:flex;flex-direction:column;gap:6px;color:#dbe6fb;font-weight:700;font-size:0.92rem;}
        .split-values span{display:flex;justify-content:space-between;gap:10px;padding:7px 10px;border-radius:10px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.05);}
        .breakdown-card{position:relative;background:linear-gradient(180deg,#16233a,#101a2c);border:1px solid rgba(221,180,87,.22);border-radius:16px;padding:16px;box-shadow:0 16px 30px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.04);}        
        .breakdown-card::before{content:"";position:absolute;left:0;right:0;top:0;height:3px;background:linear-gradient(90deg,#b4891f,rgba(96,165,250,.72),rgba(52,211,153,.45));}
        .breakdown-title{font-weight:900;color:#f4d890;margin-bottom:12px;letter-spacing:.04em;text-transform:uppercase;font-size:.82rem;}
        .top-prod-table{width:100%;border-collapse:separate;border-spacing:0 8px;background:transparent!important;border:none!important;box-shadow:none!important;}
        .top-prod-table thead th{padding:10px 12px!important;font-size:.74rem;letter-spacing:.08em;text-transform:uppercase;color:#cbd5e1;background:rgba(13,20,37,.92);border-top:1px solid rgba(221,180,87,.24);border-bottom:1px solid rgba(221,180,87,.2);}
        .top-prod-table thead th:first-child{border-left:1px solid rgba(221,180,87,.2);border-top-left-radius:12px;border-bottom-left-radius:12px;}
        .top-prod-table thead th:last-child{border-right:1px solid rgba(221,180,87,.2);border-top-right-radius:12px;border-bottom-right-radius:12px;}
        .top-prod-table tbody td{padding:12px!important;color:#e5e7eb;background:rgba(13,24,43,.92);border-top:1px solid rgba(255,255,255,.03);border-bottom:1px solid rgba(221,180,87,.08);font-weight:800;}
        .top-prod-table tbody td:first-child{color:#f7e6b3!important;border-left:1px solid rgba(221,180,87,.15);border-top-left-radius:12px;border-bottom-left-radius:12px;}
        .top-prod-table tbody td:last-child{border-right:1px solid rgba(221,180,87,.15);border-top-right-radius:12px;border-bottom-right-radius:12px;}
        .top-prod-table tbody tr:nth-child(2n) td{background:rgba(16,29,51,.96);}
        .top-prod-table tbody tr:hover td{background:rgba(29,45,73,.98);transform:translateY(-1px);}
        .top-prod-table tbody td.text-warning{color:#f4cd67!important;text-shadow:0 0 16px rgba(244,205,103,.16);}
        .top-prod-table tbody td.text-info{color:#7dc4ff!important;text-shadow:0 0 16px rgba(125,196,255,.16);}
        .top-prod-table tbody td.text-success{color:#57d89c!important;text-shadow:0 0 16px rgba(87,216,156,.16);}

        .founder-tier-page {
            background:
                radial-gradient(140% 140% at 0% 0%, rgba(180,137,31,.20) 0%, rgba(180,137,31,0) 38%),
                linear-gradient(180deg, #07101f 0%, #0c1830 100%) !important;
            border: 1px solid rgba(180,137,31,.34) !important;
            border-radius: 30px !important;
            box-shadow: 0 28px 64px rgba(0,0,0,.34) !important;
            padding: clamp(1rem, 2vw, 1.7rem) !important;
            margin-bottom: 2rem;
        }

        .founder-tier-page .command-hero,
        .founder-tier-page .command-hero__content,
        .founder-tier-page .agent-card,
        .founder-tier-page .kpi-card,
        .founder-tier-page .agent-table,
        .founder-tier-page .rev-card,
        .founder-tier-page .accordion-item.soft-dark,
        .founder-tier-page .producer-card,
        .founder-tier-page .breakdown-card,
        .founder-tier-page .metric {
            position: relative;
            overflow: hidden;
        }

        .founder-tier-page .command-hero__content,
        .founder-tier-page .agent-card,
        .founder-tier-page .rev-modal__panel,
        .founder-tier-page .agent-table,
        .founder-tier-page .producer-card,
        .founder-tier-page .breakdown-card {
            background: linear-gradient(180deg, rgba(9,18,36,.97), rgba(12,25,48,.94)) !important;
            border-color: rgba(180,137,31,.28) !important;
            box-shadow: 0 24px 48px rgba(0,0,0,.32) !important;
        }

        .founder-tier-page .command-hero__content::before,
