@model AgencyRevenueVm
@{
    string NameFor(string oid) => Model.AgentNames.TryGetValue(oid, out var n) ? n : oid;
    var totalPaidAmount = Model.Leads.Paid + Model.Clients.Paid;
    var totalPaidDeals = Model.Leads.CountPaid + Model.Clients.CountPaid;
    var inProgressAmount = Model.Leads.Submitted + Model.Leads.Issued + Model.Clients.Submitted + Model.Clients.Issued;
    var inProgressDeals = Model.Leads.CountSubmitted + Model.Leads.CountIssued + Model.Clients.CountSubmitted + Model.Clients.CountIssued;
}

<div class="rev-modal" id="revModal" aria-hidden="true">
    <div class="rev-modal__backdrop" data-close-rev></div>
    <div class="rev-modal__panel" role="dialog" aria-modal="true" aria-label="Agency Production">
        <div class="rev-modal__header">
            <div>
                <p class="eyebrow">Founder • Agency Production</p>
                <h2>Revenue Intelligence</h2>
                <p class="lede">Submitted, issued, paid — split by Leads vs Clients.</p>
            </div>
            <button class="btn-close" type="button" data-close-rev aria-label="Close">×</button>
        </div>

        <div class="revenue-kpi-layout">
            <div class="revenue-pill-grid">
                <div class="revenue-pill-row">
                    <div class="rev-card submitted">
                        <div class="label">Submitted (Clients)</div>
                        <div class="value">@Model.Clients.Submitted.ToString("C0")</div>
                        <div class="note">@Model.Clients.CountSubmitted deals</div>
                    </div>
                    <div class="rev-card issued">
                        <div class="label">Issued (Clients)</div>
                        <div class="value">@Model.Clients.Issued.ToString("C0")</div>
                        <div class="note">@Model.Clients.CountIssued deals</div>
                    </div>
                    <div class="rev-card paid">
                        <div class="label">Paid (Clients)</div>
                        <div class="value">@Model.Clients.Paid.ToString("C0")</div>
                        <div class="note">@Model.Clients.CountPaid deals</div>
                    </div>
                </div>
                <div class="revenue-pill-row">
                    <div class="rev-card submitted">
                        <div class="label">Submitted (Leads)</div>
                        <div class="value">@Model.Leads.Submitted.ToString("C0")</div>
                        <div class="note">@Model.Leads.CountSubmitted deals</div>
                    </div>
                    <div class="rev-card issued">
                        <div class="label">Issued (Leads)</div>
                        <div class="value">@Model.Leads.Issued.ToString("C0")</div>
                        <div class="note">@Model.Leads.CountIssued deals</div>
                    </div>
                    <div class="rev-card paid">
                        <div class="label">Paid (Leads)</div>
                        <div class="value">@Model.Leads.Paid.ToString("C0")</div>
                        <div class="note">@Model.Leads.CountPaid deals</div>
                    </div>
                </div>
            </div>
            <div class="revenue-major-stack">
                <div class="major-card paid-total">
                    <div class="label">Total Paid (Leads + Clients)</div>
                    <div class="value">@totalPaidAmount.ToString("C0")</div>
                    <div class="note">@totalPaidDeals deals closed paid</div>
                </div>
                <div class="major-card progress-total">
                    <div class="label">In Progress (Submitted + Issued)</div>
                    <div class="value">@inProgressAmount.ToString("C0")</div>
                    <div class="note">@inProgressDeals deals in pipeline</div>
                </div>
            </div>
        </div>

        <div class="agent-table card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Top Producers by Month</span>
                <small class="text-muted fw-bold">Paid → Issued → Submitted</small>
            </div>
            <div class="accordion" id="topProducersAccordionModal">
                @foreach (var month in Model.Monthly.OrderByDescending(m => m.Month))
                {
                    var monthName = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month.Month);
                    var collapseId = $"rev-month-{month.Month}";
                    var headingId = $"rev-heading-{month.Month}";
                    var hasData = month.Producers.Any();
                    var monthTotals = month.MonthTotals;
                    <div class="accordion-item soft-dark border-gold">
                        <h2 class="accordion-header" id="@headingId">
                            <button class="accordion-button collapsed soft-dark text-ink border-gold" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                <div class="heading-left">
                                    <span class="dot text-gold">●</span>
                                    <div class="heading-text">
                                        <div class="title">@monthName @Model.Year</div>
                                        <div class="subtitle">@monthTotals.Paid.ToString("C0") paid • @monthTotals.Issued.ToString("C0") issued • @monthTotals.Submitted.ToString("C0") submitted</div>
                                    </div>
                                </div>
                                @if (!hasData)
                                {
                                    <div class="chip-row">
                                        <span class="chip muted">No production yet</span>
                                    </div>
                                }
                            </button>
                        </h2>
                        <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#topProducersAccordionModal">
                            <div class="accordion-body">
                                @if (hasData)
                                {
                                    <div class="accordion" id="producers-@month.Month">
                                        @foreach (var producer in month.Producers)
                                        {
                                    var prodCollapseId = $"rev-month-{month.Month}-prod-{producer.AgentUserId}";
                                    var prodHeadingId = $"rev-heading-{month.Month}-prod-{producer.AgentUserId}";
                                    var name = NameFor(producer.AgentUserId);
                                    <div class="accordion-item producer-card">
                                        <h2 class="accordion-header" id="@prodHeadingId">
                                                    <button class="accordion-button collapsed producer-header" type="button" data-bs-toggle="collapse" data-bs-target="#@prodCollapseId" aria-expanded="false" aria-controls="@prodCollapseId">
                                                        <div class="producer-summary">
                                                            <div>
                                                                <div class="producer-name">@name</div>
                                                                <div class="producer-sub">@monthName @Model.Year</div>
                                                            </div>
                                                            <div class="chip-row">
                                                                <span class="chip success">Paid @producer.Totals.Paid.ToString("C0")</span>
                                                                <span class="chip info">Issued @producer.Totals.Issued.ToString("C0")</span>
                                                                <span class="chip warn">Submitted @producer.Totals.Submitted.ToString("C0")</span>
                                                            </div>
                                                        </div>
                                                    </button>
                                                </h2>
                                        <div id="@prodCollapseId" class="accordion-collapse collapse" aria-labelledby="@prodHeadingId" data-bs-parent="#producers-@month.Month">
                                            <div class="accordion-body producer-body">
                                                <div class="row g-3 mb-2">
                                                    <div class="col-12 col-md-6">
                                                        <div class="split-card leads">
                                                            <div class="split-label">Leads</div>
                                                            <div class="split-values">
                                                                <span>Submitted @producer.LeadsTotals.Submitted.ToString("C0") (@producer.LeadsTotals.CountSubmitted)</span>
                                                                <span>Issued @producer.LeadsTotals.Issued.ToString("C0") (@producer.LeadsTotals.CountIssued)</span>
                                                                <span>Paid @producer.LeadsTotals.Paid.ToString("C0") (@producer.LeadsTotals.CountPaid)</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-12 col-md-6">
                                                        <div class="split-card clients">
                                                            <div class="split-label">Clients</div>
                                                            <div class="split-values">
                                                                <span>Submitted @producer.ClientsTotals.Submitted.ToString("C0") (@producer.ClientsTotals.CountSubmitted)</span>
                                                                <span>Issued @producer.ClientsTotals.Issued.ToString("C0") (@producer.ClientsTotals.CountIssued)</span>
                                                                <span>Paid @producer.ClientsTotals.Paid.ToString("C0") (@producer.ClientsTotals.CountPaid)</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="row g-3">
                                                    <div class="col-12 col-xl-6">
                                                        <div class="breakdown-card">
                                                            <div class="breakdown-title">Weekly Breakdown</div>
                                                            @if (producer.Weekly.Any())
                                                                    {
                                                                        <table class="table table-striped table-sm align-middle mb-0 top-prod-table">
                                                                            <thead>
                                                                                <tr><th>Week Start</th><th>Submitted</th><th>Issued</th><th>Paid</th></tr>
                                                                            </thead>
                                                                            <tbody>
                                                                            @foreach (var w in producer.Weekly)
                                                                            {
                                                                                <tr>
                                                                                    <td>@w.WeekStart.ToString("MMM dd")</td>
                                                                                    <td class="text-warning">@w.Totals.Submitted.ToString("C0")</td>
                                                                                    <td class="text-info">@w.Totals.Issued.ToString("C0")</td>
                                                                                    <td class="text-success">@w.Totals.Paid.ToString("C0")</td>
                                                                                </tr>
                                                                            }
                                                                            </tbody>
                                                                        </table>
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="text-muted fw-semibold">No weekly production.</div>
                                                                    }
                                                                </div>
                                                            </div>
                                                            <div class="col-12 col-xl-6">
                                                                <div class="breakdown-card">
                                                                    <div class="breakdown-title">Monthly Total</div>
                                                                    <table class="table table-sm align-middle mb-0 top-prod-table">
                                                                        <thead>
                                                                            <tr><th>Status</th><th>Amount</th><th># Deals</th></tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            <tr>
                                                                                <td class="fw-bold" style="color:#f6e4b2">Submitted</td>
                                                                                <td class="text-warning">@producer.Totals.Submitted.ToString("C0")</td>
                                                                                <td class="text-muted">@producer.Totals.CountSubmitted</td>
                                                                            </tr>
                                                                            <tr>
                                                                                <td class="fw-bold" style="color:#f6e4b2">Issued</td>
                                                                                <td class="text-info">@producer.Totals.Issued.ToString("C0")</td>
                                                                                <td class="text-muted">@producer.Totals.CountIssued</td>
                                                                            </tr>
                                                                            <tr>
                                                                                <td class="fw-bold" style="color:#f6e4b2">Paid</td>
                                                                                <td class="text-success">@producer.Totals.Paid.ToString("C0")</td>
                                                                                <td class="text-muted">@producer.Totals.CountPaid</td>
                                                                            </tr>
                                                                            @if (producer.Totals.Personal > 0)
                                                                            {
                                                                                <tr>
                                                                                    <td class="fw-bold" style="color:#f6e4b2">Personal</td>
                                                                                    <td style="color:#f59e0b">@producer.Totals.Personal.ToString("C0")</td>
                                                                                    <td class="text-muted">@producer.Totals.CountPersonal</td>
                                                                                </tr>
                                                                            }
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted fw-semibold">No production recorded for this month.</div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
