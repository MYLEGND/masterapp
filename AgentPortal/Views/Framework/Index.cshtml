@{
    ViewData["Title"] = "Framework";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Ensure ViewBag.Illustrations is populated in the controller
    var illustrations = ViewBag.Illustrations ?? new List<dynamic>();
    var selectedTool = illustrations.Count > 0 ? illustrations[0] : null;

    var selectedToolFile = selectedTool != null ? selectedTool.File : "";
    var selectedToolLabel = selectedTool != null ? selectedTool.Label : "Framework Tool";

    var taglineLine1 = "Where Your Faith Fuels Your Future";
    var taglineLine2 = "& Wellness Meets Wealth";
}

<meta charset="utf-8" />

<div class="container framework-container">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3 framework-header" style="border-bottom:1.5px solid #a68023; padding-bottom:12px; gap:20px;">
        <div style="font-weight:700; font-size:1.25rem; color:#000; white-space:nowrap;">
            @selectedToolLabel
        </div>

        <div class="text-center flex-grow-1 my-2 my-md-0" style="font-style:italic; font-weight:600; font-size:1.05rem; color:#333;">
            <div>@taglineLine1</div>
            <div>@taglineLine2</div>
        </div>

        <div class="d-flex flex-column flex-md-row align-items-stretch align-items-md-end gap-2" style="width:100%; max-width:450px;">
            <div class="flex-grow-1">
                <label for="toolSelect" class="form-label mb-1" style="font-weight:600; color:#a68023;">Select Coaching Tool</label>
                <select id="toolSelect" class="form-select form-select-sm" onchange="swapTool(this.value)" style="border:1.5px solid #a68023; border-radius:6px; width:100%;">
                    @foreach (var tool in illustrations)
                    {
                        <option value="@tool.File" selected="@(tool.File == selectedToolFile ? "selected" : null)">
                            @tool.Label
                        </option>
                    }
                </select>
            </div>

            <div class="flex-grow-1 mt-2 mt-md-0">
                <input type="text" id="frameworkSearch" class="form-control form-control-sm" placeholder="Search tools..." style="border:1.5px solid #a68023; border-radius:6px; width:100%;" />
                <ul id="frameworkSearchResults" class="list-group" style="width:100%; max-height:220px; overflow-y:auto; margin-top:4px; display:none; border:1.5px solid #a68023; border-radius:6px;"></ul>
            </div>
        </div>
    </div>

    <div id="toolDisplay" class="mt-4 text-center framework-display" style="border:1.5px solid #a68023; border-radius:6px; padding:10px;">
        <img id="currentTool" 
             src="@Url.Content($"~/images/illustrations/{selectedToolFile}")" 
             alt="@selectedToolLabel" 
             style="max-width:100%; max-height:80vh; height:auto; display:block; margin:0 auto;" />
    </div>
</div>

@section Scripts {
<script>
    // Swap displayed image and update alt/label
    function swapTool(file) {
        const display = document.getElementById('currentTool');
        display.src = '/images/illustrations/' + file + '?v=' + new Date().getTime();

        // Use the exact label from the dropdown
        const option = document.querySelector('#toolSelect option[value="' + file + '"]');
        const label = option ? option.text : file.replace(/\.[^/.]+$/, "").replace(/[-_]/g, ' ');
        
        display.alt = label;
        document.querySelector('.framework-header > div:first-child').innerText = label;
        document.getElementById('toolSelect').value = file;
    }

    // Build a tools array for search from the actual dropdown labels
    const tools = Array.from(document.querySelectorAll('#toolSelect option')).map(opt => ({
        name: opt.text,
        file: opt.value
    }));

    const searchInput = document.getElementById('frameworkSearch');
    const resultsList = document.getElementById('frameworkSearchResults');

    // Live search
    searchInput.addEventListener('input', function () {
        const query = this.value.toLowerCase();
        resultsList.innerHTML = '';

        if (!query) { resultsList.style.display = 'none'; return; }

        const matches = tools.filter(t => t.name.toLowerCase().includes(query));
        if (matches.length === 0) { resultsList.style.display = 'none'; return; }

        matches.forEach(t => {
            const li = document.createElement('li');
            li.className = 'list-group-item list-group-item-action';
            li.textContent = t.name;
            li.onclick = function () { 
                swapTool(t.file); 
                resultsList.style.display = 'none'; 
                searchInput.value = ''; 
            };
            resultsList.appendChild(li);
        });

        resultsList.style.display = 'block';
    });
</script>
}
