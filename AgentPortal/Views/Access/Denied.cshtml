@{
    ViewData["Title"] = "Access Denied";
}

<div style="max-width:720px;margin:2.5rem auto;padding:0 1.25rem;">
    <div style="background:#fff;border:1.5px solid rgba(166,128,35,.2);border-radius:22px;box-shadow:0 18px 40px rgba(64,47,11,.08);overflow:hidden;">
        <div style="height:4px;background:linear-gradient(90deg,#a68023,#c79931,#ddb457,#c79931,#a68023);"></div>
        <div style="padding:2rem 1.8rem;">
            <div style="display:inline-flex;align-items:center;gap:.4rem;padding:.4rem .75rem;border-radius:999px;background:rgba(166,128,35,.1);color:#8a6920;font-size:.78rem;font-weight:900;text-transform:uppercase;letter-spacing:.8px;margin-bottom:1rem;">Legend Access</div>
            <h1 style="margin:0 0 .7rem;font-size:2rem;font-weight:950;color:#17120a;letter-spacing:-.4px;">Access denied</h1>
            <p style="margin:0;color:#5a4d3d;font-size:.98rem;line-height:1.7;">You do not have permission to open this area of the portal.</p>
        </div>
    </div>
</div>