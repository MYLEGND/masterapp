@{
    ViewData["Title"] = "Limited Access";
    var reason = (ViewData["Reason"]?.ToString() ?? "restricted").Trim().ToLowerInvariant();
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
    var subtitle = reason == "disabled"
        ? "Your assistant access has been turned off for this account."
        : reason == "unassigned"
            ? "This login was not matched to an active assistant assignment yet."
        : "This area is outside the assistant workspace.";
}

<style>
    .limited-shell {
        max-width: 880px;
        margin: 2rem auto;
        padding: 0 1.25rem;
    }
    .limited-hero {
        background: linear-gradient(135deg, rgba(166,128,35,.09), rgba(199,153,49,.06));
        border: 1.5px solid rgba(166,128,35,.22);
        border-radius: 24px;
        box-shadow: 0 18px 40px rgba(64,47,11,.08);
        overflow: hidden;
    }
    .limited-topbar {
        height: 4px;
        background: linear-gradient(90deg,#a68023,#c79931,#ddb457,#c79931,#a68023);
    }
    .limited-content {
        padding: 2.5rem 2.25rem;
        display: grid;
        grid-template-columns: 1.2fr .8fr;
        gap: 2rem;
        align-items: start;
    }
    .limited-badge {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .45rem .8rem;
        border-radius: 999px;
        background: rgba(166,128,35,.1);
        color: #8a6920;
        font-size: .78rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .8px;
        margin-bottom: 1rem;
    }
    .limited-title {
        font-size: 2.2rem;
        line-height: 1.05;
        font-weight: 950;
        color: #17120a;
        margin: 0 0 .8rem;
        letter-spacing: -.4px;
    }
    .limited-subtitle {
        font-size: 1rem;
        line-height: 1.7;
        color: #53483a;
        margin: 0 0 1.4rem;
        max-width: 560px;
    }
    .limited-note {
        padding: 1rem 1.1rem;
        border-radius: 16px;
        background: #fffdf8;
        border: 1px solid rgba(166,128,35,.2);
        color: #5b4f3e;
        font-size: .92rem;
        line-height: 1.65;
    }
    .limited-note strong { color: #8a6920; }
    .limited-panel {
        background: #fff;
        border: 1.5px solid rgba(166,128,35,.18);
        border-radius: 20px;
        padding: 1.35rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.9);
    }
    .limited-panel h3 {
        margin: 0 0 1rem;
        font-size: 1rem;
        font-weight: 900;
        color: #1f1a12;
    }
    .limited-links {
        display: grid;
        gap: .85rem;
    }
    .limited-link {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        text-decoration: none;
        padding: .95rem 1rem;
        border-radius: 16px;
        background: linear-gradient(180deg,#fff,#fcfbf8);
        border: 1px solid rgba(166,128,35,.16);
        color: #1b160e;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }
    .limited-link:hover {
        transform: translateY(-2px);
        border-color: rgba(166,128,35,.35);
        box-shadow: 0 12px 26px rgba(64,47,11,.08);
        color: #1b160e;
    }
    .limited-link-title {
        display: block;
        font-weight: 850;
        font-size: .95rem;
        margin-bottom: .2rem;
    }
    .limited-link-copy {
        display: block;
        color: #6a5d4d;
        font-size: .84rem;
        line-height: 1.45;
    }
    .limited-arrow {
        color: #a68023;
        font-size: 1.2rem;
        font-weight: 800;
        flex-shrink: 0;
    }
    .limited-return {
        margin-top: 1rem;
        color: #766856;
        font-size: .82rem;
        line-height: 1.55;
        word-break: break-word;
    }
    @@media (max-width: 820px) {
        .limited-content { grid-template-columns: 1fr; padding: 2rem 1.4rem; }
        .limited-title { font-size: 1.8rem; }
    }
</style>

<div class="limited-shell">
    <div class="limited-hero">
        <div class="limited-topbar"></div>
        <div class="limited-content">
            <div>
                <div class="limited-badge">Assistant Workspace</div>
                <h1 class="limited-title">You’re in the right account — just not the right section.</h1>
                <p class="limited-subtitle">@subtitle Your assistant view is intentionally focused so you can work quickly inside the agent’s lead flow without exposing the rest of the portal.</p>

                <div class="limited-note">
                    @if (reason == "unassigned")
                    {
                        <strong>Action needed:</strong><text> Ask your agent to resend your assistant invite and confirm you are signing in with the same email address that was invited.</text>
                    }
                    else
                    {
                        <strong>Your assistant access includes:</strong><text> Leads, Workstation, and the tools directly tied to lead follow-up. Settings, finance, bookkeeping, calendars, and admin areas stay reserved for the primary agent.</text>
                    }
                </div>
            </div>

            <div class="limited-panel">
                <h3>Go where you can work</h3>
                <div class="limited-links">
                    <a class="limited-link" asp-controller="Leads" asp-action="Index">
                        <span>
                            <span class="limited-link-title">Leads</span>
                            <span class="limited-link-copy">Review leads, update status, and manage follow-up activity.</span>
                        </span>
                        <span class="limited-arrow">→</span>
                    </a>

                    <a class="limited-link" asp-controller="Workstation" asp-action="Index">
                        <span>
                            <span class="limited-link-title">Workstation</span>
                            <span class="limited-link-copy">Open scripts, rebuttals, and workstation tools for active lead work.</span>
                        </span>
                        <span class="limited-arrow">→</span>
                    </a>
                </div>

                @if (!string.IsNullOrWhiteSpace(returnUrl))
                {
                    <div class="limited-return">
                        Attempted destination: @returnUrl
                    </div>
                }
            </div>
        </div>
    </div>
</div>