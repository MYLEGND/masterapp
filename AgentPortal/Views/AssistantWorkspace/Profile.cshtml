@model AgentPortal.Models.AssistantWorkspaceViewModel
@{
    ViewData["Title"] = "Assistant Workspace";
}

<link rel="stylesheet" href="~/css/legend-forms.css" asp-append-version="true" />
<style>
    :root{
        --gold:#a68023;
        --gold-strong:#c79931;
        --navy:#0b1529;
        --navy-2:#0f1d38;
    }
    body { background:#ffffff; color:#0f172a; font-family:'Inter', sans-serif; }

    .assistant-profile .legend-hero{
        border:1.6px solid var(--gold);
        border-radius:16px;
        background: var(--navy);
        box-shadow:0 20px 42px rgba(0,0,0,.14), inset 0 0 0 1px rgba(255,255,255,.08);
    }
    .assistant-profile .legend-hero-bar{
        background: linear-gradient(90deg, #a68023, #c79931 24%, #ddb457 52%, #c79931 80%, #a68023);
        height:4px;
        border-top-left-radius:14px;
        border-top-right-radius:14px;
    }
    .assistant-profile .legend-hero-body { gap: 1.25rem; }
    .assistant-profile .legend-title { margin-bottom: 0; color: var(--gold-strong); }
    .assistant-profile .legend-sub { color:#cbd5e1; }
    .assistant-profile .pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 0.9rem;
        letter-spacing: 0.01em;
        border:1px solid rgba(166,128,35,.45);
        background: rgba(166,128,35,.14);
        color:#0b1529;
    }
    .assistant-profile .pill.success { background: rgba(14,172,84,.16); color:#0e7d3a; border-color: rgba(14,172,84,.35); }
    .assistant-profile .pill.muted { background: rgba(203,213,225,.35); color:#0f172a; border-color: rgba(148,163,184,.6); }
    .assistant-profile .pill.warn { background: rgba(255,196,122,.22); color:#7a4300; border-color: rgba(255,196,122,.45); }
    .assistant-profile .section-card {
        padding: 1.25rem 1.5rem;
        border: 1.6px solid var(--gold);
        border-radius: 16px;
        box-shadow: 0 20px 42px rgba(0,0,0,.12), inset 0 0 0 1px rgba(255,255,255,.08);
        background: var(--navy);
        color: #f8fafc;
    }
    .assistant-profile .section-card .card-header { padding: 0 0 0.5rem; border: 0; background: transparent; }
    .assistant-profile .section-card h5 { color: var(--gold-strong); font-size: 1.1rem; font-weight: 900; letter-spacing: 0.01em; }
    .assistant-profile .section-card .legend-kicker { color: var(--gold-strong); font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; }
    .assistant-profile dl { row-gap: 0.75rem; }
    .assistant-profile dt { color: #cbd5e1; font-weight: 800; font-size: 0.95rem; }
    .assistant-profile dd { margin-bottom: 0; color: #f8fafc; font-size: 1rem; word-break: break-word; font-weight: 900; }
    .assistant-profile .section-actions { gap: 0.65rem; }
    .assistant-profile .quick-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.75rem; }
    .assistant-profile .quick-links .btn { width: 100%; justify-content: center; padding: 0.95rem 1rem; font-weight: 750; border-radius:12px; }
    .assistant-profile .legend-note { margin-top: 0.75rem; color:#cbd5e1; }
    .assistant-profile .quality-card{
        background: var(--navy-2);
        border:1.6px solid rgba(166,128,35,.52);
        border-radius:14px;
        padding:14px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
    }
    .assistant-profile .quality-list{
        list-style:none;
        padding-left:0;
        margin:0;
        display:grid;
        gap:8px;
    }
    .assistant-profile .quality-list li{
        display:flex;
        gap:8px;
        align-items:flex-start;
        color:#f8fafc;
        font-weight:800;
    }
    .assistant-profile .support-card{
        background: var(--navy-2);
        border:1.6px solid rgba(166,128,35,.52);
        border-radius:14px;
        padding:14px;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.06);
    }
    .assistant-profile .support-list{
        list-style:none;
        padding-left:0;
        margin:0;
        display:grid;
        gap:6px;
        color:#f8fafc;
        font-weight:800;
    }
    .assistant-profile .legend-btn-primary{
        background: var(--gold);
        border:1px solid var(--gold-strong);
        color:#0b1529;
        border-radius:10px;
        font-weight:900;
        padding:10px 14px;
        box-shadow:0 14px 28px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.12);
    }
    .assistant-profile .legend-btn-primary:hover{ background:#ddb457; border-color:#ddb457; color:#0b1529; }
</style>

<div class="legend-shell legend-form assistant-profile">
    <div class="legend-hero mb-4">
        <div class="legend-hero-bar"></div>
        <div class="legend-hero-body">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div class="d-flex flex-column gap-2">
                    <span class="legend-kicker">Assistant Workspace</span>
                    <div class="d-flex flex-wrap align-items-center gap-2">
                        <h2 class="legend-title mb-0">@Model.FullName</h2>
                        <span class="pill @(Model.IsActive ? "success" : "muted")">@Model.StatusLabel</span>
                        @if (Model.HasLoggedIn)
                        {
                            <span class="pill" style="background:#e0f2ff;color:#065986;">Accepted Invite</span>
                        }
                        else
                        {
                            <span class="pill warn">Invite Pending</span>
                        }
                    </div>
                    <p class="legend-sub mb-0">This is your workspace.<br />You see what the agent sees — Leads and Workstation only.<br />Work the leads. Use the tools. Get results.</p>
                </div>
                <div class="d-flex flex-wrap align-items-center section-actions">
                    <a asp-controller="AssistantPanel" asp-action="Index" class="btn btn-outline-secondary">← Back to Assistants</a>
                    <a asp-controller="AssistantPanel" asp-action="Details" asp-route-id="@Model.Id" class="legend-btn-primary">Manage</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="section-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <p class="legend-kicker mb-1">Profile</p>
                        <h5 class="m-0">Identity & Access</h5>
                    </div>
                </div>
                <dl class="row mb-0">
                    <dt class="col-5 col-sm-4">Name</dt>
                    <dd class="col-7 col-sm-8 fw-bold" style="color:var(--legend-navy);">@Model.FullName</dd>

                    <dt class="col-5 col-sm-4">Email</dt>
                    <dd class="col-7 col-sm-8">@Model.Email</dd>

                    <dt class="col-5 col-sm-4">Status</dt>
                    <dd class="col-7 col-sm-8">
                        <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">@Model.StatusLabel</span>
                        @if (Model.HasLoggedIn)
                        {
                            <span class="badge bg-info text-dark ms-2">Accepted Invite</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark ms-2">Invite Pending</span>
                        }
                    </dd>

                    <dt class="col-5 col-sm-4">Assistant User Id</dt>
                    <dd class="col-7 col-sm-8">@((string.IsNullOrWhiteSpace(Model.AssistantUserId) ? "—" : Model.AssistantUserId))</dd>

                    <dt class="col-5 col-sm-4">Parent Agent OID</dt>
                    <dd class="col-7 col-sm-8">@Model.ParentAgentUserId</dd>
                </dl>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="section-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <p class="legend-kicker mb-1">History</p>
                        <h5 class="m-0">Invite & Account</h5>
                    </div>
                </div>
                <dl class="row mb-0">
                    <dt class="col-5 col-sm-4">Invited</dt>
                    <dd class="col-7 col-sm-8">@Model.InvitedAtUtc.ToString("MMM d, yyyy h:mm tt") UTC</dd>

                    <dt class="col-5 col-sm-4">Created</dt>
                    <dd class="col-7 col-sm-8">@Model.CreatedUtc.ToString("MMM d, yyyy h:mm tt") UTC</dd>
                </dl>
                <p class="text-muted mt-3 mb-0">Assistants are restricted to Leads and Workstation. Agents see everything the assistant can access.</p>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="section-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <p class="legend-kicker mb-1">Permissions</p>
                        <h5 class="m-0">What You Can Use</h5>
                    </div>
                </div>
                <div class="quality-card mb-3">
                    <ul class="quality-list">
                        <li>• Work where it matters: Leads and Workstation stay front-and-center.</li>
                        <li>• Guardrails for speed: finance/admin/settings stay agent-only so you don’t hit blockers.</li>
                        <li>• Clear routing: anything outside your scope redirects instead of stopping your flow.</li>
                    </ul>
                </div>
                <div class="support-card">
                    <p class="legend-kicker mb-1">Staying in sync</p>
                    <ul class="support-list">
                        <li>• Leads: update status, notes, and next steps after each touch.</li>
                        <li>• Workstation: scripts, rebuttals, call flows—all in one place.</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="section-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <p class="legend-kicker mb-1">Shortcuts</p>
                        <h5 class="m-0">Jump To Work</h5>
                    </div>
                </div>
                <div class="quick-links">
                    <a href="/Leads" class="btn btn-outline-primary">Open Leads</a>
                    <a href="/Workstation" class="btn btn-outline-primary">Open Workstation</a>
                    <a asp-controller="AssistantPanel" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Management Panel</a>
                </div>
                <p class="legend-note mb-0"></p>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-12">
            <div class="section-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <p class="legend-kicker mb-1">Operating Rhythm</p>
                        <h5 class="m-0">Daily flow that works</h5>
                    </div>
                </div>
                <div class="quality-card">
                    <ul class="quality-list">
                        <li>• Start in Leads: confirm statuses, priorities, and next actions.</li>
                        <li>• Move to Workstation: run scripts, handle objections, log outcomes.</li>
                        <li>• Wrap: update notes, set next-touch dates, hand off a crisp summary to your agent.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
