@model AgentPortal.Models.ManageAgentProfileViewModel
@{
    ViewData["Title"] = "Manage Profile";

    var avatarInitial = string.IsNullOrWhiteSpace(Model.FullName)
        ? "A"
        : Model.FullName.Trim().Substring(0, 1).ToUpperInvariant();

    var publicProfileReady =
        !string.IsNullOrWhiteSpace(Model.FullName) &&
        !string.IsNullOrWhiteSpace(Model.Phone);

    var marketingLabel = string.IsNullOrWhiteSpace(Model.MetaPixelId)
        ? "Legend default"
        : "Custom pixel";

    var bookingLabel = Model.BookingEnabled
        ? (string.IsNullOrWhiteSpace(Model.MicrosoftBookingsEmbedUrl) ? "Needs embed" : "Personal live")
        : "Shared scheduler";

    var calendarLabel = string.IsNullOrWhiteSpace(Model.CalendarEmail)
        ? "Not linked"
        : "Linked";

    var publicStatusClass = publicProfileReady ? "is-good" : "is-warn";
    var marketingStatusClass = string.IsNullOrWhiteSpace(Model.MetaPixelId) ? "is-neutral" : "is-good";
    var bookingStatusClass = !Model.BookingEnabled
        ? "is-neutral"
        : string.IsNullOrWhiteSpace(Model.MicrosoftBookingsEmbedUrl) ? "is-warn" : "is-good";
    var calendarStatusClass = string.IsNullOrWhiteSpace(Model.CalendarEmail) ? "is-neutral" : "is-good";
}

<style>
    .profile-shell {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0.7rem 0.9rem 1.5rem;
    }

    .profile-page {
        overflow: hidden;
        border: 1px solid rgba(151, 188, 255, 0.22);
        border-radius: 18px;
        background:
            radial-gradient(circle at top right, rgba(92, 153, 255, 0.14), transparent 24%),
            linear-gradient(180deg, #102552 0%, #17356a 52%, #143161 100%);
        color: #f8fbff;
        box-shadow:
            0 18px 34px rgba(10, 23, 48, 0.16),
            inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    .profile-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 300px;
        gap: 12px;
        padding: 14px 16px 12px;
        border-bottom: 1px solid rgba(184, 211, 255, 0.14);
    }

    .profile-panel {
        border: 1px solid rgba(184, 211, 255, 0.16);
        border-radius: 15px;
        background: linear-gradient(180deg, rgba(8, 18, 38, 0.22), rgba(255, 255, 255, 0.05));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .profile-hero-copy {
        display: grid;
        gap: 8px;
        align-content: start;
    }

    .profile-eyebrow {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        min-height: 26px;
        padding: 0 10px;
        border: 1px solid rgba(184, 211, 255, 0.18);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.07);
        color: #dce9ff;
        font-size: 0.66rem;
        font-weight: 900;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .profile-title {
        margin: 0;
        color: #ffffff;
        font-size: clamp(1.32rem, 1.8vw, 1.68rem);
        line-height: 1.08;
        font-weight: 1000;
        letter-spacing: -0.03em;
    }

    .profile-sub {
        margin: 0;
        max-width: 56ch;
        color: #d9e7ff;
        font-size: 0.84rem;
        line-height: 1.35;
        font-weight: 620;
    }

    .profile-status-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 1px;
    }

    .profile-status-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        min-height: 30px;
        padding: 0 10px;
        border-radius: 999px;
        border: 1px solid rgba(184, 211, 255, 0.16);
        background: rgba(255, 255, 255, 0.08);
        color: #eef4ff;
        font-size: 0.74rem;
        font-weight: 820;
        line-height: 1;
    }

    .profile-status-chip-label {
        color: #aecaef;
        font-size: 0.61rem;
        font-weight: 950;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .profile-status-chip.is-good {
        border-color: rgba(110, 231, 183, 0.22);
        background: rgba(22, 163, 74, 0.14);
    }

    .profile-status-chip.is-warn {
        border-color: rgba(253, 224, 71, 0.22);
        background: rgba(202, 138, 4, 0.15);
    }

    .profile-avatar-panel {
        display: grid;
        gap: 10px;
        padding: 12px;
        align-content: start;
    }

    .profile-avatar-top {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .profile-avatar-preview {
        position: relative;
        width: 64px;
        height: 64px;
        aspect-ratio: 1 / 1;
        border-radius: 50%;
        overflow: hidden;
        border: 2px solid rgba(183, 212, 255, 0.24);
        background: linear-gradient(180deg, #2d58a8, #1a3769);
        box-shadow:
            0 8px 16px rgba(7, 16, 34, 0.16),
            inset 0 1px 0 rgba(255, 255, 255, 0.18);
        flex: 0 0 64px;
    }

    .profile-avatar-preview img,
    .profile-avatar-preview span {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .profile-avatar-preview img {
        display: block;
        object-fit: cover;
        object-position: center center;
        transform: scale(1.01);
    }

    .profile-avatar-preview span {
        display: grid;
        place-items: center;
        color: #ffffff;
        font-size: 1.35rem;
        font-weight: 1000;
    }

    .profile-avatar-copy {
        display: grid;
        gap: 3px;
    }

    .profile-avatar-name {
        color: #ffffff;
        font-size: 0.9rem;
        font-weight: 950;
        line-height: 1.2;
    }

    .profile-avatar-meta {
        color: #d4e3ff;
        font-size: 0.75rem;
        line-height: 1.28;
    }

    .profile-upload-form {
        display: grid;
        gap: 6px;
    }

    .profile-label {
        color: #eaf2ff;
        font-size: 0.71rem;
        font-weight: 900;
        letter-spacing: 0.02em;
    }

    .profile-help {
        margin: 0;
        color: #c8daf8;
        font-size: 0.72rem;
        line-height: 1.3;
    }

    .profile-file-input {
        width: 100%;
        min-height: 40px;
        padding: 0.4rem 0.6rem;
        border: 1px solid rgba(184, 211, 255, 0.20);
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.09);
        color: #eef4ff;
    }

    .profile-file-input::file-selector-button {
        margin-right: 8px;
        padding: 0.36rem 0.62rem;
        border: 0;
        border-radius: 8px;
        background: #3d72ea;
        color: #ffffff;
        font-weight: 900;
        cursor: pointer;
    }

    .profile-flash {
        margin: 10px 16px 0;
        padding: 8px 11px;
        border: 1px solid rgba(134, 239, 172, 0.22);
        border-radius: 11px;
        background: rgba(22, 163, 74, 0.18);
        color: #e9fff0;
        font-size: 0.8rem;
        font-weight: 800;
    }

    .profile-flash-error {
        border-color: rgba(252, 165, 165, 0.24);
        background: rgba(185, 28, 28, 0.16);
        color: #ffe2e7;
    }

    .profile-form {
        display: grid;
        gap: 10px;
        padding: 10px 16px 14px;
    }

    .profile-section {
        padding: 12px;
    }

    .profile-section-head {
        display: grid;
        gap: 2px;
        margin-bottom: 8px;
    }

    .profile-section-title {
        margin: 0;
        color: #ffffff;
        font-size: 0.92rem;
        font-weight: 950;
        letter-spacing: -0.01em;
    }

    .profile-section-sub {
        margin: 0;
        color: #cfdef8;
        font-size: 0.75rem;
        line-height: 1.28;
    }

    .profile-fields {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px 10px;
    }

    .profile-field {
        min-width: 0;
        display: grid;
        gap: 5px;
    }

    .profile-field-full {
        grid-column: 1 / -1;
    }

    .profile-input {
        width: 100%;
        min-height: 40px;
        padding: 0 11px;
        border: 1px solid rgba(181, 207, 247, 0.22);
        border-radius: 10px;
        background: linear-gradient(180deg, #f8fbff, #eaf2ff);
        color: #0f172a;
        font-weight: 700;
        box-shadow: 0 6px 12px rgba(7, 16, 34, 0.07);
        font-size: 0.94rem;
    }

    textarea.profile-input {
        min-height: 72px;
        padding: 9px 11px;
        resize: vertical;
    }

    .profile-input:focus {
        outline: none;
        border-color: rgba(59, 130, 246, 0.72);
        box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.18);
    }

    .profile-input[readonly] {
        background: linear-gradient(180deg, #dfe8f8, #d4dff0);
        color: #334155;
    }

    .profile-input::placeholder {
        color: rgba(51, 65, 85, 0.66);
    }

    .profile-toggle {
        display: flex;
        align-items: center;
        gap: 9px;
        min-height: 40px;
        padding: 0.56rem 0.72rem;
        border: 1px solid rgba(184, 211, 255, 0.16);
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.06);
        color: #eef4ff;
        font-size: 0.79rem;
        font-weight: 720;
        line-height: 1.25;
    }

    .profile-toggle input[type="checkbox"] {
        width: 18px;
        height: 18px;
        margin: 0;
        accent-color: #3b82f6;
    }

    .profile-inline-note {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        width: fit-content;
        min-height: 26px;
        padding: 0 9px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        color: #e8f1ff;
        font-size: 0.72rem;
        font-weight: 820;
    }

    .profile-validation {
        color: #ffd7de;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .profile-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        justify-content: flex-end;
        padding-top: 2px;
    }

    .profile-actions-start {
        justify-content: flex-start;
        padding-top: 0;
    }

    .profile-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        padding: 0 12px;
        border: 1px solid transparent;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 900;
        letter-spacing: 0.01em;
        font-size: 0.86rem;
        transition: transform .18s ease, box-shadow .18s ease, background .18s ease, color .18s ease;
    }

    .profile-btn:hover {
        text-decoration: none;
        transform: translateY(-1px);
    }

    .profile-btn-primary {
        background: linear-gradient(180deg, #4f8fff, #2f66dd);
        color: #ffffff;
        box-shadow: 0 10px 18px rgba(18, 74, 181, 0.20);
    }

    .profile-btn-primary:hover {
        color: #ffffff;
        box-shadow: 0 12px 20px rgba(18, 74, 181, 0.24);
    }

    .profile-btn-secondary {
        border-color: rgba(184, 211, 255, 0.20);
        background: rgba(255, 255, 255, 0.08);
        color: #edf4ff;
    }

    .profile-btn-secondary:hover {
        color: #ffffff;
        background: rgba(255, 255, 255, 0.13);
    }

    @@media (max-width: 980px) {
        .profile-hero {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 720px) {
        .profile-shell {
            padding: 0.55rem 0.6rem 1.2rem;
        }

        .profile-hero,
        .profile-form {
            padding-left: 12px;
            padding-right: 12px;
        }

        .profile-flash {
            margin-left: 12px;
            margin-right: 12px;
        }

        .profile-fields {
            grid-template-columns: 1fr;
        }

        .profile-avatar-top {
            align-items: flex-start;
        }

        .profile-actions {
            justify-content: stretch;
        }

        .profile-btn {
            width: 100%;
        }
    }
</style>

<div class="profile-shell">
    <div class="profile-page">
        <section class="profile-hero">
            <div class="profile-hero-copy">
                <span class="profile-eyebrow">Agent Portal</span>
                <div>
                    <h1 class="profile-title">Agent Profile</h1>
                    <p class="profile-sub">Manage the details behind your public handoff, tracking, and scheduling.</p>
                </div>

                <div class="profile-status-strip" aria-label="Profile status">
                    <div class="profile-status-chip @publicStatusClass">
                        <span class="profile-status-chip-label">Public</span>
                        <strong>@(publicProfileReady ? "Ready" : "Needs attention")</strong>
                    </div>
                    <div class="profile-status-chip @marketingStatusClass">
                        <span class="profile-status-chip-label">Meta</span>
                        <strong>@marketingLabel</strong>
                    </div>
                    <div class="profile-status-chip @bookingStatusClass">
                        <span class="profile-status-chip-label">Booking</span>
                        <strong>@bookingLabel</strong>
                    </div>
                    <div class="profile-status-chip @calendarStatusClass">
                        <span class="profile-status-chip-label">Calendar</span>
                        <strong>@calendarLabel</strong>
                    </div>
                </div>
            </div>

            <aside class="profile-panel profile-avatar-panel">
                <div class="profile-avatar-top">
                    <div class="profile-avatar-preview">
                        <span>@avatarInitial</span>
                        <img src="@Url.Action("Current","Avatar")"
                             alt="Current avatar"
                             onload="this.previousElementSibling.style.display='none';"
                             onerror="this.style.display='none';" />
                    </div>
                    <div class="profile-avatar-copy">
                        <div class="profile-avatar-name">@Model.FullName</div>
                        <div class="profile-avatar-meta">Shown on profile and quote handoff surfaces.</div>
                    </div>
                </div>

                <form asp-controller="Avatar" asp-action="Upload" method="post" enctype="multipart/form-data" class="profile-upload-form">
                    @Html.AntiForgeryToken()
                    <label for="photo" class="profile-label">Photo</label>
                    <input type="file" id="photo" name="photo" class="profile-file-input" accept=".png,.jpg,.jpeg,.webp" required />
                    <p class="profile-help">Square PNG, JPG, or WEBP under 3 MB.</p>
                    <div class="profile-actions profile-actions-start">
                        <button type="submit" class="profile-btn profile-btn-primary">Upload photo</button>
                    </div>
                </form>
            </aside>
        </section>

        @if (TempData["ProfileSaved"] is string ok)
        {
            <div class="profile-flash">@ok</div>
        }
        @if (TempData["AvatarSuccess"] is string avatarOk)
        {
            <div class="profile-flash">@avatarOk</div>
        }
        @if (TempData["AvatarError"] is string avatarErr)
        {
            <div class="profile-flash profile-flash-error">@avatarErr</div>
        }

        <form asp-action="ManageProfile" method="post" novalidate class="profile-form">
            @Html.AntiForgeryToken()

            <section class="profile-panel profile-section">
                <div class="profile-section-head">
                    <h2 class="profile-section-title">Identity</h2>
                    <p class="profile-section-sub">The essentials tied to your contact card and account identity.</p>
                </div>
                <div class="profile-fields">
                    <div class="profile-field">
                        <label asp-for="FullName" class="profile-label"></label>
                        <input asp-for="FullName" class="profile-input" autocomplete="name" />
                        <span asp-validation-for="FullName" class="profile-validation"></span>
                    </div>
                    <div class="profile-field">
                        <label asp-for="Title" class="profile-label"></label>
                        <input asp-for="Title" class="profile-input" autocomplete="organization-title" placeholder="Senior Agent" />
                        <span asp-validation-for="Title" class="profile-validation"></span>
                    </div>
                    <div class="profile-field">
                        <label asp-for="Email" class="profile-label"></label>
                        <input asp-for="Email" class="profile-input" readonly />
                        <p class="profile-help">Managed from your Microsoft login.</p>
                    </div>
                    <div class="profile-field">
                        <label asp-for="Phone" class="profile-label"></label>
                        <input asp-for="Phone" class="profile-input" autocomplete="tel" inputmode="tel" placeholder="555-555-1234" />
                        <span asp-validation-for="Phone" class="profile-validation"></span>
                    </div>
                </div>
            </section>

            <section class="profile-panel profile-section">
                <div class="profile-section-head">
                    <h2 class="profile-section-title">Public Card</h2>
                    <p class="profile-section-sub">What prospects see before they move into the next step.</p>
                </div>
                <div class="profile-fields">
                    <div class="profile-field profile-field-full">
                        <label asp-for="ShortBio" class="profile-label"></label>
                        <textarea asp-for="ShortBio"
                                  class="profile-input"
                                  rows="4"
                                  maxlength="280"
                                  placeholder="Short intro about how you help people review coverage options."></textarea>
                        <span asp-validation-for="ShortBio" class="profile-validation"></span>
                    </div>
                    <div class="profile-field">
                        <label asp-for="Npn" class="profile-label"></label>
                        <input asp-for="Npn" class="profile-input" autocomplete="off" placeholder="National Producer Number" />
                        <span asp-validation-for="Npn" class="profile-validation"></span>
                    </div>
                </div>
            </section>

            <section class="profile-panel profile-section">
                <div class="profile-section-head">
                    <h2 class="profile-section-title">Marketing</h2>
                    <p class="profile-section-sub">Leave blank to keep using the default Legend tracking setup.</p>
                </div>
                <div class="profile-fields">
                    <div class="profile-field profile-field-full">
                        <div class="profile-inline-note">Meta CAPI: @(Model.HasSecureMetaCapiAccessToken ? "Configured securely" : "Using shared/default setup")</div>
                    </div>
                    <div class="profile-field profile-field-full">
                        <label asp-for="MetaPixelId" class="profile-label"></label>
                        <input asp-for="MetaPixelId" class="profile-input" autocomplete="off" inputmode="numeric" placeholder="Numeric Meta Pixel ID" />
                        <span asp-validation-for="MetaPixelId" class="profile-validation"></span>
                    </div>
                </div>
            </section>

            <section class="profile-panel profile-section">
                <div class="profile-section-head">
                    <h2 class="profile-section-title">Booking</h2>
                    <p class="profile-section-sub">Use your own Bookings setup only if you want a personal scheduler in public quote flows.</p>
                </div>
                <div class="profile-fields">
                    <div class="profile-field profile-field-full">
                        <label class="profile-label" asp-for="BookingEnabled"></label>
                        <label class="profile-toggle">
                            <input asp-for="BookingEnabled" type="checkbox" />
                            <span>Use my personal scheduler on public quote handoff flows</span>
                        </label>
                    </div>
                    <div class="profile-field">
                        <label asp-for="MicrosoftBookingsEmbedUrl" class="profile-label">Embed URL</label>
                        <input asp-for="MicrosoftBookingsEmbedUrl" class="profile-input" autocomplete="off" placeholder="https://outlook.office.com/bookings/..." />
                        <span asp-validation-for="MicrosoftBookingsEmbedUrl" class="profile-validation"></span>
                    </div>
                    <div class="profile-field">
                        <label asp-for="FallbackBookingUrl" class="profile-label">Fallback URL</label>
                        <input asp-for="FallbackBookingUrl" class="profile-input" autocomplete="off" placeholder="Optional backup scheduler link" />
                        <span asp-validation-for="FallbackBookingUrl" class="profile-validation"></span>
                    </div>
                    <div class="profile-field">
                        <label asp-for="BookingPageIdOrMailbox" class="profile-label">Mailbox / Page ID</label>
                        <input asp-for="BookingPageIdOrMailbox" class="profile-input" autocomplete="off" placeholder="Mailbox, page ID, or calendar handle" />
                        <span asp-validation-for="BookingPageIdOrMailbox" class="profile-validation"></span>
                    </div>
                    <div class="profile-field">
                        <label asp-for="CalendarEmail" class="profile-label"></label>
                        <input asp-for="CalendarEmail" class="profile-input" autocomplete="email" placeholder="calendar@example.com" />
                        <span asp-validation-for="CalendarEmail" class="profile-validation"></span>
                    </div>
                </div>
            </section>

            <div class="profile-actions">
                <a class="profile-btn profile-btn-secondary" asp-controller="Home" asp-action="Index">Cancel</a>
                <button type="submit" class="profile-btn profile-btn-primary">Save profile</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
