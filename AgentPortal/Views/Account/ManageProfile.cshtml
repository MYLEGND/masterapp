@model AgentPortal.Models.ManageAgentProfileViewModel
@{
    ViewData["Title"] = "Manage Profile";
}

<style>
    .profile-shell {
        max-width: 960px;
        margin: 0 auto;
        padding: 1.5rem;
    }
    .profile-card {
        background: #0b1529;
        color: #f8fafc;
        border: 1.6px solid #a68023;
        border-radius: 16px;
        box-shadow: 0 20px 42px rgba(0,0,0,.28), inset 0 0 0 1px rgba(255,255,255,.08);
        overflow: hidden;
    }
    .profile-card .card-header {
        background: #0f1d38;
        border-bottom: 1px solid rgba(166,128,35,.42);
        padding: 1.15rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }
    .profile-card .card-header h2 {
        margin: 0;
        font-weight: 900;
        letter-spacing: .5px;
        color: #f8fafc;
    }
    .profile-card .badge {
        background: rgba(166,128,35,.16);
        color: #f8fafc;
        border: 1px solid rgba(166,128,35,.52);
        border-radius: 999px;
        padding: 0.35rem 0.9rem;
        font-weight: 800;
        letter-spacing: .4px;
    }
    .profile-card .card-body {
        padding: 1.5rem;
        display: grid;
        gap: 1rem;
    }
    .legend-input {
        background: #0f1d38;
        border: 1.5px solid rgba(166,128,35,.62);
        color: #f8fafc;
        border-radius: 10px;
        padding: 0.85rem 1rem;
        font-weight: 700;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
    }
    .legend-input:focus {
        outline: none;
        border-color: rgba(166,128,35,.92);
        box-shadow: 0 0 0 3px rgba(166,128,35,.24);
    }
    .legend-label {
        font-weight: 800;
        color: #f8fafc;
        margin-bottom: .35rem;
        letter-spacing: .25px;
    }
    .legend-help {
        color: #cbd5e1;
        font-size: 0.9rem;
        margin-bottom: 0;
    }
    .legend-btn {
        background: #a68023;
        color: #0b1529;
        border: 1px solid #c79931;
        border-radius: 12px;
        font-weight: 900;
        padding: 0.9rem 1.4rem;
        box-shadow: 0 14px 28px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.18);
    }
    .legend-btn:hover {
        color: #0b1529;
        background: #ddb457;
        border-color: #ddb457;
        text-decoration: none;
    }
    .note-pill {
        background: rgba(15,29,56,.9);
        border: 1px solid rgba(166,128,35,.52);
        color: #cbd5e1;
        border-radius: 12px;
        padding: 0.85rem 1rem;
        font-weight: 700;
    }
    .summary-card{
        border:1.2px dashed rgba(166,128,35,.45);
        border-radius:12px;
        padding:0.9rem 1rem;
        background:rgba(15,29,56,.55);
        color:#e2e8f0;
        display:grid;
        gap:0.35rem;
    }
    .summary-card strong{color:#f8fafc;}
    .avatar-block{
        display:flex;
        flex-wrap:wrap;
        gap:1.2rem;
        align-items:center;
        padding: 0.8rem 0.6rem;
        border-bottom:1px solid rgba(166,128,35,.24);
        margin-bottom: 0.5rem;
    }
    .avatar-preview{
        width:110px;
        height:110px;
        border-radius:50%;
        overflow:hidden;
        border:2px solid #c79931;
        display:grid;
        place-items:center;
        background: #0f172a;
        color:#f8fafc;
        font-weight:900;
        font-size:1.6rem;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.12), 0 10px 24px rgba(0,0,0,.22);
    }
    .avatar-actions{
        flex:1;
        min-width:240px;
        display:grid;
        gap:0.45rem;
    }
    .avatar-actions label{ color:#f8fafc; font-weight:800; }
    .avatar-actions input[type=file]{
        background:#0f1d38;
        border:1.5px solid rgba(166,128,35,.62);
        border-radius:10px;
        color:#e2e8f0;
        padding:0.65rem;
    }
    .avatar-actions .legend-btn-small{
        width: fit-content;
        padding:0.65rem 1.1rem;
        border-radius:10px;
        background:#a68023;
        color:#0b1529;
        border:1px solid #c79931;
        font-weight:900;
        box-shadow: 0 10px 20px rgba(0,0,0,.24), inset 0 1px 0 rgba(255,255,255,.16);
    }
    .avatar-actions .legend-btn-small:hover{
        background:#ddb457;
        border-color:#ddb457;
        text-decoration:none;
    }
    .two-col {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        align-items: start;
    }
    .field {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }
</style>

<div class="profile-shell">
    <div class="profile-card">
        <div class="card-header">
            <div>
                <div class="badge">Agent Profile</div>
                <h2>Manage Account</h2>
                <p class="legend-help mb-0">Name, title, phone, and NPN flow to the client app and the profile chip.</p>
            </div>
            <a class="legend-btn" asp-controller="Avatar" asp-action="Edit" style="color:#0b1529;">Edit photo</a>
        </div>

        <div class="card-body">
            @if (TempData["ProfileSaved"] is string ok)
            {
                <div class="note-pill">@ok</div>
            }
            <div class="avatar-block">
                <div class="avatar-preview">
                    <img src="@Url.Action("Current","Avatar")" alt="Current avatar" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none'; this.parentElement.textContent='A';" />
                </div>
                <div class="avatar-actions">
                    <form asp-controller="Avatar" asp-action="Upload" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <label for="photo">Profile picture</label>
                        <input type="file" id="photo" name="photo" accept=".png,.jpg,.jpeg,.webp" required />
                        <button type="submit" class="legend-btn-small mt-1">Upload photo</button>
                        <p class="legend-help mb-0">PNG/JPG/WEBP under 3 MB.</p>
                    </form>
                </div>
            </div>
            <div class="summary-card" aria-label="Contact card preview">
                <div><strong>Name:</strong> @Model.FullName</div>
                <div><strong>Title:</strong> @(string.IsNullOrWhiteSpace(Model.Title) ? "Not set" : Model.Title)</div>
                <div><strong>Email:</strong> @Model.Email (read-only)</div>
                <div><strong>Phone:</strong> @(string.IsNullOrWhiteSpace(Model.Phone) ? "Not set" : Model.Phone)</div>
                <div><strong>Short bio:</strong> @(string.IsNullOrWhiteSpace(Model.ShortBio) ? "Not set" : Model.ShortBio)</div>
                <div><strong>NPN:</strong> @(string.IsNullOrWhiteSpace(Model.Npn) ? "Not set" : Model.Npn)</div>
                <div><strong>Meta Pixel ID:</strong> @(string.IsNullOrWhiteSpace(Model.MetaPixelId) ? "Not set" : Model.MetaPixelId)</div>
                <div><strong>Agent Meta CAPI:</strong> @(Model.HasSecureMetaCapiAccessToken ? "Securely configured" : "Not configured")</div>
                <div class="legend-help mb-0">These values power your public quote handoff card and profile surfaces.</div>
            </div>

            <form asp-action="ManageProfile" method="post" novalidate>
                @Html.AntiForgeryToken()
                <div class="two-col">
                    <div class="field">
                        <label asp-for="FullName" class="legend-label"></label>
                        <input asp-for="FullName" class="legend-input" autocomplete="name" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Title" class="legend-label"></label>
                        <input asp-for="Title" class="legend-input" autocomplete="organization-title" placeholder="e.g., Senior Agent" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Email" class="legend-label"></label>
                        <input asp-for="Email" class="legend-input" readonly />
                        <p class="legend-help">Email cannot be changed here.</p>
                    </div>
                    <div class="field">
                        <label asp-for="Phone" class="legend-label"></label>
                        <input asp-for="Phone" class="legend-input" autocomplete="tel" inputmode="tel" placeholder="e.g., 555-555-1234" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="field">
                        <label asp-for="ShortBio" class="legend-label"></label>
                        <textarea asp-for="ShortBio" class="legend-input" rows="4" maxlength="280" placeholder="A short public intro for your quote links, like how you help families review protection options."></textarea>
                        <p class="legend-help">Optional. This shows on your public quote handoff card.</p>
                        <span asp-validation-for="ShortBio" class="text-danger"></span>
                    </div>
                    <div class="field">
                        <label asp-for="Npn" class="legend-label"></label>
                        <input asp-for="Npn" class="legend-input" autocomplete="off" placeholder="National Producer Number" />
                        <span asp-validation-for="Npn" class="text-danger"></span>
                    </div>
                    <div class="field" style="grid-column:1 / -1;">
                        <div class="legend-label" style="margin-bottom:0;">Marketing Settings</div>
                        <p class="legend-help">Manage the tracking defaults used on your public quote links.</p>
                    </div>
                    <div class="field" style="grid-column:1 / -1;">
                        <label asp-for="MetaPixelId" class="legend-label"></label>
                        <input asp-for="MetaPixelId" class="legend-input" autocomplete="off" inputmode="numeric" placeholder="Meta browser pixel / dataset ID" />
                        <p class="legend-help">Optional. If set, your personal/agency Meta Pixel will be used on your agent quote links. If blank, Legend’s default tracking pixel will be used.</p>
                        <p class="legend-help">Agent-specific server-side Meta CAPI tokens are configured separately and are not editable here.</p>
                        <span asp-validation-for="MetaPixelId" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="legend-btn">Save profile</button>
                    <a class="legend-btn" style="background:#0f1d38;color:#f8fafc;border-color:rgba(166,128,35,.62);" asp-controller="Home" asp-action="Index">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
