@model AgentPortal.Models.DashboardExecutionViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="home-container">

    <!-- HERO -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Legend™ Core Dashboard</h1>
        <p class="lead mb-3">
            Command Center for any Actions you flagged “Show in Dashboard” from Leads or Clients.
        </p>
        <hr class="my-3 hero-hr" />
    </div>

    <!-- SEARCH BAR -->
    <div class="text-center mb-5 search-container">
        <input type="text" id="toolSearch" class="search-input" placeholder="Search all tools..." />
        <button id="clearSearch" class="btn-clear-search">Clear Search</button>
        <div id="autocompleteList" class="autocomplete-list"></div>
    </div>

    <!-- EXECUTION SNAPSHOT (Command Center) -->
    <style>
        .legend-exec-btn{
            background:#0f172a;
            color:#f8fafc;
            border:2px solid #8b6f1f;
            border-radius:14px;
            width:100%;
            padding:18px 14px;
            text-align:left;
            box-shadow: 0 14px 28px rgba(0,0,0,.28);
            transition: transform .12s ease, box-shadow .12s ease;
        }
        .legend-exec-btn:hover{ transform: translateY(-2px); box-shadow:0 18px 32px rgba(0,0,0,.32); }
        .legend-exec-title{ color:#d5b24d; font-weight:800; letter-spacing:.02em; margin:0; }
        .legend-exec-sub{ color:#f8fafc; opacity:.78; margin:0; }
        .legend-exec-btn .chevron{ float:right; color:#d5b24d; font-weight:900; }
        .legend-badge{
            display:inline-flex;
            align-items:center;
            justify-content:center;
            min-width:26px;
            padding:2px 8px;
            margin-left:8px;
            border-radius:999px;
            background:#8b6f1f;
            color:#0b1224;
            font-weight:800;
            font-size:.9rem;
        }
        .legend-modal .modal-content{
            background:#0f172a;
            color:#f8fafc;
            border:2px solid #8b6f1f;
            border-radius:16px;
            box-shadow:0 22px 48px rgba(0,0,0,.45);
            max-height: calc(100vh - clamp(32px, 8vh, 72px));
            display:flex;
            flex-direction:column;
        }
        .legend-modal .modal-dialog{
            margin: clamp(16px, 4vh, 36px) auto;
        }
        .legend-modal .modal-header{ border-color:#8b6f1f; }
        .legend-modal .modal-title{ color:#d5b24d; font-weight:800; letter-spacing:.02em; }
        .legend-modal .modal-body{
            overflow-y:auto;
            min-height:0;
            overscroll-behavior:contain;
        }
        .legend-modal .btn-close{ opacity:.96; }
        /* Legend-styled action lists inside modals */
        .legend-modal .action-table-wrap{
            background:#0b1224;
            border:1px solid #8b6f1f;
            padding:10px;
            border-radius:14px;
        }
        .legend-modal .action-table{
            background:transparent;
        }
        .legend-modal .action-table th{
            color:#d5b24d;
            border-bottom:1px solid rgba(139,111,31,.45);
            background:linear-gradient(180deg,#0f172a,#0c1524);
        }
        .legend-modal .action-table td{
            color:#0b1224;
            border-top:1px solid rgba(15,23,42,.12);
            background:#ffffff;
        }
        .legend-modal .action-table tbody tr:nth-child(odd){
            background: #f8fafc;
        }
        .legend-modal .status-pill{
            color:#0b1224;
        }
        .legend-modal .text-muted{
            color:#d5b24d !important;
            opacity:0.7;
        }
    </style>
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <button class="legend-exec-btn" data-bs-toggle="modal" data-bs-target="#modalToday">
                <span class="legend-exec-title">Today <span class="legend-badge" id="countToday">@((Model?.Today?.Count() ?? 0))</span></span>
                <span class="chevron">⇱</span>
            </button>
        </div>
        <div class="col-md-4 mb-3">
            <button class="legend-exec-btn" data-bs-toggle="modal" data-bs-target="#modalOverdue">
                <span class="legend-exec-title">Overdue <span class="legend-badge" id="countOverdue">@((Model?.Overdue?.Count() ?? 0))</span></span>
                <span class="chevron">⇱</span>
            </button>
        </div>
        <div class="col-md-4 mb-3">
            <button class="legend-exec-btn" data-bs-toggle="modal" data-bs-target="#modalBlockers">
                <span class="legend-exec-title">Blockers <span class="legend-badge" id="countBlockers">@((Model?.Blockers?.Count() ?? 0))</span></span>
                <span class="chevron">⇱</span>
            </button>
        </div>
    </div>

    <!-- Today Modal -->
    <div class="modal fade legend-modal" id="modalToday" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Today</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body" id="modalTodayBody">
            <div class="text-muted">Loading…</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Overdue Modal -->
    <div class="modal fade legend-modal" id="modalOverdue" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Overdue</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body" id="modalOverdueBody">
            <div class="text-muted">Loading…</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Blockers Modal -->
    <div class="modal fade legend-modal" id="modalBlockers" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Blockers</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body" id="modalBlockersBody">
            <div class="text-muted">Loading…</div>
          </div>
        </div>
      </div>
    </div>

<div id="dashboardAf" style="display:none;">
    @Html.AntiForgeryToken()
</div>
<div id="dashboardToast" class="toast" aria-live="polite">Done</div>

@if (Model?.DerivedAnalytics != null)
{
    <div class="card mb-4" style="border:1px solid rgba(139,111,31,.35); background:#0f172a; color:#f8fafc;">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center flex-wrap" style="gap:8px;">
                <div>
                    <div class="text-uppercase small" style="letter-spacing:.08em;color:#d5b24d;">Insights (read-only)</div>
                    <div class="fw-bold">Conversion & Promise Fulfillment</div>
                </div>
                <div class="d-flex flex-wrap" style="gap:14px;">
                    <div class="text-center">
                        <div class="h4 mb-0">@($"{Model.DerivedAnalytics.LeadConversionRate:P1}")</div>
                        <div class="text-muted small">Lead Conversion</div>
                    </div>
                    <div class="text-center">
                        <div class="h4 mb-0">@($"{Model.DerivedAnalytics.CommitmentFulfillmentRate:P1}")</div>
                        <div class="text-muted small">Commitments On-Time (30d)</div>
                    </div>
                    <div class="text-center">
                        <div class="h5 mb-0">@Model.DerivedAnalytics.CommitmentsOpen30d</div>
                        <div class="text-muted small">Open Commitments (30d)</div>
                    </div>
                    <div class="text-center">
                        <div class="h5 mb-0">@Model.DerivedAnalytics.LeadCount</div>
                        <div class="text-muted small">Total Leads</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<script src="~/js/legend-modal.js" asp-append-version="true"></script>
<script>
    (() => {
        const loadInto = (url, targetId) => {
            const target = document.getElementById(targetId);
            if (!target) return;
            target.innerHTML = '<div class="text-muted">Loading…</div>';
            fetch(url, { credentials: 'include' })
                .then(r => r.text())
                .then(html => { target.innerHTML = html; })
                .catch(() => { target.innerHTML = '<div class="text-danger">Failed to load.</div>'; });
        };

        const refreshCounts = () => {
            fetch("/Dashboard/Counts", { credentials: 'include' })
                .then(r => r.json())
                .then(data => {
                    const set = (id,val) => { const el=document.getElementById(id); if(el) el.textContent = val ?? 0; };
                    set("countToday", data.today);
                    set("countOverdue", data.overdue);
                    set("countBlockers", data.blockers);
                })
                .catch(() => {});
        };

        const modals = [
            { id: 'modalToday', url: '/Dashboard/Today', body: 'modalTodayBody' },
            { id: 'modalOverdue', url: '/Dashboard/Overdue', body: 'modalOverdueBody' },
            { id: 'modalBlockers', url: '/Dashboard/Blockers', body: 'modalBlockersBody' }
        ];

        modals.forEach(m => {
            const el = document.getElementById(m.id);
            if (!el) return;
            const bound = window.LegendModal?.bind?.(m.id, { modalZ: 1050, backdropZ: 1045 });
            const modalEl = bound || el;
            modalEl.addEventListener('show.bs.modal', () => {
                window.LegendModal?.closeLegacyExecutionOverlays?.();
                loadInto(m.url, m.body);
            });
        });

        // Complete/Delete handling (AJAX) to keep counts accurate
        document.addEventListener("click", (event) => {
            const btn = event.target.closest(".action-complete-btn");
            if (!btn) return;
            event.preventDefault();
            const id = btn.getAttribute("data-action-id");
            if (!id) return;
            fetch("/Dashboard/CompleteAction", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": document.querySelector('#dashboardAf input[name=\"__RequestVerificationToken\"]')?.value || ""
                },
                body: JSON.stringify({ id }),
                credentials: "include"
            }).then(r => {
                if (!r.ok) throw new Error();
                // reload any open modal bodies
                modals.forEach(m => {
                    const el = document.getElementById(m.id);
                    if (el && el.classList.contains("show")) loadInto(m.url, m.body);
                });
                refreshCounts();
            }).catch(()=>{});
        });

        document.addEventListener("submit", (event) => {
            const form = event.target.closest(".action-delete-form");
            if (!form) return;
            event.preventDefault();
            const fd = new FormData(form);
            fetch(form.action, {
                method: "POST",
                body: fd,
                credentials: "include"
            }).then(r => {
                if (!r.ok) throw new Error();
                modals.forEach(m => {
                    const el = document.getElementById(m.id);
                    if (el && el.classList.contains("show")) loadInto(m.url, m.body);
                });
                refreshCounts();
            }).catch(()=>{});
        });

        refreshCounts();
    })();
</script>

