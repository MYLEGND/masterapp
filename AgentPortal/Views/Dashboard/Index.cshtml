@model AgentPortal.Models.DashboardExecutionViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var todayCount = Model?.Today?.Count() ?? 0;
    var overdueCount = Model?.Overdue?.Count() ?? 0;
    var blockerCount = Model?.Blockers?.Count() ?? 0;
    var totalExecutionItems = todayCount + overdueCount + blockerCount;
}

<link rel="stylesheet" href="~/css/dashboard-carrier-settings.css" asp-append-version="true" />

<div class="home-container dashboard-page-shell">

    <section class="dashboard-hero-panel">
        <div class="dashboard-hero-copy">
            <div class="dashboard-eyebrow">Legend Command Center</div>
            <h1 class="dashboard-hero-title">Legend™ Core Dashboard</h1>
            <p class="dashboard-hero-lead">
                Premium execution workspace for agent tasks, carrier access, and the action items you flagged from Leads or Clients.
            </p>
            <div class="dashboard-hero-tags">
                <span>Execution tracking</span>
                <span>Carrier access</span>
                <span>Faster follow-through</span>
            </div>
        </div>
        <div class="dashboard-hero-stats">
            <div class="dashboard-stat-card is-primary">
                <div class="dashboard-stat-label">Open execution</div>
                <div class="dashboard-stat-value">@totalExecutionItems</div>
                <div class="dashboard-stat-note">Today, overdue, and blocker items in one view.</div>
            </div>
            <div class="dashboard-stat-card">
                <div class="dashboard-stat-label">Due today</div>
                <div class="dashboard-stat-value" id="countToday">@todayCount</div>
                <div class="dashboard-stat-note">Current-day commitments that should move now.</div>
            </div>
            <div class="dashboard-stat-card">
                <div class="dashboard-stat-label">Overdue</div>
                <div class="dashboard-stat-value" id="countOverdue">@overdueCount</div>
                <div class="dashboard-stat-note">Items that need rescue before they age further.</div>
            </div>
            <div class="dashboard-stat-card">
                <div class="dashboard-stat-label">Blockers</div>
                <div class="dashboard-stat-value" id="countBlockers">@blockerCount</div>
                <div class="dashboard-stat-note">Dependencies and friction slowing execution down.</div>
            </div>
        </div>
    </section>

    <section class="dashboard-command-panel">
        <div class="dashboard-section-head dashboard-section-head-tight">
            <div>
                <div class="dashboard-section-kicker">Command Tools</div>
                <h2 class="dashboard-section-title">Search your carrier stack and keep settings close.</h2>
                <p class="dashboard-section-copy">Jump to any portal fast, or manage agent numbers and commission settings without leaving the command center.</p>
            </div>
        </div>

        <div class="search-container dashboard-search-panel">
            <div class="dashboard-search-shell">
                <div class="search-input-wrap">
                    <input type="text" id="toolSearch" class="search-input" placeholder="Search all tools..." />
                    <div id="autocompleteList" class="autocomplete-list"></div>
                </div>
                <div class="search-actions">
                    <button id="clearSearch" class="btn-clear-search" type="button">Clear Search</button>
                    <button
                        id="openCarrierSettings"
                        class="btn-carrier-settings"
                        type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#carrierSettingsModal">
                        Carrier Numbers &amp; Commissions
                    </button>
                </div>
            </div>
        </div>
    </section>

    <section class="dashboard-focus-panel">
        <div class="dashboard-section-head dashboard-section-head-tight">
            <div>
                <div class="dashboard-section-kicker">Execution Snapshot</div>
                <h2 class="dashboard-section-title">Open the work that actually needs attention.</h2>
                <p class="dashboard-section-copy">Each bucket opens into the live modal so you can review, complete, or clear work without hunting through the CRM first.</p>
            </div>
        </div>

        <div class="row g-3 dashboard-focus-grid">
            <div class="col-lg-4 col-md-6">
                <button class="legend-exec-btn" data-bs-toggle="modal" data-bs-target="#modalToday">
                    <span class="legend-exec-kicker">Execution</span>
                    <span class="legend-exec-title-row">
                        <span class="legend-exec-title">Today</span>
                        <span class="legend-badge">@todayCount</span>
                    </span>
                    <span class="legend-exec-sub">Current-day commitments that should get moved before momentum drops.</span>
                    <span class="chevron">Open</span>
                </button>
            </div>
            <div class="col-lg-4 col-md-6">
                <button class="legend-exec-btn" data-bs-toggle="modal" data-bs-target="#modalOverdue">
                    <span class="legend-exec-kicker">Recovery</span>
                    <span class="legend-exec-title-row">
                        <span class="legend-exec-title">Overdue</span>
                        <span class="legend-badge">@overdueCount</span>
                    </span>
                    <span class="legend-exec-sub">Aging items that need immediate rescue before they become stale.</span>
                    <span class="chevron">Open</span>
                </button>
            </div>
            <div class="col-lg-4 col-md-6">
                <button class="legend-exec-btn" data-bs-toggle="modal" data-bs-target="#modalBlockers">
                    <span class="legend-exec-kicker">Friction</span>
                    <span class="legend-exec-title-row">
                        <span class="legend-exec-title">Blockers</span>
                        <span class="legend-badge">@blockerCount</span>
                    </span>
                    <span class="legend-exec-sub">Dependencies, missing pieces, or stalled next steps slowing the board.</span>
                    <span class="chevron">Open</span>
                </button>
            </div>
        </div>
    </section>

    <!-- Today Modal -->
    <div class="modal fade legend-modal" id="modalToday" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Today</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body" id="modalTodayBody">
            <div class="text-muted">Loading…</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Overdue Modal -->
    <div class="modal fade legend-modal" id="modalOverdue" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Overdue</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body" id="modalOverdueBody">
            <div class="text-muted">Loading…</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Blockers Modal -->
    <div class="modal fade legend-modal" id="modalBlockers" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">Blockers</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body" id="modalBlockersBody">
            <div class="text-muted">Loading…</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Carrier Settings Modal -->
    <div
        class="modal fade legend-modal carrier-settings-modal"
        id="carrierSettingsModal"
        tabindex="-1"
        aria-hidden="true"
        data-load-url="@Url.Action("CarrierSettings", "Dashboard")"
        data-save-url="@Url.Action("SaveCarrierSettings", "Dashboard")"
        data-storage-scope="@((ViewData["CarrierSettingsStorageScope"] as string) ?? "dashboard")">
      <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
          <div class="modal-header">
            <div>
                <h5 class="modal-title mb-1">Agent / Entity Numbers &amp; Commission Settings</h5>
                <div class="carrier-settings-statusbar">
                    <span class="carrier-settings-count" id="carrierSettingsCount">Pulling live rows…</span>
                    <span class="carrier-settings-status" id="carrierSettingsStatus">Ready</span>
                </div>
            </div>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body" id="carrierSettingsBody">
            <div class="carrier-settings-loading">
                Pulling your current dashboard sections and saved carrier data…
            </div>
          </div>
          <div class="modal-footer">
            <div class="carrier-settings-footer-note me-auto">
                Changes save automatically to the server for the current agent profile.
            </div>
            <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
          </div>
        </div>
      </div>
    </div>

<div id="dashboardAf" style="display:none;">
    @Html.AntiForgeryToken()
</div>
<div id="dashboardToast" class="toast" aria-live="polite">Done</div>

@if (Model?.DerivedAnalytics != null)
{
    <section class="dashboard-analytics-panel">
        <div class="dashboard-section-head dashboard-section-head-tight">
            <div>
                <div class="dashboard-section-kicker">Read-Only Insights</div>
                <h2 class="dashboard-section-title">Conversion and promise fulfillment at a glance.</h2>
                <p class="dashboard-section-copy">High-signal metrics for how well lead flow is converting and whether commitments are being kept on time.</p>
            </div>
        </div>
        <div class="dashboard-analytics-grid">
            <div class="dashboard-analytics-card">
                <div class="dashboard-analytics-label">Lead Conversion</div>
                <div class="dashboard-analytics-value">@($"{Model.DerivedAnalytics.LeadConversionRate:P1}")</div>
                <div class="dashboard-analytics-copy">Closed-loop lead conversion performance across the current data set.</div>
            </div>
            <div class="dashboard-analytics-card">
                <div class="dashboard-analytics-label">Commitments On-Time</div>
                <div class="dashboard-analytics-value">@($"{Model.DerivedAnalytics.CommitmentFulfillmentRate:P1}")</div>
                <div class="dashboard-analytics-copy">Follow-through rate on commitments over the last 30 days.</div>
            </div>
            <div class="dashboard-analytics-card">
                <div class="dashboard-analytics-label">Open Commitments</div>
                <div class="dashboard-analytics-value">@Model.DerivedAnalytics.CommitmentsOpen30d</div>
                <div class="dashboard-analytics-copy">Outstanding 30-day commitments still on the board.</div>
            </div>
            <div class="dashboard-analytics-card">
                <div class="dashboard-analytics-label">Total Leads</div>
                <div class="dashboard-analytics-value">@Model.DerivedAnalytics.LeadCount</div>
                <div class="dashboard-analytics-copy">Tracked leads feeding the current conversion insight model.</div>
            </div>
        </div>
    </section>
}

<script src="~/js/legend-modal.js" asp-append-version="true"></script>
<script>
    (() => {
        const loadInto = (url, targetId) => {
            const target = document.getElementById(targetId);
            if (!target) return;
            target.innerHTML = '<div class="text-muted">Loading…</div>';
            fetch(url, { credentials: 'include' })
                .then(r => r.text())
                .then(html => { target.innerHTML = html; })
                .catch(() => { target.innerHTML = '<div class="text-danger">Failed to load.</div>'; });
        };

        const refreshCounts = () => {
            fetch("/Dashboard/Counts", { credentials: 'include' })
                .then(r => r.json())
                .then(data => {
                    const set = (id,val) => { const el=document.getElementById(id); if(el) el.textContent = val ?? 0; };
                    set("countToday", data.today);
                    set("countOverdue", data.overdue);
                    set("countBlockers", data.blockers);
                })
                .catch(() => {});
        };

        const modals = [
            { id: 'modalToday', url: '/Dashboard/Today', body: 'modalTodayBody' },
            { id: 'modalOverdue', url: '/Dashboard/Overdue', body: 'modalOverdueBody' },
            { id: 'modalBlockers', url: '/Dashboard/Blockers', body: 'modalBlockersBody' }
        ];

        modals.forEach(m => {
            const el = document.getElementById(m.id);
            if (!el) return;
            const bound = window.LegendModal?.bind?.(m.id, { modalZ: 1050, backdropZ: 1045 });
            const modalEl = bound || el;
            modalEl.addEventListener('show.bs.modal', () => {
                window.LegendModal?.closeLegacyExecutionOverlays?.();
                loadInto(m.url, m.body);
            });
        });

        // Complete/Delete handling (AJAX) to keep counts accurate
        document.addEventListener("click", (event) => {
            const btn = event.target.closest(".action-complete-btn");
            if (!btn) return;
            event.preventDefault();
            const id = btn.getAttribute("data-action-id");
            if (!id) return;
            fetch("/Dashboard/CompleteAction", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": document.querySelector('#dashboardAf input[name=\"__RequestVerificationToken\"]')?.value || ""
                },
                body: JSON.stringify({ id }),
                credentials: "include"
            }).then(r => {
                if (!r.ok) throw new Error();
                // reload any open modal bodies
                modals.forEach(m => {
                    const el = document.getElementById(m.id);
                    if (el && el.classList.contains("show")) loadInto(m.url, m.body);
                });
                refreshCounts();
            }).catch(()=>{});
        });

        document.addEventListener("submit", (event) => {
            const form = event.target.closest(".action-delete-form");
            if (!form) return;
            event.preventDefault();
            const fd = new FormData(form);
            fetch(form.action, {
                method: "POST",
                body: fd,
                credentials: "include"
            }).then(r => {
                if (!r.ok) throw new Error();
                modals.forEach(m => {
                    const el = document.getElementById(m.id);
                    if (el && el.classList.contains("show")) loadInto(m.url, m.body);
                });
                refreshCounts();
            }).catch(()=>{});
        });

        refreshCounts();
    })();
</script>

