<script>
document.addEventListener('DOMContentLoaded', function () {

    const searchInput = document.getElementById('toolSearch');
    const autocompleteList = document.getElementById('autocompleteList');
    const clearBtn = document.getElementById('clearSearch');

    const tools = Array.from(document.querySelectorAll('.dashboard-tool')).map(tool => ({
        name: tool.dataset.name || tool.querySelector('.tool-name').textContent.trim(),
        description: tool.querySelector('.tool-desc')?.textContent.toLowerCase() || '',
        href: tool.href,
        imgSrc: tool.querySelector('img').src
    }));

    clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        autocompleteList.style.display = 'none';
    });

    searchInput.addEventListener('input', () => {
        const value = searchInput.value.toLowerCase().trim();
        autocompleteList.innerHTML = '';

        if (!value) {
            autocompleteList.style.display = 'none';
            return;
        }

        const matches = tools.filter(t =>
            t.name.toLowerCase().includes(value) ||
            t.description.includes(value)
        );

        if (!matches.length) {
            autocompleteList.style.display = 'none';
            return;
        }

        matches.forEach(tool => {
            const item = document.createElement('button');
            const media = document.createElement('span');
            const icon = document.createElement('img');
            const label = document.createElement('span');

            item.type = 'button';
            item.className = 'autocomplete-item';
            media.className = 'autocomplete-item-media';
            label.className = 'autocomplete-item-label';

            icon.src = tool.imgSrc;
            icon.alt = '';
            icon.loading = 'lazy';
            label.textContent = tool.name;

            media.appendChild(icon);
            item.appendChild(media);
            item.appendChild(label);
            item.onclick = () => {
                autocompleteList.style.display = 'none';
                window.open(tool.href, '_blank');
            };
            autocompleteList.appendChild(item);
        });

        autocompleteList.style.display = 'block';
    });

    document.addEventListener('click', e => {
        if (!searchInput.contains(e.target) && !autocompleteList.contains(e.target)) {
            autocompleteList.style.display = 'none';
        }
    });

        const enableMobileCollapses = () => {
            const mq = window.matchMedia('(max-width: 720px)');
            if (!mq.matches) return;

            const categories = Array.from(document.querySelectorAll('.category-container'));
            categories.forEach((cat, idx) => {
                const tools = cat.querySelector('.centered-tools');
                const heading = cat.querySelector('.category-toggle') || cat.querySelector('h3');
                if (!tools || !heading) return;

                const setState = (open) => {
                    cat.classList.toggle('is-open', open);
                    tools.style.display = open ? '' : 'none';
                    heading.dataset.mobileState = open ? '−' : '+';
                };

            heading.setAttribute('role', 'button');
            heading.setAttribute('tabindex', '0');

            const initialOpen = idx === 0;
            setState(initialOpen);

            const toggle = () => setState(!cat.classList.contains('is-open'));
            heading.addEventListener('click', toggle);
            heading.addEventListener('keydown', e => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    toggle();
                }
            });
        });
    };

    enableMobileCollapses();
});
</script>
