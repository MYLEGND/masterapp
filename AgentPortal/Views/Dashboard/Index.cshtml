}

<script src="~/js/legend-modal.js" asp-append-version="true"></script>
<script>
    (() => {
        const loadInto = (url, targetId) => {
            const target = document.getElementById(targetId);
            if (!target) return;
            target.innerHTML = '<div class="text-muted">Loading…</div>';
            fetch(url, { credentials: 'include' })
                .then(r => r.text())
                .then(html => { target.innerHTML = html; })
                .catch(() => { target.innerHTML = '<div class="text-danger">Failed to load.</div>'; });
        };

        const refreshCounts = () => {
            fetch("/Dashboard/Counts", { credentials: 'include' })
                .then(r => r.json())
                .then(data => {
                    const set = (id,val) => { const el=document.getElementById(id); if(el) el.textContent = val ?? 0; };
                    const today = data.today ?? 0;
                    const overdue = data.overdue ?? 0;
                    const blockers = data.blockers ?? 0;
                    set("countToday", data.today);
                    set("countOverdue", data.overdue);
                    set("countBlockers", data.blockers);
                    set("countTodayStat", today);
                    set("countOverdueStat", overdue);
                    set("countBlockersStat", blockers);
                    set("countOpenExecution", today + overdue + blockers);
                })
                .catch(() => {});
        };

        const modals = [
            { id: 'modalToday', url: '/Dashboard/Today', body: 'modalTodayBody' },
            { id: 'modalOverdue', url: '/Dashboard/Overdue', body: 'modalOverdueBody' },
            { id: 'modalBlockers', url: '/Dashboard/Blockers', body: 'modalBlockersBody' }
        ];

        modals.forEach(m => {
            const el = document.getElementById(m.id);
            if (!el) return;
            const bound = window.LegendModal?.bind?.(m.id, { modalZ: 1050, backdropZ: 1045 });
            const modalEl = bound || el;
            modalEl.addEventListener('show.bs.modal', () => {
                window.LegendModal?.closeLegacyExecutionOverlays?.();
                loadInto(m.url, m.body);
            });
        });

        // Complete/Delete handling (AJAX) to keep counts accurate
        document.addEventListener("click", (event) => {
            const btn = event.target.closest(".action-complete-btn");
            if (!btn) return;
            event.preventDefault();
            const id = btn.getAttribute("data-action-id");
            if (!id) return;
            fetch("/Dashboard/CompleteAction", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "RequestVerificationToken": document.querySelector('#dashboardAf input[name=\"__RequestVerificationToken\"]')?.value || ""
                },
                body: JSON.stringify({ id }),
                credentials: "include"
            }).then(r => {
                if (!r.ok) throw new Error();
                // reload any open modal bodies
                modals.forEach(m => {
                    const el = document.getElementById(m.id);
                    if (el && el.classList.contains("show")) loadInto(m.url, m.body);
                });
                refreshCounts();
            }).catch(()=>{});
        });

        document.addEventListener("submit", (event) => {
            const form = event.target.closest(".action-delete-form");
            if (!form) return;
            event.preventDefault();
            const fd = new FormData(form);
            fetch(form.action, {
                method: "POST",
                body: fd,
                credentials: "include"
            }).then(r => {
                if (!r.ok) throw new Error();
                modals.forEach(m => {
                    const el = document.getElementById(m.id);
                    if (el && el.classList.contains("show")) loadInto(m.url, m.body);
                });
                refreshCounts();
            }).catch(()=>{});
        });

        refreshCounts();
    })();
</script>

