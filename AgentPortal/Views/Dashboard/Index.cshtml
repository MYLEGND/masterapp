                new { Name = "Tower Hill Insurance", Url = "https://portal.thig.com/#/home", Icon = "towerhill.png", Desc = "Mobile Homeowners, Residential & Commercial Property, Dwelling, rental property, etc. " },
                new { Name = "Adaptive", Url = "https://app.adaptiveinsurance.com/", Icon = "adaptive.png", Desc = "Businesses, Primarily defend against climate change. " },
            };
        }

        @foreach (var tool in commercialTools)
        {
            <a href="@tool.Url" target="_blank" class="dashboard-tool" data-name="@tool.Name">
                <img src="@Url.Content($"~/images/company-icons/{tool.Icon}")" alt="@tool.Name" />
                <div class="fw-bold text-center mt-1 tool-name">@tool.Name</div>
                <div class="tool-desc">@tool.Desc</div>
            </a>
        }
    </div>
</div>


</div>

<style>
/* ==============================
   THEME VARIABLES
============================== */
:root {
    /* Colors */
    --gold-color: #a68023;
    --gold-light: rgba(166,128,35,0.26);
    --navy-900: #0b1529;
    --navy-800: #0f1d38;
    --navy-700: #162445;
    --text-color: #f8fafc;
    --muted-text: #cbd5e1;
    --background-color: #0b1529;

    /* Tool card dimensions */
    --tool-width: 180px;
    --tool-height: 150px;
    --tool-radius: 10px;
    --tool-gap: 1.5rem;

    /* Search input */
    --search-width: 400px;
    --search-radius: 50px;

    /* Hero divider */
    --divider-color: var(--gold-color);
    --divider-width: 2px;
    --divider-margin: 1rem auto 1.5rem;

    /* Tool glow on hover */
    --tool-glow-color: rgba(166,128,35,0.45);
}

/* ==============================
   GENERAL CONTAINER
============================== */
.home-container {
    padding: 2rem 1rem;
    color: #0b1529;
    background: #fff;
}

.category-container{
    background: var(--navy-800) !important;
    border: 2.2px solid var(--gold-color) !important;
    border-radius: 18px;
    padding: 1.5rem;
    box-shadow: 0 20px 42px rgba(0,0,0,.36), 0 0 0 2px rgba(166,128,35,.15), inset 0 1px 0 rgba(255,255,255,.06);
    color: var(--text-color);
}
.category-container h3{
    color: var(--text-color) !important;
}
.category-container .tool-desc,
.category-container .tool-name{
    color: #0b1529 !important;
}

/* inside dashboard sections, keep tiles white with gold edges for contrast */
.category-container .dashboard-tool{
    background: #fff;
    color: #0b1529;
    border-color: var(--gold-color);
    box-shadow: 0 10px 24px rgba(0,0,0,0.18);
}
.category-container .dashboard-tool .tool-name,
.category-container .dashboard-tool .tool-desc{
    color: #0b1529;
}
.category-container .dashboard-tool:hover{
    color: #0b1529;
    box-shadow: 0 14px 30px rgba(0,0,0,0.26), 0 0 0 3px rgba(166,128,35,.18);
}

/* ==============================
   HERO / TITLE
============================== */
.hero-hr {
    border-color: var(--divider-color);
    border-width: var(--divider-width);
    max-width: 1500px;
    margin: var(--divider-margin);
}

/* ==============================
   SEARCH BAR
============================== */
.search-container {
    display: flex;
    justify-content: center; /* center input + button */
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
}

.search-input {
    width: var(--search-width);
    max-width: 90%;
    padding: 0.6rem 1rem;
    border-radius: var(--search-radius);
    border: 2px solid var(--gold-color);
    background: #fff;
    color: #0b1529;
    caret-color: #0b1529;
    box-shadow: 0 8px 20px rgba(0,0,0,0.18);
    font-size: 1rem;
    transition: all 0.3s ease;
}
.search-input::placeholder{
    color: #1f2a44;
    opacity: 0.95;
}

.search-input:focus {
    outline: none;
    border-color: #b2882b;
    box-shadow: 0 12px 26px rgba(0,0,0,0.22);
}

/* New clear button next to input */
.btn-clear-search {
    padding: 0.55rem 1rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 50px;
    border: 2px solid var(--gold-color);
    background-color: var(--gold-color);
    color: #0b1529;
    cursor: pointer;
    transition: all 0.2s ease;
}

.btn-clear-search:hover {
    background-color: #b2882b;
    color: #0b1529;
    box-shadow: 0 0 16px rgba(0,0,0,.28);
}
.btn-clear-search:focus-visible {
    outline: 2px solid #ddb457;
    outline-offset: 3px;
    box-shadow: 0 0 18px rgba(0,0,0,.32);
}

/* ==============================
   AUTOCOMPLETE
============================== */
.autocomplete-list {
    position: absolute;
    top: 110%;
    left: 0;
    right: 0;
    background: var(--navy-800);
    border: 1.5px solid var(--gold-color);
    border-radius: 12px;
    box-shadow: 0 14px 30px rgba(0,0,0,0.32);
    z-index: 999;
    max-height: 150px;
    overflow-y: auto;
    display: none;
}

.autocomplete-item {
    padding: 0.5rem 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: background 0.2s;
    color: var(--text-color);
}

.autocomplete-item img {
    width: 30px;
    height: 30px;
}

.autocomplete-item:hover {
    background-color: rgba(166,128,35,.16);
}

/* ==============================
   TOOL CARD
============================== */
.dashboard-tool {
    width: var(--tool-width);
    max-width: 180px;
    height: var(--tool-height);
    border: 1.6px solid var(--gold-color);
    border-radius: var(--tool-radius);
    padding: 0.5rem;
    text-decoration: none;
    color: #0b1529;
    font-weight: 700;
    background: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 24px rgba(0,0,0,0.18), inset 0 0 0 1px rgba(166,128,35,.14);
    transition: all 0.3s ease;
    position: relative; /* added for overlay */
}

.dashboard-tool:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 32px rgba(0,0,0,.26), inset 0 0 0 1.6px #c79931;
    color: #0b1529;
    border-color: #c79931;
}
.dashboard-tool:focus-visible {
    outline: 2px solid #ddb457;
    outline-offset: 3px;
    box-shadow: 0 16px 32px rgba(0,0,0,.32), 0 0 0 3px rgba(221,180,87,.32);
}
.dashboard-tool:active{
    transform: translateY(-3px);
    box-shadow: 0 10px 22px rgba(0,0,0,.26), 0 0 0 2px rgba(166,128,35,.24);
}

.dashboard-tool img {
    max-width: 80px;
    max-height: 60px;
}

/* ==============================
   TOOL HOVER DESCRIPTION OVERLAY
============================== */
.dashboard-tool .tool-desc {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(12,21,41,0.92);
    color: #f6e6b4;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 0.9rem;
    padding: 0.5rem;
    opacity: 0;
    transition: opacity 0.25s ease-in-out;
    border-radius: var(--tool-radius);
    font-weight: 700;
}
.dashboard-tool:hover .tool-desc {
    opacity: 1;
}

.dashboard-tool:hover img,
.dashboard-tool:hover .tool-name {
    opacity: 0.2;
    transition: opacity 0.25s ease-in-out;
}

/* ==============================
   RESPONSIVE
============================== */
@@media (max-width: 576px) {
    .dashboard-tool { width: 160px; height: 130px; }
    .dashboard-tool img { width: 50px; height: 50px; }
    .search-input { width: 90%; font-size: 0.95rem; }
    .btn-clear-search { font-size: 0.9rem; padding: 0.45rem 0.8rem; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {

    const searchInput = document.getElementById('toolSearch');
    const autocompleteList = document.getElementById('autocompleteList');
    const clearBtn = document.getElementById('clearSearch');

    const tools = Array.from(document.querySelectorAll('.dashboard-tool')).map(tool => ({
        name: tool.dataset.name || tool.querySelector('.tool-name').textContent.trim(),
        description: tool.querySelector('.tool-desc')?.textContent.toLowerCase() || '',
        href: tool.href,
        imgSrc: tool.querySelector('img').src
    }));

    clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        autocompleteList.style.display = 'none';
    });

    searchInput.addEventListener('input', () => {
        const value = searchInput.value.toLowerCase().trim();
        autocompleteList.innerHTML = '';

        if (!value) {
            autocompleteList.style.display = 'none';
            return;
        }

        const matches = tools.filter(t =>
            t.name.toLowerCase().includes(value) ||
            t.description.includes(value)
        );

        if (!matches.length) {
            autocompleteList.style.display = 'none';
            return;
        }

        matches.forEach(tool => {
            const item = document.createElement('div');
            item.className = 'autocomplete-item';
            item.innerHTML = `
                <img src="${tool.imgSrc}" />
                <span>${tool.name}</span>
            `;
            item.onclick = () => window.open(tool.href, '_blank');
            autocompleteList.appendChild(item);
        });

        autocompleteList.style.display = 'block';
    });

    document.addEventListener('click', e => {
        if (!searchInput.contains(e.target) && !autocompleteList.contains(e.target)) {
            autocompleteList.style.display = 'none';
        }
    });

    const enableMobileCollapses = () => {
        const mq = window.matchMedia('(max-width: 720px)');
        if (!mq.matches) return;

        const categories = Array.from(document.querySelectorAll('.category-container'));
        categories.forEach((cat, idx) => {
            const tools = cat.querySelector('.centered-tools');
            const heading = cat.querySelector('h3');
            if (!tools || !heading) return;

            const setState = (open) => {
                cat.classList.toggle('is-open', open);
                tools.style.display = open ? 'flex' : 'none';
                heading.dataset.mobileState = open ? '−' : '+';
            };

            heading.setAttribute('role', 'button');
            heading.setAttribute('tabindex', '0');

            const initialOpen = idx === 0;
            setState(initialOpen);

            const toggle = () => setState(!cat.classList.contains('is-open'));
            heading.addEventListener('click', toggle);
            heading.addEventListener('keydown', e => {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    toggle();
                }
            });
        });
    };

    enableMobileCollapses();
});
</script>
<script src="~/js/dashboard-execution.js" asp-append-version="true"></script>
