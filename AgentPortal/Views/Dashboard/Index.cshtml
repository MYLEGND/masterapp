            </div>
            <div class="dashboard-analytics-card">
                <div class="dashboard-analytics-label">Commitments On-Time</div>
                <div class="dashboard-analytics-value">@($"{Model.DerivedAnalytics.CommitmentFulfillmentRate:P1}")</div>
                <div class="dashboard-analytics-copy">Follow-through rate on commitments over the last 30 days.</div>
            </div>
            <div class="dashboard-analytics-card">
                <div class="dashboard-analytics-label">Open Commitments</div>
                <div class="dashboard-analytics-value">@Model.DerivedAnalytics.CommitmentsOpen30d</div>
                <div class="dashboard-analytics-copy">Outstanding 30-day commitments still on the board.</div>
            </div>
            <div class="dashboard-analytics-card">
                <div class="dashboard-analytics-label">Total Leads</div>
                <div class="dashboard-analytics-value">@Model.DerivedAnalytics.LeadCount</div>
                <div class="dashboard-analytics-copy">Tracked leads feeding the current conversion insight model.</div>
            </div>
        </div>
