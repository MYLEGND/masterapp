@using Shared.Auth
@using System.Globalization
@model List<AgentPortal.Models.ClientListItemViewModel>
@using AgentPortal.Services

@{
    ViewData["Title"] = "Leads";
    var portalBase = ((string)(ViewBag.ClientPortalBaseUrl ?? "https://localhost:5221")).TrimEnd('/');
    var search = (string)(ViewBag.Search ?? "");
    var hasSearch = !string.IsNullOrWhiteSpace(search);
    var totalClients = Model?.Count ?? 0;
    int CountStage(string stage) => Model?.Count(x => string.Equals(x.PipelineStage, stage, StringComparison.OrdinalIgnoreCase)) ?? 0;
    var mpCount = CountStage("MortgageProtection");
    var lifeCount = CountStage("LifeInsurance");
    var feCount = CountStage("FinalExpense");
    var diCount = CountStage("DisabilityInsurance");
    var calledTodayCount = Model?.Count(x => x.AttemptsToday > 0) ?? 0;
    var callBackCount = CountStage("CallBack");
    var contactedCount = CountStage("Contacted");
    var bookedCount = CountStage("Booked");
    var followUpCount = CountStage("FollowUp");
    var needsDocsCount = CountStage("NeedsDocs");
    var policyPlacedCount = CountStage("PolicyPlaced");
    var voicemailCount = CountStage("Voicemail");
    var notInterestedCount = CountStage("NotInterested");
    var nurtureCount = CountStage("Nurture");
    var noAnswerCount = CountStage("NoAnswer");
    var lostCount = CountStage("Lost");
    var aiReceptionCount = CountStage("AIReception");
    var doNotCallCount = CountStage("DoNotCallList");
    var prodTotals = ViewData["ProductionTotals"] as ProductionTotals ?? new ProductionTotals();
    // Personal revenue mirrors Paid (single-status per card enforced in ProductionService)
    var personalRevenueAmount = prodTotals.Personal;
    var personalRevenueCount = prodTotals.CountPersonal;

    bool IsPlaceholderEmail(string? email)
    {
        var normalized = (email ?? "").Trim().ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(normalized)) return false;

        return (normalized.StartsWith("no-email@", StringComparison.OrdinalIgnoreCase) && normalized.EndsWith(".com", StringComparison.OrdinalIgnoreCase))
            || (normalized.StartsWith("lead-", StringComparison.OrdinalIgnoreCase) && normalized.EndsWith("@scripts.local", StringComparison.OrdinalIgnoreCase))
            || normalized.EndsWith("@leads.local", StringComparison.OrdinalIgnoreCase);
    }
}

<link rel="stylesheet" href="~/css/clients-index.css" asp-append-version="true" />
<style>
    .production-rollup{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin:14px 0;}
    .prod-card{padding:14px;border-radius:14px;box-shadow:0 12px 30px rgba(0,0,0,.28);border:1px solid rgba(0,0,0,.16);position:relative;}
    .prod-card .label{font-weight:800;letter-spacing:.04em;color:#0b0f18;text-transform:uppercase;font-size:0.8rem;}
    .prod-card .value{font-weight:900;font-size:1.6rem;color:#0b0f18;}
    .prod-card .note{color:#1e293b;font-weight:700;}
    .prod-card .badge-live{display:none;position:absolute;top:8px;right:8px;background:#0b0f18;color:#f8fafc;border:1px solid #b6892b;border-radius:999px;padding:2px 8px;font-weight:800;font-size:11px;letter-spacing:.3px;}
    .prod-card.has-value{box-shadow:0 0 0 3px rgba(0,0,0,.28),0 12px 30px rgba(0,0,0,.28);}
    .prod-card.has-value .badge-live{display:inline-flex;}
    .prod-card.submitted{background:#f5d770 !important;border-color:#b6892b;}
    .prod-card.issued{background:#b6c9ff !important;border-color:#6d8ed8;}
    .prod-card.paid{background:#a2e6c1 !important;border-color:#4aa36a;}
    .prod-card.personal{background:#e0d5ff !important;border-color:#8b6fd8;}
</style>

<div class="wrap density-comfort leads-crm" id="legendWrap">

<form id="__af" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div class="head">
    <div>
        <h2 class="title">Leads</h2>
        <div class="subtitle">Legend Lead Command Center — clean, premium, fast. Built for execution.</div>
    </div>
    <div class="pill" title="Keyboard: Ctrl/Cmd + K">
        ⚡ Command Palette: <strong>Ctrl/Cmd + K</strong>
    </div>
</div>

<div class="production-rollup">
@{
    bool submittedActive = personalRevenueAmount != 0 || prodTotals.Submitted != 0 || prodTotals.CountSubmitted != 0;
    bool issuedActive = prodTotals.Issued != 0 || prodTotals.CountIssued != 0;
    bool paidActive = prodTotals.Paid != 0 || prodTotals.CountPaid != 0;
    bool personalActive = personalRevenueAmount != 0 || personalRevenueCount != 0;
}
    <div class="prod-card submitted @(submittedActive ? "has-value" : "")" style="background:#f5d770;border:1px solid #b6892b;color:#0b0f18;">
        <span class="badge-live">Active</span>
        <div class="label" style="color:#0b0f18;">Submitted</div>
        <div class="value" id="tileSubmittedTotal" style="color:#7a5a00;">@prodTotals.Submitted.ToString("C0")</div>
        <div class="note" style="color:#4b3a0f;"><span id="tileSubmittedCount">@prodTotals.CountSubmitted</span> deals</div>
    </div>
    <div class="prod-card issued @(issuedActive ? "has-value" : "")" style="background:#b6c9ff;border:1px solid #6d8ed8;color:#0b0f18;">
        <span class="badge-live">Active</span>
        <div class="label" style="color:#0b0f18;">Issued</div>
        <div class="value" id="tileIssuedTotal" style="color:#1f3f8c;">@prodTotals.Issued.ToString("C0")</div>
        <div class="note" style="color:#304870;"><span id="tileIssuedCount">@prodTotals.CountIssued</span> deals</div>
    </div>
    <div class="prod-card paid @(paidActive ? "has-value" : "")" style="background:#a2e6c1;border:1px solid #4aa36a;color:#0b0f18;">
        <span class="badge-live">Active</span>
        <div class="label" style="color:#0b0f18;">Paid</div>
        <div class="value" id="tilePaidTotal" style="color:#0f5d36;">@prodTotals.Paid.ToString("C0")</div>
        <div class="note" style="color:#1f4d37;"><span id="tilePaidCount">@prodTotals.CountPaid</span> deals</div>
    </div>
    <div class="prod-card personal @(personalActive ? "has-value" : "")" style="background:#e0d5ff;border:1px solid #8b6fd8;color:#0b0f18;">
        <span class="badge-live">Active</span>
        <div class="label" style="color:#0b0f18;">Personal Revenue</div>
        <div class="value" id="tilePersonalTotal" style="color:#3c2c78;">@personalRevenueAmount.ToString("C0")</div>
        <div class="note" style="color:#524070;"><span id="tilePersonalCount">@personalRevenueCount</span> deals</div>
    </div>
</div>

@if (TempData["Created"] != null)
{
    <div class="flash">@TempData["Created"]</div>
}

<div class="kpis" id="kpiGrid" style="display:none;">
    <div class="kpi"><div class="l">Total</div><div class="v" id="kTotal">0</div><div class="h">All client profiles</div></div>
    <div class="kpi"><div class="l">Needs Attention</div><div class="v" id="kNeeds">0</div><div class="h">Follow-up / missing</div></div>
    <div class="kpi"><div class="l">Overdue</div><div class="v" id="kOverdue">0</div><div class="h">Next action missed</div></div>
    <div class="kpi"><div class="l">Due Today</div><div class="v" id="kToday">0</div><div class="h">Execute now</div></div>
    <div class="kpi"><div class="l">Touched 14d</div><div class="v" id="kTouched">0</div><div class="h">Recent connection</div></div>
    <div class="kpi"><div class="l">Broken IDs</div><div class="v" id="kBroken">0</div><div class="h">Portal link issue</div></div>
</div>

<section class="call-metrics" id="callMetrics">
    <div class="cm-card cm-today">
        <div class="cm-label">Calls Today</div>
        <div class="cm-value" id="cmToday">0</div>
        <div class="cm-note">Logged today</div>
    </div>
    <div class="cm-card cm-week">
        <div class="cm-label">Calls This Week</div>
        <div class="cm-value" id="cmWeek">0</div>
        <div class="cm-note">Sun–Sat</div>
    </div>
    <div class="cm-card cm-month">
        <div class="cm-label">Calls This Month</div>
        <div class="cm-value" id="cmMonth">0</div>
        <div class="cm-note">Month-to-date</div>
    </div>
    <button type="button" class="btn btn-gold cm-review" id="btnDialYear">Dial Tracker — YTD <span id="cmYearBtn">0</span></button>
</section>

<section class="myday navy-shell" id="myDayQueue">
    <div class="myday-head">
        <div>
            <h3 class="myday-title">My Day</h3>
            <p class="myday-sub">Start with the work that should happen right now. These queues are live off persisted CRM data.</p>
        </div>
        <div class="myday-actions">
            <button type="button" class="btn btn-gold" id="btnCallTaskMode">Call Task Mode</button>
        </div>
    </div>
    <div class="myday-grid">
        <button type="button" class="myday-tile" data-queue="callsnow">
            <span class="myday-k">Calls Now</span>
            <strong class="myday-v" id="qCallsNow">0</strong>
            <span class="myday-h">Priority follow-up calls that should happen immediately.</span>
            <span class="myday-cta">Open Queue →</span>
        </button>
        <button type="button" class="myday-tile" data-queue="today">
            <span class="myday-k">Due Today</span>
            <strong class="myday-v" id="qDueToday">0</strong>
            <span class="myday-h">Touches due today and ready for execution.</span>
            <span class="myday-cta">Open Queue →</span>
        </button>
        <button type="button" class="myday-tile" data-queue="overdue">
            <span class="myday-k">Overdue</span>
            <strong class="myday-v" id="qOverdue">0</strong>
            <span class="myday-h">Rescue this list before it gets stale.</span>
            <span class="myday-cta">Open Queue →</span>
        </button>
        <button type="button" class="myday-tile" data-queue="meetings">
            <span class="myday-k">Meetings</span>
            <strong class="myday-v" id="qMeetings">0</strong>
            <span class="myday-h">Meeting-stage clients with event execution pressure.</span>
            <span class="myday-cta">Open Queue →</span>
        </button>
        <button type="button" class="myday-tile" data-queue="waitingclient">
            <span class="myday-k">Waiting On Client</span>
            <strong class="myday-v" id="qWaitingClient">0</strong>
            <span class="myday-h">Clients who owe the next move back to you.</span>
            <span class="myday-cta">Open Queue →</span>
        </button>
        <button type="button" class="myday-tile" data-queue="waitingcarrier">
            <span class="myday-k">Waiting On Carrier</span>
            <strong class="myday-v" id="qWaitingCarrier">0</strong>
            <span class="myday-h">Cases blocked externally and needing visibility.</span>
            <span class="myday-cta">Open Queue →</span>
        </button>
    </div>
    <div class="myday-focus" id="mydayFocus">
        <button type="button" class="btn btn-ghost" id="btnMyDayBack">← Back To Leads</button>
        <div class="myday-focus-copy">
            <div class="myday-focus-title" id="mydayFocusTitle">Queue</div>
            <div class="myday-focus-sub" id="mydayFocusSub">Work this queue, edit records in Quick View, then return to the full clients page.</div>
        </div>
        <div class="myday-focus-actions">
            <span class="pill" id="mydayFocusCount">0 records</span>
            <button type="button" class="btn btn-gold" id="btnMyDayCallTask">Open Call Task Mode</button>
        </div>
    </div>
    <div class="saved-views" id="savedViewsBar"></div>
</section>

<section class="crm-deck">
    <article class="crm-card navy-shell">
        <div class="crm-card-head">
            <div>
                <h3 class="crm-card-title">Pipeline Control Board</h3>
                <p class="crm-card-sub">Move clients through actual stages instead of leaving them in a flat list. These chips drive the pipeline filter immediately.</p>
            </div>
            <span class="pill">Live Queue</span>
        </div>
        <div class="crm-card-body">
            <div class="stage-picker-shell" id="stagePickerShell">
                <div class="stage-picker-top">
                    <label class="stage-picker-label" for="stagePickerSelect">Jump to bucket</label>
                    <div class="stage-picker-actions">
                        <select class="select stage-picker-select" id="stagePickerSelect">
                            <option value="MortgageProtection" data-count="@mpCount" data-note="Mortgage Protection leads direct from scripts.">MORTGAGE PROTECTION LEADS</option>
                            <option value="LifeInsurance" data-count="@lifeCount" data-note="Life Insurance leads ready for first touch.">LIFE INSURANCE LEADS</option>
                            <option value="FinalExpense" data-count="@feCount" data-note="Final Expense leads queued for contact.">FINAL EXPENSE LEADS</option>
                            <option value="DisabilityInsurance" data-count="@diCount" data-note="Disability Insurance leads to qualify fast.">DISABILITY INSURANCE LEADS</option>
                            <option value="CalledToday" data-count="@calledTodayCount" data-note="Touched today and ready for same-day follow-through.">CALLED TODAY</option>
                            <option value="CallBack" data-count="@callBackCount" data-note="Asked for a callback or needs a scheduled return touch.">CALL BACK</option>
                            <option value="Contacted" data-count="@contactedCount" data-note="First touch happened. Keep momentum alive.">Contacted</option>
                            <option value="Booked" data-count="@bookedCount" data-note="Appointment set; prepare and confirm.">Booked</option>
                            <option value="FollowUp" data-count="@followUpCount" data-note="Needs follow-up after conversation.">Follow Up</option>
                            <option value="NeedsDocs" data-count="@needsDocsCount" data-note="Waiting on documents to proceed.">Needs Docs</option>
                            <option value="PolicyPlaced" data-count="@policyPlacedCount" data-note="Placed business; service and retain.">Policy Placed</option>
                            <option value="Voicemail" data-count="@voicemailCount" data-note="Voicemail was left and needs callback tracking.">Voicemail Left</option>
                            <option value="NotInterested" data-count="@notInterestedCount" data-note="Lead not moving forward right now.">Not Interested</option>
                            <option value="Nurture" data-count="@nurtureCount" data-note="Stay in touch over time.">Nurture</option>
                            <option value="NoAnswer" data-count="@noAnswerCount" data-note="Could not reach lead yet.">No Answer</option>
                            <option value="Lost" data-count="@lostCount" data-note="Opportunity was lost.">Lost</option>
                            <option value="AIReception" data-count="@aiReceptionCount" data-note="Handled by AI receptionist flow.">AI Reception</option>
                            <option value="DoNotCallList" data-count="@doNotCallCount" data-note="No call or text activity should happen from the workstation.">DO NOT CALL LIST</option>
                        </select>
                        <button type="button" class="btn btn-gold stage-picker-open" id="btnStagePickerOpen" data-stagejump="MortgageProtection">Open Bucket</button>
                    </div>
                </div>
                <button type="button" class="stage-picker-detail" id="stagePickerDetail" data-stagejump="MortgageProtection">
                    <div class="stage-picker-detail-top">
                        <span class="stage-picker-name" id="stagePickerName">MORTGAGE PROTECTION LEADS</span>
                        <span class="stage-picker-count" id="stagePickerCount">@mpCount</span>
                    </div>
                    <div class="stage-picker-note" id="stagePickerNote">Mortgage Protection leads direct from scripts.</div>
                </button>
            </div>
        </div>
    </article>

    <article class="crm-card navy-shell">
        <div class="crm-card-head">
            <div>
                <h3 class="crm-card-title">Execution Console</h3>
                <p class="crm-card-sub">Focus the work that should happen today: meetings, overdue follow-up, and stage progression.</p>
            </div>
            <span class="pill">@totalClients Managed Records</span>
        </div>
        <div class="crm-card-body">
            <div class="ops-stack">
                <div class="ops-row">
                    <div class="ops-tile">
                        <div class="ops-label">Booked Queue</div>
                        <div class="ops-value">@bookedCount</div>
                        <div class="ops-note">Appointments set; confirm details and prepare.</div>
                    </div>
                    <div class="ops-tile">
                        <div class="ops-label">Follow Up Load</div>
                        <div class="ops-value">@followUpCount</div>
                        <div class="ops-note">Follow-up required after first contact.</div>
                    </div>
                </div>
                <div class="ops-row">
                    <div class="ops-tile">
                        <div class="ops-label">Docs Pending</div>
                        <div class="ops-value">@needsDocsCount</div>
                        <div class="ops-note">Leads waiting on documents to proceed.</div>
                    </div>
                    <div class="ops-tile">
                        <div class="ops-label">Nurture Base</div>
                        <div class="ops-value">@nurtureCount</div>
                        <div class="ops-note">Long-cycle relationships that still need light touches.</div>
                    </div>
                </div>
                <div class="ops-row">
                    <button type="button" class="btn btn-gold" id="btnFilterMeetings">Focus Meetings</button>
                    <button type="button" class="btn btn-ghost" id="btnFilterOverdue">Focus Overdue</button>
                </div>
            </div>
        </div>
    </article>

    <article class="crm-card">
        <div class="crm-card-head">
            <div>
                <h3 class="crm-card-title">CRM Resource Dock</h3>
                <p class="crm-card-sub">Keep execution tools in the same place so agents are not bouncing around blind.</p>
            </div>
            <span class="pill">Ops Links</span>
        </div>
        <div class="crm-card-body">
            <div class="resource-list">
                <a class="resource-link" href="/Resources">
                    <div class="resource-main">
                        <span class="resource-title">Resources Library</span>
                        <span class="resource-sub">Carrier material, product guides, and quick reference docs.</span>
                    </div>
                    <span class="resource-arrow">→</span>
                </a>
                <a class="resource-link" href="/Workstation">
                    <div class="resource-main">
                        <span class="resource-title">Workstation (Scripts + Rebuttals)</span>
                        <span class="resource-sub">Prospecting scripts, rebuttals, and talk tracks in one place.</span>
                    </div>
                    <span class="resource-arrow">→</span>
                </a>
                <a class="resource-link" href="/Tools">
                    <div class="resource-main">
                        <span class="resource-title">Agent Tools</span>
                        <span class="resource-sub">Launch external tools like Zoom and Teams without leaving the workflow.</span>
                    </div>
                    <span class="resource-arrow">→</span>
                </a>
                <button type="button" class="resource-link" id="btnResourceCalendar">
                    <div class="resource-main">
                        <span class="resource-title">Calendar Sync</span>
                        <span class="resource-sub">Connect Outlook for event creation directly from the client drawer.</span>
                    </div>
                    <span class="resource-arrow">→</span>
                </button>
            </div>
        </div>
    </article>
</section>

<div class="bar navy-shell" id="legendBar">
    <div class="bar-grid">
        <div class="bar-col">
            <div class="group search-card">
                <div class="group-title">Search + Primary Actions</div>

                <form method="get" asp-action="Index" autocomplete="off" id="clientSearchForm" style="margin:0; flex:1 1 440px; min-width:280px;">
                    <div class="field" title="Search (/)">
                        <span style="opacity:.9;">🔎</span>
                        <input name="search"
                               value="@search"
                               id="clientSearchInput"
                               placeholder="Search client name or email..."
                               class="search-input"
                               autocomplete="off"
                               autocorrect="off"
                               autocapitalize="off"
                               spellcheck="false" />
                        <span class="hint">/</span>
                    </div>
                    <div class="search-warning" id="clientSearchWarning" aria-live="polite"></div>
                </form>

                @if (hasSearch)
                {
                    <a asp-action="Index" class="btn btn-ghost">← Back To Clients</a>
                }
            </div>

            <div class="group tight filters-card">
                <div class="group-title">Filters + Sort</div>

                <select class="select" id="statusFilter" title="Filter by status (local)">
                    <option value="">All Status</option>
                    <option value="Lead">Lead</option>
                    <option value="Prospect">Prospect</option>
                    <option value="Active">Active Client</option>
                    <option value="Dormant">Inactive</option>
                </select>

                <select class="select" id="priorityFilter" title="Filter by CRM priority">
                    <option value="">All Priority</option>
                    <option value="Urgent">Urgent</option>
                    <option value="High">High</option>
                    <option value="Normal">Normal</option>
                    <option value="Low">Low</option>
                </select>

                <select class="select" id="stateFilter" title="Filter by state">
                    <option value="">State</option>
                </select>

                <select class="select" id="stageFilter" title="Filter by pipeline stage">
                    <option value="">All Stages</option>
                    <option value="PolicyPlaced">Policy Placed</option>
                    <option value="Booked">Booked</option>
                    <option value="FollowUp">Follow Up</option>
                    <option value="MortgageProtection">Mortgage Protection</option>
                    <option value="LifeInsurance">Life Insurance</option>
                    <option value="FinalExpense">Final Expense</option>
                    <option value="DisabilityInsurance">Disability Insurance</option>
                    <option value="CalledToday">Called Today</option>
                    <option value="CallBack">Call Back</option>
                    <option value="Contacted">Contacted</option>
                    <option value="NeedsDocs">Needs Docs</option>
                    <option value="Voicemail">Voicemail Left</option>
                    <option value="NotInterested">Not Interested</option>
                    <option value="Nurture">Nurture</option>
                    <option value="NoAnswer">No Answer</option>
                    <option value="Lost">Lost</option>
                    <option value="AIReception">AI Reception</option>
                    <option value="DoNotCallList">Do Not Call List</option>
                </select>

                <select class="select" id="attentionFilter" title="Focus filters">
                    <option value="">All</option>
                    <option value="callsnow">Calls Now</option>
                    <option value="needs">Needs Attention</option>
                    <option value="overdue">Overdue</option>
                    <option value="today">Due Today</option>
                    <option value="soon">Due Soon (3d)</option>
                    <option value="hasnext">Has Next Action</option>
                    <option value="nonext">No Next Action</option>
                    <option value="notouch">No Last Touch</option>
                    <option value="touched14">Touched (14d)</option>
                    <option value="missing">Missing Contact</option>
                    <option value="missingemail">Missing Email</option>
                    <option value="missingphone">Missing Phone</option>
                    <option value="broken">Broken Portal ID</option>
                    <option value="meeting">Booked</option>
                    <option value="zoom">Has Zoom Link</option>
                    <option value="location">Has Meeting Location</option>
                    <option value="waitingclient">Waiting On Client</option>
                    <option value="waitingagent">Waiting On Agent</option>
                    <option value="waitingcarrier">Waiting On Carrier</option>
                    <option value="waitinguw">Waiting On Underwriting</option>
                    <option value="waitingdocs">Waiting On Docs</option>
                    <option value="stalled">Stage Aging 7+ Days</option>
                    <option value="attempts3">3+ Attempts This Week</option>
                    <option value="duplicates">Duplicate Warning</option>
                    <option value="docsopen">Open Doc Checklist</option>
                    <option value="rescue">Needs Rescue</option>
                    <option value="appsinflight">Needs Docs / Policy Placed</option>
                </select>

                <select class="select" id="sortBy" title="Sort">
                    <option value="name_asc">Sort: Name (A→Z)</option>
                    <option value="name_desc">Sort: Name (Z→A)</option>
                    <option value="status_asc">Sort: Status</option>
                    <option value="nextaction_asc">Sort: Next Action (Soonest)</option>
                    <option value="lasttouch_desc">Sort: Last Touch (Newest)</option>
                </select>

                <select class="select" id="pageSize" title="Rows per page">
                    <option value="10">10 / page</option>
                    <option value="20" selected>20 / page</option>
                    <option value="50">50 / page</option>
                    <option value="100">100 / page</option>
                </select>

                <div class="preset-row">
                    <button type="button" class="preset-chip" data-preset="clear">Reset Filters</button>
                </div>
            </div>
        </div>

        <div class="bar-col">
            <div class="group right views-card">
                <div class="group-title">Views + Execution Tools</div>

                <button type="button" class="btn btn-amber" id="btnEnableReminders" title="Enable browser reminders">Enable Reminders</button>

                <button type="button" class="btn btn-amber" id="btnReminders" title="See Due Today / Overdue">
                    Reminders <span class="pill" style="padding:4px 8px;" id="remCount">0</span>
                </button>

                <select class="select" id="viewMode" title="View mode">
                    <option value="pipeline" selected>View: Pipeline CRM</option>
                    <option value="table">View: Table</option>
                    <option value="hybrid">View: Hybrid</option>
                </select>

                <select class="select" id="density" title="Density">
                    <option value="comfort" selected>Density: Comfort</option>
                    <option value="compact">Density: Compact</option>
                </select>

                <button type="button" class="btn btn-blue" id="btnCols">Columns</button>
                <button type="button" class="btn btn-violet" id="btnShortcuts">Shortcuts</button>
            </div>

            <div class="group right tight export-card">
                <div class="group-title">Export + Calendar</div>

                <button type="button" class="btn btn-silver" id="btnCopyEmails" disabled>Copy Emails</button>
                <button type="button" class="btn btn-green" id="btnExportCsv">Export CSV</button>

                <button type="button" class="btn btn-teal" id="btnCalendarAuth" title="Connect your Microsoft calendar">
                    Connect Calendar
                </button>
            </div>
        </div>
    </div>

    <div class="bar-row">
        <div class="left">
            @if (hasSearch)
            {
                <span class="pill">Search Results: <strong>@(Model?.Count ?? 0)</strong></span>
                <a asp-action="Index" class="btn btn-ghost">Back To Full Client List</a>
            }
            <span class="pill" id="selectionPill">Selected: <strong id="selCount">0</strong></span>
            <button type="button" class="btn btn-ghost" id="btnClearSel" disabled>Clear Selection</button>
            <button type="button" class="btn btn-gold" id="btnOpenFirst" title="Open Quick View for first selected" disabled>Open Selected</button>
            <button type="button" class="btn btn-ghost" id="btnBulkEdit" disabled>Bulk Edit</button>
            <button type="button" class="btn btn-red" id="btnBulkDelete" title="⌘/Ctrl + Shift + D">Delete Selected</button>
            <button type="button" class="btn btn-red" id="btnDeleteBucket" title="Delete entire bucket">Delete Bucket</button>
        </div>
        <div class="right">
            <span class="hint" id="pagerInfo">—</span>
            <button type="button" class="btn btn-ghost" id="btnPrev">← Prev</button>
            <span class="pill"><strong id="pageNow">1</strong> / <strong id="pageMax">1</strong></span>
            <button type="button" class="btn btn-ghost" id="btnNext">Next →</button>
        </div>
    </div>
</div>

<!-- Hybrid command bar (only shown when Hybrid view selected) -->
@if (Model == null || Model.Count == 0)
{
    <div class="legend-empty-state">
        <div class="legend-empty-icon">&#128466;</div>
        <p class="legend-empty-title">No leads in this bucket yet</p>
        <p class="legend-empty-sub">Import leads or change the selected bucket to see your pipeline.</p>
    </div>
}
else
{
<div class="card" id="tableView">
        <table id="clientsTable">
            <thead>
                <tr>
                    <th style="width:46px;" data-col="select">
                        <input type="checkbox" class="chk" id="chkAll" title="Select all on this page" />
                    </th>
                    <th data-col="name">Client</th>
                    <th data-col="email">Email</th>
                    <th data-col="phone">Phone</th>
                    <th data-col="portal">Client Portal</th>
                    <th data-col="status">CRM Status</th>
                    <th data-col="stage">Pipeline</th>
                    <th data-col="next">Next Action</th>
                    <th data-col="touch">Last Touch</th>
                    <th data-col="actions" style="text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @{
                var showProductionOnly = false;
                if (Context.Request.Query.ContainsKey("showProductionOnly"))
                {
                    bool.TryParse(Context.Request.Query["showProductionOnly"], out showProductionOnly);
                }
            }
            @foreach (var c in Model)
            {
                if (showProductionOnly && c.PaidAmount <= 0 && c.PersonalAmount <= 0)
                {
                    continue;
                }
                var hasPortalAccess = Guid.TryParse(c.ClientUserId, out _);
                var clientUrl = hasPortalAccess
                    ? (Url.Action("Edit", "Clients", new { clientUserId = c.ClientUserId, workspace = true }) ?? "")
                    : "";

                var sStatus    = (c.CrmStatus ?? "Lead").Trim();
                var sPriority  = (c.CrmPriority ?? "Normal").Trim();
                var sLastTouch = c.CrmLastTouch.HasValue ? c.CrmLastTouch.Value.ToString("yyyy-MM-dd") : "";
                var sNextDate  = c.CrmNextDate.HasValue ? c.CrmNextDate.Value.ToString("yyyy-MM-dd") : "";
                var sNextText  = (c.CrmNextText ?? "").Trim();
                var sTags      = (c.CrmTags ?? "").Trim();
                var sNotes     = (c.AgentNotes ?? "").Trim();
                var sRecordType = (c.RecordType ?? "Lead").Trim();
                var sPipeline  = (c.PipelineStage ?? "MortgageProtection").Trim();
                var sMeetingLocation = (c.MeetingLocation ?? "").Trim();
                var sZoomJoinUrl = (c.ZoomJoinUrl ?? "").Trim();
                var sUsePersonalZoom = c.UsePersonalZoomLink ? "true" : "false";
                var sMeetingTime = (c.MeetingTime ?? "09:00").Trim();
                var sMeetingDuration = c.MeetingDurationMinutes <= 0 ? 30 : c.MeetingDurationMinutes;
                var sWaitingOn = (c.WaitingOn ?? AgentPortal.Models.ClientCrmMeta.DefaultWaitingOn).Trim();
                var sPinnedBrief = (c.PinnedBrief ?? "").Trim();
                var sStageEntered = c.StageEnteredUtc.ToString("yyyy-MM-dd");
                var sPipelineOrder = c.PipelineOrder.ToString(CultureInfo.InvariantCulture);
                var sOwner = (c.AssignedOwner ?? "").Trim();
                var sWatchers = (c.WatchersCsv ?? "").Trim();
                var sAddress = (c.AddressLine ?? "").Trim();
var sCity = (c.City ?? "").Trim();
                var sState = (c.State ?? "").Trim();
                var sZip = (c.ZipCode ?? "").Trim();
                var sLender = (c.MortgageLender ?? "").Trim();
                var sCounty = (c.County ?? "").Trim();
                var sGender = (c.Gender ?? "").Trim();
                var sLoanAmount = (c.LoanAmount ?? "").Trim();
                var sDob = c.DOB.HasValue ? c.DOB.Value.ToString("yyyy-MM-dd") : "";
                var sPhone2 = (c.Phone2 ?? "").Trim();
                var sAge = (c.Age ?? "").Trim();
                var sBtc = (c.Btc ?? "").Trim();
                var sOriginalLeadType = (c.OriginalLeadType ?? "").Trim();
                var dialPhone = (c.Phone ?? "").Trim();
                var isFakeEmail = IsPlaceholderEmail(c.Email);
                var prodPaid = c.ProductionPaidAmount;
                var prodIssued = c.ProductionIssuedAmount;
                var prodSubmitted = c.ProductionSubmittedAmount;
                var prodStatus = prodPaid > 0 ? "Paid" : "";
                var prodAmount = prodPaid;

                <tr class="client-row"
                    data-client-id="@c.ClientUserId"
                    data-first="@c.FirstName"
                    data-last="@c.LastName"
                    data-email="@c.Email"
                    data-phone="@dialPhone"
                    data-phone2="@sPhone2"
                    data-age="@sAge"
                    data-btc="@sBtc"
                    data-original-lead-type="@sOriginalLeadType"
                    data-isguid="@hasPortalAccess.ToString().ToLower()"
                    data-clienturl="@clientUrl"
                    data-s-status="@sStatus"
                    data-s-priority="@sPriority"
                    data-s-lasttouch="@sLastTouch"
                    data-s-nextdate="@sNextDate"
                    data-s-nexttext="@sNextText"
                    data-s-tags="@sTags"
                    data-s-notes="@sNotes"
                    data-s-recordtype="@sRecordType"
                    data-s-pipeline="@sPipeline"
                    data-s-meeting-location="@sMeetingLocation"
                    data-s-zoom="@sZoomJoinUrl"
                    data-s-usezoom="@sUsePersonalZoom"
                    data-s-meeting-time="@sMeetingTime"
                    data-s-meeting-duration="@sMeetingDuration"
                    data-s-waiting="@sWaitingOn"
                    data-s-pinnedbrief="@sPinnedBrief"
                    data-s-stageentered="@sStageEntered"
                    data-s-pipelineorder="@sPipelineOrder"
                    data-s-attemptstoday="@c.AttemptsToday"
                    data-s-attemptsweek="@c.AttemptsThisWeek"
                    data-s-attemptsmonth="@c.AttemptsThisMonth"
                    data-s-attemptsyear="@c.AttemptsYear"
                    data-s-attemptslife="@c.AttemptsLifetime"
                    data-s-channel="@c.LastContactChannel"
                    data-s-doccount="@c.DocChecklistCompletedCount"
                    data-s-dupe-email="@(c.HasDuplicateEmail ? "true" : "false")"
                    data-s-dupe-phone="@(c.HasDuplicatePhone ? "true" : "false")"
                    data-s-dupe-household="@(c.HasDuplicateHousehold ? "true" : "false")"
                    data-s-owner="@sOwner"
                    data-s-watchers="@sWatchers"
                    data-address="@sAddress"
                    data-address-line="@sAddress"
                    data-city="@sCity"
                    data-state="@sState"
                    data-zip-code="@sZip"
                    data-zipcode="@sZip"
                    data-zip="@sZip"
                    data-county="@sCounty"
                    data-gender="@sGender"
                    data-loan-amount="@sLoanAmount"
                    data-dob="@sDob"
                    data-mortgage-lender="@sLender"
                    data-mortgagelender="@sLender"
                    data-paid="@c.PaidAmount"
                    data-personal="@c.PersonalAmount"
                    data-prod-paid="@prodPaid"
                    data-prod-issued="@prodIssued"
                    data-prod-submitted="@prodSubmitted"
                    data-prod-status="@prodStatus"
                    data-prod-amount="@prodAmount">

                    <td data-label="Select" data-col="select">
                        <input type="checkbox" class="chk row-chk" />
                    </td>

                    <td data-label="Client" data-col="name" data-open-row="true">
                        <div class="cell-stack cell-with-prod">
                            <div class="lead-prod-card" data-prod-card>
                                @if (prodPaid > 0 || prodIssued > 0 || prodSubmitted > 0)
                                {
                                    <div class="prod-line prod-line-paid"><span class="prod-lbl">Paid:</span><span class="prod-val">@prodPaid.ToString("C0")</span></div>
                                    <div class="prod-line prod-line-issued"><span class="prod-lbl">Issued:</span><span class="prod-val">@prodIssued.ToString("C0")</span></div>
                                    <div class="prod-line prod-line-submitted"><span class="prod-lbl">Submitted:</span><span class="prod-val">@prodSubmitted.ToString("C0")</span></div>
                                }
                            </div>
                            <span class="name open-drawer" title="Quick View">@c.FirstName @c.LastName</span>
                            <span class="muted@(isFakeEmail ? " crm-email-fake" : "")" data-email-summary="true">@c.Email</span>
                            @if (!string.IsNullOrWhiteSpace(dialPhone))
                            {
                                <a class="muted phone-link" href="tel:@dialPhone">@c.Phone</a>
                            }
                            else
                            {
                                <span class="muted">—</span>
                            }

                            @if (c.PaidAmount > 0 || c.PersonalAmount > 0)
                            {
                                <div class="prod-pill">
                                    @if (c.PaidAmount > 0)
                                    {
                                        <span class="pill pill-paid" title="Paid production">@c.PaidAmount.ToString("C0")</span>
                                    }
                                    @if (c.PersonalAmount > 0)
                                    {
                                        <span class="pill pill-personal" title="Personal revenue">@c.PersonalAmount.ToString("C0")</span>
                                    }
                                </div>
                            }
                        </div>
                    </td>

                    <td class="muted" data-label="Email" data-col="email">
                        <span class="@(isFakeEmail ? "crm-email-fake" : "")" data-email-cell="true">@c.Email</span>
                    </td>

                    <td class="muted" data-label="Phone" data-col="phone">
                        @if (!string.IsNullOrWhiteSpace(dialPhone))
                        {
                            <a class="phone-link" href="tel:@dialPhone">@c.Phone</a>
                        }
                        else
                        {
                            <span class="muted">—</span>
                        }
                    </td>

                    <td data-label="Client Portal" data-col="portal">
                        @if (!hasPortalAccess)
                        {
                            <span class="muted">Internal Lead</span>
                        }
                        else if (string.Equals(c.ClientUserId, User.GetStableUserId(), StringComparison.OrdinalIgnoreCase))
                        {
                            <span class="muted">Invalid client record</span>
                        }
                        else
                        {
                            var clientPortalUrl = $"{portalBase}/support/view-as-client/{c.Id}";

                            <a class="link"
                               href="@clientPortalUrl"
                               target="_blank"
                               rel="noopener noreferrer">
                                Open Profile
                            </a>
                        }
                    </td>

                    <td data-label="CRM Status" data-col="status">
                        <div class="cell-stack">
                            <span class="badge" data-badge>
                                <span class="dot"></span>
                                <span data-status-text>Active Client</span>
                            </span>
                            <span class="meta-chip" data-waiting-text>Waiting On Agent</span>
                        </div>
                    </td>

                    <td data-label="Pipeline" data-col="stage">
                        <span class="badge" data-pipeline-badge>
                            <span class="dot"></span>
                            <span data-pipeline-text>Lead</span>
                        </span>
                    </td>

                    <td data-label="Next Action" data-col="next">
                        <span class="nextpill none" data-nextpill title="Set Next Action in Quick View">
                            <span class="flag">—</span>
                            <span class="txt" data-nextaction>—</span>
                        </span>
                    </td>

                    <td data-label="Last Touch" data-col="touch">
                        <div class="cell-stack">
                            <span class="muted" data-lasttouch>—</span>
                            <span class="tiny" data-stageage>Stage Age: 0d</span>
                        </div>
                    </td>

                    <td class="actions" data-label="Actions" data-col="actions">
                        <button type="button" class="btn btn-quickview open-drawer">Quick View</button>
                        <button type="button" class="btn btn-confirm add-production-btn" data-lead-id="@c.ClientUserId" data-lead-name="@($"{c.FirstName} {c.LastName}")">Add Production</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@await Html.PartialAsync("_LeadPipelineView")

</div>

@await Html.PartialAsync("_LeadQuickView")
@await Html.PartialAsync("_LeadQuickViewUtilities")

<style>
    .production-modal-dialog { max-width: 640px; }
    .production-modal-shell {
        background: linear-gradient(180deg, rgba(15,23,42,.98) 0%, rgba(15,23,42,.94) 100%);
        color: #e2e8f0;
        border: 1px solid rgba(148,163,184,.22);
        border-radius: 24px;
        box-shadow: 0 28px 70px rgba(2,6,23,.55);
        overflow: hidden;
    }
    .production-modal-shell .modal-header,
    .production-modal-shell .modal-footer {
        border-color: rgba(148,163,184,.14);
        padding: 1rem 1.25rem;
    }
    .production-modal-shell .modal-body { padding: 1.1rem 1.25rem 1.25rem; }
    .production-modal-title { display: flex; flex-direction: column; gap: .18rem; }
    .production-modal-title h5 { margin: 0; font-size: 1.05rem; font-weight: 700; letter-spacing: .01em; }
    .production-modal-title span { font-size: .78rem; color: #94a3b8; }
    .production-modal-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: .95rem 1rem;
        margin-bottom: 1rem;
        border: 1px solid rgba(96,165,250,.2);
        border-radius: 18px;
        background: linear-gradient(135deg, rgba(30,41,59,.96), rgba(15,23,42,.9));
        box-shadow: inset 0 1px 0 rgba(255,255,255,.04);
    }
    .production-modal-hero-label { font-size: .72rem; text-transform: uppercase; letter-spacing: .12em; color: #93c5fd; }
    .production-modal-hero-name { font-size: 1rem; font-weight: 700; color: #f8fafc; }
    .production-modal-badge {
        padding: .45rem .75rem;
        border-radius: 999px;
        font-size: .73rem;
        font-weight: 700;
        color: #dbeafe;
        background: rgba(59,130,246,.18);
        border: 1px solid rgba(96,165,250,.26);
        white-space: nowrap;
    }
    .production-field-grid { display: grid; gap: .9rem; grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .production-field-grid .production-field-full { grid-column: 1 / -1; }
    .production-field label { display: block; margin-bottom: .38rem; font-size: .78rem; font-weight: 700; color: #cbd5e1; }
    .production-field .form-control,
    .production-field .form-select {
        min-height: 46px;
        border-radius: 14px;
        border: 1px solid rgba(148,163,184,.2);
        background: rgba(15,23,42,.76);
        color: #f8fafc;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.03);
    }
    .production-field textarea.form-control { min-height: 92px; padding-top: .8rem; }
    .production-field .form-control:focus,
    .production-field .form-select:focus {
        border-color: rgba(96,165,250,.65);
        box-shadow: 0 0 0 .2rem rgba(59,130,246,.15);
        background: rgba(15,23,42,.92);
        color: #fff;
    }
    .production-field .form-text { color: #94a3b8 !important; font-size: .75rem; margin-top: .35rem; }
    .production-modal-shell .btn { border-radius: 12px; font-weight: 700; padding: .72rem 1rem; }
    .production-modal-shell .btn-secondary {
        background: rgba(51,65,85,.72);
        border-color: rgba(148,163,184,.18);
        color: #e2e8f0;
    }
    .production-modal-shell .btn-success {
        background: linear-gradient(135deg, #10b981, #059669);
        border-color: transparent;
        box-shadow: 0 12px 28px rgba(16,185,129,.24);
    }
    @@media (max-width: 640px) {
        .production-field-grid { grid-template-columns: 1fr; }
    }
</style>


<div class="modal fade" id="productionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered production-modal-dialog">
        <div class="modal-content production-modal-shell">
            <div class="modal-header">
                <div class="production-modal-title">
                    <h5 class="modal-title">Add Lead Production</h5>
                    <span>Capture one production event with a cleaner, focused workflow.</span>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Production" asp-action="AddLead" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="leadId" id="prodLeadId" />
                <input type="hidden" name="returnUrl" value="@Url.Action("Index","Leads")" />
                <div class="modal-body">
                    <input type="hidden" name="id" />
                    <div class="production-modal-hero">
                        <div>
                            <div class="production-modal-hero-label">Lead</div>
                            <div id="prodLeadName" class="production-modal-hero-name"></div>
                        </div>
                        <div class="production-modal-badge">New Production</div>
                    </div>
                    <div class="production-field-grid">
                        <div class="production-field">
                            <label class="form-label">Amount</label>
                            <input type="number" step="0.01" min="0" class="form-control" name="amount" placeholder="0.00" required />
                        </div>
                        <div class="production-field">
                            <label class="form-label">Status</label>
                            <select class="form-select" name="status">
                                <option value="0">Submitted</option>
                                <option value="1">Issued</option>
                                <option value="2">Paid</option>
                            </select>
                        </div>
                        <div class="production-field production-field-full">
                            <label class="form-label">Personal Revenue</label>
                            <input type="number" step="0.01" min="0" class="form-control" name="personalAmount" placeholder="Optional" />
                            <div class="form-text text-muted">Only add personal revenue when it applies to this production event.</div>
                        </div>
                        <div class="production-field production-field-full">
                            <label class="form-label">Notes</label>
                            <textarea class="form-control" name="notes" rows="2" placeholder="Optional notes"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Production</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/js/legend-modal.js" asp-append-version="true"></script>
<script src="~/js/leads-index.js" asp-append-version="true"></script>
<script src="~/js/zoom-quick-popup.js" asp-append-version="true"></script>
<script>
    (() => {
        const modalEl = document.getElementById('productionModal');
        const nameEl = document.getElementById('prodLeadName');
        const idEl = document.getElementById('prodLeadId');
        const prodModal = modalEl ? new bootstrap.Modal(modalEl) : null;
        document.querySelectorAll('.add-production-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                if (!prodModal) return;
                const leadId = btn.getAttribute('data-lead-id');
                const leadName = btn.getAttribute('data-lead-name');
                idEl.value = leadId ?? '';
                nameEl.textContent = leadName ?? leadId ?? '';
                prodModal.show();
            });
        });

        // Force stacked quick-view layout (no side-by-side columns)
        const bodyEl = document.querySelector(".dbody");
        if (bodyEl){
            bodyEl.classList.remove("grid2");
            localStorage.removeItem('detail-layout');
        }
    })();
</script>
