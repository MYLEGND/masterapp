@model IEnumerable<Domain.Entities.Commitment>
@{
    var leadId = ViewBag.LeadId as string ?? string.Empty;
}

<div class="d-flex justify-content-between align-items-center mb-2 flex-wrap" style="gap:10px;">
    <div>
        <h5 class="mb-0">Commitments</h5>
        <div class="text-muted small">Promises tracked server-side. Actions remain the execution layer.</div>
    </div>
    <button class="btn btn-sm btn-gold" data-bs-toggle="modal" data-bs-target="#addCommitmentModal">Add Commitment</button>
</div>

@if (ViewBag.CommitmentsError != null)
{
    <div class="text-muted" role="status" style="padding:6px 0;">
        @ViewBag.CommitmentsError
    </div>
}
else if (Model == null || !Model.Any())
{
    <div class="text-muted">No commitments yet. Set a promise to keep this lead accountable.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-dark align-middle mb-2 commitments-table">
            <thead>
                <tr>
                    <th scope="col">Promise</th>
                    <th scope="col" style="width:140px;">Due</th>
                    <th scope="col" style="width:120px;">Status</th>
                    <th scope="col" style="width:170px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in Model)
            {
                var isOpen = c.Status == Domain.Enums.CommitmentStatus.Open;
                <tr>
                    <td>@c.PromiseText</td>
                    <td>@c.DueDateUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                    <td>
                        <span class="badge bg-secondary text-uppercase" style="letter-spacing:.04em;">@c.Status</span>
                    </td>
                    <td>
                        <div class="d-flex gap-2 flex-wrap">
                            <button type="button"
                                    class="btn btn-success btn-sm"
                                    data-commitment-action="fulfill"
                                    data-commitment-id="@c.Id"
                                    @(isOpen ? "" : "disabled")>Fulfill</button>
                            <button type="button"
                                    class="btn btn-outline-danger btn-sm"
                                    data-commitment-action="break"
                                    data-commitment-id="@c.Id"
                                    @(isOpen ? "" : "disabled")>Break</button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<!-- Add Commitment Modal -->
<div class="modal fade" id="addCommitmentModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Commitment</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="createCommitmentForm" method="post" action="/Leads/CreateCommitment">
            @Html.AntiForgeryToken()
            <input type="hidden" name="LeadId" value="@leadId" />
            <div class="mb-3">
                <label class="form-label">Promise</label>
                <textarea name="PromiseText" class="form-control" rows="3" required placeholder="e.g. Send needs-analysis summary by Thursday"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Due date &amp; time (local)</label>
                <input type="datetime-local" name="DueDateUtc" class="form-control" required />
                <div class="text-muted small">Stored in UTC. We convert from your local time on save.</div>
            </div>
            <div class="text-end">
                <button type="submit" class="btn btn-primary px-4">Save</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
    .commitments-table{
        width:100%;
        margin:0;
        background-color:#ffffff;
        border:1px solid rgba(15,23,42,.15);
        border-radius:10px;
        overflow:hidden;
        border-collapse: separate;
        border-spacing: 0;
    }
    .commitments-table td,
    .commitments-table th{
        color:#0b1224;
        vertical-align:middle;
        padding:8px 10px;
        border-color:rgba(15,23,42,.12);
    }
    .commitments-table th{
        white-space:nowrap;
        font-size:.74rem;
        letter-spacing:.03em;
        text-transform:uppercase;
        background:#f7f8fb;
    }
    .commitments-table th:first-child,
    .commitments-table td:first-child{
        width:46%;
        white-space:normal;
        word-break:break-word;
    }
    .commitments-table th:last-child,
    .commitments-table td:last-child{
        width:188px;
        min-width:188px;
        white-space:nowrap;
    }
    .commitments-table td .btn{
        padding:4px 10px;
        font-size:12px;
        line-height:1.2;
        border-radius:8px;
        white-space:nowrap;
    }
    #addCommitmentModal{
        background: rgba(0,0,0,0.75);
    }
    #addCommitmentModal .modal-dialog{
        max-width: 640px;
        margin: 0 auto;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        pointer-events: auto;
        background: transparent;
    }
    #addCommitmentModal .modal-content{
        background:#0b1325 !important;
        color:#f8fafc !important;
        border:1px solid #1f2b3d !important;
        border-radius: 12px;
        box-shadow: 0 18px 38px rgba(0,0,0,0.45);
    }
    #addCommitmentModal .modal-header{
        background:#0b1325 !important;
        border-bottom:1px solid #1f2b3d !important;
        padding:12px 16px;
    }
    #addCommitmentModal .modal-body{
        background:#0b1325 !important;
        padding:14px 16px;
    }
    #addCommitmentModal .form-control, #addCommitmentModal textarea{
        background:#0f172a;
        color:#f8fafc;
        border:1px solid #2c3a5a;
    }
    #addCommitmentModal .form-control::placeholder, #addCommitmentModal textarea::placeholder{
        color:#94a3b8;
    }
    #addCommitmentModal .form-label{ color:#f1c76a; font-weight:600; }
    #addCommitmentModal .btn-close{ filter: invert(1); }
</style>
