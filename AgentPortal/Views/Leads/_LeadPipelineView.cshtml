<section class="cards navy-shell" id="cardsView" aria-label="Pipeline CRM workspace">
    <div class="pipeline-head">
        <div class="pipeline-head-top">
            <div>
                <h3 class="pipeline-title">Pipeline Command Center</h3>
                <p class="pipeline-sub">Stage-focused CRM workspace — drag to move, reorder by priority, drop to update instantly.</p>
            </div>
            <div class="pipeline-head-actions">
                <span class="pill" id="pipelineBoardCount">0 active cards</span>
                <button type="button" class="btn btn-ghost" id="btnPipelineRefresh">Refresh</button>
                <button type="button" class="btn btn-ghost" id="btnPipelineAll">All Buckets</button>
                <button type="button" class="btn btn-ghost" id="btnPipelineCallTask">Call Task Mode</button>
            </div>
        </div>
        <div class="pipeline-interact">
            <div class="pipeline-metrics">
                <span class="pill" id="pipelineTotalCards">0 cards</span>
                <span class="pill pill-soft" id="pipelineFocusPill">All buckets</span>
            </div>
            <div class="pipeline-quick">
                <button type="button" class="chip chip-red" id="btnPipeOverdue">🔥 Overdue</button>
                <button type="button" class="chip chip-amber" id="btnPipeNeeds">⏱ Needs Touch</button>
                <button type="button" class="chip chip-violet" id="btnPipeMeetings">📅 Meetings</button>
                <button type="button" class="chip chip-reset" id="btnPipeReset">Reset</button>
            </div>
        </div>
        <div class="pipeline-command-bar" id="pipelineStageNav"></div>
        <div class="pipeline-focus" id="pipelineFocusBar">
            <button type="button" class="btn btn-ghost" id="btnBoardBack">← Back to Full Pipeline</button>
            <div>
                <div class="pipeline-title" id="pipelineFocusTitle">Stage Review</div>
                <div class="pipeline-sub" id="pipelineFocusSub">Review every contact in this bucket, then drag them forward when they are ready.</div>
            </div>
        </div>
    </div>
    <div class="pipeline-board" id="pipelineBoard"></div>
</section>
