@* Views/FactFinder/MiddleAged.cshtml *@
@model AgentPortal.Models.FactFinderViewModel

@{
    ViewData["Title"] = "Middle-Aged Fact Finder";
}

<style>
    :root{
        --navy-900: #0b1529;
        --navy-800: #0f1d38;
        --navy-700: #162445;
        --gold: #a68023;
        --gold-dark:#8f6f1e;
        --ink:#f8fafc;
        --muted: #cbd5e1;
        --line: rgba(166,128,35,.55);
        --bg: var(--navy-900);
        --soft:#0f1d38;
        --card:#0f1d38;
        --input-text: #0b1529;
        --shadow: 0 18px 38px rgba(0,0,0,.32);
        --radius: 18px;
    }

    body { background-color: var(--bg); color: var(--ink); }

    .ff-shell{
        max-width: 980px; /* full-screen feel, but readable */
        width: 100%;
        margin: 0 auto;
        padding: 0 14px 30px 14px;
    }

    .success-message{
        background: #e9f7ef;
        border: 1px solid #bfe5cf;
        color: #135b2c;
        padding: 12px 14px;
        border-radius: 12px;
        margin-top: 14px;
        font-weight: 800;
    }

    .ff-title{
        margin-top: 18px;
        margin-bottom: 8px;
        text-align:center;
    }

    .ff-title h1{
        font-weight: 950;
        font-size: clamp(2.0rem, 3.2vw, 2.6rem);
        color: var(--ink);
        letter-spacing: .5px;
        margin: 0;
    }

    .required-note{
        text-align:center;
        color: var(--muted);
        margin: 0 0 14px 0;
    }

    .req{ color:#dc3545; font-weight: 900; margin-left: 2px; }

    /* Progress */
    .ff-progress-wrap{
        background: var(--soft);
        border: 1.5px solid var(--gold);
        border-radius: var(--radius);
        padding: 12px 14px;
        box-shadow: var(--shadow);
        margin-bottom: 14px;
        color: var(--ink);
    }

    .ff-progress-top{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 12px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .ff-step-pill{
        background: var(--navy-900);
        border: 1.2px solid var(--gold);
        border-radius: 999px;
        padding: 6px 10px;
        font-weight: 950;
        color: var(--ink);
        font-size: .9rem;
        white-space: nowrap;
    }

    .ff-progress{
        height: 10px;
        border-radius: 999px;
        background: var(--navy-700);
        overflow:hidden;
        border: 1px solid var(--gold);
    }

    #ffProgressBarMiddle{
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, var(--gold), var(--gold-dark));
        border-radius: 999px;
        transition: width .25s ease;
    }

    /* Steps */
    .wizard-step{ display:none; }
    .wizard-step.active{ display:block; }

    /* Cards */
    .section-card{
        background: #fff;
        border: 1.6px solid var(--gold);
        border-radius: var(--radius);
        padding: 16px 16px;
        box-shadow: var(--shadow);
        margin-bottom: 14px;
        color: var(--navy-900);
    }

    .section-title{
        font-weight: 950;
        color: var(--navy-900);
        font-size: 1.15rem;
        margin-bottom: 4px;
    }

    .subtle{
        color: var(--navy-900);
        font-weight: 700;
        margin-bottom: 12px;
    }

    /* Grid wrappers (your markup uses "grid two")
       FIX: default to stacked vertical for better fitting + hierarchy */
    .grid.two{
        display:grid;
        grid-template-columns: 1fr; /* STACKED */
        gap: 14px;
        align-items: start;
    }

    /* Optional: if you ever want side-by-side later, add class "two-cols" to markup */
    .grid.two.two-cols{
        grid-template-columns: 1fr 1fr;
    }

    @@media (max-width: 980px){
        .grid.two.two-cols{ grid-template-columns: 1fr; }
    }

    .stack{
        display:flex;
        flex-direction: column;
        gap: 14px;
    }

    .block{
        background: var(--navy-800);
        border: 1.2px solid var(--gold);
        border-radius: 16px;
        padding: 14px;
        color: var(--ink);
    }

    .block-title{
        font-weight: 950;
        color: var(--ink);
        font-size: 1.05rem;
        margin-bottom: 10px;
        letter-spacing: .2px;
    }

    .mini-title{
        font-weight: 950;
        color: var(--ink);
        margin-top: 12px;
        margin-bottom: 8px;
        opacity: .92;
    }

    .block label,
    .block .field label,
    .block .block-title,
    .block .mini-title,
    .block .subtle{
        color: #fff !important;
    }

    /* Rows */
    .row.two{
        display:grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 10px;
    }

    .row.three{
        display:grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-bottom: 10px;
    }

    .row.four{
        display:grid;
        grid-template-columns: 1fr 1fr 1fr 1fr;
        gap: 12px;
        margin-bottom: 10px;
    }

    .row.five{
        display:grid;
        grid-template-columns: 1.1fr .9fr .6fr .9fr 1.1fr;
        gap: 10px;
        margin-bottom: 10px;
    }

    @@media (max-width: 980px){
        .grid.two{ grid-template-columns: 1fr; }
        .row.two, .row.three, .row.four, .row.five{ grid-template-columns: 1fr; }
    }

    .field label{
        display:block;
        font-weight: 900;
        color: var(--navy-900);
        margin-bottom: 6px;
        font-size: .92rem;
    }

    /* White container text clarity */
    .section-card .field label,
    .section-card .section-title,
    .section-card .subtle,
    .section-card .table-like label{
        color: var(--navy-900) !important;
    }

.table-like{
    background:#fff;
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 14px;
    padding: 10px;
    margin-bottom: 10px;
    position: relative;
    color: var(--navy-900);
}

/* Force white text inside navy blocks */
.block label,
.block .field label,
.block .block-title,
.block .mini-title,
.block .subtle{
    color: #fff !important;
}

.block .table-like label,
.block .table-like .field label{
    color: var(--navy-900) !important;
}

.ack-text{
    color: var(--navy-900) !important;
}

    /* GOLD INPUTS */
    input.form-control,
    textarea.form-control,
    select.form-select{
        border: 1.6px solid var(--gold) !important;
        border-radius: 12px !important;
        padding: 10px 12px !important;
        background: #fff !important;
        color: var(--input-text) !important;
        font-weight: 700;
        box-shadow: none !important;
        outline: none !important;
    }

    input.form-control:focus,
    textarea.form-control:focus,
    select.form-select:focus{
        border-color: var(--gold) !important;
        box-shadow: 0 0 0 .22rem rgba(166,128,35,.25) !important;
    }

    textarea.form-control{ resize: vertical; }

    .checkline{
        display:flex;
        align-items:center;
        gap: 10px;
        background: var(--navy-800);
        border: 1.2px solid var(--gold);
        border-radius: 12px;
        padding: 10px 12px;
        margin-bottom: 10px;
        font-weight: 800;
        color: var(--ink);
    }

    .checkline input[type="checkbox"]{
        width: 18px;
        height: 18px;
        accent-color: var(--gold);
    }

    /* Table-like rows */
    .table-like{
        background:#fff;
        border: 1px solid rgba(0,0,0,.06);
        border-radius: 14px;
        padding: 10px;
        margin-bottom: 10px;
        position: relative;
    }

    /* Buttons */
    .wizard-actions{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 12px;
        margin-top: 12px;
        flex-wrap: wrap;
    }

    .btn{
        border-radius: 999px !important;
        font-weight: 950 !important;
        letter-spacing: .2px;
        padding: 10px 16px !important;
    }

    .btn-gold{
        background: linear-gradient(180deg, var(--gold), var(--gold-dark)) !important;
        border: 1px solid rgba(0,0,0,.06) !important;
        color: #fff !important;
        box-shadow: 0 12px 26px rgba(166,128,35,.25);
    }

    .btn-gold:hover{ filter: brightness(1.02); }

    .btn-ghost{
        background: var(--navy-900) !important;
        border: 2px solid var(--gold) !important;
        color: #fff !important;
    }

    .btn-ghost:hover{
        border-color: var(--gold) !important;
        filter: brightness(1.05);
        box-shadow: 0 10px 20px rgba(0,0,0,.2);
    }

    /* ============================
       VALIDATION HELPER (Agent UX)
    ============================ */
    .ff-error-summary{
        background: #fff3cd;
        border: 1px solid rgba(166,128,35,.45);
        color: #664d03;
        padding: 12px 14px;
        border-radius: 14px;
        margin: 12px 0 14px 0;
        font-weight: 900;
        box-shadow: var(--shadow);
    }

    .ff-error-summary .title{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 10px;
        margin-bottom: 8px;
    }

    .ff-error-summary .count{
        background:#fff;
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 999px;
        padding: 4px 10px;
        font-weight: 950;
    }

    .ff-error-summary ul{
        margin: 0;
        padding-left: 18px;
        font-weight: 800;
    }

    .ff-error-summary li{
        margin: 6px 0;
    }

    .ff-error-summary a{
        color: #664d03;
        text-decoration: underline;
        font-weight: 950;
    }

    .ff-field-invalid input.form-control,
    .ff-field-invalid textarea.form-control,
    .ff-field-invalid select.form-select{
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 .22rem rgba(220,53,69,.18) !important;
    }

    .ff-fix-tag{
        display:inline-flex;
        align-items:center;
        gap: 6px;
        margin-top: 6px;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(220,53,69,.10);
        border: 1px solid rgba(220,53,69,.35);
        color: #b02a37;
        font-weight: 950;
        font-size: .82rem;
        letter-spacing: .1px;
    }

    /* optional tiny pulse so it's obvious */
    @@keyframes ffPulse {
        0%   { transform: scale(1); }
        50%  { transform: scale(1.01); }
        100% { transform: scale(1); }
    }
    .ff-field-invalid{ animation: ffPulse .22s ease-in-out; }

    /* Repeater header row (Add button lives right on the card) */
    .repeater-head{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 10px;
        margin-top: 6px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    /* ===========
       REPEATER CTA BAR
       - Buttons live INSIDE each table-like card, bottom-left
    =========== */
    .repeater-actions{
        display:flex;
        align-items:center;
        justify-content:flex-start;
        gap: 10px;
        margin-top: 10px;
        padding-top: 10px;
        border-top: 1px solid rgba(0,0,0,.08);
    }

    .btn-delete-row{
        position: static;
        border-radius: 999px !important;
        font-weight: 950 !important;
        padding: 8px 12px !important;
    }

    .repeater-actions .btn{
        padding: 8px 12px !important;
    }
</style>

<div class="ff-shell">

    @if (ViewBag.Success != null)
    {
        <div class="success-message">@ViewBag.Success</div>
    }

    <div class="ff-title">
        <h1>Fact Finder - Middle-Aged (35-61)</h1>
    </div>

    <p class="required-note">
        <strong><span class="text-danger">*</span> Fields marked with a red asterisk are required.</strong>
    </p>

    <div class="ff-progress-wrap">
        <div class="ff-progress-top">
            <div class="ff-step-pill">
                Step <span id="ffStepNowMiddle">1</span> of <span id="ffStepTotalMiddle">6</span>
            </div>
            <div style="font-weight:900; color:var(--muted); font-size:.95rem;" id="ffStepLabelMiddle">
                Values + Concerns
            </div>
        </div>
        <div class="ff-progress"><div id="ffProgressBarMiddle"></div></div>
    </div>

    <div id="ffErrorSummaryMiddle"></div>

    <div id="ffMiddleApp">
        <form id="factFinderFormMiddle" method="post" asp-action="Submit" asp-controller="FactFinder" novalidate>
            @Html.AntiForgeryToken()

            @* CRITICAL: tells controller which section was submitted *@
            <input type="hidden" asp-for="FormType" value="Middle" />

            <!-- =========================================================
                 STEP 1 — VALUES + CONCERNS (BREAK DOWN GUARDS FIRST)
            ========================================================== -->
            <section class="wizard-step active" data-step="1" data-label="Values + Concerns">

                <div class="section-card">
                    <div class="section-title">Part 1 — Values, Direction & Real Concerns</div>
                    <div class="subtle">Before money, we get truth. What matters, what’s heavy, and what “winning” looks like.</div>

                    <div class="grid two">

                        <!-- Identity (Required) -->
                        <div class="block">
                            <div class="block-title">Identity (Start Here)</div>

                            <div class="row two">
                                <div class="field">
                                    <label>Applicant Name<span class="req">*</span></label>
                                    <input asp-for="Middle.Applicant.Name" class="form-control" placeholder="Applicant Name*" required />
                                    <span asp-validation-for="Middle.Applicant.Name" class="text-danger"></span>
                                </div>
                                <div class="field">
                                    <label>Date of Birth<span class="req">*</span></label>
                                    <input asp-for="Middle.Applicant.DOB" type="date" class="form-control" required />
                                    <span asp-validation-for="Middle.Applicant.DOB" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="mini-title">Contact (Optional)</div>
                            <div class="row two">
                                <div class="field">
                                    <label>Email</label>
                                    <input asp-for="Middle.Applicant.Email" type="email" class="form-control" placeholder="Email" />
                                </div>
                                <div class="field">
                                    <label>Phone No.</label>
                                    <input asp-for="Middle.Applicant.Phone" type="tel" class="form-control" placeholder="Phone" />
                                </div>
                            </div>

                            <div class="mini-title">Spouse / Partner (Optional)</div>
                            <div class="row two">
                                <div class="field">
                                    <label>Spouse Name</label>
                                    <input asp-for="Middle.Spouse.Name" class="form-control" placeholder="Spouse Name" />
                                </div>
                                <div class="field">
                                    <label>Date of Birth</label>
                                    <input asp-for="Middle.Spouse.DOB" type="date" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <!-- Concerns + Family context -->
                        <div class="block">
                            <div class="block-title">What Matters + What’s Heavy</div>

                            <div class="field">
                                <label>34) What does “winning” look like for your family in 10–15 years?</label>
                                <textarea asp-for="Middle.Direction.WinningDefinition" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="field">
                                <label>35) What are you most afraid of financially if nothing changes?</label>
                                <textarea asp-for="Middle.Direction.BiggestFearIfNoChange" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="field">
                                <label>36) If you could change one thing starting today, what would it be?</label>
                                <textarea asp-for="Middle.Direction.ChangeOneThing" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="mini-title">Children / Dependents</div>

                            @{
                                var depCount = Model.Middle?.Dependents?.Count ?? 0;
                                var depRender = Math.Max(1, depCount);
                            }
                            <div id="depListMiddle">
                                @for (int i = 0; i < depRender; i++)
                                {
                                    var dep = (Model.Middle?.Dependents != null && Model.Middle.Dependents.Count > i)
                                        ? Model.Middle.Dependents[i]
                                        : null;

                                    <div class="table-like repeater-item">
                                        <div class="row four">
                                            <div class="field">
                                                <label>Name</label>
                                                <input name="Middle.Dependents[@i].Name" value="@(dep?.Name ?? "")" class="form-control" placeholder="Name" />
                                            </div>
                                            <div class="field">
                                                <label>Age</label>
                                                <input name="Middle.Dependents[@i].Age" value="@(dep?.Age?.ToString() ?? "")" type="number" class="form-control" placeholder="Age" />
                                            </div>
                                            <div class="field">
                                                <label>Relationship</label>
                                                <input name="Middle.Dependents[@i].Relationship" value="@(dep?.Relationship ?? "")" class="form-control" placeholder="Child / Other" />
                                            </div>
                                            <div class="field">
                                                <label>Any special needs / ongoing care?</label>
                                                <input name="Middle.Dependents[@i].SpecialNeeds" value="@(dep?.SpecialNeeds ?? "")" class="form-control" placeholder="Yes/No/Describe" />
                                            </div>
                                        </div>

                                        <div class="repeater-actions">
                                            <button type="button" class="btn btn-gold"
                                                    data-repeater-add="depListMiddle"
                                                    data-template="tplMiddleDependents">+ Add Dependent</button>
                                            <button type="button" class="btn btn-danger btn-delete-row" data-repeater-del title="Delete">Delete</button>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="mini-title">Family Responsibilities</div>
                            <div class="field">
                                <label>Are you financially supporting anyone outside your household?</label>
                                <textarea asp-for="Middle.FamilySupportOutsideHousehold" class="form-control" style="min-height:82px;"></textarea>
                            </div>

                            <div class="mini-title">Emergency Contact</div>
                            <div class="row three">
                                <div class="field">
                                    <label>Name</label>
                                    <input asp-for="Middle.EmergencyContact.Name" class="form-control" placeholder="Name" />
                                </div>
                                <div class="field">
                                    <label>Phone No.</label>
                                    <input asp-for="Middle.EmergencyContact.Phone" type="tel" class="form-control" placeholder="Phone" />
                                </div>
                                <div class="field">
                                    <label>Email</label>
                                    <input asp-for="Middle.EmergencyContact.Email" type="email" class="form-control" placeholder="Email" />
                                </div>
                            </div>

                            <div class="mini-title">Appointment (Agent Use)</div>
                            <div class="row three">
                                <div class="field">
                                    <label>Source of Visit</label>
                                    <input asp-for="Middle.SourceOfVisit" class="form-control" placeholder="Referral / Event / Online / Other" />
                                </div>
                                <div class="field">
                                    <label>Agent(s)</label>
                                    <input asp-for="Middle.Agents" class="form-control" placeholder="Agent name(s)" />
                                </div>
                                <div class="field">
                                    <label>Date of Appointment</label>
                                    <input asp-for="Middle.DateOfAppointment" type="date" class="form-control" />
                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="wizard-actions">
                        <div></div>
                        <button type="button" class="btn btn-gold" data-next>Next</button>
                    </div>
                </div>
            </section>

            <!-- =========================================================
                 STEP 2 — HOUSEHOLD + CAREER + BENEFITS (STILL HUMAN FIRST)
            ========================================================== -->
            <section class="wizard-step" data-step="2" data-label="Household + Career">

                <div class="section-card">
                    <div class="section-title">Part 2 — Household, Career & Benefits</div>
                    <div class="subtle">We learn how life is built: income structure, stability, and what could disrupt the plan.</div>

                    <div class="grid two">

                        <!-- Applicant career -->
                        <div class="block">
                            <div class="block-title">Applicant — Work & Stability</div>

                            <div class="row three">
                                <div class="field">
                                    <label>Occupation / Role</label>
                                    <input asp-for="Middle.Applicant.Occupation" class="form-control" placeholder="Job title / role" />
                                </div>
                                <div class="field">
                                    <label>Employer / Company</label>
                                    <input asp-for="Middle.Applicant.Employer" class="form-control" placeholder="Employer / business name" />
                                </div>
                                <div class="field">
                                    <label>Years in current role</label>
                                    <input asp-for="Middle.Applicant.YearsInRole" type="number" class="form-control" placeholder="Years" />
                                </div>
                            </div>

                            <div class="mini-title">Work + Income Structure</div>

                            <div class="row three">
                                <div class="field">
                                    <label>Income Type</label>
                                    <select asp-for="Middle.Applicant.IncomeType" class="form-select">
                                        <option value="">Select</option>
                                        <option>Salary</option>
                                        <option>Hourly</option>
                                        <option>Commission</option>
                                        <option>Business Owner</option>
                                        <option>Mixed</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label>Annual Income (Approx.)</label>
                                    <input asp-for="Middle.Applicant.AnnualIncome" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                </div>
                                <div class="field">
                                    <label>Income Trend (last 3 years)</label>
                                    <select asp-for="Middle.Applicant.IncomeTrend" class="form-select">
                                        <option value="">Select</option>
                                        <option>Increasing</option>
                                        <option>Flat</option>
                                        <option>Unpredictable</option>
                                        <option>Declining</option>
                                    </select>
                                </div>
                            </div>

                            <div class="field">
                                <label>What are the biggest threats to your income in the next 5 years?</label>
                                <textarea asp-for="Middle.Applicant.IncomeThreats" class="form-control" style="min-height:92px;"></textarea>
                            </div>
                        </div>

                        <!-- Benefits -->
                        <div class="block">
                            <div class="block-title">Employer Benefits Snapshot</div>

                            <div class="row two">
                                <div class="checkline">
                                    <input asp-for="Middle.ApplicantBenefits.Health" type="checkbox" id="midAppBenHealth" />
                                    <label for="midAppBenHealth">Health</label>
                                </div>
                                <div class="checkline">
                                    <input asp-for="Middle.ApplicantBenefits.Dental" type="checkbox" id="midAppBenDental" />
                                    <label for="midAppBenDental">Dental</label>
                                </div>
                                <div class="checkline">
                                    <input asp-for="Middle.ApplicantBenefits.Vision" type="checkbox" id="midAppBenVision" />
                                    <label for="midAppBenVision">Vision</label>
                                </div>
                                <div class="checkline">
                                    <input asp-for="Middle.ApplicantBenefits.HSA" type="checkbox" id="midAppBenHsa" />
                                    <label for="midAppBenHsa">HSA</label>
                                </div>
                                <div class="checkline">
                                    <input asp-for="Middle.ApplicantBenefits.FSA" type="checkbox" id="midAppBenFsa" />
                                    <label for="midAppBenFsa">FSA</label>
                                </div>
                                <div class="checkline">
                                    <input asp-for="Middle.ApplicantBenefits.GroupLife" type="checkbox" id="midAppBenGroupLife" />
                                    <label for="midAppBenGroupLife">Group Life</label>
                                </div>
                                <div class="checkline">
                                    <input asp-for="Middle.ApplicantBenefits.GroupDI" type="checkbox" id="midAppBenGroupDi" />
                                    <label for="midAppBenGroupDi">Group Disability</label>
                                </div>
                                <div class="checkline">
                                    <input asp-for="Middle.ApplicantBenefits.RetirementPlan" type="checkbox" id="midAppBenRet" />
                                    <label for="midAppBenRet">401(k)/403(b)/Retirement Plan</label>
                                </div>
                            </div>

                            <div class="row three">
                                <div class="field">
                                    <label>Retirement Plan Match (if any)</label>
                                    <input asp-for="Middle.ApplicantBenefits.RetMatch" class="form-control" placeholder="Example: 4% match" />
                                </div>
                                <div class="field">
                                    <label>Vesting Schedule (if applicable)</label>
                                    <input asp-for="Middle.ApplicantBenefits.Vesting" class="form-control" placeholder="Example: 3 years cliff" />
                                </div>
                                <div class="field">
                                    <label>Other Employer Benefits</label>
                                    <input asp-for="Middle.ApplicantBenefits.Other" class="form-control" placeholder="Describe" />
                                </div>
                            </div>

                            <div class="mini-title">Quick Pressure Check</div>
                            <div class="field">
                                <label>20) Biggest frustration with finances right now?</label>
                                <textarea asp-for="Middle.Cashflow.BiggestFrustration" class="form-control" style="min-height:84px;"></textarea>
                            </div>
                        </div>

                    </div>

                    <div class="wizard-actions">
                        <button type="button" class="btn btn-ghost" data-prev>Back</button>
                        <button type="button" class="btn btn-gold" data-next>Next</button>
                    </div>
                </div>
            </section>

            <!-- =========================================================
                 STEP 3 — HEALTH COVERAGE + RISKS
            ========================================================== -->
            <section class="wizard-step" data-step="3" data-label="Health + Coverage">

                <div class="section-card">
                    <div class="section-title">Part 3 — Health Coverage, Health Risks & Medical Exposure</div>
                    <div class="subtle">Current plan quality, gaps, and risk exposure.</div>

                    <div class="grid two">

                        <!-- Coverage -->
                        <div class="block">
                            <div class="block-title">Health Coverage Snapshot</div>

                            <div class="field">
                                <label>1) What coverage do you currently have?</label>
                                <textarea asp-for="Middle.Health.CurrentCoverageSummary" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="row three">
                                <div class="field">
                                    <label>Carrier / Company</label>
                                    <input asp-for="Middle.Health.Carrier" class="form-control" />
                                </div>
                                <div class="field">
                                    <label>Monthly Premium (Approx.)</label>
                                    <input asp-for="Middle.Health.Premium" type="number" step="0.01" class="form-control" />
                                </div>
                                <div class="field">
                                    <label>Deductible (Individual / Family)</label>
                                    <input asp-for="Middle.Health.Deductible" class="form-control" placeholder="Example: 2,000 / 4,000" />
                                </div>
                            </div>

                            <div class="row two">
                                <div class="field">
                                    <label>Out-of-Pocket Max (Individual / Family)</label>
                                    <input asp-for="Middle.Health.OOPMax" class="form-control" placeholder="Example: 6,500 / 13,000" />
                                </div>
                                <div class="field">
                                    <label>Do you have an HSA? Balance?</label>
                                    <input asp-for="Middle.Health.HSABalance" class="form-control" placeholder="Yes/No + amount" />
                                </div>
                            </div>

                            <div class="field">
                                <label>2) When was the last time you reviewed your plan?</label>
                                <textarea asp-for="Middle.Health.LastReviewNotes" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="field">
                                <label>3) Have medical bills ever surprised you?</label>
                                <textarea asp-for="Middle.Health.MedicalBillsSurprises" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="mini-title">Optional Coverage / Gap Fillers</div>
                            <div class="row two">
                                <div class="checkline"><input asp-for="Middle.Health.Additional.CriticalIllness" type="checkbox" id="midHealthCI" /><label for="midHealthCI">Critical Illness</label></div>
                                <div class="checkline"><input asp-for="Middle.Health.Additional.Accident" type="checkbox" id="midHealthAcc" /><label for="midHealthAcc">Accident</label></div>
                                <div class="checkline"><input asp-for="Middle.Health.Additional.HospitalIndemnity" type="checkbox" id="midHealthHosp" /><label for="midHealthHosp">Hospital Indemnity</label></div>
                                <div class="checkline"><input asp-for="Middle.Health.Additional.ShortTermDI" type="checkbox" id="midHealthStd" /><label for="midHealthStd">Short-Term Disability</label></div>
                                <div class="checkline"><input asp-for="Middle.Health.Additional.LongTermDI" type="checkbox" id="midHealthLtd" /><label for="midHealthLtd">Long-Term Disability</label></div>
                                <div class="field">
                                    <label>Other</label>
                                    <input asp-for="Middle.Health.Additional.Other" class="form-control" placeholder="Other coverage" />
                                </div>
                            </div>
                        </div>

                        <!-- Risk -->
                        <div class="block">
                            <div class="block-title">Health Risk & Family History</div>

                            <div class="field">
                                <label>4) How would you describe your health in the last three years?</label>
                                <textarea asp-for="Middle.Health.HealthLastThreeYears" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="field">
                                <label>5) Current medications (if any)</label>
                                <textarea asp-for="Middle.Health.CurrentMeds" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="row two">
                                <div class="field">
                                    <label>6) Any major diagnoses in the last 10 years?</label>
                                    <textarea asp-for="Middle.Health.MajorDiagnoses" class="form-control" style="min-height:84px;"></textarea>
                                </div>
                                <div class="field">
                                    <label>7) Any surgeries / hospitalizations in the last 10 years?</label>
                                    <textarea asp-for="Middle.Health.SurgeriesHosp" class="form-control" style="min-height:84px;"></textarea>
                                </div>
                            </div>

                            <div class="field">
                                <label>8) Family history of major illness?</label>
                                <textarea asp-for="Middle.Health.FamilyHistory" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="field">
                                <label>9) If a health event happened this year, how would it impact your income and responsibilities?</label>
                                <textarea asp-for="Middle.Health.HealthEventImpact" class="form-control" style="min-height:84px;"></textarea>
                            </div>
                        </div>

                    </div>

                    <div class="wizard-actions">
                        <button type="button" class="btn btn-ghost" data-prev>Back</button>
                        <button type="button" class="btn btn-gold" data-next>Next</button>
                    </div>
                </div>
            </section>

            <!-- =========================================================
                 STEP 4 — PROTECTION
            ========================================================== -->
            <section class="wizard-step" data-step="4" data-label="Protection Planning">

                <div class="section-card">
                    <div class="section-title">Part 4 — Protection Planning (Life, Disability, Liability)</div>
                    <div class="subtle">We inventory everything. Blind spots cost families.</div>

                    <div class="grid two">

                        <!-- Life -->
                        <div class="block">
                            <div class="block-title">Life Insurance Inventory</div>

                            <div class="field">
                                <label>10) Purpose of your life insurance right now?</label>
                                <textarea asp-for="Middle.Life.PrimaryPurpose" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="mini-title">Applicant Policies</div>
                            <div class="subtle">Starts with one policy. Add only if needed.</div>

                            @{
                                var laCount = Model.Middle?.Life?.Applicant?.Count ?? 0;
                                var laRender = Math.Max(1, laCount);
                            }
                            <div id="lifeApplicantListMiddle">
                                @for (int i = 0; i < laRender; i++)
                                {
                                    var p = (Model.Middle?.Life?.Applicant != null && Model.Middle.Life.Applicant.Count > i)
                                        ? Model.Middle.Life.Applicant[i]
                                        : null;

                                    <div class="table-like repeater-item">

                                        <div class="mini-title" style="margin-top:0;">Policy @(i + 1)</div>

                                        <div class="row three">
                                            <div class="field"><label>Type</label><input name="Middle.Life.Applicant[@i].Type" value="@(p?.Type ?? "")" class="form-control" placeholder="Term / Whole / UL / IUL / Variable / Group" /></div>
                                            <div class="field"><label>Company</label><input name="Middle.Life.Applicant[@i].Company" value="@(p?.Company ?? "")" class="form-control" /></div>
                                            <div class="field"><label>Face Amount</label><input name="Middle.Life.Applicant[@i].Face" value="@(p?.Face?.ToString() ?? "")" type="number" step="0.01" class="form-control" /></div>
                                        </div>

                                        <div class="row three">
                                            <div class="field"><label>Monthly Premium</label><input name="Middle.Life.Applicant[@i].Premium" value="@(p?.Premium?.ToString() ?? "")" type="number" step="0.01" class="form-control" /></div>
                                            <div class="field"><label>Duration</label><input name="Middle.Life.Applicant[@i].Duration" value="@(p?.Duration ?? "")" class="form-control" placeholder="10/20/30 yrs or permanent" /></div>
                                            <div class="field"><label>Beneficiary</label><input name="Middle.Life.Applicant[@i].Beneficiary" value="@(p?.Beneficiary ?? "")" class="form-control" /></div>
                                        </div>

                                        <div class="row two">
                                            <div class="field"><label>Cash Value (if any)</label><input name="Middle.Life.Applicant[@i].CashValue" value="@(p?.CashValue?.ToString() ?? "")" type="number" step="0.01" class="form-control" /></div>
                                            <div class="field"><label>Convertible? / Riders?</label><input name="Middle.Life.Applicant[@i].Riders" value="@(p?.Riders ?? "")" class="form-control" placeholder="Conversion, waiver, child rider, etc." /></div>
                                        </div>

                                        <div class="repeater-actions">
                                            <button type="button" class="btn btn-gold"
                                                    data-repeater-add="lifeApplicantListMiddle"
                                                    data-template="tplMiddleLifeApplicant">+ Add Policy</button>
                                            <button type="button" class="btn btn-danger btn-delete-row" data-repeater-del title="Delete">Delete</button>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="mini-title">Spouse Policies</div>
                            <div class="subtle">Starts with one policy. Add only if needed.</div>
                            @{
                                var lsCount = Model.Middle?.Life?.Spouse?.Count ?? 0;
                                var lsRender = Math.Max(1, lsCount);
                            }
                            <div id="lifeSpouseListMiddle">
                                @for (int i = 0; i < lsRender; i++)
                                {
                                    var p = (Model.Middle?.Life?.Spouse != null && Model.Middle.Life.Spouse.Count > i)
                                        ? Model.Middle.Life.Spouse[i]
                                        : null;

                                    <div class="table-like repeater-item">

                                        <div class="mini-title" style="margin-top:0;">Policy @(i + 1)</div>

                                        <div class="row three">
                                            <div class="field"><label>Type</label><input name="Middle.Life.Spouse[@i].Type" value="@(p?.Type ?? "")" class="form-control" placeholder="Term / Whole / UL / IUL / Variable / Group" /></div>
                                            <div class="field"><label>Company</label><input name="Middle.Life.Spouse[@i].Company" value="@(p?.Company ?? "")" class="form-control" /></div>
                                            <div class="field"><label>Face Amount</label><input name="Middle.Life.Spouse[@i].Face" value="@(p?.Face?.ToString() ?? "")" type="number" step="0.01" class="form-control" /></div>
                                        </div>

                                        <div class="row three">
                                            <div class="field"><label>Monthly Premium</label><input name="Middle.Life.Spouse[@i].Premium" value="@(p?.Premium?.ToString() ?? "")" type="number" step="0.01" class="form-control" /></div>
                                            <div class="field"><label>Duration</label><input name="Middle.Life.Spouse[@i].Duration" value="@(p?.Duration ?? "")" class="form-control" placeholder="10/20/30 yrs or permanent" /></div>
                                            <div class="field"><label>Beneficiary</label><input name="Middle.Life.Spouse[@i].Beneficiary" value="@(p?.Beneficiary ?? "")" class="form-control" /></div>
                                        </div>

                                        <div class="row two">
                                            <div class="field"><label>Cash Value (if any)</label><input name="Middle.Life.Spouse[@i].CashValue" value="@(p?.CashValue?.ToString() ?? "")" type="number" step="0.01" class="form-control" /></div>
                                            <div class="field"><label>Convertible? / Riders?</label><input name="Middle.Life.Spouse[@i].Riders" value="@(p?.Riders ?? "")" class="form-control" placeholder="Conversion, waiver, child rider, etc." /></div>
                                        </div>

                                        <div class="repeater-actions">
                                            <button type="button" class="btn btn-gold"
                                                    data-repeater-add="lifeSpouseListMiddle"
                                                    data-template="tplMiddleLifeSpouse">+ Add Policy</button>
                                            <button type="button" class="btn btn-danger btn-delete-row" data-repeater-del title="Delete">Delete</button>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="field">
                                <label>11) When was your life insurance last reviewed?</label>
                                <input asp-for="Middle.Life.LastReview" class="form-control" placeholder="MM/YYYY or notes" />
                            </div>

                            <div class="field">
                                <label>12) If you passed away this year, what would financially break first?</label>
                                <textarea asp-for="Middle.Life.WhatBreaksFirst" class="form-control" style="min-height:84px;"></textarea>
                            </div>
                        </div>

                        <!-- DI + Liability -->
                        <div class="block">
                            <div class="block-title">Disability + Liability + Major Risks</div>

                            <div class="field">
                                <label>13) If you couldn’t work for 6–12 months, what happens financially?</label>
                                <textarea asp-for="Middle.DI.IfCannotWorkImpact" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="mini-title">Disability Coverage</div>
                            <div class="row two">
                                <div class="field">
                                    <label>Do you have DI through work?</label>
                                    <input asp-for="Middle.DI.GroupDI" class="form-control" placeholder="Yes/No + details" />
                                </div>
                                <div class="field">
                                    <label>Do you have personal DI?</label>
                                    <input asp-for="Middle.DI.IndividualDI" class="form-control" placeholder="Yes/No + details" />
                                </div>
                            </div>

                            <div class="row three">
                                <div class="field">
                                    <label>Benefit Amount / Month</label>
                                    <input asp-for="Middle.DI.BenefitAmount" class="form-control" placeholder="$ / month" />
                                </div>
                                <div class="field">
                                    <label>Elimination Period</label>
                                    <input asp-for="Middle.DI.Elimination" class="form-control" placeholder="30/60/90 days" />
                                </div>
                                <div class="field">
                                    <label>Benefit Period</label>
                                    <input asp-for="Middle.DI.BenefitPeriod" class="form-control" placeholder="2/5/To 65/To 67" />
                                </div>
                            </div>

                            <div class="field">
                                <label>14) How long would your emergency fund cover you?</label>
                                <input asp-for="Middle.DI.EmergencyFundMonths" class="form-control" placeholder="Example: 3 months" />
                            </div>

                            <div class="mini-title">Liability / Big Risk Events</div>
                            <div class="field">
                                <label>15) Do you have umbrella liability coverage? How much?</label>
                                <input asp-for="Middle.Liability.Umbrella" class="form-control" placeholder="Yes/No + amount" />
                            </div>

                            <div class="field">
                                <label>16) Any major exposures?</label>
                                <textarea asp-for="Middle.Liability.Exposures" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="field">
                                <label>17) Any claim, lawsuit, major accident, or insurance cancellation?</label>
                                <textarea asp-for="Middle.Liability.ClaimsHistory" class="form-control" style="min-height:84px;"></textarea>
                            </div>
                        </div>

                    </div>

                    <div class="wizard-actions">
                        <button type="button" class="btn btn-ghost" data-prev>Back</button>
                        <button type="button" class="btn btn-gold" data-next>Next</button>
                    </div>
                </div>
            </section>

            <!-- =========================================================
                 STEP 5 — CASH FLOW + DEBT
            ========================================================== -->
            <section class="wizard-step" data-step="5" data-label="Cash Flow + Debt">

                <div class="section-card">
                    <div class="section-title">Part 5 — Cash Flow, Debts, Leaks & Stress Points</div>
                    <div class="subtle">Now we touch the numbers — after trust is built.</div>

                    <div class="grid two">

                        <!-- Cash Flow -->
                        <div class="block">
                            <div class="block-title">Cash Flow & Monthly Structure</div>

                            <div class="row three">
                                <div class="field">
                                    <label>Monthly Household Income (Net)</label>
                                    <input asp-for="Middle.Cashflow.NetIncome" type="number" step="0.01" class="form-control" />
                                </div>
                                <div class="field">
                                    <label>Monthly Core Expenses</label>
                                    <input asp-for="Middle.Cashflow.CoreExpenses" type="number" step="0.01" class="form-control" />
                                </div>
                                <div class="field">
                                    <label>Monthly Savings / Investing</label>
                                    <input asp-for="Middle.Cashflow.Savings" type="number" step="0.01" class="form-control" />
                                </div>
                            </div>

                            <div class="field">
                                <label>18) Where does money leak the most each month?</label>
                                <textarea asp-for="Middle.Cashflow.Leaks" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                            <div class="field">
                                <label>19) Do you operate on a written budget, a loose system, or no system?</label>
                                <select asp-for="Middle.Cashflow.BudgetSystem" class="form-select">
                                    <option value="">Select</option>
                                    <option>Written Budget</option>
                                    <option>Loose System</option>
                                    <option>No System</option>
                                </select>
                            </div>

                            <div class="mini-title">Emergency Reserves</div>
                            <div class="row two">
                                <div class="field">
                                    <label>Emergency Fund Amount</label>
                                    <input asp-for="Middle.Cashflow.EmergencyFundAmount" type="number" step="0.01" class="form-control" />
                                </div>
                                <div class="field">
                                    <label>Months Covered</label>
                                    <input asp-for="Middle.Cashflow.EmergencyFundMonths" class="form-control" placeholder="Example: 3–6 months" />
                                </div>
                            </div>

                            <div class="field">
                                <label>21) If you had an unexpected $10,000 expense this month, how would you handle it?</label>
                                <textarea asp-for="Middle.Cashflow.Unexpected10kPlan" class="form-control" style="min-height:84px;"></textarea>
                            </div>
                        </div>

                        <!-- Debt -->
                        <div class="block">
                            <div class="block-title">Debt & Obligations</div>

                            <div class="mini-title">Primary Residence</div>
                            <div class="row three">
                                <div class="field"><label>Home Value (Approx.)</label><input asp-for="Middle.Debt.HomeValue" type="number" step="0.01" class="form-control" /></div>
                                <div class="field"><label>Mortgage Balance</label><input asp-for="Middle.Debt.MortgageBalance" type="number" step="0.01" class="form-control" /></div>
                                <div class="field"><label>Interest Rate</label><input asp-for="Middle.Debt.MortgageRate" class="form-control" placeholder="%" /></div>
                            </div>

                            <div class="row two">
                                <div class="field"><label>Monthly Mortgage Payment</label><input asp-for="Middle.Debt.MortgagePayment" type="number" step="0.01" class="form-control" /></div>
                                <div class="field"><label>Years Remaining</label><input asp-for="Middle.Debt.MortgageYearsRemaining" type="number" class="form-control" /></div>
                            </div>

                            <div class="mini-title">Other Debts</div>
                            <div class="subtle">Starts with one row. Add only what applies.</div>
                            @{
                                var dCount = Model.Middle?.Debt?.Other?.Count ?? 0;
                                var dRender = Math.Max(1, dCount);
                            }
                            <div id="debtOtherListMiddle">
                                @for (int i = 0; i < dRender; i++)
                                {
                                    var d = (Model.Middle?.Debt?.Other != null && Model.Middle.Debt.Other.Count > i)
                                        ? Model.Middle.Debt.Other[i]
                                        : null;

                                    <div class="table-like repeater-item">
                                        <div class="row five">
                                            <div class="field"><label>Type</label><input name="Middle.Debt.Other[@i].Type" value="@(d?.Type ?? "")" class="form-control" placeholder="Auto / Student / Credit / Personal / Business" /></div>
                                            <div class="field"><label>Balance</label><input name="Middle.Debt.Other[@i].Balance" value="@(d?.Balance?.ToString() ?? "")" type="number" step="0.01" class="form-control" /></div>
                                            <div class="field"><label>Rate</label><input name="Middle.Debt.Other[@i].Rate" value="@(d?.Rate ?? "")" class="form-control" placeholder="%" /></div>
                                            <div class="field"><label>Monthly Payment</label><input name="Middle.Debt.Other[@i].Payment" value="@(d?.Payment?.ToString() ?? "")" type="number" step="0.01" class="form-control" /></div>
                                            <div class="field"><label>Notes</label><input name="Middle.Debt.Other[@i].Notes" value="@(d?.Notes ?? "")" class="form-control" placeholder="Any notes" /></div>
                                        </div>

                                        <div class="repeater-actions">
                                            <button type="button" class="btn btn-gold"
                                                    data-repeater-add="debtOtherListMiddle"
                                                    data-template="tplMiddleDebtOther">+ Add Debt</button>
                                            <button type="button" class="btn btn-danger btn-delete-row" data-repeater-del title="Delete">Delete</button>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="field">
                                <label>22) Do you feel your debt is under control, heavy, or chaotic?</label>
                                <select asp-for="Middle.Debt.FeelsLike" class="form-select">
                                    <option value="">Select</option>
                                    <option>Under Control</option>
                                    <option>Heavy but Managed</option>
                                    <option>Chaotic / Stressful</option>
                                </select>
                            </div>

                            <div class="field">
                                <label>23) If you could change one thing about your debt situation, what would it be?</label>
                                <textarea asp-for="Middle.Debt.ChangeOneThing" class="form-control" style="min-height:84px;"></textarea>
                            </div>

                        </div>
                    </div>

                    <div class="wizard-actions">
                        <button type="button" class="btn btn-ghost" data-prev>Back</button>
                        <button type="button" class="btn btn-gold" data-next>Next</button>
                    </div>
                </div>
            </section>

            <!-- =========================================================
                 STEP 6 — ASSETS + TAX + LEGACY + SUBMIT
            ========================================================== -->
            <section class="wizard-step" data-step="6" data-label="Assets + Legacy">

                <div class="section-card">
                    <div class="section-title">Part 6 — Assets, Taxes, Legacy & Next Steps</div>
                    <div class="subtle">We lock in the full picture and make it actionable.</div>

                    <div class="grid two">

                        <!-- Retirement + Investments -->
                        <div class="block">
                            <div class="block-title">Retirement & Investment Accounts</div>

                            <div class="mini-title">Retirement Accounts</div>
                            <div class="subtle">Starts with one row. Add only what exists.</div>
                            @{
                                var retCount = Model.Middle?.Assets?.Retirement?.Count ?? 0;
                                var retRender = Math.Max(1, retCount);
                            }
                            <div id="retirementListMiddle">
                                @for (int i = 0; i < retRender; i++)
                                {
                                    var a = (Model.Middle?.Assets?.Retirement != null && Model.Middle.Assets.Retirement.Count > i)
                                        ? Model.Middle.Assets.Retirement[i]
                                        : null;

                                    <div class="table-like repeater-item">
                                        <div class="row four">
                                            <div class="field"><label>Account Type</label><input name="Middle.Assets.Retirement[@i].Type" value="@(a?.Type ?? "")" class="form-control" placeholder="401(k)/403(b)/IRA/Roth/HSA/SEP/Solo401k" /></div>
                                            <div class="field"><label>Institution</label><input name="Middle.Assets.Retirement[@i].Institution" value="@(a?.Institution ?? "")" class="form-control" placeholder="Fidelity/Vanguard/etc." /></div>
