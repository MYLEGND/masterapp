@* Views/FactFinder/Index.cshtml *@
@model AgentPortal.Models.FactFinderViewModel

@{
    ViewData["Title"] = "Fact Finder";
}

<style>
    :root{
        --gold: #a68023;
        --gold-dark:#8f6f1e;
        --ink:#111;
        --muted: rgba(0,0,0,.68);
        --line: rgba(166,128,35,.35);
        --bg:#ffffff;
        --soft:#fcfbf7;
        --shadow: 0 16px 45px rgba(0,0,0,.06);
    }

    body { background-color: var(--bg); }

    /* Shell */
    .ff-shell{
        max-width: 1180px;
        width: 100%;
        margin: 0 auto;
        padding: 18px 14px 44px 14px;
    }

    /* HERO */
    .ff-hero{
        position: relative;
        border-radius: 18px;
        overflow: hidden;
        border: 2px solid var(--line);
        background:
            radial-gradient(900px 350px at 15% 10%, rgba(166,128,35,.13), transparent 60%),
            radial-gradient(800px 320px at 85% 20%, rgba(166,128,35,.10), transparent 60%),
            linear-gradient(180deg, #ffffff 0%, #fbf8ef 100%);
        box-shadow: var(--shadow);
        padding: 26px 22px;
        margin-bottom: 18px;
    }

    .ff-hero-inner{
        display:grid;
        gap: 12px;
        align-items: start;
    }

    .ff-kicker{
        display:inline-flex;
        align-items:center;
        gap:10px;
        font-weight: 950;
        color: var(--gold-dark);
        letter-spacing:.25px;
        text-transform: uppercase;
        font-size: .85rem;
    }

    .ff-kicker-dot{
        width:10px; height:10px; border-radius:50%;
        background: var(--gold);
        box-shadow: 0 0 0 4px rgba(166,128,35,.15);
        flex: 0 0 auto;
    }

    .ff-title{
        margin: 0;
        font-weight: 950;
        font-size: clamp(2.0rem, 3.2vw, 2.8rem);
        color: var(--ink);
        letter-spacing: .3px;
        line-height: 1.05;
    }

    .ff-sub{
        margin: 0;
        color: var(--muted);
        font-size: 1.05rem;
        max-width: 860px;
        line-height: 1.45;
    }

    .ff-badges{
        display:flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 6px;
    }

    .ff-badge{
        display:inline-flex;
        align-items:center;
        gap: 8px;
        border: 1px solid rgba(166,128,35,.28);
        background: rgba(166,128,35,.06);
        border-radius: 999px;
        padding: 8px 12px;
        font-weight: 900;
        color: rgba(0,0,0,.78);
        font-size: .92rem;
    }

    .ff-badge .dot{
        width:8px; height:8px; border-radius:50%;
        background: var(--gold);
        flex: 0 0 auto;
    }

    /* Success */
    .success-message{
        color: #fff;
        font-weight: 900;
        margin: 0 0 16px 0;
        font-size: 1.02rem;
        padding: 12px 14px;
        border-radius: 12px;
        background: #111;
        border: 2px solid var(--gold);
        box-shadow: 0 12px 30px rgba(0,0,0,.08);
    }

    /* Section Cards */
    .section-card{
        background: #fff;
        border: 2px solid var(--gold);
        padding: 22px;
        border-radius: 14px;
        margin-bottom: 18px;
        box-shadow: var(--shadow);
    }

    .section-title{
        font-weight: 950;
        color: var(--ink);
        margin: 0 0 8px 0;
        font-size: 1.25rem;
        letter-spacing:.2px;
    }

    .subtle{
        color: var(--muted);
        margin: 0 0 14px 0;
        line-height: 1.45;
    }

    /* Rows */
    .row{
        display:grid;
        grid-template-columns: 1fr;
        gap: 14px;
    }
    @@media (min-width: 900px){
        .row.three{ grid-template-columns: repeat(3, 1fr); }
    }

    /* Choice tiles */
    .choice{
        position: relative;
        display:block;
        border-radius: 14px;
        border: 2px solid rgba(166,128,35,.35);
        background: linear-gradient(180deg, rgba(252,251,247,1) 0%, rgba(255,255,255,1) 100%);
        padding: 18px 16px;
        text-decoration:none;
        color: var(--ink);
        transition: transform .12s ease, box-shadow .12s ease, border-color .12s ease;
        box-shadow: 0 10px 30px rgba(0,0,0,.05);
        min-height: 160px;
    }
    .choice:hover{
        transform: translateY(-2px);
        border-color: rgba(166,128,35,.60);
        box-shadow: 0 18px 45px rgba(0,0,0,.08);
    }

    .choice-top{
        display:flex;
        align-items:flex-start;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
    }

    .choice-title{
        font-weight: 950;
        font-size: 1.15rem;
        margin: 0;
        letter-spacing:.2px;
    }

    .choice-chip{
        display:inline-flex;
        align-items:center;
        gap: 8px;
        border-radius: 999px;
        padding: 7px 10px;
        font-weight: 950;
        font-size: .86rem;
        border: 1px solid rgba(166,128,35,.35);
        background: rgba(166,128,35,.08);
        color: rgba(0,0,0,.78);
        white-space: nowrap;
        flex: 0 0 auto;
    }

    .choice-desc{
        margin: 0;
        color: var(--muted);
        line-height: 1.45;
        font-size: .98rem;
    }

    .choice-footer{
        margin-top: 14px;
        display:flex;
        align-items:center;
        justify-content: space-between;
        gap: 10px;
    }

    .choice-action{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        gap: 10px;
        border-radius: 12px;
        padding: 10px 12px;
        font-weight: 950;
        border: 2px solid var(--gold);
        color: #fff;
        background: var(--gold);
        width: 100%;
        text-align:center;
    }
    .choice:hover .choice-action{
        background: var(--gold-dark);
        border-color: var(--gold-dark);
    }

    /* Bottom reassurance */
    .ff-footer{
        margin-top: 18px;
        text-align:center;
        color: var(--muted);
        font-size: .98rem;
    }
    .ff-footer strong{ color: var(--ink); }
</style>

<div class="ff-shell">

    <div class="ff-hero">
        <div class="ff-hero-inner">
            <div class="ff-kicker">
                <span class="ff-kicker-dot"></span>
                Legend™ Fact Finder Intake
            </div>

            <h1 class="ff-title">Choose the right Fact Finder</h1>

            <p class="ff-sub">
                This is designed to keep the process clean and intentional — not overwhelming.
                Pick the client stage below, answer what applies, and we’ll generate a PDF that matches what was selected.
            </p>

        </div>
    </div>

    @if (ViewBag.Success != null)
    {
        <div class="success-message">@ViewBag.Success</div>
    }

    <div class="section-card">
        <div class="section-title">Select an intake</div>
        <p class="subtle" style="margin-bottom:22px;">
            Each version is tailored to the client’s season of life — so the data you collect is actually useful for planning.
        </p>

        <div class="row three" style="gap:18px;">

            <a class="choice" asp-controller="FactFinder" asp-action="Senior" aria-label="Open Senior Fact Finder">
                <div class="choice-top">
                    <h3 class="choice-title">Senior</h3>
                    <span class="choice-chip">Protection + Retirement</span>
                </div>
                <p class="choice-desc">
                    Best for clients focused on income, Medicare/health cost risk, legacy decisions, and protecting what they’ve built.
                </p>
                <div class="choice-footer">
                    <div class="choice-action">Start Senior Intake →</div>
                </div>
            </a>

            <a class="choice" asp-controller="FactFinder" asp-action="MiddleAged" aria-label="Open Middle-Aged Fact Finder">
                <div class="choice-top">
                    <h3 class="choice-title">Middle-Aged</h3>
                    <span class="choice-chip">Family + Wealth Build</span>
                </div>
                <p class="choice-desc">
                    Best for clients balancing kids, mortgage, career peak years, protection planning, and structured wealth building.
                </p>
                <div class="choice-footer">
                    <div class="choice-action">Start Middle-Aged Intake →</div>
                </div>
            </a>

            <a class="choice" asp-controller="FactFinder" asp-action="Younger" aria-label="Open Younger Fact Finder">
                <div class="choice-top">
                    <h3 class="choice-title">Younger</h3>
                    <span class="choice-chip">Foundation + Direction</span>
                </div>
                <p class="choice-desc">
                    Best for clients in the build phase — stabilizing cash flow, clearing debt, building habits, and creating momentum.
                </p>
                <div class="choice-footer">
                    <div class="choice-action">Start Younger Intake →</div>
                </div>
            </a>

        </div>
    </div>

    <div class="ff-footer">
        <strong>Legend™ standard:</strong> clarity, structure, and clean next steps.
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}