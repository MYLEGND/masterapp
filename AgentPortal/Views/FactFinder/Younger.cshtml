            <!-- =========================================================
                 STEP 3 — DEBT + CREDIT
            ========================================================== -->
            <section class="wizard-step" data-step="3" data-label="Debt + Credit">
                <div class="section-card">
                    <div class="section-title">Part 3 — Debt, Credit & Major Decisions</div>
