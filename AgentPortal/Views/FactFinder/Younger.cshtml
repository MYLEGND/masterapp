@* Views/FactFinder/Younger.cshtml *@
@model AgentPortal.Models.FactFinderViewModel

@{
    ViewData["Title"] = "Younger Fact Finder";
}

<style>
    :root{
        --navy-900: #0b1529;
        --navy-800: #0f1d38;
        --navy-700: #162445;
        --gold: #a68023;
        --gold-dark:#8f6f1e;
        --ink:#f8fafc;
        --muted: #cbd5e1;
        --line: rgba(166,128,35,.55);
        --bg: var(--navy-900);
        --soft:#0f1d38;
        --card:#0f1d38;
        --input-text: #0b1529;
        --shadow: 0 18px 38px rgba(0,0,0,.32);
        --radius: 18px;
    }

    body { background-color: var(--bg); color: var(--ink); }

    .ff-shell{
        max-width: 980px; /* full-screen feel, but readable */
        width: 100%;
        margin: 0 auto;
        padding: 0 14px 30px 14px;
    }

    .success-message{
        background: #e9f7ef;
        border: 1px solid #bfe5cf;
        color: #135b2c;
        padding: 12px 14px;
        border-radius: 12px;
        margin-top: 14px;
        font-weight: 800;
    }

    .ff-title{
        margin-top: 18px;
        margin-bottom: 8px;
        text-align:center;
    }

    .ff-title h1{
        font-weight: 950;
        font-size: clamp(2.0rem, 3.2vw, 2.6rem);
        color: var(--ink);
        letter-spacing: .5px;
        margin: 0;
    }

    .required-note{
        text-align:center;
        color: var(--muted);
        margin: 0 0 14px 0;
    }

    .req{ color:#dc3545; font-weight: 900; margin-left: 2px; }

    /* Progress */
    .ff-progress-wrap{
        background: var(--soft);
        border: 1.5px solid var(--gold);
        border-radius: var(--radius);
        padding: 12px 14px;
        box-shadow: var(--shadow);
        margin-bottom: 14px;
        color: var(--ink);
    }

    .ff-progress-top{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 12px;
        margin-bottom: 10px;
        flex-wrap: wrap;
    }

    .ff-step-pill{
        background: var(--navy-900);
        border: 1.2px solid var(--gold);
        border-radius: 999px;
        padding: 6px 10px;
        font-weight: 950;
        color: var(--ink);
        font-size: .9rem;
        white-space: nowrap;
    }

    .ff-progress{
        height: 10px;
        border-radius: 999px;
        background: var(--navy-700);
        overflow:hidden;
        border: 1px solid var(--gold);
    }

    #ffProgressBarYoung{
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, var(--gold), var(--gold-dark));
        border-radius: 999px;
        transition: width .25s ease;
    }

    /* Steps */
    .wizard-step{ display:none; }
    .wizard-step.active{ display:block; }

    /* Cards */
    .section-card{
        background: #fff;
        border: 1.6px solid var(--gold);
        border-radius: var(--radius);
        padding: 16px 16px;
        box-shadow: var(--shadow);
        margin-bottom: 14px;
        color: var(--navy-900);
    }

    .section-card .section-title,
    .section-card .subtle,
    .section-card .field label,
    .section-card .table-like label {
        color: var(--navy-900) !important;
    }

.table-like{
    background:#fff;
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 14px;
    padding: 10px;
    margin-bottom: 10px;
    position: relative;
    color: var(--navy-900);
}

/* Blocks sit on navy backgrounds — keep their text white for contrast */
.section-card .block,
.section-card .block label,
.section-card .block .block-title,
.section-card .block .mini-title,
.section-card .block .subtle {
    color: #fff !important;
}

.ack-text{
    color: var(--navy-900) !important;
}

    .section-title{
        font-weight: 950;
        color: var(--ink);
        font-size: 1.15rem;
        margin-bottom: 4px;
    }

    .subtle{
        color: var(--muted);
        font-weight: 700;
        margin-bottom: 12px;
    }

    /* Vertical blocks */
    .stack{
        display:flex;
        flex-direction: column;
        gap: 14px;
    }

    .block{
        background: var(--soft);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 14px;
    }

    .block-title{
        font-weight: 950;
        color: var(--gold);
        font-size: 1.05rem;
        margin-bottom: 10px;
        letter-spacing: .2px;
    }

    .mini-title{
        font-weight: 950;
        color: var(--ink);
        margin-top: 12px;
        margin-bottom: 8px;
        opacity: .92;
    }

    /* Rows (NOTE: must be class="row two" not "row.two") */
    .row.two{
        display:grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 10px;
    }

    .row.three{
        display:grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-bottom: 10px;
    }

    .row.five{
        display:grid;
        grid-template-columns: 1.1fr .9fr .6fr .9fr 1.1fr;
        gap: 10px;
        margin-bottom: 10px;
    }

    @@media (max-width: 980px){
        .row.two, .row.three, .row.five{ grid-template-columns: 1fr; }
    }

    .field label{
        display:block;
        font-weight: 900;
        color: var(--navy-900);
        margin-bottom: 6px;
        font-size: .92rem;
    }

    /* GOLD INPUTS */
    input.form-control,
    textarea.form-control,
    select.form-select{
        border: 1.6px solid var(--gold) !important;
        border-radius: 12px !important;
        padding: 10px 12px !important;
        background: #fff !important;
        color: var(--input-text) !important;
        font-weight: 700;
        box-shadow: none !important;
        outline: none !important;
    }

    input.form-control:focus,
    textarea.form-control:focus,
    select.form-select:focus{
        border-color: var(--gold) !important;
        box-shadow: 0 0 0 .22rem rgba(166,128,35,.25) !important;
    }

    textarea.form-control{ resize: vertical; }

    .checkline{
        display:flex;
        align-items:center;
        gap: 10px;
        background: var(--navy-800);
        border: 1.2px solid var(--gold);
        border-radius: 12px;
        padding: 10px 12px;
        margin-bottom: 10px;
        font-weight: 800;
        color: var(--ink);
    }

    .checkline input[type="checkbox"]{
        width: 18px;
        height: 18px;
        accent-color: var(--gold);
    }

    /* Table-like rows */
    .table-like{
        background:#fff;
        border: 1px solid rgba(0,0,0,.06);
        border-radius: 14px;
        padding: 10px;
        margin-bottom: 10px;
        position: relative;
    }

    /* Buttons */
    .wizard-actions{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 12px;
        margin-top: 12px;
        flex-wrap: wrap;
    }

    .btn{
        border-radius: 999px !important;
        font-weight: 950 !important;
        letter-spacing: .2px;
        padding: 10px 16px !important;
    }

    .btn-gold{
        background: linear-gradient(180deg, var(--gold), var(--gold-dark)) !important;
        border: 1px solid rgba(0,0,0,.06) !important;
        color: #fff !important;
        box-shadow: 0 12px 26px rgba(166,128,35,.25);
    }

    .btn-gold:hover{ filter: brightness(1.02); }

    .btn-ghost{
        background: var(--navy-900) !important;
        border: 2px solid var(--gold) !important;
        color: #fff !important;
    }

    .btn-ghost:hover{
        border-color: var(--gold) !important;
        filter: brightness(1.05);
        box-shadow: 0 10px 20px rgba(0,0,0,.2);
    }

    /* ============================
       VALIDATION HELPER (Agent UX)
    ============================ */
    .ff-error-summary{
        background: #fff3cd;
        border: 1px solid rgba(166,128,35,.45);
        color: #664d03;
        padding: 12px 14px;
        border-radius: 14px;
        margin: 12px 0 14px 0;
        font-weight: 900;
        box-shadow: var(--shadow);
    }

    .ff-error-summary .title{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 10px;
        margin-bottom: 8px;
    }

    .ff-error-summary .count{
        background:#fff;
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 999px;
        padding: 4px 10px;
        font-weight: 950;
    }

    .ff-error-summary ul{
        margin: 0;
        padding-left: 18px;
        font-weight: 800;
    }

    .ff-error-summary li{
        margin: 6px 0;
    }

    .ff-error-summary a{
        color: #664d03;
        text-decoration: underline;
        font-weight: 950;
    }

    .ff-field-invalid input.form-control,
    .ff-field-invalid textarea.form-control,
    .ff-field-invalid select.form-select{
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 .22rem rgba(220,53,69,.18) !important;
    }

    .ff-fix-tag{
        display:inline-flex;
        align-items:center;
        gap: 6px;
        margin-top: 6px;
        padding: 4px 10px;
        border-radius: 999px;
        background: rgba(220,53,69,.10);
        border: 1px solid rgba(220,53,69,.35);
        color: #b02a37;
        font-weight: 950;
        font-size: .82rem;
        letter-spacing: .1px;
    }

    @@keyframes ffPulse {
        0%   { transform: scale(1); }
        50%  { transform: scale(1.01); }
        100% { transform: scale(1); }
    }
    .ff-field-invalid{ animation: ffPulse .22s ease-in-out; }

    /* ===========
       REPEATER CTA BAR
       - Buttons live INSIDE each table-like card, bottom-left
    =========== */
    .repeater-actions{
        display:flex;
        align-items:center;
        justify-content:flex-start;
        gap: 10px;
        margin-top: 10px;
        padding-top: 10px;
        border-top: 1px solid rgba(0,0,0,.08);
    }

    .btn-delete-row{
        position: static;
        border-radius: 999px !important;
        font-weight: 950 !important;
        padding: 8px 12px !important;
    }

    .repeater-actions .btn{
        padding: 8px 12px !important;
    }
</style>

<div class="ff-shell">

    @if (ViewBag.Success != null)
    {
        <div class="success-message">@ViewBag.Success</div>
    }

    <div class="ff-title">
        <h1>Fact Finder - Younger (18-34)</h1>
    </div>

    <p class="required-note">
        <strong><span class="text-danger">*</span> Fields marked with a red asterisk are required.</strong>
    </p>

    <!-- Progress (Young-only) -->
    <div class="ff-progress-wrap">
        <div class="ff-progress-top">
            <div class="ff-step-pill">
                Step <span id="ffStepNowYoung">1</span> of <span id="ffStepTotalYoung">5</span>
            </div>
            <div style="font-weight:900; color:var(--muted); font-size:.95rem;" id="ffStepLabelYoung">
                Life + Direction
            </div>
        </div>
        <div class="ff-progress"><div id="ffProgressBarYoung"></div></div>
    </div>

    <div id="ffErrorSummaryYoung"></div>

    <div id="ffYoungApp">
        <form id="factFinderFormYoung" method="post" asp-action="Submit" asp-controller="FactFinder" novalidate>
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="FormType" value="Young" />

            <!-- =========================================================
                 STEP 1 — TRUST + VALUES + DIRECTION (BEFORE MONEY)
            ========================================================== -->
            <section class="wizard-step active" data-step="1" data-label="Life + Direction">
                <div class="section-card">
                    <div class="section-title">Younger Fact Finder — Part 1: Life, Direction & Ownership</div>
                    <div class="subtle">We start with what matters to you — then we build the plan around it.</div>

                    <div class="stack">

                        <div class="block">
                            <div class="block-title">Personal</div>

                            <div class="row two">
                                <div class="field">
                                    <label>Full Name<span class="req">*</span></label>
                                    <input asp-for="Young.Person.Name" class="form-control" placeholder="Full Name*" required />
                                    <span asp-validation-for="Young.Person.Name" class="text-danger"></span>
                                </div>
                                <div class="field">
                                    <label>Date of Birth<span class="req">*</span></label>
                                    <input asp-for="Young.Person.DOB" type="date" class="form-control" required />
                                    <span asp-validation-for="Young.Person.DOB" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row two">
                                <div class="field">
                                    <label>City / State</label>
                                    <input asp-for="Young.Person.Location" class="form-control" placeholder="City, State" />
                                </div>
                                <div class="field">
                                    <label>Relationship Status</label>
                                    <select asp-for="Young.Person.RelationshipStatus" class="form-select">
                                        <option value="">Select</option>
                                        <option>Single</option>
                                        <option>In a Relationship</option>
                                        <option>Married</option>
                                        <option>Engaged</option>
                                        <option>Divorced</option>
                                        <option>Other</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row two">
                                <div class="field">
                                    <label>Do you have kids or dependents?</label>
                                    <select asp-for="Young.Person.HasDependents" class="form-select">
                                        <option value="">Select</option>
                                        <option>No</option>
                                        <option>Yes</option>
                                        <option>Not yet, but planned</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label>If yes, how many?</label>
                                    <input asp-for="Young.Person.DependentsCount" type="number" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <div class="block">
                            <div class="block-title">Direction & Motivation</div>

                            <div class="field">
                                <label>1) What do you want your life to look like in 3–5 years?</label>
                                <textarea asp-for="Young.Direction.ThreeToFiveYears" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="field">
                                <label>2) What do you want your life to look like in 10 years?</label>
                                <textarea asp-for="Young.Direction.TenYears" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="field">
                                <label>3) What are you most stressed about financially right now?</label>
                                <textarea asp-for="Young.Direction.CurrentStress" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="field">
                                <label>4) If nothing changes, what are you afraid could happen financially?</label>
                                <textarea asp-for="Young.Direction.FearIfNoChange" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="field">
                                <label>5) If we could fix one thing first that would make the biggest impact, what do you think it is?</label>
                                <textarea asp-for="Young.Direction.OneThingFirst" class="form-control" style="min-height:96px;"></textarea>
                            </div>
                        </div>

                        <div class="block">
                            <div class="block-title">Ownership + Commitment (Before the numbers)</div>

                            <div class="field">
                                <label>35) What does “financial stability” mean to you personally?</label>
                                <textarea asp-for="Young.Ownership.StabilityMeaning" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="field">
                                <label>37) What has stopped you from getting organized sooner? (lack of knowledge, fear, shame, time, no guidance, procrastination)</label>
                                <textarea asp-for="Young.Ownership.WhatsStoppedYou" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="field">
                                <label>39) What would make this experience feel “worth it” to you?</label>
                                <textarea asp-for="Young.Ownership.WorthIt" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="wizard-actions">
                                <div></div>
                                <button type="button" class="btn btn-gold" data-next>Next</button>
                            </div>
                        </div>

                    </div>
                </div>
            </section>

            <!-- =========================================================
                 STEP 2 — WORK + SYSTEM + HABITS (THEN MONEY)
            ========================================================== -->
            <section class="wizard-step" data-step="2" data-label="Work + System">
                <div class="section-card">
                    <div class="section-title">Part 2 — Work, Habits & Your Financial System</div>
                    <div class="subtle">We establish stability and structure first — then we measure the numbers.</div>

                    <div class="stack">

                        <div class="block">
                            <div class="block-title">Work, Income & Stability</div>

                            <div class="field">
                                <label>6) What do you do for work right now?</label>
                                <input asp-for="Young.Work.Role" class="form-control" placeholder="Job title / role" />
                            </div>

                            <div class="row two">
                                <div class="field">
                                    <label>Employer / Company</label>
                                    <input asp-for="Young.Work.Employer" class="form-control" />
                                </div>
                                <div class="field">
                                    <label>How long have you been there?</label>
                                    <input asp-for="Young.Work.Tenure" class="form-control" placeholder="Example: 1 year" />
                                </div>
                            </div>

                            <div class="row three">
                                <div class="field">
                                    <label>Income Type</label>
                                    <select asp-for="Young.Work.IncomeType" class="form-select">
                                        <option value="">Select</option>
                                        <option>Salary</option>
                                        <option>Hourly</option>
                                        <option>Commission</option>
                                        <option>Gig / Contract</option>
                                        <option>Business Owner</option>
                                        <option>Mixed</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label>Annual Income (Approx.)</label>
                                    <input asp-for="Young.Work.AnnualIncome" type="number" step="0.01" class="form-control" />
                                </div>
                                <div class="field">
                                    <label>Income Stability</label>
                                    <select asp-for="Young.Work.IncomeStability" class="form-select">
                                        <option value="">Select</option>
                                        <option>Stable</option>
                                        <option>Somewhat unstable</option>
                                        <option>Unpredictable</option>
                                    </select>
                                </div>
                            </div>

                            <div class="field">
                                <label>7) What’s your biggest obstacle to increasing income right now? (skills, confidence, time, opportunities, debt, health, mindset)</label>
                                <textarea asp-for="Young.Work.ObstacleToIncreaseIncome" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="field">
                                <label>8) Are you building toward a career path, entrepreneurship, or still exploring?</label>
                                <textarea asp-for="Young.Work.PathExploration" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="mini-title">Benefits (if employed)</div>
                            <div class="row two">
                                <div class="checkline"><input asp-for="Young.Benefits.Health" type="checkbox" id="youngBenHealth" /><label for="youngBenHealth" style="margin:0;">Health</label></div>
                                <div class="checkline"><input asp-for="Young.Benefits.Dental" type="checkbox" id="youngBenDental" /><label for="youngBenDental" style="margin:0;">Dental</label></div>
                                <div class="checkline"><input asp-for="Young.Benefits.Vision" type="checkbox" id="youngBenVision" /><label for="youngBenVision" style="margin:0;">Vision</label></div>
                                <div class="checkline"><input asp-for="Young.Benefits.RetirementPlan" type="checkbox" id="youngBenRet" /><label for="youngBenRet" style="margin:0;">401(k)/403(b)</label></div>
                                <div class="checkline"><input asp-for="Young.Benefits.HSA" type="checkbox" id="youngBenHsa" /><label for="youngBenHsa" style="margin:0;">HSA</label></div>
                                <div class="checkline"><input asp-for="Young.Benefits.GroupLife" type="checkbox" id="youngBenGL" /><label for="youngBenGL" style="margin:0;">Group Life</label></div>
                                <div class="checkline"><input asp-for="Young.Benefits.GroupDI" type="checkbox" id="youngBenDI" /><label for="youngBenDI" style="margin:0;">Group Disability</label></div>
                            </div>

                            <div class="field">
                                <label>9) Do you actually understand your benefits and how to use them strategically?</label>
                                <select asp-for="Young.Benefits.UnderstandBenefits" class="form-select">
                                    <option value="">Select</option>
                                    <option>No</option>
                                    <option>Somewhat</option>
                                    <option>Yes</option>
                                </select>
                            </div>
                        </div>

                        <div class="block">
                            <div class="block-title">Cash Flow + Habits (System First)</div>

                            <div class="field">
                                <label>11) Do you have a system for money — or do you “hope it works out”?</label>
                                <select asp-for="Young.Cashflow.SystemLevel" class="form-select">
                                    <option value="">Select</option>
                                    <option>Strong system</option>
                                    <option>Loose system</option>
                                    <option>No system</option>
                                </select>
                            </div>

                            <div class="field">
                                <label>10) What’s the #1 thing that throws your money off each month?</label>
                                <textarea asp-for="Young.Cashflow.OffTrack" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="field">
                                <label>12) What would you want a “good system” to do for you? (less stress, pay off debt, build savings, invest, buy a house)</label>
                                <textarea asp-for="Young.Cashflow.SystemDesiredOutcome" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="field">
                                <label>13) What’s your biggest spending weakness? (eating out, lifestyle, Amazon, travel, social pressure, subscriptions)</label>
                                <textarea asp-for="Young.Cashflow.SpendingWeakness" class="form-control" style="min-height:96px;"></textarea>
                            </div>

                            <div class="mini-title">Banking Setup</div>
                            <div class="row two">
                                <div class="field">
                                    <label>Do you know exactly where your money goes?</label>
                                    <select asp-for="Young.Banking.KnowWhereMoneyGoes" class="form-select">
                                        <option value="">Select</option>
                                        <option>No</option>
                                        <option>Somewhat</option>
                                        <option>Yes</option>
                                    </select>
                                </div>
                                <div class="field">
                                    <label>How many bank accounts do you use?</label>
                                    <input asp-for="Young.Banking.NumAccounts" type="number" class="form-control" />
                                </div>
                            </div>

                            <div class="mini-title">Monthly Reality Check (Numbers)</div>
                            <div class="row three">
                                <div class="field">
                                    <label>Monthly Income (Net)</label>
                                    <input asp-for="Young.Cashflow.NetIncome" type="number" step="0.01" class="form-control" />
                                </div>
                                <div class="field">
                                    <label>Monthly Fixed Bills</label>
                                    <input asp-for="Young.Cashflow.FixedBills" type="number" step="0.01" class="form-control" />
                                </div>
                                <div class="field">
                                    <label>Monthly Variable Spending</label>
                                    <input asp-for="Young.Cashflow.VariableSpending" type="number" step="0.01" class="form-control" />
                                </div>
                            </div>

                            <div class="row three">
                                <div class="field">
                                    <label>Monthly Savings (if any)</label>
                                    <input asp-for="Young.Cashflow.MonthlySavings" type="number" step="0.01" class="form-control" />
