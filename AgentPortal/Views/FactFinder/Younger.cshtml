<template id="tplYoungDebt">
    <div class="table-like repeater-item">
        <div class="row five">
            <div class="field"><label>Type</label><input name="Young.Debt[__i__].Type" class="form-control" placeholder="Credit Card / Student / Auto / Personal / Other" /></div>
            <div class="field"><label>Balance</label><input name="Young.Debt[__i__].Balance" type="number" step="0.01" class="form-control" /></div>
            <div class="field"><label>Rate</label><input name="Young.Debt[__i__].Rate" class="form-control" placeholder="%" /></div>
            <div class="field"><label>Monthly Payment</label><input name="Young.Debt[__i__].Payment" type="number" step="0.01" class="form-control" /></div>
            <div class="field"><label>Notes</label><input name="Young.Debt[__i__].Notes" class="form-control" placeholder="Any notes" /></div>
        </div>

        <div class="repeater-actions">
            <button type="button" class="btn btn-gold" data-repeater-add="debtListYoung" data-template="tplYoungDebt">+ Add Debt</button>
            <button type="button" class="btn btn-danger btn-delete-row" data-repeater-del title="Delete">Delete</button>
        </div>
    </div>
</template>

<script>
    (function () {
        const root = document.getElementById('ffYoungApp');
        if (!root) return;

        const form = root.querySelector('#factFinderFormYoung');
        if (!form) return;

        const steps = Array.from(root.querySelectorAll('.wizard-step'));
        const total = steps.length;

        const stepNowEl = document.getElementById('ffStepNowYoung');
        const stepTotalEl = document.getElementById('ffStepTotalYoung');
        const stepLabelEl = document.getElementById('ffStepLabelYoung');
        const bar = document.getElementById('ffProgressBarYoung');

        const summaryHost = document.getElementById('ffErrorSummaryYoung');

        if (stepTotalEl) stepTotalEl.textContent = String(total);

        function currentStepIndex() {
            return steps.findIndex(s => s.classList.contains('active'));
        }

        function updateProgress(idx) {
            const stepNum = idx + 1;

            if (stepNowEl) stepNowEl.textContent = String(stepNum);

            const label = steps[idx].getAttribute('data-label') || '';
            if (stepLabelEl) stepLabelEl.textContent = label;

            const pct = Math.round((stepNum / total) * 100);
            if (bar) bar.style.width = pct + '%';

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function showStep(idx) {
            steps.forEach((s, i) => s.classList.toggle('active', i === idx));
            updateProgress(idx);
        }

        // -----------------------------
        // VALIDATION VISUAL HELPERS
        // -----------------------------
        function clearVisualErrors() {
            if (summaryHost) summaryHost.innerHTML = "";
            root.querySelectorAll('.ff-field-invalid').forEach(el => el.classList.remove('ff-field-invalid'));
            root.querySelectorAll('.ff-fix-tag').forEach(el => el.remove());
        }

        function getFieldLabel(el) {
            const field = el.closest('.field');
            if (!field) return "Field";
            const lbl = field.querySelector('label');
            return (lbl && lbl.textContent) ? lbl.textContent.replace('*', '').trim() : "Field";
        }

        function getStepLabel(el) {
            const stepEl = el.closest('.wizard-step');
            return (stepEl && stepEl.getAttribute('data-label')) ? stepEl.getAttribute('data-label') : "Form";
        }

        function markFieldInvalid(el, message) {
            const field = el.closest('.field') || el.closest('.checkline') || el.parentElement;
            if (!field) return;

            field.classList.add('ff-field-invalid');

            if (field.querySelector('.ff-fix-tag')) return;

            const tag = document.createElement('div');
            tag.className = 'ff-fix-tag';
            tag.textContent = message || 'Required — fix this';

            const label = field.querySelector('label');
            if (label && label.parentNode) {
                label.insertAdjacentElement('afterend', tag);
            } else {
                field.insertAdjacentElement('afterbegin', tag);
            }
        }

        function buildSummary(invalidEls) {
            if (!summaryHost) return;
            if (!invalidEls.length) { summaryHost.innerHTML = ""; return; }

            const items = invalidEls.map((el, idx) => {
                if (!el.id) el.id = "ff_invalid_young_" + idx;
                return { id: el.id, step: getStepLabel(el), label: getFieldLabel(el) };
            });

            summaryHost.innerHTML = `
                <div class="ff-error-summary">
                    <div class="title">
                        <div>Needs attention before submit</div>
                        <div class="count">${items.length}</div>
                    </div>
                    <ul>
                        ${items.map(i => `<li><a href="#${i.id}" data-jump="${i.id}">${i.step}: ${i.label}</a></li>`).join('')}
                    </ul>
                </div>
            `;

            summaryHost.querySelectorAll('a[data-jump]').forEach(a => {
                a.addEventListener('click', function (e) {
                    e.preventDefault();
                    const id = a.getAttribute('data-jump');
                    const target = document.getElementById(id);
                    if (!target) return;

                    const stepEl = target.closest('.wizard-step');
                    if (stepEl) {
                        const idx = steps.indexOf(stepEl);
                        if (idx >= 0) showStep(idx);
                    }

                    setTimeout(() => {
                        target.scrollIntoView({ behavior: "smooth", block: "center" });
                        target.focus();
                    }, 80);
                });
            });
        }

        function getInvalidElements() {
            const all = Array.from(form.querySelectorAll("input, select, textarea"));
            return all.filter(el => !el.checkValidity());
        }

        function revealValidation() {
            clearVisualErrors();

            const invalidEls = getInvalidElements();
            invalidEls.forEach(el => markFieldInvalid(el, el.validationMessage || "Fix this field"));
            buildSummary(invalidEls);

            return invalidEls;
        }

        function focusFirstInvalid(invalidEls) {
            const firstInvalid = invalidEls[0];
            if (!firstInvalid) return;

            const stepEl = firstInvalid.closest('.wizard-step');
            if (stepEl) {
                const idx = steps.indexOf(stepEl);
                if (idx >= 0) showStep(idx);
            }

            setTimeout(() => {
                firstInvalid.scrollIntoView({ behavior: "smooth", block: "center" });
                firstInvalid.focus();
            }, 80);
        }

        // -----------------------------
        // SERVER-SIDE (ModelState) ERROR REVEAL
        // -----------------------------
        function revealServerModelStateErrors() {
            const invalidInputs = Array.from(form.querySelectorAll('.input-validation-error'));

            const msgSpans = Array.from(form.querySelectorAll('span.field-validation-error, span.text-danger'))
                .filter(s => s && s.getAttribute('data-valmsg-for') && (s.textContent || '').trim().length > 0);

            msgSpans.forEach(sp => {
                const key = sp.getAttribute('data-valmsg-for');
                if (!key) return;
                const el = form.querySelector(`[name="${CSS.escape(key)}"]`);
                if (el && !invalidInputs.includes(el)) invalidInputs.push(el);
            });

            if (!invalidInputs.length) return;

            clearVisualErrors();

            invalidInputs.forEach(el => {
                let msg = el.validationMessage || "Fix this field";
                const name = el.getAttribute('name');
                if (name) {
                    const span = form.querySelector(`span[data-valmsg-for="${CSS.escape(name)}"]`);
                    if (span && (span.textContent || '').trim().length) msg = span.textContent.trim();
                }
                markFieldInvalid(el, msg);
            });

            buildSummary(invalidInputs);
            focusFirstInvalid(invalidInputs);
        }

        // -----------------------------
        // Repeater (Add/Delete) + Reindex
        // -----------------------------
        function getNextIndex(listEl) {
            const items = listEl.querySelectorAll('.repeater-item');
            return items.length;
        }

        function reindexList(listEl) {
            const items = Array.from(listEl.querySelectorAll('.repeater-item'));
            items.forEach((item, newIdx) => {
                item.querySelectorAll('input[name], select[name], textarea[name]').forEach(ctrl => {
                    const name = ctrl.getAttribute('name');
                    if (!name) return;
                    const updated = name.replace(/\[\d+\]/, '[' + newIdx + ']');
                    ctrl.setAttribute('name', updated);
                });
            });
        }

        function addRepeaterItem(listId, templateId) {
            const listEl = document.getElementById(listId);
            const tpl = document.getElementById(templateId);
            if (!listEl || !tpl) return;

            const idx = getNextIndex(listEl);
            const html = tpl.innerHTML.replace(/__i__/g, String(idx));
            const wrap = document.createElement('div');
            wrap.innerHTML = html.trim();
            const node = wrap.firstElementChild;
            if (!node) return;

            listEl.appendChild(node);
        }

        function ensureAtLeastOne(listEl, templateId) {
            const count = listEl.querySelectorAll('.repeater-item').length;
            if (count > 0) return;
            addRepeaterItem(listEl.id, templateId);
        }

        root.addEventListener('click', function (e) {
            const addBtn = e.target.closest('[data-repeater-add]');
            if (addBtn) {
                const listId = addBtn.getAttribute('data-repeater-add');
                const tplId = addBtn.getAttribute('data-template');
                addRepeaterItem(listId, tplId);
                return;
            }

            const delBtn = e.target.closest('[data-repeater-del]');
            if (delBtn) {
                const item = delBtn.closest('.repeater-item');
                const listEl = item ? item.parentElement : null;
                if (!item || !listEl) return;

                item.remove();
                reindexList(listEl);

                const map = {
                    debtListYoung: "tplYoungDebt"
                };

                const tplId = map[listEl.id];
                if (tplId) ensureAtLeastOne(listEl, tplId);

                return;
            }
        });

        // -----------------------------
        // Wizard nav (Next/Back)
        // -----------------------------
        root.addEventListener('click', function (e) {
            const nextBtn = e.target.closest('[data-next]');
            const prevBtn = e.target.closest('[data-prev]');
            if (!nextBtn && !prevBtn) return;

            const idx = currentStepIndex();
            const current = steps[idx];

            if (nextBtn) {
                const requiredFields = Array.from(current.querySelectorAll("input, select, textarea"))
                    .filter(el => el.hasAttribute("required"));

                const invalidCurrent = requiredFields.filter(el => !el.checkValidity());

                if (invalidCurrent.length) {
                    clearVisualErrors();
                    invalidCurrent.forEach(el => markFieldInvalid(el, el.validationMessage || "Required — fix this"));
                    buildSummary(invalidCurrent);
                    focusFirstInvalid(invalidCurrent);
                    return;
                }

                showStep(Math.min(idx + 1, total - 1));
            }

            if (prevBtn) {
                showStep(Math.max(idx - 1, 0));
            }
        });

        function sanitizeNumericInputs() {
            form.querySelectorAll("input[type='number']").forEach(function (el) {
                if (!el.value) return;

                let v = el.value.trim();
                if (/^\(.*\)$/.test(v)) v = "-" + v.slice(1, -1);
                v = v.replace(/[$,%\s,]/g, "");
                v = v.replace(/[^\d.-]/g, "");
                el.value = v;
            });
        }

        form.addEventListener('input', function (e) {
            const el = e.target;
            if (!el || !(el.matches("input, select, textarea"))) return;

            if (el.checkValidity()) {
                const field = el.closest('.field') || el.closest('.checkline') || el.parentElement;
                if (field) {
                    field.classList.remove('ff-field-invalid');
                    const tag = field.querySelector('.ff-fix-tag');
                    if (tag) tag.remove();
                }
            }
        });

        form.addEventListener('submit', function (event) {
            sanitizeNumericInputs();

            const checkbox = document.getElementById('disclaimerCheckboxYoung');
            if (checkbox && !checkbox.checked) {
                event.preventDefault();
                clearVisualErrors();
                markFieldInvalid(checkbox, "Required — acknowledge to proceed");
                buildSummary([checkbox]);

                alert('Please acknowledge the disclaimer to proceed.');
                checkbox.scrollIntoView({ behavior: "smooth", block: "center" });
                checkbox.focus();
                return;
            }

            if (!form.checkValidity()) {
                event.preventDefault();
                const invalidEls = revealValidation();
                focusFirstInvalid(invalidEls);
            }
        });

        // Init wizard and reveal server-side errors
        showStep(0);
        setTimeout(revealServerModelStateErrors, 0);

    })();
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
