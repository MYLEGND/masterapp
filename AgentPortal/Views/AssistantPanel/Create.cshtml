@model AgentPortal.Models.CreateAssistantViewModel
@{
    ViewData["Title"] = "Add Assistant";
}

<link rel="stylesheet" href="~/css/legend-forms.css" asp-append-version="true" />

<div class="legend-shell legend-form">
    <div class="legend-hero">
        <div class="legend-hero-bar"></div>
        <div class="legend-hero-body">
            <span class="legend-kicker">Invite Assistant</span>
            <h2 class="legend-title">Add a new assistant to your workspace</h2>
            <p class="legend-sub">Assistants stay restricted to Leads and Workstation. Send a secure invite with their own identity.</p>
        </div>
    </div>

    <div class="row g-3 mt-3">
        <div class="col-lg-5">
            <div class="legend-card h-100">
                <div class="card-header">
                    <h5 class="m-0">How it works</h5>
                </div>
                <div class="card-body">
                    <ul class="mb-0" style="color:#0f172a; line-height:1.6;">
                        <li>Invitation is sent by email.</li>
                        <li>Assistant logs in with their own credentials.</li>
                        <li>Only Leads + Workstation are visible.</li>
                        <li>You can disable or remove access anytime.</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="legend-card h-100">
                <div class="card-header">
                    <h5 class="m-0">Assistant Details</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label fw-bold"></label>
                            <input asp-for="FirstName" class="form-control" placeholder="First name" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LastName" class="form-label fw-bold"></label>
                            <input asp-for="LastName" class="form-control" placeholder="Last name" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold"></label>
                            <input asp-for="Email" class="form-control" placeholder="name@domain.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="legend-btn-primary">Send Invite</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Back to Panel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
