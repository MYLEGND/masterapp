@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool isBusinessClient = User?.Claims?.Any(c => c.Type == "RecordType" && c.Value == "BusinessClient") == true;
    bool isAgent = User?.IsInRole("Agent") == true || User?.IsInRole("Admin") == true;
    bool showBookings = isAgent || isBusinessClient;
    var homeClientHubFlash = TempData.Peek("Created")?.ToString();
}

<div class="home-container">

    <!-- HERO -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Legend™ Legacy Protection</h1>
        <p class="lead mb-2">
            Your central hub for all tools, resources, and training
        </p>
        <hr class="my-3 hero-hr" />
    </div>

    @if (!string.IsNullOrWhiteSpace(homeClientHubFlash))
    {
        <div class="home-flash" role="status">@homeClientHubFlash</div>
    }

    <section class="home-command-strip mb-5" aria-label="Primary commands">
        <div class="home-command-copy">
            <div class="home-command-kicker">Private Client Access</div>
            <h2 class="home-command-title">View your plan, track your progress, and take the next step toward your financial goals—anytime.</h2>
        </div>
        <div class="home-command-actions">
            <button type="button" class="home-clients-trigger" id="homeClientsTrigger">Clients</button>
        </div>
    </section>

    <!-- FREQUENTLY USED TOOLS -->
    <section class="home-tools mb-5">
        <div class="home-tools-head">
            <div class="home-tools-copy">
                <h3 class="mb-0 fw-bold">Frequently Used Tools</h3>
            </div>
        </div>

        <div class="home-mini-tools-wrap">
            <div class="home-mini-tools">
                <a href="https://outlook.office.com" target="_blank" rel="noopener">
                    <img class="outlook-link" src="~/images/tools-icons/outlook2.png" alt="Outlook" />
                </a>
                <a href="https://outlook.office.com/calendar/view/workweek" target="_blank" rel="noopener">
                    <img class="outlook-link" src="~/images/tools-icons/calendar.png" alt="Outlook Calendar" />
                </a>
                @if (showBookings)
                {
                    <a href="https://outlook.office.com/bookings" target="_blank" rel="noopener">
                        <img class="outlook-link" src="~/images/tools-icons/bookings.png" alt="Bookings" />
                    </a>
                }
                <a href="https://teams.microsoft.com" target="_blank" rel="noopener">
                    <img class="outlook-link" src="~/images/tools-icons/teams.png" alt="Teams" />
                </a>
                <a href="https://m365.cloud.microsoft/chat/" target="_blank" rel="noopener">
                    <img class="outlook-link" src="~/images/tools-icons/copilot.png" alt="Copilot" />
                </a>
            </div>
        </div>

        <div class="d-flex flex-wrap justify-content-center home-tools-row frequent-tools-grid">

            @{
                var tools = new[]
                {
                    new { Name = "Term Life Quote", Url = "https://quote.ipipeline.com/LTsearch.aspx?GAID=5889", Icon = "ipipeline.png", Folder = "company-icons" },
                    new { Name = "Integrity Marketing (L&H CRM)", Url = "https://connect.integrity.com/agent/dashboard", Icon = "integrity.png", Folder = "company-icons" },
                    new { Name = "Exlynx AMS (P&C CRM)", Url = "https://app.ezlynx.com/auth/account/login", Icon = "ezlynx.png", Folder = "company-icons" },
                    new { Name = "SureLC (L&H Contracting)", Url = "https://accounts.surancebay.com/oauth/authorize?redirect_uri=https:%2F%2Fsurelc.surancebay.com%2Fproducer%2Foauth%3FreturnUrl%3D%252F%253FgaId%253D239&gaId=239&client_id=surecrmweb&response_type=code", Icon = "surelc.png", Folder = "company-icons" }
                };
            }

            @foreach (var tool in tools)
            {
                <a href="@tool.Url"
                   target="_blank"
                   rel="noopener"
                   class="dashboard-tool d-flex flex-column align-items-center justify-content-center">

                    <img src="@Url.Content($"~/images/{tool.Folder}/{tool.Icon}")"
                         alt="@tool.Name"
                         width="60"
                         height="60"
                         class="mb-2" />

                    <div class="fw-bold text-center mt-1">@tool.Name</div>
                </a>
            }
        </div>

        <div class="d-flex flex-wrap justify-content-center home-tools-row">

            @{
                var secondRowTools = new[]
                {
                    new { Name = "Final Expense Quote", Url = "https://fexquotes.com/wqt/v1/webrate.pl?id=126&fn=1&vrt=m&tgt=1&style=blue", Icon = "fex.png" },
                    new { Name = "Smart Choice (P&C)", Url = "https://commissions.smartchoiceagents.com/", Icon = "smartchoice.png" },
                    new { Name = "Carrier Website (L&H)", Url = "https://www.wmacorp.com/CarrierWebsites", Icon = "carrierweb.png" },
                    new { Name = "Western Marketing", Url = "https://www.wmacorp.com/", Icon = "westernmarketing.png" },
                };
            }

            @foreach (var tool in secondRowTools)
            {
                <a href="@tool.Url"
                   target="_blank"
                   rel="noopener"
                   class="dashboard-tool d-flex flex-column align-items-center justify-content-center">

                    <img src="@Url.Content($"~/images/company-icons/{tool.Icon}")"
                         alt="@tool.Name"
                         width="60"
                         height="60"
                         class="mb-2" />

                    <div class="fw-bold text-center mt-1">@tool.Name</div>
                </a>
            }
        </div>
    </section>

    <!-- ================================
         FACT FINDER QUICK ACCESS (NEW)
         Place UNDER all tools
    ================================= -->
    <section class="home-factfinder mt-5">
        <div class="ff-home-card">
            <div class="ff-home-top">
                <div class="ff-home-kicker">
                    <span class="ff-home-dot"></span>
                    Legend™ Intake
                </div>
                <h2 class="ff-home-title">Fact Finder — Quick Access</h2>
                <p class="ff-home-sub">
                    Choose the intake that matches the client’s stage. Answer what applies. Generate a clean PDF.
                </p>
            </div>

            <div class="ff-home-actions">
                <a class="ff-home-btn ff-home-btn-primary" href="@Url.Action("Index", "FactFinder")">
                    Open Fact Finder Hub →
                </a>
            </div>

            <div class="ff-home-grid">
                <a class="ff-home-tile" href="@Url.Action("Senior", "FactFinder")" aria-label="Open Senior Fact Finder">
                    <div class="ff-home-tile-top">
                        <div class="ff-home-tile-title">Senior</div>
                        <div class="ff-home-pill">Protection + Retirement</div>
                    </div>
                    <div class="ff-home-tile-desc ff-home-text-strong">
                        Income planning, Medicare risk, legacy decisions, protecting what they built.
                    </div>
                    <div class="ff-home-tile-cta">Start Senior →</div>
                </a>

                <a class="ff-home-tile" href="@Url.Action("MiddleAged", "FactFinder")" aria-label="Open Middle-Aged Fact Finder">
                    <div class="ff-home-tile-top">
                        <div class="ff-home-tile-title">Middle-Aged</div>
                        <div class="ff-home-pill">Family + Wealth Build</div>
                    </div>
                    <div class="ff-home-tile-desc ff-home-text-strong">
                        Kids + mortgage + peak earning years. Structure, protection, and growth.
                    </div>
                    <div class="ff-home-tile-cta">Start Middle-Aged →</div>
                </a>

                <a class="ff-home-tile" href="@Url.Action("Younger", "FactFinder")" aria-label="Open Younger Fact Finder">
                    <div class="ff-home-tile-top">
                        <div class="ff-home-tile-title">Younger</div>
                        <div class="ff-home-pill">Foundation + Direction</div>
                    </div>
                    <div class="ff-home-tile-desc ff-home-text-strong">
                        Cash flow, debt cleanup, habits, momentum, and a real plan.
                    </div>
                    <div class="ff-home-tile-cta">Start Younger →</div>
                </a>
            </div>
        </div>
    </section>

</div>

<div class="home-clients-hub" id="homeClientsHub" hidden
     data-lookup-url="@Url.Action("PortalQuickAccessClients", "Clients")"
     data-create-url="@Url.Action("Create", "Clients")"
     data-crm-url="@Url.Action("Index", "Clients")">
    <div class="home-clients-backdrop" id="homeClientsBackdrop"></div>
    <div class="home-clients-dialog" role="dialog" aria-modal="true" aria-labelledby="homeClientsTitle">
        <div class="home-clients-shell">
            <div class="home-clients-head">
                <div>
                    <div class="home-clients-kicker">Legend™ Client Access</div>
                    <h3 class="home-clients-title" id="homeClientsTitle">Clients</h3>
                    <p class="home-clients-sub">Search portal-enabled clients, reopen recent profiles fast, or launch the same create flow used in the Clients CRM page.</p>
                </div>
                <button type="button" class="home-clients-close" id="homeClientsClose" aria-label="Close client hub">×</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(homeClientHubFlash))
            {
                <div class="home-clients-banner">@homeClientHubFlash</div>
            }

            <div class="home-clients-toolbar">
                <div class="home-clients-search-wrap">
                    <span class="home-clients-search-icon">⌕</span>
                    <input id="homeClientsSearch"
                           class="home-clients-search"
                           type="search"
                           autocomplete="off"
                           placeholder="Search client name, email, or phone..."
                           aria-label="Search clients" />
                    <div class="home-clients-results" id="homeClientsResults" hidden></div>
                </div>
                <div class="home-clients-toolbar-actions">
                    <button type="button" class="home-clients-action home-clients-action-gold" id="homeClientsAdd">Add Lead / Client / Business Client</button>
                    <button type="button" class="home-clients-action home-clients-action-ghost" id="homeClientsOpenCrm">Open CRM</button>
                </div>
            </div>

            <div class="home-clients-result-status" id="homeClientsResultStatus" aria-live="polite"></div>

            <div class="home-clients-recent-head">
                <div>
                    <div class="home-clients-recent-title" id="homeClientsRecentHeading">Recently Viewed Clients</div>
                    <div class="home-clients-recent-sub" id="homeClientsRecentSub"></div>
                </div>
            </div>
            <div class="home-clients-recent-grid" id="homeClientsRecentGrid"></div>

            <!-- ── GLOBAL PROPOSALS ───────────────────────────────────── -->
            <div class="hp-proposals-section">
                <div class="hp-proposals-head">
                    <div>
                        <div class="hp-proposals-title">Proposals</div>
                        <div class="hp-proposals-sub">All saved proposals across every client — create, edit, and review from one place.</div>
                    </div>
                    <button type="button" class="home-clients-action home-clients-action-gold" id="hpBtnNew">+ New Proposal</button>
                </div>
                <div class="hp-proposals-list" id="hpProposalList">
                    <div class="home-clients-empty home-clients-empty-block">Loading proposals…</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ══ GLOBAL PROPOSAL BUILDER ══════════════════════════════════════════ -->
<div class="hp-overlay" id="hpProposalOverlay" hidden>
    <div class="hp-dialog" id="hpProposalDialog" role="dialog" aria-modal="true" aria-labelledby="hpProposalTitle">
        <div class="hp-dialog-head">
            <div class="hp-dialog-brand">
                <div class="hp-dialog-icon">📋</div>
                <div>
                    <div class="hp-dialog-title" id="hpProposalTitle">Proposal Builder</div>
                    <div class="hp-dialog-sub">Compare side-by-side options for any client</div>
                </div>
            </div>
            <button type="button" class="hp-dialog-close" data-hp-close aria-label="Close proposal builder">×</button>
        </div>

        <form id="hpProposalForm" class="hp-form">
            <div class="hp-form-meta">
                <label class="hp-field">
                    <span>Proposal Name</span>
                    <input id="hpPropName" name="hpPropName" placeholder="e.g. Smith Family — Final Expense" autocomplete="off" />
                </label>
                <label class="hp-field">
                    <span>Client Name</span>
                    <input id="hpLeadName" name="hpLeadName" placeholder="Client or lead full name" autocomplete="off" />
                </label>
                <div class="hp-form-actions">
                    <button type="submit" class="hp-btn hp-btn-gold" id="hpBtnSave">Save Proposal</button>
                    <button type="button" class="hp-btn hp-btn-ghost" data-hp-close>Cancel</button>
                </div>
            </div>

            <div class="hp-buckets">
                @for (var bi = 1; bi <= 3; bi++)
                {
                    <div class="hp-bucket" data-bucket="@bi">
                        <div class="hp-bucket-head">Option @bi</div>
                        <label class="hp-field">
                            <span>Carrier</span>
                            <select class="prop-carrier" id="hpCarrier@bi">
                                <option value="">Select carrier</option>
                                <optgroup label="Final Expense">
                                    <option>Mutual of Omaha (Living Promise)</option>
                                    <option>Royal Neighbors of America</option>
                                    <option>Americo Eagle</option>
                                    <option>Prosperity Life</option>
                                    <option>Aetna CVS / Accendo</option>
                                    <option>Liberty Bankers Life</option>
                                    <option>Kansas City Life</option>
                                    <option>Foresters PlanRight</option>
                                    <option>American Amicable</option>
                                    <option>Great Western (GI)</option>
                                    <option>Guarantee Trust Life (GI)</option>
                                </optgroup>
                                <optgroup label="Life Insurance">
                                    <option>Transamerica</option>
                                    <option>Banner Life</option>
                                    <option>Pacific Life</option>
                                    <option>North American</option>
                                    <option>Protective Life</option>
                                    <option>American National</option>
                                    <option>Nationwide</option>
                                    <option>Securian</option>
                                </optgroup>
                                <optgroup label="Disability">
                                    <option>Assurity</option>
                                    <option>Principal</option>
                                    <option>Guardian</option>
                                    <option>Ohio National</option>
                                </optgroup>
                                <optgroup label="Medicare">
                                    <option>Humana</option>
                                    <option>UnitedHealthcare</option>
                                    <option>Aetna</option>
                                    <option>Cigna</option>
                                    <option>Devoted Health</option>
                                </optgroup>
                                <option>Other</option>
                            </select>
                        </label>
                        <label class="hp-field">
                            <span>Type</span>
                            <select class="prop-type" id="hpType@bi">
                                <option value="">Select</option>
                                <option>Level</option>
                                <option>Graded</option>
                                <option>Guaranteed Issue</option>
                                <option>Term</option>
                                <option>Whole Life</option>
                                <option>IUL</option>
                                <option>Short-Term Disability</option>
                                <option>Long-Term Disability</option>
                                <option>Medicare Advantage</option>
                                <option>Medicare Supplement</option>
                            </select>
                        </label>
                        @for (var ri = 1; ri <= 3; ri++)
                        {
                            <div class="pb-row">
                                <label class="hp-field">
                                    <span>Death Benefit / Coverage @ri</span>
                                    <div class="hp-currency-wrap">
                                        <span class="hp-currency-sym">$</span>
                                        <input class="prop-benefit currency-input hp-currency-input" id="hpBenefit@bi@ri" inputmode="decimal" autocomplete="off" />
                                    </div>
                                </label>
                                <label class="hp-field">
                                    <span>Premium @ri</span>
                                    <div class="hp-currency-wrap">
                                        <span class="hp-currency-sym">$</span>
                                        <input class="prop-premium currency-input hp-currency-input" id="hpPremium@bi@ri" inputmode="decimal" autocomplete="off" />
                                        <span class="hp-currency-sfx">/mo</span>
                                    </div>
                                </label>
                            </div>
                        }
                    </div>
                }
            </div>
        </form>
    </div>
</div>

<style>
:root {
    --gold-color: #a68023;
    --gold-color-light: rgba(166,128,35,0.28);
    --navy-900: #0b1529;
    --navy-800: #0f1d38;
    --navy-700: #162445;
    --text-strong: #f8fafc;
    --text-muted: #cbd5e1;
}

.home-container {
    padding-top: 2rem;
    padding-bottom: 3rem;
    font-family: 'Inter', sans-serif;
    color: #0b1529;
    background: #fff;
}

.hero-hr {
    border-color: var(--gold-color);
    border-width: 2px;
    max-width: 800px;
    margin: 1rem auto 0;
}

/* ══ GLOBAL PROPOSALS — hub section ══════════════════════════════════════ */
.hp-proposals-section{
    margin-top: 2rem;
    padding-top: 1.6rem;
    border-top: 1px solid rgba(166,128,35,.22);
}
.hp-proposals-head{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:1.25rem;
    margin-bottom:1.1rem;
    flex-wrap:wrap;
}
.hp-proposals-title{
    font-size:1.06rem;
    font-weight:900;
    color:#f8fafc;
    margin-bottom:.2rem;
}
.hp-proposals-sub{
    color:#b9c5d8;
    font-weight:600;
    font-size:.92rem;
}
.hp-proposals-list{ min-height:3rem; }

/* ── proposal card grid ── */
.hp-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
    gap:.9rem;
}
.hp-card{
    border:1.5px solid rgba(166,128,35,.34);
    border-radius:18px;
    background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.03));
    padding:1rem 1.05rem;
    box-shadow:0 14px 28px rgba(0,0,0,.20);
    display:flex;
    flex-direction:column;
    gap:.55rem;
    transition:transform .14s ease,border-color .14s ease,box-shadow .14s ease;
}
.hp-card:hover{
    transform:translateY(-2px);
    border-color:rgba(221,180,87,.72);
    box-shadow:0 20px 36px rgba(0,0,0,.28);
}
.hp-card-top{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:.6rem;
}
.hp-card-name{
    font-weight:900;
    font-size:.97rem;
    color:#f8fafc;
    line-height:1.25;
    flex:1 1 auto;
    min-width:0;
    overflow:hidden;
    text-overflow:ellipsis;
    white-space:nowrap;
}
.hp-card-badge{
    flex-shrink:0;
    display:inline-flex;
    align-items:center;
    padding:.28rem .6rem;
    border-radius:999px;
    border:1px solid rgba(166,128,35,.4);
    background:rgba(166,128,35,.14);
    color:#f6e6b4;
    font-size:.72rem;
    font-weight:900;
    text-transform:uppercase;
    white-space:nowrap;
    max-width:130px;
    overflow:hidden;
    text-overflow:ellipsis;
}
.hp-card-date{
    color:#94a3b8;
    font-weight:600;
    font-size:.82rem;
}
.hp-card-actions{
    display:flex;
    gap:.6rem;
    margin-top:.25rem;
}

/* ══ PROPOSAL BUILDER OVERLAY ════════════════════════════════════════════ */
.hp-overlay{
    position:fixed;
    inset:0;
    z-index:3000;
    background:rgba(7,14,28,.72);
    backdrop-filter:blur(8px);
    display:flex;
    align-items:center;
    justify-content:center;
    padding:1.5rem 1rem;
}
.hp-overlay[hidden]{ display:none !important; }

body.hp-modal-open{ overflow:hidden; }

.hp-dialog{
    width:min(1380px,97vw);
    max-height:92vh;
    overflow:auto;
    border-radius:22px;
    border:1.8px solid rgba(166,128,35,.48);
    background:
        radial-gradient(900px 320px at 0% 0%, rgba(166,128,35,.14), transparent 55%),
        linear-gradient(180deg,rgba(11,21,41,.99),rgba(15,29,56,.99));
    color:#f8fafc;
    box-shadow:0 40px 100px rgba(0,0,0,.52);
    padding:1.6rem;
}

.hp-dialog-head{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:1rem;
    padding-bottom:1.2rem;
    border-bottom:1px solid rgba(166,128,35,.22);
    margin-bottom:1.35rem;
}
.hp-dialog-brand{
    display:flex;
    align-items:center;
    gap:.9rem;
}
.hp-dialog-icon{
    font-size:1.8rem;
    line-height:1;
    flex-shrink:0;
}
.hp-dialog-title{
    font-weight:950;
    font-size:1.55rem;
    color:#f4d890;
    line-height:1.15;
}
.hp-dialog-sub{
    color:#b9c5d8;
    font-weight:600;
    margin-top:.25rem;
}
.hp-dialog-close{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:44px;
    height:44px;
    border-radius:12px;
    border:1.5px solid rgba(166,128,35,.44);
    background:rgba(255,255,255,.05);
    color:#f8fafc;
    font-size:1.7rem;
    line-height:1;
    flex-shrink:0;
    transition:background .14s ease,border-color .14s ease;
}
.hp-dialog-close:hover{
    background:rgba(221,180,87,.16);
    border-color:#ddb457;
}

/* ── form ── */
.hp-form{
    display:flex;
    flex-direction:column;
    gap:1rem;
}
.hp-form-meta{
    display:flex;
    flex-wrap:wrap;
    gap:.9rem;
    align-items:flex-end;
    padding:.9rem;
    border-radius:16px;
    background:rgba(255,255,255,.04);
    border:1px solid rgba(166,128,35,.2);
}
.hp-form-actions{
    display:flex;
    gap:.75rem;
    flex-wrap:wrap;
    align-self:flex-end;
}
.hp-field{
    display:flex;
    flex-direction:column;
    gap:.45rem;
    flex:1 1 260px;
}
.hp-field span{
    font-size:.78rem;
    font-weight:900;
    letter-spacing:.06em;
    text-transform:uppercase;
    color:#f4d890;
}
.hp-field input,
.hp-field select{
    min-height:46px;
    border-radius:12px;
    border:1.5px solid rgba(166,128,35,.38);
    background:rgba(255,255,255,.07);
    color:#f8fafc;
    padding:0 .9rem;
    font-size:.95rem;
    font-weight:600;
    box-shadow:inset 0 1px 0 rgba(255,255,255,.05);
    transition:border-color .14s ease,box-shadow .14s ease;
}
.hp-field input::placeholder{ color:#64748b; }
.hp-field input:focus,
.hp-field select:focus{
    outline:none;
    border-color:#ddb457;
    box-shadow:0 0 0 3px rgba(221,180,87,.16);
}
.hp-field select option{ background:#0f1d38; color:#f8fafc; }

.hp-btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:46px;
    padding:0 1.1rem;
    border-radius:14px;
    font-weight:900;
    font-size:.95rem;
    letter-spacing:.01em;
    transition:transform .12s ease,box-shadow .12s ease,filter .12s ease;
}
.hp-btn-gold{
    background:linear-gradient(180deg,#f4dc98,#ddb457);
    color:#0b1529;
    border:1.6px solid #ddb457;
    box-shadow:0 10px 24px rgba(0,0,0,.22),inset 0 1px 0 rgba(255,255,255,.55);
}
.hp-btn-gold:hover{ filter:brightness(1.04); transform:translateY(-1px); }
.hp-btn-ghost{
    background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.03));
    color:#f8fafc;
    border:1.5px solid rgba(166,128,35,.44);
    box-shadow:0 8px 18px rgba(0,0,0,.16);
}
.hp-btn-ghost:hover{ border-color:rgba(221,180,87,.72); background:rgba(221,180,87,.14); }

/* ── buckets grid ── */
.hp-buckets{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
    gap:1rem;
}
.hp-bucket{
    border:1.5px solid rgba(166,128,35,.28);
    border-radius:18px;
    padding:1.1rem;
    background:linear-gradient(180deg,rgba(255,255,255,.06),rgba(255,255,255,.03));
    box-shadow:0 14px 32px rgba(0,0,0,.18);
    display:flex;
    flex-direction:column;
    gap:.75rem;
}
.hp-bucket-head{
    font-weight:900;
    font-size:1rem;
    color:#f4d890;
    letter-spacing:.04em;
    text-transform:uppercase;
    border-bottom:1px solid rgba(166,128,35,.22);
    padding-bottom:.55rem;
}

/* ── currency inputs ── */
.hp-currency-wrap{
    display:flex;
    align-items:center;
    gap:.4rem;
    min-height:46px;
    padding:0 .75rem;
    border-radius:12px;
    border:1.5px solid rgba(166,128,35,.5);
    background:linear-gradient(180deg,rgba(212,180,90,.22),rgba(166,128,35,.18));
    box-shadow:inset 0 2px 4px rgba(255,255,255,.08),inset 0 -2px 4px rgba(0,0,0,.18),0 8px 16px rgba(0,0,0,.14);
}
.hp-currency-sym{ font-weight:900; color:#f4d890; font-size:.95rem; flex-shrink:0; }
.hp-currency-sfx{ font-weight:800; color:#f4d890; font-size:.85rem; flex-shrink:0; }
.hp-currency-input{
    flex:1 1 auto;
    background:transparent !important;
    border:none !important;
    box-shadow:none !important;
    color:#f8fafc;
    font-weight:700;
    font-size:.95rem;
    min-width:0;
    padding:0;
}
.hp-currency-input:focus{ outline:none; }

@@media(max-width:900px){
    .hp-buckets{ grid-template-columns:1fr; }
    .hp-dialog{ padding:1.1rem; }
}
@@media(max-width:576px){
    .hp-grid{ grid-template-columns:1fr; }
    .hp-proposals-head{ flex-direction:column; align-items:flex-start; }
    .hp-proposals-head .home-clients-action{ width:100%; }
}

.home-flash{
    max-width: 980px;
    margin: 0 auto 1.25rem;
    padding: 12px 16px;
    border-radius: 14px;
    border: 1.5px solid rgba(166,128,35,.46);
    background: linear-gradient(180deg, rgba(166,128,35,.14), rgba(166,128,35,.06));
    color: var(--navy-900);
    font-weight: 800;
    box-shadow: 0 14px 28px rgba(0,0,0,.08);
}

.home-command-strip{
    max-width: 1180px;
    margin: 0 auto;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 2rem;
    padding: 1.85rem 2rem;
    border-radius: 22px;
    border: 1.8px solid rgba(166,128,35,.34);
    background:
        radial-gradient(900px 280px at 8% 0%, rgba(166,128,35,.12), transparent 58%),
        linear-gradient(180deg, rgba(11,21,41,.98), rgba(15,29,56,.98));
    color: var(--text-strong);
    box-shadow: 0 20px 44px rgba(0,0,0,.28);
}

.home-command-copy{
    max-width: 760px;
    display:grid;
    gap:.55rem;
}

.home-command-kicker{
    display:inline-flex;
    align-items:center;
    gap:.45rem;
    padding: .38rem .78rem;
    border-radius: 999px;
    border: 1px solid rgba(221,180,87,.44);
    background: linear-gradient(180deg, rgba(221,180,87,.16), rgba(221,180,87,.08));
    box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 8px 20px rgba(0,0,0,.16);
    font-size:.82rem;
    font-weight:900;
    letter-spacing:.09em;
    text-transform:uppercase;
    color:#e7c06d;
}

.home-command-title{
    margin:0;
    font-size:1.62rem;
    line-height:1.25;
    font-weight:950;
    color:var(--text-strong);
}

.home-command-sub{
    margin:0;
    max-width: 760px;
    color:#d7dfeb;
    font-weight:600;
    line-height:1.5;
}

.home-clients-trigger{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-width: 186px;
    min-height: 58px;
    padding: 0 1.5rem;
    border-radius: 18px;
    border: 2px solid var(--gold-color);
    background:
        linear-gradient(180deg, rgba(255,255,255,.34), rgba(255,255,255,0) 36%),
        linear-gradient(180deg, #f2d891, #ddb457);
    color: var(--navy-900);
    font-size: 1.02rem;
    font-weight: 950;
    letter-spacing: .02em;
    text-shadow: 0 1px 0 rgba(255,255,255,.22);
    box-shadow: 0 16px 34px rgba(0,0,0,.26), inset 0 1px 0 rgba(255,255,255,.55);
    transition: transform .15s ease, box-shadow .15s ease, filter .15s ease;
}

.home-clients-trigger:hover{
    transform: translateY(-2px);
    filter: brightness(1.05);
    box-shadow: 0 22px 46px rgba(0,0,0,.34), inset 0 1px 0 rgba(255,255,255,.62);
}

.home-clients-trigger:focus-visible{
    outline: none;
    box-shadow: 0 0 0 3px rgba(221,180,87,.30), 0 22px 46px rgba(0,0,0,.34), inset 0 1px 0 rgba(255,255,255,.62);
}

.home-clients-hub{
    position: fixed;
    inset: 0;
    z-index: 2100;
    opacity: 0;
    pointer-events: none;
    transition: opacity .18s ease;
}

.home-clients-hub.open{
    opacity: 1;
    pointer-events: auto;
}

.home-clients-backdrop{
    position: absolute;
    inset: 0;
    background: rgba(7, 12, 23, .68);
    backdrop-filter: blur(7px);
}

.home-clients-dialog{
    position: relative;
    z-index: 1;
    min-height: 100%;
    display:flex;
    align-items:center;
    justify-content:center;
    padding: 2rem 1rem;
}

.home-clients-shell{
    width: min(1160px, 100%);
    max-height: min(88vh, 980px);
    overflow: auto;
    border-radius: 26px;
    border: 1.8px solid rgba(166,128,35,.42);
    background:
        radial-gradient(840px 320px at 0% 0%, rgba(166,128,35,.14), transparent 55%),
        linear-gradient(180deg, rgba(11,21,41,.99), rgba(15,29,56,.99));
    color: var(--text-strong);
    box-shadow: 0 34px 90px rgba(0,0,0,.46);
    padding: 1.9rem;
}

.home-clients-head{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap: 1.25rem;
    padding-bottom: 1.15rem;
    border-bottom: 1px solid rgba(166,128,35,.18);
}

.home-clients-kicker{
    display:inline-flex;
    align-items:center;
    font-size:.8rem;
    font-weight:900;
    letter-spacing:.1em;
    text-transform:uppercase;
    color:#e7c06d;
}

.home-clients-title{
    margin:.45rem 0 .4rem;
    font-size:2rem;
    font-weight:950;
    line-height:1.15;
}

.home-clients-sub{
    margin:0;
    color:#d4dde9;
    font-weight:600;
    line-height:1.6;
    max-width: 820px;
}

.home-clients-close{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    border: 1.5px solid rgba(166,128,35,.44);
    background: rgba(255,255,255,.05);
    color:#f8fafc;
    font-size:1.6rem;
    line-height:1;
}

.home-clients-banner{
    margin-top: 1.2rem;
    padding: 1rem 1.1rem;
    border-radius: 14px;
    border: 1.5px solid rgba(166,128,35,.42);
    background: rgba(166,128,35,.12);
    color: #f8fafc;
    font-weight: 800;
}

.home-clients-toolbar{
    margin-top: 1.35rem;
    display:grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items:center;
}

.home-clients-search-wrap{
    position:relative;
    border-radius: 18px;
    border: 1.6px solid rgba(166,128,35,.34);
    background: linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.03));
    box-shadow: inset 0 1px 0 rgba(255,255,255,.05), 0 10px 24px rgba(0,0,0,.18);
    transition: border-color .15s ease, box-shadow .15s ease, background .15s ease;
}

.home-clients-search-wrap:focus-within{
    border-color: #ddb457;
    box-shadow: 0 0 0 3px rgba(221,180,87,.18), 0 14px 28px rgba(0,0,0,.20);
    background: linear-gradient(180deg, rgba(255,255,255,.09), rgba(255,255,255,.04));
}

.home-clients-search-icon{
    position:absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color:#d8b765;
    font-weight:900;
    pointer-events:none;
}

.home-clients-search{
    width:100%;
    min-height:58px;
    border-radius:18px;
    border:1px solid transparent;
    background: transparent;
    color:#f8fafc;
    padding: 0 1.1rem 0 2.95rem;
    font-size:1rem;
    font-weight:600;
    box-shadow: none;
}

.home-clients-search::placeholder{ color:#93a4bf; }

.home-clients-search:focus{
    outline:none;
    border-color: transparent;
    box-shadow: none;
}

.home-clients-toolbar-actions{
    display:flex;
    gap:.75rem;
    flex-wrap:wrap;
    justify-content:flex-end;
    align-items:center;
}

.home-clients-action{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height:56px;
    padding: 0 1.15rem;
    border-radius: 16px;
    border: 1.6px solid rgba(166,128,35,.5);
    font-weight: 900;
    letter-spacing:.01em;
    box-shadow: 0 10px 22px rgba(0,0,0,.16), inset 0 1px 0 rgba(255,255,255,.08);
    transition: transform .14s ease, box-shadow .14s ease, filter .14s ease, background .14s ease, border-color .14s ease;
}

.home-clients-action-gold{
    background: linear-gradient(180deg, #f4dc98, #ddb457);
    color: var(--navy-900);
    border-color: var(--gold-color);
}

.home-clients-action-ghost{
    background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
    color:#f8fafc;
}

.home-clients-action:hover{
    transform: translateY(-1px);
    box-shadow: 0 14px 28px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.10);
}

.home-clients-action-gold:hover{
    filter: brightness(1.04);
}

.home-clients-action-ghost:hover{
    border-color: rgba(221,180,87,.72);
    background: linear-gradient(180deg, rgba(221,180,87,.18), rgba(221,180,87,.08));
}

.home-clients-action:focus-visible{
    outline: none;
    box-shadow: 0 0 0 3px rgba(221,180,87,.24), 0 14px 28px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.10);
}

.home-clients-result-status{
    margin-top:1rem;
    min-height: 1.5rem;
    color:#d8e0ec;
    font-weight:600;
}

.home-clients-result-status[data-state="error"]{
    color:#f7c2bc;
}

.home-clients-results{
    position:absolute;
    top: calc(100% + .45rem);
    left: 0;
    right: 0;
    z-index: 4;
    display:flex;
    flex-direction:column;
    gap:.45rem;
    padding:.6rem;
    border-radius: 20px;
    border: 1.5px solid rgba(166,128,35,.38);
    background: linear-gradient(180deg, rgba(11,21,41,.995), rgba(15,29,56,.995));
    box-shadow: 0 24px 54px rgba(0,0,0,.34);
    max-height: 360px;
    overflow:auto;
}

.home-clients-recent-head{
    margin-top: 1.6rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(166,128,35,.22);
}

.home-clients-recent-title{
    font-size:1.06rem;
    font-weight: 900;
    color:#f8fafc;
}

.home-clients-recent-sub{
    margin-top:.2rem;
    color:#b9c5d8;
    font-weight:600;
}

.home-clients-recent-grid{
    margin-top:1rem;
    display:grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap:1rem;
}

.home-clients-card{
    text-align:left;
    width:100%;
    border-radius: 20px;
    border: 1.5px solid rgba(166,128,35,.34);
    background: linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.03));
    color:#f8fafc;
    padding: 1.1rem 1.05rem;
    box-shadow: 0 16px 34px rgba(0,0,0,.22);
    display:flex;
    flex-direction:column;
    transition: transform .14s ease, box-shadow .14s ease, border-color .14s ease;
}

.home-clients-card.is-result{
    padding: .9rem 1rem;
    border-radius: 16px;
    background: rgba(255,255,255,.035);
    box-shadow: none;
}

.home-clients-card:hover{
    transform: translateY(-2px);
    border-color: rgba(221,180,87,.72);
    box-shadow: 0 22px 40px rgba(0,0,0,.28);
}

.home-clients-card.is-result:hover{
    transform:none;
    box-shadow:none;
    background: rgba(221,180,87,.11);
}

.home-clients-card-top{
    display:flex;
    align-items:flex-start;
    justify-content:space-between;
    gap:.75rem;
    margin-bottom:.65rem;
}

.home-clients-card-title{
    font-size:1.02rem;
    font-weight:900;
    line-height:1.25;
}

.home-clients-card-badge{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:.3rem .55rem;
    border-radius:999px;
    border:1px solid rgba(166,128,35,.4);
    background: rgba(166,128,35,.14);
    color:#f6e6b4;
    font-size:.72rem;
    font-weight:900;
    text-transform:uppercase;
    white-space:nowrap;
}

.home-clients-card-meta{
    color:#d4dde9;
    font-weight:600;
    line-height:1.5;
    word-break: break-word;
}

.home-clients-card.is-result .home-clients-card-meta{
    font-size: .9rem;
}

.home-clients-card-cta{
    margin-top:1rem;
    color:#f2d891;
    font-weight:900;
}

.home-clients-card.is-result .home-clients-card-cta{
    margin-top:.55rem;
    font-size: .88rem;
}

.home-clients-card-actions{
    display:flex;
    flex-wrap:wrap;
    gap:.7rem;
    margin-top: .95rem;
}

.home-clients-card-action{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    min-height: 40px;
    padding: 0 .95rem;
    border-radius: 999px;
    border: 1px solid rgba(166,128,35,.42);
    background: rgba(255,255,255,.04);
    color:#f6e6b4;
    font-weight:800;
    box-shadow: none;
    transition: border-color .14s ease, background .14s ease, transform .14s ease;
}

.home-clients-card-action:hover{
    transform: translateY(-1px);
    border-color: rgba(221,180,87,.78);
    background: rgba(221,180,87,.12);
}

.home-clients-card-action.is-primary{
    background: linear-gradient(180deg, #f2d891, #ddb457);
    color:#081224;
    border-color:#ddb457;
}

.home-clients-card-action.is-primary:hover{
    background: linear-gradient(180deg, #efcf81, #d6ab48);
    border-color:#efcf81;
}

.home-clients-empty{
    padding: 1.05rem 1.15rem;
    border-radius: 18px;
    border: 1px dashed rgba(166,128,35,.35);
    color:#d4dde9;
    font-weight:600;
    background: rgba(255,255,255,.03);
}

.home-clients-empty-block{
    grid-column: 1 / -1;
}

.home-tools{
    padding: 1.45rem 1.25rem 1.6rem;
    background: var(--navy-800);
    border: 1.5px solid var(--gold-color);
    border-radius: 18px;
    box-shadow: 0 20px 40px rgba(0,0,0,.32), inset 0 0 0 1px rgba(255,255,255,.05);
    color: var(--text-strong);
}

/* ensure all key section shells stay navy (force) */
.home-tools,
.home-mini-tools,
.ff-home-card{
    background: var(--navy-800) !important;
    border: 2.2px solid var(--gold-color) !important;
    color: var(--text-strong) !important;
    box-shadow: 0 20px 40px rgba(0,0,0,.36), 0 0 0 2px rgba(166,128,35,.15);
}

.ff-home-text-strong{
    color: var(--navy-900) !important;
    font-weight: 700;
}

/* keep tool tiles readable on navy sections */
.home-tools .dashboard-tool{
    background: #fff;
    color: #0b1529;
    border-color: var(--gold-color);
    box-shadow: 0 10px 26px rgba(0,0,0,0.22);
}
.home-tools .dashboard-tool .tool-name,
.home-tools .dashboard-tool .tool-desc{
    color: #0b1529;
}
.home-tools .dashboard-tool:hover{
    color: #0b1529;
    box-shadow: 0 14px 32px rgba(0,0,0,0.28), 0 0 0 3px rgba(166,128,35,.18);
}

.home-tools-row {
    gap: 1.2rem 1.2rem;
}

.home-tools-row + .home-tools-row{
    margin-top: 1.85rem;
}

.home-mini-tools-wrap{
    width: 100%;
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
}

.home-mini-tools{
    border: 1.5px solid var(--gold-color);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    width: 360px;
    background: var(--navy-700);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    box-shadow: 0 12px 28px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,.08);
    color: var(--text-strong);
}

.home-mini-tools img.outlook-link{
    height: 36px;
    width: 36px;
    object-fit: contain;
    flex-shrink: 0;
    transition: transform .2s ease, opacity .2s ease;
}

.home-mini-tools img.outlook-link:hover{
    transform: translateY(-2px) scale(1.05);
    opacity: 0.9;
}

.home-tools-head{
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
}

.home-tools-copy{
    display: grid;
    gap: 0.25rem;
    text-align: center;
    justify-items: center;
    grid-column: 2;
    padding-top: .15rem;
}

.home-tools-sub{
    color: var(--text-muted);
    font-weight: 600;
    line-height: 1.45;
}

.frequent-tools-grid{
    align-items: stretch;
}

.dashboard-tool {
    width: 220px;
    height: 180px;
    border: 1.6px solid var(--gold-color);
    border-radius: 16px;
    padding: 1.25rem;
    text-decoration: none;
    color: #0b1529;
    font-weight: 700;
    background: #fff;
    box-shadow: 0 10px 26px rgba(0,0,0,0.22);
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease, border-color 0.3s ease;
}

.dashboard-tool:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 16px 36px rgba(0,0,0,0.34), 0 0 0 3px rgba(166,128,35,.18);
    background: #fff;
    border-color: #c79931;
    color: #0b1529;
}
.dashboard-tool:focus-visible {
    outline: 2px solid #ddb457;
    outline-offset: 3px;
    box-shadow: 0 16px 32px rgba(0,0,0,.32), 0 0 0 3px rgba(221,180,87,.32);
}
.dashboard-tool:active{
    transform: translateY(-2px);
    box-shadow: 0 10px 22px rgba(0,0,0,.26), 0 0 0 2px rgba(166,128,35,.24);
}

.btn-legend-store {
    grid-column: 3;
    justify-self: end;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    padding: 0.95rem 1.35rem;
    border: 2px solid var(--gold-color);
    border-radius: 16px;
    background: transparent;
    color: var(--text-strong);
    text-decoration: none;
    box-shadow: 0 8px 22px rgba(0,0,0,.22);
    transition: all 0.3s ease;
}

.btn-legend-store:hover {
    transform: translateY(-3px) scale(1.04);
    box-shadow: 0 12px 28px rgba(0,0,0,.28);
    background: linear-gradient(135deg, rgba(166,128,35,.14), transparent);
}

@@media (max-width: 992px) {
    .home-command-strip{
        flex-direction: column;
        align-items:flex-start;
        padding: 1.45rem 1.35rem;
    }

    .home-command-actions{
        width:100%;
    }

    .home-clients-trigger{
        width:100%;
    }

    .home-clients-toolbar,
    .home-clients-results,
    .home-clients-recent-grid{
        grid-template-columns: 1fr;
    }

    .home-clients-toolbar-actions{
        justify-content:stretch;
    }

    .home-clients-action{
        flex:1 1 auto;
    }

    .home-tools{
        padding: 1.2rem 1rem 1.35rem;
    }

    .dashboard-tool { width: 200px; height: 160px; }
    .home-tools-head{
        grid-template-columns: 1fr;
    }

    .home-tools-copy,
    .btn-legend-store{
        grid-column: auto;
    }

    .btn-legend-store{
        justify-self: center;
    }

    .home-tools-row{
        gap: 1rem;
    }

    .home-tools-row + .home-tools-row{
        margin-top: 1.5rem;
    }
}

@@media (max-width: 576px) {
    .home-command-strip{
        padding: 1.05rem 1rem;
    }

