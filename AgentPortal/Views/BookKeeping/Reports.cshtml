@model AgentPortal.Models.BookKeepingReportsVm
@using Domain.Entities
@using System.Globalization

@{
    ViewData["Title"] = "Reports";
    var clientUserId = ((string)(ViewBag.ClientUserId ?? "")).Trim();
    var workspaceName = ((string)(ViewBag.ClientDisplayName ?? "")).Trim();
    var hasClientContext = !string.IsNullOrWhiteSpace(clientUserId);

    Layout = hasClientContext
        ? "~/Views/Shared/_ClientWorkspaceLayout.cshtml"
        : "~/Views/Shared/_Layout.cshtml";

    if (string.IsNullOrWhiteSpace(workspaceName))
    {
        workspaceName = hasClientContext ? "Client Workspace" : "My Book Keeping";
    }

    var m = Model;
    var taxReserve = m.TaxReserve;

    // ✅ SINGLE SOURCE OF TRUTH: range from controller
    var rangeStart = m.StartDate.Date;
    var rangeEnd = m.EndDate.Date;

    // Pull entries inside the range (inclusive)
    var entries = (m.Entries ?? Enumerable.Empty<BookkeepingEntry>())
        .Where(e => e.EntryDate.Date >= rangeStart && e.EntryDate.Date <= rangeEnd)
        .OrderBy(e => e.EntryDate)
        .ToList();

    // Build month list based on range
    var monthCursor = new DateTime(rangeStart.Year, rangeStart.Month, 1);
    var monthEndCap = new DateTime(rangeEnd.Year, rangeEnd.Month, 1);

    // Precompute month entry-expenses for proportional recurring allocation
    var monthExpenseMap = new Dictionary<string, decimal>(); // yyyy-MM -> entry expenses sum
    var monthIncomeMap = new Dictionary<string, decimal>();  // yyyy-MM -> entry income sum
    var months = new List<DateTime>();

    while (monthCursor <= monthEndCap)
    {
        months.Add(monthCursor);
        var key = monthCursor.ToString("yyyy-MM");

        var monthEntries = entries.Where(e => e.EntryDate.Year == monthCursor.Year && e.EntryDate.Month == monthCursor.Month).ToList();

        var inc = monthEntries.Where(e => e.Type == BookkeepingEntryType.Income).Sum(e => e.Amount);
        var exp = monthEntries.Where(e => e.Type == BookkeepingEntryType.Expense).Sum(e => e.Amount);

        monthIncomeMap[key] = inc;
        monthExpenseMap[key] = exp;

        monthCursor = monthCursor.AddMonths(1);
    }

    var totalEntryExpensesInRange = monthExpenseMap.Values.Sum();
    var recurringTotal = m.RecurringInRangeTotal;

    decimal AllocRecurringForMonth(string key)
    {
        if (recurringTotal <= 0m) return 0m;
        if (totalEntryExpensesInRange <= 0m) return 0m;

        var monthExp = monthExpenseMap.ContainsKey(key) ? monthExpenseMap[key] : 0m;
        if (monthExp <= 0m) return 0m;

        var share = recurringTotal * (monthExp / totalEntryExpensesInRange);
        return Math.Round(share, 2);
    }

    var allocMap = new Dictionary<string, decimal>();
    if (recurringTotal > 0m && totalEntryExpensesInRange > 0m)
    {
        decimal running = 0m;
        for (int i = 0; i < months.Count; i++)
        {
            var key = months[i].ToString("yyyy-MM");
            var isLast = (i == months.Count - 1);

            if (isLast)
            {
                var remainder = Math.Round(recurringTotal - running, 2);
                allocMap[key] = remainder < 0m ? 0m : remainder;
            }
            else
            {
                var v = AllocRecurringForMonth(key);
                allocMap[key] = v;
                running += v;
            }
        }
    }
    else
    {
        foreach (var dt in months)
        {
            allocMap[dt.ToString("yyyy-MM")] = 0m;
        }
    }
}

<style>
:root{
    --gold:#a68023;
    --goldSoft: rgba(166,128,35,.14);
    --ink:#0f0f12;
    --muted: rgba(15,15,18,.62);
    --border: rgba(15,15,18,.12);
    --card:#fff;
    --shadow: 0 18px 46px rgba(0,0,0,.10);
    --shadowSoft: 0 12px 28px rgba(0,0,0,.08);
    --radius: 18px;

    --good:#1a7f37;
    --bad:#b42318;
    --warn:#b47b18;
}

.bk-wrap{ max-width:1180px; margin:0 auto; padding:26px 18px 44px; }
.bk-card{ background:var(--card); border:1px solid var(--border); border-radius:var(--radius); box-shadow:var(--shadow); overflow:hidden; }
.bk-card::before{ content:""; display:block; height:3px; background:linear-gradient(90deg, transparent, var(--gold), transparent); opacity:.95; }

.bk-head{
    padding:18px 18px 14px;
    border-bottom:1px solid rgba(0,0,0,.08);
    display:flex; align-items:flex-end; justify-content:space-between;
    gap:14px; flex-wrap:wrap;
    background: rgba(166,128,35,.04);
}
.bk-title{ margin:0; font-size:1.9rem; font-weight:950; letter-spacing:.2px; line-height:1.1; }
.bk-sub{ margin:6px 0 0; color:var(--muted); font-weight:650; font-size:.98rem; }
.bk-body{ padding:18px; }

.kpis{ display:grid; grid-template-columns:repeat(4, minmax(0,1fr)); gap:12px; }
@@media (max-width:980px){ .kpis{ grid-template-columns:repeat(2, minmax(0,1fr)); } }
@@media (max-width:520px){ .kpis{ grid-template-columns:1fr; } }

.kpi{
    border: 1px solid rgba(166,128,35,.22);
    background: linear-gradient(180deg, rgba(166,128,35,.10), rgba(255,255,255,.96));
    border-radius:18px;
    box-shadow:var(--shadowSoft);
    padding:14px;
}
.kpi .label{ color:var(--muted); font-weight:800; letter-spacing:.2px; font-size:.90rem; }
.kpi .value{ font-weight:950; font-size:1.35rem; letter-spacing:.2px; margin-top:6px; }
.kpi .hint{ margin-top:4px; color: rgba(0,0,0,.55); font-weight:650; font-size:.86rem; }

.kpi-income .value{ color:var(--good); }
.kpi-expenses .value{ color:var(--bad); }
.kpi-profit-positive .value{ color:var(--good); }
.kpi-profit-negative .value{ color:var(--bad); }
.kpi-tax .value{ color:var(--warn); }

.btnx{
    display:inline-flex; align-items:center; justify-content:center; gap:10px;
    padding:10px 14px; border-radius:14px;
    border:1px solid var(--border);
    background:#fff; color:var(--ink);
    font-weight:900; text-decoration:none; cursor:pointer;
    box-shadow:0 10px 22px rgba(0,0,0,.05);
    transition: transform .14s ease, box-shadow .14s ease, border-color .14s ease;
    white-space:nowrap;
}
.btnx:hover{ transform:translateY(-1px); border-color:rgba(166,128,35,.55); box-shadow:0 16px 32px rgba(0,0,0,.09); }

.hr{ height:1px; background:rgba(166,128,35,.22); margin:14px 0; border-radius:999px; }

.table{
    width:100%;
    border-collapse:separate;
    border-spacing:0;
    overflow:hidden;
    border-radius:14px;
    border:1px solid rgba(0,0,0,.10);
}
.table th{
    text-align:left;
    font-weight:950;
    padding:10px 12px;
    border-bottom:1px solid rgba(0,0,0,.08);
    background: rgba(166,128,35,.06);
}
.table td{
    padding:10px 12px;
    border-bottom:1px solid rgba(0,0,0,.06);
    font-weight:650;
    color: rgba(0,0,0,.74);
    vertical-align:middle;
}
.table tr:last-child td{ border-bottom:0; }

.mono{ font-variant-numeric: tabular-nums; }
.right{ text-align:right; }

.amt-income{ color:var(--good); font-weight:950; }
.amt-expense{ color:var(--bad); font-weight:950; }
.panel-title{ margin:0; font-weight:950; letter-spacing:.2px; color:var(--ink); }

.month-head{
    display:flex;
    align-items:flex-end;
    justify-content:space-between;
    gap:12px;
    flex-wrap:wrap;
    margin:0 0 10px;
}
.month-kpis{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
}
.month-pill{
    border:1px solid rgba(0,0,0,.10);
    background:#fff;
    border-radius:999px;
    padding:6px 10px;
    box-shadow:0 10px 22px rgba(0,0,0,.05);
    font-weight:900;
    color:rgba(0,0,0,.78);
    white-space:nowrap;
    font-size:.88rem;
}
.month-pill .v{ font-variant-numeric: tabular-nums; margin-left:6px; }
.month-pill.income{ border-color: rgba(26,127,55,.22); }
.month-pill.expense{ border-color: rgba(180,35,24,.22); }
.month-pill.net{ border-color: rgba(166,128,35,.22); }
</style>

<div class="bk-wrap">
    <div class="bk-card">
        <div class="bk-head">
            <div>
                <h2 class="bk-title">Reports</h2>
                <p class="bk-sub">
                    Year-to-date summary (@m.StartDate.ToString("MM/dd/yyyy") — @m.EndDate.ToString("MM/dd/yyyy"))
                </p>
            </div>
            <a class="btnx" asp-controller="BookKeeping" asp-action="Index" asp-route-clientUserId="@clientUserId">Back</a>
        </div>

        <div class="bk-body">

            <div class="kpis">
                <div class="kpi kpi-income">
                    <div class="label">Income (YTD)</div>
                    <div class="value mono">@m.IncomeYtd.ToString("C")</div>
                    <div class="hint">All income entries this year</div>
                </div>

                <div class="kpi kpi-expenses">
                    <div class="label">Expenses (YTD)</div>
                    <div class="value mono">@m.ExpensesYtd.ToString("C")</div>
                    <div class="hint">Includes @m.RecurringInRangeTotal.ToString("C") recurring occurrences</div>
                </div>

                <div class="kpi @(m.NetYtd >= 0 ? "kpi-profit-positive" : "kpi-profit-negative")">
                    <div class="label">Net Profit (YTD)</div>
                    <div class="value mono">@m.NetYtd.ToString("C")</div>
                    <div class="hint">Income minus expenses (all-in)</div>
                </div>

                <div class="kpi kpi-tax">
                    <div class="label">Tax Reserve (YTD)</div>
                    <div class="value mono">@taxReserve.ToString("C")</div>
                    <div class="hint">
                        Fed <span class="mono">@m.FederalIncomeTaxYtd.ToString("C")</span> •
                        SE <span class="mono">@m.SelfEmploymentTaxYtd.ToString("C")</span> •
                        AZ <span class="mono">@m.ArizonaTaxYtd.ToString("C")</span> •
                        Eff <span class="mono">@((m.EffectiveTaxRateYtd * 100m).ToString("0.0"))%</span>
                    </div>
                </div>
            </div>

            <div class="hr"></div>

            <h3 class="panel-title" style="margin:0 0 10px;">
                YTD Entries (@rangeStart.ToString("MMMM yyyy") — @rangeEnd.ToString("MMMM yyyy"))
            </h3>

            @foreach (var md in months)
            {
                var monthKey = md.ToString("yyyy-MM");
                var monthName = md.ToString("MMMM yyyy");

                var monthEntries = entries
                    .Where(e => e.EntryDate.Year == md.Year && e.EntryDate.Month == md.Month)
                    .ToList();

                var monthIncome = monthIncomeMap.ContainsKey(monthKey) ? monthIncomeMap[monthKey] : 0m;
                var monthEntryExpenses = monthExpenseMap.ContainsKey(monthKey) ? monthExpenseMap[monthKey] : 0m;

                // ✅ allocated recurring for month (truthful reconciliation with YTD)
                var monthRecurring = allocMap.ContainsKey(monthKey) ? allocMap[monthKey] : 0m;

                var monthAllInExpenses = monthEntryExpenses + monthRecurring;
                var monthNet = monthIncome - monthAllInExpenses;

                <div class="hr"></div>

                <div class="month-head">
                    <h3 class="panel-title">@monthName</h3>

                    <div class="month-kpis">
                        <div class="month-pill income">
                            Income <span class="v amt-income">@monthIncome.ToString("C")</span>
                        </div>
                        <div class="month-pill expense">
                            Expenses <span class="v amt-expense">@((-monthAllInExpenses).ToString("C"))</span>
                        </div>
                        <div class="month-pill net">
                            Net <span class="v @(monthNet >= 0 ? "amt-income" : "amt-expense")">@monthNet.ToString("C")</span>
                        </div>
                    </div>
                </div>

                <table class="table">
                    <thead>
                        <tr>
                            <th style="width:110px;">Date</th>
                            <th>Item</th>
                            <th style="width:160px;">Category</th>
                            <th style="width:120px;">Type</th>
                            <th class="right" style="width:160px;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!monthEntries.Any() && monthRecurring <= 0m)
                        {
                            <tr>
                                <td class="mono">—</td>
                                <td colspan="3" style="color:rgba(0,0,0,.55); font-weight:750;">No activity for @monthName</td>
                                <td class="right mono">—</td>
                            </tr>
                        }
                        else
                        {
                            // ✅ Add a recurring row so month table reconciles to the month KPI
                            if (monthRecurring > 0m)
                            {
                                <tr>
                                    <td class="mono">@((new DateTime(md.Year, md.Month, DateTime.DaysInMonth(md.Year, md.Month))).ToString("MM/dd/yyyy"))</td>
                                    <td>Recurring occurrences (allocated)</td>
                                    <td>—</td>
                                    <td>Expense</td>
                                    <td class="right mono amt-expense">@((-monthRecurring).ToString("C"))</td>
                                </tr>
                            }

                            foreach (var x in monthEntries)
                            {
                                var isExpense = x.Type == BookkeepingEntryType.Expense;
                                var signed = isExpense ? -x.Amount : x.Amount;

                                <tr>
                                    <td class="mono">@x.EntryDate.ToString("MM/dd/yyyy")</td>
                                    <td>@(string.IsNullOrWhiteSpace(x.Notes) ? x.Type.ToString() : x.Notes)</td>
                                    <td>@x.Category</td>
                                    <td>@x.Type</td>
                                    <td class="right mono @(isExpense ? "amt-expense" : "amt-income")">@signed.ToString("C")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            }

        </div>
    </div>
</div>
