@model Domain.Entities.OnboardingSubmission
@{
    ViewData["Title"] = "Onboarding Submitted";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/legend-forms.css" asp-append-version="true" />
<style>
    .legend-card { border: 1.5px solid #d7dae3; border-radius: 18px; box-shadow: 0 12px 26px rgba(15,23,42,.10); overflow:hidden; }
    .legend-card .card-body { color: #0f172a; }
    .legend-hero .legend-sub { color: #1f2937 !important; }
</style>

<div class="legend-shell legend-form">
    <div class="legend-hero">
        <div class="legend-hero-bar"></div>
        <div class="legend-hero-body">
            <span class="legend-kicker">Onboarding</span>
            <h2 class="legend-title">Thank you, @Model.FirstName</h2>
            <p class="legend-sub">Your onboarding packet has been received.</p>
        </div>
    </div>

    <div class="legend-card mt-3">
        <div class="card-body">
            <div class="alert alert-success mb-3">
                <strong>Onboarding submitted.</strong> We’ll review your information and follow up if anything else is needed.
            </div>
            <p class="mb-0">Submission time: @Model.SubmittedUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
        </div>
    </div>
</div>
