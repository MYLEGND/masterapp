@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    // Highlight and scroll to first missing required acknowledgment
    document.querySelector('form').addEventListener('submit', function(e) {
        var firstError = document.querySelector('.required-ack:invalid');
        if (firstError) {
            e.preventDefault();
            firstError.closest('.form-check').classList.add('border', 'border-danger', 'rounded', 'p-2');
            firstError.focus();
            firstError.scrollIntoView({behavior: 'smooth', block: 'center'});
        }
    });
    // Remove highlight on change
    document.querySelectorAll('.required-ack').forEach(function(box) {
        box.addEventListener('change', function() {
            if (box.checked) {
                box.closest('.form-check').classList.remove('border', 'border-danger', 'rounded', 'p-2');
            }
        });
    });

    // Mailing address copy helper
    (function() {
        const copyBox = document.getElementById('copyHomeToMailing');
        const mailing = document.getElementById('MailingAddress');
        const home = document.getElementById('CurrentAddress');
        const mailingBlock = document.querySelector('.mailing-address-block');
        if (!copyBox || !mailing || !home) return;

        function sync() {
            if (copyBox.checked) {
                mailing.value = home.value;
                mailing.setAttribute('readonly', 'readonly');
                if (mailingBlock) mailingBlock.style.display = 'none';
            } else {
                mailing.removeAttribute('readonly');
                if (mailingBlock) mailingBlock.style.display = '';
            }
        }
        copyBox.addEventListener('change', sync);
        home.addEventListener('input', () => copyBox.checked && sync());
        sync();
    })();
    </script>
}
