@model AgentPortal.Models.EditClientViewModel

@{
    Layout = "~/Views/Shared/_ClientWorkspaceLayout.cshtml";
    ViewData["Title"] = ViewData["Title"] ?? "Edit Client";

    var clientUserId = Model?.ClientUserId ?? "";
    var recordTypeLabel = Model?.RecordType == "BusinessClient" ? "Business Client" : (Model?.RecordType == "Client" ? "Client" : "Lead");
    var recordTypeHelp = Model?.HasPortalAccess == true
        ? "Portal-enabled records can switch between Client and Business Client here."
        : "Leads stay as leads here. Use Quick View conversion to enable Client or Business Client access.";
    var hasPortalAccess = Model?.HasPortalAccess == true;

    ViewBag.ClientUserId = Model?.ClientUserId;
    ViewBag.ClientDisplayName = $"{Model?.FirstName} {Model?.LastName}".Trim();
    ViewBag.ClientRecordType = Model?.RecordType;

    var returnUrl =
        (string?)ViewBag.ReturnUrl
        ?? Context.Request.Query["returnUrl"].ToString()
        ?? Url.Action("Edit", "Clients", new { clientUserId = Model?.ClientUserId })
        ?? "/Clients";
}

<style>
    :root{
        --navy-950:#050b16;
        --navy-900:#081224;
        --navy-850:#0b1529;
        --navy-820:#0f1b30;
        --gold:#a68023;
        --gold-deep:#8f6b14;
        --gold-bright:#ddb85d;
        --goldSoft: rgba(166,128,35,.18);
        --ink:#f8fafc;
        --muted: rgba(212,221,233,.82);
        --border: rgba(166,128,35,.56);
        --card:rgba(11,21,41,.96);
        --card-soft:rgba(15,27,48,.94);
        --shadow: 0 28px 62px rgba(0,0,0,.34);
        --radius: 28px;
    }

    body { color:var(--ink); font-family:'Inter', sans-serif; }

    .page-wrap{
        max-width: 1040px;
        margin: 0 auto;
        padding: 28px 18px 42px;
    }

    .card{
        background: #0b1529;
        border: 1.5px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        overflow: hidden;
        position:relative;
    }

    .card::before{
        content:"";
        position:absolute;
        top:0;
        left:0;
        right:0;
        height: 5px;
        background: linear-gradient(90deg, var(--gold-deep), var(--gold) 34%, var(--gold-bright) 58%, var(--gold) 78%, var(--gold-deep));
        opacity:1;
    }

    .card-header{
        padding: 24px;
        border-bottom: 1px solid rgba(255,255,255,.10);
        display:flex;
        align-items:flex-end;
        justify-content:space-between;
        gap: 18px;
        flex-wrap: wrap;
        background: linear-gradient(135deg,#0f172a,#1e293b);
        box-shadow: inset 0 -1px 0 rgba(255,255,255,.05);
    }

    .eyebrow{
        display:inline-flex;
        align-items:center;
        gap:.45rem;
        margin-bottom:.8rem;
        padding:.38rem .72rem;
        border-radius:999px;
        border:1px solid rgba(255,255,255,.26);
        background: rgba(255,255,255,.12);
        color:#e2e8f0;
        font-size:.76rem;
        font-weight:900;
        letter-spacing:.12em;
        text-transform:uppercase;
    }

    .title{
        margin:0;
        font-size: 2rem;
        font-weight: 900;
        letter-spacing: .2px;
        line-height: 1.1;
        color:#ffffff;
    }

    .subtitle{
        margin-top: .65rem;
        margin-bottom: 0;
        color: #cbd5e1;
        font-weight: 650;
        font-size: 1rem;
        max-width: 720px;
        line-height: 1.6;
    }

    .card-body{
        padding: 24px;
    }

    .gold-rule{
        height: 1px;
        background: rgba(166,128,35,.22);
        margin: 20px 0;
        border-radius: 999px;
    }

    .label{
        font-weight: 900;
        color: #fdfdfd;
        letter-spacing: .2px;
        margin-bottom: 6px;
    }

    .input{
        border: 1.5px solid var(--border);
        border-radius: 16px;
        padding: .82rem .95rem;
        font-weight: 750;
        transition: box-shadow .14s ease, border-color .14s ease;
        width:100%;
        background: #0f1b30;
        color:#f8fafc;
        outline:none;
        box-shadow: inset 0 1px 4px rgba(0,0,0,.35);
    }

    .input:focus{
        border-color: var(--gold-bright);
        box-shadow: 0 0 0 .2rem rgba(166,128,35,.24);
    }

    .validation{
        font-weight: 800;
    }

    .summary{
        border: 1px solid rgba(220,53,69,.28);
        background: rgba(220,53,69,.08);
        border-radius: 16px;
        padding: .9rem 1rem;
        margin-bottom: 14px;
        font-weight: 750;
        color:#ffd5d0;
    }

    .btn{
        display:inline-flex;
        align-items:center;
        justify-content:center;
        gap: 10px;
        min-height: 46px;
        padding: 10px 16px;
        border-radius: 16px;
        border: 1.5px solid rgba(166,128,35,.52);
        background:rgba(255,255,255,.04);
        color: #f6e6b4;
        font-weight: 900;
        text-decoration:none;
        cursor:pointer;
        transition: transform .14s ease, box-shadow .14s ease, border-color .14s ease;
        white-space: nowrap;
    }

    .btn:hover{
        transform: translateY(-1px);
        border-color: rgba(221,180,87,.9);
        box-shadow: 0 14px 28px rgba(0,0,0,.24);
    }

    .btn-gold{
        background: rgba(255,255,255,.04);
        color:#f6e6b4;
    }

    .btn-solid{
        border: 1.5px solid var(--gold-deep);
        background: linear-gradient(180deg, #f2d891, #ddb457);
        color:#081224;
        text-shadow: 0 1px 0 rgba(92,67,10,.22);
        box-shadow: 0 18px 34px rgba(143,107,20,.28);
    }

    .btn-solid:hover{
        background: linear-gradient(180deg, #efcf81, #d6ab48);
        border-color: #efcf81;
        box-shadow: 0 22px 38px rgba(143,107,20,.34);
    }

    .btn-outline{
        background: rgba(255,255,255,.03);
        color: #f6e6b4;
    }

    .btn-outline:hover{
        background: rgba(255,255,255,.06);
        color: #fff0c9;
    }

    .grid{
        display:grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .note{
        color: var(--muted);
        font-weight: 700;
        font-size: .92rem;
        margin: 4px 0 0;
    }

    .subcard{
        border: 1px solid rgba(166,128,35,.28);
        background: linear-gradient(180deg, rgba(15,27,48,.95), rgba(11,21,41,.94));
        border-radius: 22px;
        padding: 18px;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.03);
    }

    .input::placeholder{
        color:#9eb0ca;
    }

    .input option{
        background:#0f1b30;
        color:#f8fafc;
    }

    .subcard-top{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 10px;
    }

    .section-title{
        font-weight: 950;
        letter-spacing: .25px;
        color: #f2d891;
        margin: 0;
        font-size: 1.05rem;
    }

    .pill{
        border-radius: 999px;
        padding: 6px 12px;
        font-weight: 950;
        border: 1px solid rgba(166,128,35,.4);
        background: rgba(166,128,35,.14);
        color: #f6e6b4;
        white-space: nowrap;
    }

    .record-types{
        display:grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
    }

    .record-option{
        display:flex;
        align-items:center;
        gap: 10px;
        min-height: 54px;
        padding: 0 14px;
        border: 1px solid rgba(166,128,35,.38);
        border-radius: 16px;
        background: linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.025));
        color:#f8fafc;
        font-weight: 800;
        cursor: pointer;
        transition: border-color .14s ease, box-shadow .14s ease, background .14s ease;
    }

    .record-option:has(input:checked){
        border-color: var(--gold-bright);
        box-shadow: 0 0 0 2px rgba(166,128,35,.14);
        background: linear-gradient(180deg, rgba(221,180,87,.20), rgba(255,255,255,.05));
    }

    .record-option.is-disabled{
        opacity:.58;
        cursor:not-allowed;
    }

    .record-option input{
        accent-color: var(--gold);
    }

    @@media (max-width: 720px){
        .grid,
        .record-types{ grid-template-columns: 1fr; }

        .card-header,
        .card-body{ padding:20px; }
    }

    .full{ grid-column: 1 / -1; }

    .actions{
        display:flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 16px;
    }
</style>

<div class="page-wrap">
    <div class="card">
        <div class="card-header">
            <div>
                <div class="eyebrow">Private client editing</div>
                <h2 class="title">Edit @recordTypeLabel</h2>
                <p class="subtitle">Update this record from the same client-ready experience used on the home hub, then return without opening the full CRM board.</p>
            </div>
            <a href="@returnUrl" class="btn btn-gold">← Back</a>
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post" novalidate>
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="ClientUserId" />
                <input type="hidden" asp-for="IsDobLocked" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                <div asp-validation-summary="ModelOnly" class="summary text-danger"></div>

                <div class="subcard" style="margin-bottom:16px;">
                    <div class="subcard-top">
                        <div>
                            <div class="section-title">Record Type</div>
                            <div class="note">@recordTypeHelp</div>
                        </div>
                        <span class="pill">@recordTypeLabel</span>
                    </div>
                    <div class="record-types">
                        <label class="record-option @(hasPortalAccess ? "is-disabled" : "")">
                            <input asp-for="RecordType" type="radio" value="Lead" disabled="@hasPortalAccess" />
                            <span>Lead</span>
                        </label>
                        <label class="record-option @(!hasPortalAccess ? "is-disabled" : "")">
                            <input asp-for="RecordType" type="radio" value="Client" disabled="@(!hasPortalAccess)" />
                            <span>Client</span>
                        </label>
                        <label class="record-option @(!hasPortalAccess ? "is-disabled" : "")">
                            <input asp-for="RecordType" type="radio" value="BusinessClient" disabled="@(!hasPortalAccess)" />
                            <span>Business Client</span>
                        </label>
                    </div>
                    <span asp-validation-for="RecordType" class="text-danger validation"></span>
                </div>

                <div class="grid">
                    <div>
                        <label asp-for="FirstName" class="label"></label>
                        <input asp-for="FirstName" class="input" autocomplete="given-name" />
                        <span asp-validation-for="FirstName" class="text-danger validation"></span>
                    </div>

                    <div>
                        <label asp-for="LastName" class="label"></label>
                        <input asp-for="LastName" class="input" autocomplete="family-name" />
                        <span asp-validation-for="LastName" class="text-danger validation"></span>
                    </div>

                    <div>
                        <label asp-for="Email" class="label"></label>
                        <input asp-for="Email" class="input" autocomplete="email" inputmode="email" />
                        <span asp-validation-for="Email" class="text-danger validation"></span>
                    </div>

                    <div>
                        <label asp-for="Phone" class="label"></label>
                        <input asp-for="Phone" class="input" autocomplete="tel" inputmode="tel" />
                        <span asp-validation-for="Phone" class="text-danger validation"></span>
                    </div>

                    <div>
                        <label asp-for="MaritalStatus" class="label">Marital Status</label>
                        <select asp-for="MaritalStatus" class="input" id="MaritalStatus">
                            <option value="">-- Select --</option>
                            <option>Single</option>
                            <option>Married</option>
                            <option>Domestic Partnership</option>
                            <option>Divorced</option>
                            <option>Widowed</option>
                        </select>
                        <span asp-validation-for="MaritalStatus" class="text-danger validation"></span>
                    </div>

                    <div>
                        <label asp-for="DOB" class="label"></label>
                        @if (Model?.IsDobLocked == true)
                        {
                            <input asp-for="DOB" type="date" class="input" readonly />
                            <div class="note" style="margin-top:6px;">DOB is locked because it has already been saved.</div>
                        }
                        else
                        {
                            <input asp-for="DOB" type="date" class="input" />
                            <div class="note" style="margin-top:6px;">DOB is editable until it is saved the first time.</div>
                        }
                    </div>
                </div>

                <!-- Significant Other (conditional) -->
                <div id="soCard" class="subcard" style="display:none; margin-top:16px;">
                    <div class="subcard-top">
                        <div>
                            <div class="section-title">Significant Other</div>
                            <div class="note">Required for Married / Domestic Partnership. Stored under this client household.</div>
                        </div>
                        <span class="pill">Required for this status</span>
                    </div>

                    <div class="grid">
                        <div>
                            <label asp-for="SignificantOtherFirstName" class="label">First Name</label>
                            <input asp-for="SignificantOtherFirstName" class="input" id="SignificantOtherFirstName" autocomplete="given-name" />
                            <span asp-validation-for="SignificantOtherFirstName" class="text-danger validation"></span>
                        </div>

                        <div>
                            <label asp-for="SignificantOtherLastName" class="label">Last Name</label>
                            <input asp-for="SignificantOtherLastName" class="input" id="SignificantOtherLastName" autocomplete="family-name" />
                            <span asp-validation-for="SignificantOtherLastName" class="text-danger validation"></span>
                        </div>

                        <div>
                            <label asp-for="SignificantOtherDOB" class="label">Date of Birth</label>
                            <input asp-for="SignificantOtherDOB" type="date" class="input" id="SignificantOtherDOB" />
                            <span asp-validation-for="SignificantOtherDOB" class="text-danger validation"></span>
                        </div>

                        <div>
                            <label asp-for="SignificantOtherPhone" class="label">Phone</label>
                            <input asp-for="SignificantOtherPhone" class="input" autocomplete="tel" inputmode="tel" />
                            <span asp-validation-for="SignificantOtherPhone" class="text-danger validation"></span>
                        </div>

                        <div class="full">
                            <label asp-for="SignificantOtherEmail" class="label">Email</label>
                            <input asp-for="SignificantOtherEmail" class="input" autocomplete="email" inputmode="email" />
                            <span asp-validation-for="SignificantOtherEmail" class="text-danger validation"></span>
                        </div>
                    </div>
                </div>

                <div class="gold-rule"></div>

                <div class="actions">
                    <button type="submit" class="btn btn-solid">Save Changes</button>
                    <a href="@returnUrl" class="btn btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const status = document.getElementById('MaritalStatus');
            const soCard = document.getElementById('soCard');

            const soFirst = document.getElementById('SignificantOtherFirstName');
            const soLast  = document.getElementById('SignificantOtherLastName');
            const soDob   = document.getElementById('SignificantOtherDOB');

            function needsSO(v) {
                if (!v) return false;
                v = v.toLowerCase();
                return v === 'married' || v === 'domestic partnership';
            }

            function applySO() {
                const v = status ? status.value : '';
                const required = needsSO(v);

                if (soCard) soCard.style.display = required ? '' : 'none';

                if (soFirst) soFirst.required = required;
                if (soLast)  soLast.required  = required;
                if (soDob)   soDob.required   = required;

                if (!required) {
                    if (soFirst) soFirst.value = '';
                    if (soLast)  soLast.value  = '';
                    if (soDob)   soDob.value   = '';
                }
            }

            if (status) {
                status.addEventListener('change', applySO);
                applySO();
            }
        })();
    </script>
}
