@model IEnumerable<Domain.Entities.ActionItem>
@{
    var clientId = ViewBag.ClientId as string ?? string.Empty;
}
<div class="actions-hub-toolbar">
    <div class="actions-hub-toolbar-copy">
        <h5 class="mb-0">Actions</h5>
        <div class="text-muted small">Agent tasks; enable “Show in Dashboard” to also track in Command Center.</div>
    </div>
    <button class="btn btn-ghost actions-hub-launch-btn" data-bs-toggle="modal" data-bs-target="#clientQuickCreateActionModal">Quick Create</button>
</div>
@await Html.PartialAsync("~/Views/Shared/_ActionList.cshtml",
    Model ?? Enumerable.Empty<Domain.Entities.ActionItem>(),
    new ViewDataDictionary(ViewData) { { "EmptyMessage", "No client actions yet. Add the next step to keep this client moving." }, { "ShowActionControls", true } })

<!-- Quick Create Modal -->
<div class="modal fade quick-entry-shell quick-create-action-shell" id="clientQuickCreateActionModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg quick-entry-dialog quick-create-action-modal">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">New Action</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="clientQuickCreateActionForm" method="post" action="/Clients/CreateAction">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ClientId" value="@clientId" />
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input name="Title" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea name="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3 qc-datetime">
                <label class="form-label">Due date & time (local)</label>
                <input type="datetime-local" name="DueDateUtc" class="form-control" placeholder="yyyy-mm-ddThh:mm" />
                <div class="text-muted small">Pick a local date/time; it will convert to UTC on save.</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Priority</label>
                <select name="Priority" class="form-select">
                    <option value="P1">P1</option>
                    <option value="P2" selected>P2</option>
                    <option value="P3">P3</option>
                </select>
            </div>
            <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" id="clientShowInCommandCenter" name="ShowInCommandCenter" value="true" checked />
                <label class="form-check-label" for="clientShowInCommandCenter">
                    Show in Dashboard
                </label>
                <div class="text-muted small">Only use this for underwriting, delivery, or time-sensitive tasks.</div>
            </div>
            <div class="text-end">
                <button type="submit" class="btn btn-primary px-4">Create</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>
