@model IEnumerable<Domain.Entities.Commitment>
@{
    var clientId = ViewBag.ClientId as string ?? string.Empty;
}

<div class="commitments-head">
    <div class="commitments-head-copy">
        <h5 class="mb-0">Commitments</h5>
        <div class="text-muted small">Promises tracked server-side. Actions remain the execution layer.</div>
    </div>
    <button class="btn btn-ghost commitment-add-btn" data-bs-toggle="modal" data-bs-target="#addClientCommitmentModal">Add Commitment</button>
</div>

@if (ViewBag.CommitmentsError != null)
{
    <div class="text-muted commitments-status" role="status">@ViewBag.CommitmentsError</div>
}
else if (Model == null || !Model.Any())
{
    <div class="text-muted commitments-status">No commitments yet. Set a promise to keep this client accountable.</div>
}
else
{
    <div class="table-responsive commitments-table-wrap">
        <table class="table table-sm table-dark align-middle mb-2 commitments-table">
            <thead>
                <tr>
                    <th scope="col">Promise</th>
                    <th scope="col" class="commitments-col-due">Due</th>
                    <th scope="col" class="commitments-col-status">Status</th>
                    <th scope="col" class="commitments-col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in Model)
            {
                var isOpen = c.Status == Domain.Enums.CommitmentStatus.Open;
                <tr>
                    <td>@c.PromiseText</td>
                    <td>@c.DueDateUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                    <td><span class="commitment-status-pill">@c.Status</span></td>
                    <td>
                        <div class="commitment-action-row">
                            <button type="button" class="btn btn-ghost commitment-action-btn" data-client-commitment-action="fulfill" data-commitment-id="@c.Id" @(isOpen ? "" : "disabled")>Fulfill</button>
                            <button type="button" class="btn btn-ghost commitment-action-btn commitment-action-btn-danger" data-client-commitment-action="break" data-commitment-id="@c.Id" @(isOpen ? "" : "disabled")>Break</button>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<!-- Add Commitment Modal (Client) -->
<div class="modal fade quick-entry-shell" id="addClientCommitmentModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg quick-entry-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Commitment</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form id="clientCreateCommitmentForm" method="post" action="/Clients/CreateCommitment">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ClientId" value="@clientId" />
            <div class="mb-3">
                <label class="form-label">Promise</label>
                <textarea name="PromiseText" class="form-control" rows="3" required placeholder="e.g. Send policy review summary by Friday"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Due date &amp; time (local)</label>
                <input type="datetime-local" name="DueDateUtc" class="form-control" required />
                <div class="text-muted small">Stored in UTC. We convert from your local time on save.</div>
            </div>
            <div class="text-end">
                <button type="submit" class="btn btn-primary px-4">Save</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>
