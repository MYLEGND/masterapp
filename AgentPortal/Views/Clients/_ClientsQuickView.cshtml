                                    <label class="wfd-tog"><input type="checkbox" id="wfd_annIncomeRider" /><span class="wfd-tog-sl"></span></label>
                                    <span class="wfd-tog-lbl">Income Rider</span>
                                </div>
                                <div id="wfd_annRollupWrap" style="display:none;">
