                            <div class="col-md-6"><label class="form-label">Starting Balance</label><input class="form-control" id="wbStartingBalance" /></div>
                            <div class="col-md-6"><label class="form-label">Annual Income</label><input class="form-control" id="wbIncome" /></div>
                            <div class="col-md-6"><label class="form-label">Working Period (Years)</label><input class="form-control" id="wbYears" /></div>
                            <div class="col-md-6"><label class="form-label">Inflation %</label><input class="form-control" id="wbInflation" /></div>
                            <div class="col-md-6"><label class="form-label">After-Tax Return %</label><input class="form-control" id="wbReturn" /></div>
                            <div class="col-md-6"><label class="form-label">Tax Bracket %</label><input class="form-control" id="wbTax" /></div>
                            <div class="col-md-6"><label class="form-label">Fixed Liabilities %</label><input class="form-control" id="wbLiabilities" /></div>
                            <div class="col-md-6"><label class="form-label">Lifestyle Spending %</label><input class="form-control" id="wbLifestyle" /></div>
                        </div>
                    </div>

                    <div class="finplan-section">
                        <div class="fw-bold text-uppercase small" style="color:#94a3b8;">Distribution Planner — Foundation</div>
                        <div class="row g-2 mt-1">
                            <div class="col-md-4"><label class="form-label">Retire Age</label><input class="form-control" id="wfd_retAge" /></div>
                            <div class="col-md-4"><label class="form-label">End Age</label><input class="form-control" id="wfd_endAge" /></div>
                            <div class="col-md-4"><label class="form-label">Emergency Reserve</label><input class="form-control" id="wfd_emergency" /></div>
                            <div class="col-md-4"><label class="form-label">Desired Income</label><input class="form-control" id="wfd_desiredIncome" /></div>
                            <div class="col-md-4"><label class="form-label">Guaranteed Income</label><input class="form-control" id="wfd_guaranteedIncome" /></div>
                            <div class="col-md-4 form-check mt-2">
                                <input class="form-check-input" type="checkbox" id="wfd_manualOverride">
                                <label class="form-check-label" for="wfd_manualOverride">Manual Base Override</label>
                            </div>
                        </div>
                    </div>

                    <div class="finplan-section">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <div class="fw-bold text-uppercase small" style="color:#94a3b8;">Three Bucket Allocation</div>
                            <div class="text-muted small">Allocations must total exactly 100%. Dollar amounts are auto-calculated from the Retirement Base.</div>
                        </div>

                        <div class="wfd-bkt-grid">
                            <!-- Investments -->
                            <div class="wfd-bkt-card wfd-bkt-inv">
                                <div class="wfd-bkt-head">
                                    <div>
                                        <p class="wfd-bkt-title text-primary mb-0">A — Investments</p>
                                        <p class="wfd-bkt-sub mb-0">Growth Engine — Stocks, bonds, ETFs, mutual funds, brokerage, retirement accounts</p>
                                    </div>
                                    <div class="wfd-dm-toggle">
                                        <span class="wfd-dm-label">Down-Market:</span>
                                        <label class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="wfd_invDownMkt">
                                        </label>
                                    </div>
                                </div>
                                <div class="row g-2">
                                    <div class="col-6"><label class="form-label">Allocation %</label><input class="form-control" id="wfd_invAlloc" /></div>
                                    <div class="col-6"><label class="form-label">Starting Dollar Amount</label><input class="form-control" id="wfd_invAmt" readonly /></div>
                                    <div class="col-6"><label class="form-label">Expected Annual Return %</label><input class="form-control" id="wfd_invReturn" /></div>
                                    <div class="col-6"><label class="form-label">Tax Rate %</label><input class="form-control" id="wfd_invTax" /></div>
                                </div>
                            </div>

                            <!-- Life Insurance -->
                            <div class="wfd-bkt-card wfd-bkt-life">
                                <div class="wfd-bkt-head">
                                    <div>
                                        <p class="wfd-bkt-title text-warning mb-0">B — Life Insurance / Equivalent</p>
                                        <p class="wfd-bkt-sub mb-0">Stability Buffer — cash value life insurance, overfunded permanent insurance, protected strategies</p>
                                    </div>
                                    <div class="wfd-dm-toggle">
                                        <span class="wfd-dm-label">Down-Market:</span>
                                        <label class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="wfd_liDownMkt">
                                        </label>
                                    </div>
                                </div>
                                <div class="row g-2">
                                    <div class="col-6"><label class="form-label">Allocation %</label><input class="form-control" id="wfd_liAlloc" /></div>
                                    <div class="col-6"><label class="form-label">Starting Dollar Amount</label><input class="form-control" id="wfd_liAmt" readonly /></div>
                                    <div class="col-6"><label class="form-label">Growth / Credited Rate %</label><input class="form-control" id="wfd_liGrowth" /></div>
                                    <div class="col-6"><label class="form-label">Tax Rate %</label><input class="form-control" id="wfd_liTax" /></div>
                                    <div class="col-6"><label class="form-label">Access / Efficiency Factor %</label><input class="form-control" id="wfd_liEfficiency" /></div>
                                    <div class="col-6"><label class="form-label">Death Benefit</label><input class="form-control" id="wfd_liDeath" /></div>
                                    <div class="col-6"><label class="form-label">Whole Life Cash Value</label><input class="form-control" id="wfd_liAmtDisplay" readonly /></div>
                                    <div class="col-6"><label class="form-label">Policy Type</label><select class="form-select" id="wfd_liType"></select></div>
                                    <div class="col-6"><label class="form-label">Access Method</label><select class="form-select" id="wfd_liAccess"></select></div>
                                </div>
                            </div>

                            <!-- Annuities -->
                            <div class="wfd-bkt-card wfd-bkt-ann">
                                <div class="wfd-bkt-head">
                                    <div>
                                        <p class="wfd-bkt-title text-success mb-0">C — Annuities</p>
                                        <p class="wfd-bkt-sub mb-0">Income Floor — Protected income / accumulation hybrid</p>
                                    </div>
                                    <div class="wfd-dm-toggle">
                                        <span class="wfd-dm-label">Down-Market:</span>
                                        <label class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="wfd_annDownMkt">
                                        </label>
                                    </div>
                                </div>
                                <div class="row g-2">
                                    <div class="col-6"><label class="form-label">Allocation %</label><input class="form-control" id="wfd_annAlloc" /></div>
                                    <div class="col-6"><label class="form-label">Starting Annuity Value</label><input class="form-control" id="wfd_annAmt" readonly /></div>
                                    <div class="col-6"><label class="form-label">Credited / Expected Return %</label><input class="form-control" id="wfd_annReturn" /></div>
                                    <div class="col-6"><label class="form-label">Tax Rate %</label><input class="form-control" id="wfd_annTax" /></div>
                                    <div class="col-6"><label class="form-label">Annuity Death Benefit (optional)</label><input class="form-control" id="wfd_annDeath" /></div>
                                    <div class="col-6"><label class="form-label">Rollup %</label><input class="form-control" id="wfd_annRollup" /></div>
                                    <div class="col-6"><label class="form-label">Annuity Design</label><select class="form-select" id="wfd_annDesign"><option value="">-- SELECT DESIGN --</option></select></div>
                                    <div class="col-6 d-flex flex-wrap align-items-center gap-3">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="wfd_annIncomeRider">
                                            <label class="form-check-label" for="wfd_annIncomeRider">Income Rider</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="wfd_annDbRider">
                                            <label class="form-check-label" for="wfd_annDbRider">Death Benefit Rider</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="wfd-total-row">
                            <div class="wfd-total-label">Total Allocated</div>
                            <div class="wfd-total-value" id="finPlanAllocTotal">0%</div>
                        </div>
                    </div>

                    <!-- Strategy & scenarios are managed on the Finance page planner only (source of truth). -->
                </form>
            </div>
            <div class="modal-footer" style="border:0;">
                <div class="text-danger small me-auto" id="finPlanError" style="display:none;"></div>
                <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-gold" id="finPlanSaveBtn">Save Plan</button>
            </div>
        </div>
    </div>
</div>

<div class="note-self-overlay" id="noteSelfOverlay" data-note-self-overlay hidden>
    <div class="note-self-modal" role="dialog" aria-modal="true" aria-label="Note to Self">
        <div class="note-self-head">
            <div class="note-self-title-wrap">
                <h3 class="note-self-title">Note to Self</h3>
                <p class="note-self-sub">Track what went well and what could have been better by date.</p>
            </div>
            <button type="button" class="note-self-close" id="noteSelfClose" data-note-self-close aria-label="Close">×</button>
        </div>

        <div class="note-self-toolbar">
            <label class="note-self-field note-self-field-lead">
                <span>Lead</span>
                <input type="text" id="noteSelfLead" data-note-self-lead readonly />
            </label>
            <label class="note-self-field">
                <span>Date</span>
                <input type="date" id="noteSelfDate" data-note-self-date />
            </label>
            <label class="note-self-field">
                <span>Saved notes</span>
                <select id="noteSelfDates" data-note-self-dates>
                    <option value="">Select lead + date</option>
                </select>
            </label>
            <button type="button" class="btn lb-btn" id="noteSelfSave" data-note-self-save>Save</button>
        </div>

        <div class="note-self-doc" data-note-self-doc>
            <section class="note-self-col">
                <h4>What went well</h4>
                <textarea id="noteSelfWell" data-note-self-well placeholder="Capture wins, strong moments, and what worked..."></textarea>
            </section>
            <section class="note-self-col">
                <h4>What could have been better</h4>
                <textarea id="noteSelfBetter" data-note-self-better placeholder="Capture misses, gaps, and adjustments for next time..."></textarea>
            </section>
        </div>

        <div class="note-self-foot" id="noteSelfStatus" data-note-self-status>Ready</div>
    </div>
</div>

