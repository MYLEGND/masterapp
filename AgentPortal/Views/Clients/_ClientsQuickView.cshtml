<div class="backdrop" id="drawerBackdrop"></div>

<aside class="drawer qv-theme-shell" id="drawer" aria-hidden="true" aria-label="Client quick view" style="overflow-y:auto;">
    <div class="dhead">
        <div class="dtitle">
            <span id="dName">Client</span>
            <button type="button" class="btn btn-ghost" id="btnCloseDrawer">Close</button>
        </div>
        <div class="dsub">
            <span id="dEmail" class="crm-email-display">—</span> • <span id="dPhone">—</span>
        </div>

        <div class="drawer-statbar">
            <span class="pill" id="dStageAge">Stage Age: 0d</span>
            <span class="pill" id="dAttempts">Attempts: 0 today • 0 week • 0 total</span>
            <span class="pill" id="dWaitingOnPill">Waiting On Agent</span>
        </div>

        <div class="drawer-top-actions">
            <button type="button" class="btn btn-gold" id="btnMarkToday">Mark Touched Today</button>
            <button type="button" class="btn btn-ghost" id="btnSetNextToday">Set Next Action: Today</button>
            <button type="button" class="btn btn-ghost" id="btnCopyContact">Copy Contact</button>
            <a class="btn btn-ghost" id="btnOpenEdit" href="#" target="_blank" rel="noopener">Edit Client</a>
            <a class="btn btn-gold" id="btnOpenProfile" href="#" target="_blank" rel="noopener">Open Client Profile</a>
            <a class="btn btn-ghost" id="btnMail" href="#" target="_blank" rel="noopener">Email</a>
            <a class="btn btn-ghost" id="btnCall" href="#" target="_blank" rel="noopener">Call</a>
            <a class="btn btn-ghost" id="btnOpenQueue" href="/Clients/Queue">Queues</a>
            <span id="dPortalWrap">—</span>
        </div>
    </div>

    <div class="dbody" style="overflow:visible;">
        <div class="section section-teal qv-contact-card">
            <div style="display:flex; align-items:center; justify-content:space-between; gap:10px;">
                <h4 style="margin:0;">Contact &amp; Profile</h4>
                <div style="display:inline-flex; align-items:center; gap:8px; flex-wrap:wrap;">
                    <button type="button" class="btn btn-ghost" id="clientQuickActionsShortcut">Actions</button>
                    <button type="button" class="btn btn-gold" id="btnClientFinPlan" style="min-width:180px;">Accumulation + Distribution</button>
                    <button type="button" class="btn lb-btn note-self-cta" id="noteSelfOpen" data-note-self-open style="display:inline-flex; align-items:center; gap:8px;">
                        📝 Note to Self
                    </button>
                </div>
            </div>
            <div class="grid2">
                <div class="f">
                    <label>Phone</label>
                    <input type="tel" id="dPhoneInput" placeholder="Primary phone" />
                </div>
                <div class="f">
                    <label>Email</label>
                    <input type="email" id="dEmailInput" placeholder="Primary email" />
                </div>
            </div>
            <div class="grid2" style="margin-top:10px;">
                <div class="f">
                    <label>Phone #2</label>
                    <input type="tel" id="dPhone2Input" placeholder="Alternate phone" />
                </div>
                <div class="f">
                    <label>BTC</label>
                    <input type="text" id="dBtc" placeholder="BTC" />
                </div>
            </div>
            <div class="grid2" style="margin-top:10px;">
                <div class="f">
                    <label>DOB</label>
                    <input type="date" id="dDob" />
                </div>
                <div class="f">
                    <label>M / F</label>
                    <select id="dGender">
                        <option value="">—</option>
                        <option value="M">M</option>
                        <option value="F">F</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
            </div>
            <div class="f" style="margin-top:10px;">
                <label>Street Address</label>
                <input type="text" id="dAddress" placeholder="123 Main St" />
            </div>
            <div class="grid2" style="margin-top:10px;">
                <div class="f">
                    <label>City</label>
                    <input type="text" id="dCity" placeholder="City" />
                </div>
                <div class="f">
                    <label>State</label>
                    <input type="text" id="dState" placeholder="State" />
                </div>
            </div>
            <div class="grid2" style="margin-top:10px;">
                <div class="f">
                    <label>County</label>
                    <input type="text" id="dCounty" placeholder="County / Parish" />
                </div>
                <div class="f">
                    <label>Zip Code</label>
                    <input type="text" id="dZip" placeholder="Zip" />
                </div>
                <div class="f">
                    <label>Age</label>
                    <input type="text" id="dAge" placeholder="Age" />
                </div>
            </div>
            <div class="grid2" style="margin-top:10px;">
                <div class="f">
                    <label>Mortgage Lender</label>
                    <input type="text" id="dLender" placeholder="Current lender" />
                </div>
                <div class="f">
                    <label>Loan Amount</label>
                    <input type="text" id="dLoanAmount" placeholder="e.g. 250000" />
                </div>
            </div>
        </div>

        <details class="section section-gold qv-disclosure">
            <summary>
                <div class="qv-section-header">
                    <div class="qv-section-title">Production</div>
                    <div class="qv-section-copy">Submitted / Issued / Paid — mutually exclusive by status.</div>
                </div>
            </summary>
            <div class="qv-section-body">
                <div class="production-history">
                    <div class="ph-head">
                        <div>
                            <div class="ph-title">Client Production</div>
                            <div class="ph-sub">Track deals without duplicating stages.</div>
                        </div>
                        <button type="button" class="btn btn-gold" id="clientPhAdd">Add Production</button>
                    </div>
                    <div id="clientPhList" class="ph-list">
                        <div class="ph-empty muted">No production yet.</div>
                    </div>
                </div>
            </div>
        </details>

        <details class="section section-advanced-markets qv-disclosure" id="advancedMarketsActionRow" style="display:none;">
            <summary>
                <div class="advanced-markets-summary">
                    <span class="btn btn-advanced-markets" id="btnAdvancedMarketsInputs">Advanced Markets</span>
                    <span class="qv-section-copy">Reusable business-client inputs for the shared Advanced Markets illustration tool.</span>
                </div>
            </summary>
            <div class="qv-section-body advanced-markets-panel" id="advancedMarketsPanel">
                <form id="advancedMarketsInputsForm" novalidate>
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="advancedMarketsClientUserId" />
                    <div class="advanced-markets-modal-status">
                        <span class="pill" id="advancedMarketsClientLabel">Business Client</span>
                        <span class="tiny" id="advancedMarketsInputsStatus">Loading…</span>
                    </div>
                    <div class="advanced-markets-panel-copy" id="advancedMarketsInputsSummary">
                        Save the reusable business-client inputs here. The shared Advanced Markets page can then search this client and prefill the illustration inputs before calculation.
                    </div>
                    <div class="advanced-markets-modal-fields">
                        @await Html.PartialAsync("~/Views/Workstation/_AdvancedMarketsInputSections.cshtml", new AgentPortal.Models.AdvancedMarketsPageViewModel())
                    </div>
                    <div class="advanced-markets-modal-actions">
                        <button type="button" class="btn btn-advanced-markets" id="btnSaveAdvancedMarketsInputs">Save Inputs</button>
                    </div>
                </form>
            </div>
        </details>

        <details class="section section-relationship qv-disclosure">
            <summary>
                <div class="qv-section-header">
                    <div class="qv-section-title">Relationship / CRM</div>
                    <div class="qv-section-copy">Status, stage, outcome controls, notes, tags, and the next move.</div>
                </div>
            </summary>
            <div class="qv-section-body">
                <style>
                    /* Force Relationship/CRM to its own indigo tone (separate from Production gold) */
                    .section.section-relationship{
                        background: linear-gradient(180deg,#1a1f33,#0f1430) !important;
                        border: 1.5px solid rgba(148,129,255,.7) !important;
                        color:#a5b4fc !important;
                    }
                    .section.section-relationship h5{
                        color:#f1c76a !important;
                    }
                </style>
                <style>
                    .qv-tabs{display:flex;gap:8px;flex-wrap:wrap;}
                    .qv-tabpanel{padding:8px 0;}
                    #clientActionsContainer{
                        background: rgba(17,24,39,.35);
                        border: 1px solid rgba(217,179,90,.28);
                        border-radius: 12px;
                        padding: 10px;
                        padding-right: 14px;
                        min-height: 140px;
                        overflow: visible;
                        width: 100%;
                        box-sizing: border-box;
                    }
                    #clientActionsContainer .action-table-wrap,
                    #clientActionsContainer .action-table,
                    #clientActionsContainer .action-table th,
                    #clientActionsContainer .action-table td{
                        box-sizing: border-box;
                    }
                </style>

                    <div class="qv-subsection">
                        <h5>Relationship Control</h5>
                        <div class="grid2">
                            <div class="f">
                                <label>Status</label>
                                <select id="dStatus">
                                    <option value="Lead">Lead</option>
                                    <option value="Prospect">Prospect</option>
                                    <option value="Active">Portal Client</option>
                                    <option value="Dormant">Inactive</option>
                                </select>
                            </div>
                            <div class="f">
                                <label>Pipeline Stage</label>
                                <select id="dPipelineStage">
                                    <option value="NewLead">Lead</option>
                                    <option value="Opportunities">Opportunities</option>
                                    <option value="Contacted">Contacted</option>
                                    <option value="Qualified">Qualified</option>
                                    <option value="Client">Clients</option>
                                    <option value="BusinessClient">Business Clients</option>
                                    <option value="MeetingScheduled">Meeting Scheduled</option>
                                    <option value="ProposalSent">Proposal Sent</option>
                                    <option value="ApplicationStarted">Application Started</option>
                                    <option value="Submitted">Submitted</option>
                                    <option value="ClosedLost">Not Moving Forward</option>
                                    <option value="Nurture">Nurture</option>
                                </select>
                            </div>
                            <div class="f">
                                <label>Waiting On</label>
                                <select id="dWaitingOn">
                                    <option value="WaitingOnAgent">Waiting On Agent</option>
                                    <option value="WaitingOnClient">Waiting On Client</option>
                                    <option value="WaitingOnCarrier">Waiting On Carrier</option>
                                    <option value="WaitingOnUnderwriting">Waiting On Underwriting</option>
                                    <option value="WaitingOnDocs">Waiting On Docs</option>
                                </select>
                            </div>
                            <div class="f">
                                <label>Last Touch</label>
                                <input type="date" id="dLastTouch" />
                            </div>
                        </div>

                        <div class="grid2" style="margin-top:10px;">
                            <div class="f">
                                <label>Next Action Date</label>
                                <input type="date" id="dNextDate" />
                            </div>
                            <div class="f">
                                <label>Priority</label>
                                <select id="dPriority">
                                    <option value="Low">Low</option>
                                    <option value="Normal" selected>Normal</option>
                                    <option value="High">High</option>
                                    <option value="Urgent">Urgent</option>
                                </select>
                            </div>
                        </div>

                        <div class="f" style="margin-top:10px;">
                            <label>Next Action (what will you do?)</label>
                            <input type="text" id="dNextText" placeholder="e.g. Send quote, schedule review, follow up on application..." />
                        </div>

                        <div class="f" style="margin-top:10px;">
                            <label>Pinned Client Brief</label>
                            <textarea id="dPinnedBrief" placeholder="Current situation, objection, and next move in one fast briefing line."></textarea>
                        </div>

                        <div class="scheduler-row" style="margin-top:10px;">
                            <button type="button" class="preset-chip" data-schedulepreset="today3">Today 3pm</button>
                            <button type="button" class="preset-chip" data-schedulepreset="tomorrow10">Tomorrow 10am</button>
                            <button type="button" class="preset-chip" data-schedulepreset="nextbiz">Next business day</button>
                            <button type="button" class="preset-chip" data-schedulepreset="week">1 week follow-up</button>
                        </div>

                        <div class="tiny" style="margin-top:10px;">
                            Reminders stay browser-local, but client CRM, pipeline, and activity data are persisted for the agent account.
                        </div>
                    </div>

                    <div class="qv-subsection">
                        <h5>Outcome Console</h5>
                        <div class="outcome-grid">
                            <button type="button" class="btn btn-ghost outcome-btn" data-outcome="NoAnswer">No Answer</button>
                            <button type="button" class="btn btn-ghost outcome-btn" data-outcome="LeftVM">Left VM</button>
                            <button type="button" class="btn btn-ghost outcome-btn" data-outcome="Spoke">Spoke</button>
                            <button type="button" class="btn btn-gold outcome-btn" data-outcome="Booked">Booked</button>
                            <button type="button" class="btn btn-ghost outcome-btn" data-outcome="NeedsDocs">Needs Docs</button>
                            <button type="button" class="btn btn-ghost outcome-btn" data-outcome="BusinessClient">Business Client</button>
                            <button type="button" class="btn btn-ghost outcome-btn" data-outcome="ClosedLost">Not Moving Forward</button>
                        </div>
                        <div class="tiny" id="dOutcomeSuggestion" style="margin-top:10px;">Use one-click outcomes to auto-log activity, move stage, and queue the next move.</div>
                    </div>

                    <div class="qv-subsection">
                        <h5>Tags</h5>
                        <div class="f">
                            <label>Tags (comma separated)</label>
                            <input type="text" id="dTags" placeholder="Mortgage, Family, Referral, Gym..." />
                        </div>
                    </div>

                    <div class="qv-subsection">
                        <h5>Notes</h5>
                        <div class="f">
                            <label>Relationship Notes</label>
                            <textarea id="dNotes" placeholder="Values, objections, family, context, follow-up intel..."></textarea>
                        </div>
                    </div>
            </div>
        </details>

        <div class="modal fade actions-hub-modal" id="clientActionsHubModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered actions-hub-dialog">
                <div class="modal-content actions-hub-content">
                    <div class="modal-header actions-hub-header">
                        <h5 class="modal-title">Actions &amp; Commitments</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body actions-hub-body">
                        <div class="qv-subsection">
                            <h5 style="margin-bottom:8px;">Actions</h5>
                            <div class="text-muted tiny" style="margin-bottom:6px;">Agent-owned tasks you will execute. Check “Show in Dashboard” on create to surface in Command Center.</div>
                            <div id="clientActionsContainer">
                                <div class="text-muted">Actions will load here.</div>
                            </div>
                        </div>
                        <div class="qv-subsection">
                            <h5 style="margin-bottom:8px;">Commitments</h5>
                            <div class="text-muted tiny" style="margin-bottom:6px;">Promises you made to this client. They stay in CRM; Actions stay your execution layer.</div>
                            <div id="clientCommitmentsContainer">
                                <div class="text-muted">Commitments will load here.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <details class="section section-blue qv-disclosure">
            <summary>
                <div class="qv-section-header">
                    <div class="qv-section-title">Meeting / Calendar</div>
                    <div class="qv-section-copy">Scheduling details, Zoom helpers, and Outlook availability.</div>
                </div>
            </summary>
            <div class="qv-section-body">
                <div class="grid2">
                    <div class="f">
                        <label>Next Action Date</label>
                        <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap;">
                            <input type="date" id="dMeetingNextDate" style="flex:1 1 180px;" />
                            <button type="button" class="btn btn-ghost" id="btnMeetingNextToday">Today</button>
                        </div>
                    </div>
                    <div class="f">
                        <label>Meeting Type</label>
                        <select id="dMeetingType">
                            <option value="Phone">Phone Call</option>
                            <option value="Zoom">Zoom Call</option>
                            <option value="InPerson">In Person</option>
                        </select>
                    </div>
                    <div class="f">
                        <label>Meeting Time</label>
                        <input type="time" id="dMeetingTime" />
                    </div>
                    <div class="f">
                        <label>Duration (minutes)</label>
                        <select id="dMeetingDuration">
                            <option value="15">15 minutes</option>
                            <option value="30" selected>30 minutes</option>
                            <option value="45">45 minutes</option>
                            <option value="60">1 hour</option>
                            <option value="90">1 hour 30 minutes</option>
                            <option value="120">2 hours</option>
                        </select>
                    </div>
                </div>

                <div class="grid2" style="margin-top:10px;">
                    <div class="f">
                        <label>Location</label>
                        <input type="text" id="dMeetingLocation" placeholder="Office, Phone, Zoom, Client Home..." />
                        <div class="meeting-address-suggest" id="dMeetingLocationSuggest"></div>
                    </div>
                    <div class="f zoom-panel" id="dZoomWrap">
                        <label>Zoom</label>
                        <div class="tiny zoom-status" id="dZoomStatus">No saved personal Zoom room link yet.</div>
                        <div class="zoom-actions">
                            <button type="button" class="btn btn-ghost" id="btnZoomSavePersonal">Save My Zoom Link</button>
                            <button type="button" class="btn btn-ghost" id="btnZoomClearPersonal">Clear Saved Zoom Link</button>
                        </div>
                        <label class="zoom-toggle">
                            <input type="checkbox" id="dUsePersonalZoomLink" />
                            <span>Use my saved personal Zoom link automatically</span>
                        </label>
                        <label class="zoom-link-label">Manual Zoom Link Override (optional)</label>
                        <input type="url" id="dZoomJoinUrl" placeholder="Leave blank to use your saved personal Zoom link" />
                    </div>
                </div>

                <div class="tiny" style="margin-top:10px;">Create Outlook calendar events directly from this client without leaving the workspace. If you save a personal Zoom room link, you can reuse it here instead of pasting it every time.</div>
                <div class="calendar-busy-panel" id="dCalendarBusyPanel">
                    <div class="calendar-busy-head">
                        <span class="calendar-busy-title">My Day Availability</span>
                        <span class="pill" id="dCalendarBusyDate">Select a date</span>
                    </div>
                    <div class="tiny calendar-busy-note" id="dCalendarBusyNote">Choose a Next Action Date to see your Outlook busy blocks for that day.</div>
                    <div class="calendar-free-wrap">
                        <div class="calendar-free-head">
                            <span class="calendar-free-title">Available To Book</span>
                            <span class="tiny" id="dCalendarWorkHours">Uses your Outlook work hours</span>
                        </div>
                        <div class="calendar-free-list" id="dCalendarFreeList"></div>
                    </div>
                    <div class="calendar-busy-list" id="dCalendarBusyList"></div>
                </div>
            </div>
        </details>

        <details class="section section-green qv-disclosure">
            <summary>
                <div class="qv-section-header">
                    <div class="qv-section-title">Planning &amp; Docs</div>
                    <div class="qv-section-copy">Opportunity planning checkpoints and the working document checklist.</div>
                </div>
            </summary>
            <div class="qv-section-body">
                <div class="qv-subsection">
                    <h5>Opportunity Planning</h5>
                    <div class="tiny" style="margin-bottom:10px;">Check each planning review completed for this prospect.</div>
                    <div class="doc-grid">
                        <label><input type="checkbox" id="dPlanLifeInsurance" /> Life Insurance Planning</label>
                        <label><input type="checkbox" id="dPlanDisabilityIncome" /> Disability Income Planning</label>
                        <label><input type="checkbox" id="dPlanLongTermCare" /> Long-Term Care Planning</label>
                        <label><input type="checkbox" id="dPlanCriticalIllness" /> Critical Illness Planning</label>
                        <label><input type="checkbox" id="dPlanTerminalIllness" /> Terminal Illness Planning</label>
                        <label><input type="checkbox" id="dPlanAnnuityRetirement" /> Annuity / Retirement Income Planning</label>
                        <label><input type="checkbox" id="dPlanMortgageProtection" /> Mortgage Protection Planning</label>
                        <label><input type="checkbox" id="dPlanFinalExpense" /> Final Expense Planning</label>
                        <label><input type="checkbox" id="dPlanMedicare" /> Medicare Planning</label>
                        <label><input type="checkbox" id="dPlanHealth" /> Health / ACA Planning</label>
                        <label><input type="checkbox" id="dPlanDentalVision" /> Dental &amp; Vision Planning</label>
                        <label><input type="checkbox" id="dPlanHospitalIndemnity" /> Hospital Indemnity Planning</label>
                        <label><input type="checkbox" id="dPlanPersonalAuto" /> Personal Auto Planning</label>
                        <label><input type="checkbox" id="dPlanHomeRenters" /> Homeowners / Renters Planning</label>
                        <label><input type="checkbox" id="dPlanUmbrella" /> Umbrella Liability Planning</label>
                        <label><input type="checkbox" id="dPlanFloodEarthquake" /> Flood / Earthquake Planning</label>
                        <label><input type="checkbox" id="dPlanCommercialAuto" /> Commercial Auto Planning</label>
                        <label><input type="checkbox" id="dPlanGeneralLiability" /> General Liability Planning</label>
                        <label><input type="checkbox" id="dPlanBusinessOwnersPolicy" /> Business Owners Policy (BOP) Planning</label>
                        <label><input type="checkbox" id="dPlanWorkersComp" /> Workers' Comp Planning</label>
                        <label><input type="checkbox" id="dPlanKeyPersonBuySell" /> Key Person / Buy-Sell Planning</label>
                        <label><input type="checkbox" id="dPlanGroupBenefits" /> Group Benefits Planning</label>
                    </div>
                </div>

                <div class="qv-subsection">
                    <h5>Document Checklist</h5>
                    <div class="doc-grid">
                        <label><input type="checkbox" id="dDocIdReceived" /> ID Received</label>
                        <label><input type="checkbox" id="dDocAppSent" /> App Sent</label>
                        <label><input type="checkbox" id="dDocAppSigned" /> App Signed</label>
                        <label><input type="checkbox" id="dDocPolicyDelivered" /> Policy Delivered</label>
                        <label><input type="checkbox" id="dDocReviewBooked" /> Review Booked</label>
                    </div>
                </div>
            </div>
        </details>

        <details class="section section-teal qv-disclosure" id="protectionSnapshotSection">
            <summary>
                <div class="qv-section-header">
                    <div class="qv-section-title">Protection Snapshot</div>
                    <div class="qv-section-copy">Shared client planning view synced with the connected ClientApp workspace.</div>
                </div>
            </summary>
            <div class="qv-section-body">
                <div style="display:flex; justify-content:space-between; gap:10px; align-items:center; flex-wrap:wrap; margin-bottom:10px;">
                    <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
                        <span class="pill" id="qvProtectionScorePill">Readiness —</span>
                        <span class="pill" id="qvProtectionStagePill">Stage —</span>
                        <span class="pill" id="qvProtectionReviewPill">Review —</span>
                    </div>
                    <a class="btn btn-gold" id="btnOpenProtectionSnapshot" href="#" target="_blank" rel="noopener" style="display:none;">Open Protection Snapshot</a>
                </div>

                <div class="grid2">
                    <div class="f">
                        <label>Priority Focus</label>
                        <div class="tiny" id="qvProtectionPriorities">Loading shared snapshot…</div>
                    </div>
                    <div class="f">
                        <label>Life Events</label>
                        <div class="tiny" id="qvProtectionLifeEvents">—</div>
                    </div>
                </div>

                <div class="qv-subsection" style="margin-top:12px;">
                    <h5>Coverage Foundation</h5>
                    <div class="doc-grid" id="qvProtectionCoverageGrid">
                        <span class="pill">Life Insurance —</span>
                        <span class="pill">Disability —</span>
                        <span class="pill">Long-Term Care —</span>
                        <span class="pill">Estate Docs —</span>
                        <span class="pill">Emergency Contacts —</span>
                        <span class="pill">Document Vault —</span>
                    </div>
                </div>

                <div class="qv-subsection" style="margin-top:12px;">
                    <h5>Next Best Steps</h5>
                    <div class="timeline" id="qvProtectionNextSteps">
                        <div class="tiny">No shared snapshot yet.</div>
                    </div>
                </div>

                <div class="qv-subsection" style="margin-top:12px;">
                    <h5>Agent Follow-Up Focus</h5>
                    <div class="tiny" id="qvProtectionAgentFocus">—</div>
                </div>

                <div class="qv-subsection" style="margin-top:12px;">
                    <h5>Client Notes</h5>
                    <div class="tiny" id="qvProtectionClientNotes">—</div>
                </div>
            </div>
        </details>

        <details class="section section-violet qv-disclosure">
            <summary>
                <div class="qv-section-header">
                    <div class="qv-section-title">Team / Collaboration</div>
                    <div class="qv-section-copy">Owner, watchers, and mention notes for internal coordination.</div>
                </div>
            </summary>
            <div class="qv-section-body">
                <div class="grid2">
                    <div class="f">
                        <label>Assigned Owner</label>
                        <input type="text" id="dAssignedOwner" readonly disabled />
                    </div>
                    <div class="f">
                        <label>Watchers</label>
                        <input type="text" id="dWatchers" placeholder="comma-separated emails or names" />
                    </div>
                </div>
                <div class="f" style="margin-top:10px;">
                    <label>Mention Note</label>
                    <textarea id="dMentionNote" placeholder="Add a handoff or mention note with context for the team."></textarea>
                </div>
                <div class="timeline mention-list" id="mentionList" style="margin-top:10px;"></div>
            </div>
        </details>

        <details class="section section-blue qv-disclosure">
            <summary>
                <div class="qv-section-header">
                    <div class="qv-section-title">Activity / Timeline</div>
                    <div class="qv-section-copy">Log contact activity, filter history, and create calendar events.</div>
                </div>
            </summary>
            <div class="qv-section-body">
                <div class="preset-row" id="timelineFilters">
                    <button type="button" class="preset-chip active" data-timelinefilter="all">All</button>
                    <button type="button" class="preset-chip" data-timelinefilter="calls">Calls</button>
                    <button type="button" class="preset-chip" data-timelinefilter="meetings">Meetings</button>
                    <button type="button" class="preset-chip" data-timelinefilter="notes">Notes</button>
                    <button type="button" class="preset-chip" data-timelinefilter="system">System</button>
                </div>
                <div class="grid2">
                    <div class="f">
                        <label>Type</label>
                        <select id="dActType">
                            <option value="Call">Call</option>
                            <option value="Email">Email</option>
                            <option value="Meeting">Meeting</option>
                            <option value="Text">Text</option>
                            <option value="Note">Note</option>
                        </select>
                    </div>
                    <div class="f">
                        <label>Date</label>
                        <input type="date" id="dActDate" />
                    </div>
                </div>

                <div class="f" style="margin-top:10px;">
                    <label>Outcome / Notes</label>
                    <textarea id="dActNote" placeholder="What happened? Next step? Any objections?"></textarea>
                </div>

                <div style="margin-top:10px; display:flex; gap:10px; flex-wrap:wrap;">
                    <button type="button" class="btn btn-gold" id="btnAddActivity">Add Activity</button>
                    <button type="button" class="btn btn-ghost" id="btnClearTimeline">Clear Timeline</button>
                    <button type="button" class="btn btn-ghost" id="btnCreateCalendarEvent" title="Create a calendar event from Next Action (requires Connect Calendar)">
                        Create Calendar Event
                    </button>
                </div>

                <div style="margin-top:12px;">
                    <div class="timeline" id="timeline"></div>
                </div>
            </div>
        </details>

        <details class="section section-red qv-disclosure" style="border-color:#dc2626;">
            <summary>
                <div>
                    <span class="qv-section-title">Secondary Controls</span>
                    <span class="qv-section-copy">Save, reset local state, or delete the client record.</span>
                </div>
            </summary>
            <div class="qv-section-body" style="text-align:right;">
                <div style="display:flex; justify-content:flex-end; gap:10px; flex-wrap:wrap;">
                    <button type="button" class="btn btn-ghost" id="btnResetLocal">Reset Local CRM</button>
                    <button type="button" class="btn btn-gold" id="btnSaveLocal">Save</button>
                    <button type="button" class="btn btn-ghost" id="btnDeleteClient" style="background:#dc2626; color:#fff; border-color:#b91c1c;">
                        Delete Client
                    </button>
                </div>
                <div class="tiny" id="dSaved" style="margin-top:6px; text-align:right;">Loaded</div>
            </div>
        </details>
    </div>
</aside>

<!-- Accumulation + Distribution Modal (uses existing Legend modal system/backdrop) -->
<div class="modal fade finplan-modal" id="clientFinPlanModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" style="background:#0f172a; color:#e2e8f0; border:1.5px solid rgba(166,128,35,.5); border-radius:16px;">
            <div class="modal-header" style="border:0; align-items:flex-start;">
                <div>
                    <h5 class="modal-title fw-bold" style="color:#d9b35a;">Accumulation + Distribution</h5>
                    <div class="text-muted small" id="finPlanClientLabel">Client</div>
                    <div class="text-muted small" id="finPlanStatusLabel">Loading…</div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="max-height:70vh; overflow:auto;">
                <form id="finPlanForm">
                    <input type="hidden" id="finPlanVersion" value="0" />
