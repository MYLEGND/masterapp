<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <UseRazorSourceGenerator>false</UseRazorSourceGenerator>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>8e9aba3d-f9be-401b-8695-a6bd9233d919</UserSecretsId>

    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>

    <DefaultItemExcludes>$(DefaultItemExcludes);bin/**;obj/**;clientlogs/**;App_Data/**;Views_backup/**;wwwroot_backup/**;_safety/**;publish/**;publish-*/**;AgentPortal/**;**/*.zip;**/*.bak;**/*.db</DefaultItemExcludes>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Properties/launchSettings.json" CopyToOutputDirectory="Never" />
  </ItemGroup>

  <ItemGroup>
    <Content Remove="bin/**" />
    <Content Remove="obj/**" />
    <Content Remove="clientlogs/**" />
    <Content Remove="App_Data/**" />
    <Content Remove="Views_backup/**" />
    <Content Remove="wwwroot_backup/**" />
    <Content Remove="_safety/**" />
    <Content Remove="publish/**" />
    <Content Remove="publish-*/**" />
    <Content Remove="AgentPortal/**" />
    <Content Remove="**/*.zip" />
    <Content Remove="**/*.bak" />
    <Content Remove="**/*.db" />

    <None Remove="bin/**" />
    <None Remove="obj/**" />
    <None Remove="clientlogs/**" />
    <None Remove="App_Data/**" />
    <None Remove="Views_backup/**" />
    <None Remove="wwwroot_backup/**" />
    <None Remove="_safety/**" />
    <None Remove="publish/**" />
    <None Remove="publish-*/**" />
    <None Remove="AgentPortal/**" />
    <None Remove="**/*.zip" />
    <None Remove="**/*.bak" />
    <None Remove="**/*.db" />

    <Compile Remove="AgentPortal/**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Extensions.AspNetCore.DataProtection.Blobs" Version="1.5.1" />
    <PackageReference Include="Azure.Extensions.AspNetCore.DataProtection.Keys" Version="1.6.1" />
    <PackageReference Include="Azure.Identity" Version="1.18.0" />
    <PackageReference Include="Microsoft.ApplicationInsights.AspNetCore" Version="3.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.OpenIdConnect" Version="10.0.1" />
    <PackageReference Include="Microsoft.AspNetCore.SignalR.StackExchangeRedis" Version="10.0.5" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="10.0.2" />
    <PackageReference Include="Microsoft.Graph" Version="5.103.0" />
    <PackageReference Include="Microsoft.Identity.Web" Version="4.4.0" />
    <PackageReference Include="Microsoft.Identity.Web.MicrosoftGraph" Version="4.4.0" />
    <PackageReference Include="Microsoft.Identity.Web.UI" Version="4.4.0" />
    <PackageReference Include="QuestPDF" Version="2026.2.1" />
    <PackageReference Include="Rotativa.AspNetCore" Version="1.4.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Infrastructure\Infrastructure.csproj" />
    <ProjectReference Include="..\Domain\Domain.csproj" />
    <ProjectReference Include="..\SHARED\Shared.csproj" />
  </ItemGroup>

  <Target Name="PrunePublishArtifacts" AfterTargets="ComputeFilesToPublish">
    <ItemGroup>
      <ResolvedFileToPublish Remove="@(ResolvedFileToPublish)" Condition="$([System.String]::Copy('%(ResolvedFileToPublish.RelativePath)').StartsWith('bin/')) Or&#xA;                   $([System.String]::Copy('%(ResolvedFileToPublish.RelativePath)').StartsWith('obj/')) Or&#xA;                   $([System.String]::Copy('%(ResolvedFileToPublish.RelativePath)').StartsWith('clientlogs/')) Or&#xA;                   $([System.String]::Copy('%(ResolvedFileToPublish.RelativePath)').StartsWith('App_Data/')) Or&#xA;                   $([System.String]::Copy('%(ResolvedFileToPublish.RelativePath)').StartsWith('Views_backup/')) Or&#xA;                   $([System.String]::Copy('%(ResolvedFileToPublish.RelativePath)').StartsWith('wwwroot_backup/')) Or&#xA;                   $([System.String]::Copy('%(ResolvedFileToPublish.RelativePath)').StartsWith('_safety/')) Or&#xA;                   $([System.String]::Copy('%(ResolvedFileToPublish.RelativePath)').StartsWith('publish/')) Or&#xA;                   $([System.String]::Copy('%(ResolvedFileToPublish.RelativePath)').StartsWith('publish-'))" />
    </ItemGroup>
  </Target>

</Project>
