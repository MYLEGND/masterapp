        <!-- ===================== STEP 14: BUILDING COVERAGES + DISCLAIMER (SUBMIT) ===================== -->
        <div class="form-step" data-step="14">
            <div class="section-card">
                <div class="section-title">Building &amp; Personal Property Coverages</div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="fw-bold">Building Coverage Limit</label>
