                <div class="form-check mt-2 disclaimer-check">
                    <input asp-for="AcknowledgedDisclaimer" class="form-check-input" required />
                    <label asp-for="AcknowledgedDisclaimer" class="form-check-label">
                        I acknowledge that by submitting this form, I authorize the company to contact me regarding my commercial insurance quote request<span class="required-star">*</span>.
                    </label>
                </div>
                <span asp-validation-for="AcknowledgedDisclaimer" class="text-danger d-block mt-1"></span>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-gold">
                        Submit Commercial Quote Request
