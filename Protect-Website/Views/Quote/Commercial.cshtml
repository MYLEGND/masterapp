@model Protect_Website.Models.CommercialQuoteFormModel

@{
    ViewData["Title"] = "Commercial Insurance Quote";
    var pageKey = ((string?)ViewData["PageKey"] ?? "quote_commercial").Trim();
    if (string.IsNullOrWhiteSpace(pageKey))
    {
        pageKey = "quote_commercial";
    }
    var formKey = $"{pageKey}_form";
    ViewData["PageKey"] = pageKey;
    ViewData["PageCategory"] = "quote";
    ViewData["QuoteTypeForTracking"] = "commercial";
    ViewData["PageVariant"] = "website";
    ViewData["PageMode"] = "site_mode";
    ViewData["IsLandingPage"] = false;
    var isFounderPath = ViewData["IsFounderPath"] as bool? == true;
    var trackedSlug = ((string?)ViewData["TrackingSlug"] ?? string.Empty).Trim();
    var agentSlug = !isFounderPath ? trackedSlug : string.Empty;

    var states = new[]{
        "AZ","CA","IA","KS","LA","MD","MS","OH","SC","SD","TX","WA"
    };

    var interestedInOptions = new[]{
        "Commercial Property & Liability","Workers Compensation","Commercial Auto","Inland Marine",
        "Bond","Cyber","E&O","D&O","EPLI","Other"
    };

    var contactMethodOptions = new[]{ "Call","Text","Email" };
    var bestTimeOptions = new[]{ "Morning","Afternoon","Evening" };

    var totalSteps = 14;
}

<style>
    /* ============================================================
       QUOTE WIZARD — match Finance theme (white + subtle gold)
       ============================================================ */

    body { background: #ffffff; }

    .container-narrow{
        width: 100%;
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 14px 40px;
    }

    /* Top header area like Finance */
    .wizard-top{
        position: relative;
        padding: 18px 16px;
        border-radius: 18px;
        border: 1px solid rgba(166,128,35,0.28);
        background: #ffffff;
        box-shadow: 0 18px 55px rgba(0,0,0,0.07);
        margin: 18px auto 16px;
        display:flex;
        justify-content:space-between;
        align-items:center;
        gap: 14px;
    }
    .wizard-top:before{
        content:"";
        position:absolute;
        inset:0;
        border-radius: 18px;
        pointer-events:none;
        background: radial-gradient(700px 240px at 18% 0%, rgba(166,128,35,0.10), transparent 55%);
    }

    .wizard-steptext{
        font-weight: 900;
        color: #111;
        white-space: nowrap;
        position: relative;
        z-index: 1;
    }

    .wizard-progress{
        width: 100%;
        height: 10px;
        background: #eee;
        border-radius: 999px;
        overflow:hidden;
        border: 1px solid #e2e2e2;
        position: relative;
        z-index: 1;
    }
    .wizard-progress-fill{
        height: 100%;
        width: 0%;
        background: #a68023;
        transition: width .25s ease;
    }

    .required-note{
        margin: 14px auto 0;
    }

    /* Step cards like Finance side/main cards */
    .section-card{
        position: relative;
        background: #ffffff;
        border: 1px solid rgba(166,128,35,0.28);
        border-radius: 20px;
        padding: 22px 18px;
        margin-bottom: 20px;
        box-shadow:
            0 20px 60px rgba(0,0,0,0.08),
            inset 0 1px 0 rgba(255,255,255,0.85);
        overflow: hidden;
    }
    .section-card:before{
        content:"";
        position:absolute;
        inset:0;
        border-radius: 20px;
        pointer-events:none;
        background: radial-gradient(700px 260px at 12% 0%, rgba(166,128,35,0.10), transparent 60%);
    }
    .section-card > *{ position: relative; z-index: 1; }

    .section-title{
        font-size: 1.25rem;
        font-weight: 900;
        color: #131313;
        margin-bottom: 14px;
        letter-spacing: .2px;
    }

    /* Inputs / selects like Finance */
    .form-control, .form-select{
        border: 2px solid rgba(166,128,35,0.45) !important;
        border-radius: 14px !important;
        padding: 12px 14px !important;
        font-weight: 800 !important;
        color: #222 !important;
        background: #ffffff !important;
        box-shadow: 0 10px 28px rgba(0,0,0,0.06) !important;
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        margin-bottom: 15px;
    }
    .form-control:hover, .form-select:hover{
        transform: translateY(-1px);
        border-color: rgba(166,128,35,0.70) !important;
        box-shadow: 0 14px 34px rgba(0,0,0,0.08) !important;
    }
    .form-control:focus, .form-select:focus{
        outline: none !important;
        box-shadow: 0 0 0 .2rem rgba(166,128,35,0.18) !important;
    }

    .required-star{ color: #b42318; margin-left: 2px; font-weight: 900; }

    /* Buttons */
    .btn-gold{
        background: linear-gradient(180deg, #c79931, #a68023);
        color: #fff;
        font-weight: 900;
        padding: 10px 30px;
        border-radius: 12px;
        font-size: 1.05rem;
        border: 1.4px solid #c79931;
        box-shadow: 0 14px 32px rgba(0,0,0,0.18);
        transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
    }
    .btn-gold:hover{
        background: linear-gradient(180deg, #c79931, #a68023);
        color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 12px 26px rgba(0,0,0,0.12);
        filter: brightness(0.99);
    }

    .btn-outline-gold{
        border: 2px solid #c79931;
        color: #f8fafc;
        background: #0b1529;
        font-weight: 900;
        padding: 10px 24px;
        border-radius: 12px;
        transition: transform .18s ease, box-shadow .18s ease, filter .18s ease;
        box-shadow: 0 12px 30px rgba(0,0,0,0.14);
    }
    .btn-outline-gold:hover{
        background: #0b1529;
        border-color: #c79931;
        color: #f8fafc;
        transform: translateY(-1px);
        box-shadow: 0 12px 26px rgba(0,0,0,0.12);
        filter: brightness(0.99);
    }

    /* Gold checkboxes */
    .form-check-input{
        width: 20px;
        height: 20px;
        border: 2px solid #000;
        border-radius: 6px;
        background-color: #fff;
        transition: all 0.2s ease;
    }
    .form-check-input:checked{ background-color: #a68023; border-color: #a68023; }
    .form-check-input:hover, .form-check-input:focus{
        outline: 2px solid rgba(166,128,35,0.65);
        box-shadow: 0 0 2px rgba(166,128,35,0.65);
    }
    .form-check-label{ margin-left: 8px; font-weight: 700; color: #222; }

    /* Wizard steps */
    .form-step{ display:none; }
    .form-step.active{ display:block; }

    .wizard-actions{
        display:flex;
        gap: 10px;
        justify-content: space-between;
        align-items:center;
        margin-top: 12px;
    }

    /* Better error visibility */
    .input-validation-error{
        border-color: rgba(180,35,24,0.85) !important;
        box-shadow: 0 0 0 .2rem rgba(180,35,24,0.12) !important;
    }
    .field-validation-error{ font-weight: 800; }

    @@media (max-width: 575.98px){
        .wizard-top{ border-radius: 16px; }
        .section-card{ border-radius: 18px; padding: 18px 14px; }
        .section-title{ font-size: 1.15rem; }

        .wizard-top{
            flex-direction: column;
            align-items: stretch;
            gap: 10px;
        }

        .wizard-steptext{ white-space: normal; }

        .btn-gold,
        .btn-outline-gold{
            min-height: 48px;
        }

        .wizard-actions{
            flex-direction: column;
            align-items: stretch;
        }

        .wizard-actions .btn-gold,
        .wizard-actions .btn-outline-gold{
            width: 100%;
        }
    }
</style>

<div class="container-narrow">

    <div class="text-center" style="margin-top:18px; margin-bottom:6px;">
        <h1 style="
            font-weight: 900;
            font-size: 2.4rem;
            color: #a68023;
            letter-spacing: .5px;
            margin-bottom: 6px;">
            Commercial Insurance Quote
        </h1>
    </div>

    <p class="required-note text-center">
        <strong>
            <span class="text-danger">*</span> Fields marked with a red asterisk are required.
        </strong>
    </p>


    <div class="wizard-top">
        <div class="wizard-steptext" id="stepLabel"></div>
        <div class="wizard-progress">
            <div class="wizard-progress-fill" id="progressFill"></div>
        </div>
    </div>

<form action="/Quote/Commercial"
      method="post"
      id="commercialQuoteForm"
      data-form-key="@formKey">


        @Html.AntiForgeryToken()
        @if (!string.IsNullOrWhiteSpace(agentSlug))
        {
            <input type="hidden" name="AgentSlug" value="@agentSlug" />
        }
        <input type="hidden" name="PageKey" value="@pageKey" />

        <input asp-for="CurrentStep" type="hidden" id="CurrentStep" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- ===================== STEP 1: ACCOUNT DETAILS ===================== -->
        <div class="form-step" data-step="1">
            <div class="section-card">
                <div class="section-title">Account Details</div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="fw-bold">Risk State<span class="required-star">*</span></label>
                        <select asp-for="State" class="form-select">
                            <option value="">Select Risk State</option>
                            @foreach (var state in states)
                            {
                                <option value="@state">@state</option>
                            }
                        </select>
                        <span asp-validation-for="State" class="text-danger"></span>
                    </div>
                </div>

                <div class="wizard-actions">
                    <span></span>
                    <button type="button" class="btn btn-gold btn-next">Next</button>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 2: BUSINESS OPERATIONS ===================== -->
        <div class="form-step" data-step="2">
            <div class="section-card">
                <div class="section-title">Business Operations</div>

                <label class="fw-bold">
                    Please describe your business operations<span class="required-star">*</span>
                </label>
                <small class="text-muted d-block mb-3">
                    Tell us what your business does, the type of work performed, and the services you provide.
                </small>

                <textarea asp-for="BusinessDescription"
                          class="form-control"
                          rows="5"
                          placeholder="Example: We are a commercial HVAC contractor specializing in installation, service, and maintenance for retail and office properties."></textarea>
                <span asp-validation-for="BusinessDescription" class="text-danger"></span>

                <div class="row g-4 mt-3">
                    <div class="col-md-4">
                        <label class="fw-bold">Business Name<span class="required-star">*</span></label>
                        <input asp-for="BusinessName" class="form-control" placeholder="Legal business name" />
                        <span asp-validation-for="BusinessName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Years in Business</label>
                        <input asp-for="YearsInBusiness" class="form-control" placeholder="Optional" />
                        <span asp-validation-for="YearsInBusiness" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Years of Experience</label>
                        <input asp-for="YearsOfExperience" class="form-control" placeholder="Optional" />
                        <span asp-validation-for="YearsOfExperience" class="text-danger"></span>
                    </div>
                </div>

                <div class="row g-4 mt-2">
                    <div class="col-md-4">
                        <label class="fw-bold">Gross Sales<span class="required-star">*</span></label>
                        <input asp-for="GrossSales" class="form-control" placeholder="Annual gross sales" inputmode="decimal" />
                        <span asp-validation-for="GrossSales" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Total Payroll<span class="required-star">*</span></label>
                        <input asp-for="TotalPayroll" class="form-control" placeholder="Annual payroll" inputmode="decimal" />
                        <span asp-validation-for="TotalPayroll" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold"># of Employees<span class="required-star">*</span></label>
                        <input asp-for="NumberOfEmployees" class="form-control" placeholder="Total employees" />
                        <span asp-validation-for="NumberOfEmployees" class="text-danger"></span>
                    </div>
                </div>

                <div class="wizard-actions">
                    <button type="button" class="btn btn-outline-gold btn-prev">Back</button>
                    <button type="button" class="btn btn-gold btn-next">Next</button>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 3: CONTACT ===================== -->
        <div class="form-step" data-step="3">
            <div class="section-card">
                <div class="section-title">Insured &amp; Business Contact</div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="fw-bold">First Name<span class="required-star">*</span></label>
                        <input asp-for="InsuredFirstName" class="form-control" />
                        <span asp-validation-for="InsuredFirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Last Name<span class="required-star">*</span></label>
                        <input asp-for="InsuredLastName" class="form-control" />
                        <span asp-validation-for="InsuredLastName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Business Phone<span class="required-star">*</span></label>
                        <input asp-for="BusinessPhone" class="form-control" />
                        <span asp-validation-for="BusinessPhone" class="text-danger"></span>
                    </div>
                </div>

                <div class="row g-4 mt-2">
                    <div class="col-md-4">
                        <label class="fw-bold">Business Email<span class="required-star">*</span></label>
                        <input asp-for="BusinessEmail" class="form-control" />
                        <span asp-validation-for="BusinessEmail" class="text-danger"></span>
                    </div>

                    <div class="col-md-8">
                        <label class="fw-bold">Website or Facebook URL</label>
                        <input asp-for="BusinessWebsiteOrFacebook" class="form-control" placeholder="Optional" />
                        <span asp-validation-for="BusinessWebsiteOrFacebook" class="text-danger"></span>
                    </div>
                </div>

                <div class="wizard-actions">
                    <button type="button" class="btn btn-outline-gold btn-prev">Back</button>
                    <button type="button" class="btn btn-gold btn-next">Next</button>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 4: ADDRESS ===================== -->
        <div class="form-step" data-step="4">
            <div class="section-card">
                <div class="section-title">Physical Address (No PO Boxes)</div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="fw-bold">Street Address<span class="required-star">*</span></label>
                        <input asp-for="StreetAddress" class="form-control" />
                        <span asp-validation-for="StreetAddress" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Address Line 2</label>
                        <input asp-for="AddressLine2" class="form-control" placeholder="Optional" />
                        <span asp-validation-for="AddressLine2" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">City<span class="required-star">*</span></label>
                        <input asp-for="City" class="form-control" />
                        <span asp-validation-for="City" class="text-danger"></span>
                    </div>
                </div>

                <div class="row g-4 mt-2">
                    <div class="col-md-4">
                        <label class="fw-bold">ZIP Code<span class="required-star">*</span></label>
                        <input asp-for="ZipCode" class="form-control" />
                        <span asp-validation-for="ZipCode" class="text-danger"></span>
                    </div>
                </div>

                <div class="wizard-actions">
                    <button type="button" class="btn btn-outline-gold btn-prev">Back</button>
                    <button type="button" class="btn btn-gold btn-next">Next</button>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 5: COVERAGE & TIMING ===================== -->
        <div class="form-step" data-step="5">
            <div class="section-card">
                <div class="section-title">Coverage &amp; Timing</div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="fw-bold">Effective Date<span class="required-star">*</span></label>
                        <input asp-for="EffectiveDate" type="date" class="form-control" />
                        <span asp-validation-for="EffectiveDate" class="text-danger"></span>
                    </div>
                </div>

                <label class="fw-bold mt-4">
                    Coverage Types Needed<span class="required-star">*</span>
                </label>

                @foreach (var option in interestedInOptions)
                {
                    var id = "interest_" + option.Replace(" ", "").Replace("&", "").Replace("/", "").Replace("-", "");
                    var isChecked = Model.InterestedIn != null && Model.InterestedIn.Contains(option);

                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="InterestedIn"
                               value="@option"
                               id="@id"
                               @(isChecked ? "checked" : "") />
                        <label class="form-check-label" for="@id">@option</label>
                    </div>
                }

                <span asp-validation-for="InterestedIn" class="text-danger d-block mt-2"></span>

                <label class="fw-bold mt-3">Additional Comments</label>
                <textarea asp-for="Comments" class="form-control" rows="4" placeholder="Optional"></textarea>
                <span asp-validation-for="Comments" class="text-danger"></span>

                <div class="wizard-actions">
                    <button type="button" class="btn btn-outline-gold btn-prev">Back</button>
                    <button type="button" class="btn btn-gold btn-next">Next</button>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 6: CONTACT PREFERENCE ===================== -->
        <div class="form-step" data-step="6">
            <div class="section-card">
                <div class="section-title">Preferred Contact Method</div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="fw-bold">Contact Method<span class="required-star">*</span></label>
                        <select asp-for="PreferredContactMethod" class="form-select">
                            <option value="">Select</option>
                            @foreach (var method in contactMethodOptions)
                            {
                                <option value="@method">@method</option>
                            }
                        </select>
                        <span asp-validation-for="PreferredContactMethod" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Best Time<span class="required-star">*</span></label>
                        <select asp-for="BestTimeToContact" class="form-select">
                            <option value="">Select</option>
                            @foreach (var time in bestTimeOptions)
                            {
                                <option value="@time">@time</option>
                            }
                        </select>
                        <span asp-validation-for="BestTimeToContact" class="text-danger"></span>
                    </div>
                </div>

                <div class="wizard-actions">
                    <button type="button" class="btn btn-outline-gold btn-prev">Back</button>
                    <button type="button" class="btn btn-gold btn-next">Next</button>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 7: ENTITY & GENERAL INFO ===================== -->
        <div class="form-step" data-step="7">
            <div class="section-card">
                <div class="section-title">Entity &amp; General Info</div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="fw-bold">Entity Type</label>
                        <select asp-for="EntityType" class="form-select">
                            <option value="">Select Entity Type</option>
                            <option value="Limited Liability Company">Limited Liability Company</option>
                            <option value="S Corporation">S Corporation</option>
                            <option value="C Corporation">C Corporation</option>
                            <option value="Partnership">Partnership</option>
                            <option value="Sole Proprietorship">Sole Proprietorship</option>
                            <option value="Non-Profit">Non-Profit</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="EntityType" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Federal Tax ID</label>
                        <input asp-for="FederalTaxId" class="form-control" placeholder="EIN" />
                        <span asp-validation-for="FederalTaxId" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Has Active Property Liability Policy</label>
                        <select asp-for="HasActivePropertyLiabilityPolicy" class="form-select">
                            <option value="">Select</option>
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                        </select>
                        <span asp-validation-for="HasActivePropertyLiabilityPolicy" class="text-danger"></span>
                    </div>
                </div>

                <div class="row g-4 mt-3">
                    <div class="col-md-4">
                        <label class="fw-bold">Prior Coverage End Date</label>
                        <input asp-for="PriorCoverageEndDate" type="date" class="form-control" />
                        <span asp-validation-for="PriorCoverageEndDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Officers / Members / Partners</label>
                        <input asp-for="OfficersMembersPartners" class="form-control" placeholder="Names / Titles" />
                        <span asp-validation-for="OfficersMembersPartners" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Current Renewal Date</label>
                        <input asp-for="CurrentRenewalDate" type="date" class="form-control" />
                        <span asp-validation-for="CurrentRenewalDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="row g-4 mt-3">
                    <div class="col-md-4">
                        <label class="fw-bold">Owns Other Businesses</label>
                        <select asp-for="OwnsOtherBusinesses" class="form-select">
                            <option value="">Select</option>
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                        </select>
                        <span asp-validation-for="OwnsOtherBusinesses" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Other Business Types</label>
                        <input asp-for="OtherBusinessTypes" class="form-control" placeholder="Describe other businesses" />
                        <span asp-validation-for="OtherBusinessTypes" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label class="fw-bold">Has High Public Profile</label>
                        <select asp-for="HasHighPublicProfile" class="form-select">
                            <option value="">Select</option>
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                        </select>
                        <span asp-validation-for="HasHighPublicProfile" class="text-danger"></span>
                    </div>
                </div>

                <div class="row g-4 mt-3">
                    <div class="col-md-4">
                        <label class="fw-bold">Is Social Media Influencer</label>
                        <select asp-for="IsSocialMediaInfluencer" class="form-select">
                            <option value="">Select</option>
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                        </select>
                        <span asp-validation-for="IsSocialMediaInfluencer" class="text-danger"></span>
                    </div>
                </div>

                <div class="wizard-actions">
                    <button type="button" class="btn btn-outline-gold btn-prev">Back</button>
                    <button type="button" class="btn btn-gold btn-next">Next</button>
                </div>
            </div>
        </div>

        <!-- ===================== STEP 8: LIABILITY, PAYROLL & AUTO ===================== -->
        <div class="form-step" data-step="8">
            <div class="section-card">
                <div class="section-title">Liability, Payroll &amp; Auto</div>

                <div class="row g-4">
                    <div class="col-md-4">
                        <label class="fw-bold">Liability Occurrence Limit</label>
                        <select asp-for="LiabilityOccurrenceLimit" class="form-select">
                            <option value="">Select</option>
                            <option value="300000">$300,000</option>
                            <option value="500000">$500,000</option>
                            <option value="1000000">$1,000,000</option>
                        </select>
                        <span asp-validation-for="LiabilityOccurrenceLimit" class="text-danger"></span>
