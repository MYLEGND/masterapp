    <input type="hidden" name="SessionId" />
    <input type="hidden" name="VisitorId" />
    <input type="hidden" name="UtmSource" />
    <input type="hidden" name="UtmMedium" />
    <input type="hidden" name="UtmCampaign" />
    <input type="hidden" name="UtmId" />
    <input type="hidden" name="UtmTerm" />
    <input type="hidden" name="UtmContent" />
    <input type="hidden" name="MetaCampaignId" />
    <input type="hidden" name="MetaAdSetId" />
    <input type="hidden" name="MetaAdId" />
    <input type="hidden" name="Fbclid" />
    <input type="hidden" name="ReferrerUrl" />
    <input type="hidden" name="LandingPageUrl" />
    </form>
</div>
<script>
(function () {
    var ids = window.legendTrackingIds;
    var p = new URLSearchParams(window.location.search);
    var attr = ids && ids.getAttribution ? (ids.getAttribution() || {}) : {};
    function sh(n, v) { var e = document.querySelector('input[name="' + n + '"]'); if (e && v) e.value = v; }
    sh('SessionId',    ids && ids.getSessionId ? ids.getSessionId() : '');
    sh('VisitorId',    ids && ids.getVisitorId ? ids.getVisitorId() : '');
    sh('UtmSource',    attr.utmSource || p.get('utm_source') || '');
    sh('UtmMedium',    attr.utmMedium || p.get('utm_medium') || '');
    sh('UtmCampaign',  attr.utmCampaign || p.get('utm_campaign') || '');
    sh('UtmId',        attr.utmId || p.get('utm_id') || '');
    sh('UtmTerm',      attr.utmTerm || p.get('utm_term') || '');
    sh('UtmContent',   attr.utmContent || p.get('utm_content') || '');
    sh('MetaCampaignId', attr.metaCampaignId || p.get('meta_campaign_id') || '');
    sh('MetaAdSetId',  attr.metaAdSetId || p.get('meta_adset_id') || '');
    sh('MetaAdId',     attr.metaAdId || p.get('meta_ad_id') || '');
    sh('Fbclid',       attr.fbclid || p.get('fbclid') || '');
    sh('ReferrerUrl',  document.referrer || '');
    sh('LandingPageUrl', window.location.href || '');
})();
</script>

@section Scripts {
    <script>
        (function () {
            const totalSteps = @totalSteps;
            const pageKey = '@pageKey';
            const formKey = '@formKey';
            const form = document.getElementById('commercialQuoteForm');
            const stepLabel = document.getElementById('stepLabel');
            const progressFill = document.getElementById('progressFill');
            const currentStepInput = document.getElementById('CurrentStep');
            const trackCommercialQuote = (window.LegendAnalytics?.track && typeof window.LegendAnalytics.track === 'function')
                ? window.LegendAnalytics.track
                : (window.legendTrack && typeof window.legendTrack === 'function')
                    ? window.legendTrack
                    : null;
            const commercialCompletedSteps = new Set();
            const commercialViewedContactSteps = new Set();

            if (!form) return;

            // -----------------------------
            // Helpers
            // -----------------------------
            function getStep() {
                const n = parseInt(currentStepInput?.value || '1', 10);
                return isNaN(n) ? 1 : Math.min(Math.max(n, 1), totalSteps);
            }

            function setStep(step) {
                step = Math.min(Math.max(step, 1), totalSteps);
                if (currentStepInput) currentStepInput.value = step;

                document.querySelectorAll('.form-step').forEach(el => {
                    el.classList.toggle('active', el.getAttribute('data-step') == step);
                });

                if (stepLabel) stepLabel.textContent = `Step ${step} of ${totalSteps}`;
                if (progressFill) progressFill.style.width = Math.round((step / totalSteps) * 100) + '%';
                if (step === 3 && trackCommercialQuote && !commercialViewedContactSteps.has(step)) {
                    commercialViewedContactSteps.add(step);
                    trackCommercialQuote({
                        EventType: 'quote_contact_step_view',
                        FormKey: formKey,
                        PageKey: pageKey,
                        MetadataJson: JSON.stringify({ stepNumber: step, source: 'wizard_step_view' })
                    });
                }

                window.scrollTo({ top: 0, behavior: 'smooth' });
            }

            function scrollAndFocus(el) {
                if (!el) return;
                el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                setTimeout(() => {
                    try { el.focus({ preventScroll: true }); } catch { el.focus(); }
                }, 50);
            }

            function getActiveStepEl(stepNumber) {
                return document.querySelector(`.form-step[data-step="${stepNumber}"]`);
            }

            function getStepForElement(el) {
                const stepEl = el?.closest?.('.form-step');
                if (!stepEl) return null;
                const n = parseInt(stepEl.getAttribute('data-step') || '', 10);
                return isNaN(n) ? null : n;
            }

            // -----------------------------
            // Make "required-star" actually required in HTML
            // (so native validity works even if you forgot required attrs)
            // -----------------------------
function enforceRequiredByLabels() {
    // Only set required when the asterisk is INSIDE the same label as the field’s label.
    // Never “guess” required across a whole card (prevents Step 14 building limits getting marked required).
    document.querySelectorAll('label').forEach(label => {
        // If this label doesn’t contain the required-star, skip
        if (!label.querySelector('.required-star')) return;

        // Find the associated control:
        // 1) If label has "for", use it (best + precise)
        const forId = label.getAttribute('for');
        let control = null;

        if (forId) {
            control = document.getElementById(forId);
        }

        // 2) Otherwise, pick the next input/select/textarea sibling
        if (!control) {
            let next = label.nextElementSibling;
            while (next && !(next.matches && next.matches('input, select, textarea'))) {
                next = next.nextElementSibling;
            }
            control = next;
        }

        // 3) Last fallback: search only within the same immediate wrapper, NOT the entire card
        if (!control) {
            const wrapper = label.parentElement;
            if (wrapper) {
                control = wrapper.querySelector('input, select, textarea');
            }
        }

        if (!control) return;

        if (control.type === 'hidden' || control.type === 'button' || control.type === 'submit') return;

        // Checkbox group handled separately
        if (control.name === 'InterestedIn') return;

        // IMPORTANT: Do NOT force required on Step 14 building fields (or any field) unless its own label has the star.
        control.setAttribute('required', 'required');
    });
}

            // -----------------------------
            // Custom rules
            // -----------------------------
            function validateInterestedIn(stepEl) {
                if (!stepEl) return true;

                const inputs = stepEl.querySelectorAll('input[name="InterestedIn"]');
                if (!inputs || inputs.length === 0) return true;

                const checked = stepEl.querySelectorAll('input[name="InterestedIn"]:checked').length;
                const msg = stepEl.querySelector('[data-valmsg-for="InterestedIn"], span[data-valmsg-for="InterestedIn"]');

                if (checked < 1) {
                    if (msg) {
                        msg.classList.remove('field-validation-valid');
                        msg.classList.add('field-validation-error');
                        msg.textContent = "Please select at least one coverage type.";
                    }
                    scrollAndFocus(inputs[0]);
                    return false;
                }

                if (msg) {
                    msg.classList.remove('field-validation-error');
                    msg.classList.add('field-validation-valid');
                    msg.textContent = "";
                }
                return true;
            }

            function validateDisclaimer(stepEl) {
                if (!stepEl) return true;

                const cb = stepEl.querySelector('input[name="AcknowledgedDisclaimer"]');
                if (!cb) return true;

                const msg = stepEl.querySelector('[data-valmsg-for="AcknowledgedDisclaimer"], span[data-valmsg-for="AcknowledgedDisclaimer"]');

                if (!cb.checked) {
                    if (msg) {
                        msg.classList.remove('field-validation-valid');
                        msg.classList.add('field-validation-error');
                        msg.textContent = "You must acknowledge the disclaimer.";
                    }
                    scrollAndFocus(cb);
                    return false;
                }

                if (msg) {
                    msg.classList.remove('field-validation-error');
                    msg.classList.add('field-validation-valid');
                    msg.textContent = "";
                }
                return true;
            }

            // -----------------------------
            // Native per-step validation
            // -----------------------------
            function validateStep(stepNumber) {
                const stepEl = getActiveStepEl(stepNumber);
                if (!stepEl) return true;

                // custom: coverage checkboxes
                if (stepNumber === 5 && !validateInterestedIn(stepEl)) return false;

                // custom: disclaimer checkbox (step 14)
                if (stepNumber === 14 && !validateDisclaimer(stepEl)) return false;

                // Validate ONLY fields in this step
                const fields = Array.from(stepEl.querySelectorAll('input, select, textarea'))
                    .filter(el =>
                        el.type !== 'hidden' &&
                        el.type !== 'button' &&
                        el.type !== 'submit' &&
                        !el.disabled &&
                        // Don't let hidden steps fields trigger validity checks
                        el.offsetParent !== null
                    );

                for (const el of fields) {
                    // Skip InterestedIn individual checkboxes (handled above)
                    if (el.name === 'InterestedIn') continue;

                    if (!el.checkValidity()) {
                        // Shows browser message + blocks next
                        el.reportValidity();
                        scrollAndFocus(el);
                        return false;
                    }
                }

                return true;
            }

            function validateAllStepsAndJumpToFirstInvalid() {
                // Temporarily activate each step, validate, jump to the first invalid
                const original = getStep();

                for (let s = 1; s <= totalSteps; s++) {
                    setStep(s);

                    // step-level custom validations
                    const stepEl = getActiveStepEl(s);

                    if (s === 5 && !validateInterestedIn(stepEl)) return false;
                    if (s === 14 && !validateDisclaimer(stepEl)) return false;

                    const fields = Array.from(stepEl.querySelectorAll('input, select, textarea'))
                        .filter(el => el.type !== 'hidden' && el.type !== 'button' && el.type !== 'submit' && !el.disabled);

                    for (const el of fields) {
                        if (el.name === 'InterestedIn') continue;

                        if (!el.checkValidity()) {
                            el.reportValidity();
                            scrollAndFocus(el);
                            return false;
                        }
                    }
                }

                // restore step if all good
                setStep(original);
                return true;
            }

            // -----------------------------
            // Events
            // -----------------------------
            // Ensure required attrs exist for all "starred" label fields
            enforceRequiredByLabels();

            document.addEventListener('click', function (e) {
                const nextBtn = e.target.closest('.btn-next');
                const prevBtn = e.target.closest('.btn-prev');

                if (nextBtn) {
                    const step = getStep();
                    if (!validateStep(step)) return;
                    if (trackCommercialQuote && !commercialCompletedSteps.has(step)) {
                        commercialCompletedSteps.add(step);
                        trackCommercialQuote({
                            EventType: 'quote_step_complete',
                            FormKey: formKey,
                            PageKey: pageKey,
                            MetadataJson: JSON.stringify({ stepNumber: step, nextStep: step + 1 })
                        });
                    }
                    setStep(step + 1);
                }

                if (prevBtn) {
                    setStep(getStep() - 1);
                }
            });


            form.addEventListener('submit', function (e) {
                // Strip $ and commas before submit so decimals bind clean
                document.querySelectorAll('input').forEach(function (input) {
                    if (typeof input.value === 'string' && (input.value.includes('$') || input.value.includes(','))) {
                        input.value = input.value.replace(/[$,]/g, '');
                    }
                });

                // Always enable and set disclaimer value
                var disclaimer = document.getElementById('AcknowledgedDisclaimer');
                if (disclaimer) {
                    disclaimer.disabled = false;
                    disclaimer.value = disclaimer.checked ? 'true' : 'false';
                    // hidden override to guarantee post even if main box toggled/disabled earlier
                    var hidden = document.getElementById('AcknowledgedDisclaimerHidden');
                    if (!hidden) {
                        hidden = document.createElement('input');
                        hidden.type = 'hidden';
                        hidden.id = 'AcknowledgedDisclaimerHidden';
                        hidden.name = 'AcknowledgedDisclaimer';
                        form.appendChild(hidden);
                    }
                    hidden.value = disclaimer.checked ? 'true' : 'false';
                }

                // Hard-stop + jump to first missed required field anywhere
                if (!validateAllStepsAndJumpToFirstInvalid()) {
                    form._trackSubmitAttempt?.(false, form.querySelectorAll(':invalid').length || 1);
                    e.preventDefault();
                } else {
                    form._trackSubmitAttempt?.(true, 0);
                }
            });

            // Initial step (supports postback keeping CurrentStep)
            setStep(getStep());

            // Dev-only sticky form state (localhost only)
            const storageKey = 'commercialQuoteForm-dev';
            const isLocalHost = ['localhost', '127.0.0.1'].includes(location.hostname);
            if (isLocalHost) {
                function saveState() {
                    const data = { step: currentStep, values: {} };
                    form.querySelectorAll('input, select, textarea').forEach(el => {
                        if (!el.name) return;
                        data.values[el.name] = el.type === 'checkbox' ? el.checked : el.value;
                    });
                    try { localStorage.setItem(storageKey, JSON.stringify(data)); } catch { /* ignore */ }
                }

                function restoreState() {
                    try {
                        const raw = localStorage.getItem(storageKey);
                        if (!raw) return;
                        const data = JSON.parse(raw);
                        const vals = data?.values ?? {};
                        Object.keys(vals).forEach(name => {
                            const el = form.querySelector(`[name="${name}"]`);
                            if (!el) return;
                            if (el.type === 'checkbox') el.checked = !!vals[name];
                            else el.value = vals[name];
                        });
                        if (data?.step) setStep(parseInt(data.step) || 1);
                    } catch { /* ignore */ }
                }

                restoreState();
                form.addEventListener('input', saveState);
                form.addEventListener('change', saveState);
            }
        })();
    </script>
}
