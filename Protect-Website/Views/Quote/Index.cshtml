}

.next-card:before{
    content:"";
    position:absolute;
    inset:0;
    border-radius:var(--radius);
    pointer-events:none;
    background:
        radial-gradient(600px 240px at 12% 0%, rgba(166,128,35,.08), transparent 65%);
}

.next-badge{
    width:44px;
    height:44px;
    border-radius:14px;
    border:2px solid var(--border);
    color:var(--gold-strong);
    font-weight:950;
    display:flex;
    align-items:center;
    justify-content:center;
    margin-bottom:14px;
}

.next-card h5{
    font-weight:900;
    margin:0 0 8px;
    color:var(--gold-strong);
}

.next-card p{
    margin:0;
    color:#f8fafc;
    line-height:1.7;
}

/* ------------------- CALENDAR ------------------- */
.calendar-section{
    margin-top:36px;
    padding:28px 20px;
    background:var(--card);
    border-radius:var(--radius);
    box-shadow:var(--shadow-soft);
    border:1.4px solid var(--border);
    text-align:center;
    position:relative;
    color:#f8fafc;
}

.calendar-section:before{
    content:"";
    position:absolute;
    inset:0;
    border-radius:var(--radius);
    pointer-events:none;
    background:
        radial-gradient(700px 260px at 12% 0%, rgba(199,153,49,.12), transparent 65%);
}

.calendar-section h2{
    font-weight:950;
    margin-bottom:10px;
    color:var(--gold-strong);
}

.calendar-section p{
    color:#f8fafc;
    max-width:780px;
    margin:0 auto 18px;
    line-height:1.75;
}

/* 🔥 THIS WAS MISSING */
.calendar-container{
    width:100%;
    height:700px;               /* required so iframe 100% works */
    border-radius:16px;
    overflow:hidden;
    border:1px solid var(--border);
    box-shadow:0 14px 34px rgba(0,0,0,.08);
    position:relative;
}

.calendar-container iframe{
    position:absolute;          /* ensures true fill */
    inset:0;
    width:100% !important;
    height:100% !important;
    border:0;
    display:block;
}

@@media (max-width:576px){
    .calendar-container{
        height:520px;
    }
/* ------------------- PRAYER SECTION ------------------- */
.prayer-card{
    position:relative;
    background:var(--card);
    border:1px solid var(--border);
    border-radius:var(--radius);
    box-shadow:var(--shadow-soft);
    padding:28px 20px;
    text-align:center;
    margin-top:36px;
}

.prayer-card:before{
    content:"";
    position:absolute;
    inset:0;
    border-radius:var(--radius);
    pointer-events:none;
    background:
        radial-gradient(700px 260px at 12% 0%, rgba(166,128,35,.08), transparent 65%);
}

.prayer-kicker{
    letter-spacing:.18em;
    text-transform:uppercase;
    font-size:.78rem;
    color:#5a3b00;
    font-weight:950;
}

.prayer-text{
    margin:14px auto;
    max-width:820px;
    font-size:1.05rem;
