        </div>

        <div class="next-strip" aria-label="What happens next">
            <div class="next-step">
                <span>1</span>
                <h5>Start</h5>
                <p>Choose the lane and complete the quick intake.</p>
            </div>
            <div class="next-step">
                <span>2</span>
                <h5>Review</h5>
                <p>We organize options around your real situation.</p>
            </div>
            <div class="next-step">
                <span>3</span>
                <h5>Decide</h5>
                <p>You get clear direction before anything moves forward.</p>
            </div>
        </div>
    </section>

    <!-- ===================== CALENDAR ===================== -->
    <div class="calendar-section reveal" id="calendar">
        <h2>Want to talk first?</h2>
        <p>Book a time below and we’ll point you toward the right protection path before you start.</p>

        <div class="calendar-container">
            <iframe src="https://outlook.office.com/book/LEGEND@mylegnd.com/?ismsaljsauthenabled=true"></iframe>
        </div>
    </div>

    <!-- ===================== PRAYER SECTION ===================== -->
    <section class="prayer-section">
        <div class="prayer-card reveal">
            <div class="prayer-kicker">A Blessing Over You</div>
