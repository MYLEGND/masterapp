                    <a href="#quoteTypes" class="btn-gold" data-cta="hero_start_quote" data-lead-trigger="true" data-lead-interest="quote_general">Start a Quote →</a>
                    <a href="#calendar" class="btn-outline" data-cta="hero_book_call">Talk First ↗</a>
                </div>
            </div>

            <aside class="hero-side">
