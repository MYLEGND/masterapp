@{
    ViewData["Title"] = "Get a Quote";
    Layout = "_Layout";
    ViewData["PageKey"] = "quote_index";
}

<style>
:root{
    --surface:#0f172a;
    --surface-soft:#111c32;
    --ink:#0f172a;
    --ink-light:#f8fafc;
    --gold:#a68023;
    --gold-strong:#c79931;
    --border:rgba(199,153,49,.95);
    --subtle:rgba(199,153,49,.16);
    --card:var(--surface);
    --shadow:0 20px 60px rgba(0,0,0,.18);
    --shadow-soft:0 14px 34px rgba(0,0,0,.14);
    --radius:20px;
}

/* ------------------- PAGE WRAP ------------------- */
.quote-page{
    max-width: 1200px;
    margin: 0 auto;
    padding: 28px 18px 90px;
}

/* ------------------- HERO ------------------- */
.quote-hero{
    position:relative;
    background:var(--card);
    border:1.6px solid var(--border);
    border-radius:22px;
    box-shadow:var(--shadow);
    padding:34px 28px;
    overflow:hidden;
}

/* subtle gold corner glow */
.quote-hero:before{
    content:"";
    position:absolute;
    inset:0;
    border-radius:22px;
    pointer-events:none;
    background:
        radial-gradient(800px 280px at 14% 0%, rgba(199,153,49,.16), transparent 60%);
}

.hero-kicker{
    letter-spacing:.18em;
    text-transform:uppercase;
    font-size:.78rem;
    color:var(--ink-light);
    font-weight:900;
    background:rgba(199,153,49,.20);
    border:1px solid rgba(199,153,49,.35);
    padding:6px 12px;
    border-radius:999px;
    display:inline-block;
}

.hero-title{
    font-size:clamp(2rem,3vw,2.6rem);
    line-height:1.1;
    font-weight:950;
    margin:14px 0 8px;
    color:#dfe6f0;
}

.hero-lead{
    font-size:1.08rem;
    line-height:1.8;
    color:rgba(248,250,252,0.86);
    max-width:820px;
    margin:0 0 18px;
}

.hero-lead .hl{ color:var(--gold); font-weight:900; }

.hero-bar{
    height:2px;
    width:110px;
    background:var(--gold-strong);
    border-radius:999px;
    margin:14px 0 18px;
}

.hero-actions{
    display:flex;
    gap:12px;
    flex-wrap:wrap;
}

.btn-gold{
    background:linear-gradient(180deg, var(--gold-strong), var(--gold));
    color:#fff;
    font-weight:900;
    padding:12px 20px;
    border-radius:14px;
    text-decoration:none;
    border:1.6px solid var(--border);
    box-shadow:0 14px 32px rgba(0,0,0,.18);
    transition:.18s ease;
    display:inline-flex;
    align-items:center;
    gap:8px;
}
.btn-gold:hover{
    transform:translateY(-2px);
    box-shadow:0 16px 36px rgba(0,0,0,.14);
    color:#fff;
    background:linear-gradient(180deg, var(--gold-strong), var(--gold));
}

.btn-outline{
    background:var(--surface-soft);
    border:2px solid var(--border);
    color:#f8fafc;
    font-weight:900;
    padding:12px 20px;
    border-radius:14px;
    text-decoration:none;
    transition:.18s ease;
}
.btn-outline:hover{
    transform:translateY(-2px);
    border-color:var(--gold-strong);
}

/* ------------------- SECTION HEADERS ------------------- */
.section{
    margin-top:40px;
}

.section-head{
    text-align:center;
    margin:24px 0 14px;
}

.section-title{
    font-weight:950;
    color:var(--gold-strong);
    font-size:1.85rem;
    margin:0 0 8px;
}

.section-sub{
    color:var(--ink);
    font-size:1.05rem;
    line-height:1.75;
    max-width:820px;
    margin:0 auto;
}

.center-divider{
    width:90px;
    height:2px;
    background:var(--gold-strong);
    border-radius:999px;
    margin:14px auto 0;
}

/* ------------------- QUOTE GRID ------------------- */
.quote-grid{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:18px;
    margin-top:24px;
}
@@media (max-width:992px){
    .quote-grid{ grid-template-columns:repeat(2,minmax(0,1fr)); }
}
@@media (max-width:576px){
    .quote-grid{ grid-template-columns:1fr; }
}

/* TILE */
.quote-tile{
    position:relative;
    background:var(--card);
    border:1.4px solid var(--border);
    border-radius:var(--radius);
    padding:22px;
    box-shadow:var(--shadow-soft);
    text-decoration:none;
    color:#f8fafc;
    transition:.18s ease;
    display:flex;
    flex-direction:column;
    justify-content:space-between;
    min-height:170px;
    color:#f8fafc;
}

.quote-tile:before{
    content:"";
    position:absolute;
    inset:0;
    border-radius:var(--radius);
    pointer-events:none;
    background:
        radial-gradient(600px 240px at 12% 0%, rgba(166,128,35,.08), transparent 65%);
}

.quote-tile:hover{
    transform:translateY(-6px);
    border-color:var(--gold-strong);
    box-shadow:0 22px 50px rgba(0,0,0,.16);
}

.tile-title{
    font-weight:900;
    font-size:1.12rem;
    margin:0;
    color:var(--gold-strong);
}
.quote-tile:hover .tile-action{
    color: var(--gold-strong);
    background: transparent;
}
.quote-tile,
.quote-tile:hover,
.quote-tile:focus,
.quote-tile:active{
    background: var(--card);
    color: #f8fafc;
    text-decoration: none;
}

.life-tile{
    position:relative;
    cursor:pointer;
    overflow:visible;
}
.life-modal{
    position:fixed;
    inset:0;
    background:rgba(8,12,24,0.72);
    backdrop-filter:blur(8px);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:10000;
    padding:16px;
}
.life-modal.open{ display:flex; }
.life-modal-card{
    width:min(480px, 94vw);
    background:linear-gradient(180deg,#0f172a 0%, #0c1427 100%);
    border:1.6px solid rgba(199,153,49,.8);
    border-radius:16px;
    box-shadow:0 24px 60px rgba(0,0,0,.35);
    color:#f4f6fb;
    padding:18px;
    position:relative;
}
.life-modal-card h3{
    margin:0 0 12px;
    font-weight:900;
    font-size:1.2rem;
    text-align:center;
    color:#dfb75a;
}
.life-modal-close{
    position:absolute;
    top:10px;
    right:10px;
    background:transparent;
    border:1px solid rgba(244,246,251,.35);
    color:#f4f6fb;
    border-radius:10px;
    width:32px;
    height:32px;
    font-size:1.1rem;
    cursor:pointer;
}
.life-modal-grid{
    display:grid;
    grid-template-columns:1fr;
    gap:10px;
}
@media (min-width: 520px){
    .life-modal-grid{ grid-template-columns:repeat(2,1fr); }
}
.life-option{
    display:block;
    padding:12px 14px;
    border:1px solid rgba(199,153,49,.65);
    border-radius:10px;
    text-decoration:none;
    color:#f8fafc;
    font-weight:850;
    text-align:center;
    background:rgba(199,153,49,0.08);
}
.life-option:hover{
    border-color:#c79931;
    background:rgba(199,153,49,0.15);
    color:#dfb75a;
}
.life-dropdown{
    display:none;
}
.life-dropdown a{
    padding:11px 14px;
    color:#f8fafc;
    font-weight:800;
    border-bottom:1px solid rgba(199,153,49,0.22);
    text-decoration:none;
}
.life-dropdown a:last-child{ border-bottom:none; }
.life-dropdown a:hover{ background:rgba(199,153,49,0.12); color:var(--gold-strong); }
.life-tile{ cursor:pointer; position:relative; }

.tile-sub{
    margin:8px 0 0;
    color:#f8fafc;
    font-size:.98rem;
}

.tile-footer{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-top:18px;
    padding-top:14px;
    border-top:1px solid var(--subtle);
    font-weight:900;
}

.tile-action{ color:var(--gold-strong); text-decoration:none; }

.tile-arrow{
    width:34px;
    height:34px;
    border-radius:999px;
    border:1px solid var(--border);
    display:flex;
    align-items:center;
    justify-content:center;
    transition:.18s ease;
}
.life-dropdown{
    margin-top:10px;
    background:var(--card);
    border:1.2px solid var(--border);
    border-radius:12px;
    box-shadow:0 12px 30px rgba(0,0,0,0.22);
    display:flex;
    flex-direction:column;
    overflow:hidden;
}
.life-dropdown a{
    padding:11px 14px;
    color:#f8fafc;
    font-weight:800;
    border-bottom:1px solid rgba(199,153,49,0.22);
    text-decoration:none;
}
.life-dropdown a:last-child{ border-bottom:none; }
.life-dropdown a:hover{ background:rgba(199,153,49,0.12); color:var(--gold-strong); }
.life-tile{ cursor:pointer; position:relative; }
.life-tile:focus-visible{ outline:2px solid var(--gold-strong); outline-offset:4px; }
.quote-tile:hover .tile-arrow{
    border-color:var(--gold-strong);
    color:var(--gold-strong);
}
.quote-tile:hover .tile-action{
    color: var(--gold-strong);
}

/* ------------------- WHAT HAPPENS NEXT ------------------- */
.next-grid{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:18px;
    margin-top:24px;
}
@@media (max-width:992px){
    .next-grid{ grid-template-columns:1fr; }
}

.next-card{
    position:relative;
    background:var(--card);
    border:1.4px solid var(--border);
    border-radius:var(--radius);
