@{
    ViewData["Title"] = "Get a Quote";
    Layout = "_Layout";
    ViewData["PageKey"] = "quote_index";
    ViewData["SeoTitle"] = "Get a Personalized Insurance Quote";
    ViewData["SeoDescription"] = "Start a personalized insurance review for life, mortgage protection, disability, health, auto, home, or commercial coverage.";
}

<style>
:root{
    --surface:#0f172a;
    --surface-soft:#111c32;
    --ink:#0f172a;
    --ink-light:#f8fafc;
    --gold:#a68023;
    --gold-strong:#c79931;
    --border:rgba(199,153,49,.85);
    --subtle:rgba(199,153,49,.18);
    --shadow:0 20px 60px rgba(0,0,0,.16);
    --radius:22px;
}

.quote-page{
    max-width:1160px;
    margin:0 auto;
    padding:24px 18px 72px;
}

/* ONE CONNECTED CONVERSION SURFACE */
.quote-flow{
    background:linear-gradient(180deg,#0f172a 0%, #0b1325 100%);
    border:1.6px solid var(--border);
    border-radius:24px;
    box-shadow:var(--shadow);
    overflow:hidden;
    position:relative;
}

.quote-flow:before{
    content:"";
    position:absolute;
    inset:0;
    pointer-events:none;
    background:
        radial-gradient(900px 320px at 12% 0%, rgba(199,153,49,.16), transparent 62%),
        radial-gradient(700px 260px at 92% 0%, rgba(199,153,49,.10), transparent 70%);
}

.quote-flow > *{
    position:relative;
    z-index:1;
}

.quote-hero{
    display:grid;
    grid-template-columns:minmax(0,1.1fr) minmax(280px,.62fr);
    gap:22px;
    align-items:center;
    padding:34px 30px 22px;
}

.hero-kicker{
    display:inline-flex;
    align-items:center;
    gap:8px;
    letter-spacing:.16em;
    text-transform:uppercase;
    font-size:.76rem;
    color:#f8fafc;
    font-weight:950;
    background:rgba(199,153,49,.18);
    border:1px solid rgba(199,153,49,.34);
    padding:7px 12px;
    border-radius:999px;
}

.hero-title{
    font-size:clamp(2rem,3vw,2.65rem);
    line-height:1.06;
    font-weight:950;
    margin:14px 0 10px;
    color:#e8edf7;
    letter-spacing:-.03em;
}

.hero-lead{
    max-width:760px;
    margin:0;
    color:rgba(248,250,252,.84);
    font-size:1.04rem;
    line-height:1.58;
}

.hero-lead .hl{
    color:#f2cd75;
    font-weight:950;
}

.hero-actions{
    display:flex;
    gap:12px;
    flex-wrap:wrap;
    margin-top:18px;
}

.btn-gold,
.btn-outline{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    border-radius:14px;
    padding:12px 18px;
    font-weight:950;
    text-decoration:none;
    transition:.18s ease;
}

.btn-gold{
    background:linear-gradient(180deg,var(--gold-strong),var(--gold));
    color:#fff;
    border:1.5px solid var(--border);
    box-shadow:0 14px 32px rgba(0,0,0,.18);
}

.btn-outline{
    background:rgba(255,255,255,.04);
    color:#f8fafc;
    border:1.5px solid rgba(199,153,49,.74);
}

.btn-gold:hover,
.btn-outline:hover{
    transform:translateY(-2px);
    color:#fff;
}

.hero-side{
    border:1px solid rgba(199,153,49,.34);
    background:rgba(255,255,255,.045);
    border-radius:20px;
    padding:18px;
}

.hero-side-title{
    margin:0 0 10px;
    color:#f2cd75;
    font-weight:950;
    font-size:1rem;
}

.hero-side-list{
    list-style:none;
    display:grid;
    gap:9px;
    padding:0;
    margin:0;
}

.hero-side-list li{
    color:rgba(248,250,252,.82);
    font-weight:750;
    line-height:1.35;
}

.hero-side-list li:before{
    content:"✓";
    color:#f2cd75;
    font-weight:950;
    margin-right:8px;
}

/* QUOTE CHOOSER INSIDE SAME SHELL */
.quote-picker{
    padding:0 30px 28px;
}

.picker-head{
    border-top:1px solid rgba(199,153,49,.20);
    padding-top:22px;
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    gap:18px;
    margin-bottom:16px;
}

.picker-head h2{
    margin:0;
    color:#f2cd75;
    font-size:1.35rem;
    font-weight:950;
}

.picker-head p{
    margin:4px 0 0;
    color:rgba(248,250,252,.72);
    line-height:1.45;
}

.picker-note{
    color:rgba(248,250,252,.62);
    font-size:.9rem;
    font-weight:800;
    white-space:nowrap;
}

.quote-grid{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:12px;
}

.quote-tile{
    position:relative;
    display:grid;
    grid-template-columns:auto 1fr auto;
    align-items:center;
    gap:12px;
    min-height:82px;
    padding:13px 14px;
    border-radius:17px;
    border:1px solid rgba(199,153,49,.42);
    background:rgba(255,255,255,.045);
    color:#f8fafc;
    text-decoration:none;
    transition:.18s ease;
    cursor:pointer;
}

.quote-tile:hover{
    transform:translateY(-3px);
    border-color:#f2cd75;
    background:rgba(199,153,49,.10);
    color:#f8fafc;
}

.life-tile{
    border-color:rgba(242,205,117,.78);
    background:rgba(199,153,49,.09);
}

.tile-mark{
    width:40px;
    height:40px;
    border-radius:14px;
    display:flex;
    align-items:center;
    justify-content:center;
    background:rgba(199,153,49,.14);
    border:1px solid rgba(199,153,49,.42);
    color:#f2cd75;
    font-weight:950;
    font-size:.75rem;
}

.tile-title{
    margin:0 0 2px;
    color:#f2cd75;
    font-weight:950;
    font-size:.98rem;
}

.tile-sub{
    margin:0;
    color:rgba(248,250,252,.72);
    font-size:.86rem;
    line-height:1.3;
}

.tile-arrow{
    width:28px;
    height:28px;
    border-radius:999px;
    border:1px solid rgba(199,153,49,.55);
    display:flex;
    align-items:center;
    justify-content:center;
    color:#f8fafc;
    font-weight:950;
}

/* PROCESS STRIP */
.next-strip{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:0;
    border-top:1px solid rgba(199,153,49,.20);
    background:rgba(255,255,255,.025);
}

.next-step{
    padding:18px 22px;
    border-right:1px solid rgba(199,153,49,.16);
}

.next-step:last-child{
    border-right:0;
}

.next-step span{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width:28px;
    height:28px;
    border-radius:999px;
    border:1px solid rgba(199,153,49,.62);
    color:#f2cd75;
    font-weight:950;
    margin-bottom:8px;
}

.next-step h5{
    margin:0 0 4px;
    color:#f2cd75;
    font-weight:950;
}

.next-step p{
    margin:0;
    color:rgba(248,250,252,.76);
    line-height:1.45;
    font-size:.92rem;
}

/* CALENDAR CTA */
.calendar-section{
    margin-top:28px;
    padding:24px 20px;
    background:linear-gradient(180deg,#0f172a 0%, #0b1325 100%);
    border:1.4px solid var(--border);
    border-radius:22px;
    box-shadow:0 14px 34px rgba(0,0,0,.14);
    text-align:center;
    color:#f8fafc;
}

.calendar-section h2{
    margin:0 0 8px;
    color:var(--gold-strong);
    font-weight:950;
}

.calendar-section p{
    max-width:720px;
    margin:0 auto 16px;
    color:rgba(248,250,252,.82);
    line-height:1.6;
}

.calendar-container{
    width:100%;
    height:600px;
    border-radius:16px;
    overflow:hidden;
    border:1px solid var(--border);
    background:#fff;
    position:relative;
}

.calendar-container iframe{
    position:absolute;
    inset:0;
    width:100% !important;
    height:100% !important;
    border:0;
    display:block;
}

/* LIFE MODAL */
.life-modal{
    position:fixed;
    inset:0;
    background:rgba(8,12,24,.72);
    backdrop-filter:blur(8px);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:10000;
    padding:16px;
}

.life-modal.open{ display:flex; }

.life-modal-card{
    width:min(480px,94vw);
    background:linear-gradient(180deg,#0f172a 0%,#0c1427 100%);
    border:1.6px solid rgba(199,153,49,.8);
    border-radius:16px;
    box-shadow:0 24px 60px rgba(0,0,0,.35);
    color:#f4f6fb;
    padding:18px;
    position:relative;
}

.life-modal-card h3{
    margin:0 0 12px;
    font-weight:900;
    font-size:1.2rem;
    text-align:center;
    color:#dfb75a;
}

.life-modal-close{
    position:absolute;
    top:10px;
    right:10px;
    background:transparent;
    border:1px solid rgba(244,246,251,.35);
    color:#f4f6fb;
    border-radius:10px;
    width:32px;
    height:32px;
    font-size:1.1rem;
    cursor:pointer;
}

.life-modal-grid{
    display:grid;
    grid-template-columns:1fr;
    gap:10px;
}

@@media (min-width:520px){
    .life-modal-grid{ grid-template-columns:repeat(2,1fr); }
}

.life-option{
    display:block;
    padding:12px 14px;
    border:1px solid rgba(199,153,49,.65);
    border-radius:10px;
    text-decoration:none;
    color:#f8fafc;
    font-weight:850;
    text-align:center;
    background:rgba(199,153,49,.08);
}

.life-option:hover{
    border-color:#c79931;
    background:rgba(199,153,49,.15);
    color:#dfb75a;
}

/* PRAYER */
.prayer-card{
    position:relative;
    background:#0f172a;
    border:1px solid var(--border);
    border-radius:22px;
    box-shadow:0 14px 34px rgba(0,0,0,.12);
    padding:24px 20px;
    text-align:center;
    margin-top:28px;
}

.prayer-kicker{
    letter-spacing:.18em;
    text-transform:uppercase;
    font-size:.78rem;
    color:#c79931;
    font-weight:950;
}

.prayer-text{
    margin:12px auto;
    max-width:820px;
    font-size:1rem;
    line-height:1.75;
    color:#f8fafc;
    font-weight:650;
}

.prayer-divider{
    height:2px;
    width:90px;
    background:var(--gold);
    border-radius:999px;
    margin:12px auto;
}

/* reveal */
.reveal{ opacity:0; transform:translateY(14px); transition:.55s ease; }
.reveal.show{ opacity:1; transform:translateY(0); }

@@media (max-width:992px){
    .quote-hero{ grid-template-columns:1fr; }
    .quote-grid{ grid-template-columns:repeat(2,minmax(0,1fr)); }
}

@@media (max-width:700px){
    .quote-page{ padding:16px 12px 56px; }
    .quote-hero{ padding:24px 18px 18px; }
    .quote-picker{ padding:0 18px 22px; }
    .picker-head{ align-items:flex-start; flex-direction:column; }
    .picker-note{ white-space:normal; }
    .quote-grid{ grid-template-columns:1fr; }
    .next-strip{ grid-template-columns:1fr; }
    .next-step{ border-right:0; border-bottom:1px solid rgba(199,153,49,.16); }
    .next-step:last-child{ border-bottom:0; }
    .calendar-container{ height:520px; }
}
</style>

<!-- HTML BELOW REMAINS EXACTLY THE SAME -->


@{
    var path = Context?.Request?.Path.Value ?? string.Empty;
    var segs = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
    var slugPrefix = (segs.Length >= 2 && segs[0].Equals("a", StringComparison.OrdinalIgnoreCase))
        ? $"/a/{segs[1]}"
        : string.Empty;
    string Link(string relative)
    {
        var basePath = Context?.Request?.PathBase.Value ?? string.Empty;
        return $"{basePath}{slugPrefix}{relative}";
    }
}

<div class="quote-page">

    <section class="quote-flow reveal">
        <div class="quote-hero">
            <div>
                <div class="hero-kicker">Legend™ Quote Center</div>
                <h1 class="hero-title">Get covered without guessing.</h1>
                <p class="hero-lead">
                    Choose the protection lane that fits your situation. We’ll help you move from
