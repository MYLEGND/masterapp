                    </span>
                    <span class="tile-arrow">→</span>
                </a>

                <a href="@Link("/Quote/Commercial")" class="quote-tile" aria-label="Start Commercial Insurance Quote" data-cta="quote_index_commercial_start">
                    <span class="tile-mark">BIZ</span>
                    <span>
                        <p class="tile-title">Commercial Insurance</p>
                        <p class="tile-sub">Business, team, income stream.</p>
                    </span>
                    <span class="tile-arrow">→</span>
                </a>

                <div class="quote-tile life-tile" tabindex="0" role="button" aria-haspopup="dialog" aria-expanded="false" data-cta="quote_index_life_start">
                    <span class="tile-mark">LIFE</span>
                    <span>
                        <p class="tile-title">Life Insurance</p>
                        <p class="tile-sub">Family, mortgage, legacy.</p>
                    </span>
                    <span class="tile-arrow">▾</span>
                </div>

                <a href="@Link("/Quote/Disability")" class="quote-tile" aria-label="Start Disability Insurance Quote" data-cta="quote_index_disability_start">
                    <span class="tile-mark">DI</span>
                    <span>
                        <p class="tile-title">Disability Insurance</p>
                        <p class="tile-sub">Protect your paycheck.</p>
                    </span>
                    <span class="tile-arrow">→</span>
                </a>

                <a href="@Link("/Quote/Health")" class="quote-tile" aria-label="Start Health Insurance Quote" data-cta="quote_index_health_start">
                    <span class="tile-mark">HLTH</span>
                    <span>
                        <p class="tile-title">Health Insurance</p>
                        <p class="tile-sub">Needs, budget, season.</p>
                    </span>
                    <span class="tile-arrow">→</span>
