@using System.Text.Json
@model Protect_Website.Models.HealthQuoteFormModel

@{
    var form = Model ?? new Protect_Website.Models.HealthQuoteFormModel();
    var requestPath = Context?.Request?.Path.Value ?? string.Empty;
    var isLandingRoutePath = requestPath.Contains("/landing", StringComparison.OrdinalIgnoreCase);
    const string websitePageVariant = "website";
    const string contactFirstEducationVariant = "contact_first_education_v1";
    var pageVariant = string.IsNullOrWhiteSpace(form.PageVariant)
        ? (isLandingRoutePath ? contactFirstEducationVariant : websitePageVariant)
        : form.PageVariant.Trim();
    var pageMode = string.IsNullOrWhiteSpace(form.PageMode)
        ? (isLandingRoutePath ? "paid_landing" : "site_mode")
        : form.PageMode.Trim();
    var isPaidLandingExperience = string.Equals(pageMode, "paid_landing", StringComparison.OrdinalIgnoreCase);
    var isStandaloneLandingExperience = isLandingRoutePath || isPaidLandingExperience;
    var pageKey = string.IsNullOrWhiteSpace(form.PageKey)
        ? (isStandaloneLandingExperience ? "quote_health_landing" : "quote_health")
        : form.PageKey.Trim();
    var formKey = $"{pageKey}_form";
    var requestScheme = Context?.Request?.Scheme ?? "https";
    var requestHost = Context?.Request?.Host.Value ?? string.Empty;
    var seoImageUrl = string.IsNullOrWhiteSpace(requestHost)
        ? "/images/ads/health-top-banner.png"
        : $"{requestScheme}://{requestHost}/images/ads/health-top-banner.png";

    ViewData["SeoTitle"] = "Health Insurance Review";
    ViewData["SeoDescription"] = "Review health insurance options around household needs, current coverage, doctor access, and affordability.";
    ViewData["SeoImage"] = seoImageUrl;
    ViewData["Title"] = "Get Your Personalized Health Coverage Review";
    ViewData["PageKey"] = pageKey;
    ViewData["PageCategory"] = "quote";
    ViewData["PageVariant"] = pageVariant;
    ViewData["PageMode"] = pageMode;
    ViewData["QuoteTypeForTracking"] = "health";
    ViewData["IsLandingPage"] = isStandaloneLandingExperience;
    ViewData["BodyClass"] = isStandaloneLandingExperience ? "health-landing" : "health-quote";

    var isFounderPath = ViewData["IsFounderPath"] as bool? == true;
    var trackedSlug = ((string?)ViewData["TrackingSlug"] ?? string.Empty).Trim();
    var agentSlug = !isFounderPath ? trackedSlug : string.Empty;
    var postedAgeRange = Context?.Request?.HasFormContentType == true
        ? Context.Request.Form["AgeRange"].ToString()
        : string.Empty;

    string ResolveAgeRange(int? age)
    {
        if (!age.HasValue) return string.Empty;
        return age.Value switch
        {
            <= 24 => "18-24",
            <= 34 => "25-34",
            <= 44 => "35-44",
            <= 54 => "45-54",
            <= 64 => "55-64",
            _ => "65+"
        };
    }

    int ResolveAgeValue(string? ageRange)
    {
        return (ageRange ?? string.Empty).Trim() switch
        {
            "18-24" => 21,
            "25-34" => 30,
            "35-44" => 40,
            "45-54" => 50,
            "55-64" => 60,
            "65+" => 70,
            _ => form.Age ?? 30
        };
    }

    string CheckedIf(bool condition) => condition ? "checked" : string.Empty;
    string SelectedClassIf(bool condition) => condition ? "lq-selected" : string.Empty;

    var selectedAgeRange = string.IsNullOrWhiteSpace(form.AgeRange)
        ? (!string.IsNullOrWhiteSpace(postedAgeRange) ? postedAgeRange : ResolveAgeRange(form.Age))
        : form.AgeRange.Trim();

    var initialAgeValue = form.Age ?? ResolveAgeValue(selectedAgeRange);
    var hasServerErrors = ViewData.ModelState.ErrorCount > 0;
    var showContactStepByDefault =
        hasServerErrors ||
        !string.IsNullOrWhiteSpace(form.FirstName) ||
        !string.IsNullOrWhiteSpace(form.LastName) ||
        !string.IsNullOrWhiteSpace(form.Email) ||
        !string.IsNullOrWhiteSpace(form.Phone);
    IReadOnlyList<string> heroProofChips = new[] { "Affordable options", "Licensed review", "No obligation" };
    var heroStepIntroTitle = "Start with the coverage pressure";
    var heroStepIntroHelper = "A quick health coverage review built around your household, current plan status, and what matters most before unexpected medical costs catch you off guard.";
    var primaryStartCtaText = "Check My Coverage Fit";
    var primaryStartCtaNote = "A quick review now can help protect your household from costly coverage gaps later.";
    var contactMethodHelperText = "Best number to save and review your health coverage details.";
    var contactMethodErrorText = "Please enter your phone number so we can save your review.";
    var consentPromptText = "I agree to receive a call or text to review my health coverage options and next steps.";
    var consentErrorText = "Please check the box so we can save your review.";

    form.PageVariant = pageVariant;
    form.PageMode = pageMode;
}

