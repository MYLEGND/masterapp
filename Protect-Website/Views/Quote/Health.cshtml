@model Protect_Website.Models.HealthQuoteFormModel

@{
    ViewData["Title"] = "Explore Your Health Insurance Options";
    ViewData["PageKey"] = "quote_health";
    var isFounderPath = ViewData["IsFounderPath"] as bool? == true;
    var trackedSlug = ((string?)ViewData["TrackingSlug"] ?? string.Empty).Trim();
    var agentSlug = !isFounderPath ? trackedSlug : string.Empty;
}

<div class="container-narrow">

    <div class="text-center" style="margin-top:18px; margin-bottom:6px;">
        <h1 style="
            font-weight: 900;
            font-size: 2rem;
            color: #a68023;
            letter-spacing: .5px;
            margin-bottom: 6px;">
            Explore Your Health Insurance Options
        </h1>
    </div>

    <p class="required-note text-center">
        <strong>
            * Fields marked with an asterisk are required.
        </strong>
    </p>

<style>
    body { background-color: #0f172a; color: #f8fafc; }

    .section-card {
        background-color: #0f172a;
        border: 1.6px solid #c79931;
        padding: 16px;
        border-radius: 12px;
        margin-bottom: 24px;
        box-shadow: 0 18px 40px rgba(0,0,0,0.18);
        color: #f8fafc;
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 900;
        color: #c79931;
        margin-bottom: 12px;
    }

    .form-control, .form-select {
        border: 1.6px solid #c79931;
        margin-bottom: 10px;
        background: #ffffff;
        color: #0f172a;
        font-size: 0.95rem;
        padding: 8px 10px;
    }
    .form-control::placeholder, .form-select::placeholder{
        color: rgba(15,23,42,0.55);
    }
    .form-control:focus, .form-select:focus {
        outline: none;
        box-shadow: 0 0 0 0.2rem rgba(199,153,49,0.22);
        border-color: #c79931;
        background: #ffffff;
        color: #0f172a;
    }

    .btn-gold {
        background: linear-gradient(180deg, #c79931, #a68023);
        color: #fff;
        font-weight: 900;
        padding: 9px 20px;
        border-radius: 8px;
        font-size: 1rem;
        border: 1.4px solid #c79931;
        box-shadow: 0 14px 32px rgba(0,0,0,0.18);
    }

    .btn-gold:hover {
        background: linear-gradient(180deg, #c79931, #a68023);
        color: #fff;
    }

    .text-gold { color: #c79931; }

    /* ===================== DISCLAIMER ===================== */
    .disclaimer-container {
        margin-top: 40px;
        margin-bottom: 40px;
        font-size: 1rem;
        font-weight: bold;
        line-height: 1.5;
        color: #f8fafc;
        display: flex;
        align-items: flex-start;
    }

    .disclaimer-container input {
        margin-right: 12px;
        margin-top: 4px;
        width: 20px;
        height: 20px;
    }

    /* ===== Visual-only: single-card layout + tighter, lead-form grouping ===== */
    .lead-card{
        max-width: 1100px;
        width: 100%;
        margin: 0 auto 24px auto;
    }

    .lead-grid{
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
    }

    .lead-block{
        border: 1.4px solid #c79931;
        border-radius: 10px;
        padding: 12px 12px 4px 12px;
        background: #111c32;
        color: #f8fafc;
    }

    .lead-block .section-title{
        margin-bottom: 12px;
        font-size: 1.15rem;
        color: #c79931;
    }

    .lead-row{
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px 14px;
    }

    @@media (min-width: 768px){
        .lead-row.three{
            grid-template-columns: repeat(3, 1fr);
        }
        .lead-row.two{
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .field{
        margin-bottom: 0;
    }

    .field label{
        display:block;
        margin-bottom: 6px;
        font-weight: 800;
        color: #f8fafc;
        font-size: .95rem;
    }

    .field .form-control,
    .field .form-select{
        margin-bottom: 8px;
    }

    .field .form-select{
        cursor: pointer;
        appearance: auto;
    }

    .field .form-select:invalid{
        color: #64748b;
    }

    .field .form-select option[value=""]{
        color: #64748b;
    }

.disclaimer-wrap{
    margin-top: 6px;
}
.disclaimer-check{
    display:flex;
    align-items:flex-start;
    gap:10px;
    padding:10px 0;
}
.disclaimer-check .form-check-input{
    width:18px;
    height:18px;
    margin-top:2px;
    margin-left:0;
    margin-right:0;
    position:static;
    flex-shrink:0;
}
.disclaimer-check .form-check-label{
    line-height:1.5;
    white-space:normal;
    color:#f8fafc;
}
</style>

<!-- ===================== SUCCESS MESSAGE ===================== -->
@if (ViewBag.Success != null)
{
    <div class="success-message">
        @ViewBag.Success
    </div>
}

<form asp-action="SubmitHealthQuote" asp-controller="HealthQuote" method="post" id="healthQuoteForm" data-form-key="quote_health_form">
    @if (!string.IsNullOrWhiteSpace(agentSlug))
    {
        <input type="hidden" name="AgentSlug" value="@agentSlug" />
    }

    <!-- ===================== SINGLE CONTACT CARD (VISUAL RE-ORG ONLY) ===================== -->
    <div class="section-card lead-card">

        <div class="lead-grid">

            <!-- CORE DETAILS -->
            <div class="lead-block">

                <div class="section-title">Tell Us About You</div>

                <div class="lead-row three">
                    <div class="field">
                        <label>First Name*</label>
                        <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                    </div>
                    <div class="field">
                        <label>Last Name*</label>
                        <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                    </div>
                    <div class="field">
                        <label>Age*</label>
                        <input asp-for="Age" class="form-control" placeholder="Age" />
                    </div>
                </div>

                <div class="lead-row two">
                    <div class="field">
                        <label>Email*</label>
                        <input asp-for="Email" class="form-control" placeholder="Email" />
                    </div>
                    <div class="field">
                        <label>Phone*</label>
                        <input asp-for="Phone" class="form-control" placeholder="Phone" />
                    </div>
                </div>

                <div class="section-title" style="margin-top: 6px;">Next Steps</div>

                <div class="lead-row two">
                    <div class="field">
                        <label>Preferred Contact Method*</label>
                        <select asp-for="ContactMethod" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Phone</option>
                            <option>Email</option>
                            <option>Text</option>
                        </select>
                    </div>

                    <div class="field">
                        <label>Best Time To Contact*</label>
                        <select asp-for="BestTimeToContact" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Morning</option>
                            <option>Afternoon</option>
                            <option>Evening</option>
                        </select>
                    </div>
                </div>

            </div>

            <!-- ADDITIONAL DETAILS -->
            <div class="lead-block">

                <div class="section-title">Help Us Understand Your Needs</div>

                <div class="lead-row two">
                    <div class="field">
                        <label>Household Size*</label>
                        <input asp-for="HouseholdSize" class="form-control" placeholder="e.g. 4" required />
                    </div>

                    <div class="field">
                        <label>Primary Concern*</label>
                        <select asp-for="PrimaryConcern" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Lower Monthly Premium</option>
                            <option>Lower Deductible</option>
                            <option>Better Doctor Network</option>
                            <option>Prescription Coverage</option>
                            <option>Family Coverage</option>
                            <option>Dental / Vision Options</option>
                            <option>Marketplace / ACA Guidance</option>
                            <option>Not Sure / Need Guidance</option>
                        </select>
                    </div>
                </div>

            </div>

        </div>

        <!-- ===================== DISCLAIMER ===================== -->
        <div class="lead-block disclaimer-wrap">
            <div class="form-check disclaimer-check">
                <input asp-for="AcknowledgedDisclaimer" type="checkbox" class="form-check-input" id="disclaimerCheckbox" required />
                <label class="form-check-label" for="disclaimerCheckbox">
                    I acknowledge that by submitting this form, I authorize the company to contact me regarding my health insurance inquiry and personalized coverage review.*
                </label>
            </div>
            <span asp-validation-for="AcknowledgedDisclaimer" class="text-danger"></span>

            <div class="text-center mb-5" style="margin-top: 30px;">
                <button type="submit" class="btn btn-gold">Explore My Options</button>
            </div>
        </div>

    </div>
    <input type="hidden" name="SessionId" />
    <input type="hidden" name="VisitorId" />
    <input type="hidden" name="UtmSource" />
    <input type="hidden" name="UtmMedium" />
    <input type="hidden" name="UtmCampaign" />
    <input type="hidden" name="UtmId" />
    <input type="hidden" name="UtmTerm" />
    <input type="hidden" name="UtmContent" />
    <input type="hidden" name="MetaCampaignId" />
    <input type="hidden" name="MetaAdSetId" />
    <input type="hidden" name="MetaAdId" />
    <input type="hidden" name="Fbclid" />
    <input type="hidden" name="ReferrerUrl" />
    <input type="hidden" name="LandingPageUrl" />
</form>
<script>
(function () {
    var ids = window.legendTrackingIds;
    var p = new URLSearchParams(window.location.search);
    var attr = ids && ids.getAttribution ? (ids.getAttribution() || {}) : {};
    function sh(n, v) { var e = document.querySelector('input[name="' + n + '"]'); if (e && v) e.value = v; }
    sh('SessionId',    ids && ids.getSessionId ? ids.getSessionId() : '');
    sh('VisitorId',    ids && ids.getVisitorId ? ids.getVisitorId() : '');
    sh('UtmSource',    attr.utmSource || p.get('utm_source') || '');
    sh('UtmMedium',    attr.utmMedium || p.get('utm_medium') || '');
    sh('UtmCampaign',  attr.utmCampaign || p.get('utm_campaign') || '');
    sh('UtmId',        attr.utmId || p.get('utm_id') || '');
    sh('UtmTerm',      attr.utmTerm || p.get('utm_term') || '');
    sh('UtmContent',   attr.utmContent || p.get('utm_content') || '');
    sh('MetaCampaignId', attr.metaCampaignId || p.get('meta_campaign_id') || '');
    sh('MetaAdSetId',  attr.metaAdSetId || p.get('meta_adset_id') || '');
    sh('MetaAdId',     attr.metaAdId || p.get('meta_ad_id') || '');
    sh('Fbclid',       attr.fbclid || p.get('fbclid') || '');
    sh('ReferrerUrl',  document.referrer || '');
    sh('LandingPageUrl', window.location.href || '');
})();
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById('healthQuoteForm');
    const checkbox = document.getElementById('disclaimerCheckbox');
    const trackHealthQuote = (window.legendTrack && typeof window.legendTrack === 'function')
        ? window.legendTrack
        : null;

    if (!form || !checkbox) return;

    trackHealthQuote?.({
        EventType: 'quote_contact_step_view',
        FormKey: 'quote_health_form',
        PageKey: 'quote_health',
        MetadataJson: JSON.stringify({ stepNumber: 1, source: 'single_step_form_view' })
    });

    form.addEventListener('submit', function(event) {
        if (!checkbox.checked) {
            form._trackSubmitAttempt?.(false, 1);
            event.preventDefault();
            alert('Please acknowledge the disclaimer to proceed: You must authorize us to contact you regarding your health insurance inquiry and personalized coverage review.');
        }
    });
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.querySelector("form");

    if (!form) return;

    form.addEventListener("submit", function (event) {
        if (!form.checkValidity()) {
            form._trackSubmitAttempt?.(false, form.querySelectorAll(':invalid').length);
            event.preventDefault();

            const firstInvalid = form.querySelector(":invalid");
            if (firstInvalid) {
                firstInvalid.scrollIntoView({
                    behavior: "smooth",
                    block: "center"
                });
                firstInvalid.focus();
            }
        } else {
            form._trackSubmitAttempt?.(true, 0);
        }
    });
});
</script>
