@model Protect_Website.Models.HealthQuoteFormModel

@{
    ViewData["Title"] = "Health Insurance Quote";
    ViewData["PageKey"] = "quote_health";
}

<div class="container-narrow">

    <div class="text-center" style="margin-top:18px; margin-bottom:6px;">
        <h1 style="
            font-weight: 900;
            font-size: 2.4rem;
            color: #a68023;
            letter-spacing: .5px;
            margin-bottom: 6px;">
            Health Insurance Quote
        </h1>
    </div>

    <p class="required-note text-center">
        <strong>
            <span class="text-danger">*</span> Fields marked with a red asterisk are required.
        </strong>
    </p>

<style>
    body { background-color: #0f172a; color: #f8fafc; }

    .section-card {
        background-color: #0f172a;
        border: 1.6px solid #c79931;
        padding: 18px;
        border-radius: 12px;
        margin-bottom: 24px;
        box-shadow: 0 18px 40px rgba(0,0,0,0.18);
        color: #f8fafc;
    }

    .section-title {
        font-size: 1.4rem;
        font-weight: 900;
        color: #c79931;
        margin-bottom: 16px;
    }

    .form-control, .form-select {
        border: 1.6px solid #c79931;
        margin-bottom: 16px;
        background: #ffffff;
        color: #0f172a;
    }
    .form-control::placeholder, .form-select::placeholder{
        color: rgba(15,23,42,0.55);
    }
    .form-control:focus, .form-select:focus {
        outline: none;
        box-shadow: 0 0 0 0.2rem rgba(199,153,49,0.22);
        border-color: #c79931;
        background: #ffffff;
        color: #0f172a;
    }

    .btn-gold {
        background: linear-gradient(180deg, #c79931, #a68023);
        color: #fff;
        font-weight: 900;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 1.1rem;
        border: 1.4px solid #c79931;
        box-shadow: 0 14px 32px rgba(0,0,0,0.18);
    }

    .btn-gold:hover {
        background: linear-gradient(180deg, #c79931, #a68023);
        color: #fff;
    }

    .text-gold { color: #c79931; }

    /* ===================== DISCLAIMER ===================== */
    .disclaimer-container {
        margin-top: 40px;
        margin-bottom: 40px;
        font-size: 1rem;
        font-weight: bold;
        line-height: 1.5;
        color: #f8fafc;
        display: flex;
        align-items: flex-start;
    }

    .disclaimer-container input {
        margin-right: 12px;
        margin-top: 4px;
        width: 20px;
        height: 20px;
    }

    /* ===== Visual-only: single-card layout + tighter, lead-form grouping ===== */
    .lead-card{
        max-width: 1320px;
        width: 100%;
        margin: 0 auto 30px auto;
    }

    .lead-grid{
        display: grid;
        grid-template-columns: 1fr;
        gap: 18px;
    }

    @@media (min-width: 992px){
        .lead-grid{
            grid-template-columns: 1fr 1fr;
            gap: 22px;
        }
    }

    .lead-block{
        border: 1.4px solid #c79931;
        border-radius: 10px;
        padding: 16px 16px 6px 16px;
        background: #111c32;
        color: #f8fafc;
    }

    .lead-block .section-title{
        margin-bottom: 12px;
        font-size: 1.15rem;
        color: #c79931;
    }

    .lead-row{
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px 14px;
    }

    @@media (min-width: 768px){
        .lead-row.three{
            grid-template-columns: repeat(3, 1fr);
        }
        .lead-row.two{
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .field{
        margin-bottom: 0;
    }

    .field label{
        display:block;
        margin-bottom: 6px;
        font-weight: 800;
        color: #f8fafc;
        font-size: .95rem;
    }

    .field .form-control,
    .field .form-select{
        margin-bottom: 8px;
    }

    .field .form-select{
        cursor: pointer;
        appearance: auto;
    }

    .field .form-select:invalid{
        color: #64748b;
    }

    .field .form-select option[value=""]{
        color: #64748b;
    }

    .quote-step-nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 14px;
        padding: 10px 12px;
        border: 1px solid rgba(199,153,49,.45);
        border-radius: 10px;
        background: #111c32;
    }

    .quote-step-label {
        color: #f8fafc;
        font-weight: 800;
        font-size: .95rem;
    }

    .btn-step {
        border: 1.4px solid #c79931;
        background: transparent;
        color: #f8fafc;
        border-radius: 8px;
        font-weight: 800;
        padding: 8px 12px;
    }

    .qs-hidden { display: none !important; }

.disclaimer-wrap{
    margin-top: 6px;
}
.disclaimer-check{
    display:flex;
    align-items:flex-start;
    gap:10px;
    padding:10px 0;
}
.disclaimer-check .form-check-input{
    width:18px;
    height:18px;
    margin-top:2px;
    margin-left:0;
    margin-right:0;
    position:static;
    flex-shrink:0;
}
.disclaimer-check .form-check-label{
    line-height:1.5;
    white-space:normal;
    color:#f8fafc;
}
</style>

<!-- ===================== SUCCESS MESSAGE ===================== -->
@if (ViewBag.Success != null)
{
    <div class="success-message">
        @ViewBag.Success
    </div>
}

<form asp-action="SubmitHealthQuote" asp-controller="HealthQuote" method="post" id="healthQuoteForm" data-form-key="quote_health_form">

    <!-- ===================== SINGLE CONTACT CARD (VISUAL RE-ORG ONLY) ===================== -->
    <div class="section-card lead-card">

        <div class="quote-step-nav">
            <div class="quote-step-label" id="health-step-label">Step 1 of 2 · Quick Quote</div>
            <div class="d-flex gap-2">
                <button type="button" class="btn-step qs-hidden" id="health-step-back">Back</button>
                <button type="button" class="btn-step" id="health-step-next">Continue</button>
            </div>
        </div>

        <div class="lead-grid">

            <!-- LEFT: Personal Info + Next Steps -->
            <div class="lead-block">

                <div class="section-title">Personal Information</div>

                <div class="lead-row three">
                    <div class="field">
                        <label>First Name<span class="text-danger">*</span></label>
                        <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                    </div>
                    <div class="field">
                        <label>Last Name<span class="text-danger">*</span></label>
                        <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                    </div>
                    <div class="field">
                        <label>Age<span class="text-danger">*</span></label>
                        <input asp-for="Age" class="form-control" placeholder="Age" />
                    </div>
                </div>

                <div class="lead-row two">
                    <div class="field">
                        <label>Email<span class="text-danger">*</span></label>
                        <input asp-for="Email" class="form-control" placeholder="Email" />
                    </div>
                    <div class="field">
                        <label>Phone<span class="text-danger">*</span></label>
                        <input asp-for="Phone" class="form-control" placeholder="Phone" />
                    </div>
                </div>

                <div class="section-title" style="margin-top: 6px;">Next Steps</div>

                <div class="lead-row two">
                    <div class="field">
                        <label>Preferred Contact Method<span class="text-danger">*</span></label>
                        <select asp-for="ContactMethod" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Phone</option>
                            <option>Email</option>
                            <option>Text</option>
                        </select>
                    </div>

                    <div class="field">
                        <label>Best Time<span class="text-danger">*</span></label>
                        <select asp-for="BestTimeToContact" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Morning</option>
                            <option>Afternoon</option>
                            <option>Evening</option>
                        </select>
                    </div>
                </div>

            </div>

            <!-- RIGHT: Coverage Needs -->
            <div class="lead-block">

                <div class="section-title">Coverage Needs</div>

                <div class="lead-row three">
                    <div class="field">
                        <label>Coverage Type<span class="text-danger">*</span></label>
                        <select asp-for="CoverageType" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Individual</option>
                            <option>Family</option>
                            <option>Employer</option>
                            <option>Marketplace</option>
                        </select>
                    </div>

                    <div class="field">
                        <label>Currently Insured?<span class="text-danger">*</span></label>
                        <select asp-for="CurrentCoverage" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Yes</option>
                            <option>No</option>
                        </select>
                    </div>

                    <div class="field">
                        <label>Household Size<span class="text-danger">*</span></label>
                        <select asp-for="HouseholdSize" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>1</option>
                            <option>2–3</option>
                            <option>4–5</option>
                            <option>6+</option>
                        </select>
                    </div>
                </div>

                <div class="lead-row two">
                    <div class="field">
                        <label>Primary Concern<span class="text-danger">*</span></label>
                        <select asp-for="PrimaryConcern" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Monthly Cost</option>
                            <option>High Deductibles</option>
                            <option>Doctor Network</option>
                            <option>Prescription Coverage</option>
                        </select>
                    </div>

                    <div class="field">
                        <label>When Do You Need Coverage?<span class="text-danger">*</span></label>
                        <select asp-for="Timeline" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Immediately</option>
                            <option>Within 30 Days</option>
                            <option>60+ Days</option>
                        </select>
                    </div>
                </div>

            </div>

        </div>

        <!-- ===================== DISCLAIMER ===================== -->
        <div class="lead-block disclaimer-wrap">
            <div class="form-check disclaimer-check">
                <input asp-for="AcknowledgedDisclaimer" type="checkbox" class="form-check-input" id="disclaimerCheckbox" required />
                <label class="form-check-label" for="disclaimerCheckbox">
                    I acknowledge that by submitting this form, I authorize the company to contact me regarding my health insurance quote request.<span class="text-danger">*</span>
                </label>
            </div>
            <span asp-validation-for="AcknowledgedDisclaimer" class="text-danger"></span>

            <div class="text-center mb-5" style="margin-top: 30px;">
                <button type="submit" class="btn btn-gold">Request My Quote</button>
            </div>
        </div>

    </div>

</form>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById('healthQuoteForm');
    const nextBtn = document.getElementById('health-step-next');
    const backBtn = document.getElementById('health-step-back');
    const stepLabel = document.getElementById('health-step-label');
    const disclaimerWrap = form?.querySelector('.disclaimer-wrap');

    if (!form || !nextBtn || !backBtn || !stepLabel) return;

    const step2Names = new Set([
        'CurrentCoverage',
        'PrimaryConcern',
        'Timeline',
        'ContactMethod',
        'BestTimeToContact',
        'AcknowledgedDisclaimer'
    ]);

    const step1RequiredNames = [
        'FirstName', 'LastName', 'Age', 'Email', 'Phone', 'CoverageType', 'HouseholdSize'
    ];

    const step2Fields = [];
    step2Names.forEach((name) => {
        const input = form.querySelector(`[name="${name}"]`);
        if (!input) return;
        const wrapper = input.closest('.field') || input.closest('.form-check') || input;
        if (wrapper) step2Fields.push(wrapper);
    });

    const setStep = (step) => {
        const showStep2 = step === 2;
        step2Fields.forEach(el => el.classList.toggle('qs-hidden', !showStep2));
        if (disclaimerWrap) disclaimerWrap.classList.toggle('qs-hidden', !showStep2);
        nextBtn.classList.toggle('qs-hidden', showStep2);
        backBtn.classList.toggle('qs-hidden', !showStep2);
        stepLabel.textContent = showStep2 ? 'Step 2 of 2 · Final Details' : 'Step 1 of 2 · Quick Quote';
    };

    const validateStep1 = () => {
        for (const name of step1RequiredNames) {
            const input = form.querySelector(`[name="${name}"]`);
            if (input && !input.checkValidity()) {
                input.reportValidity();
                input.focus();
                return false;
            }
        }
        return true;
    };

    nextBtn.addEventListener('click', () => {
        if (!validateStep1()) return;
        setStep(2);
        form.querySelector('[name="CurrentCoverage"]')?.focus();
    });

    backBtn.addEventListener('click', () => {
        setStep(1);
        form.querySelector('[name="FirstName"]')?.focus();
    });

    setStep(1);
});
</script>

<script>
    const form = document.getElementById('healthQuoteForm');
    const checkbox = document.getElementById('disclaimerCheckbox');

    form.addEventListener('submit', function(event) {
        if (!checkbox.checked) {
            event.preventDefault();
            alert('Please acknowledge the disclaimer to proceed: You must authorize us to contact me regarding your health insurance interest.');
        }
    });
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.querySelector("form");

    if (!form) return;

    form.addEventListener("submit", function (event) {
        if (!form.checkValidity()) {
            event.preventDefault();

            const firstInvalid = form.querySelector(":invalid");
            if (firstInvalid) {
                firstInvalid.scrollIntoView({
                    behavior: "smooth",
                    block: "center"
                });
                firstInvalid.focus();
            }
        }
    });
});
</script>
