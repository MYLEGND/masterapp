<div class="dq-shell">
    <div class="lq-hero-shell">
        <div class="dq-surface">
            <div class="dq-hero-entry" id="healthHeroEntryPanel" @((showContactStepByDefault ? "hidden" : null))>
                <figure class="dq-hero-banner-wrap">
                    <img class="dq-hero-banner-image" src="~/images/ads/health-top-banner.png" asp-append-version="true" alt="Legend health insurance review creative inviting a quick health coverage review." loading="eager" />
                </figure>

                <div class="lq-above-fold-proof" aria-label="Review benefits">
                    @foreach (var chip in heroProofChips)
                    {
                        <span>@chip</span>
                    }
                </div>

                <div class="lq-hero-step-copy">
                    <div class="lq-hero-step-copy-title">@heroStepIntroTitle</div>
                    <p class="lq-hero-step-copy-helper">@heroStepIntroHelper</p>
                </div>

                <div class="lq-contact-first-hero-actions">
                    <button type="button" class="btn-gold lq-primary-start-cta lq-contact-first-hero-cta" id="healthHeroStartCta" data-cta="health_funnel_start">@primaryStartCtaText</button>
                    <div class="lq-contact-first-hero-cta-note lq-primary-start-note">@primaryStartCtaNote</div>
                </div>
            </div>

            <form asp-action="SubmitHealthQuote" asp-controller="HealthQuote" method="post" id="healthQuoteForm" data-form-key="quote_health_form" novalidate>
                @Html.AntiForgeryToken()
                @if (!string.IsNullOrWhiteSpace(agentSlug))
                {
                    <input type="hidden" name="AgentSlug" value="@agentSlug" />
                }

                <input type="hidden" name="PageKey" value="quote_health" />
                <input type="hidden" name="PageVariant" value="@pageVariant" />
                <input type="hidden" name="PageMode" value="@pageMode" />
                <input type="hidden" name="Age" id="Age" value="@initialAgeValue" />
                <input type="hidden" name="SessionId" id="SessionId" />
                <input type="hidden" name="VisitorId" id="VisitorId" />
                <input type="hidden" name="UtmSource" id="UtmSource" />
                <input type="hidden" name="UtmMedium" id="UtmMedium" />
                <input type="hidden" name="UtmCampaign" id="UtmCampaign" />
                <input type="hidden" name="UtmId" id="UtmId" />
                <input type="hidden" name="UtmTerm" id="UtmTerm" />
                <input type="hidden" name="UtmContent" id="UtmContent" />
                <input type="hidden" name="MetaCampaignId" id="MetaCampaignId" />
                <input type="hidden" name="MetaAdSetId" id="MetaAdSetId" />
                <input type="hidden" name="MetaAdId" id="MetaAdId" />
                <input type="hidden" name="Fbclid" id="Fbclid" />
                <input type="hidden" name="ReferrerUrl" id="ReferrerUrl" />
                <input type="hidden" name="LandingPageUrl" id="LandingPageUrl" />

                <noscript>
                    <style>
                        #healthEducationPanel[hidden] { display: block !important; }
                    </style>
                </noscript>

                <div class="dq-primary-grid" id="healthEducationPanel" @((showContactStepByDefault ? null : "hidden"))>
                    <section class="dq-form-panel" id="healthEducationContactPanel">
                        <div class="dq-proof-card" aria-label="How this health review helps">
                            <div class="dq-proof-icon" aria-hidden="true">
                                <svg viewBox="0 0 48 48" fill="none"><use href="#dq-icon-shield"></use></svg>
                            </div>
                            <div class="dq-proof-copy">
                                <div class="dq-proof-kicker">Health coverage review</div>
                                <div class="dq-proof-title">Protect your household from surprise medical costs and coverage gaps.</div>
                                <p class="dq-proof-text">Answer a few quick questions so the conversation starts around your household needs, current coverage, and the kind of plan guidance you want first.</p>
                            </div>
                        </div>

                        <div class="dq-proof-chips" aria-hidden="true">
                            <span class="dq-proof-chip">Affordable plan focus</span>
                            <span class="dq-proof-chip">Family coverage guidance</span>
                            <span class="dq-proof-chip">Private and no-pressure</span>
                        </div>

                        <div class="dq-wizard-surface">
                            @if (hasServerErrors)
                            {
                                <div class="lq-alert" role="alert">
                                    <ul>
                                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                        {
                                            <li>@error.ErrorMessage</li>
                                        }
                                    </ul>
                                </div>
                            }

                            <div class="lq-step-panel" id="dqStep1Panel" @((showContactStepByDefault ? "hidden" : null))>
                                <div class="lq-step-panel-pad">
                                    <div class="lq-step-progress-wrap" aria-live="polite">
                                        <div class="lq-step-progress" id="dqStep1Progress">Question 1 of 5</div>
                                        <div class="lq-step-progress-track" aria-hidden="true">
                                            <span class="lq-step-progress-fill" id="dqStep1ProgressFill"></span>
                                        </div>
                                    </div>

                                    <div class="lq-micro-step" data-micro-step="0">
                                        <div class="lq-step-intro">
                                            <h2 class="lq-step-title">Let's tailor the health review.</h2>
                                            <p class="lq-step-helper">Answer a few quick questions first so your review reflects your household, current coverage, and the tradeoffs that matter most.</p>
                                        </div>
                                        <div class="lq-choice-group" role="radiogroup" aria-labelledby="dqAgeRangeLabel">
                                            <div class="lq-choice-label" id="dqAgeRangeLabel">What is your age range?</div>
                                            <div class="lq-choice-grid">
                                                <label class="lq-card lq-card-rich @SelectedClassIf(selectedAgeRange == "18-24")">
                                                    <input type="radio" name="AgeRange" value="18-24" @CheckedIf(selectedAgeRange == "18-24") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-calendar"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Age band</span>
                                                        <span class="lq-card-title">18-24</span>
                                                        <span class="lq-card-helper">A strong time to lock in affordable basics before care gets more expensive.</span>
                                                    </span>
                                                </label>
                                                <label class="lq-card lq-card-rich @SelectedClassIf(selectedAgeRange == "25-34")">
                                                    <input type="radio" name="AgeRange" value="25-34" @CheckedIf(selectedAgeRange == "25-34") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-calendar"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Age band</span>
                                                        <span class="lq-card-title">25-34</span>
                                                        <span class="lq-card-helper">Monthly cost, preventive care, and reliable access often matter more here.</span>
                                                    </span>
                                                </label>
                                                <label class="lq-card lq-card-rich @SelectedClassIf(selectedAgeRange == "35-44")">
                                                    <input type="radio" name="AgeRange" value="35-44" @CheckedIf(selectedAgeRange == "35-44") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-calendar"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Age band</span>
                                                        <span class="lq-card-title">35-44</span>
                                                        <span class="lq-card-helper">Family needs, prescriptions, and network fit often shape plan choices here.</span>
                                                    </span>
                                                </label>
                                                <label class="lq-card lq-card-rich @SelectedClassIf(selectedAgeRange == "45-54")">
                                                    <input type="radio" name="AgeRange" value="45-54" @CheckedIf(selectedAgeRange == "45-54") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-calendar"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Age band</span>
                                                        <span class="lq-card-title">45-54</span>
                                                        <span class="lq-card-helper">Doctor access, deductible exposure, and preventive care usually matter more here.</span>
                                                    </span>
                                                </label>
                                                <label class="lq-card lq-card-rich @SelectedClassIf(selectedAgeRange == "55-64")">
                                                    <input type="radio" name="AgeRange" value="55-64" @CheckedIf(selectedAgeRange == "55-64") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-calendar"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Age band</span>
                                                        <span class="lq-card-title">55-64</span>
                                                        <span class="lq-card-helper">Coverage gaps can get more expensive here, so fit matters more.</span>
                                                    </span>
                                                </label>
                                                <label class="lq-card lq-card-rich @SelectedClassIf(selectedAgeRange == "65+")">
                                                    <input type="radio" name="AgeRange" value="65+" @CheckedIf(selectedAgeRange == "65+") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-calendar"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Age band</span>
                                                        <span class="lq-card-title">65+</span>
                                                        <span class="lq-card-helper">We can still point you toward the coverage options that make the most sense.</span>
                                                    </span>
                                                </label>
                                            </div>
                                            <div class="lq-choice-error" id="err-AgeRange">Please select your age range.</div>
                                        </div>
                                    </div>

                                    <div class="lq-micro-step" data-micro-step="1" hidden>
                                        <div class="lq-choice-group" role="radiogroup" aria-labelledby="dqHouseholdSizeLabel">
                                            <div class="lq-choice-label" id="dqHouseholdSizeLabel">Who needs this health coverage review?</div>
                                            <div class="lq-choice-grid">
                                                <label class="lq-card lq-card-rich @SelectedClassIf(form.HouseholdSize == "Just me")">
                                                    <input type="radio" name="HouseholdSize" value="Just me" @CheckedIf(form.HouseholdSize == "Just me") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-briefcase"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Household</span>
                                                        <span class="lq-card-title">Just me</span>
                                                        <span class="lq-card-helper">A solo review can focus tightly on your own doctors, prescriptions, and budget.</span>
                                                    </span>
                                                </label>
                                                <label class="lq-card lq-card-rich @SelectedClassIf(form.HouseholdSize == "Me + spouse / partner")">
                                                    <input type="radio" name="HouseholdSize" value="Me + spouse / partner" @CheckedIf(form.HouseholdSize == "Me + spouse / partner") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-briefcase"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Household</span>
                                                        <span class="lq-card-title">Me + spouse / partner</span>
                                                        <span class="lq-card-helper">This review can focus on balancing cost, network fit, and shared care needs.</span>
                                                    </span>
                                                </label>
                                                <label class="lq-card lq-card-rich @SelectedClassIf(form.HouseholdSize == "Me + child / children")">
                                                    <input type="radio" name="HouseholdSize" value="Me + child / children" @CheckedIf(form.HouseholdSize == "Me + child / children") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-briefcase"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Household</span>
                                                        <span class="lq-card-title">Me + child / children</span>
                                                        <span class="lq-card-helper">Family care needs and pediatric access usually become a bigger part of the decision.</span>
                                                    </span>
                                                </label>
                                                <label class="lq-card lq-card-rich @SelectedClassIf(form.HouseholdSize == "Family of 4+")">
                                                    <input type="radio" name="HouseholdSize" value="Family of 4+" @CheckedIf(form.HouseholdSize == "Family of 4+") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-briefcase"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Household</span>
                                                        <span class="lq-card-title">Family of 4+</span>
                                                        <span class="lq-card-helper">A larger household often needs a closer look at premium, deductible, and provider tradeoffs.</span>
                                                    </span>
                                                </label>
                                                <label class="lq-card lq-card-rich @SelectedClassIf(form.HouseholdSize == "Not sure yet")">
                                                    <input type="radio" name="HouseholdSize" value="Not sure yet" @CheckedIf(form.HouseholdSize == "Not sure yet") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-briefcase"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Household</span>
                                                        <span class="lq-card-title">Not sure yet</span>
