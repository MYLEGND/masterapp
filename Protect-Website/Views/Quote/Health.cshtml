                                            <input type="checkbox" id="AcknowledgedDisclaimer" name="AcknowledgedDisclaimer" value="true" @(form.AcknowledgedDisclaimer ? "checked" : null) />
                                            <span class="consent-text">
                                                <span class="consent-main">@consentPromptText <span class="lq-required-star">*</span></span>
                                            </span>
                                        </label>
                                        <input type="hidden" name="AcknowledgedDisclaimer" value="false" />
                                        <input type="hidden" id="ContactMethod" name="ContactMethod" value="@(string.IsNullOrWhiteSpace(form.ContactMethod) ? "Phone" : form.ContactMethod)" />
                                        <input type="hidden" id="BestTimeToContact" name="BestTimeToContact" value="@(string.IsNullOrWhiteSpace(form.BestTimeToContact) ? "Not specified" : form.BestTimeToContact)" />
                                        <div class="lq-field-err" id="err-AcknowledgedDisclaimer">@consentErrorText</div>

                                        <div class="lq-step-actions">
                                            <button type="button" class="btn-ghost" id="dqBackToQuestionsBtn">Back to answers</button>
                                            <div class="btn-block">
                                                <p class="dq-submit-note">Private review. No obligation. You stay in control.</p>
                                                <button type="submit" class="btn-gold btn-progress btn-block" id="dqSubmitBtn" data-cta="health_submit_review">Get My Health Review</button>
                                            </div>
                                        </div>

                                        <div class="lq-error" id="healthError"></div>
                                        <div class="lq-success" id="healthSuccess">Thanks! We received your request.</div>
                                    </div>

                                    <div class="lq-post-submit-slot" id="healthPostSubmitSlot" hidden></div>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    (function () {
        'use strict';

        var track = (window.LegendAnalytics?.track && typeof window.LegendAnalytics.track === 'function')
            ? window.LegendAnalytics.track
            : (window.legendTrack && typeof window.legendTrack === 'function')
                ? window.legendTrack
                : function () {};

        var form = document.getElementById('healthQuoteForm');
        if (!form) return;

        var body = document.body;
        var pageKey = '@pageKey';
        var formKey = form.getAttribute('data-form-key') || '@formKey';
        var heroEntryPanel = document.getElementById('healthHeroEntryPanel');
        var educationPanel = document.getElementById('healthEducationPanel');
        var startButton = document.getElementById('healthHeroStartCta');
        var step1Panel = document.getElementById('dqStep1Panel');
        var processingPanel = document.getElementById('dqProcessingPanel');
        var contactPanel = document.getElementById('dqContactPanel');
        var contactFirstPanel = document.getElementById('healthEducationContactPanel');
        var contactCaptureWrap = document.getElementById('healthContactCaptureWrap');
        var postSubmitSlot = document.getElementById('healthPostSubmitSlot');
        var progressLabel = document.getElementById('dqStep1Progress');
        var progressFill = document.getElementById('dqStep1ProgressFill');
        var processingFill = document.getElementById('dqProcessingFill');
        var continueButton = document.getElementById('dqContinueToContactBtn');
        var backToQuestionsButton = document.getElementById('dqBackToQuestionsBtn');
        var submitButton = document.getElementById('dqSubmitBtn');
        var proofCard = contactFirstPanel ? contactFirstPanel.querySelector('.dq-proof-card') : null;
        var errorBanner = document.getElementById('healthError');
        var successBanner = document.getElementById('healthSuccess');
        var reviewSummary = document.getElementById('healthReviewSummary');
        var ageHidden = document.getElementById('Age');
        var contactMethodInput = document.getElementById('ContactMethod');
        var bestTimeInput = document.getElementById('BestTimeToContact');
        var submitDefaultLabel = submitButton ? asTrimmed(submitButton.textContent) : 'Get My Health Review';
        var bookingExperienceUrl = '@Url.Action("ActivatePublicBookingExperience", "HealthQuote")';
        var bookingConfirmationUrl = '@Url.Action("ConfirmPublicBookingExperience", "HealthQuote")';
        var microSteps = Array.prototype.slice.call(step1Panel ? step1Panel.querySelectorAll('[data-micro-step]') : []);
        var hasServerErrors = '@(hasServerErrors ? "true" : "false")' === 'true';
        var showContactStepByDefault = '@(showContactStepByDefault ? "true" : "false")' === 'true';
        var ageRangeToAge = Object.freeze({
            '18-24': '21',
            '25-34': '30',
            '35-44': '40',
            '45-54': '50',
            '55-64': '60',
            '65+': '70'
        });
        var microStepConfigs = [
            { field: 'AgeRange', errorId: 'err-AgeRange', viewEvent: 'first_question_view' },
            { field: 'HouseholdSize', errorId: 'err-HouseholdSize', viewEvent: 'quote_step_view' },
            { field: 'CurrentCoverage', errorId: 'err-CurrentCoverage', viewEvent: 'quote_step_view' },
            { field: 'CoverageType', errorId: 'err-CoverageType', viewEvent: 'quote_step_view' },
            { field: 'PrimaryConcern', errorId: 'err-PrimaryConcern', viewEvent: 'quote_step_view' }
        ];
        var completedSteps = {};
        var viewedMicroSteps = {};
        var currentMicroStep = 0;
        var autoAdvanceTimer = null;
        var processingTimer = null;
        var contactStepTracked = false;
        var thankYouTracked = false;
        var latestSubmitResponse = null;
        var publicBookingState = null;
        var publicBookingEmbedViewed = false;
        var publicBookingBookedConfirmed = false;
        var publicBookingConfirmationRequested = false;
        var publicBookingSlotSelectedTracked = false;
        var publicBookingFallbackClicked = false;
        var publicBookingLoadingText = 'Preparing your scheduling options...';
        var publicBookingDisabledText = 'Your health coverage review is saved. Scheduling is not available in this view right now, but a licensed agent can still continue the review with you.';

        function asTrimmed(value) {
            return typeof value === 'string' ? value.trim() : '';
        }

        function escapeHtml(value) {
            return String(value == null ? '' : value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function setBannerMessage(element, message) {
            if (!element) return;
            element.textContent = message || '';
            element.style.display = message ? 'block' : 'none';
        }

        function clearServerFeedback() {
            setBannerMessage(errorBanner, '');
            setBannerMessage(successBanner, '');
        }

        function resetPostSubmitShell() {
            latestSubmitResponse = null;
            publicBookingState = null;
            publicBookingEmbedViewed = false;
            publicBookingBookedConfirmed = false;
            publicBookingConfirmationRequested = false;
            publicBookingSlotSelectedTracked = false;
            publicBookingFallbackClicked = false;

            if (contactFirstPanel) {
                contactFirstPanel.classList.remove('qf-final-panel-no-chrome', 'qf-final-review-flat-mode', 'is-submitted', 'is-submit-loading');
            }

            if (contactCaptureWrap) {
                contactCaptureWrap.hidden = false;
            }

            if (postSubmitSlot) {
                postSubmitSlot.hidden = true;
                postSubmitSlot.innerHTML = '';
            }

            if (processingFill) {
                processingFill.style.width = '0%';
            }
        }

        function populateAttributionFields() {
            var ids = window.legendTrackingIds;
            var params = new URLSearchParams(window.location.search);
            var attr = ids && ids.getAttribution ? (ids.getAttribution() || {}) : {};

            function setHidden(name, value) {
                var input = document.getElementById(name) || form.querySelector('input[name="' + name + '"]');
                if (input && value != null) input.value = value;
            }

            setHidden('SessionId', ids && ids.getSessionId ? ids.getSessionId() : '');
            setHidden('VisitorId', ids && ids.getVisitorId ? ids.getVisitorId() : '');
            setHidden('UtmSource', attr.utmSource || params.get('utm_source') || '');
            setHidden('UtmMedium', attr.utmMedium || params.get('utm_medium') || '');
            setHidden('UtmCampaign', attr.utmCampaign || params.get('utm_campaign') || '');
            setHidden('UtmId', attr.utmId || params.get('utm_id') || '');
            setHidden('UtmTerm', attr.utmTerm || params.get('utm_term') || '');
            setHidden('UtmContent', attr.utmContent || params.get('utm_content') || '');
            setHidden('MetaCampaignId', attr.metaCampaignId || params.get('meta_campaign_id') || '');
            setHidden('MetaAdSetId', attr.metaAdSetId || params.get('meta_adset_id') || '');
            setHidden('MetaAdId', attr.metaAdId || params.get('meta_ad_id') || '');
            setHidden('Fbclid', attr.fbclid || params.get('fbclid') || '');
            setHidden('ReferrerUrl', document.referrer || '');
            setHidden('LandingPageUrl', window.location.href || '');
        }

        function trackCta(elementKey, label) {
            track({
                EventType: 'cta_click',
                ElementKey: elementKey,
                ButtonLabel: label,
                PageKey: pageKey
            });
            track({
                EventType: 'quote_cta_click',
                ElementKey: elementKey,
                ButtonLabel: label,
                PageKey: pageKey
            });
        }

        function setStartedState(started) {
            body.classList.toggle('health-quote-started', !!started);
            if (heroEntryPanel) heroEntryPanel.hidden = !!started;
            if (educationPanel) educationPanel.hidden = !started;
        }

        function setFinalStepState(active) {
            body.classList.toggle('health-final-step-active', !!active);
        }

        function updateProgress(stepIndex) {
            var stepNumber = Math.max(0, Math.min(microSteps.length - 1, stepIndex)) + 1;
            if (progressLabel) progressLabel.textContent = 'Question ' + stepNumber + ' of ' + microSteps.length;
            if (progressFill) progressFill.style.width = ((stepNumber / microSteps.length) * 100) + '%';
        }

        function syncChoiceCards(groupName) {
            Array.prototype.forEach.call(document.querySelectorAll('input[name="' + groupName + '"]'), function (radio) {
                var card = radio.closest('.lq-card');
                if (!card) return;
                card.classList.toggle('lq-selected', !!radio.checked);
                if (radio.checked) card.classList.remove('lq-invalid');
            });
        }

        function clearGroupError(groupName, errorId) {
            Array.prototype.forEach.call(document.querySelectorAll('input[name="' + groupName + '"]'), function (radio) {
                var card = radio.closest('.lq-card');
                if (card) card.classList.remove('lq-invalid');
            });
            var error = document.getElementById(errorId);
            if (error) error.classList.remove('visible');
        }

        function showGroupError(groupName, errorId) {
            Array.prototype.forEach.call(document.querySelectorAll('input[name="' + groupName + '"]'), function (radio) {
                var card = radio.closest('.lq-card');
                if (card) card.classList.add('lq-invalid');
            });
            var error = document.getElementById(errorId);
            if (error) error.classList.add('visible');
        }

        function requireSelection(groupName, errorId) {
            var checked = form.querySelector('input[name="' + groupName + '"]:checked');
            if (!checked) {
                showGroupError(groupName, errorId);
                return false;
            }
            clearGroupError(groupName, errorId);
            return true;
        }

        function syncAgeHidden() {
            var selectedAgeRange = form.querySelector('input[name="AgeRange"]:checked');
            if (!ageHidden) return;
            ageHidden.value = selectedAgeRange ? (ageRangeToAge[selectedAgeRange.value] || ageHidden.value || '30') : (ageHidden.value || '30');
        }

        function syncDerivedContactFields() {
            var phoneValue = asTrimmed(document.getElementById('Phone') ? document.getElementById('Phone').value : '');
            var emailValue = asTrimmed(document.getElementById('Email') ? document.getElementById('Email').value : '');

            if (contactMethodInput) {
                contactMethodInput.value = phoneValue ? 'Phone' : (emailValue ? 'Email' : 'Phone');
            }

            if (bestTimeInput && !asTrimmed(bestTimeInput.value)) {
                bestTimeInput.value = 'Not specified';
            }
        }

        function readSelectedValue(name) {
            var input = form.querySelector('input[name="' + name + '"]:checked');
            return input ? asTrimmed(input.value) : '';
        }

        function focusCurrentMicroStep() {
            var currentStepEl = microSteps[currentMicroStep];
            if (!currentStepEl) return;
            var focusTarget = currentStepEl.querySelector('input, button');
            if (focusTarget && typeof focusTarget.focus === 'function') {
                window.setTimeout(function () {
                    focusTarget.focus({ preventScroll: true });
                }, 110);
            }
            currentStepEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function trackMicroStepView(index) {
            if (viewedMicroSteps[index]) return;
            viewedMicroSteps[index] = true;
            var config = microStepConfigs[index];
            if (!config) return;
            track({
                EventType: config.viewEvent,
                PageKey: pageKey,
                FormKey: formKey,
                MetadataJson: JSON.stringify({ stepNumber: index + 1, field: config.field })
            });
        }

        function trackStepComplete(stepNumber, nextStep, source) {
            if (completedSteps[stepNumber]) return;
            completedSteps[stepNumber] = true;
            var metadataJson = JSON.stringify({ stepNumber: stepNumber, nextStep: nextStep, source: source });
            if (stepNumber === 1) {
                track({
                    EventType: 'first_question_answered',
                    FormKey: formKey,
                    PageKey: pageKey,
                    MetadataJson: metadataJson
                });
            }
            track({
                EventType: 'quote_step_complete',
                FormKey: formKey,
                PageKey: pageKey,
                MetadataJson: metadataJson
            });
        }

        function showMicroStep(index) {
            if (index < 0 || index >= microSteps.length) return;
            resetPostSubmitShell();
            currentMicroStep = index;
            if (step1Panel) step1Panel.hidden = false;
            if (processingPanel) processingPanel.hidden = true;
            if (contactPanel) contactPanel.hidden = true;
            setStartedState(true);
            setFinalStepState(false);
            microSteps.forEach(function (step, idx) {
                step.hidden = idx !== index;
            });
            updateProgress(index);
            trackMicroStepView(index);
            focusCurrentMicroStep();
        }

        function buildReviewSummaryHtml() {
            var ageRange = readSelectedValue('AgeRange') || 'Age range';
            var householdSize = readSelectedValue('HouseholdSize') || 'Household';
            var currentCoverage = readSelectedValue('CurrentCoverage') || 'Current coverage';
            var coverageType = readSelectedValue('CoverageType') || 'Coverage goal';
            var primaryConcern = readSelectedValue('PrimaryConcern') || 'Priority';

            var signal = 'Your review will focus on plan fit first, then narrow the tradeoffs between monthly cost, deductible exposure, and care access.';
            if (currentCoverage === 'No current coverage') {
                signal = 'No current coverage means the review should start with affordable options and how quickly you want coverage in place.';
            } else if (currentCoverage === 'Employer plan') {
                signal = 'Employer coverage can still leave gaps in deductibles, network fit, or family needs, so the conversation should start there.';
            } else if (primaryConcern === 'Lower Monthly Premium') {
                signal = 'Because monthly affordability matters most, the conversation should stay centered on balancing premium, deductible, and day-to-day budget pressure.';
            } else if (primaryConcern === 'Better Doctor Network') {
                signal = 'Because provider access matters most, the review should stay focused on keeping the doctors, facilities, and specialists you trust in network.';
            }

            return ''
                + '<div class="dq-review-kicker">Review snapshot</div>'
                + '<div class="dq-review-title">We will pick up the conversation from these answers.</div>'
                + '<div class="dq-review-copy">Your answers shape the conversation so it starts with the coverage tradeoffs and care priorities that matter most.</div>'
                + '<div class="dq-review-stats">'
                +   '<div class="dq-review-stat"><div class="dq-review-stat-label">Age range</div><div class="dq-review-stat-value">' + escapeHtml(ageRange) + '</div></div>'
                +   '<div class="dq-review-stat"><div class="dq-review-stat-label">Household</div><div class="dq-review-stat-value">' + escapeHtml(householdSize) + '</div></div>'
                +   '<div class="dq-review-stat"><div class="dq-review-stat-label">Coverage goal</div><div class="dq-review-stat-value">' + escapeHtml(coverageType) + '</div></div>'
                + '</div>'
                + '<div class="dq-review-signal"><strong>Next step:</strong> ' + escapeHtml(signal) + ' Coverage status noted: ' + escapeHtml(currentCoverage) + '.</div>';
        }

        function renderReviewSummary() {
            if (!reviewSummary) return;
            reviewSummary.innerHTML = buildReviewSummaryHtml();
        }

        function trackBookingEvent(eventType, metadata) {
            track({
                EventType: eventType,
                PageKey: pageKey,
                FormKey: formKey,
                MetadataJson: JSON.stringify(metadata || {})
            });
        }

        function resolveRequestedBookingSurface(payload) {
            return Boolean(payload && (payload.canEmbed || payload.eligible))
                ? 'website_embed'
                : 'external_redirect_fallback';
        }

        function buildDisabledBookingState(reason) {
            return {
                enabled: false,
                canEmbed: false,
                canFallback: false,
                preferModalOnMobile: false,
                embedUrl: '',
                fallbackUrl: '',
                surface: 'external_redirect_fallback',
                linkedToLead: false,
                appointmentStatus: '',
                pendingConfirmation: false,
                reason: asTrimmed(reason) || 'disabled',
                contextToken: ''
            };
        }

        function normalizePublicBookingPayload(payload, hint) {
            var source = payload && typeof payload === 'object' ? payload : {};
            var sourceHint = hint && typeof hint === 'object' ? hint : {};
            var canEmbed = Boolean(source.canEmbed != null ? source.canEmbed : sourceHint.canEmbed);
            var canFallback = Boolean(source.canFallback != null ? source.canFallback : sourceHint.canFallback);
            var enabled = Boolean(source.enabled != null ? source.enabled : sourceHint.eligible) && (canEmbed || canFallback);

            return {
                enabled: enabled,
                canEmbed: canEmbed,
                canFallback: canFallback,
                preferModalOnMobile: Boolean(source.preferModalOnMobile != null ? source.preferModalOnMobile : sourceHint.preferModalOnMobile),
                embedUrl: asTrimmed(source.embedUrl || sourceHint.embedUrl || ''),
                fallbackUrl: asTrimmed(source.fallbackUrl || sourceHint.fallbackUrl || ''),
                surface: asTrimmed(source.surface || resolveRequestedBookingSurface(sourceHint)),
                linkedToLead: Boolean(source.linkedToLead),
                appointmentStatus: asTrimmed(source.appointmentStatus || ''),
                requestedBookingSource: asTrimmed(source.requestedBookingSource || ''),
                confirmationSource: asTrimmed(source.confirmationSource || ''),
                confirmationVerified: Boolean(source.confirmationVerified),
                pendingConfirmation: Boolean(source.pendingConfirmation),
                reason: asTrimmed(source.reason || (enabled ? 'configured' : 'disabled')) || 'disabled',
                contextToken: asTrimmed(source.contextToken || sourceHint.contextToken || ''),
                bookingConfigSource: asTrimmed(source.bookingConfigSource || sourceHint.bookingConfigSource || ''),
                bookingConfigAgentSlug: asTrimmed(source.bookingConfigAgentSlug || sourceHint.bookingConfigAgentSlug || ''),
                bookingTrackingProfileId: asTrimmed(source.bookingTrackingProfileId || sourceHint.bookingTrackingProfileId || ''),
                calendarEventId: asTrimmed(source.calendarEventId || ''),
                calendarEventWebLink: asTrimmed(source.calendarEventWebLink || ''),
                scheduledStartUtc: asTrimmed(source.scheduledStartUtc || ''),
                scheduledEndUtc: asTrimmed(source.scheduledEndUtc || '')
            };
        }

        function buildAppointmentTrackingMetadata(payload, extra) {
            var normalized = normalizePublicBookingPayload(payload, publicBookingState);
            return Object.assign({
                bookingSurface: normalized.surface || resolveRequestedBookingSurface(normalized),
                bookingMode: normalized.canEmbed ? 'inline' : 'fallback',
                hasFallback: normalized.canFallback,
                appointmentStatus: normalized.appointmentStatus || '',
                requestedBookingSource: normalized.requestedBookingSource || '',
                confirmationSource: normalized.confirmationSource || '',
                confirmationVerified: normalized.confirmationVerified,
                linkedToLead: normalized.linkedToLead,
                pendingConfirmation: normalized.pendingConfirmation,
                bookingReason: normalized.reason || '',
                bookingConfigSource: normalized.bookingConfigSource || '',
                bookingConfigAgentSlug: normalized.bookingConfigAgentSlug || '',
                bookingTrackingProfileId: normalized.bookingTrackingProfileId || ''
            }, extra || {});
        }

        function renderBookingIframe(frameSlot, statusEl, url) {
            if (!frameSlot || !statusEl || !url) {
                return;
            }

            var normalizedUrl = asTrimmed(url);
            var existingIframe = frameSlot.querySelector('iframe.lq-booking-iframe');

            if (existingIframe instanceof HTMLIFrameElement && existingIframe.dataset.bookingSrc === normalizedUrl) {
                statusEl.hidden = true;
                return;
            }

            frameSlot.innerHTML = '';
            statusEl.hidden = false;
            statusEl.textContent = publicBookingLoadingText;

            var iframe = document.createElement('iframe');
            iframe.className = 'lq-booking-iframe';
            iframe.src = normalizedUrl;
            iframe.dataset.bookingSrc = normalizedUrl;
            iframe.loading = 'lazy';
            iframe.referrerPolicy = 'strict-origin-when-cross-origin';
            iframe.title = 'Continue your health coverage review';

            var frameLoaded = false;
            var loadTimeout = window.setTimeout(function () {
                if (frameLoaded) {
                    return;
                }

                statusEl.hidden = false;
                statusEl.textContent = 'Scheduling is taking longer than expected. Please give the secure booking window another moment.';
            }, 8000);

            iframe.addEventListener('load', function () {
                frameLoaded = true;
                window.clearTimeout(loadTimeout);
                statusEl.hidden = true;
            }, { once: true });

            frameSlot.appendChild(iframe);
        }

        function markAppointmentEmbedViewed(payload) {
            if (publicBookingEmbedViewed) {
                return;
            }

            publicBookingEmbedViewed = true;
            trackBookingEvent('appointment_embed_viewed', buildAppointmentTrackingMetadata(payload));
        }

        async function activatePublicBookingExperience(hint) {
            if (!hint || typeof hint !== 'object' || !asTrimmed(hint.contextToken)) {
                return buildDisabledBookingState('missing_context');
            }

            var requestSurface = resolveRequestedBookingSurface(hint);

            try {
                var response = await fetch(bookingExperienceUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'fetch'
                    },
                    body: JSON.stringify({
                        contextToken: hint.contextToken,
                        surface: requestSurface
                    })
                });

                if (!response.ok) {
                    throw new Error('booking_activation_failed');
                }

                var payload = await response.json().catch(function () { return {}; });
                return normalizePublicBookingPayload(payload, hint);
            } catch (error) {
                console.warn('[HealthQuote] public booking activation failed', error);
                return normalizePublicBookingPayload({
                    enabled: Boolean(hint.eligible),
                    canEmbed: Boolean(hint.canEmbed),
                    canFallback: Boolean(hint.canFallback),
                    preferModalOnMobile: Boolean(hint.preferModalOnMobile),
                    embedUrl: hint.embedUrl || '',
                    fallbackUrl: hint.fallbackUrl || '',
                    surface: requestSurface,
                    reason: 'activation_failed',
                    contextToken: hint.contextToken || ''
                }, hint);
            }
        }

        async function confirmPublicBookingExperience(payload) {
            var normalized = normalizePublicBookingPayload(payload, publicBookingState);
            if (!normalized.contextToken) {
                return normalized;
            }

            try {
                var response = await fetch(bookingConfirmationUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'fetch'
                    },
                    body: JSON.stringify({
                        contextToken: normalized.contextToken,
                        surface: normalized.surface || resolveRequestedBookingSurface(normalized)
                    })
                });

                if (!response.ok) {
                    throw new Error('booking_confirmation_failed');
                }

                var confirmationPayload = await response.json().catch(function () { return {}; });
                return normalizePublicBookingPayload(Object.assign({}, normalized, confirmationPayload), normalized);
            } catch (error) {
                console.warn('[HealthQuote] public booking confirmation failed', error);
                return normalized;
            }
        }

        function renderPostSubmitBookingState(payload) {
            if (!postSubmitSlot) return;

            var normalized = payload && payload.loading
                ? { loading: true }
                : normalizePublicBookingPayload(payload, publicBookingState);

            if (!normalized.loading) {
                publicBookingState = normalized;
                if (normalized.confirmationVerified) {
                    publicBookingBookedConfirmed = true;
                }
            }

            var responseBody = latestSubmitResponse || {};
            var agentName = asTrimmed(responseBody.agentFirstName) || 'our licensed team';
            var proofHtml = proofCard ? '<div class="lq-final-review-agent-row">' + proofCard.outerHTML + '</div>' : '';
            var ageRange = readSelectedValue('AgeRange') || 'Age range';
            var householdSize = readSelectedValue('HouseholdSize') || 'Household';
            var currentCoverage = readSelectedValue('CurrentCoverage') || 'Current coverage';
            var coverageType = readSelectedValue('CoverageType') || 'Coverage goal';
            var primaryConcern = readSelectedValue('PrimaryConcern') || 'Priority';
            var resultHtml = ''
                + '<div class="dq-final-review-stats" aria-label="Saved review snapshot">'
                +   '<div class="dq-final-review-stat"><div class="dq-final-review-stat-label">Age range</div><div class="dq-final-review-stat-value">' + escapeHtml(ageRange) + '</div></div>'
                +   '<div class="dq-final-review-stat"><div class="dq-final-review-stat-label">Household</div><div class="dq-final-review-stat-value">' + escapeHtml(householdSize) + '</div></div>'
                +   '<div class="dq-final-review-stat"><div class="dq-final-review-stat-label">Current coverage</div><div class="dq-final-review-stat-value">' + escapeHtml(currentCoverage) + '</div></div>'
                +   '<div class="dq-final-review-stat"><div class="dq-final-review-stat-label">Review focus</div><div class="dq-final-review-stat-value">' + escapeHtml(coverageType) + '</div></div>'
                + '</div>';
            var showInlineShell = !normalized.loading && normalized.enabled && normalized.canEmbed && normalized.embedUrl;
            var showFallbackLink = false;
            var bookingUnavailableCopy = !normalized.loading && !showInlineShell && !showFallbackLink
                ? (normalized.enabled
                    ? 'Your review is saved. Scheduling is not available in this view right now, but a licensed agent can still continue the conversation with you.'
                    : publicBookingDisabledText)
                : '';

            postSubmitSlot.innerHTML = ''
                + '<section class="lq-final-review-unified-card" aria-labelledby="healthPostSubmitTitle">'
                + proofHtml
                +   '<div class="lq-final-review-head">'
                +     '<div class="lq-final-review-kicker">Review saved</div>'
                +     '<div class="lq-final-review-title" id="healthPostSubmitTitle">Your health review is ready for the next step.</div>'
                +     '<div class="lq-final-review-copy">We saved your answers so the conversation can start with your household needs, current coverage, and the plan tradeoffs that matter most.</div>'
                +   '</div>'
                +   '<div class="lq-final-review-proof-row" aria-label="Review value">'
                +     '<span>Review saved</span>'
                +     '<span>Licensed guidance</span>'
                +     '<span>No obligation</span>'
                +   '</div>'
                +   '<div class="lq-final-review-impact-grid" aria-label="Why this review matters">'
                +     '<div class="lq-final-review-impact-card">'
                +       '<div class="lq-final-review-impact-label">What surfaced</div>'
                +       '<div class="lq-final-review-impact-text">Your answers suggest this review should focus on ' + escapeHtml(primaryConcern.toLowerCase()) + ', current coverage fit, and what your household actually needs from the next plan conversation.</div>'
                +     '</div>'
                +     '<div class="lq-final-review-impact-card is-urgent">'
                +       '<div class="lq-final-review-impact-label">Why timing matters</div>'
                +       '<div class="lq-final-review-impact-text">Monthly cost, deductibles, network fit, and care access usually feel more urgent once appointments or prescriptions are already in motion.</div>'
                +     '</div>'
                +   '</div>'
                +   '<div class="lq-final-review-result-slot">'
                +     resultHtml
                +   '</div>'
                +   '<div class="lq-final-review-next-step" aria-label="What happens during the review">'
                +     '<div class="lq-final-review-next-kicker">What the review confirms</div>'
                +     '<div class="lq-final-review-next-title">' + escapeHtml(agentName) + ' helps turn this review into a clear coverage decision.</div>'
                +     '<div class="lq-final-review-next-copy">The review can now confirm affordability, deductible comfort, provider access, and whether your current path still makes sense before any recommendation moves forward.</div>'
                +     '<div class="lq-final-review-checklist" aria-label="Review checklist">'
                +       '<span>Premium fit</span>'
                +       '<span>Doctor access</span>'
                +       '<span>Plan direction</span>'
                +     '</div>'
                +   '</div>'
                +   '<div class="lq-final-review-booking-card">'
                +     '<div class="lq-final-review-booking-kicker">Finish the review</div>'
                +     '<div class="lq-final-review-booking-title">Choose a time to keep the review moving.</div>'
                +     '<div class="lq-final-review-booking-copy">Schedule while this is fresh so ' + escapeHtml(agentName) + ' can confirm affordability, provider access, deductible comfort, and what path fits best.</div>'
                +   '</div>'
                +   (normalized.loading
                    ? '<div class="lq-final-review-loading">' + escapeHtml(publicBookingLoadingText) + '</div>'
                    : '')
                +   (showInlineShell
                    ? '<div class="lq-booking-frame-only" id="healthBookingInlineFrameSlot"></div>'
                    + '<div class="lq-booking-embed-status" id="healthBookingInlineStatus" hidden>' + escapeHtml(publicBookingLoadingText) + '</div>'
                    : '')
                +   (bookingUnavailableCopy
                    ? '<div class="lq-final-review-unavailable">' + escapeHtml(bookingUnavailableCopy) + '</div>'
                    : '')
                + '</section>';

            postSubmitSlot.hidden = false;

            var inlineFrameSlot = document.getElementById('healthBookingInlineFrameSlot');
            var inlineStatus = document.getElementById('healthBookingInlineStatus');
            if (showInlineShell) {
                renderBookingIframe(inlineFrameSlot, inlineStatus, normalizePublicBookingPayload(publicBookingState, payload).embedUrl);
                markAppointmentEmbedViewed(normalizePublicBookingPayload(publicBookingState, payload));
            }

        }

        function showContactStep(trackView) {
            resetPostSubmitShell();
            if (step1Panel) step1Panel.hidden = true;
            if (processingPanel) processingPanel.hidden = true;
            if (contactPanel) contactPanel.hidden = false;
            setStartedState(true);
            setFinalStepState(true);
            renderReviewSummary();

            if (trackView !== false && !contactStepTracked) {
                contactStepTracked = true;
                track({ EventType: 'contact_step_view', PageKey: pageKey, FormKey: formKey });
                track({
                    EventType: 'quote_contact_step_view',
                    FormKey: formKey,
                    PageKey: pageKey,
                    MetadataJson: JSON.stringify({ stepNumber: microSteps.length + 1, source: 'contact_step_view' })
                });
            }

            var focusTarget = document.getElementById('FirstName');
            if (focusTarget && typeof focusTarget.focus === 'function') {
                window.setTimeout(function () {
                    focusTarget.focus({ preventScroll: true });
                }, 120);
            }

            if (contactPanel) {
                contactPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        function showProcessingThenContact() {
            resetPostSubmitShell();
            if (step1Panel) step1Panel.hidden = true;
            if (contactPanel) contactPanel.hidden = true;
            if (processingPanel) processingPanel.hidden = false;
            setStartedState(true);
            setFinalStepState(false);
            if (processingFill) processingFill.style.width = '100%';
            track({
                EventType: 'form_start',
                PageKey: pageKey,
                FormKey: formKey
            });

            window.clearTimeout(processingTimer);
            processingTimer = window.setTimeout(function () {
                showContactStep(true);
            }, 900);
        }

        function startFunnel(trackStartClick) {
            setStartedState(true);
            if (trackStartClick) {
                var label = startButton ? asTrimmed(startButton.textContent) : 'Check My Coverage Fit';
                trackCta('health_funnel_start', label);
                track({
                    EventType: 'form_start',
                    PageKey: pageKey,
                    FormKey: formKey
                });
            }
            showMicroStep(0);
        }

        function showFieldError(fieldId, isVisible) {
            var field = document.getElementById(fieldId);
            var error = document.getElementById('err-' + fieldId);
            if (field) field.classList.toggle('is-invalid', !!isVisible);
            if (error) {
                if (!error.dataset.defaultText) error.dataset.defaultText = error.textContent || '';
                if (!isVisible && error.dataset.defaultText) error.textContent = error.dataset.defaultText;
                error.classList.toggle('visible', !!isVisible);
            }
        }

        function showDisclaimerError(message) {
            var error = document.getElementById('err-AcknowledgedDisclaimer');
            if (!error) return;
            if (!error.dataset.defaultText) error.dataset.defaultText = error.textContent || '';
            error.textContent = message || error.dataset.defaultText;
            error.classList.add('visible');
        }

        function applyServerValidationErrors(fieldErrors) {
            if (!fieldErrors || typeof fieldErrors !== 'object') return false;

            var applied = false;

            Object.keys(fieldErrors).forEach(function (name) {
                var messages = fieldErrors[name];
                var firstMessage = Array.isArray(messages) ? asTrimmed(messages[0]) : '';
                if (!firstMessage) return;

                switch (name) {
                    case 'AgeRange':
                        showGroupError('AgeRange', 'err-AgeRange');
                        applied = true;
                        return;
                    case 'HouseholdSize':
                        showGroupError('HouseholdSize', 'err-HouseholdSize');
                        applied = true;
                        return;
                    case 'CurrentCoverage':
                        showGroupError('CurrentCoverage', 'err-CurrentCoverage');
                        applied = true;
                        return;
                    case 'CoverageType':
                        showGroupError('CoverageType', 'err-CoverageType');
                        applied = true;
                        return;
                    case 'PrimaryConcern':
                        showGroupError('PrimaryConcern', 'err-PrimaryConcern');
                        applied = true;
                        return;
                    case 'AcknowledgedDisclaimer':
                        showDisclaimerError(firstMessage);
                        applied = true;
                        return;
                    default:
                        showFieldError(name, true);
                        var error = document.getElementById('err-' + name);
                        if (error) {
                            if (!error.dataset.defaultText) error.dataset.defaultText = error.textContent || '';
                            error.textContent = firstMessage;
                        }
                        applied = true;
                        return;
                }
            });

            return applied;
        }

        function trackThankYouViewOnce() {
            if (thankYouTracked) return;
            thankYouTracked = true;
            track({ EventType: 'thank_you_view', PageKey: pageKey, FormKey: formKey });
        }

        function resolveBookingMessageSignal(event) {
            if (!event || typeof event !== 'object' || !event.origin) {
                return '';
            }

            var hostname = '';
            try {
                hostname = new URL(event.origin).hostname.toLowerCase();
            } catch (error) {
                return '';
            }

            if (!hostname.endsWith('office.com') &&
                !hostname.endsWith('outlook.com') &&
                !hostname.endsWith('microsoft.com')) {
                return '';
            }

            var data = event.data;
            var signalType = typeof data === 'string'
                ? data.trim().toLowerCase()
                : typeof (data && data.type) === 'string'
                    ? data.type.trim().toLowerCase()
                    : '';

            if (signalType === 'appointment_slot_selected' || signalType === 'ms_bookings_slot_selected') {
                return 'slot_selected';
            }

            if (signalType === 'appointment_booked' || signalType === 'ms_bookings_booked' || signalType === 'ms_bookings_confirmed') {
                return 'booked';
            }

            if (typeof data === 'object' && data && data.bookingConfirmed === true) {
                return 'booked';
            }

            return '';
        }

        window.addEventListener('message', function (event) {
            var signal = resolveBookingMessageSignal(event);
            if (!signal) {
                return;
            }

            if (signal === 'slot_selected' && !publicBookingSlotSelectedTracked) {
                publicBookingSlotSelectedTracked = true;
                trackBookingEvent('appointment_slot_selected', buildAppointmentTrackingMetadata(publicBookingState));
                return;
            }

            if (signal === 'booked' && !publicBookingBookedConfirmed) {
                if (publicBookingConfirmationRequested) {
                    return;
                }

                publicBookingConfirmationRequested = true;
                void confirmPublicBookingExperience(publicBookingState).then(function (confirmedState) {
                    publicBookingConfirmationRequested = false;
                    publicBookingState = normalizePublicBookingPayload(confirmedState, publicBookingState);
                    renderPostSubmitBookingState(publicBookingState);

                    if (publicBookingState.confirmationVerified && !publicBookingBookedConfirmed) {
                        publicBookingBookedConfirmed = true;
                        trackBookingEvent('appointment_booked', buildAppointmentTrackingMetadata(publicBookingState));
                    }
                }).catch(function (error) {
                    publicBookingConfirmationRequested = false;
                    console.warn('[HealthQuote] trusted booking confirmation failed', error);
                });
            }
        });

        async function showPostSubmitSuccess(responseBody) {
            latestSubmitResponse = responseBody || {};
            publicBookingState = null;
            publicBookingEmbedViewed = false;
            publicBookingBookedConfirmed = false;
            publicBookingConfirmationRequested = false;
            publicBookingSlotSelectedTracked = false;
            publicBookingFallbackClicked = false;

            if (contactCaptureWrap) {
                contactCaptureWrap.hidden = true;
            }

            if (processingPanel) {
                processingPanel.hidden = true;
            }

            if (contactPanel) {
                contactPanel.hidden = false;
            }

            if (contactFirstPanel) {
                contactFirstPanel.classList.add('qf-final-panel-no-chrome', 'qf-final-review-flat-mode', 'is-submitted');
                contactFirstPanel.classList.remove('is-submit-loading');
            }

            clearServerFeedback();
            track({
                EventType: 'form_submit_attempt',
                SubmitOutcome: 'success',
                PageKey: pageKey,
                FormKey: formKey,
                MetadataJson: JSON.stringify({
                    leadId: asTrimmed(responseBody && responseBody.leadId)
                })
            });
            track({
                EventType: 'lead_form_submit_success',
                PageKey: pageKey,
                FormKey: formKey,
                MetadataJson: JSON.stringify({ leadId: asTrimmed(responseBody && responseBody.leadId) })
            });
            trackThankYouViewOnce();

            renderPostSubmitBookingState({ loading: true });

            var bookingHint = responseBody && typeof responseBody.booking === 'object'
                ? responseBody.booking
                : null;

            if (!bookingHint || !bookingHint.eligible) {
                renderPostSubmitBookingState(buildDisabledBookingState(asTrimmed(bookingHint && bookingHint.reason) || 'disabled'));
            } else {
                var bookingPayload = await activatePublicBookingExperience(bookingHint);
                renderPostSubmitBookingState(bookingPayload);
            }

            if (postSubmitSlot) {
                postSubmitSlot.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        function enterSubmitLoading() {
            clearServerFeedback();
            if (contactFirstPanel) contactFirstPanel.classList.add('is-submit-loading');
            if (processingPanel) processingPanel.hidden = false;
            if (processingFill) {
                processingFill.style.width = '18%';
                requestAnimationFrame(function () {
                    processingFill.style.width = '76%';
                });
            }
        }

        function exitSubmitLoadingToContact() {
            if (contactFirstPanel) contactFirstPanel.classList.remove('is-submit-loading');
            if (processingPanel) processingPanel.hidden = true;
            if (contactPanel) contactPanel.hidden = false;
            if (contactCaptureWrap) contactCaptureWrap.hidden = false;
            if (processingFill) processingFill.style.width = '0%';
        }

        function validateEmail(value) {
            return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(asTrimmed(value));
        }

        function validatePhone(value) {
            return String(value || '').replace(/\D/g, '').length >= 10;
        }

        function wireChoiceGroup(config, stepIndex) {
            function handleSelection() {
                syncChoiceCards(config.field);
                clearGroupError(config.field, config.errorId);
                if (config.field === 'AgeRange') syncAgeHidden();
                if (stepIndex < microSteps.length - 1 && currentMicroStep === stepIndex) {
                    trackStepComplete(stepIndex + 1, stepIndex + 2, 'auto_advance');
                    window.clearTimeout(autoAdvanceTimer);
                    autoAdvanceTimer = window.setTimeout(function () {
                        showMicroStep(stepIndex + 1);
                    }, 180);
                }
            }

            Array.prototype.forEach.call(form.querySelectorAll('input[name="' + config.field + '"]'), function (radio) {
                radio.addEventListener('change', handleSelection);
                var card = radio.closest('label');
                if (card) {
                    card.addEventListener('click', function () {
                        window.setTimeout(function () {
                            if (!radio.checked) return;
                            handleSelection();
                        }, 0);
                    });
                }
            });
        }

        microStepConfigs.forEach(function (config, index) {
            wireChoiceGroup(config, index);
        });

        Array.prototype.forEach.call(document.querySelectorAll('[data-step-back]'), function (button) {
            button.addEventListener('click', function () {
                var target = parseInt(button.getAttribute('data-step-back'), 10);
                if (!Number.isNaN(target)) showMicroStep(target);
            });
        });

        if (continueButton) {
            continueButton.addEventListener('click', function () {
                var config = microStepConfigs[microSteps.length - 1];
                if (!requireSelection(config.field, config.errorId)) return;
                trackStepComplete(microSteps.length, microSteps.length + 1, 'continue_to_contact');
                trackCta('health_see_review', asTrimmed(continueButton.textContent));
                showProcessingThenContact();
            });
        }

        if (backToQuestionsButton) {
            backToQuestionsButton.addEventListener('click', function () {
                showMicroStep(microSteps.length - 1);
            });
        }

        if (startButton) {
            startButton.addEventListener('click', function () {
                startFunnel(true);
            });
        }

        ['FirstName', 'LastName'].forEach(function (fieldId) {
            var input = document.getElementById(fieldId);
            if (!input) return;
            input.addEventListener('input', function () {
                if (asTrimmed(input.value)) showFieldError(fieldId, false);
            });
        });

        var emailInput = document.getElementById('Email');
        if (emailInput) {
            emailInput.addEventListener('input', function () {
                syncDerivedContactFields();
                if (!asTrimmed(emailInput.value) || validateEmail(emailInput.value)) showFieldError('Email', false);
            });
        }

        var phoneInput = document.getElementById('Phone');
        if (phoneInput) {
            phoneInput.addEventListener('input', function () {
                var digits = String(phoneInput.value || '').replace(/\D/g, '').slice(0, 10);
                if (!digits) return;
                if (digits.length < 4) phoneInput.value = '(' + digits;
                else if (digits.length < 7) phoneInput.value = '(' + digits.slice(0, 3) + ') ' + digits.slice(3);
                else phoneInput.value = '(' + digits.slice(0, 3) + ') ' + digits.slice(3, 6) + '-' + digits.slice(6);
                syncDerivedContactFields();
                if (validatePhone(phoneInput.value)) showFieldError('Phone', false);
            });
        }

        var disclaimerCheckbox = document.getElementById('AcknowledgedDisclaimer');
        if (disclaimerCheckbox) {
            disclaimerCheckbox.addEventListener('change', function () {
                var error = document.getElementById('err-AcknowledgedDisclaimer');
                if (error) error.classList.toggle('visible', !disclaimerCheckbox.checked);
            });
        }

        form.addEventListener('submit', async function (event) {
            event.preventDefault();
            populateAttributionFields();
            syncAgeHidden();
            syncDerivedContactFields();
            clearServerFeedback();

            for (var i = 0; i < microStepConfigs.length; i += 1) {
                if (!requireSelection(microStepConfigs[i].field, microStepConfigs[i].errorId)) {
                    showMicroStep(i);
                    return false;
                }
            }

            var valid = true;
            var firstName = document.getElementById('FirstName');
            var lastName = document.getElementById('LastName');

            var textFields = [
                { id: 'FirstName', value: firstName ? firstName.value : '' }
            ];

            textFields.forEach(function (entry) {
                var isInvalid = !asTrimmed(entry.value);
                showFieldError(entry.id, isInvalid);
                if (isInvalid) valid = false;
            });

            var isEmailInvalid = !!(emailInput && asTrimmed(emailInput.value) && !validateEmail(emailInput.value));
            showFieldError('Email', isEmailInvalid);
            if (isEmailInvalid) valid = false;

            var isPhoneInvalid = !phoneInput || !validatePhone(phoneInput.value);
            showFieldError('Phone', isPhoneInvalid);
            if (isPhoneInvalid) valid = false;

            var disclaimerError = document.getElementById('err-AcknowledgedDisclaimer');
            var isDisclaimerInvalid = !disclaimerCheckbox || !disclaimerCheckbox.checked;
            if (disclaimerError) disclaimerError.classList.toggle('visible', isDisclaimerInvalid);
            if (isDisclaimerInvalid) valid = false;

            if (!valid) {
                showContactStep(false);
                return false;
            }

            trackCta('health_submit_review', submitButton ? asTrimmed(submitButton.textContent) : 'Get My Health Review');
            track({
                EventType: 'form_submit_attempt',
                SubmitOutcome: 'attempt',
                PageKey: pageKey,
                FormKey: formKey
            });

            enterSubmitLoading();

            if (submitButton) {
                submitButton.disabled = true;
                submitButton.textContent = 'Sending...';
            }

            try {
                var response = await fetch(form.action, {
                    method: 'POST',
                    body: new FormData(form),
                    headers: { 'X-Requested-With': 'fetch' }
                });

                var responseBody = await response.json().catch(function () { return {}; });
                if (!response.ok) {
                    var submitError = new Error(
                        typeof responseBody.error === 'string' && responseBody.error.trim()
                            ? responseBody.error.trim()
                            : 'We could not send this right now. Please try again.');
                    submitError.responseBody = responseBody;
                    throw submitError;
                }

                if (processingFill) processingFill.style.width = '100%';
                await showPostSubmitSuccess(responseBody);
            } catch (error) {
                exitSubmitLoadingToContact();
                var responseBody = error && typeof error === 'object' && 'responseBody' in error && error.responseBody && typeof error.responseBody === 'object'
                    ? error.responseBody
                    : null;
                var errorMessage = responseBody && typeof responseBody.error === 'string' && responseBody.error.trim()
                    ? responseBody.error.trim()
                    : 'We could not send this right now. Please try again.';

                applyServerValidationErrors(responseBody && responseBody.fieldErrors);
                setBannerMessage(errorBanner, errorMessage);

                if (responseBody && responseBody.correlationId) {
                    console.warn('[HealthQuote] submit failed correlationId=' + responseBody.correlationId, responseBody.fieldErrors || responseBody);
                }

                track({
                    EventType: 'form_submit_attempt',
                    SubmitOutcome: 'failure',
                    PageKey: pageKey,
                    FormKey: formKey,
                    MetadataJson: JSON.stringify({
                        correlationId: responseBody && responseBody.correlationId ? responseBody.correlationId : ''
                    })
                });
            } finally {
                if (submitButton) {
                    submitButton.disabled = false;
                    submitButton.textContent = submitDefaultLabel;
                }
            }
        });

        populateAttributionFields();
        syncAgeHidden();
        syncDerivedContactFields();
        microStepConfigs.forEach(function (config) { syncChoiceCards(config.field); });

        if (showContactStepByDefault) {
            setStartedState(true);
            showContactStep(!hasServerErrors);
        } else {
            setStartedState(false);
        }
    }());
    </script>
}
