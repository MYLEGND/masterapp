    margin: 6px 0 14px;
    padding: 16px;
    border-radius: 22px;
    border: 1px solid rgba(59, 130, 246, 0.22);
    background: linear-gradient(180deg, rgba(8, 29, 57, 0.94), rgba(5, 18, 36, 0.98));
}

.dq-review-kicker {
    color: rgba(243, 214, 136, 0.94);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-size: 0.72rem;
    font-weight: 800;
}

.dq-review-title {
    color: #fff7df;
    font-size: 1.06rem;
    font-weight: 800;
}

.dq-review-copy {
    color: rgba(226, 232, 240, 0.8);
    font-size: 0.92rem;
    line-height: 1.55;
}

.dq-review-stats {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
}

.dq-review-stat {
    border-radius: 18px;
    border: 1px solid rgba(243, 200, 75, 0.16);
    background: rgba(6, 20, 39, 0.82);
    padding: 12px;
}

.dq-review-stat-label {
    color: rgba(226, 232, 240, 0.66);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 700;
}

.dq-review-stat-value {
    color: #fff8e7;
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1.35;
    margin-top: 6px;
}

.dq-review-signal {
    border-radius: 18px;
    padding: 12px 14px;
    border: 1px solid rgba(54, 197, 106, 0.24);
    background: rgba(18, 76, 44, 0.12);
    color: #d7f7e3;
    font-size: 0.9rem;
    line-height: 1.5;
}

.dq-contact-head {
    display: grid;
    gap: 5px;
    margin-bottom: 14px;
}

.dq-contact-kicker {
    color: rgba(243, 214, 136, 0.94);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 800;
}

.dq-contact-title {
    color: #fff7df;
    font-size: 1.2rem;
    font-weight: 800;
    line-height: 1.2;
}

.dq-contact-copy {
    color: rgba(226, 232, 240, 0.8);
    font-size: 0.94rem;
    line-height: 1.58;
}

.lq-alert {
    margin-bottom: 16px;
    border-radius: 18px;
    border: 1px solid rgba(248, 113, 113, 0.48);
    background: rgba(127, 29, 29, 0.16);
    color: #fecaca;
    padding: 14px 16px;
}

.lq-alert ul {
    margin: 0;
    padding-left: 18px;
}

.lq-field-row {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: 12px;
}

.lq-field-row.lq-field-row-3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
}

.lq-field {
    display: grid;
    gap: 6px;
}

.lq-field label {
    color: #fff8e7;
    font-size: 0.92rem;
    font-weight: 800;
}

.lq-required-star {
    color: #fda4af;
}

.form-control,
.form-select {
    width: 100%;
    min-height: 52px;
    border-radius: 16px;
    border: 1px solid rgba(231, 181, 58, 0.28);
    background: rgba(248, 250, 252, 0.98);
    color: #0f172a;
    padding: 0 14px;
    font-size: 0.95rem;
    box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.06);
}

.form-control::placeholder {
    color: rgba(15, 23, 42, 0.48);
}

.form-control:focus,
.form-select:focus {
    border-color: rgba(54, 197, 106, 0.72);
    box-shadow: 0 0 0 0.2rem rgba(54, 197, 106, 0.16);
}

.form-control.is-invalid,
.form-select.is-invalid {
    border-color: rgba(248, 113, 113, 0.84);
}

.dq-contact-hint {
    color: rgba(226, 232, 240, 0.7);
    font-size: 0.85rem;
    margin-bottom: 10px;
}

.lq-consent {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px;
    align-items: start;
    margin-top: 8px;
    padding-top: 14px;
    border-top: 1px solid rgba(59, 130, 246, 0.16);
}

.lq-consent input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin-top: 3px;
    accent-color: #36c56a;
}

.lq-consent-copy {
    color: rgba(226, 232, 240, 0.85);
    font-size: 0.9rem;
    line-height: 1.55;
}

.dq-submit-note {
    color: rgba(226, 232, 240, 0.72);
    font-size: 0.83rem;
    margin: 0 0 8px;
}

body.health-final-step-active .dq-proof-chips {
    display: none;
}

body.health-final-step-active .dq-form-panel {
    padding-top: 16px;
}

@@media (max-width: 767.98px) {
    .dq-surface {
        padding: 14px;
    }

    .dq-brand-row {
        align-items: flex-start;
        flex-direction: column;
    }

    .dq-form-panel {
        padding: 14px;
    }

    .lq-field-row,
    .lq-field-row.lq-field-row-3,
    .dq-review-stats,
    .lq-choice-grid {
        grid-template-columns: 1fr;
    }

    .lq-card {
        min-height: 0;
    }

    .lq-above-fold-proof {
        gap: 6px;
        margin: 6px 0 8px;
    }

    .lq-above-fold-proof span {
        min-height: 24px;
        padding: 4px 8px;
        border-radius: 999px;
        font-size: 0.66rem;
        line-height: 1.05;
        white-space: nowrap;
    }

    .lq-hero-step-copy {
        margin: 2px auto 9px;
        padding: 0 4px;
    }

    .lq-hero-step-copy-title {
        font-size: 1rem;
        line-height: 1.12;
    }

    .lq-hero-step-copy-helper {
        font-size: 0.76rem;
        line-height: 1.28;
        margin-top: 4px;
    }

    .lq-contact-first-hero-actions {
        width: 100%;
        max-width: 100%;
        margin: 4px auto 10px;
        gap: 4px;
    }

    .lq-primary-start-note {
        font-size: 0.72rem;
        line-height: 1.2;
    }

    .lq-step-actions {
        flex-direction: column;
    }

    .btn-ghost,
    .btn-gold,
    .lq-primary-start-cta {
        width: 100%;
    }
}
</style>

