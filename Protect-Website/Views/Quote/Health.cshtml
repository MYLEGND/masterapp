<div class="dq-shell">
    <div class="lq-hero-shell">
        <div class="dq-surface">
            <div class="dq-hero-entry" id="healthHeroEntryPanel" @((showContactStepByDefault ? "hidden" : null))>
                <figure class="dq-hero-banner-wrap">
                    <img class="dq-hero-banner-image" src="~/images/ads/health-top-banner.png" asp-append-version="true" alt="Legend health insurance review creative inviting a quick health coverage review." loading="eager" />
                </figure>

                <div class="lq-above-fold-proof" aria-label="Review benefits">
                    <span>
                        <svg class="lq-pill-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="8" r="3.1"></circle>
                            <circle cx="5.6" cy="10" r="2.35"></circle>
                            <circle cx="18.4" cy="10" r="2.35"></circle>
                            <path d="M6.8 19.2c.65-3.15 2.55-5 5.2-5s4.55 1.85 5.2 5"></path>
                            <path d="M1.9 18.6c.45-2.25 1.8-3.55 3.7-3.55 1.05 0 1.95.38 2.65 1.1"></path>
                            <path d="M15.75 16.15c.7-.72 1.6-1.1 2.65-1.1 1.9 0 3.25 1.3 3.7 3.55"></path>
                        </svg>
                        @heroProofChips[0]
                    </span>
                    <span>
                        <svg class="lq-pill-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="12" r="8.2"></circle>
                            <path d="M12 7.2v5.15l3.35 2.05"></path>
                        </svg>
                        @heroProofChips[1]
                    </span>
                    <span>
                        <svg class="lq-pill-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2.8 19.2 5.6v5.55c0 4.55-2.85 8.25-7.2 10.05-4.35-1.8-7.2-5.5-7.2-10.05V5.6L12 2.8Z"></path>
                            <path d="m8.7 12.1 2.15 2.15 4.55-4.8"></path>
                        </svg>
                        @heroProofChips[2]
                    </span>
                </div>

                <div class="lq-hero-step-copy">
                    <div class="lq-hero-step-copy-title">@heroStepIntroTitle</div>
                    <p class="lq-hero-step-copy-helper">@heroStepIntroHelper</p>
                </div>

                <div class="lq-contact-first-hero-actions">
                    <button type="button" class="btn-gold lq-primary-start-cta lq-contact-first-hero-cta" id="healthHeroStartCta" data-cta="health_funnel_start" data-primary-cta="hero">@primaryStartCtaText</button>
                    <div class="lq-contact-first-hero-cta-note lq-primary-start-note"><span>@primaryStartCtaNote</span></div>
                </div>
            </div>

            <form asp-action="SubmitHealthQuote" asp-controller="HealthQuote" method="post" id="healthQuoteForm" data-form-key="@formKey" novalidate>
                @Html.AntiForgeryToken()
                @if (!string.IsNullOrWhiteSpace(agentSlug))
                {
                    <input type="hidden" name="AgentSlug" value="@agentSlug" />
                }

                <input type="hidden" name="PageKey" value="@pageKey" />
                <input type="hidden" name="PageVariant" value="@pageVariant" />
                <input type="hidden" name="PageMode" value="@pageMode" />
                <input type="hidden" name="Age" id="Age" value="@initialAgeValue" />
                <input type="hidden" name="SessionId" id="SessionId" />
                <input type="hidden" name="VisitorId" id="VisitorId" />
                <input type="hidden" name="UtmSource" id="UtmSource" />
                <input type="hidden" name="UtmMedium" id="UtmMedium" />
                <input type="hidden" name="UtmCampaign" id="UtmCampaign" />
                <input type="hidden" name="UtmId" id="UtmId" />
                <input type="hidden" name="UtmTerm" id="UtmTerm" />
                <input type="hidden" name="UtmContent" id="UtmContent" />
                <input type="hidden" name="MetaCampaignId" id="MetaCampaignId" />
                <input type="hidden" name="MetaAdSetId" id="MetaAdSetId" />
                <input type="hidden" name="MetaAdId" id="MetaAdId" />
                <input type="hidden" name="Fbclid" id="Fbclid" />
                <input type="hidden" name="ReferrerUrl" id="ReferrerUrl" />
                <input type="hidden" name="LandingPageUrl" id="LandingPageUrl" />

                <noscript>
                    <style>
                        #healthEducationPanel[hidden] { display: block !important; }
                    </style>
                </noscript>

                <div class="dq-primary-grid" id="healthEducationPanel" @((showContactStepByDefault ? null : "hidden"))>
                    <section class="dq-form-panel" id="healthEducationContactPanel">
                        <div class="dq-proof-card" aria-label="How this health review helps">
                            <div class="dq-proof-icon" aria-hidden="true">
                                <svg viewBox="0 0 48 48" fill="none"><use href="#dq-icon-shield"></use></svg>
                            </div>
                            <div class="dq-proof-copy">
                                <div class="dq-proof-kicker">Health coverage review</div>
                                <div class="dq-proof-title">Protect your household from surprise medical costs and coverage gaps.</div>
                                <p class="dq-proof-text">Answer a few quick questions so the conversation starts around your household needs, current coverage, and the kind of plan guidance you want first.</p>
                            </div>
                        </div>

                        <div class="dq-proof-chips" aria-hidden="true">
                            <span class="dq-proof-chip">Affordable plan focus</span>
                            <span class="dq-proof-chip">Family coverage guidance</span>
                            <span class="dq-proof-chip">Private and no-pressure</span>
                        </div>

                        <div class="dq-wizard-surface">
                            @if (hasServerErrors)
                            {
                                <div class="lq-alert" role="alert">
                                    <ul>
                                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                        {
                                            <li>@error.ErrorMessage</li>
                                        }
                                    </ul>
                                </div>
                            }

                            <div class="lq-step-panel" id="dqStep1Panel" @((showContactStepByDefault ? "hidden" : null))>
                                <div class="lq-step-panel-pad">
                                    <div class="lq-step-progress-wrap" aria-live="polite">
                                        <div class="lq-step-progress" id="dqStep1Progress">Question 1 of 5</div>
                                        <div class="lq-step-progress-track" aria-hidden="true">
                                            <span class="lq-step-progress-fill" id="dqStep1ProgressFill"></span>
                                        </div>
                                    </div>

                                    <div class="lq-micro-step" data-micro-step="0">
                                        <div class="lq-step-intro">
                                            <h2 class="lq-step-title">Let's tailor the health review.</h2>
                                            <p class="lq-step-helper">Answer a few quick questions first so your review reflects your household, current coverage, and the tradeoffs that matter most.</p>
                                        </div>
                                        <div class="lq-choice-group" role="radiogroup" aria-labelledby="dqAgeRangeLabel">
                                            <div class="lq-choice-label" id="dqAgeRangeLabel">What is your age range?</div>
                                            <div class="lq-choice-grid">
                                                <label class="lq-card lq-card-rich @SelectedClassIf(selectedAgeRange == "18-24")">
                                                    <input type="radio" name="AgeRange" value="18-24" @CheckedIf(selectedAgeRange == "18-24") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-calendar"></use></svg></span>
                                                    <span class="lq-card-copy">
                                                        <span class="lq-card-kicker">Age band</span>
                                                        <span class="lq-card-title">18-24</span>
                                                        <span class="lq-card-helper">A strong time to lock in affordable basics before care gets more expensive.</span>
                                                    </span>
                                                </label>
                                                <label class="lq-card lq-card-rich @SelectedClassIf(selectedAgeRange == "25-34")">
                                                    <input type="radio" name="AgeRange" value="25-34" @CheckedIf(selectedAgeRange == "25-34") />
                                                    <span class="lq-card-visual" aria-hidden="true"><svg class="lq-card-icon" viewBox="0 0 48 48" fill="none"><use href="#dq-icon-calendar"></use></svg></span>
