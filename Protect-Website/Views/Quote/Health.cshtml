@model Protect_Website.Models.HealthQuoteFormModel

@{
    ViewData["Title"] = "Health Insurance Quote";
    ViewData["PageKey"] = "quote_health";
}

<div class="container-narrow">

    <div class="text-center" style="margin-top:18px; margin-bottom:6px;">
        <h1 style="
            font-weight: 900;
            font-size: 2rem;
            color: #a68023;
            letter-spacing: .5px;
            margin-bottom: 6px;">
            Health Insurance Quote
        </h1>
    </div>

    <p class="required-note text-center">
        <strong>
            <span class="text-danger">*</span> Fields marked with a red asterisk are required.
        </strong>
    </p>

<style>
    body { background-color: #0f172a; color: #f8fafc; }

    .section-card {
        background-color: #0f172a;
        border: 1.6px solid #c79931;
        padding: 16px;
        border-radius: 12px;
        margin-bottom: 24px;
        box-shadow: 0 18px 40px rgba(0,0,0,0.18);
        color: #f8fafc;
    }

    .section-title {
        font-size: 1.25rem;
        font-weight: 900;
        color: #c79931;
        margin-bottom: 12px;
    }

    .form-control, .form-select {
        border: 1.6px solid #c79931;
        margin-bottom: 10px;
        background: #ffffff;
        color: #0f172a;
        font-size: 0.95rem;
        padding: 8px 10px;
    }
    .form-control::placeholder, .form-select::placeholder{
        color: rgba(15,23,42,0.55);
    }
    .form-control:focus, .form-select:focus {
        outline: none;
        box-shadow: 0 0 0 0.2rem rgba(199,153,49,0.22);
        border-color: #c79931;
        background: #ffffff;
        color: #0f172a;
    }

    .btn-gold {
        background: linear-gradient(180deg, #c79931, #a68023);
        color: #fff;
        font-weight: 900;
        padding: 9px 20px;
        border-radius: 8px;
        font-size: 1rem;
        border: 1.4px solid #c79931;
        box-shadow: 0 14px 32px rgba(0,0,0,0.18);
    }

    .btn-gold:hover {
        background: linear-gradient(180deg, #c79931, #a68023);
        color: #fff;
    }

    .text-gold { color: #c79931; }

    /* ===================== DISCLAIMER ===================== */
    .disclaimer-container {
        margin-top: 40px;
        margin-bottom: 40px;
        font-size: 1rem;
        font-weight: bold;
        line-height: 1.5;
        color: #f8fafc;
        display: flex;
        align-items: flex-start;
    }

    .disclaimer-container input {
        margin-right: 12px;
        margin-top: 4px;
        width: 20px;
        height: 20px;
    }

    /* ===== Visual-only: single-card layout + tighter, lead-form grouping ===== */
    .lead-card{
        max-width: 1100px;
        width: 100%;
        margin: 0 auto 24px auto;
    }

    .lead-grid{
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
    }

    .lead-block{
        border: 1.4px solid #c79931;
        border-radius: 10px;
        padding: 12px 12px 4px 12px;
        background: #111c32;
        color: #f8fafc;
    }

    .lead-block .section-title{
        margin-bottom: 12px;
        font-size: 1.15rem;
        color: #c79931;
    }

    .lead-row{
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px 14px;
    }

    @@media (min-width: 768px){
        .lead-row.three{
            grid-template-columns: repeat(3, 1fr);
        }
        .lead-row.two{
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .field{
        margin-bottom: 0;
    }

    .field label{
        display:block;
        margin-bottom: 6px;
        font-weight: 800;
        color: #f8fafc;
        font-size: .95rem;
    }

    .field .form-control,
    .field .form-select{
        margin-bottom: 8px;
    }

    .field .form-select{
        cursor: pointer;
        appearance: auto;
    }

    .field .form-select:invalid{
        color: #64748b;
    }

    .field .form-select option[value=""]{
        color: #64748b;
    }

.disclaimer-wrap{
    margin-top: 6px;
}
.disclaimer-check{
    display:flex;
    align-items:flex-start;
    gap:10px;
    padding:10px 0;
}
.disclaimer-check .form-check-input{
    width:18px;
    height:18px;
    margin-top:2px;
    margin-left:0;
    margin-right:0;
    position:static;
    flex-shrink:0;
}
.disclaimer-check .form-check-label{
    line-height:1.5;
    white-space:normal;
    color:#f8fafc;
}
</style>

<!-- ===================== SUCCESS MESSAGE ===================== -->
@if (ViewBag.Success != null)
{
    <div class="success-message">
        @ViewBag.Success
    </div>
}

<form asp-action="SubmitHealthQuote" asp-controller="HealthQuote" method="post" id="healthQuoteForm" data-form-key="quote_health_form">

    <!-- ===================== SINGLE CONTACT CARD (VISUAL RE-ORG ONLY) ===================== -->
    <div class="section-card lead-card">

        <div class="lead-grid">

            <!-- CORE DETAILS -->
            <div class="lead-block">

                <div class="section-title">Core Quote Details</div>

                <div class="lead-row three">
                    <div class="field">
                        <label>First Name<span class="text-danger">*</span></label>
                        <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                    </div>
                    <div class="field">
                        <label>Last Name<span class="text-danger">*</span></label>
                        <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                    </div>
                    <div class="field">
                        <label>Age<span class="text-danger">*</span></label>
                        <input asp-for="Age" class="form-control" placeholder="Age" />
                    </div>
                </div>

                <div class="lead-row two">
                    <div class="field">
                        <label>Email<span class="text-danger">*</span></label>
                        <input asp-for="Email" class="form-control" placeholder="Email" />
                    </div>
                    <div class="field">
                        <label>Phone<span class="text-danger">*</span></label>
                        <input asp-for="Phone" class="form-control" placeholder="Phone" />
                    </div>
                </div>

                <div class="section-title" style="margin-top: 6px;">Next Steps</div>

                <div class="lead-row two">
                    <div class="field">
                        <label>Preferred Contact Method<span class="text-danger">*</span></label>
                        <select asp-for="ContactMethod" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Phone</option>
                            <option>Email</option>
                            <option>Text</option>
                        </select>
                    </div>

                    <div class="field">
                        <label>Best Time<span class="text-danger">*</span></label>
                        <select asp-for="BestTimeToContact" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Morning</option>
                            <option>Afternoon</option>
                            <option>Evening</option>
                        </select>
                    </div>
                </div>

            </div>

            <!-- ADDITIONAL DETAILS -->
            <div class="lead-block">

                <div class="section-title">Additional Details</div>

                <div class="lead-row three">
                    <div class="field">
                        <label>Monthly Budget Goal<span class="text-danger">*</span></label>
                        <input asp-for="CoverageType" class="form-control" placeholder="e.g. $750 monthly budget" required />
                    </div>

                    <div class="field">
                        <label>Household Size<span class="text-danger">*</span></label>
                        <select asp-for="HouseholdSize" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>1</option>
                            <option>2–3</option>
                            <option>4–5</option>
                            <option>6+</option>
                        </select>
                    </div>
                </div>

                <div class="lead-row two">
                    <div class="field">
                        <label>Primary Concern<span class="text-danger">*</span></label>
                        <select asp-for="PrimaryConcern" class="form-select" required>
                            <option value="">-- Select an Option --</option>
                            <option>Lower Monthly Premium</option>
                            <option>Lower Deductible</option>
                            <option>Better Doctor Network</option>
                            <option>Prescription Coverage</option>
                            <option>Family Coverage</option>
                            <option>Dental / Vision Options</option>
                            <option>Marketplace / ACA Guidance</option>
                            <option>Not Sure / Need Guidance</option>
                        </select>
                    </div>
                </div>

            </div>

        </div>

        <!-- ===================== DISCLAIMER ===================== -->
        <div class="lead-block disclaimer-wrap">
            <div class="form-check disclaimer-check">
                <input asp-for="AcknowledgedDisclaimer" type="checkbox" class="form-check-input" id="disclaimerCheckbox" required />
                <label class="form-check-label" for="disclaimerCheckbox">
                    I acknowledge that by submitting this form, I authorize the company to contact me regarding my health insurance inquiry and personalized coverage review.<span class="text-danger">*</span>
                </label>
            </div>
            <span asp-validation-for="AcknowledgedDisclaimer" class="text-danger"></span>

            <div class="text-center mb-5" style="margin-top: 30px;">
                <button type="submit" class="btn btn-gold">Request My Custom Plan</button>
            </div>
        </div>

    </div>

</form>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById('healthQuoteForm');
    const checkbox = document.getElementById('disclaimerCheckbox');

    if (!form || !checkbox) return;

    form.addEventListener('submit', function(event) {
        if (!checkbox.checked) {
            event.preventDefault();
            alert('Please acknowledge the disclaimer to proceed: You must authorize us to contact me regarding your health insurance inquiry and personalized coverage review.');
        }
    });
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.querySelector("form");

    if (!form) return;

    form.addEventListener("submit", function (event) {
        if (!form.checkValidity()) {
            event.preventDefault();

            const firstInvalid = form.querySelector(":invalid");
            if (firstInvalid) {
                firstInvalid.scrollIntoView({
                    behavior: "smooth",
                    block: "center"
                });
                firstInvalid.focus();
            }
        }
    });
});
</script>
