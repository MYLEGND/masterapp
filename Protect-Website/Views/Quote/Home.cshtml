<script>
(function () {
    var ids = window.legendTrackingIds;
    var p = new URLSearchParams(window.location.search);
    var attr = ids && ids.getAttribution ? (ids.getAttribution() || {}) : {};
    function sh(n, v) { var e = document.querySelector('input[name="' + n + '"]'); if (e && v) e.value = v; }
    sh('SessionId',    ids && ids.getSessionId ? ids.getSessionId() : '');
    sh('VisitorId',    ids && ids.getVisitorId ? ids.getVisitorId() : '');
    sh('UtmSource',    attr.utmSource || p.get('utm_source') || '');
    sh('UtmMedium',    attr.utmMedium || p.get('utm_medium') || '');
    sh('UtmCampaign',  attr.utmCampaign || p.get('utm_campaign') || '');
    sh('UtmId',        attr.utmId || p.get('utm_id') || '');
    sh('UtmTerm',      attr.utmTerm || p.get('utm_term') || '');
    sh('UtmContent',   attr.utmContent || p.get('utm_content') || '');
    sh('MetaCampaignId', attr.metaCampaignId || p.get('meta_campaign_id') || '');
    sh('MetaAdSetId',  attr.metaAdSetId || p.get('meta_adset_id') || '');
    sh('MetaAdId',     attr.metaAdId || p.get('meta_ad_id') || '');
    sh('Fbclid',       attr.fbclid || p.get('fbclid') || '');
    sh('ReferrerUrl',  document.referrer || '');
    sh('LandingPageUrl', window.location.href || '');
})();
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        let currentStep = 1;
        const pageKey = '@pageKey';
        const formKey = '@formKey';
        const trackHomeQuote = (window.legendTrack && typeof window.legendTrack === 'function')
            ? window.legendTrack
            : null;
        const homeCompletedSteps = new Set();
        const homeViewedContactSteps = new Set();

        function emitHomeStepComplete(stepNumber, nextStep) {
            if (!trackHomeQuote || homeCompletedSteps.has(stepNumber)) return;
            homeCompletedSteps.add(stepNumber);
            trackHomeQuote({
                EventType: 'quote_step_complete',
                FormKey: formKey,
                PageKey: pageKey,
                MetadataJson: JSON.stringify({ stepNumber, nextStep })
            });
        }

        function emitHomeContactStepView(stepNumber) {
            if (!trackHomeQuote || homeViewedContactSteps.has(stepNumber)) return;
            homeViewedContactSteps.add(stepNumber);
            trackHomeQuote({
                EventType: 'quote_contact_step_view',
                FormKey: formKey,
                PageKey: pageKey,
                MetadataJson: JSON.stringify({ stepNumber, source: 'wizard_step_view' })
            });
        }

        function setStep(step) {
            currentStep = step;

            document.querySelectorAll(".wizard-step").forEach(s => {
                const isActive = parseInt(s.getAttribute("data-step")) === step;
                s.classList.toggle("active", isActive);

                // disable inputs outside active step so browser doesn't validate them
                s.querySelectorAll("input, select, textarea").forEach(el => {
                    el.disabled = !isActive;
                });
            });

            document.querySelectorAll(".wizard-pill").forEach(p => {
                p.classList.toggle("active", parseInt(p.getAttribute("data-pill")) === step);
            });

            // keep conditional logic correct when moving steps
            if (step === 2) togglePreviousAddress();
            toggleHouseUpdateYearFields();
            if (step === 2) emitHomeContactStepView(step);
        }

        function validateCurrentStep() {
            const stepEl = document.querySelector(`.wizard-step[data-step="${currentStep}"]`);
            if (!stepEl) return true;

            // Ensure conditional required fields are correct before validating
            togglePreviousAddress(true);
            toggleHouseUpdateYearFields();

            const inputs = stepEl.querySelectorAll("input, select, textarea");
            for (const el of inputs) {
                if (el.disabled) continue;
                if (!el.checkValidity()) {
                    el.reportValidity();
                    return false;
                }
            }
            return true;
        }

        function goNext() {
            if (!validateCurrentStep()) return;
            if (currentStep < 6) {
                emitHomeStepComplete(currentStep, currentStep + 1);
                setStep(currentStep + 1);
            }
        }

        function goBack() {
            if (currentStep > 1) setStep(currentStep - 1);
        }

        // -------- Previous Address: show only if PrimaryYearsAtAddress < 3 --------

        function setRequired(el, yes) {
            if (!el) return;
            if (yes) el.setAttribute("required", "required");
            else el.removeAttribute("required");
        }

        function togglePreviousAddress(keepVisibleIfOnServerError = false) {
            const yrsRaw = (document.getElementById("PrimaryYearsAtAddress")?.value ?? "").trim();
            const yrs = parseFloat(yrsRaw);
            const show = !isNaN(yrs) && yrs < 3;

            const block = document.getElementById("previousAddressBlock");
            if (!block) return;

            block.style.display = show ? "" : "none";

            // Enable/disable inputs for UX + wizard validation
            block.querySelectorAll("input, select, textarea").forEach(el => {
                el.disabled = !show || (currentStep !== 2); // only enable when step 2 is active
            });

            // Required ONLY when shown
            const reqIds = ["PreviousAddress", "PreviousCity", "PreviousState", "PreviousCountry", "PreviousPostalCode", "PreviousYearsAtAddress"];
            reqIds.forEach(id => setRequired(document.getElementById(id), show));

            // If server returned errors and user is in step 2 already, keep it visible
            if (keepVisibleIfOnServerError && currentStep === 2 && show) {
                block.style.display = "";
            }
        }

        // -------- Updates: if not "Not Updated", show Year Updated field --------

        function toggleOneUpdate(selectEl) {
            if (!selectEl) return;
            const targetId = selectEl.getAttribute("data-year-target");
            if (!targetId) return;

            const wrap = document.getElementById(targetId + "Wrap");
            const input = document.getElementById(targetId);

            const v = (selectEl.value ?? "").trim();
            const show = v !== "" && v !== "Not Updated";

            if (wrap) wrap.style.display = show ? "" : "none";
            if (input) {
                input.disabled = !show || (currentStep !== 4);
                // Year Updated is NOT marked required in your outline
                input.removeAttribute("required");
            }
        }

        function toggleHouseUpdateYearFields() {
            document.querySelectorAll(".houseUpdate").forEach(sel => toggleOneUpdate(sel));
        }

        function enableAllInputsForSubmit() {
            document.querySelectorAll("input, select, textarea").forEach(el => el.disabled = false);
        }

        document.addEventListener("DOMContentLoaded", function () {
            const startStep = parseInt("@(ViewData["StartStep"] ?? 1)") || 1;

            setStep(startStep);

            // Default Primary/Previous Country to United States if empty
            const pc = document.getElementById("PrimaryCountry");
            if (pc && (pc.value ?? "") === "") pc.value = "United States";
            const prc = document.getElementById("PreviousCountry");
            if (prc && (prc.value ?? "") === "") prc.value = "United States";

            // Wire years-at-address to previous address logic
            const yearsEl = document.getElementById("PrimaryYearsAtAddress");
            if (yearsEl) {
                yearsEl.addEventListener("input", () => togglePreviousAddress());
                yearsEl.addEventListener("change", () => togglePreviousAddress());
            }
            togglePreviousAddress();

            // Wire house update dropdowns to year fields
            document.querySelectorAll(".houseUpdate").forEach(sel => {
                sel.addEventListener("change", () => toggleOneUpdate(sel));
                sel.addEventListener("input", () => toggleOneUpdate(sel));
            });
            toggleHouseUpdateYearFields();

        const form = document.getElementById("homeQuoteForm");
        if (form) {
            form.addEventListener("submit", function () {
                form._trackSubmitAttempt?.(true, 0);
                // Ensure conditional fields are correct, then allow submit
                togglePreviousAddress(true);
                    toggleHouseUpdateYearFields();
                    enableAllInputsForSubmit();
                    const disclaimer = document.getElementById("AcknowledgedDisclaimer");
                    if (disclaimer) {
                        disclaimer.disabled = false;
                        disclaimer.value = disclaimer.checked ? 'true' : 'false';
                        // hidden override to guarantee post even if main box was disabled earlier
                        let hidden = document.getElementById("AcknowledgedDisclaimerHidden");
                        if (!hidden) {
                            hidden = document.createElement("input");
                            hidden.type = "hidden";
                            hidden.id = "AcknowledgedDisclaimerHidden";
                            hidden.name = "AcknowledgedDisclaimer";
                            form.appendChild(hidden);
                        }
                        hidden.value = disclaimer.checked ? 'true' : 'false';
                    }
                });
            }
        });

        // Dev-only sticky form state (localhost only)
        (function () {
            const form = document.getElementById("homeQuoteForm");
            const storageKey = "homeQuoteForm-dev";
            const isLocalHost = ["localhost", "127.0.0.1"].includes(location.hostname);
            if (!isLocalHost || !form) return;

            function saveState() {
                const data = { step: currentStep, values: {} };
                form.querySelectorAll("input, select, textarea").forEach(el => {
                    if (!el.name) return;
                    data.values[el.name] = el.type === "checkbox" ? el.checked : el.value;
                });
                try { localStorage.setItem(storageKey, JSON.stringify(data)); } catch { /* ignore */ }
            }

            function restoreState() {
                try {
                    const raw = localStorage.getItem(storageKey);
                    if (!raw) return;
                    const data = JSON.parse(raw);
                    const vals = data?.values ?? {};
                    Object.keys(vals).forEach(name => {
                        const el = form.querySelector(`[name=\"${name}\"]`);
                        if (!el) return;
                        if (el.type === "checkbox") el.checked = !!vals[name];
                        else el.value = vals[name];
                    });
                    if (data?.step) setStep(parseInt(data.step) || 1);
                } catch { /* ignore */ }
            }

            restoreState();
            form.addEventListener("input", saveState);
            form.addEventListener("change", saveState);
        })();

        // Visual cues: answered vs missing required
        function updateFieldState(el) {
            if (!el) return;
            el.classList.remove("input-answered", "input-required-missing");

            const isRequired = el.hasAttribute("required") || el.dataset.originalRequired === "1";
            const val = (el.value ?? "").trim();

            if (val !== "") {
                el.classList.add("input-answered");
            } else if (isRequired) {
                el.classList.add("input-required-missing");
            }
        }

        document.querySelectorAll("input, select, textarea").forEach(el => {
            updateFieldState(el);
            el.addEventListener("input", () => updateFieldState(el));
            el.addEventListener("change", () => updateFieldState(el));
        });
    </script>
}
