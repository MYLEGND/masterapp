@using System.Text.Json
@model Protect_Website.Models.HomeQuoteFormModel

@{
    ViewData["Title"] = "Home Insurance Quote";
    var pageKey = ((string?)ViewData["PageKey"] ?? "quote_home").Trim();
    if (string.IsNullOrWhiteSpace(pageKey))
    {
        pageKey = "quote_home";
    }
    var formKey = $"{pageKey}_form";
    ViewData["PageKey"] = pageKey;
    ViewData["PageCategory"] = "quote";
    ViewData["QuoteTypeForTracking"] = "home";
    ViewData["PageVariant"] = "website";
    ViewData["PageMode"] = "site_mode";
    ViewData["IsLandingPage"] = false;
    var isFounderPath = ViewData["IsFounderPath"] as bool? == true;
    var trackedSlug = ((string?)ViewData["TrackingSlug"] ?? string.Empty).Trim();
    var agentSlug = !isFounderPath ? trackedSlug : string.Empty;
}

<div class="container-narrow">

    <div class="text-center" style="margin-top:18px; margin-bottom:6px;">
        <h1 style="
            font-weight: 900;
            font-size: 2.4rem;
            color: #a68023;
            letter-spacing: .5px;
            margin-bottom: 6px;">
            Home Insurance Quote
        </h1>
    </div>

    <p class="required-note text-center">
        <strong>
            <span class="text-danger">*</span> Fields marked with a red asterisk are required.
        </strong>
    </p>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger fw-bold">
            @Html.ValidationSummary(excludePropertyErrors: false)
        </div>
    }

<style>
    body { background-color: #ffffff; }

    form.container { max-width: 1200px; padding-bottom: 40px; }

    .section-card {
        background-color: #ffffff;
        border: 2px solid #a68023;
        padding: 26px;
        border-radius: 12px;
        margin: 18px auto 26px;
        box-shadow: 0 12px 26px rgba(0,0,0,0.06);
    }

    .section-title {
        font-size: 1.45rem;
        font-weight: 900;
        color: #a68023;
        margin-bottom: 18px;
        letter-spacing: 0.2px;
    }

    .section-card h5 { font-weight: 900; margin-top: 10px; margin-bottom: 10px; }

    label { font-weight: 800; }

    .form-control, .form-select, textarea {
        border: 1px solid #a68023;
        margin-bottom: 12px;
        border-radius: 10px;
        padding: 10px 12px;
    }

    /* Answered vs missing (inline cues) */
    .input-answered {
        border-color: #a68023 !important;
        box-shadow: 0 0 0 1px #a68023 !important;
    }

    .input-required-missing {
        border-color: #dc3545 !important;
        box-shadow: 0 0 10px rgba(220, 53, 69, 0.55) !important;
    }

    .form-control:focus, .form-select:focus, textarea:focus {
        outline: none;
        box-shadow: 0 0 0 0.2rem rgba(166,128,35,0.20);
        border-color: #a68023;
    }

    .btn-gold {
        background-color: #a68023;
        color: #fff;
        font-weight: 900;
        padding: 12px 26px;
        border-radius: 10px;
        font-size: 1.05rem;
        border: none;
        letter-spacing: 0.2px;
    }

    .btn-gold:hover { background-color: #8f6f1e; color: #fff; }

    /* Back button styling (avoid flat white) */
    .btn-secondary {
        background: transparent;
        color: #a68023;
        border: 1.6px solid #a68023;
        font-weight: 800;
        box-shadow: none;
    }
    .btn-secondary:hover {
        background: rgba(166,128,35,0.12);
        color: #a68023;
        border-color: #a68023;
    }

    .mini-card {
        border: 1px solid rgba(0,0,0,0.10);
        padding: 18px;
        border-radius: 12px;
        margin-bottom: 16px;
        background: #fff;
        box-shadow: 0 8px 18px rgba(0,0,0,0.05);
    }

    .mini-card h5 { color: #222; margin-bottom: 12px; font-weight: 900; }

    .wizard-steps {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin: 10px auto 18px;
        justify-content: center;
        max-width: 1200px;
        padding: 0 12px;
    }

    .wizard-pill {
        border: 1px solid #a68023;
        padding: 8px 12px;
        border-radius: 999px;
        font-weight: 900;
        font-size: 0.95rem;
        color: #222;
        opacity: 0.45;
        background: #fff;
        user-select: none;
    }

    .wizard-pill.active { opacity: 1; background: #a68023; color: #fff; }

    .wizard-step { display: none; }
    .wizard-step.active { display: block; }

    .muted-help { color: rgba(0,0,0,.62); font-weight: 700; font-size: 0.92rem; }

    @@media (max-width: 768px) {
        .section-card { padding: 18px; }
        .btn-gold { width: 100%; min-height: 48px; }

        .wizard-steps {
            flex-wrap: nowrap;
            overflow-x: auto;
            justify-content: flex-start;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            padding-bottom: 6px;
        }

        .wizard-steps::-webkit-scrollbar { display: none; }

        .wizard-pill {
            flex: 0 0 auto;
            white-space: nowrap;
        }
    }
</style>

<div class="wizard-steps">
    <div class="wizard-pill" data-pill="1">Section 1 — Applicant</div>
    <div class="wizard-pill" data-pill="2">Section 2 — Address & Contact</div>
    <div class="wizard-pill" data-pill="3">Section 3 — Policy</div>
    <div class="wizard-pill" data-pill="4">Section 4 — Dwelling</div>
    <div class="wizard-pill" data-pill="5">Section 5 — Coverages</div>
    <div class="wizard-pill" data-pill="6">Section 6 — Endorsements</div>
</div>

<form asp-action="SubmitHomeQuote" asp-controller="HomeQuote" method="post" class="container" id="homeQuoteForm" novalidate data-form-key="@formKey">
    @Html.AntiForgeryToken()
    @if (!string.IsNullOrWhiteSpace(agentSlug))
    {
        <input type="hidden" name="AgentSlug" value="@agentSlug" />
    }
    <input type="hidden" name="PageKey" value="@pageKey" />

    <!-- ===================== SECTION 1: APPLICANT INFO ===================== -->
    <div class="section-card wizard-step active" data-step="1">
        <div class="section-title">Applicant Info</div>

        <div class="mini-card">
            <h5>Applicant</h5>

            <div class="row">
                <div class="col-md-4">
                    <label>First Name<span class="text-danger">*</span></label>
                    <input asp-for="FirstName" class="form-control" required data-original-required="1" id="Applicant_FirstName" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Last Name<span class="text-danger">*</span></label>
                    <input asp-for="LastName" class="form-control" required data-original-required="1" id="Applicant_LastName" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Nickname</label>
                    <input asp-for="Nickname" class="form-control" id="Applicant_Nickname" />
                    <span asp-validation-for="Nickname" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>Address State<span class="text-danger">*</span></label>
                    <select asp-for="AddressState" class="form-select" required data-original-required="1" id="Applicant_AddressState">
                        <option value="">--Select--</option>
                        <option>AZ</option><option>CA</option><option>IA</option><option>KS</option><option>LA</option><option>MD</option><option>MS</option><option>OH</option><option>SC</option><option>SD</option><option>TX</option><option>WA</option>
                    </select>
                    <span asp-validation-for="AddressState" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Postal Code<span class="text-danger">*</span></label>
                    <input asp-for="PostalCode" class="form-control" required data-original-required="1" id="Applicant_PostalCode" />
                    <span asp-validation-for="PostalCode" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Gender<span class="text-danger">*</span></label>
                    <select asp-for="Gender" class="form-select" required data-original-required="1" id="Applicant_Gender">
                        <option value="">--Select--</option>
                        <option>Female</option>
                        <option>Male</option>
                        <option>Not Specified</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>DOB<span class="text-danger">*</span></label>
                    <input asp-for="DOB" type="date" class="form-control" required data-original-required="1" id="Applicant_DOB" />
                    <span asp-validation-for="DOB" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Marital Status<span class="text-danger">*</span></label>
                    <select asp-for="MaritalStatus" class="form-select" required data-original-required="1" id="Applicant_MaritalStatus">
                        <option value="">--Select--</option>
                        <option>Single</option>
                        <option>Married</option>
                        <option>Domestic Partner</option>
                        <option>Widowed</option>
                        <option>Separated</option>
                        <option>Divorced</option>
                    </select>
                    <span asp-validation-for="MaritalStatus" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Driver’s License #<span class="text-danger">*</span></label>
                    <input asp-for="DriversLicenseNumber" class="form-control" required data-original-required="1" id="Applicant_DriversLicenseNumber" />
                    <span asp-validation-for="DriversLicenseNumber" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>DL Status<span class="text-danger">*</span></label>
                    <select asp-for="DLStatus" class="form-select" required data-original-required="1" id="Applicant_DLStatus">
                        <option value="">--Select--</option>
                        <option>Valid</option>
                        <option>Permit</option>
                        <option>Expired</option>
                        <option>Suspended</option>
                        <option>Cancelled</option>
                        <option>Not Licensed</option>
                        <option>Permanently Revoked</option>
                    </select>
                    <span asp-validation-for="DLStatus" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label>DL State<span class="text-danger">*</span></label>
                    <select asp-for="DLState" class="form-select" required data-original-required="1" id="Applicant_DLState">
                        <option value="">--Select--</option>
                        <option>AZ</option><option>CA</option><option>IA</option><option>KS</option><option>LA</option><option>MD</option><option>MS</option><option>OH</option><option>SC</option><option>SD</option><option>TX</option><option>WA</option>
                    </select>
                    <span asp-validation-for="DLState" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label>Education</label>
                    <select asp-for="Education" class="form-select" id="Applicant_Education">
                        <option value="">--Select--</option>
                        <option>No High School Diploma</option>
                        <option>Some College - No Degree</option>
                        <option>Vocational/Technical Degree</option>
                        <option>Associates Degree</option>
                        <option>Bachelors</option>
                        <option>Masters</option>
                        <option>Phd</option>
                        <option>Medical Degree</option>
                        <option>Law Degree</option>
                    </select>
                    <span asp-validation-for="Education" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-12">
                    <label>Industry<span class="text-danger">*</span></label>
                    <select asp-for="Industry" class="form-select" required data-original-required="1" id="Applicant_Industry">
                        <option value="">--Select--</option>
                        <option>Homemaker/House Person</option>
                        <option>Retired</option>
                        <option>Disabled</option>
                        <option>Unemployed</option>
                        <option>Student</option>
                        <option>Agriculture/Forestry/Fishing</option>
                        <option>Art/Design/Media</option>
                        <option>Banking/Finance/Real Estate</option>
                        <option>Business/Sales/Office</option>
                        <option>Construction/Energy/Trades</option>
                        <option>Education/Library</option>
                        <option>Engineer/Architect/Science/Math</option>
                        <option>Government/Military</option>
                        <option>Information Technology</option>
                        <option>Insurance</option>
                        <option>Legal/Law Enforcement/Security</option>
                        <option>Maintenance/Repair/Housekeeping</option>
                        <option>Manufacturing/Production</option>
                        <option>Medical/Social Services/Religion</option>
                        <option>Personal Care/Service</option>
                        <option>Restaurant/Hotel Services</option>
                        <option>Sports/Recreation</option>
                        <option>Travel/Transporation/Warehousing</option>
                        <option>Other</option>
                    </select>
                    <span asp-validation-for="Industry" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end mt-2">
            <button type="button" class="btn btn-gold" onclick="goNext()">Next — Address & Contact</button>
        </div>
    </div>

    <!-- ===================== SECTION 2: ADDRESS & CONTACT ===================== -->
    <div class="section-card wizard-step" data-step="2">
        <div class="section-title">Address & Contact</div>

        <div class="mini-card" id="primaryAddressCard">
            <h5>Primary Address</h5>

            <div class="row">
                <div class="col-md-6">
                    <label>Address<span class="text-danger">*</span></label>
                    <input asp-for="PrimaryAddress" class="form-control" required data-original-required="1" id="PrimaryAddress" />
                    <span asp-validation-for="PrimaryAddress" class="text-danger"></span>
                </div>
                <div class="col-md-2">
                    <label>Unit</label>
                    <input asp-for="PrimaryUnit" class="form-control" id="PrimaryUnit" />
                    <span asp-validation-for="PrimaryUnit" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Address Line 2</label>
                    <input asp-for="PrimaryAddressLine2" class="form-control" id="PrimaryAddressLine2" />
                    <span asp-validation-for="PrimaryAddressLine2" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>City<span class="text-danger">*</span></label>
                    <input asp-for="PrimaryCity" class="form-control" required data-original-required="1" id="PrimaryCity" />
                    <span asp-validation-for="PrimaryCity" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>State<span class="text-danger">*</span></label>
                    <select asp-for="PrimaryState" class="form-select" required data-original-required="1" id="PrimaryState">
                        <option value="">--Select--</option>
                        <option>AZ</option><option>CA</option><option>IA</option><option>KS</option><option>LA</option><option>MD</option><option>MS</option><option>OH</option><option>SC</option><option>SD</option><option>TX</option><option>WA</option>
                    </select>
                    <span asp-validation-for="PrimaryState" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Country<span class="text-danger">*</span></label>
                    <select asp-for="PrimaryCountry" class="form-select" required data-original-required="1" id="PrimaryCountry">
                        <option value="">--Select--</option>
                        <option>United States</option>
                        <option>Canada</option>
                        <option>Mexico</option>
                        <option>Other</option>
                    </select>
                    <span asp-validation-for="PrimaryCountry" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>Postal Code<span class="text-danger">*</span></label>
                    <input asp-for="PrimaryPostalCode" class="form-control" required data-original-required="1" id="PrimaryPostalCode" />
                    <span asp-validation-for="PrimaryPostalCode" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Years At Address<span class="text-danger">*</span></label>
                    <input asp-for="PrimaryYearsAtAddress" class="form-control" required data-original-required="1" id="PrimaryYearsAtAddress" />
                    <span asp-validation-for="PrimaryYearsAtAddress" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <div class="muted-help" style="margin-top:34px;">
                        If less than 3 years, we’ll ask for the previous address.
                    </div>
                </div>
            </div>

            <div id="previousAddressBlock" style="display:none;">
                <hr />
                <h5 class="mb-2">Previous Address</h5>

                <div class="row">
                    <div class="col-md-6">
                        <label>Address<span class="text-danger">*</span></label>
                        <input asp-for="PreviousAddress" class="form-control" id="PreviousAddress" />
                        <span asp-validation-for="PreviousAddress" class="text-danger"></span>
                    </div>
                    <div class="col-md-2">
                        <label>Unit</label>
                        <input asp-for="PreviousUnit" class="form-control" id="PreviousUnit" />
                        <span asp-validation-for="PreviousUnit" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label>Address Line 2</label>
                        <input asp-for="PreviousAddressLine2" class="form-control" id="PreviousAddressLine2" />
                        <span asp-validation-for="PreviousAddressLine2" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <label>City<span class="text-danger">*</span></label>
                        <input asp-for="PreviousCity" class="form-control" id="PreviousCity" />
                        <span asp-validation-for="PreviousCity" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label>State<span class="text-danger">*</span></label>
                        <select asp-for="PreviousState" class="form-select" id="PreviousState">
                            <option value="">--Select--</option>
                            <option>AZ</option><option>CA</option><option>IA</option><option>KS</option><option>LA</option><option>MD</option><option>MS</option><option>OH</option><option>SC</option><option>SD</option><option>TX</option><option>WA</option>
                        </select>
                        <span asp-validation-for="PreviousState" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label>Country<span class="text-danger">*</span></label>
                        <select asp-for="PreviousCountry" class="form-select" id="PreviousCountry">
                            <option value="">--Select--</option>
                            <option>United States</option>
                            <option>Canada</option>
                            <option>Mexico</option>
                            <option>Other</option>
                        </select>
                        <span asp-validation-for="PreviousCountry" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <label>Postal Code<span class="text-danger">*</span></label>
                        <input asp-for="PreviousPostalCode" class="form-control" id="PreviousPostalCode" />
                        <span asp-validation-for="PreviousPostalCode" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label>Years At Address<span class="text-danger">*</span></label>
                        <input asp-for="PreviousYearsAtAddress" class="form-control" id="PreviousYearsAtAddress" />
                        <span asp-validation-for="PreviousYearsAtAddress" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="mini-card" id="contactInfoCard">
            <h5>Contact Info</h5>

            <div class="row">
                <div class="col-md-4">
                    <label>Phone Type<span class="text-danger">*</span></label>
                    <select asp-for="PhoneType" class="form-select" required data-original-required="1" id="PhoneType">
                        <option value="">--Select--</option>
                        <option>Home</option>
                        <option>Work</option>
                        <option>Mobile</option>
                        <option>Fax</option>
                    </select>
                    <span asp-validation-for="PhoneType" class="text-danger"></span>
                </div>
                <div class="col-md-8">
                    <label>Phone Number<span class="text-danger">*</span></label>
                    <input asp-for="PhoneNumber" class="form-control" required data-original-required="1" id="PhoneNumber" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>Email Type<span class="text-danger">*</span></label>
                    <select asp-for="EmailType" class="form-select" required data-original-required="1" id="EmailType">
                        <option value="">--Select--</option>
                        <option>Primary</option>
                        <option>Secondary</option>
                    </select>
                    <span asp-validation-for="EmailType" class="text-danger"></span>
                </div>
                <div class="col-md-8">
                    <label>Email Address<span class="text-danger">*</span></label>
                    <input asp-for="EmailAddress" type="email" class="form-control" required data-original-required="1" id="EmailAddress" />
                    <span asp-validation-for="EmailAddress" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label>Preferred Contact Method<span class="text-danger">*</span></label>
                    <select asp-for="PreferredContactMethod" class="form-select" required data-original-required="1" id="PreferredContactMethod">
                        <option value="">--Select--</option>
                        <option>Phone</option>
                        <option>Email</option>
                        <option>Text</option>
                    </select>
                    <span asp-validation-for="PreferredContactMethod" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label>Best Time to Contact<span class="text-danger">*</span></label>
                    <select asp-for="BestTimeToContact" class="form-select" required data-original-required="1" id="BestTimeToContact">
                        <option value="">--Select--</option>
                        <option>Morning</option>
                        <option>Afternoon</option>
                        <option>Evening</option>
                    </select>
                    <span asp-validation-for="BestTimeToContact" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between mt-2">
            <button type="button" class="btn btn-secondary fw-bold" onclick="goBack()">Back</button>
            <button type="button" class="btn btn-gold" onclick="goNext()">Next — Policy</button>
        </div>
    </div>

    <!-- ===================== SECTION 3: POLICY INFORMATION ===================== -->
    <div class="section-card wizard-step" data-step="3">
        <div class="section-title">Policy Information</div>

        <div class="mini-card">
            <h5>Policy</h5>

            <div class="row">
                <div class="col-md-4">
                    <label>Policy / Form Type<span class="text-danger">*</span></label>
                    <select asp-for="PolicyFormType" class="form-select" required data-original-required="1" id="PolicyFormType">
                        <option value="">--Select--</option>
                        <option>HO3 - Dwelling</option>
                        <option>HO4 - Renters</option>
                        <option>HO5</option>
                        <option>HO6 - Condo</option>
                    </select>
                    <span asp-validation-for="PolicyFormType" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label>Prior Carrier<span class="text-danger">*</span></label>
                    <input asp-for="PriorCarrier" class="form-control" required data-original-required="1" id="PriorCarrier" />
                    <span asp-validation-for="PriorCarrier" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label>Expiration Date (Current Policy)<span class="text-danger">*</span></label>
                    <input asp-for="CurrentPolicyExpirationDate" type="date" class="form-control" required data-original-required="1" id="CurrentPolicyExpirationDate" />
                    <span asp-validation-for="CurrentPolicyExpirationDate" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>Prior Policy Premium</label>
                    <input asp-for="PriorPolicyPremium" class="form-control" id="PriorPolicyPremium" />
                    <span asp-validation-for="PriorPolicyPremium" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <label>Years with Prior Carrier<span class="text-danger">*</span></label>
                    <select asp-for="YearsWithPriorCarrier" class="form-select" required data-original-required="1" id="YearsWithPriorCarrier">
