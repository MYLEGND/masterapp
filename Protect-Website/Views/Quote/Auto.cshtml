(function () {
    var ids = window.legendTrackingIds;
    var p = new URLSearchParams(window.location.search);
    var attr = ids && ids.getAttribution ? (ids.getAttribution() || {}) : {};
    function sh(n, v) { var e = document.querySelector('input[name="' + n + '"]'); if (e && v) e.value = v; }
    sh('SessionId',    ids && ids.getSessionId ? ids.getSessionId() : '');
    sh('VisitorId',    ids && ids.getVisitorId ? ids.getVisitorId() : '');
    sh('UtmSource',    attr.utmSource || p.get('utm_source') || '');
    sh('UtmMedium',    attr.utmMedium || p.get('utm_medium') || '');
    sh('UtmCampaign',  attr.utmCampaign || p.get('utm_campaign') || '');
    sh('UtmId',        attr.utmId || p.get('utm_id') || '');
    sh('UtmTerm',      attr.utmTerm || p.get('utm_term') || '');
    sh('UtmContent',   attr.utmContent || p.get('utm_content') || '');
    sh('MetaCampaignId', attr.metaCampaignId || p.get('meta_campaign_id') || '');
    sh('MetaAdSetId',  attr.metaAdSetId || p.get('meta_adset_id') || '');
    sh('MetaAdId',     attr.metaAdId || p.get('meta_ad_id') || '');
    sh('Fbclid',       attr.fbclid || p.get('fbclid') || '');
    sh('ReferrerUrl',  document.referrer || '');
    sh('LandingPageUrl', window.location.href || '');
})();
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

	    <script>
	    let currentStep = 1;
	    const pageKey = '@pageKey';
	    const formKey = '@formKey';
	    const initialStartStep = parseInt("@(ViewData["StartStep"] ?? 1)") || 1;
	    let quoteStarted = '@(showQuoteStartedByDefault ? "true" : "false")' === 'true';
	    const trackAutoQuote = (window.LegendAnalytics?.track && typeof window.LegendAnalytics.track === 'function')
	        ? window.LegendAnalytics.track
	        : (window.legendTrack && typeof window.legendTrack === 'function')
	            ? window.legendTrack
	            : null;
	    const autoCompletedSteps = new Set();
	    const autoViewedContactSteps = new Set();
	    const heroEntryPanel = document.getElementById("autoHeroEntryPanel");
	    const quoteFlowShell = document.getElementById("autoQuoteFlowShell");
	    const startButton = document.getElementById("autoHeroStartCta");
	    const currentStepField = document.getElementById("CurrentStep");

	    function setQuoteStartedState(started) {
	        quoteStarted = !!started;
	        document.body.classList.toggle("pcq-quote-started", quoteStarted);
	        if (heroEntryPanel) heroEntryPanel.hidden = quoteStarted;
	        if (quoteFlowShell) quoteFlowShell.hidden = !quoteStarted;
	    }

	    function trackAutoCta(elementKey, buttonLabel) {
	        if (!trackAutoQuote) return;
	        trackAutoQuote({
	            EventType: 'quote_cta_click',
	            ElementKey: elementKey,
	            ButtonLabel: buttonLabel,
	            FormKey: formKey,
	            PageKey: pageKey
	        });
	        trackAutoQuote({
	            EventType: 'cta_click',
	            ElementKey: elementKey,
	            ButtonLabel: buttonLabel,
	            FormKey: formKey,
	            PageKey: pageKey
	        });
	    }

    function emitAutoStepComplete(stepNumber, nextStep) {
        if (!trackAutoQuote || autoCompletedSteps.has(stepNumber)) return;
        autoCompletedSteps.add(stepNumber);
        trackAutoQuote({
            EventType: 'quote_step_complete',
            FormKey: formKey,
            PageKey: pageKey,
            MetadataJson: JSON.stringify({ stepNumber, nextStep })
        });
    }

    function emitAutoContactStepView(stepNumber) {
        if (!trackAutoQuote || autoViewedContactSteps.has(stepNumber)) return;
        autoViewedContactSteps.add(stepNumber);
        trackAutoQuote({
            EventType: 'quote_contact_step_view',
            FormKey: formKey,
            PageKey: pageKey,
            MetadataJson: JSON.stringify({ stepNumber, source: 'wizard_step_view' })
        });
    }

	    function setStep(step) {
	        currentStep = step;
	        if (currentStepField) currentStepField.value = step.toString();
	
	        document.querySelectorAll(".wizard-step").forEach(s => {
	            const isActive = parseInt(s.getAttribute("data-step")) === step;
	            s.classList.toggle("active", isActive);

            s.querySelectorAll("input, select, textarea").forEach(el => {
                el.disabled = !isActive;
            });
        });

        document.querySelectorAll(".wizard-pill").forEach(p => {
            p.classList.toggle("active", parseInt(p.getAttribute("data-pill")) === step);
        });

        if (step === 3 || step === 4 || step === 5) {
            syncAllDriverDropdowns();
            syncIncidentDropdowns();
            applyPendingIncidentSelections();
        }
	        if (step === 5) {
	            buildVehicleCoverageCards();
	        }
	        if (step === 1 && quoteStarted) {
	            emitAutoContactStepView(step);
	        }
	        refreshFieldStates();
	    }

	    function updateFieldState(el) {
	        if (!el) return;
	        el.classList.remove("input-answered", "input-required-missing");
	        if (el.disabled || el.type === "hidden") return;

	        const isRequired = el.hasAttribute("required") || el.dataset.originalRequired === "1";
	        const hasValue = el.type === "checkbox"
	            ? !!el.checked
	            : (el.value ?? "").trim() !== "";

	        if (hasValue) {
	            el.classList.add("input-answered");
	        } else if (isRequired) {
	            el.classList.add("input-required-missing");
	        }
	    }

	    function refreshFieldStates() {
	        document.querySelectorAll("input, select, textarea").forEach(updateFieldState);
	    }

    function validateCurrentStep() {
        const stepEl = document.querySelector(`.wizard-step[data-step="${currentStep}"]`);
        if (!stepEl) return true;

        const inputs = stepEl.querySelectorAll("input, select, textarea");
        for (const el of inputs) {
            if (el.disabled) continue;
            if (!el.checkValidity()) {
                el.reportValidity();
                return false;
            }
        }
        return true;
    }

    function goNext() {
        if (!validateCurrentStep()) return;
        if (currentStep < 5) {
            emitAutoStepComplete(currentStep, currentStep + 1);
            setStep(currentStep + 1);
        }
    }

    function goBack() {
        if (currentStep > 1) setStep(currentStep - 1);
    }

    function removeCard(btn, type) {
        const card = btn.closest(".mini-card");
        if (!card) return;

        if (type === "driver" && card.getAttribute("data-driver") === "0") return;
        if (type === "vehicle" && card.getAttribute("data-vehicle") === "0") return;

        card.remove();

        if (type === "driver") reindexCards("driversContainer", "driver-card", "Drivers", "data-driver");
        if (type === "vehicle") reindexCards("vehiclesContainer", "vehicle-card", "Vehicles", "data-vehicle");

        if (type === "accident") reindexMini("accidentsContainer", "Accidents");
        if (type === "violation") reindexMini("violationsContainer", "Violations");
        if (type === "comp") reindexMini("compLossesContainer", "CompLosses");

        syncAllDriverDropdowns();
        syncIncidentDropdowns();
        applyPendingIncidentSelections();
        buildVehicleCoverageCards();
    }

    function reindexCards(containerId, cardClass, prefix, dataAttr) {
        const container = document.getElementById(containerId);
        if (!container) return;

        const cards = container.querySelectorAll("." + cardClass);
        cards.forEach((card, index) => {
            card.setAttribute(dataAttr, index);

            const title = card.querySelector(".driver-title") || card.querySelector(".vehicle-title");
            if (title) {
                if (prefix === "Drivers") title.innerText = index === 0 ? "Primary Insured" : "Additional Driver " + index;
                if (prefix === "Vehicles") title.innerText = index === 0 ? "Primary Vehicle" : "Additional Vehicle " + index;
            }

            card.querySelectorAll("input, select, textarea").forEach(el => {
                if (!el.name) return;
                el.name = el.name.replace(new RegExp(prefix + "\\[\\d+\\]", "g"), prefix + "[" + index + "]");
            });
        });
    }

    function reindexMini(containerId, prefix) {
        const container = document.getElementById(containerId);
        if (!container) return;

        const cards = container.querySelectorAll(".mini-card");
        cards.forEach((card, index) => {
            card.querySelectorAll("input, select, textarea").forEach(el => {
                if (!el.name) return;
                el.name = el.name.replace(new RegExp(prefix + "\\[\\d+\\]", "g"), prefix + "[" + index + "]");
            });
        });
    }

