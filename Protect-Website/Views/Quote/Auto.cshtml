    function getVehicleDisplayNames() {
        const vehicles = [];
        document.querySelectorAll(".vehicle-card").forEach((card, idx) => {
            const year = card.querySelector(`[name="Vehicles[${idx}].Year"]`)?.value?.trim() || "";
            const make = card.querySelector(`[name="Vehicles[${idx}].Make"]`)?.value?.trim() || "";
