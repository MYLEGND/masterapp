    function snapshotValues(rootEl) {
        const map = new Map();
        if (!rootEl) return map;

        rootEl.querySelectorAll("input[name], select[name], textarea[name]").forEach(el => {
            if (!el.name) return;
            if (el.type === "checkbox") map.set(el.name, el.checked ? "true" : "false");
            else map.set(el.name, el.value ?? "");
        });

        return map;
    }

    function restoreValues(rootEl, map) {
        if (!rootEl || !map) return;

        rootEl.querySelectorAll("input[name], select[name], textarea[name]").forEach(el => {
            if (!map.has(el.name)) return;
            const v = map.get(el.name) ?? "";
            if (el.type === "checkbox") el.checked = (v === "true");
            else el.value = v;
        });
    }

