    function rebuildAccidentsFromModel(items) {
        const container = document.getElementById("accidentsContainer");
        const tpl = document.getElementById("accidentTemplate");
        if (!container || !tpl) return;

        container.innerHTML = "";

        (items || []).forEach((a, idx) => {
            const fragment = tpl.content.cloneNode(true);
            fragment.querySelectorAll("[name]").forEach(el => el.name = el.name.replace(/__i__/g, idx));
            container.appendChild(fragment);

            const root = container.lastElementChild;

            root.querySelector(`[name="Accidents[${idx}].Date"]`).value = a.Date ?? "";
            root.querySelector(`[name="Accidents[${idx}].Description"]`).value = a.Description ?? "";
            root.querySelector(`[name="Accidents[${idx}].PropertyDamageAmount"]`).value = a.PropertyDamageAmount ?? "";
            root.querySelector(`[name="Accidents[${idx}].BodilyInjuryAmount"]`).value = a.BodilyInjuryAmount ?? "";
            root.querySelector(`[name="Accidents[${idx}].CollisionAmount"]`).value = a.CollisionAmount ?? "";
            root.querySelector(`[name="Accidents[${idx}].MedicalPaymentAmount"]`).value = a.MedicalPaymentAmount ?? "";
            root.querySelector(`[name="Accidents[${idx}].VehicleInvolvedText"]`).value = a.VehicleInvolvedText ?? "";

            // saved selections applied after dropdown options exist
            root.querySelector(`[name="Accidents[${idx}].DriverIndex"]`).setAttribute("data-pending", (a.DriverIndex ?? "").toString());
            root.querySelector(`[name="Accidents[${idx}].VehicleIndex"]`).setAttribute("data-pending", (a.VehicleIndex ?? "").toString());
        });

        reindexMini("accidentsContainer", "Accidents");
    }

