    function safeSet(el, val) {
        if (!el) return;
        const v = (val ?? "").toString();
        const canOverwrite = (el.value ?? "") === "" || el.getAttribute("data-autofilled") === "1";
        if (!canOverwrite) return;
        el.value = v;
        el.setAttribute("data-autofilled", "1");
        el.dispatchEvent(new Event("change", { bubbles: true }));
        el.dispatchEvent(new Event("input", { bubbles: true }));
    }

    function applyApplicantToPrimaryDriver() {
        const aFirst = document.getElementById("Applicant_FirstName")?.value ?? "";
        const aLast = document.getElementById("Applicant_LastName")?.value ?? "";
        const aDob = document.getElementById("Applicant_DOB")?.value ?? "";
        const aGender = document.getElementById("Applicant_Gender")?.value ?? "";
        const aMarital = document.getElementById("Applicant_MaritalStatus")?.value ?? "";
        const aDLNum = document.getElementById("Applicant_DriversLicenseNumber")?.value ?? "";
        const aDLStatus = document.getElementById("Applicant_DLStatus")?.value ?? "";
        const aDLState = document.getElementById("Applicant_DLState")?.value ?? "";
        const aIndustry = document.getElementById("Applicant_Industry")?.value ?? "";

        safeSet(document.getElementById("Driver0_FirstName"), aFirst);
        safeSet(document.getElementById("Driver0_LastName"), aLast);
        safeSet(document.getElementById("Driver0_DOB"), aDob);

        // Driver dropdown list is Male/Female/Not Specified. Applicant is Female/Male/Not Specified.
        safeSet(document.getElementById("Driver0_Gender"), aGender);

        // Driver marital list in your HTML is missing Single/Married; we only set if option exists.
        const maritalEl = document.getElementById("Driver0_MaritalStatus");
        if (maritalEl && (maritalEl.value === "" || maritalEl.getAttribute("data-autofilled") === "1")) {
            const exists = Array.from(maritalEl.options).some(o => o.value === aMarital || o.text === aMarital);
            if (exists) {
                maritalEl.value = aMarital;
                maritalEl.setAttribute("data-autofilled", "1");
                maritalEl.dispatchEvent(new Event("change", { bubbles: true }));
            }
        }

        safeSet(document.getElementById("Driver0_DLNumber"), aDLNum);
        safeSet(document.getElementById("Driver0_DLStatus"), aDLStatus);
        safeSet(document.getElementById("Driver0_DLState"), aDLState);

        // Industry -> OccupationIndustry
        safeSet(document.getElementById("Driver0_OccupationIndustry"), aIndustry);

        // Keep vehicle assignment dropdowns fresh
        syncAllDriverDropdowns();
        syncIncidentDropdowns();
        applyPendingIncidentSelections();
    }

    let _autoAssignLock = false;

    function defaultPrimaryVehicleToPrimaryDriver() {
        if (_autoAssignLock) return;
        const sel = document.getElementById("Vehicle0_AssignedDriverIndex");
        if (!sel) return;

        // If empty (or previously auto-set), lock it to driver 0
        const canOverwrite = (sel.value ?? "") === "" || sel.getAttribute("data-autofilled") === "1";
        if (!canOverwrite) return;

        // Ensure the options exist before setting
        const has0 = Array.from(sel.options).some(o => o.value === "0");
        if (has0) {
            const already = sel.value === "0";
            _autoAssignLock = true;
            sel.value = "0";
            sel.setAttribute("data-autofilled", "1");
            if (!already) {
                sel.dispatchEvent(new Event("change", { bubbles: true }));
            }
            _autoAssignLock = false;
        }
    }

    function togglePreviousAddress() {
        const yrsRaw = (document.getElementById("PrimaryYearsAtAddress")?.value ?? "").trim();
        const yrs = parseFloat(yrsRaw);
        const show = !isNaN(yrs) && yrs < 3;

        const block = document.getElementById("previousAddressBlock");
        if (!block) return;

        block.style.display = show ? "" : "none";

        // Disable inputs when hidden so they don't interfere with UX
        block.querySelectorAll("input, select, textarea").forEach(el => {
            el.disabled = !show;
        });
    }

