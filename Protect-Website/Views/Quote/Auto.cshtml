	    document.addEventListener("DOMContentLoaded", function () {
	        setQuoteStartedState(quoteStarted);
	
	        // ✅ rebuild incident cards from server model so they persist after validation errors
	        const initialAccidents = @Html.Raw(JsonSerializer.Serialize(Model.Accidents ?? new List<Protect_Website.Models.Accident>()));
	        const initialViolations = @Html.Raw(JsonSerializer.Serialize(Model.Violations ?? new List<Protect_Website.Models.Violation>()));
	        const initialCompLosses = @Html.Raw(JsonSerializer.Serialize(Model.CompLosses ?? new List<Protect_Website.Models.CompLoss>()));

        rebuildAccidentsFromModel(initialAccidents);
        rebuildViolationsFromModel(initialViolations);
        rebuildCompLossesFromModel(initialCompLosses);

	        setStep(initialStartStep);

        syncAllDriverDropdowns();
        syncIncidentDropdowns();
        applyPendingIncidentSelections();
        buildVehicleCoverageCards();

        // Default Primary Country to United States if empty (doesn't overwrite user choice)
        const pc = document.getElementById("PrimaryCountry");
        if (pc && (pc.value ?? "") === "") pc.value = "United States";

        // Wire Applicant -> Primary Driver autofill
        const applicantFields = [
            "Applicant_FirstName","Applicant_LastName","Applicant_DOB","Applicant_Gender","Applicant_MaritalStatus",
            "Applicant_DriversLicenseNumber","Applicant_DLStatus","Applicant_DLState","Applicant_Industry"
        ];

        applicantFields.forEach(id => {
            const el = document.getElementById(id);
            if (!el) return;
            el.addEventListener("input", applyApplicantToPrimaryDriver);
            el.addEventListener("change", applyApplicantToPrimaryDriver);
        });

        // PrimaryYearsAtAddress drives Previous Address visibility
        const yearsEl = document.getElementById("PrimaryYearsAtAddress");
        if (yearsEl) {
            yearsEl.addEventListener("input", togglePreviousAddress);
            yearsEl.addEventListener("change", togglePreviousAddress);
        }
        togglePreviousAddress();

        // Keep primary vehicle assigned to primary driver (if not manually changed)
        defaultPrimaryVehicleToPrimaryDriver();
        document.querySelectorAll(".driverPick").forEach(sel => {
            sel.addEventListener("change", defaultPrimaryVehicleToPrimaryDriver);
        });

        // First load: apply autofill immediately if model has values or user starts step 2
        applyApplicantToPrimaryDriver();
        defaultPrimaryVehicleToPrimaryDriver();

        const form = document.getElementById("autoQuoteForm");
        if (form) {
            form.addEventListener("submit", function () {
                form._trackSubmitAttempt?.(true, 0);
                buildVehicleCoverageCards();
                enableAllInputsForSubmit();
                // ensure required checkbox stays enabled and submitted
                const disclaimer = document.getElementById("AcknowledgedDisclaimer");
                if (disclaimer) {
                    disclaimer.disabled = false;
                    disclaimer.value = disclaimer.checked ? 'true' : 'false';
                    // create/refresh hidden override to guarantee posting value
                    let hidden = document.getElementById("AcknowledgedDisclaimerHidden");
                    if (!hidden) {
                        hidden = document.createElement("input");
                        hidden.type = "hidden";
                        hidden.id = "AcknowledgedDisclaimerHidden";
                        hidden.name = "AcknowledgedDisclaimer";
                        form.appendChild(hidden);
                    }
                    hidden.value = disclaimer.checked ? "true" : "false";
                }
            });
        }

        // Dev-only sticky form state (only on localhost to speed manual testing)
        const storageKey = "autoQuoteForm-dev";
        const isLocalHost = () => ["localhost", "127.0.0.1"].includes(location.hostname);

        function saveFormState() {
            if (!isLocalHost() || !form) return;
            const data = { step: currentStep, values: {} };
            form.querySelectorAll("input, select, textarea").forEach(el => {
                if (!el.name) return;
                data.values[el.name] = el.type === "checkbox" ? el.checked : el.value;
            });
            try { localStorage.setItem(storageKey, JSON.stringify(data)); } catch { /* ignore */ }
        }

        function restoreFormState() {
            if (!isLocalHost() || !form) return;
            try {
                const raw = localStorage.getItem(storageKey);
                if (!raw) return;
                const data = JSON.parse(raw);
                const vals = data?.values ?? {};
                Object.keys(vals).forEach(name => {
                    const el = form.querySelector(`[name=\"${name}\"]`);
                    if (!el) return;
                    if (el.type === "checkbox") el.checked = !!vals[name];
                    else el.value = vals[name];
                });
                if (data?.step) setStep(parseInt(data.step) || 1);
            } catch { /* ignore */ }
        }

	        restoreFormState();
	        if (currentStep > 1) {
	            setQuoteStartedState(true);
	        }
	        if (form) {
	            form.addEventListener("input", saveFormState);
	            form.addEventListener("change", saveFormState);
	        }

	        if (startButton) {
	            startButton.addEventListener("click", function () {
	                const label = (startButton.textContent || "").trim();
	                if (!quoteStarted) {
	                    trackAutoCta('auto_quote_start', label || 'Check My Auto Protection Fit');
	                }
	                setQuoteStartedState(true);
	                setStep(currentStep || initialStartStep || 1);
	                if (quoteFlowShell) {
	                    quoteFlowShell.scrollIntoView({ behavior: "smooth", block: "start" });
	                }
	            });
	        }
	
	        const watchedSelectors = "input, select, textarea";
	        document.querySelectorAll(watchedSelectors).forEach(el => {
	            el.addEventListener("input", () => updateFieldState(el));
	            el.addEventListener("change", () => updateFieldState(el));
	        });
	        refreshFieldStates();
	    });
	</script>
	}
