            const last = card.querySelector(`[name="Drivers[${idx}].LastName"]`)?.value?.trim() || "";
            const label = (first || last) ? `${first} ${last}`.trim() : (idx === 0 ? "Primary Insured" : `Driver ${idx}`);
            names.push({ value: idx.toString(), text: label });
