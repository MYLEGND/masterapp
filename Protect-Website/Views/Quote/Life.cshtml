.lq-card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 14px 10px;
    min-height: 58px;
    border: 1.7px solid rgba(223,183,90,0.54);
    border-radius: 10px;
    background:
        linear-gradient(180deg, rgba(42,61,92,0.98) 0%, rgba(30,45,70,0.98) 100%);
    color: #f8fafc;
    font-weight: 800;
    font-size: .95rem;
    cursor: pointer;
    transition: border-color .2s ease, background .2s ease, box-shadow .2s ease, color .2s ease, transform .18s cubic-bezier(0.22, 1, 0.36, 1), filter .2s ease;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    line-height: 1.25;
    position: relative;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.05),
        0 9px 20px rgba(0,0,0,0.19);
}
.lq-card:hover {
    border-color: rgba(244,210,124,0.88);
    background:
        linear-gradient(180deg, rgba(49,70,103,0.99) 0%, rgba(34,51,79,0.99) 100%);
    transform: translateY(-2px) scale(1.012);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.07),
        0 14px 28px rgba(0,0,0,0.25),
        0 0 0 1px rgba(244,210,124,0.16);
    filter: saturate(1.05);
}
.lq-card:active {
    transform: translateY(0) scale(0.992);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.06),
        0 6px 14px rgba(0,0,0,0.24);
    filter: saturate(1.04);
}
.lq-card input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
}
.lq-card.lq-selected,
.lq-card:has(input:checked) {
    border-color: #f4d58b;
    background:
        linear-gradient(180deg, rgba(210,166,62,0.28) 0%, rgba(128,89,20,0.18) 100%),
        linear-gradient(180deg, rgba(45,64,96,0.99) 0%, rgba(32,48,74,0.99) 100%);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.1),
        0 16px 30px rgba(0,0,0,0.28),
        0 0 0 2px rgba(244,210,124,0.56),
        0 0 24px rgba(244,210,124,0.22);
    color: #f8fafc;
    transform: translateY(-3px) scale(1.015);
}
.lq-card.lq-selected:active,
.lq-card:has(input:checked):active {
    transform: translateY(-1px) scale(1.005);
}
.lq-card.lq-invalid { border-color: #ef4444; }
.lq-card-rich {
    display: grid;
    justify-items: center;
    align-content: start;
    gap: 12px;
    text-align: center;
    padding: 15px 13px;
    min-height: 138px;
}
.lq-card-rich::after {
    content: "";
    position: absolute;
    top: 10px;
    right: 10px;
    width: 11px;
    height: 11px;
    border-radius: 999px;
    border: 1.4px solid rgba(244,210,124,0.34);
    background: rgba(255,255,255,0.02);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
    transition: transform .18s ease, background .18s ease, border-color .18s ease, box-shadow .18s ease;
}
.lq-card-rich .lq-card-visual {
    width: 56px;
    height: 56px;
    border-radius: 18px;
    display: grid;
    place-items: center;
    background:
        linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%),
        rgba(11,19,34,0.54);
    border: 1px solid rgba(244,210,124,0.18);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.08),
        0 8px 16px rgba(0,0,0,0.18);
}
.lq-card-rich .lq-card-icon {
    width: 31px;
    height: 31px;
    color: #f0c66d;
}
.lq-card-rich .lq-card-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 38px;
    min-height: 38px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(240,198,109,0.12);
    color: #fff4d0;
    font-size: .86rem;
    font-weight: 900;
    letter-spacing: .02em;
}
.lq-card-rich .lq-card-copy {
    display: grid;
    gap: 5px;
    width: 100%;
}
.lq-card-rich .lq-card-kicker {
    color: rgba(240,198,109,0.92);
    font-size: .68rem;
    font-weight: 880;
    letter-spacing: .08em;
    text-transform: uppercase;
    line-height: 1;
}
.lq-card-rich .lq-card-title {
    color: #f8fafc;
    font-size: 1.02rem;
    font-weight: 860;
    line-height: 1.2;
}
.lq-card-rich .lq-card-helper {
    color: rgba(231,236,245,0.72);
    font-size: .76rem;
    font-weight: 690;
    line-height: 1.34;
}
.lq-card-rich .lq-card-kicker:empty,
.lq-card-rich .lq-card-helper:empty {
    display: none;
}
.lq-card-rich:has(.lq-card-helper:empty) {
    min-height: 104px;
    gap: 8px;
}
.lq-card-rich:has(.lq-card-helper:empty) .lq-card-copy {
    gap: 3px;
}
.lq-card-rich:has(.lq-card-kicker:empty):has(.lq-card-helper:empty) {
    min-height: 96px;
    gap: 6px;
    padding-top: 14px;
    padding-bottom: 14px;
}
.lq-card-rich:has(.lq-card-kicker:empty):has(.lq-card-helper:empty) .lq-card-copy {
    gap: 0;
}
.lq-card-rich.no-visual {
    min-height: 116px;
    gap: 8px;
    padding-top: 18px;
}
.lq-card-rich.no-visual .lq-card-copy {
    align-self: center;
}
.lq-card-rich.no-visual:has(.lq-card-kicker:empty):has(.lq-card-helper:empty) {
    min-height: 78px;
    padding-top: 14px;
    padding-bottom: 14px;
}
.lq-card-rich.tone-protect .lq-card-visual {
    background:
        radial-gradient(circle at top left, rgba(137,197,255,0.18), transparent 52%),
        linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%),
        rgba(11,19,34,0.54);
}
.lq-card-rich.tone-goal .lq-card-visual {
    background:
        radial-gradient(circle at top left, rgba(240,198,109,0.18), transparent 52%),
        linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%),
        rgba(11,19,34,0.54);
}
.lq-card-rich.tone-coverage .lq-card-visual,
.lq-card-rich.tone-age .lq-card-visual {
    background:
        radial-gradient(circle at top left, rgba(214,170,76,0.22), transparent 50%),
        linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%),
        rgba(11,19,34,0.54);
}
.lq-card-rich.tone-health .lq-card-visual {
    background:
        radial-gradient(circle at top left, rgba(158,226,190,0.16), transparent 52%),
        linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.02) 100%),
        rgba(11,19,34,0.54);
}
.lq-card-rich.lq-selected::after,
.lq-card-rich:has(input:checked)::after {
    background: #f4d58b;
    border-color: #f4d58b;
    box-shadow: 0 0 0 4px rgba(244,210,124,0.14);
    transform: scale(1.06);
}
.lq-card-rich.lq-selected .lq-card-visual,
.lq-card-rich:has(input:checked) .lq-card-visual {
    border-color: rgba(244,210,124,0.72);
    background:
        radial-gradient(circle at top left, rgba(248,220,145,0.22), transparent 54%),
        linear-gradient(180deg, rgba(255,255,255,0.10) 0%, rgba(255,255,255,0.03) 100%),
        rgba(14,22,36,0.72);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.10),
        0 12px 22px rgba(0,0,0,0.22),
        0 0 0 1px rgba(248,220,145,0.12);
}
.lq-card-rich.lq-selected .lq-card-helper,
.lq-card-rich:has(input:checked) .lq-card-helper {
    color: rgba(248,250,252,0.86);
}
.lq-choice-error {
    color: #f87171;
    font-size: .82rem;
    margin-top: 4px;
    min-height: 18px;
    display: none;
}
.lq-choice-error.visible { display: block; }

.lq-step-actions { margin-top: 16px; }
.lq-step-actions.dual {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}
#step2BackBtn{
    display: block;
    width: auto;
    min-width: 120px;
    margin: 10px auto 0;
}
.lq-reassurance {
    text-align: center;
    font-size: .84rem;
    color: rgba(248,250,252,0.55);
    margin-top: 6px;
}
.lq-contact-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
}
@@media (min-width: 600px) {
    .lq-contact-grid { grid-template-columns: 1fr 1fr; }
    .lq-contact-grid .full { grid-column: 1 / -1; }
}

.lq-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-weight: 800;
    color: #f8fafc;
}
.lq-consent input { width: 18px; height: 18px; margin-top: 3px; flex-shrink: 0; }
.consent-text { display: flex; flex-direction: column; gap: 3px; }
.consent-main { font-size: .97rem; font-weight: 800; color: #f8fafc; line-height: 1.4; }
.consent-sub  { font-size: .85rem; font-weight: 600; color: rgba(248,250,252,0.62); line-height: 1.4; }
.lq-submit-row { margin-top: 14px; }
.lq-reach-note {
    text-align: center;
    color: rgba(248,250,252,0.82);
    font-size: .92rem;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.4;
}
.lq-field-row{
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
}
@@media (min-width: 720px){
    .lq-field-row.two{ grid-template-columns: repeat(2,1fr); }
}
@@media (min-width: 560px) and (max-width: 767.98px){
    .lq-contact-step .lq-field-row.two{ grid-template-columns: repeat(2,1fr); }
}
.lq-field{
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.lq-field label{
    font-weight: 850;
    color: #f8fafc;
    letter-spacing: .01em;
}
.lq-field-help{
    color: rgba(248,250,252,0.68);
    font-size: .8rem;
    font-weight: 700;
    margin-top: -2px;
}
.lq-field-err{
    color: #f87171;
    font-size: .82rem;
    font-weight: 800;
    display: none;
}
.lq-field-err.visible{ display:block; }
.lq-contact-license-note {
    margin-top: -6px;
    margin-bottom: 10px;
    color: rgba(221,228,239,0.58);
    font-size: .72rem;
    font-weight: 720;
    line-height: 1.38;
}
.lq-contact-capture-head {
    display: grid;
    gap: 4px;
    padding: 2px 0 4px;
    text-align: center;
}
.lq-contact-capture-kicker {
    color: rgba(240,198,109,0.86);
    font-size: .7rem;
    font-weight: 860;
    letter-spacing: .08em;
    text-transform: uppercase;
}
.lq-contact-capture-title {
    color: #fff7df;
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.16;
}
.lq-contact-capture-copy {
    color: rgba(236,240,247,0.74);
    font-size: .84rem;
    line-height: 1.45;
    max-width: 48ch;
    margin: 0 auto;
}
.lq-agent-handoff {
    display: grid;
    gap: 12px;
    margin-bottom: 14px;
    padding: 14px;
    border-radius: 14px;
    border: 1.4px solid rgba(199,153,49,0.38);
    background:
        radial-gradient(circle at top right, rgba(199,153,49,0.16), transparent 38%),
        rgba(11,22,39,0.92);
    box-shadow:
        0 16px 28px rgba(0,0,0,0.24),
        inset 0 1px 0 rgba(255,255,255,0.06);
}
.lq-agent-handoff-head {
    display: flex;
    align-items: center;
    gap: 12px;
}
.lq-agent-identity {
    display: grid;
    justify-items: center;
    align-content: start;
    gap: 8px;
    flex-shrink: 0;
    min-width: 92px;
    text-align: center;
}
.lq-agent-avatar {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    border: 2px solid rgba(239,200,111,0.92);
    background: linear-gradient(180deg, #13233f 0%, #0b1529 100%);
    box-shadow: 0 12px 24px rgba(0,0,0,0.28);
}
.lq-agent-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}
.lq-agent-avatar-fallback {
    color: #f3d78f;
    font-size: 1.2rem;
    font-weight: 900;
    letter-spacing: .02em;
}
.lq-agent-name {
    color: #f3d78f;
    font-size: 1.08rem;
    font-weight: 900;
    margin-bottom: 3px;
}
.lq-agent-display-name {
    color: rgba(248,250,252,0.8);
    font-size: .8rem;
    font-weight: 800;
    line-height: 1.2;
}
.lq-agent-bio {
    color: rgba(248,250,252,0.82);
    font-size: .9rem;
    line-height: 1.45;
}
.lq-agent-license {
    color: rgba(248,250,252,0.56);
    font-size: .74rem;
    font-weight: 700;
    line-height: 1.35;
    margin-top: 8px;
}
.lq-error, .lq-success {
    font-weight: 800;
    margin-top: 10px;
    display: none;
}
.lq-error { color: #fca5a5; }
.lq-success { color: #bbf7d0; }

/* ── Mobile / tablet tightening (≤640px) ─────────────────────────────────── */
@@media (max-width: 640px){
    .lq-container { padding: 4px 12px 14px; }
    .lq-header h1 { font-size: 1.32rem; line-height: 1.18; margin-bottom: 3px; }
    .lq-subtext { font-size: .88rem; line-height: 1.32; margin-bottom: 6px; }
    .lq-progress-rail { gap: 8px; }
    .lq-pill-step { padding: 10px; }
    .lq-human-strip {
        gap: 8px;
        margin: 7px auto 8px;
        padding: 7px 8px;
        border-radius: 11px;
    }
    .lq-human-strip-avatar {
        width: 36px;
        height: 36px;
    }
    .lq-human-strip-name { font-size: .79rem; }
    .lq-human-strip-role { font-size: .66rem; }
    .lq-human-strip-note { font-size: .72rem; }

    /* Hero shell — reclaim vertical space */
    .lq-hero-shell {
        padding: 10px 10px 8px;
        margin: 4px auto 10px;
        border-radius: 14px;
    }

    /* Hero header block */
    .lq-header { margin-top: 6px; margin-bottom: 7px; }

    /* Step panels */
    .lq-step-panel { margin-bottom: 10px; }
    .lq-step-panel-pad { padding: 10px; }
    .lq-inner-block { padding: 14px 12px 10px; }
    .lq-step-title { font-size: 1.02rem; margin-bottom: 4px; }
    .lq-step-helper { margin-bottom: 8px; font-size: .88rem; line-height: 1.32; }
    .lq-step-question {
        font-size: 1.16rem;
        margin-bottom: 7px;
    }
    .lq-step-kicker {
        font-size: .76rem;
        margin-bottom: 5px;
    }
    .lq-step-progress-wrap { gap: 7px; margin-bottom: 10px; }
    .lq-step-progress { font-size: .71rem; padding: 3px 8px; }
    .lq-step-progress-track { height: 5px; }
    .lq-card { min-height: 56px; padding: 12px 10px; font-size: .9rem; }
    .lq-card-rich {
        min-height: 122px;
        gap: 8px;
        padding: 12px 10px;
    }
    .lq-card-rich:has(.lq-card-kicker:empty):has(.lq-card-helper:empty) {
        min-height: 84px;
    }
    .lq-card-rich .lq-card-visual {
        width: 46px;
        height: 46px;
    }
    .lq-card-rich .lq-card-icon {
        width: 25px;
        height: 25px;
    }
    .lq-card-rich .lq-card-title { font-size: .94rem; }
    .lq-card-rich .lq-card-helper { font-size: .73rem; }
    .lq-card-rich.no-visual:has(.lq-card-kicker:empty):has(.lq-card-helper:empty) {
        min-height: 68px;
    }
    .lq-choice-grid.lq-step1-twoup .lq-card { min-height: 58px; }
    .lq-choice-grid { gap: 8px; }
    .lq-age-picker {
        gap: 12px;
        padding: 14px 14px 12px;
        border-radius: 14px;
    }
    .lq-age-picker-top {
        flex-direction: column;
        align-items: stretch;
    }
    .lq-age-pill {
        min-width: 0;
        width: 100%;
        font-size: 1.08rem;
    }
    .lq-age-quick-grid { gap: 7px; }
    .lq-age-quick-btn {
        flex: 1 1 calc(50% - 7px);
        justify-content: center;
        text-align: center;
    }
    .lq-age-picker-note { font-size: .84rem; }
    .lq-age-scale { font-size: .68rem; }
    .lq-step-actions { margin-top: 10px; }
    .lq-step-actions.dual { align-items: stretch; gap: 8px; }
    .lq-step-actions.dual .btn-ghost { min-height: 44px; padding: 9px 12px; }
    .lq-step-actions.dual .btn-gold { min-height: 56px; }
    .lq-processing-bridge { margin: 10px 0 6px; }
    .lq-value-list { gap: 8px; margin: 4px 0 10px; }
    .lq-value-item { font-size: .86rem; padding: 9px 10px; }
    .lq-value-note { font-size: .82rem; margin-bottom: 2px; }

    /* Contact step fields */
    .lq-contact-grid { gap: 8px; }
    .lq-field-row { gap: 10px; }
    .lq-field { gap: 4px; }
    .lq-field label { font-size: .85rem; }
    .lq-field-help { font-size: .76rem; margin-top: -1px; }
    .lq-agent-handoff { gap: 10px; margin-bottom: 10px; padding: 12px; }
    .lq-agent-identity { min-width: 84px; gap: 7px; }
    .lq-agent-avatar { width: 60px; height: 60px; }
    .lq-agent-name { font-size: 1rem; }
    .lq-agent-display-name { font-size: .75rem; }
    .lq-agent-bio { font-size: .86rem; }
    .lq-agent-license { font-size: .7rem; margin-top: 7px; }
    .form-control, .form-select { padding: 8px 10px; margin-bottom: 4px; }
    .lq-reach-note { font-size: .84rem; margin-bottom: 7px; }
    .lq-submit-row { margin-top: 8px; }
    .btn-gold { padding: 13px 18px; }
}

