                    "1000000" => ("none", string.Empty, "Expanded planning room", "Creates more room for a protection strategy that balances long-term coverage, flexibility, and legacy goals.", "tone-coverage"),
                    "2000000" => ("none", string.Empty, "Legacy-focused structure", "Designed for people considering a larger long-range protection plan tied to future planning and family legacy.", "tone-coverage"),
