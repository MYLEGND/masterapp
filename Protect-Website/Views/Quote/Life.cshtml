



@{
    ViewData["SeoTitle"] = "Personalized Life Insurance Review";
    ViewData["SeoDescription"] = "Compare life insurance options based on your family, budget, goals, age, and coverage needs. Start your personalized protection review.";
}

@using System.Text.Json
@using Shared.Analytics
@model Protect_Website.Models.LifeWizardViewModel
@inject Microsoft.Extensions.Options.IOptionsSnapshot<ProtectWebsite.Services.MetaSignal.MetaSignalIntelligenceOptions> MetaSignalOptionsAccessor

@{
    var cfg = Model.Config;
    var form = Model.Form;
    var pageKey = string.IsNullOrWhiteSpace(Model.EffectivePageKey) ? cfg.PageKey : Model.EffectivePageKey;
    var requestPath = Context?.Request?.Path.Value ?? string.Empty;
    var isLandingPage = Model.IsLandingPage;
    var isLandingRoutePath = requestPath.Contains("/landing", StringComparison.OrdinalIgnoreCase);
    const string contactFirstEducationVariant = "contact_first_education_v1";
    const string lowFrictionOptionsVariant = "low_friction_options_v1";
    var pageVariant = string.IsNullOrWhiteSpace(Model.PageVariant)
        ? ((isLandingPage || isLandingRoutePath) ? contactFirstEducationVariant : "website")
        : Model.PageVariant;
    var isContactFirstEducationVariant = string.Equals(pageVariant, contactFirstEducationVariant, StringComparison.OrdinalIgnoreCase);
    var isLowFrictionOptionsVariant = string.Equals(pageVariant, lowFrictionOptionsVariant, StringComparison.OrdinalIgnoreCase);
    var usesContactFirstShell = isContactFirstEducationVariant || isLowFrictionOptionsVariant;
    var isLandingView = isLandingPage || isLandingRoutePath || usesContactFirstShell;
    var offerBodyClass = $"life-offer-{cfg.OfferKey?.ToLowerInvariant()}";
    var pageMode = string.IsNullOrWhiteSpace(Model.PageMode) ? ((isLandingPage || isLandingRoutePath) ? "paid_landing" : "site_mode") : Model.PageMode;
    var isPaidLandingExperience = string.Equals(pageMode, "paid_landing", StringComparison.OrdinalIgnoreCase);
    var isStandaloneLandingExperience = isLandingPage || isLandingRoutePath || isPaidLandingExperience;
    var tracksContactFirstFlow = usesContactFirstShell;
    var normalizedOfferKey = cfg.OfferKey?.Trim().ToLowerInvariant() ?? string.Empty;
    ViewData["Title"] = cfg.PageTitle;
    ViewData["PageKey"] = pageKey;
    ViewData["IsLandingPage"] = isStandaloneLandingExperience;
    ViewData["PageVariant"] = pageVariant;
    ViewData["PageMode"] = pageMode;
    ViewData["PageCategory"] = "quote";
    ViewData["QuoteTypeForTracking"] = cfg.OfferKey;
    ViewData["BodyClass"] = isLandingView ? $"life-landing {offerBodyClass}" : offerBodyClass;
    // Shared discovery intake for all life product types.
    IReadOnlyList<Protect_Website.Models.LifeWizardStep> viewSteps = (cfg.Steps?.Take(5).ToList() ?? new List<Protect_Website.Models.LifeWizardStep>());
    if (viewSteps.Count < 5)
    {
        var fallbackProtectOptions = normalizedOfferKey switch
        {
            "finalexpense" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","Spouse / partner"),
                new("children","Children / grandkids"),
                new("family","Loved ones"),
                new("other","Someone else"),
            },
            "mortgage" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","Spouse / partner"),
                new("children","Children"),
                new("family","Household"),
                new("just_me","Just me"),
                new("other","Someone else"),
            },
            "wholelife" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","Spouse / partner"),
                new("children","Children"),
                new("family","Family / legacy"),
                new("other","Someone else"),
            },
            "iul" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","Spouse / partner"),
                new("children","Children"),
                new("family","Family / legacy"),
                new("other","Someone else"),
            },
            _ => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","Spouse / partner"),
                new("children","Children"),
                new("family","Family"),
                new("other","Someone else"),
            }
        };

        var fallbackGoalOptions = normalizedOfferKey switch
        {
            "term" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("replace_income","Replace income"),
                new("mortgage_or_bills","Mortgage / bills"),
                new("protect_term_years","Protect key years"),
                new("keep_costs_affordable","Keep it affordable"),
            },
            "wholelife" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("lifelong_protection","Lifetime protection"),
                new("cash_value_growth","Long-term flexibility"),
                new("leave_legacy","Leave support behind"),
                new("final_expenses","Final expenses"),
            },
            "finalexpense" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("burial_costs","Funeral costs"),
                new("final_bills","Final bills"),
                new("ease_family_burden","Ease the burden"),
                new("leave_small_benefit","Leave a cushion"),
            },
            "mortgage" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("mortgage_balance","Mortgage balance"),
                new("monthly_payment","Monthly payment"),
                new("stay_in_home","Keep the home"),
                new("household_bills","Household bills"),
            },
            "iul" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("cash_value_growth","Long-term flexibility"),
                new("lifelong_protection","Keep protection in place for the long term"),
                new("future_access","Future flexibility"),
                new("leave_legacy","Leave lasting support for my family"),
            },
            _ => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("replace_income","Replace income"),
                new("final_expenses","Help protect loved ones from final expenses"),
                new("mortgage_or_bills","Mortgage / bills"),
                new("leave_something","Leave lasting support behind"),
            }
        };

        var fallbackCoverageOptions = normalizedOfferKey switch
        {
            "finalexpense" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("25000","$25,000"),
                new("50000","$50,000"),
                new("75000","$75,000"),
                new("100000","$100,000"),
            },
            "wholelife" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("50000","$50,000"),
                new("100000","$100,000"),
                new("250000","$250,000"),
                new("500000","$500,000"),
            },
            "term" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("1000000","$1,000,000"),
                new("2000000","$2,000,000+"),
            },
            "mortgage" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("150000","$150,000"),
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("750000","$750,000+"),
            },
            "iul" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("1000000","$1,000,000"),
                new("2000000","$2,000,000+"),
            },
