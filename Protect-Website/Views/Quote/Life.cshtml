                new("non_smoker","Non-smoker"),
                new("smoker","Smoker"),
            }, "TobaccoUse"),
        };
    }
    var isMortgageOffer = string.Equals(normalizedOfferKey, "mortgage", StringComparison.OrdinalIgnoreCase);
    var usesGoalFirstDiscovery = true;
    var usesAgeBeforeTobaccoFlow = true;
    Protect_Website.Models.LifeWizardStep ResolveStep(string fieldAlias, int fallbackIndex)
    {
        return viewSteps.FirstOrDefault(step => string.Equals(step.FieldAlias, fieldAlias, StringComparison.OrdinalIgnoreCase))
            ?? viewSteps.ElementAtOrDefault(fallbackIndex)
            ?? new Protect_Website.Models.LifeWizardStep(string.Empty, new List<Protect_Website.Models.LifeWizardOption>(), fieldAlias);
    }
    var protectStep = ResolveStep("ProtectingWho", 1);
    var goalStep = ResolveStep("CoverageGoal", 0);
    var coverageAmountStep = ResolveStep("CoverageAmountOption", 2);
    var tobaccoStep = ResolveStep("TobaccoUse", 4);
    var firstDiscoveryStep = usesGoalFirstDiscovery ? goalStep : protectStep;
    var secondDiscoveryStep = usesGoalFirstDiscovery ? protectStep : goalStep;
    var firstDiscoveryFieldName = usesGoalFirstDiscovery ? "CoverageGoal" : "ProtectingWho";
    var secondDiscoveryFieldName = usesGoalFirstDiscovery ? "ProtectingWho" : "CoverageGoal";
    var firstDiscoveryQuestionId = usesGoalFirstDiscovery ? "lbl-step1-goal" : "lbl-step1-protect";
    var secondDiscoveryQuestionId = usesGoalFirstDiscovery ? "lbl-step1-protect" : "lbl-step1-goal";
    var coverageAmountQuestionText = coverageAmountStep.Question;
    var protectingWhoErrorText = isMortgageOffer ? "Please choose who depends on the home." : "Please choose who you want to protect.";
    var coverageGoalErrorText = isMortgageOffer ? "Please choose what you'd want protected." : "Please select what matters most right now.";
    var coverageAmountErrorText = isMortgageOffer ? "Please choose an approximate mortgage balance." : "Please choose a coverage amount to explore.";
    var showCarrierDisclosure = isLandingView;
    var ageStepOptions = string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase)
        ? new List<(string Value, string Label, int ApproxAge, bool IsWide)>
        {
            ("45-54", "45-54", 50, false),
            ("55-64", "55-64", 60, false),
            ("65-74", "65-74", 70, false),
            ("75+", "75+", 78, false),
        }
        : new List<(string Value, string Label, int ApproxAge, bool IsWide)>
        {
            ("18-24", "18-24", 21, false),
            ("25-34", "25-34", 30, false),
            ("35-44", "35-44", 40, false),
            ("45-54", "45-54", 50, false),
            ("55+", "55+", 60, true),
        };
    var ageRangeToNumericJson = JsonSerializer.Serialize(ageStepOptions.ToDictionary(option => option.Value, option => option.ApproxAge));
    var ageStepQuestionText = "Your age";
    (string VisualMode, string VisualValue, string Kicker, string Helper, string ToneClass) GetChoiceCardMeta(string fieldName, string optionCode)
    {
        var normalizedField = (fieldName ?? string.Empty).Trim();
        var normalizedCode = (optionCode ?? string.Empty).Trim().ToLowerInvariant();

        (string VisualMode, string VisualValue, string Kicker, string Helper, string ToneClass) baseChoiceMeta = normalizedField switch
        {
            "ProtectingWho" => normalizedCode switch
            {
                "spouse_or_partner" => ("icon", "choice-icon-partner", "Partner", "Protect the person closest to your day-to-day financial life", "tone-protect"),
                "children" => ("icon", "choice-icon-children", string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase) ? "Family next generation" : "Children", string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase) ? "Help shield children or grandchildren from carrying the burden alone" : "Protect the people counting on you most", "tone-protect"),
                "family" => ("icon", "choice-icon-family", normalizedOfferKey switch
                    {
                        "mortgage" => "Household",
                        "finalexpense" => "Loved ones",
                        _ => "Household"
                    },
                    normalizedOfferKey switch
                    {
                        "mortgage" => "Protect the people and home life that depend on your monthly stability",
                        "wholelife" => "Protect the people you love while keeping legacy goals in view",
                        "iul" => "Protect the people you love while thinking longer term about legacy",
                        "finalexpense" => "Ease the emotional and financial burden on the people closest to you",
                        _ => "Cover the people who depend on your support"
                    },
                    "tone-protect"),
                "just_me" => ("icon", "choice-icon-home", "Just me", "Keep the focus on protecting the home and monthly stability you depend on.", "tone-protect"),
                _ => ("icon", "choice-icon-family", string.Empty, string.Empty, "tone-protect")
            },
            "CoverageGoal" => normalizedCode switch
            {
                "replace_income" => ("icon", "choice-icon-income", "Family stability", "Help your family stay financially steady if your income suddenly disappeared.", "tone-goal"),
                "final_expenses" => ("icon", "choice-icon-heart", "Peace of mind", "Help loved ones avoid carrying funeral costs, final bills, and added pressure alone.", "tone-goal"),
                "mortgage_or_bills" => ("icon", "choice-icon-home", "Monthly stability", "Help protect the mortgage and the everyday bills your family would still face.", "tone-goal"),
                "leave_something" => ("icon", "choice-icon-legacy", "Family support", "Leave behind something meaningful that helps your family stay grounded.", "tone-goal"),
                "protect_term_years" => ("icon", "choice-icon-income", "Critical years", "Built for the years your family depends on your income, your stability, and your presence the most.", "tone-goal"),
                "keep_costs_affordable" => ("icon", "choice-icon-income", "Practical fit", "Start with meaningful protection that still needs to fit your real monthly budget.", "tone-goal"),
                "lifelong_protection" => ("icon", "choice-icon-legacy", "Lifetime stability", "Create protection designed to stay in place instead of expiring later.", "tone-goal"),
                "cash_value_growth" => ("icon", "choice-icon-income", "Long-term protection", "Explore protection designed to stay with you and support future flexibility over time.", "tone-goal"),
                "leave_legacy" => ("icon", "choice-icon-legacy", "Legacy", "Keep the focus on what you want to leave behind for the people you love", "tone-goal"),
                "burial_costs" => ("icon", "choice-icon-heart", "Funeral costs", "Help your loved ones avoid carrying funeral and burial costs during an already difficult time.", "tone-goal"),
                "final_bills" => ("icon", "choice-icon-heart", "Family relief", "Help cover funeral costs, medical bills, and the unexpected expenses families are often left handling alone.", "tone-goal"),
                "ease_family_burden" => ("icon", "choice-icon-heart", "Ease the burden", "Help your loved ones avoid financial pressure on top of emotional loss.", "tone-goal"),
                "leave_small_benefit" => ("icon", "choice-icon-legacy", "Family relief", "Create a layer of protection designed to help your family handle final expenses without scrambling financially.", "tone-goal"),
                "mortgage_balance" => ("icon", "choice-icon-home", "Protect the home", "Help protect the home and monthly stability your family depends on.", "tone-goal"),
                "monthly_payment" => ("icon", "choice-icon-home", "Monthly breathing room", "Help keep the house payment from becoming a crisis for the people staying in the home.", "tone-goal"),
                "stay_in_home" => ("icon", "choice-icon-home", "Keep the home", "Help your family stay in the home they know and love if something happened to you unexpectedly.", "tone-goal"),
                "household_bills" => ("icon", "choice-icon-home", "Home stability", "Help protect the home and the bills that keep daily life steady.", "tone-goal"),
                "future_access" => ("icon", "choice-icon-income", "Long-range flexibility", "Explore long-term protection designed to provide flexibility and future access over time.", "tone-goal"),
                _ => ("icon", "choice-icon-legacy", string.Empty, string.Empty, "tone-goal")
            },
            "CoverageAmountOption" => normalizedOfferKey switch
            {
                "finalexpense" => normalizedCode switch
                {
                    "25000" => ("none", string.Empty, "Immediate relief", "A focused layer of protection to help loved ones with funeral costs and the first wave of final expenses.", "tone-coverage"),
                    "50000" => ("none", string.Empty, "Family buffer", "A stronger starting point for families who may need help with funeral costs, final bills, and financial breathing room.", "tone-coverage"),
                    "75000" => ("none", string.Empty, "Added breathing room", "Creates more room for your family to handle final expenses without scrambling financially.", "tone-coverage"),
                    "100000" => ("none", string.Empty, "Stronger family protection", "Designed for households that want a larger cushion around funeral costs, final bills, and family stress.", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                },
                "wholelife" => normalizedCode switch
                {
                    "50000" => ("none", string.Empty, "Foundation", "A starting point for people who want lifelong protection that stays with them and helps cover lasting family needs.", "tone-coverage"),
                    "100000" => ("none", string.Empty, "Lifetime fit", "A starting point built for people who want lifelong protection that stays in place instead of expiring later.", "tone-coverage"),
                    "250000" => ("none", string.Empty, "Lasting security", "Adds more room for long-term protection when lifelong stability matters to you and the people you love.", "tone-coverage"),
                    "500000" => ("none", string.Empty, "Long-term anchor", "Designed for people who want a stronger layer of permanent protection that can stay in place through every stage of life.", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                },
                "term" => normalizedCode switch
                {
                    "250000" => ("none", string.Empty, "Focused support", "A practical layer of protection when the goal is covering a meaningful income gap or key monthly bills.", "tone-coverage"),
                    "500000" => ("none", string.Empty, "Family stability", "A practical layer of protection designed to help your family stay financially stable if your income suddenly disappeared.", "tone-coverage"),
                    "1000000" => ("none", string.Empty, "Deeper cushion", "Creates more room to protect income, major bills, and the years your family relies on you most.", "tone-coverage"),
                    "2000000" => ("none", string.Empty, "Broad protection", "Built for households that want a larger safety net around income, debt, and long-term family stability.", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                },
                "mortgage" => normalizedCode switch
                {
                    "150000" => ("none", string.Empty, "Home cushion", "A focused amount when the goal is helping protect the home and preserve monthly breathing room.", "tone-coverage"),
                    "250000" => ("none", string.Empty, "Home stability", "A practical starting point for families who want help keeping the home and the budget from unraveling.", "tone-coverage"),
                    "500000" => ("none", string.Empty, "Stronger protection", "Adds more protection for households carrying a bigger mortgage or tighter monthly obligations.", "tone-coverage"),
                    "750000" => ("none", string.Empty, "Larger home safeguard", "Built for families who want a larger layer of protection around the home, the payment, and overall household stability.", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                },
                "iul" => normalizedCode switch
                {
                    "250000" => ("none", string.Empty, "Long-range foundation", "A starting point for people thinking long-term about protection, flexibility, and future planning.", "tone-coverage"),
                    "500000" => ("none", string.Empty, "Flexible protection", "Built for people who want long-term protection with room for future flexibility over time.", "tone-coverage"),
                    "1000000" => ("none", string.Empty, "Expanded planning room", "Creates more room for a protection strategy that balances long-term coverage, flexibility, and legacy goals.", "tone-coverage"),
                    "2000000" => ("none", string.Empty, "Legacy-focused structure", "Designed for people considering a larger long-range protection plan tied to future planning and family legacy.", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                },
                _ => normalizedCode switch
                {
                    "100000" => ("none", string.Empty, "Starting point", "A focused first layer of protection when you want to begin with something practical and clear.", "tone-coverage"),
                    "250000" => ("none", string.Empty, "Family fit", "A balanced starting point for households looking for meaningful protection without overcomplicating the decision.", "tone-coverage"),
                    "500000" => ("none", string.Empty, "Stronger support", "Often where families start when the goal is real protection around income, bills, and stability.", "tone-coverage"),
                    "1000000" => ("none", string.Empty, "Larger safety net", "A bigger protection range for households trying to cover a wider financial gap.", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                }
            },
            "TobaccoUse" => normalizedCode switch
            {
                "non_smoker" => ("icon", "choice-icon-leaf", "Lower-risk profile", "Estimate built around non-tobacco pricing", "tone-health"),
                "smoker" => ("icon", "choice-icon-smoke", "Tobacco use", "Estimate adjusted for tobacco-related pricing", "tone-health"),
                _ => ("icon", "choice-icon-leaf", string.Empty, string.Empty, "tone-health")
            },
            "AgeBracket" => normalizedCode switch
            {
                "18-24" => ("none", string.Empty, "Starting out", "Early-rate years with more room to explore options", "tone-age"),
                "25-34" => ("none", string.Empty, "Building years", "Often the stretch where family and income protection grows", "tone-age"),
                "35-44" => ("none", string.Empty, "Peak protection", "A common window for heavier family and bill responsibility", "tone-age"),
                "45-54" when string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase)
                    => ("none", string.Empty, "Early peace of mind", "A common window for putting final expense protection in place before it feels urgent.", "tone-age"),
                "45-54" => ("none", string.Empty, "Established years", "Often focused on income protection and long-range stability", "tone-age"),
                "55-64" => ("none", string.Empty, "Protection planning", "Often a strong window for putting family relief and final wishes in place.", "tone-age"),
                "65-74" => ("none", string.Empty, "Family relief focus", "Often centered on keeping loved ones from carrying funeral costs and final expenses alone.", "tone-age"),
                "75+" => ("none", string.Empty, "Peace-of-mind planning", "Focused on helping loved ones avoid financial pressure during an already difficult time.", "tone-age"),
                "55+" => ("none", string.Empty, "Long-range planning", "Later-career years where lasting fit matters more", "tone-age"),
                _ => ("none", string.Empty, string.Empty, string.Empty, "tone-age")
            },
            _ => ("icon", "choice-icon-family", string.Empty, string.Empty, string.Empty)
        };

        var compactKicker = baseChoiceMeta.Kicker;
        if (string.Equals(normalizedField, "CoverageGoal", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(normalizedField, "CoverageAmountOption", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(normalizedField, "AgeBracket", StringComparison.OrdinalIgnoreCase))
        {
            compactKicker = string.Empty;
        }

        return (baseChoiceMeta.VisualMode, baseChoiceMeta.VisualValue, compactKicker, string.Empty, baseChoiceMeta.ToneClass);
    }
    var selectedCoverageAmountOption = !string.IsNullOrWhiteSpace(form.CoverageAmountOption)
        ? form.CoverageAmountOption.Trim()
        : (form.CoverageAmount.HasValue ? form.CoverageAmount.Value.ToString() : string.Empty);
    bool IsStepOptionChecked(string fieldName, string optionCode)
    {
        var normalizedFieldName = (fieldName ?? string.Empty).Trim();
        return normalizedFieldName switch
        {
            "ProtectingWho" =>
                string.Equals(form.ProtectingWho, optionCode, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(form.Answer1, optionCode, StringComparison.OrdinalIgnoreCase),
            "CoverageGoal" =>
                string.Equals(form.CoverageGoal, optionCode, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(form.Answer2, optionCode, StringComparison.OrdinalIgnoreCase),
            "CoverageAmountOption" =>
                string.Equals(form.CoverageAmountOption, optionCode, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(selectedCoverageAmountOption, optionCode, StringComparison.OrdinalIgnoreCase),
            "TobaccoUse" =>
                string.Equals(form.TobaccoUse, optionCode, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(form.Answer3, optionCode, StringComparison.OrdinalIgnoreCase),
            _ => false
        };
    }
    var isFinalExpenseOffer = string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase);
    var selectedAgeBracket = string.Empty;
    var ageValueNumber = form.Age;
    if (!string.IsNullOrWhiteSpace(form.AgeRange) && (form.AgeRange.Contains('-') || form.AgeRange.Contains('+')))
    {
        selectedAgeBracket = form.AgeRange.Trim();
    }
    if (string.IsNullOrWhiteSpace(selectedAgeBracket) && !string.IsNullOrWhiteSpace(form.Answer4) && (form.Answer4.Contains('-') || form.Answer4.Contains('+')))
    {
        selectedAgeBracket = form.Answer4.Trim();
    }
    if (!ageValueNumber.HasValue && int.TryParse(form.Answer4, out var parsedAnswerAge))
    {
        ageValueNumber = parsedAnswerAge;
    }
    if (!ageValueNumber.HasValue && int.TryParse(form.AgeRange, out var parsedRangeAge))
    {
        ageValueNumber = parsedRangeAge;
    }
    if (string.IsNullOrWhiteSpace(selectedAgeBracket) && ageValueNumber.HasValue)
    {
        var ageNumber = ageValueNumber.Value;
        if (isFinalExpenseOffer)
        {
            if (ageNumber <= 54) selectedAgeBracket = "45-54";
