/* ── Mobile / tablet tightening (≤640px) ─────────────────────────────────── */
@@media (max-width: 640px){
    .lq-container { padding: 4px 12px 14px; }
    .lq-header h1 { font-size: 1.32rem; line-height: 1.18; margin-bottom: 3px; }
    .lq-subtext { font-size: .88rem; line-height: 1.32; margin-bottom: 6px; }
    .lq-progress-rail { gap: 8px; }
    .lq-pill-step { padding: 10px; }
    .lq-human-strip {
        gap: 8px;
        margin: 7px auto 8px;
        padding: 7px 8px;
        border-radius: 11px;
    }
    .lq-human-strip-avatar {
        width: 36px;
        height: 36px;
    }
    .lq-human-strip-name { font-size: .79rem; }
    .lq-human-strip-role { font-size: .66rem; }
    .lq-human-strip-note { font-size: .72rem; }

    /* Hero shell — reclaim vertical space */
    .lq-hero-shell {
        padding: 10px 10px 8px;
        margin: 4px auto 10px;
        border-radius: 14px;
    }

    /* Hero header block */
    .lq-header { margin-top: 6px; margin-bottom: 7px; }

    /* Step panels */
    .lq-step-panel { margin-bottom: 10px; }
    .lq-step-panel-pad { padding: 10px; }
    .lq-inner-block { padding: 14px 12px 10px; }
    .lq-step-title { font-size: 1.02rem; margin-bottom: 4px; }
    .lq-step-helper { margin-bottom: 8px; font-size: .88rem; line-height: 1.32; }
    .lq-step-question {
        font-size: 1.16rem;
        margin-bottom: 7px;
    }
    .lq-step-kicker {
        font-size: .76rem;
        margin-bottom: 5px;
    }
    .lq-step-progress-wrap { gap: 7px; margin-bottom: 10px; }
    .lq-step-progress { font-size: .71rem; padding: 3px 8px; }
    .lq-step-progress-track { height: 5px; }
    .lq-card { min-height: 56px; padding: 12px 10px; font-size: .9rem; }
    .lq-card-rich {
        min-height: 122px;
        gap: 8px;
        padding: 12px 10px;
    }
    .lq-card-rich:has(.lq-card-kicker:empty):has(.lq-card-helper:empty) {
        min-height: 84px;
    }
    .lq-card-rich .lq-card-visual {
        width: 46px;
        height: 46px;
    }
    .lq-card-rich .lq-card-icon {
        width: 25px;
        height: 25px;
    }
    .lq-card-rich .lq-card-title { font-size: .94rem; }
    .lq-card-rich .lq-card-helper { font-size: .73rem; }
    .lq-card-rich.no-visual:has(.lq-card-kicker:empty):has(.lq-card-helper:empty) {
        min-height: 68px;
    }
    .lq-choice-grid.lq-step1-twoup .lq-card { min-height: 58px; }
    .lq-choice-grid { gap: 8px; }
    .lq-age-picker {
        gap: 12px;
        padding: 14px 14px 12px;
        border-radius: 14px;
    }
    .lq-age-picker-top {
        flex-direction: column;
        align-items: stretch;
    }
    .lq-age-pill {
        min-width: 0;
        width: 100%;
        font-size: 1.08rem;
    }
    .lq-age-quick-grid { gap: 7px; }
    .lq-age-quick-btn {
        flex: 1 1 calc(50% - 7px);
        justify-content: center;
        text-align: center;
    }
    .lq-age-picker-note { font-size: .84rem; }
    .lq-age-scale { font-size: .68rem; }
    .lq-step-actions { margin-top: 10px; }
    .lq-step-actions.dual { align-items: stretch; gap: 8px; }
    .lq-step-actions.dual .btn-ghost { min-height: 44px; padding: 9px 12px; }
    .lq-step-actions.dual .btn-gold { min-height: 56px; }
    .lq-processing-bridge { margin: 10px 0 6px; }
    .lq-value-list { gap: 8px; margin: 4px 0 10px; }
    .lq-value-item { font-size: .86rem; padding: 9px 10px; }
    .lq-value-note { font-size: .82rem; margin-bottom: 2px; }

    /* Contact step fields */
    .lq-contact-grid { gap: 8px; }
    .lq-field-row { gap: 10px; }
    .lq-field { gap: 4px; }
    .lq-field label { font-size: .85rem; }
    .lq-field-help { font-size: .76rem; margin-top: -1px; }
    .lq-agent-handoff { gap: 10px; margin-bottom: 10px; padding: 12px; }
    .lq-agent-identity { min-width: 84px; gap: 7px; }
    .lq-agent-avatar { width: 60px; height: 60px; }
    .lq-agent-name { font-size: 1rem; }
    .lq-agent-display-name { font-size: .75rem; }
    .lq-agent-bio { font-size: .86rem; }
    .lq-agent-license { font-size: .7rem; margin-top: 7px; }
    .form-control, .form-select { padding: 8px 10px; margin-bottom: 4px; }
    .lq-reach-note { font-size: .84rem; margin-bottom: 7px; }
    .lq-submit-row { margin-top: 8px; }
    .btn-gold { padding: 13px 18px; }
}

/* ── Phone-only tightening (≤480px) ─────────────────────────────────────── */
@@media (max-width: 480px){
