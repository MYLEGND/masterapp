    publicBookingState = null;
    publicBookingEmbedViewed = false;
    publicBookingBookedConfirmed = false;
    publicBookingConfirmationRequested = false;
    publicBookingSlotSelectedTracked = false;
    publicBookingFallbackClicked = false;
    publicBookingAbandonedTracked = false;
    clearPersistedFunnelState();

    if (contactCaptureWrap instanceof HTMLElement) {
      contactCaptureWrap.hidden = true;
    }
    renderStep2EstimateSummary(latestEstimatePreview, { expanded: true });

    await trackThankYouViewOnce({
      inlineExperience: true,
      handoffType: hasAgentTrustProfile ? 'agent' : 'generic'
    });

    renderPostSubmitBookingState({ loading: true });
    focusFunnelPanel(step2Panel, { shouldFocus: true });

    const bookingHint = responseBody && typeof responseBody.booking === 'object'
      ? responseBody.booking
      : null;

    if (!bookingHint?.eligible) {
      renderPostSubmitBookingState(buildDisabledBookingState(asTrimmed(bookingHint?.reason) || 'disabled'));
      return;
    }

    const bookingPayload = await activatePublicBookingExperience(bookingHint);
    renderPostSubmitBookingState(bookingPayload);
  }

  function showProcessingBridge(shouldScroll = true) {
    clearAutoAdvanceTimer();
    clearProcessingTimer(true);
    clearEstimatePreviewCache();
    syncStepOneAnswersFromUI();
    const previewPromise = ensureEstimatePreview(true);
    setActivePanel(processingPanel);
    trackEvent('life_processing_bridge_view');
    animateProcessingNarrative();
    animateProcessingBar();
    if (shouldScroll) {
      focusFunnelPanel(processingPanel, {
        shouldFocus: true
      });
    }
    processingTimer = window.setTimeout(async () => {
      processingTimer = null;
      trackEvent('life_processing_bridge_complete');
      syncStepOneAnswersFromUI();
      try {
        const preview = await previewPromise;
        await showStep2(true, { estimatePreview: preview });
      } catch {
        trackEvent('estimate_results_error', {
          protectingWho: answer1Hidden?.value || '',
          coverageGoal: answer2Hidden?.value || '',
          coverageAmount: coverageAmountHidden?.value || '',
          tobaccoUse: answer3Hidden?.value || '',
          ageRange: ageHidden?.value || ''
        });
        showStep2(true, { trackRecommendationView: false });
      }
    }, PROCESSING_BRIDGE_MS + 80);
