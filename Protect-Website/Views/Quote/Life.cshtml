@model Protect_Website.Models.LifeWizardViewModel

@{
    var cfg = Model.Config;
    var form = Model.Form;
    var pageKey = string.IsNullOrWhiteSpace(Model.EffectivePageKey) ? cfg.PageKey : Model.EffectivePageKey;
    var requestPath = Context?.Request?.Path.Value ?? string.Empty;
    var isLandingPage = Model.IsLandingPage;
    var isLandingRoutePath = requestPath.Contains("/landing", StringComparison.OrdinalIgnoreCase);
    var isLandingView = isLandingPage || isLandingRoutePath;
    var offerBodyClass = $"life-offer-{cfg.OfferKey?.ToLowerInvariant()}";
    var pageVariant = string.IsNullOrWhiteSpace(Model.PageVariant) ? (isLandingView ? "landing" : "website") : Model.PageVariant;
    var pageMode = string.IsNullOrWhiteSpace(Model.PageMode) ? (isLandingView ? "paid_landing" : "site_mode") : Model.PageMode;
    ViewData["Title"] = cfg.PageTitle;
    ViewData["PageKey"] = pageKey;
    ViewData["IsLandingPage"] = isLandingView;
    ViewData["PageVariant"] = pageVariant;
    ViewData["PageMode"] = pageMode;
    ViewData["PageCategory"] = "quote";
    ViewData["QuoteTypeForTracking"] = cfg.OfferKey;
    ViewData["BodyClass"] = isLandingView ? $"life-landing landing-mode {offerBodyClass}" : $"site-mode {offerBodyClass}";
    // Shared two-step intake for all life product types.
    IReadOnlyList<Protect_Website.Models.LifeWizardStep> viewSteps = (cfg.Steps?.Take(4).ToList() ?? new List<Protect_Website.Models.LifeWizardStep>());
    if (viewSteps.Count < 4)
    {
        viewSteps = new List<Protect_Website.Models.LifeWizardStep>
        {
            new("Who are you looking to protect?", new List<Protect_Website.Models.LifeWizardOption>
            {
                new("just_me","Just me"),
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children"),
                new("family","My family"),
                new("not_sure","I’m not sure yet"),
            }, "ProtectingWho"),
            new("What would you like this coverage to help with most?", new List<Protect_Website.Models.LifeWizardOption>
            {
                new("replace_income","Replace income for my family"),
                new("final_expenses","Cover final expenses"),
                new("mortgage_or_bills","Help with mortgage or bills"),
                new("leave_something","Leave something behind"),
                new("not_sure","I’m not sure yet"),
            }, "CoverageGoal"),
            new("Tobacco use", new List<Protect_Website.Models.LifeWizardOption>
            {
                new("non_smoker","Non-smoker"),
                new("smoker","Smoker"),
            }, "TobaccoUse"),
            new("Your age", new List<Protect_Website.Models.LifeWizardOption>(), "Age"),
        };
    }
    var protectStep = viewSteps[0];
    var goalStep = viewSteps[1];
    var tobaccoStep = viewSteps[2];
    var ageStep = viewSteps[3];
    var ageValue = form.Age?.ToString() ?? form.Answer4 ?? form.AgeRange ?? string.Empty;
    var usesLeanContactFields = true;
    var hasContactInput =
        !string.IsNullOrWhiteSpace(form.FirstName) ||
        !string.IsNullOrWhiteSpace(form.LastName) ||
        !string.IsNullOrWhiteSpace(form.Phone) ||
        !string.IsNullOrWhiteSpace(form.Email) ||
        !string.IsNullOrWhiteSpace(form.State);
    var showContactStepByDefault = !ViewData.ModelState.IsValid || hasContactInput;
    var path = requestPath;
    var segs = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
    var agentSlug = (segs.Length >= 2 && segs[0].Equals("a", StringComparison.OrdinalIgnoreCase)) ? segs[1] : string.Empty;
}

<style>
/* ================================================================
   Shared Life Wizard — Mobile-first, micro-step, premium styling
   ================================================================ */
body { background: radial-gradient(120% 140% at 50% 0%, #12203c 0%, #0b1529 40%, #0a1121 100%); color: #f8fafc; }

/* site.css forces background:#fff !important on main, .layout-content, and .container.
   Override on this page so the dark hero shell and body gradient are visible. */
main.layout-content,
.lq-container { background: transparent !important; }

/* Page-scoped nav softening for paid landing */
body.life-landing header .navbar {
    padding: 10px 14px;
    box-shadow: 0 8px 18px rgba(0,0,0,0.22);
    background: #0b1529 !important;
    border-color: rgba(166,128,35,.55) !important;
}
body.life-landing header .nav-links,
body.life-landing header .nav-toggle,
body.life-landing header .header-bottom,
body.life-landing header .header-psalms {
    display: none !important;
}
body.life-landing header .navbar .nav-link {
    background: transparent;
    border-color: rgba(199,153,49,.45);
    color: #f6d27e !important;
    opacity: .78;
    padding: 0.6rem 1.05rem;
}
body.life-landing header .navbar .nav-link:hover,
body.life-landing header .navbar .nav-link:focus {
    opacity: 1;
    color: #fbe4a0 !important;
    background: rgba(199,153,49,0.08);
}

.lq-container{
    padding: 8px 16px 20px;
}

.lq-hero-shell{
    /* Cinematic outer shell: deep navy base + very subtle warm gold breath at the crown.
       Gives the ad-matched "premium dark" atmosphere without a flat slab look. */
    background:
        radial-gradient(ellipse 90% 38% at 50% 0%, rgba(199,153,49,0.07) 0%, transparent 68%),
        linear-gradient(180deg, #080e1e 0%, #0b1528 50%, #090e1c 100%);
    border: 1.5px solid rgba(199,153,49,.44);
    border-radius: 18px;
    /* Deeper drop-shadow + 1px inner top edge for glass/depth cue */
    box-shadow:
        0 32px 60px rgba(0,0,0,0.42),
        inset 0 1px 0 rgba(199,153,49,0.09);
    padding: 18px 18px 14px 18px;
    max-width: 980px;
    margin: 14px auto 18px auto;
}

.form-control,
.form-select {
    border: 1.6px solid #c79931;
    margin-bottom: 10px;
    background: #ffffff;
    color: #0f172a;
    font-size: 0.95rem;
    padding: 10px 12px;
    border-radius: 8px;
}
.form-control::placeholder { color: rgba(15,23,42,0.55); }
.form-control:focus,
.form-select:focus {
    outline: none;
    box-shadow: 0 0 0 0.2rem rgba(199,153,49,0.22);
    border-color: #c79931;
    background: #ffffff;
    color: #0f172a;
}

.btn-gold {
    background: linear-gradient(175deg, #efc86f, #c08b21);
    color: #1c1303;
    font-weight: 900;
    padding: 13px 24px;
    border-radius: 12px;
    font-size: 1.02rem;
    border: 2px solid #f1cf80;
    box-shadow:
        0 14px 32px rgba(0,0,0,0.28),
        0 0 0 2px rgba(241,207,128,0.26);
    transition: opacity 0.15s, transform 0.12s, box-shadow .15s ease, filter .15s ease;
    text-transform: uppercase;
    letter-spacing: .35px;
    cursor: pointer;
    min-height: 52px;
    text-shadow: 0 1px 0 rgba(255,255,255,0.2);
}
.btn-gold:hover {
    opacity: 0.98;
    color: #1c1303;
    transform: translateY(-1px);
    box-shadow:
        0 18px 40px rgba(0,0,0,.32),
        0 0 0 2px rgba(241,207,128,0.34);
    filter: saturate(1.05);
}
.btn-gold:active {
    transform: translateY(0);
    box-shadow:
        0 8px 20px rgba(0,0,0,.30),
        0 0 0 2px rgba(241,207,128,0.28);
}
.btn-gold:focus-visible {
    outline: 3px solid rgba(248,227,170,0.95);
    outline-offset: 2px;
}
.text-gold { color: #c79931; }

.btn-ghost {
    border: 1px solid rgba(199,153,49,0.55);
    background: transparent;
    color: #f8fafc;
    padding: 10px 14px;
    border-radius: 10px;
    font-weight: 850;
    transition: border-color .12s ease, color .12s ease, transform .12s ease, box-shadow .12s ease;
}
.btn-ghost:hover { border-color: #c79931; color: #dfb75a; transform: translateY(-1px); box-shadow: 0 8px 18px rgba(0,0,0,0.18); }
.btn-ghost:focus-visible { outline: 2px solid #dfb75a; outline-offset: 2px; }

.lq-header { margin-top: 18px; margin-bottom: 20px; text-align: center; }
.lq-header h1 {
    font-weight: 900;
    font-size: 2rem;
    color: #a68023;
    letter-spacing: .5px;
    margin-bottom: 6px;
}
.lq-subtext { color: #c79931; font-weight: 700; font-size: 1.05rem; margin-bottom: 12px; }
.lq-cta-note { color: rgba(248,250,252,0.72); font-weight: 800; font-size: .95rem; margin-top: 10px; }
.lq-subtext {
    color: #c79931;
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 16px;
}
.lq-trust-note{
    text-align:center;
    color: rgba(248,250,252,0.7);
    font-weight: 780;
    letter-spacing: .015em;
    font-size: .9rem;
    margin-top: 8px;
}
.lq-trust-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
}
.lq-trust-chip {
    background: #c79931;
    color: #0f172a;
    font-weight: 800;
    border-radius: 10px;
    padding: 6px 12px;
    font-size: .9rem;
}
.lq-helper-intro { color: rgba(248,250,252,0.72); font-size: .96rem; margin-top: 2px; }

.lq-step-meta{ display:none; }

/* Step panels — frame layer sits between outer shell and inner surface */
.lq-step-panel {
    max-width: 760px;
    width: 100%;
    margin: 0 auto 14px auto;
    background: #0c1a30;
    border: 1.5px solid rgba(199,153,49,.44);
    border-radius: 12px;
    box-shadow: 0 20px 44px rgba(0,0,0,0.38);
    animation: lqFadeIn 0.22s ease;
    position: relative;
}
.lq-inner-block {
    /* Primary interaction surface — noticeably lighter than the panel frame
       so the eye reads it immediately as the place to act. */
    background: #1c2f4e;
    border: 1.4px solid rgba(199,153,49,0.60);
    border-radius: 12px;
    padding: 20px 18px 16px 18px;
    /* Subtle elevation: modest drop shadow + 1px gold rim at the top edge */
    box-shadow:
        0 8px 24px rgba(0,0,0,0.26),
        inset 0 1px 0 rgba(199,153,49,0.11);
}
.lq-step-title {
    font-size: 1.2rem;
    font-weight: 900;
    color: #c79931;
    margin-bottom: 6px;
}
.lq-step-helper {
    font-size: .94rem;
    color: rgba(248,250,252,0.7);
    margin-bottom: 16px;
}
.lq-step-panel-pad { padding: 16px; }

@@keyframes lqFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
}

.lq-choice-group { margin-bottom: 8px; }
.lq-choice-label {
    font-weight: 800;
    font-size: 1rem;
    color: #f8fafc;
    margin-bottom: 12px;
}
.lq-choice-grid {
    display: grid;
    gap: 10px;
    grid-template-columns: 1fr;
}
.lq-choice-grid.lq-grid-2 { grid-template-columns: 1fr 1fr; }
.lq-choice-grid.lq-step1-twoup .lq-card {
    min-height: 64px;
    padding: 12px 8px;
}
.lq-choice-grid.lq-step1-twoup .lq-card span {
    overflow-wrap: anywhere;
}
@@media (min-width: 600px) {
    .lq-choice-grid.lq-grid-2 { grid-template-columns: repeat(2, 1fr); }
}
.lq-card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 14px 10px;
    min-height: 58px;
    border: 1.6px solid rgba(199,153,49,0.32);
    border-radius: 10px;
    background: rgba(15,23,42,0.8);
    color: #f8fafc;
    font-weight: 800;
    font-size: .95rem;
    cursor: pointer;
    transition: border-color 0.14s, background 0.14s, box-shadow 0.14s, color 0.14s;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    line-height: 1.25;
    position: relative;
}
.lq-card:hover { border-color: #c79931; background: rgba(199,153,49,0.08); }
.lq-card input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
}
.lq-card.lq-selected,
.lq-card:has(input:checked) {
    border-color: #c79931;
    background: rgba(199,153,49,0.18);
    box-shadow: 0 0 0 2px rgba(199,153,49,0.32);
    color: #c79931;
}
.lq-card.lq-invalid { border-color: #ef4444; }
.lq-choice-error {
    color: #f87171;
    font-size: .82rem;
    margin-top: 4px;
    min-height: 18px;
    display: none;
}
.lq-choice-error.visible { display: block; }

.lq-step-actions { margin-top: 16px; }
.lq-step-actions.dual {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}
.lq-reassurance {
    text-align: center;
    font-size: .84rem;
    color: rgba(248,250,252,0.55);
    margin-top: 6px;
}
.lq-contact-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
}
@@media (min-width: 600px) {
    .lq-contact-grid { grid-template-columns: 1fr 1fr; }
    .lq-contact-grid .full { grid-column: 1 / -1; }
}

.lq-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-weight: 800;
    color: #f8fafc;
}
.lq-consent input { width: 18px; height: 18px; margin-top: 3px; flex-shrink: 0; }
.consent-text { display: flex; flex-direction: column; gap: 3px; }
.consent-main { font-size: .97rem; font-weight: 800; color: #f8fafc; line-height: 1.4; }
.consent-sub  { font-size: .85rem; font-weight: 600; color: rgba(248,250,252,0.62); line-height: 1.4; }
.lq-submit-row { margin-top: 14px; }
.lq-reach-note {
    text-align: center;
    color: rgba(248,250,252,0.82);
    font-size: .92rem;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.4;
}
.lq-field-row{
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
}
@@media (min-width: 720px){
    .lq-field-row.two{ grid-template-columns: repeat(2,1fr); }
}
.lq-field{
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.lq-field label{
    font-weight: 850;
    color: #f8fafc;
    letter-spacing: .01em;
}
.lq-field-help{
    color: rgba(248,250,252,0.68);
    font-size: .8rem;
    font-weight: 700;
    margin-top: -2px;
}
.lq-field-err{
    color: #f87171;
    font-size: .82rem;
    font-weight: 800;
    display: none;
}
.lq-field-err.visible{ display:block; }
.lq-error, .lq-success {
    font-weight: 800;
    margin-top: 10px;
    display: none;
}
.lq-error { color: #fca5a5; }
.lq-success { color: #bbf7d0; }

/* ── Mobile / tablet tightening (≤640px) ─────────────────────────────────── */
