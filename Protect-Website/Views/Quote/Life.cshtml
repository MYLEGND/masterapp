<div class="lq-hero-shell">
<div class="@(isLandingView ? "lq-container" : "container lq-container")">
    <div class="lq-hero-rail" id="lifeHeroEntryPanel" data-funnel-entry-panel="true">
        <div class="lq-header">
            @if (isLowFrictionOptionsVariant)
            {
                <div class="lq-low-friction-hero">
                    <div class="lq-low-friction-hero-kicker">@lowFrictionHeroKicker</div>
                    <h1 class="hero-title">@lowFrictionHeroHeadline</h1>
                    <div class="lq-subtext lq-low-friction-subtext">@lowFrictionHeroSubheadline</div>
                    <div class="lq-low-friction-hero-chips" aria-hidden="true">
                        @foreach (var chip in lowFrictionHeroChips)
                        {
                            <span class="lq-low-friction-hero-chip">@chip</span>
                        }
                    </div>
                    <div class="lq-low-friction-hero-actions">
                        <button type="button" class="btn-gold lq-primary-start-cta lq-low-friction-hero-cta" id="lifeHeroPrimaryCtaMain" data-cta="life_funnel_start" data-life-funnel-start="true" data-primary-cta="hero">@primaryStartCtaText</button>
                        <div class="lq-low-friction-cta-note lq-primary-start-note">
                            <span>A small plan today can protect your family from major financial stress later.</span>
                        </div>
                    </div>
                </div>
            }
            else if (usesContactFirstShell)
            {
                <figure class="lq-hero-banner-wrap">
                    <img class="lq-hero-banner-image" src="@contactFirstBannerImageUrl" asp-append-version="true" alt="@contactFirstBannerAlt" loading="eager" />
                </figure>
                <div class="lq-above-fold-proof" aria-label="Why people start here">
                    <span>
                        <svg class="lq-pill-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="8" r="3.1"></circle>
                            <circle cx="5.6" cy="10" r="2.35"></circle>
                            <circle cx="18.4" cy="10" r="2.35"></circle>
                            <path d="M6.8 19.2c.65-3.15 2.55-5 5.2-5s4.55 1.85 5.2 5"></path>
                            <path d="M1.9 18.6c.45-2.25 1.8-3.55 3.7-3.55 1.05 0 1.95.38 2.65 1.1"></path>
                            <path d="M15.75 16.15c.7-.72 1.6-1.1 2.65-1.1 1.9 0 3.25 1.3 3.7 3.55"></path>
                        </svg>
                        25+ carriers
                    </span>
                    <span>
                        <svg class="lq-pill-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="12" r="8.2"></circle>
                            <path d="M12 7.2v5.15l3.35 2.05"></path>
                        </svg>
                        Protection that fits your life
                    </span>
                    <span>
                        <svg class="lq-pill-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2.8 19.2 5.6v5.55c0 4.55-2.85 8.25-7.2 10.05-4.35-1.8-7.2-5.5-7.2-10.05V5.6L12 2.8Z"></path>
                            <path d="m8.7 12.1 2.15 2.15 4.55-4.8"></path>
                        </svg>
                        No obligation
                    </span>
                </div>
                @if (!string.IsNullOrWhiteSpace(heroStepIntroTitle) || !string.IsNullOrWhiteSpace(heroStepIntroHelper))
                {
                    <div class="lq-hero-step-copy">
                        @if (!string.IsNullOrWhiteSpace(heroStepIntroTitle))
                        {
                            <div class="lq-hero-step-copy-title">@heroStepIntroTitle</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(heroStepIntroHelper))
                        {
