.lq-low-friction-value-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}
.lq-sticky-mobile-cta {
    position: fixed;
    left: 12px;
    right: 12px;
    bottom: max(12px, env(safe-area-inset-bottom));
    z-index: 42;
    display: none;
    opacity: 0;
    transform: translateY(120%);
    pointer-events: none;
    transition: opacity .18s ease, transform .18s ease;
}
.lq-sticky-mobile-cta.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
}
.lq-sticky-mobile-cta-btn {
    width: 100%;
    min-height: 58px;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.34),
        0 18px 30px rgba(0,0,0,.30),
        0 0 0 1px rgba(241,207,128,0.24) !important;
}
body.life-final-step-active .lq-sticky-mobile-cta {
    opacity: 0 !important;
    transform: translateY(120%) !important;
    pointer-events: none !important;
}

@@media (max-width: 767.98px) {
    body.page-variant-low-friction-options-v1.life-landing .lq-hero-shell {
        margin-top: 4px !important;
        padding: 14px 12px 12px !important;
    }

    body.page-variant-low-friction-options-v1.life-landing .lq-header h1 {
        max-width: 13.5ch !important;
        font-size: clamp(1.34rem, 5.4vw, 1.72rem) !important;
        line-height: 1.06 !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
    }

    .lq-low-friction-hero {
        gap: 10px;
    }

    .lq-low-friction-hero-actions {
        max-width: none;
    }

    .lq-low-friction-hero-cta {
        min-height: 56px;
    }

    .lq-low-friction-hero-chip,
    .lq-low-friction-value-chip {
        font-size: .69rem;
        min-height: 28px;
        padding: 5px 8px;
    }

    .lq-low-friction-value-strip {
        padding: 12px 12px 10px;
        border-radius: 14px;
    }

    .lq-sticky-mobile-cta {
        display: block;
    }
}

@@media (min-width: 768px) {
    .lq-sticky-mobile-cta {
        display: none !important;
    }
}

/* Final contact isolation */
body.life-final-step-active .lq-hero-rail {
    display: none !important;
}
body.life-final-step-active .lq-hero-shell {
    max-width: 760px;
}
body.life-final-step-active .lq-contact-step {
    position: relative;
    z-index: 2;
}
body.life-final-step-active.page-variant-contact-first-education-v1 .lq-funnel-bridge-wrap,
body.life-final-step-active.page-variant-contact-first-education-v1 .lq-options-summary {
    display: none !important;
}
body.life-final-step-active.page-variant-contact-first-education-v1 .lq-education-stack {
    gap: 0;
}
body.life-final-step-active.page-variant-contact-first-education-v1 .lq-contact-first-primary-grid {
    margin-top: 0;
}
body.life-final-step-active.page-variant-contact-first-education-v1 #lifeEducationContactPanel {
    padding-top: 14px;
    padding-bottom: 14px;
}
body.life-final-step-active.page-variant-contact-first-education-v1 #lifeEducationContactPanel .lq-contact-first-proof-row {
    gap: 12px;
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: 0;
}
body.life-final-step-active.page-variant-contact-first-education-v1 #lifeEducationContactPanel .lq-contact-first-proof-avatar {
    width: 50px;
    height: 50px;
}
body.life-final-step-active.page-variant-contact-first-education-v1 #lifeEducationContactPanel .lq-contact-first-proof-title {
    font-size: 1rem;
}
body.life-final-step-active.page-variant-contact-first-education-v1 #lifeEducationContactPanel .lq-contact-first-proof-chips {
    display: none;
}
body.life-final-step-active.page-variant-contact-first-education-v1 #lifeEducationContactPanel .lq-contact-first-form-surface {
    padding-top: 18px;
}

@@media (max-width: 767.98px) {
    body.life-final-step-active .lq-hero-shell {
        padding-top: 10px !important;
        padding-bottom: 12px !important;
    }

    body.life-final-step-active.page-variant-contact-first-education-v1 #lifeEducationContactPanel {
        padding-top: 10px;
        padding-bottom: 10px;
    }
}

</style>

