    @await Html.PartialAsync("_TrustedCarrierStrip", carrierTrustResultsStripModel)
</template>

@if (isPaidLandingExperience)
{
    <script src="~/js/meta-signal-intelligence.js" asp-append-version="true"></script>
}
<script src="~/js/life-estimate-engine.js" asp-append-version="true"></script>
<script src="~/js/trusted-carrier-strip.js" asp-append-version="true"></script>
<script>
(async () => {
  const form = document.getElementById('lifeWizardForm');
  if (!form) return;

  const contactFirstPanel = document.getElementById('lifeEducationContactPanel');
  const funnelBridgeBtn = document.getElementById('lifeFunnelBridge');
  const step1Panel = document.getElementById('lifeStep1Panel');
  const processingPanel = document.getElementById('lifeProcessingPanel');
  const step2Panel = document.getElementById('lifeStep2Panel');
  const processingHeading = document.getElementById('lifeProcessingHeading');
  const step2Heading = document.getElementById('lifeStep2Heading');
  const processingFill = document.getElementById('lifeProcessingFill');
  const step1Progress = document.getElementById('lifeStep1Progress');
  const step1ProgressFill = document.getElementById('lifeStep1ProgressFill');
  const heroTrustStrip = document.getElementById('lifeHeroTrustStrip');
  const microSteps = Array.from(document.querySelectorAll('[data-micro-step]'));
  const step1ContinueBtn = document.getElementById('step1Continue');
  const step2BackBtn = document.getElementById('step2BackBtn');
  const carrierTrustResultsTemplate = document.getElementById('lifeCarrierTrustStripResultsTemplate');
  const carrierTrustResultsHtml = carrierTrustResultsTemplate?.innerHTML?.trim() || '';
  const showContactStepByDefault = '@(showContactStepByDefault ? "true" : "false")' === 'true';
  const answer1Hidden = document.getElementById('Answer1');
  const answer2Hidden = document.getElementById('Answer2');
  const answer3Hidden = document.getElementById('Answer3');
  const answer4Hidden = document.getElementById('Answer4');
  const ageHidden = document.getElementById('AgeRange');
  const coverageAmountHidden = document.getElementById('CoverageAmount');
  const focusHidden = document.getElementById('ProtectFocus');
  const submitBtn = document.getElementById('submitLife');
  const submitLabel = submitBtn?.dataset.defaultLabel || 'Submit';
  const recPrimaryKeyEl = document.getElementById('RecommendationPrimaryKey');
  const recPrimaryTitleEl = document.getElementById('RecommendationPrimaryTitle');
  const recSecondaryKeyEl = document.getElementById('RecommendationSecondaryKey');
  const recSecondaryTitleEl = document.getElementById('RecommendationSecondaryTitle');
  const estimatePreviewUrl = '@Url.Action("EstimatePreview", "LifeQuote")';
  const pageKey = form.dataset.formKey || 'quote_life';
  const quoteType = '@normalizedOfferKey';
  const metaBrowserAckUrl = '/Quote/Life/meta-browser-ack';
  const pageVariant = '@pageVariant';
  const pageMode = '@pageMode';
  const startEvent = '@cfg.StartEvent';
  const submitEvent = '@cfg.SubmitEvent';
  const usesLeanContactFields = '@(usesLeanContactFields ? "true" : "false")' === 'true';
  const hasServerErrors = '@(ViewData.ModelState.ErrorCount > 0 ? "true" : "false")' === 'true';
  const hasAgentTrustProfile = '@(showAgentTrustCard ? "true" : "false")' === 'true';
  const isContactFirstEducationVariant = '@(isContactFirstEducationVariant ? "true" : "false")' === 'true';
  const continueResultsLabel = @Html.Raw(resultsContinueButtonTextJson);
  const agentTrackingSlug = '@agentSlug';
  const agentTrackingProfileId = '@(agentTrustProfile?.AgentTrackingProfileId.ToString() ?? string.Empty)';
  const isLandingMobile = document.body.classList.contains('life-landing') && window.matchMedia('(max-width: 767.98px)').matches;
  const stateSelect = document.getElementById('State');
  const ageInput = document.getElementById('Age');
  const ageRangeInputs = Array.from(form.querySelectorAll('input[name="AgeBracket"]'));
  const requiredContactFields = isContactFirstEducationVariant
    ? ['FirstName', 'LastName', 'Phone']
    : ['FirstName', 'Phone'];
  const contactFieldNames = usesLeanContactFields
    ? ['FirstName', 'LastName', 'Phone', 'Email']
    : ['FirstName', 'LastName', 'Phone', 'Email', 'State'];
  const metaSignal = window.metaSignalIntelligence?.createLandingSession(@Html.Raw(metaSignalConfigJson)) || null;
  const AGE_RANGE_TO_NUMERIC = Object.freeze(@Html.Raw(ageRangeToNumericJson));
  const PROCESSING_BRIDGE_MS = 1500;
  const FUNNEL_STATE_SCOPE = `${window.location.pathname}:${pageKey}:${pageVariant}:${pageMode}:${quoteType}`;
  const FUNNEL_STATE_STORAGE_KEY = `life-funnel:${FUNNEL_STATE_SCOPE}`;
  const FUNNEL_STATE_MAX_AGE_MS = 1000 * 60 * 60 * 12;
  const microStepViewEvents = [
    'life_step1_protecting_view',
    'life_step1_goal_view',
    'life_step1_coverage_view',
    'life_step1_tobacco_view',
    'life_step1_age_view',
  ];
  let currentMicroStep = 0;
  let autoAdvanceTimer = null;
  let processingTimer = null;
  let latestEstimatePreview = null;
  let estimatePreviewPromise = null;
  let isRestoringFunnelState = false;

  if (stateSelect?.dataset.selected) {
    stateSelect.value = stateSelect.dataset.selected;
  }

  function getSessionStorageSafe() {
    try {
      return window.sessionStorage;
    } catch {
      return null;
    }
  }

  function getVisibleFunnelPanel() {
    const previewPanel = document.getElementById('lifeMiniResultsPanel');
    if (previewPanel && !previewPanel.hidden) return previewPanel;
    if (step2Panel && !step2Panel.hidden) return step2Panel;
    if (processingPanel && !processingPanel.hidden) return processingPanel;
    return step1Panel;
  }

  function getActivePanelKey() {
    const previewPanel = document.getElementById('lifeMiniResultsPanel');
    if (previewPanel && !previewPanel.hidden) return 'results';
    if (step2Panel && !step2Panel.hidden) return 'contact';
    if (processingPanel && !processingPanel.hidden) return 'processing';
    return 'step1';
  }

  function setRadioValue(name, value) {
    if (!value) return;
    const radio = form.querySelector(`input[name="${name}"][value="${CSS.escape(String(value))}"]`);
    if (radio instanceof HTMLInputElement) {
      radio.checked = true;
    }
  }

  function setFieldValue(name, value) {
    const el = form.querySelector(`[name="${name}"]`);
    if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement)) {
      return;
    }
    el.value = value ?? '';
  }

  function hasMeaningfulPersistedState(state) {
    if (!state || typeof state !== 'object') {
      return false;
    }

    const fieldValues = state.fields && typeof state.fields === 'object' ? Object.values(state.fields) : [];
    return fieldValues.some((value) => asTrimmed(String(value ?? '')) !== '')
      || Boolean(state.latestEstimatePreview)
      || state.activePanel === 'results'
      || state.activePanel === 'contact'
      || Number.isFinite(state.currentMicroStep) && Number(state.currentMicroStep) > 0;
  }

  function resetFunnelToMarkupDefaults() {
    form.reset();
    if (stateSelect?.dataset.selected) {
      stateSelect.value = stateSelect.dataset.selected;
    }

    latestEstimatePreview = null;
    estimatePreviewPromise = null;
    currentMicroStep = 0;

    const previewPanel = document.getElementById('lifeMiniResultsPanel');
    if (previewPanel) {
      previewPanel.remove();
    }
  }

  function buildPersistedFunnelState() {
    syncStepOneAnswersFromUI();

    return {
      scope: FUNNEL_STATE_SCOPE,
      currentMicroStep,
      activePanel: getActivePanelKey(),
      latestEstimatePreview,
      fields: {
        ProtectingWho: selectedRadio('ProtectingWho')?.value || '',
        CoverageGoal: selectedRadio('CoverageGoal')?.value || '',
        CoverageAmountOption: selectedRadio('CoverageAmountOption')?.value || '',
        TobaccoUse: selectedRadio('TobaccoUse')?.value || '',
        AgeBracket: selectedRadio('AgeBracket')?.value || '',
        FirstName: asTrimmed(form.querySelector('[name="FirstName"]')?.value || ''),
        LastName: asTrimmed(form.querySelector('[name="LastName"]')?.value || ''),
        Phone: asTrimmed(form.querySelector('[name="Phone"]')?.value || ''),
        Email: asTrimmed(form.querySelector('[name="Email"]')?.value || ''),
        State: asTrimmed(form.querySelector('[name="State"]')?.value || '')
      },
      timestamp: Date.now()
    };
  }

  function clearPersistedFunnelState() {
    const storage = getSessionStorageSafe();
    if (!storage) return;
    storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
  }

  function persistFunnelState() {
    if (isRestoringFunnelState) {
      return;
    }

    const storage = getSessionStorageSafe();
    if (!storage) {
      return;
    }

    const state = buildPersistedFunnelState();
    if (!hasMeaningfulPersistedState(state)) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      return;
    }

    try {
      storage.setItem(FUNNEL_STATE_STORAGE_KEY, JSON.stringify(state));
    } catch {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
    }
  }

  async function restorePersistedFunnelState() {
    const storage = getSessionStorageSafe();
    if (!storage) {
      resetFunnelToMarkupDefaults();
      return false;
    }

    const raw = storage.getItem(FUNNEL_STATE_STORAGE_KEY);
    if (!raw) {
      resetFunnelToMarkupDefaults();
      return false;
    }

    let state = null;
    try {
      state = JSON.parse(raw);
    } catch {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    if (!state || typeof state !== 'object') {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    if (asTrimmed(state.scope) && asTrimmed(state.scope) !== FUNNEL_STATE_SCOPE) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    if (Number.isFinite(state.timestamp) && Date.now() - Number(state.timestamp) > FUNNEL_STATE_MAX_AGE_MS) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    isRestoringFunnelState = true;

    const fields = state.fields && typeof state.fields === 'object' ? state.fields : {};
    setRadioValue('ProtectingWho', fields.ProtectingWho || '');
    setRadioValue('CoverageGoal', fields.CoverageGoal || '');
    setRadioValue('CoverageAmountOption', fields.CoverageAmountOption || '');
    setRadioValue('TobaccoUse', fields.TobaccoUse || '');
    setRadioValue('AgeBracket', fields.AgeBracket || '');
    setFieldValue('FirstName', fields.FirstName || '');
    setFieldValue('LastName', fields.LastName || '');
    setFieldValue('Phone', fields.Phone || '');
    setFieldValue('Email', fields.Email || '');
    setFieldValue('State', fields.State || '');

    latestEstimatePreview = state.latestEstimatePreview || null;
    applyEstimatePreviewToHiddenFields(latestEstimatePreview);
    syncStepOneAnswersFromUI();

    const restoredMicroStep = Number.isFinite(Number(state.currentMicroStep))
      ? Math.max(0, Math.min(microSteps.length - 1, Number(state.currentMicroStep)))
      : resolveInitialMicroStep();

    try {
      if (state.activePanel === 'results') {
        let preview = latestEstimatePreview;
        if (!preview) {
          preview = await ensureEstimatePreview();
        }
        await showMiniResultsPreview(preview, { trackView: false });
      } else if (state.activePanel === 'contact') {
        currentMicroStep = restoredMicroStep;
        setActivePanel(step2Panel);
      } else if (state.activePanel === 'processing') {
        if (latestEstimatePreview) {
          await showMiniResultsPreview(latestEstimatePreview, { trackView: false });
        } else {
          showStep1(restoredMicroStep, false, { trackView: false });
        }
      } else {
        showStep1(restoredMicroStep, false, { trackView: false });
      }
    } finally {
      isRestoringFunnelState = false;
    }

    return true;
  }

  contactFieldNames.forEach((name) => {
    const el = form.querySelector(`[name="${name}"]`);
    if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement)) {
      return;
    }

    const eventName = el instanceof HTMLSelectElement ? 'change' : 'input';
    el.addEventListener(eventName, () => {
      clearFieldError(name);
      const lifeError = document.getElementById('lifeError');
      if (lifeError) {
        lifeError.style.display = 'none';
      }
      persistFunnelState();
    });
  });

  function trackEvent(eventType, metadata = {}) {
    return window.legendTrack?.({
      EventType: eventType,
      PageKey: pageKey,
      Offer: '@cfg.OfferKey',
      MetadataJson: JSON.stringify({
        pageVariant,
        pageMode,
        pagePath: window.location.pathname,
        hasAgentTrustProfile,
        ...(agentTrackingSlug ? { agentSlug: agentTrackingSlug } : {}),
        ...(agentTrackingProfileId ? { agentProfileId: agentTrackingProfileId } : {}),
        ...metadata
      })
    }) ?? Promise.resolve();
  }

  function trackFormSubmitOutcome(submitOutcome, metadata = {}) {
    return window.legendTrack?.({
      EventType: 'form_submit',
      FormKey: pageKey,
      PageKey: pageKey,
      SubmitOutcome: submitOutcome,
      MetadataJson: JSON.stringify({
        offer: '@cfg.OfferKey',
        pageVariant,
        pageMode,
        pagePath: window.location.pathname,
        hasAgentTrustProfile,
        ...(agentTrackingSlug ? { agentSlug: agentTrackingSlug } : {}),
        ...(agentTrackingProfileId ? { agentProfileId: agentTrackingProfileId } : {}),
        ...metadata
      })
    }) ?? Promise.resolve();
  }

  function notifyBrowserPixelStatus(leadId, metaLeadEventId, status, note = '') {
    if (!leadId || !metaLeadEventId) {
      return;
    }

    const payload = JSON.stringify({
      leadId,
      eventId: metaLeadEventId,
      status,
      ...(note ? { note } : {})
    });

    try {
      if (navigator.sendBeacon) {
        const blob = new Blob([payload], { type: 'application/json' });
        if (navigator.sendBeacon(metaBrowserAckUrl, blob)) {
          return;
        }
      }
    } catch {
      // Fall through to fetch keepalive below.
    }

    try {
      fetch(metaBrowserAckUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: payload,
        keepalive: true
      }).catch(() => {});
    } catch {
      // Never block the thank-you redirect on diagnostics.
    }
  }

  function trackMetaLeadSuccess(leadId, metaLeadEventId) {
    if (!metaLeadEventId) {
      return Promise.resolve(false);
    }

    if (typeof window.fbq !== 'function') {
      notifyBrowserPixelStatus(leadId, metaLeadEventId, 'unavailable', 'fbq_unavailable');
      return Promise.resolve(false);
    }

    try {
      window.fbq('track', 'Lead', {
        content_name: pageKey,
        content_category: '@cfg.OfferKey'
      }, {
        eventID: metaLeadEventId
      });
      notifyBrowserPixelStatus(leadId, metaLeadEventId, 'sent');
      return Promise.resolve(true);
    } catch {
      notifyBrowserPixelStatus(leadId, metaLeadEventId, 'error', 'fbq_exception');
      return Promise.resolve(false);
    }
  }

  async function flushSuccessTracking(leadId, metaLeadEventId) {
    const trackingTasks = [
      trackEvent('life_step2_submit_success'),
      trackEvent(submitEvent, { submitOutcome: 'success' }),
      trackEvent('results_contact_submit', {
        primaryRec: recPrimaryKeyEl?.value || '',
        secondaryRec: recSecondaryKeyEl?.value || '',
      }),
      trackFormSubmitOutcome('success'),
      trackMetaLeadSuccess(leadId, metaLeadEventId)
    ];

    await Promise.race([
      Promise.allSettled(trackingTasks),
      new Promise((resolve) => window.setTimeout(resolve, 700))
    ]);
  }

  async function flushContactFirstSuccessTracking(leadId, metaLeadEventId) {
    const trackingTasks = [
      trackEvent('life_contact_first_submit_success'),
      trackEvent('life_step2_submit_success', { variantFlow: 'contact_first_education' }),
      trackEvent(submitEvent, { submitOutcome: 'success', variantFlow: 'contact_first_education' }),
      trackFormSubmitOutcome('success', { variantFlow: 'contact_first_education' }),
      trackMetaLeadSuccess(leadId, metaLeadEventId)
    ];

    await Promise.race([
      Promise.allSettled(trackingTasks),
      new Promise((resolve) => window.setTimeout(resolve, 700))
    ]);
  }

  function selectedRadio(name) {
    return form.querySelector(`input[name="${name}"]:checked`);
  }

  function asTrimmed(value) {
    return typeof value === 'string' ? value.trim() : '';
  }

  function normalizedAgeFromRange(ageRange) {
    const mapped = AGE_RANGE_TO_NUMERIC[ageRange];
    return Number.isFinite(mapped) ? String(mapped) : '';
  }

  function buildMetaProgressMetadata(extra = {}) {
    return Object.assign({
      protectingWho: answer1Hidden?.value || '',
      coverageGoal: answer2Hidden?.value || '',
      coverageAmount: coverageAmountHidden?.value || '',
      tobaccoUse: answer3Hidden?.value || '',
      ageRange: ageHidden?.value || ''
    }, extra);
  }

  async function ensureMetaLeadFormStart(extra = {}) {
    if (!metaSignal?.trackLeadFormStart) {
      return null;
    }

    return metaSignal.trackLeadFormStart(buildMetaProgressMetadata(extra));
  }

  function clearEstimatePreviewCache() {
    latestEstimatePreview = null;
    estimatePreviewPromise = null;
    persistFunnelState();
  }

  function applyEstimatePreviewToHiddenFields(preview) {
    if (!preview) {
      return;
    }

    if (recPrimaryKeyEl) recPrimaryKeyEl.value = preview.primary?.policyKey || '';
    if (recPrimaryTitleEl) recPrimaryTitleEl.value = preview.primary?.policyType || '';
    if (recSecondaryKeyEl) recSecondaryKeyEl.value = preview.secondary?.policyKey || '';
    if (recSecondaryTitleEl) recSecondaryTitleEl.value = preview.secondary?.policyType || '';
  }

  async function ensureEstimatePreview(forceRefresh = false) {
    syncStepOneAnswersFromUI();

    if (!window.lifeEstimateEngine?.fetchPreview) {
      throw new Error('life_estimate_engine_unavailable');
    }

    if (!forceRefresh && latestEstimatePreview) {
      return latestEstimatePreview;
    }

    if (!forceRefresh && estimatePreviewPromise) {
      return estimatePreviewPromise;
    }

    estimatePreviewPromise = window.lifeEstimateEngine.fetchPreview(form, estimatePreviewUrl)
      .then((preview) => {
        latestEstimatePreview = preview;
        applyEstimatePreviewToHiddenFields(preview);
        return preview;
      })
      .finally(() => {
        estimatePreviewPromise = null;
      });

    return estimatePreviewPromise;
  }

  const formTrackingKey = form.dataset.formKey || pageKey;
  const TRACKED_FIELD_NAME_MAP = Object.freeze({
    ProtectingWho: 'step_1_choice',
    CoverageGoal: 'step_2_choice',
    CoverageAmountOption: 'coverage_amount',
    TobaccoUse: 'tobacco_use',
    AgeBracket: 'age_range',
    FirstName: 'first_name',
    LastName: 'last_name',
    Phone: 'phone',
    Email: 'email',
    State: 'state',
  });

  function resolveTrackedFieldName(name) {
    return TRACKED_FIELD_NAME_MAP[name] || String(name || 'unknown').trim().toLowerCase();
  }

  function trackQuoteFieldError(name, errorType, fieldContext) {
    const trackedFieldName = resolveTrackedFieldName(name);
    window.legendFormTracking?.trackFieldError(formTrackingKey, trackedFieldName, errorType, '@cfg.OfferKey');

    if (!window.legendFormTracking && typeof window.legendTrack === 'function') {
      window.legendTrack({
        EventType: 'form_field_error',
        FormKey: formTrackingKey,
        FieldName: trackedFieldName,
        MetadataJson: JSON.stringify({
          errorType,
          fieldContext,
          pageVariant,
          pageMode,
        }),
      });
    }
  }

  function clearQuoteFieldError(name) {
    const trackedFieldName = resolveTrackedFieldName(name);
    window.legendFormTracking?.clearFieldError(formTrackingKey, trackedFieldName);
  }

  function showChoiceError(errorId, show) {
    const el = document.getElementById(errorId);
    if (!el) return;
    el.classList.toggle('visible', !!show);
  }

  function setFieldError(name, message) {
    const el = document.getElementById(`err-${name}`);
    if (!el) return;
    if (!el.dataset.defaultText) {
      el.dataset.defaultText = el.textContent || '';
    }
    el.textContent = message || el.dataset.defaultText;
    el.classList.add('visible');
  }

  function clearFieldError(name) {
    const el = document.getElementById(`err-${name}`);
    clearQuoteFieldError(name);
    if (!el) return;
    if (el.dataset.defaultText) {
      el.textContent = el.dataset.defaultText;
    }
    el.classList.remove('visible');
  }

  function getContactFieldError(name) {
    const el = form.querySelector(`[name="${name}"]`);
    if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement)) {
      return '';
    }

    const value = asTrimmed(el.value);
    if (name === 'Email') {
      if (!value) {
        return '';
      }

      if (el instanceof HTMLInputElement && !el.checkValidity()) {
        return 'Please enter a valid email address.';
      }

      return '';
    }

    if (!value) {
      if (!requiredContactFields.includes(name)) {
        return '';
      }

      return name === 'State'
        ? 'Please select your state.'
        : `Please enter your ${name === 'Email' ? 'email' : name === 'Phone' ? 'phone' : name === 'FirstName' ? 'first name' : 'last name'}.`;
    }

    return '';
  }

  function resolveContactErrorType(name, error) {
    if (name === 'Email' && /valid email/i.test(error || '')) {
      return 'invalid_email';
    }

    return 'required_missing';
  }

  function validateContactFields(focusFirst = false) {
    let firstInvalid = null;

    requiredContactFields.forEach((name) => {
      const error = getContactFieldError(name);
      if (error) {
        setFieldError(name, error);
        trackQuoteFieldError(name, resolveContactErrorType(name, error), 'contact');
        metaSignal?.trackFieldError(name, { fieldContext: 'contact' });
        firstInvalid ??= form.querySelector(`[name="${name}"]`);
      } else {
        clearFieldError(name);
      }
    });

    const optionalEmailError = getContactFieldError('Email');
    if (optionalEmailError) {
      setFieldError('Email', optionalEmailError);
      trackQuoteFieldError('Email', resolveContactErrorType('Email', optionalEmailError), 'contact');
      metaSignal?.trackFieldError('Email', { fieldContext: 'contact' });
      firstInvalid ??= form.querySelector('[name="Email"]');
    } else {
      clearFieldError('Email');
    }

    if (focusFirst && firstInvalid instanceof HTMLElement) {
      firstInvalid.focus();
    }

    return firstInvalid === null;
  }

  function clearAutoAdvanceTimer() {
    if (autoAdvanceTimer) {
      window.clearTimeout(autoAdvanceTimer);
      autoAdvanceTimer = null;
    }
  }

  function clearProcessingTimer(resetBar = false) {
    if (processingTimer) {
      window.clearTimeout(processingTimer);
      processingTimer = null;
    }
    if (processingFill && resetBar) {
      processingFill.style.transition = 'none';
      processingFill.style.width = '0%';
      void processingFill.offsetWidth;
    }
  }

  function setActivePanel(activePanel) {
    const previewPanel = document.getElementById('lifeMiniResultsPanel');
    [step1Panel, processingPanel, step2Panel, previewPanel].forEach((panel) => {
      if (!panel) return;
      panel.hidden = panel !== activePanel;
    });
    if (heroTrustStrip) {
      heroTrustStrip.hidden = activePanel === step2Panel;
    }
    persistFunnelState();
  }

  function resolveScrollTarget(target) {
    if (!target) return target;
    if (
      contactFirstPanel &&
      (target === step1Panel ||
       target === processingPanel ||
       target === step2Panel ||
       (target instanceof HTMLElement && target.id === 'lifeMiniResultsPanel'))
    ) {
      return contactFirstPanel;
    }
    return target;
  }

  function getScrollTopOffset() {
    const navbar = document.querySelector('header .navbar');
    const navbarHeight = !isPaidLandingExperience && navbar instanceof HTMLElement
      ? navbar.getBoundingClientRect().height
      : 0;
    const viewportPadding = window.matchMedia('(max-width: 767.98px)').matches ? 10 : 18;
    return navbarHeight + viewportPadding;
  }

  function scrollPanelIntoView(target, behavior = 'smooth') {
    const scrollTarget = resolveScrollTarget(target);
    if (!(scrollTarget instanceof HTMLElement)) return;
    const targetTop = window.scrollY + scrollTarget.getBoundingClientRect().top - getScrollTopOffset();
    window.scrollTo({
      top: Math.max(0, targetTop),
      behavior
    });
  }

  function scrollIntoViewAndFocus(target, shouldFocus = false) {
    if (!target) return;
    const scrollBehavior = (isLandingMobile && target === step1Panel) ? 'auto' : 'smooth';
    setTimeout(() => {
      scrollPanelIntoView(target, scrollBehavior);
      if (shouldFocus && target instanceof HTMLElement) {
        target.focus({ preventScroll: true });
      }
    }, 40);
  }

  function scrollInitialFunnelIntoView() {
    const initialTarget = getVisibleFunnelPanel();
    if (!(initialTarget instanceof HTMLElement)) return;
    window.requestAnimationFrame(() => {
      window.requestAnimationFrame(() => {
        scrollPanelIntoView(initialTarget, 'auto');
      });
    });
  }

  funnelBridgeBtn?.addEventListener('click', () => {
    const activeTarget = getVisibleFunnelPanel() || step1Panel || contactFirstPanel;
    scrollPanelIntoView(activeTarget, 'smooth');
  });

  function syncStepOneAnswersFromUI() {
    const protecting = selectedRadio('ProtectingWho');
    const goal = selectedRadio('CoverageGoal');
    const coverageAmount = selectedRadio('CoverageAmountOption');
    const tobaccoUse = selectedRadio('TobaccoUse');
    const selectedAgeRange = selectedRadio('AgeBracket')?.value || '';
    const ageFromRange = normalizedAgeFromRange(selectedAgeRange);
    const fallbackAgeValue = asTrimmed(ageInput?.value);
    const resolvedAgeValue = ageFromRange || fallbackAgeValue;

    if (protecting) {
      answer1Hidden.value = protecting.value;
    } else if (answer1Hidden) {
      answer1Hidden.value = '';
    }
    if (goal) {
      answer2Hidden.value = goal.value;
      focusHidden.value = goal.dataset.label || goal.value;
    } else if (answer2Hidden) {
      answer2Hidden.value = '';
    }
    if (coverageAmountHidden) {
      coverageAmountHidden.value = coverageAmount?.value || '';
    }
    if (answer3Hidden) {
      answer3Hidden.value = tobaccoUse?.value || '';
    }
    if (ageInput) {
      ageInput.value = resolvedAgeValue;
    }
    if (answer4Hidden) {
      answer4Hidden.value = selectedAgeRange || resolvedAgeValue;
    }
    if (ageHidden) {
      ageHidden.value = selectedAgeRange;
    }
  }

  function validateCoverageAmountOnly() {
    const coverageAmount = selectedRadio('CoverageAmountOption');
    const hasSelection = !!coverageAmount;
    showChoiceError('err-step1-coverage-amount', !hasSelection);
    return hasSelection;
  }

  function validateTobaccoOnly() {
    const tobaccoUse = selectedRadio('TobaccoUse');
    const hasSelection = !!tobaccoUse;
    showChoiceError('err-step1-tobacco-use', !hasSelection);
    return hasSelection;
  }

  function validateAgeOnly() {
    const selectedAgeRange = selectedRadio('AgeBracket')?.value || '';
    const ageFromRange = normalizedAgeFromRange(selectedAgeRange);
    if (ageFromRange) {
      if (ageInput) {
        ageInput.value = ageFromRange;
      }
      showChoiceError('err-step1-age', false);
      return true;
    }
    const ageValue = asTrimmed(ageInput?.value);
    const ageNum = Number.parseInt(ageValue, 10);
    const hasValidAge = Number.isFinite(ageNum) && ageNum >= 18 && ageNum <= 85;
    showChoiceError('err-step1-age', !hasValidAge);
    return hasValidAge;
  }

  function showMicroStep(stepIndex, shouldScroll = false, options = {}) {
    const bounded = Math.max(0, Math.min(microSteps.length - 1, stepIndex));
    currentMicroStep = bounded;
    microSteps.forEach((stepEl, i) => {
      stepEl.hidden = i !== bounded;
    });

    if (step1Progress) {
      step1Progress.textContent = `Step ${bounded + 1} of ${microSteps.length}`;
    }
    if (step1ProgressFill) {
      step1ProgressFill.style.width = `${((bounded + 1) / microSteps.length) * 100}%`;
    }
    if (options.trackView !== false) {
      trackEvent(microStepViewEvents[bounded], { microStep: bounded + 1 });
    }

    persistFunnelState();

    if (shouldScroll) {
      scrollIntoViewAndFocus(step1Panel, false);
    }
  }

  function showStep1(microStepIndex = 0, shouldScroll = false, options = {}) {
    clearAutoAdvanceTimer();
    clearProcessingTimer(true);
    setActivePanel(step1Panel);
    if (options.trackView !== false) {
      trackEvent('life_step1_intro_view');
    }
    showMicroStep(microStepIndex, shouldScroll, options);
  }

  function animateProcessingBar() {
    if (!processingFill) return;
    processingFill.style.transition = 'none';
    processingFill.style.width = '0%';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        processingFill.style.transition = `width ${PROCESSING_BRIDGE_MS}ms cubic-bezier(0.22, 1, 0.36, 1)`;
        processingFill.style.width = '100%';
      });
    });
  }

  function showProcessingBridge(shouldScroll = true) {
    clearAutoAdvanceTimer();
    clearProcessingTimer(true);
    clearEstimatePreviewCache();
    syncStepOneAnswersFromUI();
    const previewPromise = ensureEstimatePreview(true);
    setActivePanel(processingPanel);
    trackEvent('life_processing_bridge_view');
    animateProcessingBar();
    if (shouldScroll) {
      scrollIntoViewAndFocus(processingHeading || processingPanel, true);
    }
    processingTimer = window.setTimeout(async () => {
      processingTimer = null;
      trackEvent('life_processing_bridge_complete');
      syncStepOneAnswersFromUI();
      try {
        const preview = await previewPromise;
        await showMiniResultsPreview(preview);
      } catch {
        trackEvent('estimate_results_error', {
          protectingWho: answer1Hidden?.value || '',
          coverageGoal: answer2Hidden?.value || '',
          coverageAmount: coverageAmountHidden?.value || '',
          tobaccoUse: answer3Hidden?.value || '',
          ageRange: ageHidden?.value || ''
        });
        showStep2(true);
      }
    }, PROCESSING_BRIDGE_MS + 80);
  }

  async function showMiniResultsPreview(preview, options = {}) {
    const existing = document.getElementById('lifeMiniResultsPanel');
    if (existing) existing.remove();

    const estimatePreview = preview || latestEstimatePreview;
    if (!estimatePreview) {
      return;
    }

    latestEstimatePreview = estimatePreview;
    applyEstimatePreviewToHiddenFields(estimatePreview);

    const previewHtml = window.lifeEstimateEngine.buildResultsPanelHtml(estimatePreview, continueResultsLabel, carrierTrustResultsHtml);
    const primary = estimatePreview.primary || {};
    const secondary = estimatePreview.secondary || {};

    processingPanel.insertAdjacentHTML('afterend', previewHtml);
    const previewPanel = document.getElementById('lifeMiniResultsPanel');
    window.trustedCarrierStrip?.init(previewPanel);
    setActivePanel(previewPanel);
    if (options.trackView !== false) {
      trackEvent('mini_results_view', {
        recommendationPrimaryKey: primary.policyKey || '',
        recommendationSecondaryKey: secondary.policyKey || ''
      });
      trackEvent('estimate_results_viewed', {
        primaryPolicyType: primary.policyType || '',
        secondaryPolicyType: secondary.policyType || '',
        ageBand: estimatePreview.ageBand || '',
        requestedCoverageAmount: estimatePreview.requestedCoverageAmount || coverageAmountHidden?.value || '',
        tobaccoUse: estimatePreview.tobaccoUse || answer3Hidden?.value || '',
        coverageGoal: estimatePreview.coverageGoal || answer2Hidden?.value || '',
        protectingWho: estimatePreview.protectingWho || answer1Hidden?.value || '',
        estimatedLow: primary.estimatedLowMonthly || '',
        estimatedHigh: primary.estimatedHighMonthly || '',
        secondaryEstimatedLow: secondary.estimatedLowMonthly || '',
        secondaryEstimatedHigh: secondary.estimatedHighMonthly || ''
      });
      await ensureMetaLeadFormStart();
      metaSignal?.trackRecommendationViewed(buildMetaProgressMetadata({
        recommendationPrimaryKey: primary.policyKey || '',
        recommendationSecondaryKey: secondary.policyKey || ''
      }));
    }

    persistFunnelState();

    document.getElementById('continueToContactBtn')?.addEventListener('click', () => {
      trackEvent('estimate_contact_continue', {
        primaryPolicyType: primary.policyType || '',
        secondaryPolicyType: secondary.policyType || '',
        ageBand: estimatePreview.ageBand || '',
        requestedCoverageAmount: estimatePreview.requestedCoverageAmount || coverageAmountHidden?.value || '',
        tobaccoUse: estimatePreview.tobaccoUse || answer3Hidden?.value || '',
        coverageGoal: estimatePreview.coverageGoal || answer2Hidden?.value || '',
        estimatedLow: primary.estimatedLowMonthly || '',
        estimatedHigh: primary.estimatedHighMonthly || ''
      });
      metaSignal?.trackStepComplete(2, 'recommendation_complete', {
        ...buildMetaProgressMetadata(),
        recommendationPrimaryKey: primary.policyKey || '',
        recommendationSecondaryKey: secondary.policyKey || ''
      });
      previewPanel.remove();
      persistFunnelState();
      showStep2(true);
    });
  }

  async function showStep2(shouldScroll = true) {
    clearAutoAdvanceTimer();
    clearProcessingTimer(false);
    setActivePanel(step2Panel);
    trackEvent('life_step2_view', { handoffType: hasAgentTrustProfile ? 'agent' : 'generic' });
    await ensureMetaLeadFormStart();
    metaSignal?.trackContactStepReached(buildMetaProgressMetadata({
      handoffType: hasAgentTrustProfile ? 'agent' : 'generic'
    }));
    if (shouldScroll) {
      scrollIntoViewAndFocus(step2Heading || step2Panel, true);
    }
  }

  function resolveInitialMicroStep() {
    if (!selectedRadio('ProtectingWho')) return 0;
    if (!selectedRadio('CoverageGoal')) return 1;
    if (!selectedRadio('CoverageAmountOption')) return 2;
    if (!selectedRadio('TobaccoUse')) return 3;
    return 4; // age step
  }

  function validateStepOneComplete() {
    const protecting = selectedRadio('ProtectingWho');
    const goal = selectedRadio('CoverageGoal');
    const coverageAmount = selectedRadio('CoverageAmountOption');
    const hasValidCoverageAmount = validateCoverageAmountOnly();
    const tobaccoUse = selectedRadio('TobaccoUse');
    const hasValidTobaccoUse = validateTobaccoOnly();
    const hasValidAge = validateAgeOnly();

    showChoiceError('err-step1-protecting-who', !protecting);
    showChoiceError('err-step1-coverage-goal', !goal);
    showChoiceError('err-step1-coverage-amount', !coverageAmount);
    showChoiceError('err-step1-tobacco-use', !tobaccoUse);

    if (!protecting) {
      trackQuoteFieldError('ProtectingWho', 'required_missing', 'discovery');
      metaSignal?.trackFieldError('ProtectingWho', { fieldContext: 'discovery' });
      showStep1(0, true);
      form.querySelector('input[name="ProtectingWho"]')?.focus();
      return false;
    }
    if (!goal) {
      trackQuoteFieldError('CoverageGoal', 'required_missing', 'discovery');
      metaSignal?.trackFieldError('CoverageGoal', { fieldContext: 'discovery' });
      showStep1(1, true);
      form.querySelector('input[name="CoverageGoal"]')?.focus();
      return false;
    }
    if (!hasValidCoverageAmount) {
      trackQuoteFieldError('CoverageAmountOption', 'required_missing', 'discovery');
      metaSignal?.trackFieldError('CoverageAmountOption', { fieldContext: 'discovery' });
      showStep1(2, true);
      form.querySelector('input[name="CoverageAmountOption"]')?.focus();
      return false;
    }
    if (!hasValidTobaccoUse) {
      trackQuoteFieldError('TobaccoUse', 'required_missing', 'discovery');
      metaSignal?.trackFieldError('TobaccoUse', { fieldContext: 'discovery' });
      showStep1(3, true);
      form.querySelector('input[name="TobaccoUse"]')?.focus();
      return false;
    }
    if (!hasValidAge) {
      trackQuoteFieldError('AgeBracket', 'required_missing', 'discovery');
      metaSignal?.trackFieldError('AgeBracket', { fieldContext: 'discovery' });
      showStep1(4, true);
      form.querySelector('input[name="AgeBracket"]')?.focus();
      return false;
    }
    return true;
  }

  function focusFirstInvalidContactField() {
    validateContactFields(true);
  }

  function populateAttributionFields() {
    var ids = window.legendTrackingIds;
    var p = new URLSearchParams(window.location.search);
    var attr = ids && ids.getAttribution ? (ids.getAttribution() || {}) : {};
    function set(id, v) { var el = document.getElementById(id); if (el && v) el.value = v; }
    set('SessionId',    ids && ids.getSessionId ? ids.getSessionId() : '');
    set('VisitorId',    ids && ids.getVisitorId ? ids.getVisitorId() : '');
    set('UtmSource',    attr.utmSource || p.get('utm_source') || '');
    set('UtmMedium',    attr.utmMedium || p.get('utm_medium') || '');
    set('UtmCampaign',  attr.utmCampaign || p.get('utm_campaign') || '');
    set('UtmId',        attr.utmId || p.get('utm_id') || '');
    set('UtmTerm',      attr.utmTerm || p.get('utm_term') || '');
    set('UtmContent',   attr.utmContent || p.get('utm_content') || '');
    set('MetaCampaignId', attr.metaCampaignId || p.get('meta_campaign_id') || '');
    set('MetaAdSetId',  attr.metaAdSetId || p.get('meta_adset_id') || '');
    set('MetaAdId',     attr.metaAdId || p.get('meta_ad_id') || '');
    set('Fbclid',       attr.fbclid || p.get('fbclid') || '');
    set('ReferrerUrl',  document.referrer || '');
    set('LandingPageUrl', window.location.href || '');
  }

  function resolveThankYouPath() {
    const parts = location.pathname.split('/').filter(Boolean);
    if (parts.length >= 2 && parts[0] === 'a') {
      return `/a/${parts[1]}/ThankYou`;
    }
    return '/ThankYou';
  }

  if (isContactFirstEducationVariant) {
    trackEvent('life_contact_first_view', { variantFlow: 'contact_first_education' });
  }

  function queueMicroAdvance(expectedStep, nextStep) {
    if (step1Panel.hidden || currentMicroStep !== expectedStep) return;
    clearAutoAdvanceTimer();
    autoAdvanceTimer = window.setTimeout(() => showMicroStep(nextStep, true), 160);
  }

  function queueProcessingAdvanceFromAgeSelection() {
    if (step1Panel.hidden || currentMicroStep !== 4) return;
    clearAutoAdvanceTimer();
    autoAdvanceTimer = window.setTimeout(() => step1ContinueBtn?.click(), 180);
  }

  function wireAutoAdvanceGroup(groupName, errorId, selectEvent, expectedStep, nextStep) {
    form.querySelectorAll(`input[name="${groupName}"]`).forEach((radio) => {
      radio.addEventListener('change', () => {
        showChoiceError(errorId, false);
        clearQuoteFieldError(groupName);
        clearEstimatePreviewCache();
        syncStepOneAnswersFromUI();
        persistFunnelState();
        trackEvent(selectEvent, { choice: radio.dataset.label || radio.value, code: radio.value });
        void ensureMetaLeadFormStart();
        queueMicroAdvance(expectedStep, nextStep);
      });
      radio.closest('label')?.addEventListener('click', () => {
        // Allow forward movement when revisiting a step where the choice is already selected.
        setTimeout(() => {
          if (radio.checked) queueMicroAdvance(expectedStep, nextStep);
        }, 0);
      });
    });
  }

  wireAutoAdvanceGroup('ProtectingWho', 'err-step1-protecting-who', 'life_step1_protecting_select', 0, 1);
  form.querySelectorAll('input[name="CoverageGoal"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      showChoiceError('err-step1-coverage-goal', false);
      clearQuoteFieldError('CoverageGoal');
      clearEstimatePreviewCache();
      syncStepOneAnswersFromUI();
      persistFunnelState();
      trackEvent('life_step1_goal_select', { choice: radio.dataset.label || radio.value, code: radio.value });
      void ensureMetaLeadFormStart();
      if (!step1Panel.hidden && currentMicroStep === 1) {
        clearAutoAdvanceTimer();
        autoAdvanceTimer = window.setTimeout(() => showMicroStep(2, true), 160);
      }
    });
  });
  document.getElementById('ageStepBackBtn')?.addEventListener('click', () => {
    metaSignal?.trackBacktrack({ fromStep: 'age', toStep: 'tobacco' });
    showStep1(3, true);
  });

  wireAutoAdvanceGroup('CoverageAmountOption', 'err-step1-coverage-amount', 'life_step1_coverage_select', 2, 3);
  wireAutoAdvanceGroup('TobaccoUse', 'err-step1-tobacco-use', 'life_step1_tobacco_select', 3, 4);

  ageRangeInputs.forEach((radio) => {
    radio.addEventListener('change', () => {
      showChoiceError('err-step1-age', false);
      clearQuoteFieldError('AgeBracket');
      clearEstimatePreviewCache();
      syncStepOneAnswersFromUI();
      persistFunnelState();
      trackEvent('step1_age_entered', { ageRange: radio.value, age: radio.dataset.age || '' });
      void ensureMetaLeadFormStart();
      queueProcessingAdvanceFromAgeSelection();
    });
    radio.closest('label')?.addEventListener('click', () => {
      setTimeout(() => {
        if (radio.checked) queueProcessingAdvanceFromAgeSelection();
      }, 0);
    });
  });
  document.querySelectorAll('[data-step1-back]').forEach((btn) => {
    btn.addEventListener('click', () => {
      metaSignal?.trackBacktrack({ fromStep: `micro_${currentMicroStep + 1}`, toStep: `micro_${btn.getAttribute('data-step1-back') || '0'}` });
      const target = Number.parseInt(btn.getAttribute('data-step1-back') || '0', 10);
      showMicroStep(Number.isFinite(target) ? target : 0, true);
    });
  });

  step1ContinueBtn?.addEventListener('click', () => {
    clearAutoAdvanceTimer();
    syncStepOneAnswersFromUI();
    if (!validateStepOneComplete()) return;
    syncStepOneAnswersFromUI();
    trackEvent('life_step1_age_continue', {
      protectingWho: answer1Hidden?.value || '',
      coverageGoal: answer2Hidden?.value || '',
      coverageAmount: coverageAmountHidden?.value || '',
      tobaccoUse: answer3Hidden?.value || '',
      age: answer4Hidden?.value || '',
      ageRange: ageHidden?.value || ''
    });
    if (metaSignal?.trackDiscoveryComplete) {
      metaSignal.trackDiscoveryComplete(buildMetaProgressMetadata());
    } else {
      metaSignal?.trackStepComplete(1, 'discovery_complete', buildMetaProgressMetadata());
    }
    showProcessingBridge(true);
  });

  step2BackBtn?.addEventListener('click', () => {
    trackEvent('life_step2_back');
    metaSignal?.trackBacktrack({ fromStep: 'contact', toStep: 'discovery' });
    showStep1(4, true);
  });

  // form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    syncStepOneAnswersFromUI();
    if (!validateStepOneComplete()) {
      form._trackSubmitAttempt?.(false, 1);
      return;
    }

    let estimatePreview = latestEstimatePreview;
    try {
      estimatePreview = await ensureEstimatePreview();
      trackEvent('recommendation_generated', {
        primary: estimatePreview.primary?.policyKey || '',
        secondary: estimatePreview.secondary?.policyKey || '',
        coverageAmount: estimatePreview.requestedCoverageAmount || coverageAmountHidden?.value || '',
        tobaccoUse: estimatePreview.tobaccoUse || answer3Hidden?.value || '',
        ageBand: estimatePreview.ageBand || ''
      });
    } catch {
      trackEvent('estimate_results_error', {
        step: 'submit_attempt',
        protectingWho: answer1Hidden?.value || '',
        coverageGoal: answer2Hidden?.value || '',
        coverageAmount: coverageAmountHidden?.value || '',
        tobaccoUse: answer3Hidden?.value || '',
        ageRange: ageHidden?.value || ''
      });
    }

    const lifeError = document.getElementById('lifeError');
    const lifeSuccess = document.getElementById('lifeSuccess');
    if (lifeError) lifeError.style.display = 'none';
    if (lifeSuccess) lifeSuccess.style.display = 'none';
    ['FirstName','LastName','Phone','Email','State'].forEach(clearFieldError);
    showStep2(false);

    // contact validation
    if (!validateContactFields(true)) {
      if (lifeError) {
        lifeError.textContent = 'Please review the highlighted contact fields.';
        lifeError.style.display = 'block';
      }
      showStep2(false);
      form._trackSubmitAttempt?.(false, 1);
      return;
    }

    if (isContactFirstEducationVariant) {
      trackEvent('life_contact_first_submit_attempt', { variantFlow: 'contact_first_education' });
    }
    trackEvent('life_step2_submit_attempt');
    form._trackSubmitAttempt?.(true, 0);
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
    }

    populateAttributionFields();

    trackFormSubmitOutcome('attempt', {
      step: 'submit_attempt',
      protectingWho: answer1Hidden?.value || '',
      coverageGoal: answer2Hidden?.value || '',
      coverageAmount: coverageAmountHidden?.value || '',
      tobaccoUse: answer3Hidden?.value || '',
      age: answer4Hidden?.value || '',
      ageRange: ageHidden.value,
      protectFocus: focusHidden.value,
      recommendationPrimaryKey: estimatePreview?.primary?.policyKey || recPrimaryKeyEl?.value || '',
      recommendationSecondaryKey: estimatePreview?.secondary?.policyKey || recSecondaryKeyEl?.value || ''
    });
    metaSignal?.trackSubmitAttempt(buildMetaProgressMetadata({
      requiredContactFieldsComplete: true,
      contactStepReached: true
    }));

    try {
      const res = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'X-Requested-With': 'fetch' } });
      if (!res.ok) throw new Error('Network');
      const responseBody = await res.json().catch(() => ({}));
      const leadId = typeof responseBody.leadId === 'string' ? responseBody.leadId.trim() : '';
      const metaLeadEventId = typeof responseBody.metaLeadEventId === 'string' ? responseBody.metaLeadEventId.trim() : '';
      metaSignal?.markSubmitted({ leadId, metaLeadEventId, requiredContactFieldsComplete: true, contactStepReached: true });
      form._trackSubmitSuccess?.();
      await flushSuccessTracking(leadId, metaLeadEventId);
      if (isContactFirstEducationVariant) {
        await trackEvent('life_contact_first_submit_success', { variantFlow: 'contact_first_education' });
      }
      clearPersistedFunnelState();
      window.location.href = resolveThankYouPath();
    } catch (err) {
      if (lifeError) {
        lifeError.textContent = 'We could not send this right now. Please try again.';
        lifeError.style.display = 'block';
      }
      trackFormSubmitOutcome('error');
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = submitLabel;
      }
    }
  });

  // fire start event once
  window.legendTrack?.({
    EventType: startEvent,
    PageKey: pageKey,
    Offer: '@cfg.OfferKey',
    MetadataJson: JSON.stringify({
      pageVariant,
      pageMode,
      pagePath: window.location.pathname,
      hasAgentTrustProfile,
      ...(agentTrackingSlug ? { agentSlug: agentTrackingSlug } : {}),
      ...(agentTrackingProfileId ? { agentProfileId: agentTrackingProfileId } : {})
    })
  });

  const restoredFunnelState = await restorePersistedFunnelState();
  if (!restoredFunnelState) {
    syncStepOneAnswersFromUI();
    if (showContactStepByDefault) {
      showStep2(false);
    } else {
      const initMicro = resolveInitialMicroStep();
      showStep1(initMicro, false);
    }
  }
  scrollInitialFunnelIntoView();
  if (showContactStepByDefault && hasServerErrors) {
    setTimeout(() => focusFirstInvalidContactField(), 30);
  }
  window.addEventListener('pagehide', () => {
    syncStepOneAnswersFromUI();
    persistFunnelState();
  });
  window.trustedCarrierStrip?.init(document);
})();
</script>
