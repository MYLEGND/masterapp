@model Protect_Website.Models.LifeWizardViewModel

@{
    var cfg = Model.Config;
    var form = Model.Form;
    var pageKey = string.IsNullOrWhiteSpace(Model.EffectivePageKey) ? cfg.PageKey : Model.EffectivePageKey;
    var requestPath = Context?.Request?.Path.Value ?? string.Empty;
    var isLandingPage = Model.IsLandingPage;
    var isLandingRoutePath = requestPath.Contains("/landing", StringComparison.OrdinalIgnoreCase);
    var isLandingView = isLandingPage || isLandingRoutePath;
    var offerBodyClass = $"life-offer-{cfg.OfferKey?.ToLowerInvariant()}";
    var pageVariant = string.IsNullOrWhiteSpace(Model.PageVariant) ? (isLandingView ? "landing" : "website") : Model.PageVariant;
    var pageMode = string.IsNullOrWhiteSpace(Model.PageMode) ? (isLandingView ? "paid_landing" : "site_mode") : Model.PageMode;
    ViewData["Title"] = cfg.PageTitle;
    ViewData["PageKey"] = pageKey;
    ViewData["IsLandingPage"] = isLandingView;
    ViewData["PageVariant"] = pageVariant;
    ViewData["PageMode"] = pageMode;
    ViewData["PageCategory"] = "quote";
    ViewData["QuoteTypeForTracking"] = cfg.OfferKey;
    ViewData["BodyClass"] = isLandingView ? $"life-landing landing-mode {offerBodyClass}" : $"site-mode {offerBodyClass}";
    // Shared two-step intake for all life product types.
    IReadOnlyList<Protect_Website.Models.LifeWizardStep> viewSteps = (cfg.Steps?.Take(4).ToList() ?? new List<Protect_Website.Models.LifeWizardStep>());
    if (viewSteps.Count < 4)
    {
        viewSteps = new List<Protect_Website.Models.LifeWizardStep>
        {
            new("Who depends on you the most?", new List<Protect_Website.Models.LifeWizardOption>
            {
                new("just_me","Just me"),
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children"),
                new("family","My family"),
                new("not_sure","I’m not sure yet"),
            }, "ProtectingWho"),
            new("What matters most for this protection?", new List<Protect_Website.Models.LifeWizardOption>
            {
                new("replace_income","Replace income for my family"),
                new("final_expenses","Cover final expenses"),
                new("mortgage_or_bills","Help with mortgage or bills"),
                new("leave_something","Leave something behind"),
                new("not_sure","I’m not sure yet"),
            }, "CoverageGoal"),
            new("Tobacco use", new List<Protect_Website.Models.LifeWizardOption>
            {
                new("non_smoker","Non-smoker"),
                new("smoker","Smoker"),
            }, "TobaccoUse"),
            new("Your age", new List<Protect_Website.Models.LifeWizardOption>(), "Age"),
        };
    }
    var protectStep = viewSteps[0];
    var goalStep = viewSteps[1];
    var ageStep = viewSteps[3];
    var selectedAgeBracket = string.Empty;
    var ageValueNumber = form.Age;
    if (!string.IsNullOrWhiteSpace(form.AgeRange) && (form.AgeRange.Contains('-') || form.AgeRange.Contains('+')))
    {
        selectedAgeBracket = form.AgeRange.Trim();
    }
    if (string.IsNullOrWhiteSpace(selectedAgeBracket) && !string.IsNullOrWhiteSpace(form.Answer4) && (form.Answer4.Contains('-') || form.Answer4.Contains('+')))
    {
        selectedAgeBracket = form.Answer4.Trim();
    }
    if (!ageValueNumber.HasValue && int.TryParse(form.Answer4, out var parsedAnswerAge))
    {
        ageValueNumber = parsedAnswerAge;
    }
    if (!ageValueNumber.HasValue && int.TryParse(form.AgeRange, out var parsedRangeAge))
    {
        ageValueNumber = parsedRangeAge;
    }
    if (string.IsNullOrWhiteSpace(selectedAgeBracket) && ageValueNumber.HasValue)
    {
        var ageNumber = ageValueNumber.Value;
        if (ageNumber <= 24) selectedAgeBracket = "18-24";
        else if (ageNumber <= 34) selectedAgeBracket = "25-34";
        else if (ageNumber <= 44) selectedAgeBracket = "35-44";
        else if (ageNumber <= 54) selectedAgeBracket = "45-54";
        else selectedAgeBracket = "55+";
    }
    if (!ageValueNumber.HasValue)
    {
        ageValueNumber = selectedAgeBracket switch
        {
            "18-24" => 21,
            "25-34" => 30,
            "35-44" => 40,
            "45-54" => 50,
            "55+" => 60,
            _ => null,
        };
    }
    var ageValue = ageValueNumber?.ToString() ?? string.Empty;
    var usesLeanContactFields = true;
    var hasContactInput =
        !string.IsNullOrWhiteSpace(form.FirstName) ||
        !string.IsNullOrWhiteSpace(form.LastName) ||
        !string.IsNullOrWhiteSpace(form.Phone) ||
        !string.IsNullOrWhiteSpace(form.Email) ||
        !string.IsNullOrWhiteSpace(form.State);
    var showContactStepByDefault = !ViewData.ModelState.IsValid || hasContactInput;
    var isFounderPath = ViewData["IsFounderPath"] as bool? == true;
    var trackedSlug = ((string?)ViewData["TrackingSlug"] ?? string.Empty).Trim();
    var agentTrustProfile = Model.AgentTrustProfile;
    var agentSlug = !string.IsNullOrWhiteSpace(agentTrustProfile?.AgentSlug)
        ? agentTrustProfile.AgentSlug
        : (!isFounderPath ? trackedSlug : string.Empty);
    var showAgentTrustCard = agentTrustProfile != null;
    var agentDisplayName = !string.IsNullOrWhiteSpace(agentTrustProfile?.DisplayName)
        ? agentTrustProfile!.DisplayName!.Trim()
        : "Your licensed agent";
    var agentGreetingName = !string.IsNullOrWhiteSpace(agentTrustProfile?.FirstName)
        ? agentTrustProfile!.FirstName!.Trim()
        : agentDisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "there";
    var finalStepHeading = showAgentTrustCard
        ? "You're almost done, I'll help you understand what may fit."
        : "You're almost done, we'll help you understand what may fit.";
    var finalStepHelper = showAgentTrustCard ? string.Empty : "Share the best way to reach you and we'll walk through what may fit your situation.";
    var agentTrustBio = !string.IsNullOrWhiteSpace(agentTrustProfile?.ShortBio)
        ? agentTrustProfile!.ShortBio!.Trim()
        : "I'll personally help you understand what options may fit your situation and answer any questions you have.";
    var finalSubmitButtonText = showAgentTrustCard
        ? $"Review My Options With {agentGreetingName}"
        : cfg.SubmitButtonText;
}

<style>
/* ================================================================
   Shared Life Wizard — Mobile-first, micro-step, premium styling
   ================================================================ */
body { background: radial-gradient(120% 140% at 50% 0%, #12203c 0%, #0b1529 40%, #0a1121 100%); color: #f8fafc; }

/* site.css forces background:#fff !important on main, .layout-content, and .container.
   Override on this page so the dark hero shell and body gradient are visible. */
main.layout-content,
.lq-container { background: transparent !important; }

/* Page-scoped nav softening for paid landing */
body.life-landing header .navbar {
    padding: 10px 14px;
    box-shadow: 0 8px 18px rgba(0,0,0,0.22);
    background: #0b1529 !important;
    border-color: rgba(166,128,35,.55) !important;
}
body.life-landing header .nav-links,
body.life-landing header .nav-toggle,
body.life-landing header .header-bottom,
body.life-landing header .header-psalms {
    display: none !important;
}
body.life-landing header .navbar .nav-link {
    background: transparent;
    border-color: rgba(199,153,49,.45);
    color: #f6d27e !important;
    opacity: .78;
    padding: 0.6rem 1.05rem;
}
body.life-landing header .navbar .nav-link:hover,
body.life-landing header .navbar .nav-link:focus {
    opacity: 1;
    color: #fbe4a0 !important;
    background: rgba(199,153,49,0.08);
}

.lq-container{
    padding: 8px 16px 20px;
}

.lq-hero-shell{
