@model Protect_Website.Models.LifeQuoteFormModel

@{
    ViewData["Title"] = "Explore Your Life Insurance Options";
    ViewData["PageKey"] = "quote_life";
}

<style>
/* ================================================================
   LIFE QUOTE PAGE — MOBILE‑FIRST MICRO WIZARD
   ================================================================ */
body { background-color: #0f172a; color: #f8fafc; }

/* ---- Shared form primitives ---- */
.form-control,
.form-select {
    border: 1.6px solid #c79931;
    margin-bottom: 10px;
    background: #ffffff;
    color: #0f172a;
    font-size: 0.95rem;
    padding: 10px 12px;
    border-radius: 8px;
}
.form-control::placeholder { color: rgba(15,23,42,0.55); }
.form-control:focus,
.form-select:focus {
    outline: none;
    box-shadow: 0 0 0 0.2rem rgba(199,153,49,0.22);
    border-color: #c79931;
    background: #ffffff;
    color: #0f172a;
}

.btn-gold {
    background: linear-gradient(180deg, #c79931, #a68023);
    color: #fff;
    font-weight: 900;
    padding: 12px 24px;
    border-radius: 10px;
    font-size: 1rem;
    border: 1.4px solid #c79931;
    box-shadow: 0 10px 28px rgba(0,0,0,0.24);
    transition: opacity 0.15s, transform 0.12s;
}
.btn-gold:hover { opacity: 0.93; color: #fff; transform: translateY(-1px); }
.text-gold { color: #c79931; }

/* ---- Page header ---- */
.lq-header { margin-top: 18px; margin-bottom: 16px; text-align: center; }
.lq-header h1 {
    font-weight: 900;
    font-size: 2rem;
    color: #a68023;
    letter-spacing: .5px;
    margin-bottom: 6px;
}
.lq-subtext {
    color: #c79931;
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 6px;
}
.lq-trust-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
}
.lq-trust-chip {
    background: #c79931;
    color: #0f172a;
    font-weight: 800;
    border-radius: 10px;
    padding: 6px 12px;
    font-size: .9rem;
}
.lq-helper-intro { color: rgba(248,250,252,0.72); font-size: .96rem; margin-top: 2px; }

/* ---- Progress indicator (pill rail) ---- */
.lq-progress {
    max-width: 760px;
    margin: 0 auto 18px auto;
    padding: 0 12px;
}
.lq-progress-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #d5b77c;
    font-weight: 800;
    letter-spacing: .02em;
    font-size: .95rem;
    margin-bottom: 8px;
}
.lq-progress-rail {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
}
.lq-pill-step {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 12px;
    border: 1.6px solid rgba(199,153,49,0.35);
    background: linear-gradient(145deg, rgba(17,28,50,0.9), rgba(24,36,58,0.82));
    box-shadow: inset 0 0 0 1px rgba(199,153,49,0.12), 0 10px 24px rgba(0,0,0,0.18);
    transition: background 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.15s;
}
.lq-pill-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(199,153,49,0.14);
    color: #c79931;
    font-weight: 900;
    font-size: .9rem;
}
.lq-pill-label {
    font-weight: 800;
    color: rgba(248,250,252,0.8);
    font-size: .92rem;
    letter-spacing: 0.01em;
}
.lq-pill-step.active {
    border-color: #c79931;
    background: linear-gradient(135deg, #dfb75a 0%, #b88a26 45%, #916a1d 100%);
    box-shadow: 0 12px 28px rgba(0,0,0,0.34), 0 0 18px rgba(199,153,49,0.35);
    transform: translateY(-1px);
}
.lq-pill-step.active .lq-pill-num {
    background: #0f172a;
    color: #dfb75a;
}
.lq-pill-step.active .lq-pill-label { color: #0f172a; }
.lq-pill-step.complete {
    border-color: rgba(199,153,49,0.55);
    background: linear-gradient(135deg, rgba(199,153,49,0.22), rgba(199,153,49,0.12));
    box-shadow: inset 0 0 0 1px rgba(199,153,49,0.18);
}
.lq-pill-step.complete .lq-pill-num { background: rgba(199,153,49,0.25); color: #c79931; }
.lq-pill-step.complete .lq-pill-label { color: rgba(248,250,252,0.78); }

/* ---- Step cards ---- */
.lq-step-panel {
    max-width: 760px;
    width: 100%;
    margin: 0 auto 18px auto;
    background: #0f172a;
    border: 1.6px solid #c79931;
    border-radius: 12px;
    box-shadow: 0 18px 40px rgba(0,0,0,0.22);
    animation: lqFadeIn 0.22s ease;
}
.lq-inner-block {
    background: #111c32;
    border: 1.4px solid rgba(199,153,49,0.35);
    border-radius: 10px;
    padding: 18px 16px 14px 16px;
}
.lq-step-title {
    font-size: 1.2rem;
    font-weight: 900;
    color: #c79931;
    margin-bottom: 6px;
}
.lq-step-kicker {
    text-transform: uppercase;
    letter-spacing: .12em;
    font-weight: 800;
    color: rgba(248,250,252,0.55);
    font-size: .72rem;
    margin-bottom: 4px;
}
.lq-step-helper {
    font-size: .94rem;
    color: rgba(248,250,252,0.7);
    margin-bottom: 16px;
}
.lq-step-panel-pad { padding: 16px; }

@@keyframes lqFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ---- Choice card groups ---- */
.lq-choice-group { margin-bottom: 8px; }
.lq-choice-label {
    font-weight: 800;
    font-size: 1rem;
    color: #f8fafc;
    margin-bottom: 12px;
}
.lq-choice-grid {
    display: grid;
    gap: 10px;
    grid-template-columns: 1fr;
}
.lq-choice-grid.lq-grid-2 { grid-template-columns: 1fr 1fr; }
.lq-choice-grid.lq-grid-3 { grid-template-columns: 1fr 1fr; }
@@media (min-width: 600px) {
    .lq-choice-grid.lq-grid-3 { grid-template-columns: repeat(3, 1fr); }
}
.lq-card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 14px 10px;
    min-height: 58px;
    border: 1.6px solid rgba(199,153,49,0.32);
    border-radius: 10px;
    background: rgba(15,23,42,0.8);
    color: #f8fafc;
    font-weight: 800;
    font-size: .95rem;
    cursor: pointer;
    transition: border-color 0.14s, background 0.14s, box-shadow 0.14s, color 0.14s;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    line-height: 1.25;
    position: relative;
}
.lq-card:hover { border-color: #c79931; background: rgba(199,153,49,0.08); }
.lq-card input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
}
.lq-card.lq-selected,
.lq-card:has(input:checked) {
    border-color: #c79931;
    background: rgba(199,153,49,0.18);
    box-shadow: 0 0 0 2px rgba(199,153,49,0.32);
    color: #c79931;
}
.lq-card.lq-invalid { border-color: #ef4444; }
.lq-choice-error {
    color: #f87171;
    font-size: .82rem;
    margin-top: 4px;
    min-height: 18px;
    display: none;
}
.lq-choice-error.visible { display: block; }

/* ---- Step actions ---- */
.lq-step-actions { margin-top: 16px; }
.lq-step-actions.dual {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}
.lq-reassurance {
    text-align: center;
    font-size: .84rem;
    color: rgba(248,250,252,0.55);
    margin-top: 10px;
    margin-bottom: 0;
}

/* ---- Field layout ---- */
.lq-field-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    margin-bottom: 4px;
}
@@media (min-width: 720px) {
    .lq-field-row { grid-template-columns: repeat(3, 1fr); }
}
.lq-field label {
    display: block;
    margin-bottom: 6px;
    font-weight: 800;
    color: #f8fafc;
    font-size: .95rem;
}
.lq-field .form-control { margin-bottom: 0; }
.lq-field-err {
    color: #f87171;
    font-size: .8rem;
    margin-top: 4px;
    display: none;
}
.lq-field-err.visible { display: block; }

/* ---- Consent checkbox ---- */
.lq-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 0 6px 0;
    border-top: 1px solid rgba(199,153,49,0.18);
    margin-top: 14px;
}
.lq-consent-checkbox {
    width: 18px;
    height: 18px;
    margin-top: 2px;
    flex-shrink: 0;
    accent-color: #c79931;
    cursor: pointer;
}
.lq-consent-label {
    line-height: 1.5;
    color: rgba(248,250,252,0.85);
    font-size: .9rem;
    cursor: pointer;
}

/* ---- Validation alert ---- */
.lq-alert {
    background: rgba(239,68,68,0.12);
    border: 1px solid #ef4444;
    border-radius: 6px;
    color: #fca5a5;
    padding: 10px 14px;
    margin-bottom: 14px;
    font-size: .9rem;
}
.lq-alert ul { margin: 0; padding-left: 18px; }

.lq-success {
    color: #f8fafc;
    font-weight: bold;
    margin-bottom: 20px;
    font-size: 1.1rem;
}
</style>

<div class="container-narrow">

    <div class="lq-header">
        <h1>Get Your Personalized Life Insurance Review</h1>
        <div class="lq-subtext">No obligation. Personalized guidance based on your needs.</div>
        <div class="lq-trust-row">
            <span class="lq-trust-chip">No obligation</span>
            <span class="lq-trust-chip">Takes 60 Seconds</span>
        </div>
        <div class="lq-helper-intro">Tap through a few fast steps to get guided life coverage options.</div>
    </div>

    <!-- Progress Indicator -->
    <div class="lq-progress" id="lq-progress-indicator" aria-label="Form progress" role="progressbar"
         aria-valuemin="0" aria-valuemax="100" aria-valuenow="33">
        <div class="lq-progress-head">
            <span>Progress</span>
            <span id="lq-progress-percent">Step 1 of 3</span>
        </div>
        <div class="lq-progress-rail">
            <div class="lq-pill-step active" id="lq-prog-step1" aria-current="step">
                <span class="lq-pill-num">1</span>
                <span class="lq-pill-label">Age</span>
            </div>
            <div class="lq-pill-step" id="lq-prog-step2">
                <span class="lq-pill-num">2</span>
                <span class="lq-pill-label">Focus</span>
            </div>
            <div class="lq-pill-step" id="lq-prog-step3">
                <span class="lq-pill-num">3</span>
                <span class="lq-pill-label">Your Details</span>
            </div>
        </div>
    </div>

    @if (ViewBag.Success != null)
    {
        <div class="lq-success">@ViewBag.Success</div>
    }

    <form asp-action="SubmitLifeQuote" asp-controller="LifeQuote" method="post" id="lifeQuoteForm" data-form-key="quote_life_form" autocomplete="on" novalidate>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="lq-alert" role="alert">
                <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
                </ul>
            </div>
        }

        <!-- ======================== STEP 1 ======================== -->
        <div class="lq-step-panel" id="life-quote-step1" data-step="1">
            <div class="lq-step-panel-pad">
                <div class="lq-inner-block">
                    <div class="lq-step-kicker">Step 1 of 3</div>
                    <div class="lq-step-title">What is your age range?</div>
                    <p class="lq-step-helper">One tap to set the right track. We’ll auto-advance.</p>

                    <div class="lq-choice-group" id="grp-AgeRange" role="radiogroup" aria-labelledby="lbl-AgeRange" aria-required="true">
                        <div class="lq-choice-label" id="lbl-AgeRange">Select your age range.</div>
                        <div class="lq-choice-grid lq-grid-2">
                            <label class="lq-card" for="age-18-24">
                                <input type="radio" id="age-18-24" name="AgeRange" value="18–24">
                                <span>18–24</span>
                            </label>
                            <label class="lq-card" for="age-25-34">
                                <input type="radio" id="age-25-34" name="AgeRange" value="25–34">
                                <span>25–34</span>
                            </label>
                            <label class="lq-card" for="age-35-44">
                                <input type="radio" id="age-35-44" name="AgeRange" value="35–44">
                                <span>35–44</span>
                            </label>
                            <label class="lq-card" for="age-45-54">
                                <input type="radio" id="age-45-54" name="AgeRange" value="45–54">
                                <span>45–54</span>
                            </label>
                            <label class="lq-card" for="age-55-64">
                                <input type="radio" id="age-55-64" name="AgeRange" value="55–64">
                                <span>55–64</span>
                            </label>
                            <label class="lq-card" for="age-65-plus">
                                <input type="radio" id="age-65-plus" name="AgeRange" value="65+">
                                <span>65+</span>
                            </label>
                        </div>
                        <div class="lq-choice-error" id="err-AgeRange" role="alert">Please select your age range.</div>
                    </div>

                    <div class="lq-step-actions">
                        <button type="button" class="btn btn-gold btn-lg w-100 lq-next" data-next="2" data-validate="AgeRange">Next</button>
                        <p class="lq-reassurance">Takes less than a minute.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- ======================== STEP 2 ======================== -->
        <div class="lq-step-panel" id="life-quote-step2" data-step="2" style="display:none;">
            <div class="lq-step-panel-pad">
                <div class="lq-inner-block">
                    <div class="lq-step-kicker">Step 2 of 3</div>
                    <div class="lq-step-title">What are you mainly looking to protect?</div>
                    <p class="lq-step-helper">We’ll tailor the review toward your priority.</p>

                    <div class="lq-choice-group" id="grp-PrimaryReason" role="radiogroup" aria-labelledby="lbl-PrimaryReason" aria-required="true">
                        <div class="lq-choice-label" id="lbl-PrimaryReason">Choose the focus area.</div>
                        <div class="lq-choice-grid">
                            <label class="lq-card" for="reason-family">
                                <input type="radio" id="reason-family" name="PrimaryReason" value="Protect my family">
                                <span>My family</span>
                            </label>
                            <label class="lq-card" for="reason-mortgage">
                                <input type="radio" id="reason-mortgage" name="PrimaryReason" value="Cover mortgage / debts">
                                <span>My mortgage / debts</span>
                            </label>
                            <label class="lq-card" for="reason-income">
                                <input type="radio" id="reason-income" name="PrimaryReason" value="Replace income">
                                <span>My income</span>
                            </label>
                            <label class="lq-card" for="reason-final">
                                <input type="radio" id="reason-final" name="PrimaryReason" value="Final expenses">
                                <span>Final expenses</span>
                            </label>
                            <label class="lq-card" for="reason-business">
                                <input type="radio" id="reason-business" name="PrimaryReason" value="Business / key person planning">
                                <span>My business</span>
                            </label>
                            <label class="lq-card" for="reason-unsure">
                                <input type="radio" id="reason-unsure" name="PrimaryReason" value="Not sure — need guidance">
                                <span>Not sure yet</span>
                            </label>
                        </div>
                        <div class="lq-choice-error" id="err-PrimaryReason" role="alert">Please choose what you want to protect.</div>
                    </div>

                    <div class="lq-step-actions dual">
                        <button type="button" class="btn btn-outline-light w-50 lq-back" data-back="1">Back</button>
                        <button type="button" class="btn btn-gold w-50 lq-next" data-next="3" data-validate="PrimaryReason">Next</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ======================== STEP 3 ======================== -->
        <div class="lq-step-panel" id="life-quote-step3" data-step="3" style="display:none;">
            <div class="lq-step-panel-pad">
                <div class="lq-inner-block">
                    <div class="lq-step-kicker">Step 3 of 3</div>
                    <div class="lq-step-title">Where Should We Send Your Review?</div>
                    <p class="lq-step-helper">Enter your details below and we’ll follow up with personalized guidance.</p>

                    <div class="lq-field-row">
                        <div class="lq-field">
                            <label for="FirstName">First Name <span style="color:#f87171">*</span></label>
                            <input type="text" id="FirstName" name="FirstName" class="form-control" placeholder="First Name" autocomplete="given-name" />
                            <div class="lq-field-err" id="err-FirstName" role="alert">Please enter your first name.</div>
                        </div>
                        <div class="lq-field">
                            <label for="Phone">Phone <span style="color:#f87171">*</span></label>
                            <input type="tel" id="Phone" name="Phone" class="form-control" placeholder="(555) 000-0000" autocomplete="tel" inputmode="tel" />
                            <div class="lq-field-err" id="err-Phone" role="alert">Please enter your phone number.</div>
                        </div>
                        <div class="lq-field">
                            <label for="Email">Email <span style="color:#f87171">*</span></label>
                            <input type="email" id="Email" name="Email" class="form-control" placeholder="you@email.com" autocomplete="email" />
                            <div class="lq-field-err" id="err-Email" role="alert">Please enter a valid email.</div>
                        </div>
                    </div>

                    <div class="lq-consent">
                        <input asp-for="AcknowledgedDisclaimer" type="checkbox" class="lq-consent-checkbox" id="disclaimerCheckbox" />
                        <label class="lq-consent-label" for="disclaimerCheckbox">
                            I agree to be contacted regarding my life insurance inquiry and personalized coverage review.
                        </label>
                    </div>
                    <div class="lq-field-err" id="err-Consent" role="alert" style="margin-top:2px;">You must agree to continue.</div>
                    <span asp-validation-for="AcknowledgedDisclaimer" class="text-danger" style="font-size:.82rem;"></span>

                    <div class="lq-step-actions dual mt-3">
                        <button type="button" class="btn btn-outline-light w-50 lq-back" data-back="2">Back</button>
                        <button type="submit" id="life-quote-submit" class="btn btn-gold w-50">Get My Personalized Review</button>
                    </div>
                </div>
            </div>
        </div>

    </form>
</div>

<script>
(function () {
    'use strict';

    var track = (window.legendTrack && typeof window.legendTrack === 'function')
        ? window.legendTrack
        : function () {};

    var form = document.getElementById('lifeQuoteForm');
    var steps = [
        { id: 'life-quote-step1', group: 'AgeRange', err: 'err-AgeRange', focus: '#grp-AgeRange input', event: 'life_quote_age_selected' },
        { id: 'life-quote-step2', group: 'PrimaryReason', err: 'err-PrimaryReason', focus: '#grp-PrimaryReason input', event: 'life_quote_reason_selected' },
        { id: 'life-quote-step3', group: null, err: null, focus: '#FirstName' }
    ];
    var currentStep = 1;
    var autoTimer = null;

    if (!form) return;

    // Initial view analytics
    track({ EventType: 'life_quote_step1_view', PageKey: 'quote_life' });

    // ---- Progress indicator ----
    function setProgress(step) {
        var percent = Math.min(100, Math.round(step / 3 * 100));
        var percentLabel = document.getElementById('lq-progress-percent');
        var bar = document.getElementById('lq-progress-indicator');

        if (percentLabel) percentLabel.textContent = 'Step ' + step + ' of 3';
        if (bar) bar.setAttribute('aria-valuenow', percent.toString());

        for (var i = 1; i <= 3; i++) {
            var stepEl = document.getElementById('lq-prog-step' + i);
            if (!stepEl) continue;
            stepEl.classList.remove('active', 'complete');
            stepEl.removeAttribute('aria-current');
            if (i < step) {
                stepEl.classList.add('complete');
            } else if (i === step) {
                stepEl.classList.add('active');
                stepEl.setAttribute('aria-current', 'step');
            }
        }
    }

    function scrollAndFocus(selector) {
        var el = selector ? (typeof selector === 'string' ? document.querySelector(selector) : selector) : null;
        var fallbackPanel = document.getElementById('life-quote-step' + currentStep);
        var target = el || fallbackPanel;

        if (target && target.getBoundingClientRect) {
            var rect = target.getBoundingClientRect();
            var desiredTop = rect.top + window.scrollY - (window.innerHeight / 2) + (rect.height / 2);
            window.scrollTo({ top: Math.max(0, desiredTop), behavior: 'smooth' });
        } else {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        setTimeout(function () {
            if (!el) return;
            if (el.getAttribute && !el.getAttribute('tabindex')) el.setAttribute('tabindex', '-1');
            if (el.focus) el.focus({ preventScroll: true });
        }, 160);
    }

    function showStep(step, opts) {
        if (step < 1 || step > steps.length) return;
        var fromStep = currentStep;
        steps.forEach(function (s, idx) {
            var panel = document.getElementById(s.id);
            if (panel) panel.style.display = (idx + 1 === step) ? 'block' : 'none';
        });
        currentStep = step;
        setProgress(step);
        var focusTarget = steps[step - 1].focus;
        scrollAndFocus(focusTarget);
        if (fromStep === 1 && step === 2) {
            track({ EventType: 'life_quote_step1_continue', PageKey: 'quote_life' });
        }
        if (step === 3) {
            track({ EventType: 'life_quote_contact_step_view', PageKey: 'quote_life' });
            track({ EventType: 'life_quote_step2_view', PageKey: 'quote_life' }); // legacy analytics name
        }
    }

    // ---- Error helpers ----
    function showGroupError(groupName, errorId) {
        var cards = document.querySelectorAll('input[name="' + groupName + '"]');
        cards.forEach(function (r) { var card = r.closest('.lq-card'); if (card) card.classList.add('lq-invalid'); });
        var err = document.getElementById(errorId);
        if (err) err.classList.add('visible');
    }

    function clearGroupError(groupName, errorId) {
        var cards = document.querySelectorAll('input[name="' + groupName + '"]');
        cards.forEach(function (r) { var card = r.closest('.lq-card'); if (card) card.classList.remove('lq-invalid'); });
        var err = document.getElementById(errorId);
        if (err) err.classList.remove('visible');
    }

    function requireSelection(groupName, errorId) {
        if (!groupName) return true;
        var checked = document.querySelector('input[name="' + groupName + '"]:checked');
        if (!checked) {
            showGroupError(groupName, errorId);
            if (groupName === 'AgeRange') {
                track({ EventType: 'life_quote_step1_validation_error', PageKey: 'quote_life' });
            }
            return false;
        }
        clearGroupError(groupName, errorId);
        return true;
    }

    // ---- Wire radio interactions & auto-advance ----
    steps.slice(0, 2).forEach(function (s, idx) {
        var radios = document.querySelectorAll('input[name="' + s.group + '"]');
        radios.forEach(function (radio) {
            radio.addEventListener('change', function () {
                clearGroupError(s.group, s.err);
                var card = radio.closest('.lq-card');
                if (card) {
                    card.classList.add('lq-selected');
                    card.classList.remove('lq-invalid');
                }
                track({ EventType: s.event, PageKey: 'quote_life', ElementKey: s.group, ButtonLabel: radio.value });
                if (idx === 0) {
                    track({ EventType: 'life_quote_step1_select', PageKey: 'quote_life', ElementKey: s.group, ButtonLabel: radio.value });
                }
                clearTimeout(autoTimer);
                autoTimer = setTimeout(function () {
                    showStep(idx + 2);
                }, 220);
            });
        });
    });

    // ---- Next buttons ----
    document.querySelectorAll('.lq-next').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var target = parseInt(btn.getAttribute('data-next'), 10);
            var groupName = btn.getAttribute('data-validate');
            var map = {
                'AgeRange': 'err-AgeRange',
                'PrimaryReason': 'err-PrimaryReason'
            };
            if (groupName && !requireSelection(groupName, map[groupName])) {
                return;
            }
            showStep(target);
        });
    });

    // ---- Back buttons ----
    document.querySelectorAll('.lq-back').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var target = parseInt(btn.getAttribute('data-back'), 10);
            track({ EventType: 'life_quote_back_click', PageKey: 'quote_life', ElementKey: 'from_' + currentStep });
            if (currentStep === 3) {
                track({ EventType: 'life_quote_step2_back', PageKey: 'quote_life' });
            }
            showStep(target);
        });
    });

    // ---- Progress init ----
    setProgress(1);

    // ---- Field validation helpers ----
    function showFieldError(fieldId, errorId, show) {
        var field = document.getElementById(fieldId);
        var err   = document.getElementById(errorId);
        if (!field || !err) return;
        if (show) {
            field.classList.add('is-invalid');
            field.style.borderColor = '#ef4444';
            err.classList.add('visible');
        } else {
            field.classList.remove('is-invalid');
            field.style.borderColor = '';
            err.classList.remove('visible');
        }
    }

    ['FirstName', 'Phone', 'Email'].forEach(function (id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('blur', function () {
            var empty = !el.value.trim();
            showFieldError(id, 'err-' + id, empty);
        });
        el.addEventListener('input', function () {
            if (el.value.trim()) showFieldError(id, 'err-' + id, false);
        });
    });

    // ---- Form submit ----
    form.addEventListener('submit', function (event) {
        var valid = true;

    // Ensure the question steps have answers
        if (!requireSelection('AgeRange', 'err-AgeRange')) { valid = false; showStep(1); }
        else if (!requireSelection('PrimaryReason', 'err-PrimaryReason')) { valid = false; showStep(2); }

        // Validate step 4 fields
        ['FirstName', 'Phone', 'Email'].forEach(function (id) {
            var el = document.getElementById(id);
            var empty = !el || !el.value.trim();
            showFieldError(id, 'err-' + id, empty);
            if (empty) valid = false;
        });

        // Consent
        var disclaimer = document.getElementById('disclaimerCheckbox');
        var consentErr = document.getElementById('err-Consent');
        if (!disclaimer || !disclaimer.checked) {
            valid = false;
            if (consentErr) consentErr.classList.add('visible');
        } else if (consentErr) {
            consentErr.classList.remove('visible');
        }

        if (!valid) {
            event.preventDefault();
            track({ EventType: 'life_quote_submit_error', PageKey: 'quote_life' });
            return false;
        }

        // Inject hidden fields for backend model compatibility
        function ensureHidden(name, value) {
            var el = form.querySelector('input[name="' + name + '"]:not([type=\"radio\"])');
            if (!el) {
                el = document.createElement('input');
                el.type = 'hidden';
                el.name = name;
                form.appendChild(el);
            }
            el.value = value;
        }

        // Map AgeRange string → Age int (midpoint)
        var ageMap = {
            '18\u201324': 21,
            '25\u201334': 30,
            '35\u201344': 40,
            '45\u201354': 50,
            '55\u201364': 60,
            '65+': 70
        };
        var selectedAge = document.querySelector('input[name="AgeRange"]:checked');
        ensureHidden('Age', selectedAge ? (ageMap[selectedAge.value] || 30) : 30);

        // Map CoverageGoal → CoverageAmount
        var selectedCoverage = document.querySelector('input[name="CoverageGoal"]:checked');
        ensureHidden('CoverageAmount', selectedCoverage ? selectedCoverage.value : 'I need help choosing');

        track({ EventType: 'life_quote_submit_attempt', PageKey: 'quote_life' });
        track({ EventType: 'life_quote_submit_success', PageKey: 'quote_life' });
        // Allow natural form submit (server handles success + CRM posting)
    });

    // Consent live feedback
    var disclaimer = document.getElementById('disclaimerCheckbox');
    if (disclaimer) {
        disclaimer.addEventListener('change', function () {
            var consentErr = document.getElementById('err-Consent');
            if (consentErr) consentErr.classList.toggle('visible', !disclaimer.checked);
        });
    }

    // Auto-focus first interactive element on load
    scrollAndFocus('#grp-AgeRange input');
}());
</script>
