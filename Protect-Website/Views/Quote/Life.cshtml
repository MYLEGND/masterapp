    ViewData["PageKey"] = pageKey;
    ViewData["IsLandingPage"] = isStandaloneLandingExperience;
    ViewData["PageVariant"] = pageVariant;
    ViewData["PageMode"] = pageMode;
    ViewData["PageCategory"] = "quote";
    ViewData["QuoteTypeForTracking"] = cfg.OfferKey;
    ViewData["BodyClass"] = isLandingView ? $"life-landing {offerBodyClass}" : offerBodyClass;
    // Shared discovery intake for all life product types.
    IReadOnlyList<Protect_Website.Models.LifeWizardStep> viewSteps = (cfg.Steps?.Take(5).ToList() ?? new List<Protect_Website.Models.LifeWizardStep>());
    if (viewSteps.Count < 5)
    {
        var fallbackProtectOptions = normalizedOfferKey switch
        {
            "finalexpense" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children or grandchildren"),
                new("family","My loved ones"),
            },
            "mortgage" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children"),
                new("family","My household"),
                new("just_me","Just me"),
            },
            "wholelife" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children"),
                new("family","My family or legacy"),
            },
            "iul" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children"),
                new("family","My family or legacy"),
            },
            _ => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children"),
                new("family","My family"),
            }
        };

        var fallbackGoalOptions = normalizedOfferKey switch
        {
            "term" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("replace_income","Help my family stay financially steady"),
                new("mortgage_or_bills","Help protect the mortgage and major bills"),
                new("protect_term_years","Protect the years my family depends on me most"),
                new("keep_costs_affordable","Start with meaningful protection that fits my budget"),
            },
            "wholelife" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("lifelong_protection","Keep protection that stays with me for life"),
                new("cash_value_growth","Keep long-term protection with flexibility"),
                new("leave_legacy","Leave lasting support behind"),
                new("final_expenses","Keep final wishes from becoming a burden"),
            },
            "finalexpense" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("burial_costs","Help cover funeral and burial costs"),
                new("final_bills","Help cover final bills families are often left handling"),
                new("ease_family_burden","Help my loved ones avoid added financial stress"),
                new("leave_small_benefit","Create a cushion so my family is not scrambling"),
            },
            "mortgage" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("mortgage_balance","Protect the home and the mortgage"),
                new("monthly_payment","Help keep the monthly payment manageable"),
                new("stay_in_home","Help my spouse or family stay in the home"),
                new("household_bills","Protect the home and key household bills"),
            },
            "iul" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("cash_value_growth","Keep long-term protection with flexibility"),
                new("lifelong_protection","Keep protection in place for the long term"),
                new("future_access","Build future flexibility into the plan"),
                new("leave_legacy","Leave lasting support for my family"),
            },
            _ => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("replace_income","Help my family stay financially steady"),
                new("final_expenses","Help protect loved ones from final expenses"),
                new("mortgage_or_bills","Help protect the mortgage and major bills"),
                new("leave_something","Leave lasting support behind"),
            }
        };

        var fallbackCoverageOptions = normalizedOfferKey switch
        {
            "finalexpense" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("25000","$25,000"),
                new("50000","$50,000"),
                new("75000","$75,000"),
                new("100000","$100,000"),
            },
            "wholelife" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("50000","$50,000"),
                new("100000","$100,000"),
                new("250000","$250,000"),
                new("500000","$500,000"),
            },
            "term" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("1000000","$1,000,000"),
                new("2000000","$2,000,000+"),
            },
            "mortgage" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("150000","$150,000"),
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("750000","$750,000+"),
            },
            "iul" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("1000000","$1,000,000"),
                new("2000000","$2,000,000+"),
            },
            _ => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("100000","$100,000"),
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("1000000","$1,000,000+"),
            }
