  function buildPriorityContextForStep2(preview) {
    const normalized = normalizeStep2Preview(preview);
    const protectingLabel = humanizeProtectingWhoForStep2(normalized.protectingWho);
    const goalLabel = humanizeCoverageGoalForStep2(normalized.coverageGoal);
    const segments = [];

    if (protectingLabel) {
      segments.push(`protecting ${protectingLabel.toLowerCase()}`);
    }
    if (goalLabel) {
      segments.push(goalLabel);
    }

