  function syncAgePickerUi(dobValue = getSelectedDobValue(), isSelected = hasExplicitAgeSelectionInUi()) {
    const age = calculateAgeFromDob(dobValue);
    const hasValidAge = Number.isFinite(age) && age >= AGE_MIN && age <= AGE_MAX;
    const normalizedDob = parseDobValue(dobValue) ? String(dobValue || '').trim() : '';
    const pillText = hasValidAge ? `Age ${age}` : normalizedDob ? 'Outside age range' : 'Enter DOB';

    if (dateOfBirthHidden instanceof HTMLInputElement) {
      dateOfBirthHidden.value = normalizedDob;
    }

    dobInputs.forEach((input) => {
      if (input instanceof HTMLInputElement && input.value !== normalizedDob) {
        input.value = normalizedDob;
      }
    });

    agePickers.forEach((picker) => {
      picker.dataset.ageSelected = hasValidAge ? 'true' : 'false';
      picker.classList.toggle('is-active', hasValidAge);
    });

    ageDisplays.forEach((display) => {
      display.textContent = pillText;
    });

    return hasValidAge;
  }

  function extractPhoneDigits(value) {
