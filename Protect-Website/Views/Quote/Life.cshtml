          <div class="lq-contact-estimate-stat-value">${escapeHtml(productCopy.focusTwoValue)}</div>
        </div>`
      : '';

    return `
      <div class="lq-contact-estimate-wrap is-expanded-review" id="lifeStep2EstimateSummary">
        <div class="lq-contact-estimate-metrics">
          <div class="lq-contact-estimate-metric">
