@@keyframes lqSelectedAdvance {
    0% { transform: scale(1); }
    45% { transform: scale(1.022); }
    100% { transform: scale(1.006); }
}

@@keyframes lqProcessingSweep {
    0% { transform: translateX(-120%); opacity: 0; }
    35% { opacity: .75; }
    100% { transform: translateX(120%); opacity: 0; }
}

@@media (prefers-reduced-motion: reduce) {
    body.life-landing:not(.life-quote-started) .lq-hero-shell::before,
    body.life-landing:not(.life-quote-started) .lq-contact-first-hero-image,
    .lq-primary-start-cta,
    .lq-primary-start-cta::after,
    .lq-card.is-auto-advancing,
    .lq-processing-bridge::after {
        animation: none !important;
    }
}

@@media (max-width: 720px) {
    .lq-above-fold-proof,
    .lq-contact-first-proof-chips,
    .lq-low-friction-hero-chips,
    .lq-trust-row {
        gap: 8px;
        margin: 10px auto 12px;
    }

    .lq-above-fold-proof span,
    .lq-contact-first-proof-chip,
    .lq-low-friction-hero-chip,
    .lq-trust-chip {
        min-height: 34px;
        padding: 7px 11px;
        font-size: .72rem;
    }

    .lq-contact-first-hero-actions,
    .lq-low-friction-hero-actions {
        width: 100%;
        margin: 8px auto 12px;
        gap: 8px;
    }

    .lq-primary-start-cta {
        width: 100%;
        min-height: 66px;
        border-radius: 15px;
        padding: 16px 48px 16px 18px;
        font-size: 1rem;
    }

    .lq-primary-start-cta::after {
        right: 22px;
        font-size: 1.45rem;
    }

    .lq-primary-start-note {
        font-size: .84rem;
    }

    .lq-card:has(input:checked)::before {
        font-size: .58rem;
        padding: 2px 6px;
    }

    .lq-estimate-preserve-note {
        font-size: .8rem;
    }
}
</style>


