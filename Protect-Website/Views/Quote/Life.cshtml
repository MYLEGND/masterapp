            focusTwoValue: 'Structure + funding fit',
            nextStep: `Choose a time below so ${agentName} can explain the structure clearly and help confirm whether it fits your long-term plan.`
          };
        default:
          return {
            insight: `This range is built around the protection details you shared. The next step is confirming whether the coverage amount, monthly range, and purpose actually line up with what you need protected.`,
            focusOneLabel: 'Built to protect',
            focusOneValue: productName,
