    quoteStartTracked = true;
    const startTasks = [
      safeTrackingCall('form_start', () => window.legendFormTracking?.trackStart?.(form.dataset.formKey || pageKey) ?? null),
      trackQuoteStart(metadata)
    ];

    if (tracksContactFirstFlow) {
      startTasks.push(trackEvent('life_contact_first_start', {
        variantFlow: pageVariant,
        ...metadata
      }));
    }

    return Promise.allSettled(startTasks).then(() => undefined);
  }

