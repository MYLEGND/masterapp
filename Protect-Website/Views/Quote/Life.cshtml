  function clearProcessingTimer(resetBar = false) {
    if (processingTimer) {
      window.clearTimeout(processingTimer);
      processingTimer = null;
    }
    processingStageTimers.forEach((timerId) => window.clearTimeout(timerId));
    processingStageTimers = [];
    if (resetBar) {
      if (processingHeading) {
        processingHeading.textContent = defaultProcessingHeadingText;
      }
      if (processingHelper) {
        processingHelper.textContent = defaultProcessingHelperText;
      }
      if (processingNote) {
        processingNote.textContent = defaultProcessingNoteText;
      }
    }
    if (processingFill && resetBar) {
      processingFill.style.transition = 'none';
      processingFill.style.width = '0%';
      void processingFill.offsetWidth;
    }
  }

  function setFinalContactFocus(isActive) {
    document.body.classList.toggle('life-final-step-active', !!isActive);
  }

  function setActivePanel(activePanel) {
    [step1Panel, processingPanel, step2Panel].forEach((panel) => {
      if (!panel) return;
      panel.hidden = panel !== activePanel;
    });
    setFinalContactFocus(activePanel === step2Panel);
    if (heroTrustStrip) {
      heroTrustStrip.hidden = activePanel === step2Panel;
    }
    updateStickyPrimaryCtaVisibility();
    persistFunnelState();
  }

  function getNearestFunnelPanel(target) {
    if (!(target instanceof HTMLElement)) {
      return null;
    }

    if (
      target === step1Panel ||
      target === processingPanel ||
      target === step2Panel
    ) {
      return target;
    }

    return target.closest('#lifeStep2Panel, #lifeProcessingPanel, #lifeStep1Panel');
  }

  function getActiveMicroStepElement() {
    return microSteps.find((stepEl) => !stepEl.hidden) || null;
  }

  function getPanelFocusTarget(panel) {
    const funnelPanel = getNearestFunnelPanel(panel);
    if (!(funnelPanel instanceof HTMLElement)) {
      return panel instanceof HTMLElement ? panel : null;
    }

    if (funnelPanel === step1Panel) {
      return getActiveMicroStepElement()?.querySelector('.lq-step-question') || step1Progress || funnelPanel;
    }

    if (funnelPanel === processingPanel) {
      return processingHeading || funnelPanel;
    }

    if (funnelPanel === step2Panel) {
      return step2Heading || funnelPanel;
    }

    return funnelPanel.querySelector('.lq-step-title, .lq-step-question, button, input, select, textarea') || funnelPanel;
  }

  function resolveScrollTarget(target, options = {}) {
    if (!target) return target;
    const nearestFunnelPanel = getNearestFunnelPanel(target);
    if (options.preferVisiblePanel === true && nearestFunnelPanel) {
      return nearestFunnelPanel;
    }
    if (
      options.preferVisiblePanel !== true &&
      contactFirstPanel &&
      (nearestFunnelPanel === step1Panel ||
       nearestFunnelPanel === processingPanel ||
       nearestFunnelPanel === step2Panel)
    ) {
      return contactFirstPanel;
    }
    return nearestFunnelPanel || target;
  }

  function getScrollTopOffset() {
    const navbar = document.querySelector('header .navbar');
    const navbarHeight = !isPaidLandingExperience && navbar instanceof HTMLElement
      ? navbar.getBoundingClientRect().height
      : 0;
    const viewportPadding = window.matchMedia('(max-width: 767.98px)').matches ? 10 : 18;
    return navbarHeight + viewportPadding;
  }

  function ensureFocusableTarget(target) {
    if (!(target instanceof HTMLElement)) {
      return;
    }

    if (!target.hasAttribute('tabindex')) {
      target.setAttribute('tabindex', '-1');
    }
  }

  function spotlightPanel(target) {
    if (!(target instanceof HTMLElement)) {
      return;
    }

    target.classList.remove('lq-panel-spotlight');
    void target.offsetWidth;
    target.classList.add('lq-panel-spotlight');
    window.setTimeout(() => target.classList.remove('lq-panel-spotlight'), 1400);
  }

  function scrollPanelIntoView(target, behavior = 'smooth', options = {}) {
    const scrollTarget = resolveScrollTarget(target, options);
    if (!(scrollTarget instanceof HTMLElement)) return;
    const topOffset = getScrollTopOffset();
    const bottomPadding = window.matchMedia('(max-width: 767.98px)').matches ? 12 : 24;
    const targetRect = scrollTarget.getBoundingClientRect();
    let targetTop = window.scrollY + targetRect.top - topOffset;

    if (options.align === 'center') {
      const availableHeight = Math.max(0, window.innerHeight - topOffset - bottomPadding);
      const centeredOffset = Math.max(0, (availableHeight - Math.min(targetRect.height, availableHeight)) / 2);
      targetTop = window.scrollY + targetRect.top - topOffset - centeredOffset;
    }

    window.scrollTo({
      top: Math.max(0, targetTop),
      behavior
    });
  }

  function scrollIntoViewAndFocus(target, shouldFocus = false, options = {}) {
    if (!target) return;
    const focusTarget = options.focusTarget instanceof HTMLElement ? options.focusTarget : target;
    const scrollBehavior = options.behavior || ((isLandingMobile && target === step1Panel) ? 'auto' : 'smooth');
    setTimeout(() => {
      scrollPanelIntoView(target, scrollBehavior, options);
      if (options.spotlightTarget instanceof HTMLElement) {
        spotlightPanel(options.spotlightTarget);
      }
      if (shouldFocus && focusTarget instanceof HTMLElement) {
        ensureFocusableTarget(focusTarget);
        window.setTimeout(() => {
          focusTarget.focus({ preventScroll: true });
        }, 120);
      }
    }, 40);
  }

  function getFunnelPanelAlignment(target, fallback = 'center') {
    const funnelPanel = getNearestFunnelPanel(target);
    if (funnelPanel === step2Panel) {
      return 'start';
    }

    return fallback;
  }

  function focusFunnelPanel(target, options = {}) {
    const panelTarget = getNearestFunnelPanel(target) || target;
    const focusTarget = options.focusTarget instanceof HTMLElement
      ? options.focusTarget
      : getPanelFocusTarget(panelTarget);

    scrollIntoViewAndFocus(panelTarget, options.shouldFocus !== false, {
      behavior: options.behavior,
      align: options.align || getFunnelPanelAlignment(panelTarget),
      preferVisiblePanel: true,
      spotlightTarget: panelTarget instanceof HTMLElement ? panelTarget : undefined,
      focusTarget
    });
  }

  function scrollInitialFunnelIntoView() {
    const initialTarget = getVisibleFunnelPanel();
    if (!(initialTarget instanceof HTMLElement)) return;
    window.requestAnimationFrame(() => {
      window.requestAnimationFrame(() => {
        scrollPanelIntoView(initialTarget, 'auto', {
          align: getFunnelPanelAlignment(initialTarget),
          preferVisiblePanel: true
        });
      });
    });
  }

  function updateStickyPrimaryCtaVisibility() {
    if (!(stickyPrimaryCtaWrap instanceof HTMLElement) || !isLowFrictionOptionsVariant) {
      return;
    }

    const isMobileViewport = window.matchMedia('(max-width: 767.98px)').matches;
    if (!isMobileViewport || document.body.classList.contains('life-final-step-active')) {
      stickyPrimaryCtaWrap.classList.remove('is-visible');
      return;
    }

    const targetPanel = getVisibleFunnelPanel() || step1Panel || contactFirstPanel;
    if (!(targetPanel instanceof HTMLElement)) {
      stickyPrimaryCtaWrap.classList.remove('is-visible');
      return;
    }

    const rect = targetPanel.getBoundingClientRect();
    const panelVisible = rect.top < window.innerHeight * 0.72 && rect.bottom > window.innerHeight * 0.18;
    stickyPrimaryCtaWrap.classList.toggle('is-visible', !panelVisible);
  }

  function installPrimaryCtaVisibilityTracking() {
    if (!primaryCtaTargets.length) {
      return;
    }

    if (!('IntersectionObserver' in window)) {
      trackPrimaryCtaSeenOnce('fallback');
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting || primaryCtaSeenTracked) {
          return;
        }

        const placement = entry.target.getAttribute('data-primary-cta') || 'hero';
        trackPrimaryCtaSeenOnce(placement);
        observer.disconnect();
      });
    }, {
      threshold: 0.65
    });

    primaryCtaTargets.forEach((target) => observer.observe(target));
  }

  function installFirstQuestionVisibilityTracking() {
    if (!(firstQuestionElement instanceof HTMLElement)) {
      return;
    }

    if (!('IntersectionObserver' in window)) {
      if (!tracksContactFirstFlow) {
        trackFirstQuestionViewOnce();
      }
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting || firstQuestionViewTracked) {
          return;
        }

        trackFirstQuestionViewOnce();
        observer.disconnect();
      });
    }, {
      threshold: 0.6
    });

    observer.observe(firstQuestionElement);
  }

  function handleStartCtaClick(startSource) {
    void ensureQuoteStartTracked({ startSource });
    void ensureMetaLeadFormStart({ startSource });
    if (!('IntersectionObserver' in window)) {
      trackFirstQuestionViewOnce();
    }
    const activeTarget = getVisibleFunnelPanel() || step1Panel || contactFirstPanel;
    focusFunnelPanel(activeTarget, {
      behavior: 'smooth'
    });
  }

  startCtaButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const placement = button.getAttribute('data-primary-cta') || 'bridge';
      handleStartCtaClick(`${placement}_click`);
    });
  });

  installPrimaryCtaVisibilityTracking();
  installFirstQuestionVisibilityTracking();
  updateStickyPrimaryCtaVisibility();
  window.addEventListener('scroll', updateStickyPrimaryCtaVisibility, { passive: true });
  window.addEventListener('resize', updateStickyPrimaryCtaVisibility);

  function syncStepOneAnswersFromUI() {
    const protecting = selectedRadio('ProtectingWho');
    const goal = selectedRadio('CoverageGoal');
    const coverageAmount = selectedRadio('CoverageAmountOption');
    const tobaccoUse = selectedRadio('TobaccoUse');
    const selectedAgeValue = getSelectedAgeValue();
    const selectedAgeRange = getSelectedAgeBand();

    if (protecting) {
      answer1Hidden.value = protecting.value;
    } else if (answer1Hidden) {
      answer1Hidden.value = '';
    }
    if (goal) {
      answer2Hidden.value = goal.value;
      focusHidden.value = goal.dataset.label || goal.value;
    } else if (answer2Hidden) {
      answer2Hidden.value = '';
    }
    if (coverageAmountHidden) {
      coverageAmountHidden.value = coverageAmount?.value || '';
    }
    if (answer3Hidden) {
      answer3Hidden.value = tobaccoUse?.value || '';
    }
    if (ageInput) {
      ageInput.value = selectedAgeValue;
    }
    if (answer4Hidden) {
      answer4Hidden.value = selectedAgeValue;
    }
    if (ageHidden) {
      ageHidden.value = selectedAgeRange;
    }
  }

  function validateCoverageAmountOnly() {
    const coverageAmount = selectedRadio('CoverageAmountOption');
    const hasSelection = !!coverageAmount;
    showChoiceError('err-step1-coverage-amount', !hasSelection);
    return hasSelection;
  }

  function validateTobaccoOnly() {
    const tobaccoUse = selectedRadio('TobaccoUse');
    const hasSelection = !!tobaccoUse;
    showChoiceError('err-step1-tobacco-use', !hasSelection);
    return hasSelection;
  }

  function validateAgeOnly() {
    const ageValue = getSelectedAgeValue();
    const ageNum = Number.parseInt(ageValue, 10);
    const hasValidAge = hasExplicitAgeSelectionInUi()
      && Number.isFinite(ageNum)
      && ageNum >= AGE_MIN
      && ageNum <= AGE_MAX;
    showChoiceError('err-step1-age', !hasValidAge);
    return hasValidAge;
  }

  function hasSelectionForDiscoveryField(fieldName) {
    switch (fieldName) {
      case 'ProtectingWho':
      case 'CoverageGoal':
      case 'CoverageAmountOption':
      case 'TobaccoUse':
        return Boolean(selectedRadio(fieldName));
      case 'Age':
        {
          const ageValue = getSelectedAgeValue();
          const ageNum = Number.parseInt(ageValue, 10);
          return hasExplicitAgeSelectionInUi()
            && Number.isFinite(ageNum)
            && ageNum >= AGE_MIN
            && ageNum <= AGE_MAX;
        }
      default:
        return false;
    }
  }

  function getDiscoveryErrorId(fieldName) {
    switch (fieldName) {
      case 'ProtectingWho':
        return 'err-step1-protecting-who';
      case 'CoverageGoal':
        return 'err-step1-coverage-goal';
      case 'CoverageAmountOption':
        return 'err-step1-coverage-amount';
      case 'TobaccoUse':
        return 'err-step1-tobacco-use';
      case 'Age':
        return 'err-step1-age';
      default:
        return '';
    }
  }

  function getDiscoveryFieldFocusTarget(fieldName) {
    switch (fieldName) {
      case 'ProtectingWho':
        return form.querySelector('input[name="ProtectingWho"]');
      case 'CoverageGoal':
        return form.querySelector('input[name="CoverageGoal"]');
      case 'CoverageAmountOption':
        return form.querySelector('input[name="CoverageAmountOption"]');
      case 'TobaccoUse':
        return form.querySelector('input[name="TobaccoUse"]');
      case 'Age':
        return form.querySelector('[data-age-slider]');
      default:
        return null;
    }
  }

  function showMicroStep(stepIndex, shouldScroll = false, options = {}) {
    const bounded = Math.max(0, Math.min(microSteps.length - 1, stepIndex));
    currentMicroStep = bounded;
    microSteps.forEach((stepEl, i) => {
      stepEl.hidden = i !== bounded;
    });

    if (step1Progress) {
      step1Progress.textContent = `Question ${bounded + 1}`;
    }
    if (step1ProgressFill) {
      step1ProgressFill.style.width = `${((bounded + 1) / microSteps.length) * 100}%`;
    }
    if (options.trackView !== false) {
      trackEvent(microStepViewEvents[bounded], { microStep: bounded + 1 });
    }

    persistFunnelState();

    if (shouldScroll) {
      focusFunnelPanel(step1Panel, {
        shouldFocus: true
      });
    }
  }

  function showStep1(microStepIndex = 0, shouldScroll = false, options = {}) {
    clearAutoAdvanceTimer();
    clearProcessingTimer(true);
    setActivePanel(step1Panel);
    if (options.trackView !== false) {
      trackEvent('life_step1_intro_view');
    }
    showMicroStep(microStepIndex, shouldScroll, options);
  }

  function animateProcessingBar() {
    if (!processingFill) return;
    processingFill.style.transition = 'none';
    processingFill.style.width = '0%';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        processingFill.style.transition = `width ${PROCESSING_BRIDGE_MS}ms cubic-bezier(0.22, 1, 0.36, 1)`;
        processingFill.style.width = '100%';
      });
    });
  }

  function buildEstimateTrackingPayload(estimatePreview) {
    const primary = estimatePreview?.primary || {};
    const secondary = estimatePreview?.secondary || {};

    return {
      primaryPolicyType: primary.policyType || '',
      secondaryPolicyType: secondary.policyType || '',
      ageBand: estimatePreview?.ageBand || '',
      requestedCoverageAmount: estimatePreview?.requestedCoverageAmount || coverageAmountHidden?.value || '',
      tobaccoUse: estimatePreview?.tobaccoUse || answer3Hidden?.value || '',
      coverageGoal: estimatePreview?.coverageGoal || answer2Hidden?.value || '',
      protectingWho: estimatePreview?.protectingWho || answer1Hidden?.value || '',
      estimatedLow: primary.estimatedLowMonthly || '',
      estimatedHigh: primary.estimatedHighMonthly || '',
      secondaryEstimatedLow: secondary.estimatedLowMonthly || '',
      secondaryEstimatedHigh: secondary.estimatedHighMonthly || '',
      recommendationPrimaryKey: primary.policyKey || '',
      recommendationSecondaryKey: secondary.policyKey || ''
    };
  }

  async function trackEstimateSummaryView(estimatePreview) {
    if (!canRenderEstimateSummary(estimatePreview)) {
      return;
    }

    const trackingPayload = buildEstimateTrackingPayload(estimatePreview);
    trackEvent('estimate_inline_contact_view', {
      ...trackingPayload,
      placement: 'contact_step'
    });
    trackEvent('estimate_results_viewed', {
      ...trackingPayload,
      placement: 'contact_step'
    });
    await ensureMetaLeadFormStart();
    metaSignalApi?.trackRecommendationViewed(buildMetaProgressMetadata({
      recommendationPrimaryKey: trackingPayload.recommendationPrimaryKey,
      recommendationSecondaryKey: trackingPayload.recommendationSecondaryKey
    }));
    metaSignalApi?.trackStepComplete(2, 'recommendation_complete', {
      ...buildMetaProgressMetadata(),
      recommendationPrimaryKey: trackingPayload.recommendationPrimaryKey,
      recommendationSecondaryKey: trackingPayload.recommendationSecondaryKey
    });
  }

  function showProcessingBridge(shouldScroll = true) {
    clearAutoAdvanceTimer();
    clearProcessingTimer(true);
    clearEstimatePreviewCache();
    syncStepOneAnswersFromUI();
    const previewPromise = ensureEstimatePreview(true);
    setActivePanel(processingPanel);
    trackEvent('life_processing_bridge_view');
    animateProcessingNarrative();
    animateProcessingBar();
    if (shouldScroll) {
      focusFunnelPanel(processingPanel, {
        shouldFocus: true
      });
    }
    processingTimer = window.setTimeout(async () => {
      processingTimer = null;
      trackEvent('life_processing_bridge_complete');
      syncStepOneAnswersFromUI();
      try {
        const preview = await previewPromise;
        await showStep2(true, { estimatePreview: preview });
      } catch {
        trackEvent('estimate_results_error', {
          protectingWho: answer1Hidden?.value || '',
          coverageGoal: answer2Hidden?.value || '',
          coverageAmount: coverageAmountHidden?.value || '',
          tobaccoUse: answer3Hidden?.value || '',
          ageRange: ageHidden?.value || ''
        });
        showStep2(true, { trackRecommendationView: false });
      }
    }, PROCESSING_BRIDGE_MS + 80);
  }

  async function showStep2(shouldScroll = true, options = {}) {
    clearAutoAdvanceTimer();
    clearProcessingTimer(false);
    const estimatePreview = options.estimatePreview ?? latestEstimatePreview;
    latestEstimatePreview = estimatePreview || null;
    applyEstimatePreviewToHiddenFields(latestEstimatePreview);
    renderStep2EstimateSummary(latestEstimatePreview);
    setActivePanel(step2Panel);
    if (options.trackRecommendationView !== false) {
      await trackEstimateSummaryView(latestEstimatePreview);
    }
    if (options.trackView !== false) {
      trackContactStepViewOnce({
        handoffType: hasAgentTrustProfile ? 'agent' : 'generic'
      });
      trackEvent('estimate_contact_continue', {
        handoffType: hasAgentTrustProfile ? 'agent' : 'generic'
      });
      trackEvent('quote_contact_step_view', {
        handoffType: hasAgentTrustProfile ? 'agent' : 'generic'
      });
      trackEvent('life_step2_view', { handoffType: hasAgentTrustProfile ? 'agent' : 'generic' });
      await ensureMetaLeadFormStart();
      metaSignalApi?.trackContactStepReached(buildMetaProgressMetadata({
        handoffType: hasAgentTrustProfile ? 'agent' : 'generic'
      }));
    }
    if (shouldScroll) {
      focusFunnelPanel(step2Panel, {
        shouldFocus: true
      });
    }
  }

  function resolveInitialMicroStep() {
    for (let stepIndex = 0; stepIndex < discoveryStepSequence.length; stepIndex += 1) {
      if (!hasSelectionForDiscoveryField(discoveryStepSequence[stepIndex])) {
        return stepIndex;
      }
    }

    return Math.max(0, discoveryStepSequence.length - 1);
  }

  function validateStepOneComplete() {
    const validationResults = {
      ProtectingWho: Boolean(selectedRadio('ProtectingWho')),
      CoverageGoal: Boolean(selectedRadio('CoverageGoal')),
      CoverageAmountOption: validateCoverageAmountOnly(),
      TobaccoUse: validateTobaccoOnly(),
      Age: validateAgeOnly()
    };

    showChoiceError('err-step1-protecting-who', !validationResults.ProtectingWho);
    showChoiceError('err-step1-coverage-goal', !validationResults.CoverageGoal);
    showChoiceError('err-step1-coverage-amount', !validationResults.CoverageAmountOption);
    showChoiceError('err-step1-tobacco-use', !validationResults.TobaccoUse);

    for (const fieldName of discoveryStepSequence) {
      if (validationResults[fieldName]) {
        continue;
      }

      const trackedFieldName = fieldName === 'Age' ? 'AgeBracket' : fieldName;
      const stepIndex = discoveryStepIndexes[fieldName] ?? 0;
      trackQuoteFieldError(trackedFieldName, 'required_missing', 'discovery');
      metaSignalApi?.trackFieldError(trackedFieldName, { fieldContext: 'discovery' });
      showStep1(stepIndex, true);
      getDiscoveryFieldFocusTarget(fieldName)?.focus();
      return false;
    }

    return true;
  }

  function focusFirstInvalidContactField() {
    validateContactFields(true);
  }

  function populateAttributionFields() {
    var ids = window.legendTrackingIds;
    var p = new URLSearchParams(window.location.search);
    var attr = ids && ids.getAttribution ? (ids.getAttribution() || {}) : {};
    function set(id, v) { var el = document.getElementById(id); if (el && v) el.value = v; }
    set('SessionId',    ids && ids.getSessionId ? ids.getSessionId() : '');
    set('VisitorId',    ids && ids.getVisitorId ? ids.getVisitorId() : '');
    set('UtmSource',    attr.utmSource || p.get('utm_source') || '');
    set('UtmMedium',    attr.utmMedium || p.get('utm_medium') || '');
    set('UtmCampaign',  attr.utmCampaign || p.get('utm_campaign') || '');
    set('UtmId',        attr.utmId || p.get('utm_id') || '');
    set('UtmTerm',      attr.utmTerm || p.get('utm_term') || '');
    set('UtmContent',   attr.utmContent || p.get('utm_content') || '');
    set('MetaCampaignId', attr.metaCampaignId || p.get('meta_campaign_id') || '');
    set('MetaAdSetId',  attr.metaAdSetId || p.get('meta_adset_id') || '');
    set('MetaAdId',     attr.metaAdId || p.get('meta_ad_id') || '');
    set('Fbclid',       attr.fbclid || p.get('fbclid') || '');
    set('ReferrerUrl',  document.referrer || '');
    set('LandingPageUrl', window.location.href || '');
  }

  function resolveThankYouPath() {
    const parts = location.pathname.split('/').filter(Boolean);
    if (parts.length >= 2 && parts[0] === 'a') {
      return `/a/${parts[1]}/ThankYou`;
    }
    return '/ThankYou';
  }

  if (tracksContactFirstFlow) {
    trackEvent('life_contact_first_view', { variantFlow: pageVariant });
  }

  function queueMicroAdvance(expectedStep, nextStep) {
    if (step1Panel.hidden || currentMicroStep !== expectedStep || !Number.isFinite(nextStep) || nextStep >= microSteps.length) return;
    clearAutoAdvanceTimer();
    autoAdvanceTimer = window.setTimeout(() => showMicroStep(nextStep, true), 160);
  }

  function wireAutoAdvanceGroup(groupName, errorId, selectEvent, expectedStep, nextStep) {
    form.querySelectorAll(`input[name="${groupName}"]`).forEach((radio) => {
      radio.addEventListener('change', () => {
        showChoiceError(errorId, false);
        clearQuoteFieldError(groupName);
        clearEstimatePreviewCache();
        syncStepOneAnswersFromUI();
        persistFunnelState();
        trackEvent(selectEvent, { choice: radio.dataset.label || radio.value, code: radio.value });
        if (groupName === firstDiscoveryFieldName) {
          trackFirstQuestionAnsweredOnce(radio.value, radio.dataset.label || radio.value);
        }
        trackQuoteStepComplete(selectEvent, { choice: radio.dataset.label || radio.value, code: radio.value });
        void ensureQuoteStartTracked({ startSource: `${groupName}_change`, fieldName: groupName, choiceCode: radio.value });
        void ensureMetaLeadFormStart();
        queueMicroAdvance(expectedStep, nextStep);
      });
      radio.closest('label')?.addEventListener('click', () => {
        // Allow forward movement when revisiting a step where the choice is already selected.
        setTimeout(() => {
          if (radio.checked) queueMicroAdvance(expectedStep, nextStep);
        }, 0);
      });
    });
  }

  const protectingStepIndex = discoveryStepIndexes.ProtectingWho ?? 0;
  const goalStepIndex = discoveryStepIndexes.CoverageGoal ?? 1;
  const coverageAmountStepIndex = discoveryStepIndexes.CoverageAmountOption ?? 2;
  const ageStepIndex = discoveryStepIndexes.Age ?? (microSteps.length - 1);
  const tobaccoStepIndex = discoveryStepIndexes.TobaccoUse ?? Math.max(0, microSteps.length - 2);

  wireAutoAdvanceGroup('ProtectingWho', 'err-step1-protecting-who', 'life_step1_protecting_select', protectingStepIndex, protectingStepIndex + 1);
  form.querySelectorAll('input[name="CoverageGoal"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      showChoiceError('err-step1-coverage-goal', false);
      clearQuoteFieldError('CoverageGoal');
      clearEstimatePreviewCache();
      syncStepOneAnswersFromUI();
      persistFunnelState();
      trackEvent('life_step1_goal_select', { choice: radio.dataset.label || radio.value, code: radio.value });
      if (firstDiscoveryFieldName === 'CoverageGoal') {
        trackFirstQuestionAnsweredOnce(radio.value, radio.dataset.label || radio.value);
      }
      trackQuoteStepComplete('life_step1_goal_select', { choice: radio.dataset.label || radio.value, code: radio.value });
      void ensureQuoteStartTracked({ startSource: 'CoverageGoal_change', fieldName: 'CoverageGoal', choiceCode: radio.value });
      void ensureMetaLeadFormStart();
      if (!step1Panel.hidden && currentMicroStep === goalStepIndex) {
        clearAutoAdvanceTimer();
        autoAdvanceTimer = window.setTimeout(() => showMicroStep(goalStepIndex + 1, true), 160);
      }
    });
  });
  document.getElementById('ageStepBackBtn')?.addEventListener('click', () => {
    metaSignalApi?.trackBacktrack({ fromStep: 'age', toStep: discoveryStepSequence[Math.max(0, ageStepIndex - 1)] || 'previous' });
    showStep1(Math.max(0, ageStepIndex - 1), true);
  });
  ageStepContinueBtn?.addEventListener('click', () => {
    clearAutoAdvanceTimer();
    syncStepOneAnswersFromUI();
    if (!validateAgeOnly()) {
      trackQuoteFieldError('AgeBracket', 'required_missing', 'discovery');
      metaSignalApi?.trackFieldError('AgeBracket', { fieldContext: 'discovery' });
      form.querySelector('[data-age-slider]')?.focus();
      return;
    }

    clearEstimatePreviewCache();
    syncStepOneAnswersFromUI();
    trackEvent('life_step1_age_continue', {
      age: answer4Hidden?.value || '',
      ageRange: ageHidden?.value || ''
    });
    trackQuoteStepComplete('life_step1_age_continue', {
      age: answer4Hidden?.value || '',
      ageRange: ageHidden?.value || ''
    });
    void ensureQuoteStartTracked({ startSource: 'age_continue', fieldName: 'AgeBracket' });
    void ensureMetaLeadFormStart();
    showMicroStep(tobaccoStepIndex, true);
  });
  tobaccoStepBackBtn?.addEventListener('click', () => {
    metaSignalApi?.trackBacktrack({ fromStep: 'tobacco', toStep: 'age' });
    showStep1(Math.max(0, tobaccoStepIndex - 1), true);
  });

  wireAutoAdvanceGroup('CoverageAmountOption', 'err-step1-coverage-amount', 'life_step1_coverage_select', coverageAmountStepIndex, coverageAmountStepIndex + 1);
  wireAutoAdvanceGroup('TobaccoUse', 'err-step1-tobacco-use', 'life_step1_tobacco_select', tobaccoStepIndex, isAgeBeforeTobaccoFlow ? Number.NaN : tobaccoStepIndex + 1);

  ageSliders.forEach((slider) => {
    if (!(slider instanceof HTMLInputElement)) {
      return;
    }

    slider.addEventListener('input', () => {
      syncAgePickerUi(slider.value, true);
      showChoiceError('err-step1-age', false);
      clearQuoteFieldError('AgeBracket');
      syncStepOneAnswersFromUI();
      persistFunnelState();
    });

    slider.addEventListener('change', () => {
      syncAgePickerUi(slider.value, true);
      showChoiceError('err-step1-age', false);
      clearQuoteFieldError('AgeBracket');
      clearEstimatePreviewCache();
      syncStepOneAnswersFromUI();
      persistFunnelState();
      trackEvent('step1_age_entered', {
        ageRange: getSelectedAgeBand(),
        age: getSelectedAgeValue()
      });
      trackQuoteStepComplete('step1_age_entered', {
        ageRange: getSelectedAgeBand(),
        age: getSelectedAgeValue()
      });
      void ensureQuoteStartTracked({ startSource: 'age_change', fieldName: 'AgeBracket', ageRange: getSelectedAgeBand() });
      void ensureMetaLeadFormStart();
    });
  });
  ageQuickButtons.forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) {
      return;
    }

    button.addEventListener('click', () => {
      const nextValue = String(button.dataset.ageValue || '').trim();
      if (!nextValue) {
        return;
      }

      syncAgePickerUi(nextValue, true);
      showChoiceError('err-step1-age', false);
      clearQuoteFieldError('AgeBracket');
      clearEstimatePreviewCache();
      syncStepOneAnswersFromUI();
      persistFunnelState();
      trackEvent('step1_age_entered', {
        ageRange: getSelectedAgeBand(),
        age: getSelectedAgeValue()
      });
      trackQuoteStepComplete('step1_age_entered', {
        ageRange: getSelectedAgeBand(),
        age: getSelectedAgeValue()
      });
      void ensureQuoteStartTracked({ startSource: 'age_quick_select', fieldName: 'AgeBracket', ageRange: getSelectedAgeBand() });
      void ensureMetaLeadFormStart();
    });
  });
  document.querySelectorAll('[data-step1-back]').forEach((btn) => {
    btn.addEventListener('click', () => {
      metaSignalApi?.trackBacktrack({ fromStep: `micro_${currentMicroStep + 1}`, toStep: `micro_${btn.getAttribute('data-step1-back') || '0'}` });
      const target = Number.parseInt(btn.getAttribute('data-step1-back') || '0', 10);
      showMicroStep(Number.isFinite(target) ? target : 0, true);
    });
  });

  step1ContinueBtn?.addEventListener('click', () => {
    clearAutoAdvanceTimer();
    syncStepOneAnswersFromUI();
    if (!validateStepOneComplete()) return;
    syncStepOneAnswersFromUI();
    void ensureQuoteStartTracked({ startSource: 'step1_continue' });
    trackEvent(finalDiscoveryContinueEvent, {
      protectingWho: answer1Hidden?.value || '',
      coverageGoal: answer2Hidden?.value || '',
      coverageAmount: coverageAmountHidden?.value || '',
      tobaccoUse: answer3Hidden?.value || '',
      age: answer4Hidden?.value || '',
      ageRange: ageHidden?.value || ''
    });
    trackQuoteStepComplete(finalDiscoveryContinueEvent, {
      protectingWho: answer1Hidden?.value || '',
      coverageGoal: answer2Hidden?.value || '',
      coverageAmount: coverageAmountHidden?.value || '',
      tobaccoUse: answer3Hidden?.value || '',
      age: answer4Hidden?.value || '',
      ageRange: ageHidden?.value || ''
    });
    if (metaSignalApi?.trackDiscoveryComplete) {
      metaSignalApi.trackDiscoveryComplete(buildMetaProgressMetadata());
    } else {
      metaSignalApi?.trackStepComplete(1, 'discovery_complete', buildMetaProgressMetadata());
    }
    showProcessingBridge(true);
  });

  step2BackBtn?.addEventListener('click', () => {
    trackEvent('life_step2_back');
    metaSignalApi?.trackBacktrack({ fromStep: 'contact', toStep: 'discovery' });
    showStep1(Math.max(0, discoveryStepSequence.length - 1), true);
  });

  // form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    syncStepOneAnswersFromUI();
    if (!validateStepOneComplete()) {
      form._trackSubmitAttempt?.(false, 1);
      return;
    }

    let estimatePreview = latestEstimatePreview;
    try {
      estimatePreview = await ensureEstimatePreview();
      trackEvent('recommendation_generated', {
        primary: estimatePreview.primary?.policyKey || '',
        secondary: estimatePreview.secondary?.policyKey || '',
        coverageAmount: estimatePreview.requestedCoverageAmount || coverageAmountHidden?.value || '',
        tobaccoUse: estimatePreview.tobaccoUse || answer3Hidden?.value || '',
        ageBand: estimatePreview.ageBand || ''
      });
    } catch {
      trackEvent('estimate_results_error', {
        step: 'submit_attempt',
        protectingWho: answer1Hidden?.value || '',
        coverageGoal: answer2Hidden?.value || '',
        coverageAmount: coverageAmountHidden?.value || '',
        tobaccoUse: answer3Hidden?.value || '',
        ageRange: ageHidden?.value || ''
      });
    }

    const lifeError = document.getElementById('lifeError');
    const lifeSuccess = document.getElementById('lifeSuccess');
    if (lifeError) lifeError.style.display = 'none';
    if (lifeSuccess) lifeSuccess.style.display = 'none';
    ['FirstName','LastName','Phone','Email','State','ContactMethod','MarketingEmailConsent'].forEach(clearFieldError);
    await showStep2(false, {
      estimatePreview,
      trackView: false,
      trackRecommendationView: false
    });

    // contact validation
    if (!validateContactFields(true)) {
      if (lifeError) {
        lifeError.textContent = 'Please complete the highlighted contact fields.';
        lifeError.style.display = 'block';
      }
      await showStep2(false, {
        estimatePreview,
        trackView: false,
        trackRecommendationView: false
      });
      form._trackSubmitAttempt?.(false, 1);
      return;
    }

    const submitTrackingMetadata = {
      handoffType: hasAgentTrustProfile ? 'agent' : 'generic',
      recommendationPrimaryKey: estimatePreview?.primary?.policyKey || recPrimaryKeyEl?.value || '',
      recommendationSecondaryKey: estimatePreview?.secondary?.policyKey || recSecondaryKeyEl?.value || ''
    };

    if (tracksContactFirstFlow) {
      trackEvent('life_contact_first_submit_attempt', { variantFlow: pageVariant });
    }
    trackEvent('lead_form_submit_attempt', submitTrackingMetadata);
    trackEvent('life_step2_submit_attempt', submitTrackingMetadata);
    form._trackSubmitAttempt?.(true, 0);
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
    }

    populateAttributionFields();

    trackFormSubmitOutcome('attempt', {
      step: 'submit_attempt',
      protectingWho: answer1Hidden?.value || '',
      coverageGoal: answer2Hidden?.value || '',
      coverageAmount: coverageAmountHidden?.value || '',
      tobaccoUse: answer3Hidden?.value || '',
      age: answer4Hidden?.value || '',
      ageRange: ageHidden.value,
      protectFocus: focusHidden.value,
      recommendationPrimaryKey: estimatePreview?.primary?.policyKey || recPrimaryKeyEl?.value || '',
      recommendationSecondaryKey: estimatePreview?.secondary?.policyKey || recSecondaryKeyEl?.value || ''
    });
    metaSignalApi?.trackSubmitAttempt(buildMetaProgressMetadata({
      requiredContactFieldsComplete: true,
      contactStepReached: true
    }));

    try {
      const res = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'X-Requested-With': 'fetch' } });
      if (!res.ok) throw new Error('Network');
      const responseBody = await res.json().catch(() => ({}));
      const leadId = typeof responseBody.leadId === 'string' ? responseBody.leadId.trim() : '';
      const metaLeadEventId = typeof responseBody.metaLeadEventId === 'string' ? responseBody.metaLeadEventId.trim() : '';
      metaSignalApi?.markSubmitted({ leadId, metaLeadEventId, requiredContactFieldsComplete: true, contactStepReached: true });
      form._trackSubmitSuccess?.();
      if (tracksContactFirstFlow) {
        await flushContactFirstSuccessTracking(leadId, metaLeadEventId);
      } else {
        await flushSuccessTracking(leadId, metaLeadEventId);
      }
      clearPersistedFunnelState();
      window.location.href = resolveThankYouPath();
    } catch (err) {
      if (lifeError) {
        lifeError.textContent = 'We could not send this right now. Please try again.';
        lifeError.style.display = 'block';
      }
      trackEvent('lead_form_submit_failure', {
        handoffType: hasAgentTrustProfile ? 'agent' : 'generic',
        errorMessage: err instanceof Error ? err.message : 'submit_failed'
      });
      trackFormSubmitOutcome('error');
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = submitLabel;
      }
    }
  });

  const restoredFunnelState = await restorePersistedFunnelState();
  if (!restoredFunnelState) {
    syncStepOneAnswersFromUI();
    if (showContactStepByDefault) {
      showStep2(false);
    } else {
      const initMicro = resolveInitialMicroStep();
      showStep1(initMicro, false);
    }
  }
  scrollInitialFunnelIntoView();
  if (showContactStepByDefault && hasServerErrors) {
    setTimeout(() => focusFirstInvalidContactField(), 30);
  }
  window.addEventListener('pagehide', () => {
    syncStepOneAnswersFromUI();
