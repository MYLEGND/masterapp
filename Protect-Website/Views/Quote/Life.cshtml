                                var choiceMeta = GetChoiceCardMeta("ProtectingWho", opt.Code);
                                <label class="lq-card lq-card-rich @choiceMeta.ToneClass@(string.Equals(choiceMeta.VisualMode, "none", StringComparison.OrdinalIgnoreCase) ? " no-visual" : "")">
                                    <input type="radio" name="ProtectingWho" value="@opt.Code" data-label="@opt.Label" @(isChecked ? "checked" : null) />
                                    @if (!string.Equals(choiceMeta.VisualMode, "none", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="lq-card-visual" aria-hidden="true">
                                            <svg class="lq-card-icon" viewBox="0 0 48 48" fill="none">
                                                <use href="@($"#{choiceMeta.VisualValue}")"></use>
                                            </svg>
                                        </span>
                                    }
                                    <span class="lq-card-copy">
                                        <span class="lq-card-kicker">@choiceMeta.Kicker</span>
                                        <span class="lq-card-title">@opt.Label</span>
                                        <span class="lq-card-helper">@choiceMeta.Helper</span>
                                    </span>
                                </label>
                            }
                        </div>
                        <div class="lq-choice-error" id="err-step1-protecting-who">Please choose who you want to protect.</div>
                        @if (showInlineMobileTrustBlock)
                        {
                            <div class="lq-human-strip lq-human-strip-soft lq-human-strip-inline" role="note" aria-label="@heroTrustAriaLabel">
