/* Step panels — frame layer sits between outer shell and inner surface */
.lq-step-panel {
    max-width: 760px;
    width: 100%;
    margin: 0 auto 12px auto;
    background: #122541;
    border: 1.5px solid rgba(199,153,49,.44);
    border-radius: 12px;
    box-shadow: 0 16px 34px rgba(0,0,0,0.30);
    animation: lqFadeIn 0.22s ease;
    position: relative;
}
.lq-inner-block {
    /* Primary interaction surface — noticeably lighter than the panel frame
       so the eye reads it immediately as the place to act. */
    background: #1c2f4e;
    border: 1.4px solid rgba(199,153,49,0.60);
    border-radius: 12px;
    padding: 20px 18px 16px 18px;
    /* Subtle elevation: modest drop shadow + 1px gold rim at the top edge */
    box-shadow:
        0 8px 24px rgba(0,0,0,0.26),
        inset 0 1px 0 rgba(199,153,49,0.11);
}
.lq-step-title {
    font-size: 1.2rem;
    font-weight: 900;
    color: #c79931;
    margin-bottom: 6px;
}
.lq-step-helper {
    font-size: .94rem;
    color: rgba(248,250,252,0.7);
    margin-bottom: 16px;
}
.lq-step-panel-pad { padding: 14px; }

@@keyframes lqFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
}

