                                <div class="lq-contact-capture-kicker">Your licensed review</div>
                                <div class="lq-agent-handoff-head">
                                    <div class="lq-agent-identity">
                                        <div class="lq-agent-avatar" aria-hidden="true">
                                            @if (!string.IsNullOrWhiteSpace(contactFirstTrustImageUrl))
                                            {
                                                <img src="@contactFirstTrustImageUrl" alt="" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.hidden=false;" />
                                            }
                                            <span class="lq-agent-avatar-fallback" @(!string.IsNullOrWhiteSpace(contactFirstTrustImageUrl) ? "hidden" : null)>@contactFirstTrustInitials</span>
                                        </div>
                                    </div>
                                    <div>
                                        <div class="lq-agent-name">@contactFirstTrustIntroLine</div>
                                        <div class="lq-agent-display-name">@agentTrustHeadline</div>
                                        <div class="lq-agent-bio">@resolvedAgentTrustMessage</div>
                                        @if (!string.IsNullOrWhiteSpace(agentTrustNpn))
                                        {
                                            <div class="lq-agent-license">NPN @agentTrustNpn</div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="lq-contact-capture-kicker">@stepTwoContactKickerText</div>
                            <div class="lq-contact-capture-title" id="lifeStep2ContactTitle">@stepTwoContactTitleText</div>
                            <div class="lq-contact-capture-copy" id="lifeStep2ContactCopy">@stepTwoContactCopyText</div>
                        </div>
                        @if (showCarrierReviewBeforeContact)
                        {
                            <div class="full">
                                @if (showCarrierDisclosure)
                                {
                                    <details class="lq-carrier-disclosure">
                                        <summary class="lq-carrier-disclosure-summary">Carriers we may review</summary>
                                        <div class="lq-carrier-disclosure-body">
                                            @await Html.PartialAsync("_TrustedCarrierStrip", carrierTrustContactStripModel)
                                        </div>
                                    </details>
                                }
                                else
                                {
                                    @await Html.PartialAsync("_TrustedCarrierStrip", carrierTrustContactStripModel)
                                }
                            </div>
                        }
                        <div class="lq-field-row two full">
                            <div class="lq-field">
                                <label for="FirstName">First Name <span class="lq-required-star">*</span></label>
                                <input type="text" id="FirstName" name="FirstName" class="form-control" autocomplete="given-name" value="@form.FirstName" required />
                                <div class="lq-field-err" id="err-FirstName">Please enter your first name.</div>
                            </div>
                            <div class="lq-field">
                                <label for="LastName">Last Name <span class="lq-required-star">*</span></label>
                                <input type="text" id="LastName" name="LastName" class="form-control" autocomplete="family-name" value="@form.LastName" required />
                                <div class="lq-field-err" id="err-LastName">Please enter your last name.</div>
                            </div>
                        </div>
                        <div class="lq-field-row two full">
