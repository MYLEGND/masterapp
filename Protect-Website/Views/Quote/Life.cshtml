  function syncStep2PanelMessaging(preview, options = {}) {
    const expanded = options.expanded === true;
    if (!canRenderEstimateSummary(preview)) {
      if (step2Progress) step2Progress.textContent = defaultStep2ProgressText;
      if (step2Heading) step2Heading.textContent = defaultStep2HeadingText;
      if (step2Helper) {
        step2Helper.textContent = defaultStep2HelperText;
        step2Helper.hidden = defaultStep2HelperHidden;
      }
      if (step2ContactTitle) step2ContactTitle.textContent = defaultStep2ContactTitleText;
      if (step2ContactCopy) step2ContactCopy.textContent = defaultStep2ContactCopyText;
      if (step2ContactMethodHelp) step2ContactMethodHelp.textContent = defaultStep2ContactMethodHelpText;
      return;
    }

    if (step2Progress) {
      step2Progress.textContent = expanded ? 'Review ready' : 'Estimate preview';
    }

    if (step2Heading) {
      step2Heading.textContent = expanded ? postSubmitSuccessHeadingText : 'Your starting range is ready';
    }

    if (step2Helper) {
      step2Helper.hidden = false;
      step2Helper.textContent = expanded ? resolvePostSubmitSuccessHelperText(preview) : 'Unlock the full carrier fit, coverage direction, and next best step.';
    }

    if (step2ContactTitle) {
      step2ContactTitle.textContent = defaultStep2ContactTitleText;
    }

    if (step2ContactCopy) {
      step2ContactCopy.textContent = defaultStep2ContactCopyText;
    }

    if (step2ContactMethodHelp) {
      step2ContactMethodHelp.textContent = defaultStep2ContactMethodHelpText;
    }
  }

  function renderStep2EstimateSummary(preview, options = {}) {
    if (!step2EstimateSlot) {
      return;
    }

    if (!canRenderEstimateSummary(preview)) {
      syncStep2PanelMessaging(null, options);
      step2EstimateSlot.innerHTML = '';
      step2EstimateSlot.hidden = true;
      return;
    }

    const expanded = options.expanded === true;
    step2EstimateSlot.innerHTML = expanded
      ? buildPostSubmitEstimateSummaryHtml(preview)
      : buildPreSubmitEstimateSummaryHtml(preview);
    syncStep2PanelMessaging(preview, options);
    step2EstimateSlot.hidden = false;
  }

  function clearEstimatePreviewCache() {
    latestEstimatePreview = null;
    estimatePreviewPromise = null;
    renderStep2EstimateSummary(null);
    applyEstimatePreviewToHiddenFields(null);
    persistFunnelState();
  }

  function applyEstimatePreviewToHiddenFields(preview) {
    if (recPrimaryKeyEl) recPrimaryKeyEl.value = preview?.primary?.policyKey || '';
    if (recPrimaryTitleEl) recPrimaryTitleEl.value = preview?.primary?.policyType || '';
    if (recSecondaryKeyEl) recSecondaryKeyEl.value = preview?.secondary?.policyKey || '';
    if (recSecondaryTitleEl) recSecondaryTitleEl.value = preview?.secondary?.policyType || '';
  }

  async function ensureEstimatePreview(forceRefresh = false) {
    syncStepOneAnswersFromUI();

    if (!window.lifeEstimateEngine?.fetchPreview) {
      throw new Error('life_estimate_engine_unavailable');
    }

    if (!forceRefresh && latestEstimatePreview) {
      return latestEstimatePreview;
    }

    if (!forceRefresh && estimatePreviewPromise) {
      return estimatePreviewPromise;
    }

    estimatePreviewPromise = window.lifeEstimateEngine.fetchPreview(form, estimatePreviewUrl)
      .then((preview) => {
        latestEstimatePreview = preview;
        applyEstimatePreviewToHiddenFields(preview);
        return preview;
      })
      .finally(() => {
        estimatePreviewPromise = null;
      });

    return estimatePreviewPromise;
  }

  const formTrackingKey = form.dataset.formKey || pageKey;
  const TRACKED_FIELD_NAME_MAP = Object.freeze({
    ProtectingWho: 'step_2_choice',
    CoverageGoal: 'step_1_choice',
    CoverageAmountOption: 'coverage_amount',
    TobaccoUse: 'tobacco_use',
    AgeBracket: 'age_range',
    FirstName: 'first_name',
    LastName: 'last_name',
    ContactMethod: 'contact_method',
    Phone: 'phone',
    Email: 'email',
    State: 'state',
    MarketingEmailConsent: 'consent_contact',
  });

  function resolveTrackedFieldName(name) {
    return TRACKED_FIELD_NAME_MAP[name] || String(name || 'unknown').trim().toLowerCase();
  }

  function trackQuoteFieldError(name, errorType, fieldContext) {
    const trackedFieldName = resolveTrackedFieldName(name);
    if (window.legendFormTracking?.trackFieldError) {
      void safeTrackingCall(`field_error:${trackedFieldName}`, () => window.legendFormTracking.trackFieldError(formTrackingKey, trackedFieldName, errorType, '@cfg.OfferKey'));
    }

    if (!window.legendFormTracking && typeof window.LegendAnalytics?.track === 'function') {
      void safeTrackingCall(`field_error:${trackedFieldName}`, () => window.LegendAnalytics.track({
        EventType: 'form_field_error',
        FormKey: formTrackingKey,
        FieldName: trackedFieldName,
        MetadataJson: JSON.stringify({
          errorType,
          fieldContext,
          pageVariant,
          pageMode,
        }),
      }));
    }
  }

  function clearQuoteFieldError(name) {
    const trackedFieldName = resolveTrackedFieldName(name);
    try {
      window.legendFormTracking?.clearFieldError(formTrackingKey, trackedFieldName);
    } catch (error) {
      console.warn(`[LifeQuote] clear field error failed for ${trackedFieldName}`, error);
    }
  }

  function showChoiceError(errorId, show) {
    const el = document.getElementById(errorId);
    if (!el) return;
    el.classList.toggle('visible', !!show);
  }

  function setFieldError(name, message) {
    const el = document.getElementById(`err-${name}`);
    if (!el) return;
    if (!el.dataset.defaultText) {
      el.dataset.defaultText = el.textContent || '';
    }
    el.textContent = message || el.dataset.defaultText;
    el.classList.add('visible');
  }

  function clearFieldError(name) {
    const el = document.getElementById(`err-${name}`);
    clearQuoteFieldError(name);
    if (!el) return;
    if (el.dataset.defaultText) {
      el.textContent = el.dataset.defaultText;
    }
    el.classList.remove('visible');
  }

  function applyServerValidationErrors(fieldErrors) {
    if (!fieldErrors || typeof fieldErrors !== 'object') {
      return false;
    }

    let applied = false;

    Object.entries(fieldErrors).forEach(([name, messages]) => {
      const normalizedName = asTrimmed(name);
      const firstMessage = Array.isArray(messages) ? asTrimmed(messages[0] || '') : '';
      if (!normalizedName || !firstMessage || normalizedName === 'Form') {
        return;
      }

      switch (normalizedName) {
        case 'ProtectingWho':
          showChoiceError('err-step1-protecting-who', true);
          applied = true;
          return;
        case 'CoverageGoal':
          showChoiceError('err-step1-coverage-goal', true);
          applied = true;
          return;
        case 'CoverageAmountOption':
          showChoiceError('err-step1-coverage-amount', true);
          applied = true;
          return;
        case 'TobaccoUse':
          showChoiceError('err-step1-tobacco-use', true);
          applied = true;
          return;
        case 'Age':
        case 'AgeRange':
        case 'AgeBracket':
        case 'Answer4':
          showChoiceError('err-step1-age', true);
          applied = true;
          return;
        default:
          setFieldError(normalizedName, firstMessage);
          applied = true;
          return;
      }
    });

    return applied;
  }

  function getContactFieldError(name) {
    if (name === 'ContactMethod') {
      const phoneValue = asTrimmed(form.querySelector('[name="Phone"]')?.value || '');
      const emailValue = asTrimmed(form.querySelector('[name="Email"]')?.value || '');
      return phoneValue || emailValue ? '' : contactMethodErrorText;
    }

    if (name === 'MarketingEmailConsent') {
      return consentCheckbox?.checked ? '' : consentErrorText;
    }

    const el = form.querySelector(`[name="${name}"]`);
    if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement)) {
      return '';
    }

    const value = asTrimmed(el.value);
    if (name === 'Email') {
      if (!value) {
        return requiredContactFields.includes(name) ? 'Please enter your email.' : '';
      }

      if (el instanceof HTMLInputElement && !el.checkValidity()) {
        return 'Please enter a valid email address.';
      }

      return '';
    }

    if (!value) {
      if (!requiredContactFields.includes(name)) {
        return '';
      }

      return name === 'State'
        ? 'Please select your state.'
        : `Please enter your ${name === 'Email' ? 'email' : name === 'Phone' ? 'phone' : name === 'FirstName' ? 'first name' : 'last name'}.`;
    }

    if (name === 'Phone' && extractPhoneDigits(value).length !== 10) {
      return 'Please enter a valid phone number.';
    }

    return '';
  }

  function resolveContactErrorType(name, error) {
    if (name === 'Email' && /valid email/i.test(error || '')) {
      return 'invalid_email';
    }
    if (name === 'Phone' && /valid phone/i.test(error || '')) {
      return 'invalid_phone';
    }
    if (name === 'ContactMethod') {
      return 'contact_method_required';
    }
    if (name === 'MarketingEmailConsent') {
      return 'consent_required';
    }

    return 'required_missing';
  }

  function validateContactFields(focusFirst = false) {
    let firstInvalid = null;

    requiredContactFields.forEach((name) => {
      const error = getContactFieldError(name);
      if (error) {
        setFieldError(name, error);
        trackQuoteFieldError(name, resolveContactErrorType(name, error), 'contact');
        metaSignalApi?.trackFieldError(name, { fieldContext: 'contact' });
        if (name === 'ContactMethod') {
          firstInvalid ??= form.querySelector('[name="Email"]') || form.querySelector('[name="Phone"]');
        } else {
          firstInvalid ??= form.querySelector(`[name="${name}"]`);
        }
      } else {
        clearFieldError(name);
      }
    });

    const optionalEmailError = getContactFieldError('Email');
    if (optionalEmailError) {
      setFieldError('Email', optionalEmailError);
      trackQuoteFieldError('Email', resolveContactErrorType('Email', optionalEmailError), 'contact');
      metaSignalApi?.trackFieldError('Email', { fieldContext: 'contact' });
      firstInvalid ??= form.querySelector('[name="Email"]');
    } else {
      clearFieldError('Email');
    }

    const consentError = getContactFieldError('MarketingEmailConsent');
    if (consentError) {
      setFieldError('MarketingEmailConsent', consentError);
      trackQuoteFieldError('MarketingEmailConsent', resolveContactErrorType('MarketingEmailConsent', consentError), 'contact');
      metaSignalApi?.trackFieldError('MarketingEmailConsent', { fieldContext: 'contact' });
      firstInvalid ??= consentCheckbox;
    } else {
      clearFieldError('MarketingEmailConsent');
    }

    if (focusFirst && firstInvalid instanceof HTMLElement) {
      firstInvalid.focus();
    }

    return firstInvalid === null;
  }

  function clearAutoAdvanceTimer() {
    if (autoAdvanceTimer) {
      window.clearTimeout(autoAdvanceTimer);
      autoAdvanceTimer = null;
    }
  }

  function clearProcessingTimer(resetBar = false) {
    if (processingTimer) {
      window.clearTimeout(processingTimer);
      processingTimer = null;
    }
    processingStageTimers.forEach((timerId) => window.clearTimeout(timerId));
    processingStageTimers = [];
    if (resetBar) {
      if (processingProgress) {
        processingProgress.textContent = defaultProcessingProgressText;
      }
      if (processingHeading) {
        processingHeading.textContent = defaultProcessingHeadingText;
      }
      if (processingHelper) {
        processingHelper.textContent = defaultProcessingHelperText;
      }
      if (processingNote) {
        processingNote.textContent = defaultProcessingNoteText;
      }
    }
    if (processingFill && resetBar) {
      processingFill.style.transition = 'none';
      processingFill.style.width = '0%';
      void processingFill.offsetWidth;
    }
  }

  function setFinalContactFocus(isActive) {
    document.body.classList.toggle('life-final-step-active', !!isActive);
  }

  function setActivePanel(activePanel) {
    [step1Panel, processingPanel, step2Panel].forEach((panel) => {
      if (!panel) return;
      panel.hidden = panel !== activePanel;
    });
    setFinalContactFocus(activePanel === step2Panel);
    if (heroTrustStrip) {
      heroTrustStrip.hidden = activePanel === step2Panel;
    }
    persistFunnelState();
  }

  function getNearestFunnelPanel(target) {
    if (!(target instanceof HTMLElement)) {
      return null;
    }

    if (
      target === step1Panel ||
      target === processingPanel ||
      target === step2Panel
    ) {
      return target;
    }

    return target.closest('#lifeStep2Panel, #lifeProcessingPanel, #lifeStep1Panel');
  }

  function getActiveMicroStepElement() {
    return microSteps.find((stepEl) => !stepEl.hidden) || null;
  }

  function getPanelFocusTarget(panel) {
    const funnelPanel = getNearestFunnelPanel(panel);
    if (!(funnelPanel instanceof HTMLElement)) {
      return panel instanceof HTMLElement ? panel : null;
    }

    if (funnelPanel === step1Panel) {
      return step1Progress || funnelPanel;
    }

    if (funnelPanel === processingPanel) {
      return processingHeading || funnelPanel;
    }

    if (funnelPanel === step2Panel) {
      return step2Heading || funnelPanel;
    }

    return funnelPanel.querySelector('.lq-step-title, .lq-step-question, button, input, select, textarea') || funnelPanel;
  }

  function resolveScrollTarget(target, options = {}) {
    if (!target) return target;
    const nearestFunnelPanel = getNearestFunnelPanel(target);
    if (options.preferVisiblePanel === true && nearestFunnelPanel) {
      return nearestFunnelPanel;
    }
    if (
      options.preferVisiblePanel !== true &&
      contactFirstPanel &&
      (nearestFunnelPanel === step1Panel ||
       nearestFunnelPanel === processingPanel ||
       nearestFunnelPanel === step2Panel)
    ) {
      return contactFirstPanel;
    }
    return nearestFunnelPanel || target;
  }

  function getScrollTopOffset() {
    const navbar = document.querySelector('header .navbar');
    const navbarHeight = !isPaidLandingExperience && navbar instanceof HTMLElement
      ? navbar.getBoundingClientRect().height
      : 0;
    const viewportPadding = window.matchMedia('(max-width: 767.98px)').matches ? 10 : 18;
    return navbarHeight + viewportPadding;
  }

  function ensureFocusableTarget(target) {
    if (!(target instanceof HTMLElement)) {
      return;
    }

    if (!target.hasAttribute('tabindex')) {
      target.setAttribute('tabindex', '-1');
    }
  }

  function spotlightPanel(target) {
    if (!(target instanceof HTMLElement)) {
      return;
    }

    target.classList.remove('lq-panel-spotlight');
    void target.offsetWidth;
    target.classList.add('lq-panel-spotlight');
    window.setTimeout(() => target.classList.remove('lq-panel-spotlight'), 1400);
  }

  function scrollPanelIntoView(target, behavior = 'smooth', options = {}) {
    const scrollTarget = resolveScrollTarget(target, options);
    if (!(scrollTarget instanceof HTMLElement)) return;
    const topOffset = getScrollTopOffset();
    const bottomPadding = window.matchMedia('(max-width: 767.98px)').matches ? 12 : 24;
    const targetRect = scrollTarget.getBoundingClientRect();
    let targetTop = window.scrollY + targetRect.top - topOffset;

    if (options.align === 'center') {
      const availableHeight = Math.max(0, window.innerHeight - topOffset - bottomPadding);
      const centeredOffset = Math.max(0, (availableHeight - Math.min(targetRect.height, availableHeight)) / 2);
      targetTop = window.scrollY + targetRect.top - topOffset - centeredOffset;
    }

    window.scrollTo({
      top: Math.max(0, targetTop),
      behavior
    });
  }

  function scrollIntoViewAndFocus(target, shouldFocus = false, options = {}) {
    if (!target) return;
    const focusTarget = options.focusTarget instanceof HTMLElement ? options.focusTarget : target;
    const scrollBehavior = options.behavior || ((isLandingMobile && target === step1Panel) ? 'auto' : 'smooth');
    setTimeout(() => {
      scrollPanelIntoView(target, scrollBehavior, options);
      if (options.spotlightTarget instanceof HTMLElement) {
        spotlightPanel(options.spotlightTarget);
      }
      if (shouldFocus && focusTarget instanceof HTMLElement) {
        ensureFocusableTarget(focusTarget);
        window.setTimeout(() => {
          focusTarget.focus({ preventScroll: true });
        }, 120);
      }
    }, 40);
  }

  function getFunnelPanelAlignment(target, fallback = 'center') {
    const funnelPanel = getNearestFunnelPanel(target);
    if (funnelPanel === step2Panel) {
      return 'start';
    }

    return fallback;
  }

  function focusFunnelPanel(target, options = {}) {
    const panelTarget = getNearestFunnelPanel(target) || target;
    const focusTarget = options.focusTarget instanceof HTMLElement
      ? options.focusTarget
      : getPanelFocusTarget(panelTarget);

    scrollIntoViewAndFocus(panelTarget, options.shouldFocus !== false, {
      behavior: options.behavior,
      align: options.align || getFunnelPanelAlignment(panelTarget),
      preferVisiblePanel: true,
      spotlightTarget: panelTarget instanceof HTMLElement ? panelTarget : undefined,
      focusTarget
    });
  }

  function scrollInitialFunnelIntoView() {
    const initialTarget = getVisibleFunnelPanel();
    if (!(initialTarget instanceof HTMLElement)) return;
    window.requestAnimationFrame(() => {
      window.requestAnimationFrame(() => {
        scrollPanelIntoView(initialTarget, 'auto', {
          align: getFunnelPanelAlignment(initialTarget),
          preferVisiblePanel: true
        });
      });
    });
  }

  function getPrimaryCtaCandidates() {
    return Array.from(new Set([
      ...primaryCtaTargets,
      ...new Set([
        ...document.querySelectorAll('#lifeHeroPrimaryCtaMain'),
        ...document.querySelectorAll('#lifeHeroPrimaryCtaSecondary'),
        ...document.querySelectorAll('[data-life-funnel-start]'),
        ...document.querySelectorAll('[data-primary-cta]'),
        ...document.querySelectorAll('.lq-contact-first-hero-cta'),
        ...document.querySelectorAll('.lq-low-friction-hero-cta')
      ])
    ])).filter((target) => target instanceof HTMLElement);
  }

  function isPrimaryCtaActuallyVisible(target) {
    if (!(target instanceof HTMLElement)) {
      return false;
    }

    const style = window.getComputedStyle(target);
    if (style.display === 'none' || style.visibility === 'hidden' || Number(style.opacity || 1) <= 0.05) {
      return false;
    }

    const rect = target.getBoundingClientRect();
    return rect.width > 0 &&
      rect.height > 0 &&
      rect.bottom >= 0 &&
      rect.top <= window.innerHeight &&
      rect.right >= 0 &&
      rect.left <= window.innerWidth;
  }

  function tryTrackVisiblePrimaryCta(source = 'viewport_check') {
    if (primaryCtaSeenTracked) {
      return true;
    }

    const visibleTarget = getPrimaryCtaCandidates().find(isPrimaryCtaActuallyVisible);
    if (!visibleTarget) {
      return false;
    }

    const placement = visibleTarget.getAttribute('data-primary-cta') || visibleTarget.getAttribute('data-placement') || 'hero';
    const rect = visibleTarget.getBoundingClientRect();
    trackPrimaryCtaSeenOnce(visibleTarget, placement, {
      source,
      ctaId: visibleTarget.getAttribute('data-cta') || 'life_funnel_start',
      ctaText: visibleTarget.textContent?.replace(/\s+/g, ' ')?.trim() || '',
      viewportWidth: window.innerWidth,
      viewportHeight: window.innerHeight,
      ctaTop: Math.round(rect.top),
      ctaBottom: Math.round(rect.bottom)
    });

    return true;
  }

  function installPrimaryCtaVisibilityTracking() {
    const targets = getPrimaryCtaCandidates();
    if (!targets.length) {
      return;
    }

    const runCheck = (source) => {
      window.requestAnimationFrame(() => {
        tryTrackVisiblePrimaryCta(source);
      });
    };

    runCheck('initial');
    window.setTimeout(() => tryTrackVisiblePrimaryCta('delayed_150ms'), 150);
    window.setTimeout(() => tryTrackVisiblePrimaryCta('delayed_600ms'), 600);
    window.setTimeout(() => tryTrackVisiblePrimaryCta('delayed_1200ms'), 1200);

    if (!('IntersectionObserver' in window)) {
      window.setTimeout(() => tryTrackVisiblePrimaryCta('fallback_no_intersection_observer'), 250);
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      if (primaryCtaSeenTracked) {
        observer.disconnect();
        return;
      }

      const visibleEntry = entries.find((entry) => entry.isIntersecting && isPrimaryCtaActuallyVisible(entry.target));
      if (!visibleEntry) {
        return;
      }

      const placement = visibleEntry.target.getAttribute('data-primary-cta') || visibleEntry.target.getAttribute('data-placement') || 'hero';
      trackPrimaryCtaSeenOnce(visibleEntry.target, placement, {
        source: 'intersection_observer',
        ctaId: visibleEntry.target.getAttribute('data-cta') || 'life_funnel_start',
        ctaText: visibleEntry.target.textContent?.replace(/\s+/g, ' ')?.trim() || '',
        intersectionRatio: Number(visibleEntry.intersectionRatio || 0).toFixed(2),
        viewportWidth: window.innerWidth,
        viewportHeight: window.innerHeight
      });
      observer.disconnect();
    }, {
      root: null,
      rootMargin: '160px 0px 160px 0px',
      threshold: [0, 0.01, 0.1, 0.25]
    });

    targets.forEach((target) => observer.observe(target));

    const passiveCheck = () => {
      if (tryTrackVisiblePrimaryCta('passive_visibility_check')) {
        window.removeEventListener('scroll', passiveCheck);
        window.removeEventListener('resize', passiveCheck);
        window.removeEventListener('pageshow', passiveCheck);
        window.removeEventListener('load', passiveCheck);
      }
    };

    window.addEventListener('scroll', passiveCheck, { passive: true });
    window.addEventListener('resize', passiveCheck);
    window.addEventListener('pageshow', passiveCheck);
    window.addEventListener('load', passiveCheck);
  }

  function installFirstQuestionVisibilityTracking() {
    if (!(firstQuestionElement instanceof HTMLElement)) {
      return;
    }

    if (!('IntersectionObserver' in window)) {
      if (!tracksContactFirstFlow) {
        trackFirstQuestionViewOnce();
      }
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting || firstQuestionViewTracked) {
          return;
        }

        trackFirstQuestionViewOnce();
        observer.disconnect();
      });
    }, {
      threshold: 0.6
    });

    observer.observe(firstQuestionElement);
  }

