        linear-gradient(90deg, rgba(230,192,107,0.95) 0%, rgba(230,192,107,0.95) var(--age-progress), rgba(79,97,127,0.88) var(--age-progress), rgba(42,56,82,0.88) 100%);
    box-shadow:
