        max-height: 14px;
    }

    .lq-carrier-strip-text-badge {
        font-size: .64rem;
    }

    .lq-carrier-strip-disclaimer {
        font-size: .66rem;
        line-height: 1.32;
    }

    .lq-carrier-strip-compact {
        display: none !important;
    }
}

@@media (max-width: 480px) {
    .lq-carrier-strip-logo-frame {
        width: 108px;
        height: 30px;
        padding: 0 7px;
    }

    .lq-carrier-strip-logo-frame img {
        max-width: 78px;
        max-height: 13px;
    }

    .lq-carrier-strip-viewport::before,
    .lq-carrier-strip-viewport::after {
        width: 18px;
    }
}

@@media (prefers-reduced-motion: reduce) {
