.lq-carrier-disclosure {
    width: 100%;
}

.lq-carrier-disclosure-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    list-style: none;
    cursor: pointer;
    padding: 12px 14px;
    border-radius: 14px;
    border: 1px solid rgba(208, 162, 68, 0.22);
    background:
        linear-gradient(180deg, rgba(14, 19, 31, 0.90) 0%, rgba(8, 11, 19, 0.92) 100%);
    color: rgba(249, 236, 204, 0.92);
    font-size: .82rem;
    font-weight: 820;
    line-height: 1.3;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.03),
        0 10px 20px rgba(0,0,0,0.16);
}

.lq-carrier-disclosure-summary::-webkit-details-marker {
    display: none;
}

.lq-carrier-disclosure-summary::after {
    content: '+';
    flex: 0 0 auto;
    color: #f3d78f;
    font-size: 1rem;
    font-weight: 900;
}

.lq-carrier-disclosure[open] .lq-carrier-disclosure-summary::after {
    content: '−';
}

.lq-carrier-disclosure-body {
    margin-top: 10px;
}

@@media (min-width: 768px) {
