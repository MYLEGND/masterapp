.lq-carrier-strip {
    --carrier-marquee-gap: 10px;
    --carrier-marquee-distance: 0px;
    --carrier-marquee-duration: 44s;
    display: grid;
    gap: 10px;
    width: 100%;
    margin-top: 14px;
    padding: 12px 13px 11px;
    border-radius: 16px;
    border: 1px solid rgba(208, 162, 68, 0.28);
    background-color: rgba(10, 14, 24, 0.72) !important;
    background-image:
        radial-gradient(circle at top right, rgba(208, 162, 68, 0.10), transparent 34%),
        linear-gradient(180deg, rgba(15, 20, 33, 0.92) 0%, rgba(8, 11, 19, 0.94) 100%) !important;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.03),
        0 14px 28px rgba(0,0,0,0.22);
    box-sizing: border-box;
    overflow: hidden;
    isolation: isolate;
}

.lq-carrier-strip-copy {
    color: rgba(249, 236, 204, 0.94);
    font-size: .84rem;
    font-weight: 780;
    line-height: 1.42;
    margin: 0;
}

.lq-carrier-strip-compact {
    --carrier-marquee-gap: 8px;
    margin-top: 0;
    padding: 10px 11px 10px;
    border-radius: 14px;
    border-color: rgba(208, 162, 68, 0.20);
    background-color: rgba(9, 12, 21, 0.68) !important;
    background-image:
        linear-gradient(180deg, rgba(14, 19, 31, 0.88) 0%, rgba(8, 11, 19, 0.90) 100%) !important;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.02),
        0 10px 20px rgba(0,0,0,0.16);
}

.lq-carrier-strip-compact .lq-carrier-strip-copy {
    font-size: .78rem;
    color: rgba(242, 229, 197, 0.84);
}

.lq-carrier-strip-viewport {
    position: relative;
    overflow-x: auto;
    overflow-y: hidden;
    max-width: 100%;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x;
    scrollbar-width: none;
}
.lq-carrier-strip-viewport::-webkit-scrollbar {
    display: none;
}

.lq-carrier-strip-viewport::before,
.lq-carrier-strip-viewport::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 34px;
    z-index: 2;
    pointer-events: none;
}

.lq-carrier-strip-viewport::before {
    left: 0;
    background: linear-gradient(90deg, rgba(8, 11, 19, 0.96) 0%, rgba(8, 11, 19, 0) 100%);
}

.lq-carrier-strip-viewport::after {
    right: 0;
    background: linear-gradient(270deg, rgba(8, 11, 19, 0.96) 0%, rgba(8, 11, 19, 0) 100%);
}

.lq-carrier-strip-track {
    display: flex;
    align-items: center;
    gap: var(--carrier-marquee-gap);
    width: max-content;
    animation: lqCarrierMarquee var(--carrier-marquee-duration) linear infinite;
    will-change: transform;
    transform: translate3d(0, 0, 0);
    backface-visibility: hidden;
}

.lq-carrier-strip:hover .lq-carrier-strip-track,
.lq-carrier-strip:focus-within .lq-carrier-strip-track {
    animation-play-state: paused;
}

.lq-carrier-strip-group {
    display: flex;
    align-items: center;
    gap: var(--carrier-marquee-gap);
    flex-shrink: 0;
}

.lq-carrier-strip-item {
    flex: 0 0 auto;
}

.lq-carrier-strip-logo-frame {
    width: 136px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 13px;
    border: 1px solid rgba(205, 159, 68, 0.28);
    background-color: rgba(14, 18, 30, 0.94) !important;
    background-image:
        linear-gradient(180deg, rgba(45, 54, 73, 0.20) 0%, rgba(9, 13, 22, 0.16) 100%) !important;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.04),
        inset 0 -1px 0 rgba(0,0,0,0.18),
        0 8px 16px rgba(0,0,0,0.12);
    padding: 0 10px;
    box-sizing: border-box;
}

.lq-carrier-strip-compact .lq-carrier-strip-logo-frame {
    width: 126px;
    height: 34px;
    border-radius: 11px;
}

.lq-carrier-strip-logo-frame img {
    display: block;
    max-width: 104px;
    max-height: 18px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(1) brightness(1.22);
    opacity: 0.62;
    transition: opacity .2s ease, filter .2s ease, transform .2s ease;
}

.lq-carrier-strip-compact .lq-carrier-strip-logo-frame img {
    max-width: 94px;
    max-height: 16px;
}

.lq-carrier-strip-item:hover img,
.lq-carrier-strip-item:focus-within img {
    opacity: 0.9;
    filter: grayscale(0.25) brightness(1.36);
    transform: translateY(-1px);
}

.lq-carrier-strip-text-badge {
    display: none;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    text-align: center;
    color: rgba(248, 238, 214, 0.92);
    font-size: .72rem;
    font-weight: 780;
    line-height: 1.15;
    letter-spacing: .01em;
}

.lq-carrier-strip-item.is-fallback .lq-carrier-strip-text-badge {
    display: inline-flex;
}

.lq-carrier-strip.is-text-only .lq-carrier-strip-text-badge {
    display: inline-flex;
}

.lq-carrier-strip-item.is-fallback img {
    display: none;
}

.lq-carrier-strip.is-text-only .lq-carrier-strip-logo-frame,
.lq-carrier-strip-item.is-fallback .lq-carrier-strip-logo-frame {
    border-color: rgba(216, 174, 84, 0.34);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.05),
        inset 0 -1px 0 rgba(0,0,0,0.22),
        0 10px 18px rgba(0,0,0,0.16);
}

.lq-carrier-strip-disclaimer {
    color: rgba(226, 232, 241, 0.66);
    font-size: .73rem;
    line-height: 1.42;
}

.lq-carrier-strip-compact .lq-carrier-strip-disclaimer {
    font-size: .69rem;
    color: rgba(226, 232, 241, 0.58);
}

@@keyframes lqCarrierMarquee {
    from { transform: translate3d(0, 0, 0); }
    to { transform: translate3d(calc(-1 * var(--carrier-marquee-distance)), 0, 0); }
}

@@media (prefers-reduced-motion: reduce) {
    .lq-carrier-strip-viewport {
        overflow-x: auto;
        padding-bottom: 2px;
        scrollbar-width: thin;
    }

    .lq-carrier-strip-track {
        animation: none !important;
        width: max-content;
        flex-wrap: nowrap;
        transform: none !important;
    }

    .lq-carrier-strip-group[aria-hidden="true"] {
        display: none;
    }

    .lq-carrier-strip-viewport::before,
    .lq-carrier-strip-viewport::after {
        display: none;
    }
}

@@media (max-width: 767.98px) {
    .lq-carrier-strip {
        margin-top: 12px;
        padding: 10px 10px 9px;
        border-radius: 14px;
    }

    .lq-carrier-strip-viewport {
        overflow-x: auto;
        padding-bottom: 2px;
        overscroll-behavior-x: contain;
        scroll-snap-type: x proximity;
        -webkit-overflow-scrolling: touch;
        touch-action: pan-x;
    }

    .lq-carrier-strip-track {
        animation: none !important;
        width: max-content;
        transform: none !important;
    }

    .lq-carrier-strip-group[aria-hidden="true"] {
        display: none;
    }

    .lq-carrier-strip-item {
        scroll-snap-align: start;
    }

    .lq-carrier-strip-copy {
        font-size: .78rem;
    }

    .lq-carrier-strip-logo-frame {
        width: 118px;
        height: 32px;
        padding: 0 8px;
        border-radius: 12px;
    }

    .lq-carrier-strip-logo-frame img {
        max-width: 84px;
        max-height: 14px;
    }

    .lq-carrier-strip-text-badge {
        font-size: .64rem;
    }

    .lq-carrier-strip-disclaimer {
        font-size: .66rem;
        line-height: 1.32;
    }

    .lq-carrier-strip-compact {
        display: none !important;
    }
}

@@media (max-width: 480px) {
    .lq-carrier-strip-logo-frame {
        width: 108px;
        height: 30px;
        padding: 0 7px;
    }

    .lq-carrier-strip-logo-frame img {
        max-width: 78px;
        max-height: 13px;
    }

    .lq-carrier-strip-viewport::before,
    .lq-carrier-strip-viewport::after {
        width: 18px;
    }
}

@@media (prefers-reduced-motion: reduce) {
    .lq-funnel-bridge-arrow svg {
        animation: none !important;
    }
}

@@media (max-width: 640px) {
    .lq-funnel-bridge-wrap {
        margin: 0 auto 10px;
    }

    .lq-funnel-bridge {
        gap: 8px;
    }

    .lq-funnel-bridge-core {
        min-height: 38px;
        padding: 6px 11px;
        gap: 8px;
    }

    .lq-funnel-bridge-copy {
        font-size: .74rem;
    }

    .lq-funnel-bridge-arrow {
        width: 24px;
        height: 24px;
    }

    .lq-funnel-bridge-arrow svg {
        width: 13px;
        height: 13px;
    }
}

@@media (max-width: 480px) {
    .lq-funnel-bridge {
        grid-template-columns: 12px minmax(0,1fr) 12px;
    }

    .lq-funnel-bridge-core {
        justify-content: center;
        width: 100%;
    }

    .lq-funnel-bridge-copy {
        text-align: center;
    }
}

