        {
            new(fallbackGoalQuestion, fallbackGoalOptions, "CoverageGoal"),
            new(fallbackProtectQuestion, fallbackProtectOptions, "ProtectingWho"),
            new(fallbackCoverageQuestion, fallbackCoverageOptions, "CoverageAmountOption"),
            new("Your age", new List<Protect_Website.Models.LifeWizardOption>(), "Age"),
            new("Tobacco use", new List<Protect_Website.Models.LifeWizardOption>
