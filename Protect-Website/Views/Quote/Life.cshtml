  function resolveAgeBand(ageValue) {
    const parsedAge = Number.parseInt(String(ageValue ?? ''), 10);
    if (!Number.isFinite(parsedAge)) {
      return '';
    }

    if (quoteType === 'finalexpense') {
      if (parsedAge <= 54) return '45-54';
      if (parsedAge <= 64) return '55-64';
      if (parsedAge <= 74) return '65-74';
      return '75+';
    }

    if (parsedAge <= 24) return '18-24';
    if (parsedAge <= 34) return '25-34';
    if (parsedAge <= 44) return '35-44';
    if (parsedAge <= 54) return '45-54';
    if (parsedAge <= 64) return '55-64';
    return '65+';
  }

  function parseDobValue(value) {
    const raw = String(value ?? '').trim();
    if (!/^\d{4}-\d{2}-\d{2}$/.test(raw)) {
      return null;
    }

    const [year, month, day] = raw.split('-').map((part) => Number.parseInt(part, 10));
    const dob = new Date(year, month - 1, day);
    if (
      dob.getFullYear() !== year ||
      dob.getMonth() !== month - 1 ||
      dob.getDate() !== day
    ) {
      return null;
    }

    return dob;
  }

  function calculateAgeFromDob(value) {
    const dob = parseDobValue(value);
    if (!dob) {
      return null;
    }

    const today = new Date();
    let age = today.getFullYear() - dob.getFullYear();
    const hasHadBirthdayThisYear =
      today.getMonth() > dob.getMonth() ||
      (today.getMonth() === dob.getMonth() && today.getDate() >= dob.getDate());

    if (!hasHadBirthdayThisYear) {
      age -= 1;
    }

    return Number.isFinite(age) ? age : null;
  }

  function getSelectedDobValue() {
    const visibleDob = dobInputs.find((input) => input instanceof HTMLInputElement && input.value);
    if (visibleDob instanceof HTMLInputElement) {
      return visibleDob.value;
