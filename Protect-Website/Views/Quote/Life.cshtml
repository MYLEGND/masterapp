<div class="lq-hero-shell">
<div class="@(isLandingView ? "lq-container" : "container lq-container")">
    <div class="lq-hero-rail">
        <div class="lq-header">
            @if (isLowFrictionOptionsVariant)
            {
                <div class="lq-low-friction-hero">
                    <div class="lq-low-friction-hero-kicker">@lowFrictionHeroKicker</div>
                    <h1 class="hero-title">@lowFrictionHeroHeadline</h1>
                    <div class="lq-subtext lq-low-friction-subtext">@lowFrictionHeroSubheadline</div>
                    <div class="lq-low-friction-hero-chips" aria-hidden="true">
                        @foreach (var chip in lowFrictionHeroChips)
                        {
                            <span class="lq-low-friction-hero-chip">@chip</span>
                        }
                    </div>
                    <div class="lq-low-friction-hero-actions">
                        <button type="button" class="btn-gold lq-low-friction-hero-cta" id="lifeHeroPrimaryCta" data-cta="life_funnel_start" data-life-funnel-start="true" data-primary-cta="hero">@lowFrictionHeroCtaText</button>
                        <div class="lq-low-friction-cta-note">@lowFrictionHeroCtaNote</div>
                    </div>
                </div>
            }
            else if (usesContactFirstShell)
            {
                <figure class="lq-hero-banner-wrap">
                    <img class="lq-hero-banner-image" src="@contactFirstBannerImageUrl" asp-append-version="true" alt="@contactFirstBannerAlt" loading="eager" />
                </figure>
            }
            else if (isLandingView)
            {
                <div class="lq-contact-first-hero-grid">
                    <div class="lq-contact-first-hero-copy">
                        <h1 class="hero-title">@heroHeadline</h1>
                    </div>
                    <figure class="lq-contact-first-hero-media">
                        <img class="lq-contact-first-hero-image" src="~/images/ads/life-insurance-review-ad.png" asp-append-version="true" alt="Legend Legacy Protection ad showing a family and inviting a quick life insurance estimate." loading="eager" />
                    </figure>
                </div>
            }
            else
            {
                <h1 class="hero-title">@heroHeadline</h1>
            }
            @if (!isLandingView && !string.IsNullOrWhiteSpace(heroSubheadline))
            {
                <div class="lq-subtext">@heroSubheadline</div>
            }
            @if (!isLandingView)
            {
                <div class="lq-trust-note">@heroTrustNote</div>
            }
        </div>
        @if (!isLandingView)
        {
            <div class="lq-human-strip" id="lifeHeroTrustStrip" role="note" aria-label="@heroTrustAriaLabel" @(showContactStepByDefault ? "hidden" : "")>
                <div class="lq-human-strip-avatar" aria-hidden="true">
                    @if (!string.IsNullOrWhiteSpace(heroTrustPersonImageUrl))
                    {
                        <img src="@heroTrustPersonImageUrl" alt="" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.hidden=false;" />
                    }
                    <span class="lq-human-strip-fallback" @(!string.IsNullOrWhiteSpace(heroTrustPersonImageUrl) ? "hidden" : null)>@heroTrustPersonInitials</span>
                </div>
                <div class="lq-human-strip-copy">
                    <div class="lq-human-strip-name">@heroTrustPersonName</div>
                    <div class="lq-human-strip-role">@heroTrustPersonRole</div>
                    <div class="lq-human-strip-note">@heroTrustPersonSupport</div>
                </div>
            </div>
        }
    </div>
    @if (usesContactFirstShell)
    {
        @if (!isLowFrictionOptionsVariant)
        {
            <div class="lq-funnel-bridge-wrap">
                <button type="button" class="lq-funnel-bridge" id="lifeFunnelBridge" data-cta="life_funnel_start" data-life-funnel-start="true" data-primary-cta="bridge" aria-label="@contactFirstBridgeText">
                    <span class="lq-funnel-bridge-line" aria-hidden="true"></span>
                    <span class="lq-funnel-bridge-core">
                        <span class="lq-funnel-bridge-arrow" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none">
                                <path d="M7 8.5l5 5 5-5" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M7 4.5l5 5 5-5" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round" opacity=".72"/>
                            </svg>
                        </span>
                        <span class="lq-funnel-bridge-copy">@contactFirstBridgeText</span>
                    </span>
                    <span class="lq-funnel-bridge-line" aria-hidden="true"></span>
                </button>
            </div>
        }
    }

    @if (isLowFrictionOptionsVariant)
    {
        <div class="lq-sticky-mobile-cta" id="lifeStickyPrimaryCtaWrap" aria-hidden="true">
            <button type="button" class="btn-gold lq-sticky-mobile-cta-btn" id="lifeStickyPrimaryCta" data-cta="life_funnel_start" data-life-funnel-start="true" data-primary-cta="sticky">@lowFrictionHeroCtaText</button>
        </div>
    }

    <form asp-action="@cfg.PostAction" asp-controller="LifeQuote" method="post" id="lifeWizardForm" data-form-key="@pageKey" data-ajax-submit="true" novalidate>
        @Html.AntiForgeryToken()
        @if (!string.IsNullOrWhiteSpace(agentSlug))
        {
            <input type="hidden" name="AgentSlug" value="@agentSlug" />
        }
        <input type="hidden" name="OfferKey" id="OfferKey" value="@cfg.OfferKey" />
        <input type="hidden" name="ProductType" id="ProductType" value="@cfg.ProductType" />
        <input type="hidden" name="PageKey" value="@pageKey" />
        <input type="hidden" name="PageVariant" value="@pageVariant" />
        <input type="hidden" name="PageMode" value="@pageMode" />
        <input type="hidden" name="Age" id="Age" value="@(hasExplicitAgeSelection ? ageValue : string.Empty)" />
        <input type="hidden" name="AgeRange" id="AgeRange" value="@(hasExplicitAgeSelection ? selectedAgeBracket : string.Empty)" />
        <input type="hidden" name="CoverageAmount" id="CoverageAmount" value="@(form.CoverageAmount?.ToString() ?? selectedCoverageAmountOption)" />
        <input type="hidden" name="ProtectFocus" id="ProtectFocus" value="@form.ProtectFocus" />
        <input type="hidden" name="Answer1" id="Answer1" value="@form.Answer1" />
        <input type="hidden" name="Answer2" id="Answer2" value="@form.Answer2" />
        <input type="hidden" name="Answer3" id="Answer3" value="@(string.IsNullOrWhiteSpace(form.Answer3) ? form.TobaccoUse : form.Answer3)" />
        <input type="hidden" name="Answer4" id="Answer4" value="@(hasExplicitAgeSelection ? ageValue : (form.Answer4 ?? string.Empty))" />
        <input type="hidden" name="SessionId" id="SessionId" />
        <input type="hidden" name="VisitorId" id="VisitorId" />
        <input type="hidden" name="UtmSource" id="UtmSource" />
        <input type="hidden" name="UtmMedium" id="UtmMedium" />
        <input type="hidden" name="UtmCampaign" id="UtmCampaign" />
        <input type="hidden" name="UtmId" id="UtmId" />
        <input type="hidden" name="UtmTerm" id="UtmTerm" />
        <input type="hidden" name="UtmContent" id="UtmContent" />
        <input type="hidden" name="MetaCampaignId" id="MetaCampaignId" />
        <input type="hidden" name="MetaAdSetId" id="MetaAdSetId" />
        <input type="hidden" name="MetaAdId" id="MetaAdId" />
        <input type="hidden" name="Fbclid" id="Fbclid" />
        <input type="hidden" name="ReferrerUrl" id="ReferrerUrl" />
        <input type="hidden" name="LandingPageUrl" id="LandingPageUrl" />
        <input type="hidden" name="MarketingEmailConsent" value="false" />
        <input type="hidden" name="RecommendationPrimaryKey" id="RecommendationPrimaryKey" value="@form.RecommendationPrimaryKey" />
        <input type="hidden" name="RecommendationPrimaryTitle" id="RecommendationPrimaryTitle" value="@form.RecommendationPrimaryTitle" />
        <input type="hidden" name="RecommendationSecondaryKey" id="RecommendationSecondaryKey" value="@form.RecommendationSecondaryKey" />
        <input type="hidden" name="RecommendationSecondaryTitle" id="RecommendationSecondaryTitle" value="@form.RecommendationSecondaryTitle" />

        @if (isLandingView)
        {
            <div class="lq-education-stack">
                <div class="lq-contact-first-primary-grid">
                    <section class="lq-step-panel lq-education-panel lq-contact-first-form-panel" id="lifeEducationContactPanel">
                        <div class="lq-contact-first-proof-row" aria-label="Personal guidance from @contactFirstTrustLabelName">
                            <div class="lq-education-trust-avatar lq-contact-first-proof-avatar" aria-hidden="true">
                                @if (!string.IsNullOrWhiteSpace(contactFirstTrustImageUrl))
                                {
                                    <img src="@contactFirstTrustImageUrl" alt="" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.hidden=false;" />
                                }
                                <span class="lq-education-trust-fallback" @(!string.IsNullOrWhiteSpace(contactFirstTrustImageUrl) ? "hidden" : null)>@contactFirstTrustInitials</span>
                            </div>
                            <div class="lq-contact-first-proof-copy">
                                <div class="lq-contact-first-proof-kicker">@contactFirstProofKicker</div>
                                <div class="lq-contact-first-proof-title">@contactFirstTrustIntroLine</div>
                                <p class="lq-contact-first-proof-text">@contactFirstProofText</p>
                            </div>
                        </div>

                        <div class="lq-contact-first-proof-chips" aria-hidden="true">
                            @foreach (var chip in contactFirstProofChips)
                            {
                                <span class="lq-contact-first-proof-chip">@chip</span>
                            }
                        </div>

                        <div class="lq-contact-first-form-surface lq-contact-first-flow-surface">
                            @if (isLowFrictionOptionsVariant)
                            {
                                <div class="lq-low-friction-value-strip" aria-label="What you get from the quick estimate">
                                    <div class="lq-low-friction-value-title">What you’ll get first</div>
                                    <div class="lq-low-friction-value-chips">
                                        @foreach (var chip in lowFrictionValueChips)
                                        {
                                            <span class="lq-low-friction-value-chip">@chip</span>
                                        }
                                    </div>
                                </div>
                            }
                            <div class="lq-step-panel lq-step1-panel lq-contact-first-wizard-panel" id="lifeStep1Panel" data-funnel-step="1" @(showContactStepByDefault ? "hidden" : "")>
                                <div class="lq-step-panel-pad">
                                    @if (!string.IsNullOrWhiteSpace(step1IntroTitle))
                                    {
                                        <div class="lq-step-title">@step1IntroTitle</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(step1IntroHelper))
                                    {
                                        <div class="lq-step-helper">@step1IntroHelper</div>
                                    }
                                    <div class="lq-step-progress-wrap" aria-live="polite">
                                        <div class="lq-step-progress" id="lifeStep1Progress">Question 1</div>
                                        <div class="lq-step-progress-track" aria-hidden="true">
                                            <span class="lq-step-progress-fill" id="lifeStep1ProgressFill"></span>
                                        </div>
                                    </div>

                                    <div class="lq-micro-step" data-micro-step="0">
                                        <div class="lq-choice-group" role="radiogroup" aria-labelledby="@firstDiscoveryQuestionId">
                                            <div class="lq-choice-label lq-step-question" id="@firstDiscoveryQuestionId">@firstDiscoveryStep.Question</div>
                                            <div class="lq-choice-grid lq-grid-2 lq-step1-twoup">
                        @foreach (var opt in firstDiscoveryStep.Options)
                        {
                            var isChecked = IsStepOptionChecked(firstDiscoveryFieldName, opt.Code);
                            var choiceMeta = GetChoiceCardMeta(firstDiscoveryFieldName, opt.Code);
