@using System.Text.Json
@model Protect_Website.Models.LifeWizardViewModel
@inject Microsoft.Extensions.Options.IOptionsSnapshot<ProtectWebsite.Services.MetaSignal.MetaSignalIntelligenceOptions> MetaSignalOptionsAccessor

@{
    var cfg = Model.Config;
    var form = Model.Form;
    var pageKey = string.IsNullOrWhiteSpace(Model.EffectivePageKey) ? cfg.PageKey : Model.EffectivePageKey;
    var requestPath = Context?.Request?.Path.Value ?? string.Empty;
    var isLandingPage = Model.IsLandingPage;
    var isLandingRoutePath = requestPath.Contains("/landing", StringComparison.OrdinalIgnoreCase);
    var pageVariant = string.IsNullOrWhiteSpace(Model.PageVariant)
        ? ((isLandingPage || isLandingRoutePath) ? "contact_first_education_v1" : "website")
        : Model.PageVariant;
    var usesContactFirstShell = string.Equals(pageVariant, "contact_first_education_v1", StringComparison.OrdinalIgnoreCase);
    var isLandingView = isLandingPage || isLandingRoutePath || usesContactFirstShell;
    var offerBodyClass = $"life-offer-{cfg.OfferKey?.ToLowerInvariant()}";
    var pageMode = string.IsNullOrWhiteSpace(Model.PageMode) ? ((isLandingPage || isLandingRoutePath) ? "paid_landing" : "site_mode") : Model.PageMode;
    var isPaidLandingExperience = string.Equals(pageMode, "paid_landing", StringComparison.OrdinalIgnoreCase);
    var isStandaloneLandingExperience = isLandingPage || isLandingRoutePath || isPaidLandingExperience;
    var isContactFirstEducationVariant = usesContactFirstShell;
    var normalizedOfferKey = cfg.OfferKey?.Trim().ToLowerInvariant() ?? string.Empty;
    ViewData["Title"] = cfg.PageTitle;
    ViewData["PageKey"] = pageKey;
    ViewData["IsLandingPage"] = isStandaloneLandingExperience;
    ViewData["PageVariant"] = pageVariant;
    ViewData["PageMode"] = pageMode;
    ViewData["PageCategory"] = "quote";
    ViewData["QuoteTypeForTracking"] = cfg.OfferKey;
    ViewData["BodyClass"] = isLandingView ? $"life-landing {offerBodyClass}" : offerBodyClass;
    // Shared discovery intake for all life product types.
    IReadOnlyList<Protect_Website.Models.LifeWizardStep> viewSteps = (cfg.Steps?.Take(5).ToList() ?? new List<Protect_Website.Models.LifeWizardStep>());
    if (viewSteps.Count < 5)
    {
        var fallbackProtectOptions = normalizedOfferKey switch
        {
            "finalexpense" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children or grandchildren"),
                new("family","My loved ones"),
            },
            "mortgage" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children"),
                new("family","My household"),
            },
            "wholelife" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children"),
                new("family","My family or legacy"),
            },
            "iul" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children"),
                new("family","My family or legacy"),
            },
            _ => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("spouse_or_partner","My spouse or partner"),
                new("children","My children"),
                new("family","My family"),
            }
        };

        var fallbackGoalOptions = normalizedOfferKey switch
        {
            "term" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("replace_income","Replace income for my family"),
                new("mortgage_or_bills","Cover mortgage or major bills"),
                new("protect_term_years","Protect the years my family needs it most"),
                new("keep_costs_affordable","Keep coverage more affordable"),
            },
            "wholelife" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("lifelong_protection","Build lifelong protection"),
                new("cash_value_growth","Build cash value over time"),
                new("leave_legacy","Leave something behind"),
                new("final_expenses","Cover final expenses permanently"),
            },
            "finalexpense" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("burial_costs","Cover burial and funeral costs"),
                new("final_bills","Handle final medical or household bills"),
                new("ease_family_burden","Reduce financial stress on my loved ones"),
                new("leave_small_benefit","Leave a small benefit behind"),
            },
            "mortgage" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("mortgage_balance","Cover the mortgage balance"),
                new("monthly_payment","Help keep the monthly payment covered"),
                new("stay_in_home","Help my family stay in the home"),
                new("household_bills","Protect mortgage plus key household bills"),
            },
            "iul" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("cash_value_growth","Build cash value with long-term flexibility"),
                new("lifelong_protection","Keep lifelong protection in place"),
                new("future_access","Create future access to cash value"),
                new("leave_legacy","Leave a legacy for my family"),
            },
            _ => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("replace_income","Replace income for my family"),
                new("final_expenses","Cover final expenses"),
                new("mortgage_or_bills","Help with mortgage or bills"),
                new("leave_something","Leave something behind"),
            }
        };

        var fallbackCoverageOptions = normalizedOfferKey switch
        {
            "finalexpense" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("25000","$25,000"),
                new("50000","$50,000"),
                new("75000","$75,000"),
                new("100000","$100,000"),
            },
            "wholelife" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("50000","$50,000"),
                new("100000","$100,000"),
                new("250000","$250,000"),
                new("500000","$500,000"),
            },
            "term" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("1000000","$1,000,000"),
                new("2000000","$2,000,000+"),
            },
            "mortgage" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("150000","$150,000"),
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("750000","$750,000"),
            },
            "iul" => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("1000000","$1,000,000"),
                new("2000000","$2,000,000+"),
            },
            _ => new List<Protect_Website.Models.LifeWizardOption>
            {
                new("100000","$100,000"),
                new("250000","$250,000"),
                new("500000","$500,000"),
                new("1000000","$1,000,000+"),
            }
        };

        viewSteps = new List<Protect_Website.Models.LifeWizardStep>
        {
            new("Who are you looking to protect?", fallbackProtectOptions, "ProtectingWho"),
            new("What would you like this coverage to help with most?", fallbackGoalOptions, "CoverageGoal"),
            new("About how much coverage would you like to explore?", fallbackCoverageOptions, "CoverageAmountOption"),
            new("Tobacco use", new List<Protect_Website.Models.LifeWizardOption>
            {
                new("non_smoker","Non-smoker"),
                new("smoker","Smoker"),
            }, "TobaccoUse"),
            new("Your age", new List<Protect_Website.Models.LifeWizardOption>(), "Age"),
        };
    }
    var protectStep = viewSteps[0];
    var goalStep = viewSteps[1];
    var coverageAmountStep = viewSteps[2];
    var tobaccoStep = viewSteps[3];
    var ageStep = viewSteps[4];
    var ageStepOptions = string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase)
        ? new List<(string Value, string Label, int ApproxAge, bool IsWide)>
        {
            ("45-54", "45-54", 50, false),
            ("55-64", "55-64", 60, false),
            ("65-74", "65-74", 70, false),
            ("75+", "75+", 78, false),
        }
        : new List<(string Value, string Label, int ApproxAge, bool IsWide)>
        {
            ("18-24", "18-24", 21, false),
            ("25-34", "25-34", 30, false),
            ("35-44", "35-44", 40, false),
            ("45-54", "45-54", 50, false),
            ("55+", "55+", 60, true),
        };
    var ageRangeToNumericJson = JsonSerializer.Serialize(ageStepOptions.ToDictionary(option => option.Value, option => option.ApproxAge));
    var ageStepQuestionText = string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase) ? "Your age range" : ageStep.Question;
    (string VisualMode, string VisualValue, string Kicker, string Helper, string ToneClass) GetChoiceCardMeta(string fieldName, string optionCode)
    {
        var normalizedField = (fieldName ?? string.Empty).Trim();
        var normalizedCode = (optionCode ?? string.Empty).Trim().ToLowerInvariant();

        (string VisualMode, string VisualValue, string Kicker, string Helper, string ToneClass) baseChoiceMeta = normalizedField switch
        {
            "ProtectingWho" => normalizedCode switch
            {
                "spouse_or_partner" => ("icon", "choice-icon-partner", "Partner", "Protect the person closest to your day-to-day financial life", "tone-protect"),
                "children" => ("icon", "choice-icon-children", string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase) ? "Family next generation" : "Children", string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase) ? "Help shield children or grandchildren from carrying the burden alone" : "Protect the people counting on you most", "tone-protect"),
                "family" => ("icon", "choice-icon-family", normalizedOfferKey switch
                    {
                        "mortgage" => "Household",
                        "finalexpense" => "Loved ones",
                        _ => "Household"
                    },
                    normalizedOfferKey switch
                    {
                        "mortgage" => "Protect the people and home life that depend on your monthly stability",
                        "wholelife" => "Protect the people you love while keeping legacy goals in view",
                        "iul" => "Protect the people you love while thinking longer term about legacy",
                        "finalexpense" => "Ease the emotional and financial burden on the people closest to you",
                        _ => "Cover the people who depend on your support"
                    },
                    "tone-protect"),
                _ => ("icon", "choice-icon-family", string.Empty, string.Empty, "tone-protect")
            },
            "CoverageGoal" => normalizedCode switch
            {
                "replace_income" => ("icon", "choice-icon-income", "Income", "Help replace lost earnings for the people who rely on you", "tone-goal"),
                "final_expenses" => ("icon", "choice-icon-heart", "Final costs", "Ease burial, funeral, and end-of-life expense pressure", "tone-goal"),
                "mortgage_or_bills" => ("icon", "choice-icon-home", "Home & bills", "Help cover the mortgage and major monthly costs", "tone-goal"),
                "leave_something" => ("icon", "choice-icon-legacy", "Legacy", "Leave behind a benefit that supports the people you love", "tone-goal"),
                "protect_term_years" => ("icon", "choice-icon-income", "Key years", "Focus on the years your family would feel the loss of your income most", "tone-goal"),
                "keep_costs_affordable" => ("icon", "choice-icon-income", "Affordability", "Start with efficient protection that keeps the monthly estimate in a practical range", "tone-goal"),
                "lifelong_protection" => ("icon", "choice-icon-legacy", "Permanent", "Keep coverage in place for the long haul instead of only a temporary term", "tone-goal"),
                "cash_value_growth" => ("icon", "choice-icon-income", "Cash value", "Explore coverage designed to build long-range value over time", "tone-goal"),
                "leave_legacy" => ("icon", "choice-icon-legacy", "Legacy", "Keep the focus on what you want to leave behind for the people you love", "tone-goal"),
                "burial_costs" => ("icon", "choice-icon-heart", "Burial costs", "Keep burial, funeral, and immediate final costs from falling on family", "tone-goal"),
                "final_bills" => ("icon", "choice-icon-heart", "Final bills", "Help cover medical, household, or end-of-life costs that can pile up quickly", "tone-goal"),
                "ease_family_burden" => ("icon", "choice-icon-heart", "Ease the burden", "Reduce the financial stress your loved ones may face during a hard time", "tone-goal"),
                "leave_small_benefit" => ("icon", "choice-icon-legacy", "Small benefit", "Leave behind a modest amount that can still make things easier for loved ones", "tone-goal"),
                "mortgage_balance" => ("icon", "choice-icon-home", "Mortgage balance", "Focus on helping cover the loan balance tied to the home", "tone-goal"),
                "monthly_payment" => ("icon", "choice-icon-home", "Monthly payment", "Help keep the monthly home payment from becoming a crisis", "tone-goal"),
                "stay_in_home" => ("icon", "choice-icon-home", "Stay in the home", "Keep the people you love in the home they know and count on", "tone-goal"),
                "household_bills" => ("icon", "choice-icon-home", "Home stability", "Protect the mortgage along with the bills that keep the household running", "tone-goal"),
                "future_access" => ("icon", "choice-icon-income", "Future access", "Explore long-term flexibility and access to cash value later on", "tone-goal"),
                _ => ("icon", "choice-icon-legacy", string.Empty, string.Empty, "tone-goal")
            },
            "CoverageAmountOption" => normalizedOfferKey switch
            {
                "finalexpense" => normalizedCode switch
                {
                    "25000" => ("none", string.Empty, "Starter", "A modest benefit focused on burial and immediate final costs", "tone-coverage"),
                    "50000" => ("none", string.Empty, "Common", "A balanced final expense starting point for many households", "tone-coverage"),
                    "75000" => ("none", string.Empty, "Stronger", "Leaves more room for final costs and added family support", "tone-coverage"),
                    "100000" => ("none", string.Empty, "Higher range", "The top end of this final expense range for added peace of mind", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                },
                "wholelife" => normalizedCode switch
                {
                    "50000" => ("none", string.Empty, "Starter", "A smaller lifelong base for final costs and lasting support", "tone-coverage"),
                    "100000" => ("none", string.Empty, "Common", "A balanced whole life starting point with steady cash value potential", "tone-coverage"),
                    "250000" => ("none", string.Empty, "Stronger", "More lifelong coverage with room to build long-range value", "tone-coverage"),
                    "500000" => ("none", string.Empty, "Higher range", "A larger permanent protection target for higher lifelong needs", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                },
                "term" => normalizedCode switch
                {
                    "250000" => ("none", string.Empty, "Focused", "A leaner term target for a focused income gap or key bills", "tone-coverage"),
                    "500000" => ("none", string.Empty, "Common", "A strong family-income starting point for many households", "tone-coverage"),
                    "1000000" => ("none", string.Empty, "Broader", "More breathing room for income, debt, and future family needs", "tone-coverage"),
                    "2000000" => ("none", string.Empty, "Higher range", "A larger term safety net for bigger family protection goals", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                },
                "mortgage" => normalizedCode switch
                {
                    "150000" => ("none", string.Empty, "Starter", "Fits smaller balances or a focused cushion around the home", "tone-coverage"),
                    "250000" => ("none", string.Empty, "Common", "A practical starting point for many mortgage balances", "tone-coverage"),
                    "500000" => ("none", string.Empty, "Stronger", "More room to protect the home and the monthly household budget", "tone-coverage"),
                    "750000" => ("none", string.Empty, "Higher range", "Built for higher balances and a larger monthly obligation", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                },
                "iul" => normalizedCode switch
                {
                    "250000" => ("none", string.Empty, "Base", "A flexible starting point for lifelong coverage with growth potential", "tone-coverage"),
                    "500000" => ("none", string.Empty, "Common", "A strong IUL target for lasting protection and cash value growth", "tone-coverage"),
                    "1000000" => ("none", string.Empty, "Broader", "More room to pair lifetime protection with long-range strategy", "tone-coverage"),
                    "2000000" => ("none", string.Empty, "Higher range", "A larger IUL design for high protection and legacy-focused goals", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                },
                _ => normalizedCode switch
                {
                    "100000" => ("none", string.Empty, "Starter", "Good for a smaller protection need or focused final planning", "tone-coverage"),
                    "250000" => ("none", string.Empty, "Common", "A balanced starting point for many households", "tone-coverage"),
                    "500000" => ("none", string.Empty, "Stronger", "Often chosen for broader family and income protection", "tone-coverage"),
                    "1000000" => ("none", string.Empty, "Higher range", "Explore a larger protection target with a bigger safety net", "tone-coverage"),
                    _ => ("none", string.Empty, string.Empty, string.Empty, "tone-coverage")
                }
            },
            "TobaccoUse" => normalizedCode switch
            {
                "non_smoker" => ("icon", "choice-icon-leaf", "Lower-risk profile", "Estimate built around non-tobacco pricing", "tone-health"),
                "smoker" => ("icon", "choice-icon-smoke", "Tobacco use", "Estimate adjusted for tobacco-related pricing", "tone-health"),
                _ => ("icon", "choice-icon-leaf", string.Empty, string.Empty, "tone-health")
            },
            "AgeBracket" => normalizedCode switch
            {
                "18-24" => ("none", string.Empty, "Starting out", "Early-rate years with more room to explore options", "tone-age"),
                "25-34" => ("none", string.Empty, "Building years", "Often the stretch where family and income protection grows", "tone-age"),
                "35-44" => ("none", string.Empty, "Peak protection", "A common window for heavier family and bill responsibility", "tone-age"),
                "45-54" when string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase)
                    => ("none", string.Empty, "Early planning", "A common starting window for exploring simpler final expense coverage", "tone-age"),
                "45-54" => ("none", string.Empty, "Established years", "Often focused on income protection and long-range stability", "tone-age"),
                "55-64" => ("none", string.Empty, "Retirement years", "Often a strong window for final expense planning and simpler permanent protection", "tone-age"),
                "65-74" => ("none", string.Empty, "Later planning", "Often centered on final costs, simplicity, and easing the burden on loved ones", "tone-age"),
                "75+" => ("none", string.Empty, "Senior planning", "Focused on straightforward final expense protection and peace of mind", "tone-age"),
                "55+" => ("none", string.Empty, "Long-range planning", "Later-career years where lasting fit matters more", "tone-age"),
                _ => ("none", string.Empty, string.Empty, string.Empty, "tone-age")
            },
            _ => ("icon", "choice-icon-family", string.Empty, string.Empty, string.Empty)
        };

        var compactKicker = baseChoiceMeta.Kicker;
        if (string.Equals(normalizedField, "CoverageGoal", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(normalizedField, "CoverageAmountOption", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(normalizedField, "AgeBracket", StringComparison.OrdinalIgnoreCase))
        {
            compactKicker = string.Empty;
        }

        return (baseChoiceMeta.VisualMode, baseChoiceMeta.VisualValue, compactKicker, string.Empty, baseChoiceMeta.ToneClass);
    }
    var selectedCoverageAmountOption = !string.IsNullOrWhiteSpace(form.CoverageAmountOption)
        ? form.CoverageAmountOption.Trim()
        : (form.CoverageAmount.HasValue ? form.CoverageAmount.Value.ToString() : string.Empty);
    var selectedAgeBracket = string.Empty;
    var ageValueNumber = form.Age;
    if (!string.IsNullOrWhiteSpace(form.AgeRange) && (form.AgeRange.Contains('-') || form.AgeRange.Contains('+')))
    {
        selectedAgeBracket = form.AgeRange.Trim();
    }
    if (string.IsNullOrWhiteSpace(selectedAgeBracket) && !string.IsNullOrWhiteSpace(form.Answer4) && (form.Answer4.Contains('-') || form.Answer4.Contains('+')))
    {
        selectedAgeBracket = form.Answer4.Trim();
    }
    if (!ageValueNumber.HasValue && int.TryParse(form.Answer4, out var parsedAnswerAge))
    {
        ageValueNumber = parsedAnswerAge;
    }
    if (!ageValueNumber.HasValue && int.TryParse(form.AgeRange, out var parsedRangeAge))
    {
        ageValueNumber = parsedRangeAge;
    }
    if (string.IsNullOrWhiteSpace(selectedAgeBracket) && ageValueNumber.HasValue)
    {
        var ageNumber = ageValueNumber.Value;
        if (string.Equals(normalizedOfferKey, "finalexpense", StringComparison.OrdinalIgnoreCase))
        {
            if (ageNumber <= 54) selectedAgeBracket = "45-54";
            else if (ageNumber <= 64) selectedAgeBracket = "55-64";
            else if (ageNumber <= 74) selectedAgeBracket = "65-74";
            else selectedAgeBracket = "75+";
        }
        else
        {
            if (ageNumber <= 24) selectedAgeBracket = "18-24";
            else if (ageNumber <= 34) selectedAgeBracket = "25-34";
            else if (ageNumber <= 44) selectedAgeBracket = "35-44";
            else if (ageNumber <= 54) selectedAgeBracket = "45-54";
            else selectedAgeBracket = "55+";
        }
    }
    if (!ageValueNumber.HasValue)
    {
        ageValueNumber = selectedAgeBracket switch
        {
            "18-24" => 21,
            "25-34" => 30,
            "35-44" => 40,
            "45-54" => 50,
            "55-64" => 60,
            "65-74" => 70,
            "75+" => 78,
            "55+" => 60,
            _ => null,
        };
    }
    var ageValue = ageValueNumber?.ToString() ?? string.Empty;
    var usesLeanContactFields = true;
    var hasContactInput =
        !string.IsNullOrWhiteSpace(form.FirstName) ||
        !string.IsNullOrWhiteSpace(form.LastName) ||
        !string.IsNullOrWhiteSpace(form.Phone) ||
        !string.IsNullOrWhiteSpace(form.Email) ||
        !string.IsNullOrWhiteSpace(form.State);
    var showContactStepByDefault = !ViewData.ModelState.IsValid || hasContactInput;
    var isFounderPath = ViewData["IsFounderPath"] as bool? == true;
    var trackedSlug = ((string?)ViewData["TrackingSlug"] ?? string.Empty).Trim();
    var agentTrustProfile = Model.AgentTrustProfile;
    var agentSlug = !string.IsNullOrWhiteSpace(agentTrustProfile?.AgentSlug)
        ? agentTrustProfile.AgentSlug
        : (!isFounderPath ? trackedSlug : string.Empty);
    var showAgentTrustCard = agentTrustProfile != null;
    var agentDisplayName = !string.IsNullOrWhiteSpace(agentTrustProfile?.DisplayName)
        ? agentTrustProfile!.DisplayName!.Trim()
        : "Your licensed agent";
    var agentGreetingName = !string.IsNullOrWhiteSpace(agentTrustProfile?.FirstName)
        ? agentTrustProfile!.FirstName!.Trim()
        : agentDisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "there";
    var agentDirectContactName = !string.IsNullOrWhiteSpace(agentTrustProfile?.FirstName)
        ? agentTrustProfile!.FirstName!.Trim()
        : (!string.IsNullOrWhiteSpace(agentTrustProfile?.DisplayName)
            ? agentTrustProfile!.DisplayName!.Trim()
            : "Your Agent");
    var finalStepHeading = isContactFirstEducationVariant ? "Get your personal walkthrough" : "Want a personalized review?";
    var finalStepHelper = isContactFirstEducationVariant
        ? $"{agentDirectContactName} will walk through what may fit and answer your questions. No obligation."
        : string.Empty;
    var agentTrustHeadline = isContactFirstEducationVariant
        ? $"You’ll hear directly from {agentDirectContactName}."
        : $"You’ll hear directly from {agentDirectContactName}.";
    var agentTrustBio = isContactFirstEducationVariant
        ? "I’ll walk through what may fit and answer your questions. No obligation."
        : "I’ll review what you shared and explain what may fit.";
    var agentTrustNpn = !string.IsNullOrWhiteSpace(agentTrustProfile?.Npn)
        ? agentTrustProfile!.Npn!.Trim()
        : null;
    var stepOneContinueButtonText = "Show My Estimate";
    var resultsContinueButtonText = "Continue To My Personal Review";
    var finalSubmitButtonText = isContactFirstEducationVariant
        ? "Get My Personal Review"
        : "Get My Personalized Review";
    var heroHeadline = isContactFirstEducationVariant
        ? "See what may help protect the people who depend on you most."
        : "See what protection options may fit your family’s needs.";
    var heroSubheadline = isContactFirstEducationVariant
        ? "Life insurance can feel confusing. I’ll personally help you understand what may fit your situation. No pressure. No obligation."
        : (isLandingView ? "Answer a few quick questions to review personalized options. No pressure. No obligation." : string.Empty);
    var heroTrustNote = isContactFirstEducationVariant ? "Quick • Private • Personalized" : "Quick • Private • No obligation";
    var heroTrustPersonName = !string.IsNullOrWhiteSpace(agentTrustProfile?.DisplayName)
        ? agentTrustProfile!.DisplayName!.Trim()
        : "Zac Owen";
    var heroTrustPersonRole = "Licensed Insurance Professional";
    var heroTrustPersonSupport = "No pressure. Just personalized guidance.";
    var heroTrustPersonImageUrl = !string.IsNullOrWhiteSpace(agentTrustProfile?.ProfileImageUrl)
        ? agentTrustProfile!.ProfileImageUrl!.Trim()
        : string.Empty;
    var heroTrustPersonInitials = !string.IsNullOrWhiteSpace(agentTrustProfile?.FirstName)
        ? agentTrustProfile!.FirstName!.Substring(0, 1).ToUpperInvariant()
        : "ZO";
    var contactFirstTrustImageUrl = !string.IsNullOrWhiteSpace(agentTrustProfile?.ProfileImageUrl)
        ? agentTrustProfile!.ProfileImageUrl!.Trim()
        : string.Empty;
    var contactFirstTrustLabelName = !string.IsNullOrWhiteSpace(agentTrustProfile?.DisplayName)
        ? agentTrustProfile!.DisplayName!.Trim()
        : "your licensed agent";
    var contactFirstTrustIntroLine = !string.IsNullOrWhiteSpace(agentTrustProfile?.FirstName)
        ? $"Hey, I’m {agentTrustProfile!.FirstName!.Trim()}."
        : (!string.IsNullOrWhiteSpace(agentTrustProfile?.DisplayName)
            ? $"Hey, I’m {agentTrustProfile!.DisplayName!.Trim()}."
            : "Hey, I’m your licensed agent.");
    var contactFirstTrustInitials = string.Concat(
