@using System.Text.Json
@using Shared.Analytics
@model Protect_Website.Models.LifeWizardViewModel
@inject Microsoft.Extensions.Options.IOptionsSnapshot<ProtectWebsite.Services.MetaSignal.MetaSignalIntelligenceOptions> MetaSignalOptionsAccessor

@{
    var cfg = Model.Config;
    var form = Model.Form;
    var pageKey = string.IsNullOrWhiteSpace(Model.EffectivePageKey) ? cfg.PageKey : Model.EffectivePageKey;
    var requestPath = Context?.Request?.Path.Value ?? string.Empty;
    var isLandingPage = Model.IsLandingPage;
    var isLandingRoutePath = requestPath.Contains("/landing", StringComparison.OrdinalIgnoreCase);
    const string contactFirstEducationVariant = "contact_first_education_v1";
    const string lowFrictionOptionsVariant = "low_friction_options_v1";
    var pageVariant = string.IsNullOrWhiteSpace(Model.PageVariant)
        ? ((isLandingPage || isLandingRoutePath) ? contactFirstEducationVariant : "website")
        : Model.PageVariant;
    var isContactFirstEducationVariant = string.Equals(pageVariant, contactFirstEducationVariant, StringComparison.OrdinalIgnoreCase);
    var isLowFrictionOptionsVariant = string.Equals(pageVariant, lowFrictionOptionsVariant, StringComparison.OrdinalIgnoreCase);
    var usesContactFirstShell = isContactFirstEducationVariant || isLowFrictionOptionsVariant;
    var isLandingView = isLandingPage || isLandingRoutePath || usesContactFirstShell;
    var offerBodyClass = $"life-offer-{cfg.OfferKey?.ToLowerInvariant()}";
