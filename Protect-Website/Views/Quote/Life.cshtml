          : normalized.canFallback
            ? publicBookingFallbackOnlyText
            : publicBookingDisabledText;

    const statusLabel = normalized.loading
      ? 'Preparing your review'
      : !normalized.enabled
        ? 'Review saved'
        : normalized.canEmbed
          ? ''
          : normalized.canFallback
            ? 'Continue in new tab'
            : 'Review saved';

    const showPrimaryCta = false;
    const showFallbackLink = !normalized.loading && normalized.canFallback && normalized.fallbackUrl;
    const showInlineShell = !normalized.loading && normalized.enabled && normalized.canEmbed && normalized.embedUrl;

    postSubmitSlot.innerHTML = `
      <section class="lq-post-submit-card" aria-labelledby="lifePostSubmitBookingTitle">
        <div class="lq-post-submit-head">
          <div class="lq-post-submit-kicker">${escapeHtml(publicBookingKickerText)}</div>
          <div class="lq-post-submit-title" id="lifePostSubmitBookingTitle">${escapeHtml(publicBookingHeadingText)}</div>
          <div class="lq-post-submit-copy">${escapeHtml(bookingCopyText)}</div>
        </div>
        <div class="lq-booking-shell${!normalized.enabled && !normalized.loading ? ' is-disabled' : ''}">
          <div class="lq-booking-head">
            <div class="lq-booking-status-pill">${escapeHtml(statusLabel)}</div>
            <div class="lq-booking-copy">${escapeHtml(noteText)}</div>
            ${(!normalized.loading && normalized.pendingConfirmation) ? `<div class="lq-booking-pending-note">${escapeHtml(publicBookingPendingText)}</div>` : ''}
          </div>
          <div class="lq-booking-actions">
            
            ${showFallbackLink ? `<a href="${escapeHtml(normalized.fallbackUrl)}" target="_blank" rel="noopener noreferrer" class="lq-booking-secondary-link" id="lifeBookingFallbackLink">${escapeHtml(publicBookingFallbackText)}</a>` : ''}
          </div>
          ${showInlineShell ? `
            <div class="lq-booking-embed-shell is-auto-open" id="lifeBookingInlineShell">
              <div class="lq-booking-embed-status" id="lifeBookingInlineStatus">${escapeHtml(publicBookingLoadingText)}</div>
              <div class="lq-booking-embed-frame-wrap" id="lifeBookingInlineFrameSlot"></div>
            </div>
          ` : ''}
        </div>
      </section>`;

    postSubmitSlot.hidden = false;

    const inlineShellAuto = document.getElementById('lifeBookingInlineShell');
    const inlineFrameSlotAuto = document.getElementById('lifeBookingInlineFrameSlot');
    const inlineStatusAuto = document.getElementById('lifeBookingInlineStatus');
    if (showInlineShell && inlineShellAuto instanceof HTMLElement) {
      inlineShellAuto.hidden = false;
      renderBookingIframe(inlineFrameSlotAuto, inlineStatusAuto, normalizePublicBookingPayload(publicBookingState, payload).embedUrl);
      markAppointmentEmbedViewed('website_embed', normalizePublicBookingPayload(publicBookingState, payload));
    }

    const primaryCta = document.getElementById('lifeBookingPrimaryCta');
    if (primaryCta instanceof HTMLButtonElement) {
      primaryCta.addEventListener('click', () => {
        const activeBookingState = normalizePublicBookingPayload(publicBookingState, payload);
        if (shouldUseBookingModal(activeBookingState)) {
          if (!(bookingModal instanceof HTMLElement)) {
            return;
          }

          bookingModal.hidden = false;
          bookingModal.setAttribute('aria-hidden', 'false');
          document.body.style.setProperty('overflow', 'hidden');
          if (bookingModalStatus instanceof HTMLElement) {
            bookingModalStatus.hidden = false;
            bookingModalStatus.textContent = publicBookingLoadingText;
          }
          renderBookingIframe(bookingModalFrameSlot, bookingModalStatus, activeBookingState.embedUrl);
          markAppointmentEmbedViewed('website_modal', activeBookingState);
          window.setTimeout(() => {
            bookingModal.querySelector('.lq-booking-modal-close')?.focus({ preventScroll: true });
          }, 50);
          return;
        }

        const inlineShell = document.getElementById('lifeBookingInlineShell');
        const inlineFrameSlot = document.getElementById('lifeBookingInlineFrameSlot');
        const inlineStatus = document.getElementById('lifeBookingInlineStatus');
        if (!(inlineShell instanceof HTMLElement)) {
          return;
        }

