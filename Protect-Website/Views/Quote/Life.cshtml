    if (!isPaidLandingExperience || !metaSignalApi) {
      notifyBrowserPixelStatus(leadId, metaLeadEventId, 'skipped', 'not_paid_landing_or_meta_signal_unavailable');
      return Promise.resolve(false);
    }

    // Browser pixel dispatch is owned by the Meta Signal wrapper.
    // Do not call window.fbq directly here; this prevents raw/non-human traffic from bypassing funnel gating.
    notifyBrowserPixelStatus(leadId, metaLeadEventId, 'skipped', 'direct_fbq_disabled_use_meta_signal');
    return Promise.resolve(false);
  }

