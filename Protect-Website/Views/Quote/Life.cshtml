  function animateProcessingBar() {
    if (!processingFill) return;
    processingFill.style.transition = 'none';
    processingFill.style.width = '0%';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        processingFill.style.transition = `width ${PROCESSING_BRIDGE_MS}ms cubic-bezier(0.22, 1, 0.36, 1)`;
        processingFill.style.width = '100%';
      });
    });
  }

  function buildEstimateTrackingPayload(estimatePreview) {
    const primary = estimatePreview?.primary || {};
    const secondary = estimatePreview?.secondary || {};

    return {
      primaryPolicyType: primary.policyType || '',
      secondaryPolicyType: secondary.policyType || '',
      ageBand: estimatePreview?.ageBand || '',
      requestedCoverageAmount: estimatePreview?.requestedCoverageAmount || coverageAmountHidden?.value || '',
      tobaccoUse: estimatePreview?.tobaccoUse || answer3Hidden?.value || '',
      coverageGoal: estimatePreview?.coverageGoal || answer2Hidden?.value || '',
      protectingWho: estimatePreview?.protectingWho || answer1Hidden?.value || '',
      estimatedLow: primary.estimatedLowMonthly || '',
      estimatedHigh: primary.estimatedHighMonthly || '',
      secondaryEstimatedLow: secondary.estimatedLowMonthly || '',
      secondaryEstimatedHigh: secondary.estimatedHighMonthly || '',
      recommendationPrimaryKey: primary.policyKey || '',
      recommendationSecondaryKey: secondary.policyKey || ''
    };
  }

  async function trackEstimateSummaryView(estimatePreview) {
    if (!canRenderEstimateSummary(estimatePreview)) {
      return;
    }

    const trackingPayload = buildEstimateTrackingPayload(estimatePreview);
    trackEvent('estimate_inline_contact_view', {
      ...trackingPayload,
      placement: 'contact_step'
    });
    trackEvent('estimate_results_viewed', {
      ...trackingPayload,
      placement: 'contact_step'
    });
    await ensureMetaLeadFormStart();
    metaSignalApi?.trackRecommendationViewed(buildMetaProgressMetadata({
      recommendationPrimaryKey: trackingPayload.recommendationPrimaryKey,
      recommendationSecondaryKey: trackingPayload.recommendationSecondaryKey
    }));
    metaSignalApi?.trackStepComplete(2, 'recommendation_complete', {
      ...buildMetaProgressMetadata(),
      recommendationPrimaryKey: trackingPayload.recommendationPrimaryKey,
      recommendationSecondaryKey: trackingPayload.recommendationSecondaryKey
    });
  }

  function escapeHtml(value) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function trackThankYouViewOnce(metadata = {}) {
    if (thankYouViewTracked) {
      return Promise.resolve();
    }

    thankYouViewTracked = true;
    return trackEvent('thank_you_view', metadata);
  }

  function resolveRequestedBookingSurface(payload) {
    if (!payload?.canEmbed) {
      return 'external_redirect_fallback';
    }

    return shouldUseBookingModal(payload)
      ? 'website_modal'
      : 'website_embed';
  }

  function shouldUseBookingModal(payload) {
    return Boolean(payload?.canEmbed)
      && Boolean(payload?.preferModalOnMobile)
      && window.matchMedia('(max-width: 767.98px)').matches;
  }

  function buildDisabledBookingState(reason = 'disabled') {
    return {
      enabled: false,
      canEmbed: false,
      canFallback: false,
      preferModalOnMobile: true,
      embedUrl: '',
      fallbackUrl: '',
      surface: 'external_redirect_fallback',
      linkedToLead: false,
      appointmentStatus: '',
      pendingConfirmation: false,
      reason,
      contextToken: ''
    };
  }

  function normalizePublicBookingPayload(payload, hint = null) {
    const source = payload && typeof payload === 'object' ? payload : {};
    const sourceHint = hint && typeof hint === 'object' ? hint : {};
    const canEmbed = Boolean(source.canEmbed ?? sourceHint.canEmbed);
    const canFallback = Boolean(source.canFallback ?? sourceHint.canFallback);
    const preferModalOnMobile = Boolean(source.preferModalOnMobile ?? sourceHint.preferModalOnMobile);
    const enabled = Boolean(source.enabled ?? sourceHint.eligible) && (canEmbed || canFallback);

    return {
      enabled,
      canEmbed,
      canFallback,
      preferModalOnMobile,
      embedUrl: asTrimmed(source.embedUrl || sourceHint.embedUrl || ''),
      fallbackUrl: asTrimmed(source.fallbackUrl || sourceHint.fallbackUrl || ''),
      surface: asTrimmed(source.surface || resolveRequestedBookingSurface(sourceHint)),
      linkedToLead: Boolean(source.linkedToLead),
      appointmentStatus: asTrimmed(source.appointmentStatus || ''),
      requestedBookingSource: asTrimmed(source.requestedBookingSource || ''),
      confirmationSource: asTrimmed(source.confirmationSource || ''),
      confirmationVerified: Boolean(source.confirmationVerified),
      pendingConfirmation: Boolean(source.pendingConfirmation),
      reason: asTrimmed(source.reason || (enabled ? 'configured' : 'disabled')) || 'disabled',
      contextToken: asTrimmed(source.contextToken || sourceHint.contextToken || ''),
      bookingConfigSource: asTrimmed(source.bookingConfigSource || sourceHint.bookingConfigSource || ''),
      bookingConfigAgentSlug: asTrimmed(source.bookingConfigAgentSlug || sourceHint.bookingConfigAgentSlug || ''),
      bookingTrackingProfileId: asTrimmed(source.bookingTrackingProfileId || sourceHint.bookingTrackingProfileId || ''),
      calendarEventId: asTrimmed(source.calendarEventId || ''),
      calendarEventWebLink: asTrimmed(source.calendarEventWebLink || ''),
      scheduledStartUtc: asTrimmed(source.scheduledStartUtc || ''),
      scheduledEndUtc: asTrimmed(source.scheduledEndUtc || '')
    };
  }

  function buildAppointmentTrackingMetadata(payload, extra = {}) {
    const normalized = normalizePublicBookingPayload(payload, publicBookingState);
    return {
      bookingSurface: normalized.surface || resolveRequestedBookingSurface(normalized),
      bookingMode: shouldUseBookingModal(normalized) ? 'modal' : normalized.canEmbed ? 'inline' : 'fallback',
      hasFallback: normalized.canFallback,
      appointmentStatus: normalized.appointmentStatus || '',
      requestedBookingSource: normalized.requestedBookingSource || '',
      confirmationSource: normalized.confirmationSource || '',
      confirmationVerified: normalized.confirmationVerified,
      linkedToLead: normalized.linkedToLead,
      pendingConfirmation: normalized.pendingConfirmation,
      bookingReason: normalized.reason || '',
      bookingConfigSource: normalized.bookingConfigSource || '',
      bookingConfigAgentSlug: normalized.bookingConfigAgentSlug || '',
      bookingTrackingProfileId: normalized.bookingTrackingProfileId || '',
      handoffType: hasAgentTrustProfile ? 'agent' : 'generic',
      recommendationPrimaryKey: recPrimaryKeyEl?.value || '',
      recommendationSecondaryKey: recSecondaryKeyEl?.value || '',
      ...extra
    };
  }

  function closeBookingModal(options = {}) {
    if (!(bookingModal instanceof HTMLElement)) {
      return;
    }

    bookingModal.hidden = true;
    bookingModal.setAttribute('aria-hidden', 'true');
    document.body.style.removeProperty('overflow');

