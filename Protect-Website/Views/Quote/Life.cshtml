        trackEvent('appointment_booking_fallback_clicked', buildAppointmentTrackingMetadata(publicBookingState, {
          bookingSurface: 'external_redirect_fallback'
        }));
        if (publicBookingState?.contextToken) {
          void activatePublicBookingExperience(publicBookingState, 'external_redirect_fallback')
            .then((nextState) => {
              publicBookingState = normalizePublicBookingPayload(nextState, publicBookingState);
            });
        }
      });
