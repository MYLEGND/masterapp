  function notifyBrowserPixelStatus(leadId, metaLeadEventId, status, note = '') {
    if (!leadId || !metaLeadEventId) {
      return;
    }

    const payload = JSON.stringify({
      leadId,
      eventId: metaLeadEventId,
      status,
      ...(note ? { note } : {})
    });

    try {
      if (navigator.sendBeacon) {
        const blob = new Blob([payload], { type: 'application/json' });
        if (navigator.sendBeacon(metaBrowserAckUrl, blob)) {
          return;
        }
      }
    } catch {
      // Fall through to fetch keepalive below.
    }

    try {
      fetch(metaBrowserAckUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: payload,
        keepalive: true
      }).catch(() => {});
    } catch {
      // Never block the thank-you redirect on diagnostics.
    }
  }

  function trackMetaLeadSuccess(leadId, metaLeadEventId) {
    if (!metaLeadEventId) {
      return Promise.resolve(false);
    }

    if (typeof window.fbq !== 'function') {
      notifyBrowserPixelStatus(leadId, metaLeadEventId, 'unavailable', 'fbq_unavailable');
      return Promise.resolve(false);
    }

    try {
      window.fbq('track', 'Lead', {
        content_name: pageKey,
        content_category: '@cfg.OfferKey'
      }, {
        eventID: metaLeadEventId
      });
      notifyBrowserPixelStatus(leadId, metaLeadEventId, 'sent');
      return Promise.resolve(true);
    } catch {
      notifyBrowserPixelStatus(leadId, metaLeadEventId, 'error', 'fbq_exception');
      return Promise.resolve(false);
    }
  }

  async function flushSuccessTracking(leadId, metaLeadEventId) {
    const trackingTasks = [
      trackEvent('lead_form_submit_success'),
      trackEvent('life_step2_submit_success'),
      trackEvent(submitEvent, { submitOutcome: 'success' }),
      trackEvent('results_contact_submit', {
        primaryRec: recPrimaryKeyEl?.value || '',
        secondaryRec: recSecondaryKeyEl?.value || '',
      }),
      trackFormSubmitOutcome('success'),
      trackMetaLeadSuccess(leadId, metaLeadEventId)
    ];

    await Promise.race([
      Promise.allSettled(trackingTasks),
      new Promise((resolve) => window.setTimeout(resolve, 700))
    ]);
  }

  async function flushContactFirstSuccessTracking(leadId, metaLeadEventId) {
    const trackingTasks = [
      trackEvent('lead_form_submit_success', { variantFlow: pageVariant }),
      trackEvent('life_contact_first_submit_success'),
      trackEvent('life_contact_first_complete', { variantFlow: pageVariant }),
      trackEvent('life_step2_submit_success', { variantFlow: pageVariant }),
      trackEvent(submitEvent, { submitOutcome: 'success', variantFlow: pageVariant }),
      trackFormSubmitOutcome('success', { variantFlow: pageVariant }),
      trackMetaLeadSuccess(leadId, metaLeadEventId)
    ];

    await Promise.race([
      Promise.allSettled(trackingTasks),
      new Promise((resolve) => window.setTimeout(resolve, 700))
    ]);
