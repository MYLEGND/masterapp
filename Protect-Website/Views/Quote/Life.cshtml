  const formTrackingKey = form.dataset.formKey || pageKey;
  const TRACKED_FIELD_NAME_MAP = Object.freeze({
    ProtectingWho: 'step_2_choice',
    CoverageGoal: 'step_1_choice',
    CoverageAmountOption: 'coverage_amount',
    TobaccoUse: 'tobacco_use',
    AgeBracket: 'age_range',
    FirstName: 'first_name',
    LastName: 'last_name',
    ContactMethod: 'contact_method',
    Phone: 'phone',
    Email: 'email',
    State: 'state',
    MarketingEmailConsent: 'consent_contact',
  });

  function resolveTrackedFieldName(name) {
    return TRACKED_FIELD_NAME_MAP[name] || String(name || 'unknown').trim().toLowerCase();
  }

  function trackQuoteFieldError(name, errorType, fieldContext) {
    const trackedFieldName = resolveTrackedFieldName(name);
    if (window.legendFormTracking?.trackFieldError) {
      void safeTrackingCall(`field_error:${trackedFieldName}`, () => window.legendFormTracking.trackFieldError(formTrackingKey, trackedFieldName, errorType, '@cfg.OfferKey'));
    }

    if (!window.legendFormTracking && typeof window.legendTrack === 'function') {
      void safeTrackingCall(`field_error:${trackedFieldName}`, () => window.legendTrack({
        EventType: 'form_field_error',
        FormKey: formTrackingKey,
        FieldName: trackedFieldName,
        MetadataJson: JSON.stringify({
          errorType,
          fieldContext,
          pageVariant,
          pageMode,
        }),
      }));
    }
  }

  function clearQuoteFieldError(name) {
    const trackedFieldName = resolveTrackedFieldName(name);
    try {
      window.legendFormTracking?.clearFieldError(formTrackingKey, trackedFieldName);
    } catch (error) {
      console.warn(`[LifeQuote] clear field error failed for ${trackedFieldName}`, error);
    }
  }

  function showChoiceError(errorId, show) {
    const el = document.getElementById(errorId);
    if (!el) return;
    el.classList.toggle('visible', !!show);
  }

  function setFieldError(name, message) {
    const el = document.getElementById(`err-${name}`);
    if (!el) return;
    if (!el.dataset.defaultText) {
      el.dataset.defaultText = el.textContent || '';
    }
    el.textContent = message || el.dataset.defaultText;
    el.classList.add('visible');
  }

  function clearFieldError(name) {
    const el = document.getElementById(`err-${name}`);
    clearQuoteFieldError(name);
    if (!el) return;
    if (el.dataset.defaultText) {
      el.textContent = el.dataset.defaultText;
    }
    el.classList.remove('visible');
  }

  function getContactFieldError(name) {
    if (name === 'ContactMethod') {
      const phoneValue = asTrimmed(form.querySelector('[name="Phone"]')?.value || '');
      const emailValue = asTrimmed(form.querySelector('[name="Email"]')?.value || '');
      return phoneValue || emailValue ? '' : contactMethodErrorText;
    }

    if (name === 'MarketingEmailConsent') {
      return consentCheckbox?.checked ? '' : consentErrorText;
    }

    const el = form.querySelector(`[name="${name}"]`);
    if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement)) {
      return '';
    }

    const value = asTrimmed(el.value);
    if (name === 'Email') {
      if (!value) {
        return '';
      }

      if (el instanceof HTMLInputElement && !el.checkValidity()) {
        return 'Please enter a valid email address.';
      }

      return '';
    }

    if (!value) {
      if (!requiredContactFields.includes(name)) {
        return '';
      }

      return name === 'State'
        ? 'Please select your state.'
        : `Please enter your ${name === 'Email' ? 'email' : name === 'Phone' ? 'phone' : name === 'FirstName' ? 'first name' : 'last name'}.`;
    }

    if (name === 'Phone' && extractPhoneDigits(value).length !== 10) {
      return 'Please enter a valid phone number.';
    }

    return '';
  }

  function resolveContactErrorType(name, error) {
    if (name === 'Email' && /valid email/i.test(error || '')) {
      return 'invalid_email';
    }
    if (name === 'Phone' && /valid phone/i.test(error || '')) {
      return 'invalid_phone';
    }
    if (name === 'ContactMethod') {
      return 'contact_method_required';
    }
    if (name === 'MarketingEmailConsent') {
      return 'consent_required';
    }

    return 'required_missing';
  }

  function validateContactFields(focusFirst = false) {
    let firstInvalid = null;

    requiredContactFields.forEach((name) => {
      const error = getContactFieldError(name);
      if (error) {
        setFieldError(name, error);
        trackQuoteFieldError(name, resolveContactErrorType(name, error), 'contact');
        metaSignalApi?.trackFieldError(name, { fieldContext: 'contact' });
        if (name === 'ContactMethod') {
          firstInvalid ??= form.querySelector('[name="Email"]') || form.querySelector('[name="Phone"]');
        } else {
          firstInvalid ??= form.querySelector(`[name="${name}"]`);
        }
      } else {
        clearFieldError(name);
      }
    });

    const optionalEmailError = getContactFieldError('Email');
    if (optionalEmailError) {
      setFieldError('Email', optionalEmailError);
      trackQuoteFieldError('Email', resolveContactErrorType('Email', optionalEmailError), 'contact');
      metaSignalApi?.trackFieldError('Email', { fieldContext: 'contact' });
      firstInvalid ??= form.querySelector('[name="Email"]');
    } else {
      clearFieldError('Email');
    }

    const consentError = getContactFieldError('MarketingEmailConsent');
    if (consentError) {
      setFieldError('MarketingEmailConsent', consentError);
      trackQuoteFieldError('MarketingEmailConsent', resolveContactErrorType('MarketingEmailConsent', consentError), 'contact');
      metaSignalApi?.trackFieldError('MarketingEmailConsent', { fieldContext: 'contact' });
      firstInvalid ??= consentCheckbox;
    } else {
      clearFieldError('MarketingEmailConsent');
    }

    if (focusFirst && firstInvalid instanceof HTMLElement) {
      firstInvalid.focus();
    }

    return firstInvalid === null;
  }

  function clearAutoAdvanceTimer() {
    if (autoAdvanceTimer) {
      window.clearTimeout(autoAdvanceTimer);
      autoAdvanceTimer = null;
    }
