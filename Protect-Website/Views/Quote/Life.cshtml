    opacity: .78;
    padding: 0.6rem 1.05rem;
}
body.life-landing header .navbar .nav-link:hover,
body.life-landing header .navbar .nav-link:focus {
    opacity: 1;
    color: #fbe4a0 !important;
    background: rgba(199,153,49,0.08);
}

.lq-container{
    padding: 8px 16px 20px;
}

.lq-hero-shell{
    /* Cinematic outer shell: deep navy base + very subtle warm gold breath at the crown.
       Gives the ad-matched "premium dark" atmosphere without a flat slab look. */
    background:
        radial-gradient(ellipse 90% 38% at 50% 0%, rgba(199,153,49,0.07) 0%, transparent 68%),
        linear-gradient(180deg, #0a1224 0%, #0f1d35 50%, #0b1527 100%);
    border: 1.5px solid rgba(199,153,49,.44);
    border-radius: 18px;
    /* Deeper drop-shadow + 1px inner top edge for glass/depth cue */
    box-shadow:
        0 24px 46px rgba(0,0,0,0.34),
        inset 0 1px 0 rgba(199,153,49,0.09);
    padding: 18px 18px 14px 18px;
    max-width: 980px;
    margin: 14px auto 18px auto;
}

.form-control,
.form-select {
    border: 1.6px solid #c79931;
    margin-bottom: 10px;
    background: #ffffff;
    color: #0f172a;
    font-size: 0.95rem;
    padding: 10px 12px;
    border-radius: 8px;
}
.form-control::placeholder { color: rgba(15,23,42,0.55); }
.form-control:focus,
.form-select:focus {
    outline: none;
    box-shadow: 0 0 0 0.2rem rgba(199,153,49,0.22);
    border-color: #c79931;
    background: #ffffff;
    color: #0f172a;
}

.btn-gold {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #f3d688 0%, #e2ba5d 38%, #c69025 100%);
    color: #211503;
    font-weight: 920;
    padding: 14px 22px;
    border-radius: 14px;
    font-size: 1rem;
    line-height: 1.14;
    border: 1px solid #f1cf80;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.34),
        0 14px 28px rgba(0,0,0,0.28),
        0 0 0 1px rgba(241,207,128,0.20);
    transition: transform .18s cubic-bezier(0.22, 1, 0.36, 1), box-shadow .18s ease, filter .18s ease, background .18s ease;
    text-transform: none;
    letter-spacing: .01em;
    cursor: pointer;
    min-height: 56px;
    text-shadow: 0 1px 0 rgba(255,255,255,0.24);
    text-align: center;
    text-wrap: balance;
    white-space: normal;
    overflow-wrap: anywhere;
}
.btn-gold:hover {
    color: #211503;
    transform: translateY(-2px) scale(1.006);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.40),
        0 14px 26px rgba(0,0,0,.26),
        0 0 0 1px rgba(241,207,128,0.28),
        0 0 22px rgba(226,186,93,0.18);
    filter: saturate(1.03) brightness(1.01);
}
.btn-gold:active {
    color: #211503;
    transform: translateY(0) scale(0.992);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.28),
        0 8px 18px rgba(0,0,0,.28),
        0 0 0 1px rgba(241,207,128,0.22);
}
.btn-gold:focus-visible {
    outline: 3px solid rgba(248,227,170,0.95);
    outline-offset: 2px;
}
#step1Continue,
#continueToContactBtn,
#submitLife {
    text-wrap: balance;
}
.text-gold { color: #c79931; }

