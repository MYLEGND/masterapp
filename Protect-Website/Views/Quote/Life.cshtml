  function persistFunnelState() {
    if (isRestoringFunnelState) {
      return;
    }

    const storage = getSessionStorageSafe();
    if (!storage) {
      return;
    }

    if (shouldStartOnLandingHero && !quoteEntryStarted) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      return;
    }

    if (postSubmitSuccessActive) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      return;
    }

    const state = buildPersistedFunnelState();
    if (!hasMeaningfulPersistedState(state)) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      return;
    }

    try {
      storage.setItem(FUNNEL_STATE_STORAGE_KEY, JSON.stringify(state));
    } catch {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
    }
  }

  async function restorePersistedFunnelState() {
    const storage = getSessionStorageSafe();
    if (!storage) {
      resetFunnelToMarkupDefaults();
      return false;
    }

    const raw = storage.getItem(FUNNEL_STATE_STORAGE_KEY);
    if (!raw) {
      resetFunnelToMarkupDefaults();
      return false;
    }

    let state = null;
    try {
      state = JSON.parse(raw);
    } catch {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    if (!state || typeof state !== 'object') {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    if (asTrimmed(state.scope) && asTrimmed(state.scope) !== FUNNEL_STATE_SCOPE) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    if (Number.isFinite(state.timestamp) && Date.now() - Number(state.timestamp) > FUNNEL_STATE_MAX_AGE_MS) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    const restoredFields = state.fields && typeof state.fields === 'object' ? state.fields : {};
    const restoredHasRealDiscoveryChoice =
      asTrimmed(restoredFields.ProtectingWho || '') !== '' ||
      asTrimmed(restoredFields.CoverageGoal || '') !== '' ||
      asTrimmed(restoredFields.CoverageAmountOption || '') !== '' ||
      asTrimmed(restoredFields.TobaccoUse || '') !== '';
    const restoredHasRealContactInput =
      asTrimmed(restoredFields.FirstName || '') !== '' ||
      asTrimmed(restoredFields.LastName || '') !== '' ||
      asTrimmed(restoredFields.Phone || '') !== '' ||
      asTrimmed(restoredFields.Email || '') !== '' ||
      asTrimmed(restoredFields.State || '') !== '';
    const restoredIsPastDiscovery =
      state.activePanel === 'contact' ||
      state.activePanel === 'results' ||
      state.activePanel === 'processing' ||
      Boolean(state.latestEstimatePreview);

    if (shouldStartOnLandingHero && !restoredHasRealDiscoveryChoice && !restoredHasRealContactInput && !restoredIsPastDiscovery) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    isRestoringFunnelState = true;
    setQuoteEntryStarted(true);

    const fields = state.fields && typeof state.fields === 'object' ? state.fields : {};
    setRadioValue('ProtectingWho', fields.ProtectingWho || '');
    setRadioValue('CoverageGoal', fields.CoverageGoal || '');
    setRadioValue('CoverageAmountOption', fields.CoverageAmountOption || '');
    setRadioValue('TobaccoUse', fields.TobaccoUse || '');
    const restoredAgeValue = resolveStoredAgeValue(fields.AgeValue || fields.AgeBracket || '');
    syncAgePickerUi(restoredAgeValue || AGE_DEFAULT, !!restoredAgeValue);
    setFieldValue('FirstName', fields.FirstName || '');
    setFieldValue('LastName', fields.LastName || '');
    setFieldValue('Phone', fields.Phone || '');
    setFieldValue('Email', fields.Email || '');
    setFieldValue('State', fields.State || '');
    if (consentCheckbox) {
      consentCheckbox.checked = String(fields.MarketingEmailConsent || '').toLowerCase() === 'true';
    }
    form.querySelectorAll('input[name="Phone"]').forEach((input) => {
      if (input instanceof HTMLInputElement) {
        input.value = formatPhoneNumber(input.value);
      }
    });

    latestEstimatePreview = state.latestEstimatePreview || null;
    applyEstimatePreviewToHiddenFields(latestEstimatePreview);
    syncStepOneAnswersFromUI();

    const restoredMicroStep = Number.isFinite(Number(state.currentMicroStep))
      ? Math.max(0, Math.min(microSteps.length - 1, Number(state.currentMicroStep)))
      : resolveInitialMicroStep();

    try {
      if (state.activePanel === 'results') {
        let preview = latestEstimatePreview;
        if (!preview) {
          preview = await ensureEstimatePreview();
        }
        currentMicroStep = restoredMicroStep;
        await showStep2(false, {
          estimatePreview: preview,
          trackView: false,
          trackRecommendationView: false
        });
      } else if (state.activePanel === 'contact') {
        currentMicroStep = restoredMicroStep;
        await showStep2(false, {
          estimatePreview: latestEstimatePreview,
          trackView: false,
          trackRecommendationView: false
        });
