  function maybeMarkContactFieldCompleted(fieldName, el, trigger = 'input') {
    const rule = contactFieldCompletionRules[fieldName];
    if (typeof rule !== 'function') return;

    const value = el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement
      ? String(el.value || '')
      : '';
    const isComplete = Boolean(rule(value, el));
    const state = contactFieldProgress.get(fieldName) || {};

    contactFieldProgress.set(fieldName, {
      ...state,
      currentComplete: isComplete
    });

    if (!isComplete || state.completed) return;

    contactFieldProgress.set(fieldName, {
      ...state,
      currentComplete: true,
      completed: true,
      completedAt: Date.now()
    });

    void trackContactFieldEvent('contact_field_complete', fieldName, el, { trigger });
    void trackContactFieldEvent('form_field_complete', fieldName, el, { trigger });
