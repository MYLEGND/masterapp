        var fallbackGoalQuestion = normalizedOfferKey switch
        {
            "term" => "What would you want term life to help protect first?",
            "wholelife" => "What would you want whole life to help with most?",
            "finalexpense" => "What would you want final expense coverage to help with first?",
            "mortgage" => "What would you want protected if something happened to you?",
            "iul" => "What would you want this IUL coverage to help with most?",
            _ => "What would you want this coverage to help with first?"
        };

        var fallbackProtectQuestion = normalizedOfferKey switch
        {
            "wholelife" => "Who would you want that protection to support?",
            "finalexpense" => "Who could be left carrying those costs?",
            "mortgage" => "Who depends on the home?",
            "iul" => "Who would you want that protection to support?",
            _ => "Who depends on you most?"
        };

        var fallbackCoverageQuestion = normalizedOfferKey switch
        {
            "term" => "About how much term coverage would you like to explore?",
            "wholelife" => "About how much whole life coverage would you like to explore?",
            "finalexpense" => "About how much final expense coverage would you like to explore?",
            "mortgage" => "Approximate mortgage balance",
            "iul" => "About how much IUL coverage would you like to explore?",
            _ => "About how much coverage would you like to explore?"
        };

