@if (isPaidLandingExperience)
{
    <script src="~/js/meta-signal-intelligence.js" asp-append-version="true"></script>
}
<script src="~/js/life-estimate-engine.js" asp-append-version="true"></script>
<script src="~/js/trusted-carrier-strip.js" asp-append-version="true"></script>
<script>
(async () => {
  const form = document.getElementById('lifeWizardForm');
  if (!form) return;

  const contactFirstPanel = document.getElementById('lifeEducationContactPanel');
  const startCtaButtons = Array.from(document.querySelectorAll('[data-life-funnel-start]'));
  const primaryCtaTargets = Array.from(document.querySelectorAll('[data-primary-cta]'));
  const stickyPrimaryCtaWrap = document.getElementById('lifeStickyPrimaryCtaWrap');
  const step1Panel = document.getElementById('lifeStep1Panel');
  const processingPanel = document.getElementById('lifeProcessingPanel');
  const step2Panel = document.getElementById('lifeStep2Panel');
  const processingHeading = document.getElementById('lifeProcessingHeading');
  const processingHelper = processingPanel?.querySelector('.lq-step-helper');
  const processingNote = processingPanel?.querySelector('.lq-processing-note');
  const step2Progress = document.getElementById('lifeStep2Progress');
  const step2Heading = document.getElementById('lifeStep2Heading');
  const step2Helper = document.getElementById('lifeStep2Helper');
  const step2ContactTitle = document.getElementById('lifeStep2ContactTitle');
  const step2ContactCopy = document.getElementById('lifeStep2ContactCopy');
  const step2ContactMethodHelp = document.getElementById('lifeContactMethodHelp');
  const processingFill = document.getElementById('lifeProcessingFill');
  const step1Progress = document.getElementById('lifeStep1Progress');
  const step1ProgressFill = document.getElementById('lifeStep1ProgressFill');
  const heroTrustStrip = document.getElementById('lifeHeroTrustStrip');
  const step2EstimateSlot = document.getElementById('lifeStep2EstimateSlot');
  const contactCaptureWrap = document.getElementById('lifeContactCaptureWrap');
  const postSubmitSlot = document.getElementById('lifePostSubmitSlot');
  const bookingModal = document.getElementById('lifeBookingModal');
  const bookingModalFrameSlot = document.getElementById('lifeBookingModalFrameSlot');
  const bookingModalStatus = document.getElementById('lifeBookingModalStatus');
  const bookingModalCloseButtons = Array.from(document.querySelectorAll('[data-booking-modal-close]'));
  const microSteps = Array.from(document.querySelectorAll('[data-micro-step]'));
  const ageStepContinueBtn = document.getElementById('ageStepContinueBtn');
  const step1ContinueBtn = document.getElementById('step1Continue');
  const step2BackBtn = document.getElementById('step2BackBtn');
  const tobaccoStepBackBtn = document.getElementById('tobaccoStepBackBtn');
  const showContactStepByDefault = '@(showContactStepByDefault ? "true" : "false")' === 'true';
  const answer1Hidden = document.getElementById('Answer1');
  const answer2Hidden = document.getElementById('Answer2');
  const answer3Hidden = document.getElementById('Answer3');
  const answer4Hidden = document.getElementById('Answer4');
  const ageHidden = document.getElementById('AgeRange');
  const coverageAmountHidden = document.getElementById('CoverageAmount');
  const focusHidden = document.getElementById('ProtectFocus');
  const submitBtn = document.getElementById('submitLife');
  const submitLabel = submitBtn?.dataset.defaultLabel || 'Submit';
  const consentCheckbox = form.querySelector('input[name="MarketingEmailConsent"][type="checkbox"]');
  const recPrimaryKeyEl = document.getElementById('RecommendationPrimaryKey');
  const recPrimaryTitleEl = document.getElementById('RecommendationPrimaryTitle');
  const recSecondaryKeyEl = document.getElementById('RecommendationSecondaryKey');
  const recSecondaryTitleEl = document.getElementById('RecommendationSecondaryTitle');
  const estimatePreviewUrl = '@Url.Action("EstimatePreview", "LifeQuote")';
  const pageKey = form.dataset.formKey || 'quote_life';
  const quoteType = '@normalizedOfferKey';
  const metaBrowserAckUrl = '/Quote/Life/meta-browser-ack';
  const bookingExperienceUrl = '@Url.Action("ActivatePublicBookingExperience", "LifeQuote")';
  const bookingConfirmationUrl = '@Url.Action("ConfirmPublicBookingExperience", "LifeQuote")';
  const pageVariant = '@pageVariant';
  const pageMode = '@pageMode';
  const firstDiscoveryFieldName = '@firstDiscoveryFieldName';
  const firstDiscoveryQuestionId = '@firstDiscoveryQuestionId';
  const isPaidLandingExperience = '@(isPaidLandingExperience ? "true" : "false")' === 'true';
  const startEvent = '@cfg.StartEvent';
  const submitEvent = '@cfg.SubmitEvent';
  const usesLeanContactFields = '@(usesLeanContactFields ? "true" : "false")' === 'true';
  const hasServerErrors = '@(ViewData.ModelState.ErrorCount > 0 ? "true" : "false")' === 'true';
  const hasAgentTrustProfile = '@(showAgentTrustCard ? "true" : "false")' === 'true';
  const isContactFirstEducationVariant = '@(isContactFirstEducationVariant ? "true" : "false")' === 'true';
  const isLowFrictionOptionsVariant = '@(isLowFrictionOptionsVariant ? "true" : "false")' === 'true';
  const tracksContactFirstFlow = '@(tracksContactFirstFlow ? "true" : "false")' === 'true';
  const agentDirectContactName = @Html.Raw(JsonSerializer.Serialize(agentDirectContactName));
  const agentTrackingSlug = '@agentSlug';
  const agentTrackingProfileId = '@(agentTrustProfile?.AgentTrackingProfileId.ToString() ?? string.Empty)';
  const isLandingMobile = document.body.classList.contains('life-landing') && window.matchMedia('(max-width: 767.98px)').matches;
  const stateSelect = document.getElementById('State');
  const ageInput = document.getElementById('Age');
  const agePickers = Array.from(form.querySelectorAll('[data-age-picker]'));
  const ageSliders = Array.from(form.querySelectorAll('[data-age-slider]'));
  const ageDisplays = Array.from(form.querySelectorAll('[data-age-display]'));
  const ageQuickButtons = Array.from(form.querySelectorAll('[data-age-quick-select]'));
  const requiredContactFields = ['FirstName', 'ContactMethod'];
  const contactFieldNames = usesLeanContactFields
    ? ['FirstName', 'LastName', 'Phone', 'Email']
    : ['FirstName', 'LastName', 'Phone', 'Email', 'State'];
  const firstQuestionElement = document.getElementById(firstDiscoveryQuestionId);
  const metaSignal = window.metaSignalIntelligence?.createLandingSession(@Html.Raw(metaSignalConfigJson)) || null;
  const metaSignalApi = metaSignal && typeof metaSignal === 'object'
    ? new Proxy(metaSignal, {
        get(target, prop, receiver) {
          const value = Reflect.get(target, prop, receiver);
          if (typeof value !== 'function') {
            return value;
          }

          return (...args) => Promise.resolve()
            .then(() => value.apply(target, args))
            .catch((error) => {
              console.warn(`[LifeQuote] meta signal ${String(prop)} failed`, error);
              return null;
            });
        }
      })
    : null;
  const AGE_RANGE_TO_NUMERIC = Object.freeze(@Html.Raw(ageRangeToNumericJson));
  const AGE_MIN = @minSelectableAge;
  const AGE_MAX = @maxSelectableAge;
  const AGE_DEFAULT = @selectedAgeValue;
  const AGE_SELECTION_PROVIDED = '@(hasExplicitAgeSelection ? "true" : "false")' === 'true';
  const PROCESSING_BRIDGE_MS = 450;
  const postSubmitSuccessHeadingText = 'Your personalized review is ready.';
  const postSubmitSuccessHelperText = 'Review the recommendation below, then schedule while this is fresh if you want help comparing the fit in more detail.';
  const publicBookingHeadingText = 'Continue Your Review';
  const publicBookingKickerText = 'Continue your review';
  const publicBookingCopyText = 'Choose a time to continue your personalized review, compare what surfaced, and confirm what may realistically fit best.';
  const publicBookingCtaText = 'Continue Your Review';
  const publicBookingFallbackText = '';
  const publicBookingLoadingText = 'Preparing your scheduling options...';
  const publicBookingDisabledText = 'Your estimate is saved. Scheduling is not available in this view right now, but a licensed agent can still continue your personalized review.';
  const publicBookingFallbackOnlyText = 'Continue your review in scheduling. It opens in a new tab for now.';
  const publicBookingPendingText = 'We only mark appointments as booked after Microsoft confirms the scheduling request.';
  const defaultProcessingHeadingText = processingHeading?.textContent?.trim() || '';
  const defaultProcessingHelperText = processingHelper?.textContent?.trim() || '';
  const defaultProcessingNoteText = processingNote?.textContent?.trim() || '';
  const defaultStep2ProgressText = step2Progress?.textContent?.trim() || '';
  const defaultStep2HeadingText = step2Heading?.textContent?.trim() || '';
  const defaultStep2HelperText = step2Helper?.textContent?.trim() || '';
  const defaultStep2HelperHidden = step2Helper?.hidden ?? true;
  const defaultStep2ContactTitleText = step2ContactTitle?.textContent?.trim() || '';
  const defaultStep2ContactCopyText = step2ContactCopy?.textContent?.trim() || '';
  const defaultStep2ContactMethodHelpText = step2ContactMethodHelp?.textContent?.trim() || '';
  const contactMethodErrorText = @Html.Raw(JsonSerializer.Serialize(contactMethodErrorText));
  const consentErrorText = @Html.Raw(JsonSerializer.Serialize(consentErrorText));
  const FUNNEL_STATE_SCOPE = `${window.location.pathname}:${pageKey}:${pageVariant}:${pageMode}:${quoteType}`;
  const FUNNEL_STATE_STORAGE_KEY = `life-funnel:${FUNNEL_STATE_SCOPE}`;
  const FUNNEL_STATE_MAX_AGE_MS = 1000 * 60 * 60 * 12;
  const isAgeBeforeTobaccoFlow = '@(usesAgeBeforeTobaccoFlow ? "true" : "false")' === 'true';
  const discoveryStepSequence = Object.freeze(@Html.Raw(JsonSerializer.Serialize(
    new[] { "CoverageGoal", "ProtectingWho", "CoverageAmountOption", "Age", "TobaccoUse" })));
  const discoveryStepIndexes = Object.freeze(discoveryStepSequence.reduce((accumulator, fieldName, index) => {
    accumulator[fieldName] = index;
    return accumulator;
  }, {}));
  const microStepViewEvents = Object.freeze(@Html.Raw(JsonSerializer.Serialize(
    new[] { "life_step1_goal_view", "life_step1_protecting_view", "life_step1_coverage_view", "life_step1_age_view", "life_step1_tobacco_view" })));
  const finalDiscoveryContinueEvent = isAgeBeforeTobaccoFlow ? 'life_step1_tobacco_continue' : 'life_step1_age_continue';
  let currentMicroStep = 0;
  let autoAdvanceTimer = null;
  let processingTimer = null;
  let processingStageTimers = [];
  let latestEstimatePreview = null;
  let estimatePreviewPromise = null;
  let isRestoringFunnelState = false;
  let primaryCtaSeenTracked = false;
  let firstQuestionViewTracked = false;
  let firstQuestionAnsweredTracked = false;
  let contactStepViewTracked = false;
  let thankYouViewTracked = false;
  let postSubmitSuccessActive = false;
  let publicBookingState = null;
  let publicBookingEmbedViewed = false;
  let publicBookingBookedConfirmed = false;
  let publicBookingConfirmationRequested = false;
  let publicBookingSlotSelectedTracked = false;
  let publicBookingFallbackClicked = false;
  let publicBookingAbandonedTracked = false;

  function safeTrackingCall(label, factory) {
    try {
      return Promise.resolve(factory()).catch((error) => {
        console.warn(`[LifeQuote] ${label} failed`, error);
        return null;
      });
    } catch (error) {
      console.warn(`[LifeQuote] ${label} failed`, error);
      return Promise.resolve(null);
    }
  }

  if (stateSelect?.dataset.selected) {
    stateSelect.value = stateSelect.dataset.selected;
  }

  function getSessionStorageSafe() {
    try {
      return window.sessionStorage;
    } catch {
      return null;
    }
  }

  function getVisibleFunnelPanel() {
    if (step2Panel && !step2Panel.hidden) return step2Panel;
    if (processingPanel && !processingPanel.hidden) return processingPanel;
    return step1Panel;
  }

  function getActivePanelKey() {
    if (postSubmitSuccessActive) return 'success';
    if (step2Panel && !step2Panel.hidden) return 'contact';
    if (processingPanel && !processingPanel.hidden) return 'processing';
    return 'step1';
  }

  function setRadioValue(name, value) {
    if (!value) return;
    const radio = form.querySelector(`input[name="${name}"][value="${CSS.escape(String(value))}"]`);
    if (radio instanceof HTMLInputElement) {
      radio.checked = true;
    }
  }

  function setFieldValue(name, value) {
    const el = form.querySelector(`[name="${name}"]`);
    if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement)) {
      return;
    }
    el.value = value ?? '';
  }

  function resolveAgeBand(ageValue) {
    const parsedAge = Number.parseInt(String(ageValue ?? ''), 10);
    if (!Number.isFinite(parsedAge)) {
      return '';
    }

    if (quoteType === 'finalexpense') {
      if (parsedAge <= 54) return '45-54';
      if (parsedAge <= 64) return '55-64';
      if (parsedAge <= 74) return '65-74';
      return '75+';
    }

    if (parsedAge <= 24) return '18-24';
    if (parsedAge <= 34) return '25-34';
    if (parsedAge <= 44) return '35-44';
    if (parsedAge <= 54) return '45-54';
    return '55+';
  }

  function resolveStoredAgeValue(value) {
    const trimmedValue = String(value ?? '').trim();
    if (!trimmedValue) {
      return '';
    }

    const parsedAge = Number.parseInt(trimmedValue, 10);
    if (Number.isFinite(parsedAge)) {
      return String(Math.max(AGE_MIN, Math.min(AGE_MAX, parsedAge)));
    }

    const mappedAge = AGE_RANGE_TO_NUMERIC[trimmedValue];
    return Number.isFinite(mappedAge) ? String(mappedAge) : '';
  }

  function getCurrentSliderAgeValue() {
    const slider = ageSliders[0];
    return slider instanceof HTMLInputElement ? resolveStoredAgeValue(slider.value) : '';
  }

  function hasExplicitAgeSelectionInUi() {
    return agePickers.some((picker) => picker.dataset.ageSelected === 'true');
  }

  function syncAgePickerUi(ageValue, isSelected) {
    const resolvedAge = resolveStoredAgeValue(ageValue) || String(AGE_DEFAULT);
    const numericAge = Number.parseInt(resolvedAge, 10);
    const progress = Number.isFinite(numericAge) && AGE_MAX > AGE_MIN
      ? ((numericAge - AGE_MIN) / (AGE_MAX - AGE_MIN)) * 100
      : 0;
    const pillText = isSelected ? resolvedAge : 'Select age';
    const resolvedBand = resolveAgeBand(resolvedAge);

    agePickers.forEach((picker) => {
      picker.dataset.ageSelected = isSelected ? 'true' : 'false';
      picker.classList.toggle('is-active', isSelected);
      picker.style.setProperty('--age-progress', `${Math.max(0, Math.min(100, progress))}%`);
    });

    ageSliders.forEach((slider) => {
      slider.value = resolvedAge;
      slider.setAttribute('aria-valuetext', isSelected ? `${resolvedAge} years old` : 'Select your age');
    });

    ageDisplays.forEach((display) => {
      display.textContent = pillText;
    });

    ageQuickButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      button.classList.toggle(
        'is-active',
        isSelected && String(button.dataset.ageRange || '').trim() === resolvedBand
      );
    });
  }

  function getSelectedAgeValue() {
    return hasExplicitAgeSelectionInUi() ? getCurrentSliderAgeValue() : '';
  }

  function getSelectedAgeBand() {
    return resolveAgeBand(getSelectedAgeValue());
  }

  function extractPhoneDigits(value) {
    return String(value ?? '').replace(/\D/g, '').slice(0, 10);
  }

  function formatPhoneNumber(value) {
    const digits = extractPhoneDigits(value);
    if (!digits) {
      return '';
    }
    if (digits.length < 4) {
      return `(${digits}`;
    }
    if (digits.length < 7) {
      return `(${digits.slice(0, 3)})${digits.slice(3)}`;
    }
    return `(${digits.slice(0, 3)})${digits.slice(3, 6)}-${digits.slice(6)}`;
  }

  function hasMeaningfulPersistedState(state) {
    if (!state || typeof state !== 'object') {
      return false;
    }

    const fieldValues = state.fields && typeof state.fields === 'object' ? Object.values(state.fields) : [];
    return fieldValues.some((value) => asTrimmed(String(value ?? '')) !== '')
      || Boolean(state.latestEstimatePreview)
      || state.activePanel === 'results'
      || state.activePanel === 'contact'
      || Number.isFinite(state.currentMicroStep) && Number(state.currentMicroStep) > 0;
  }

  function resetFunnelToMarkupDefaults() {
    resetPostSubmitSuccessState();
    form.reset();
    if (stateSelect?.dataset.selected) {
      stateSelect.value = stateSelect.dataset.selected;
    }
    form.querySelectorAll('input[name="Phone"]').forEach((input) => {
      if (input instanceof HTMLInputElement) {
        input.value = formatPhoneNumber(input.value);
      }
    });
    syncAgePickerUi(AGE_DEFAULT, AGE_SELECTION_PROVIDED);

    latestEstimatePreview = null;
    estimatePreviewPromise = null;
    currentMicroStep = 0;
    renderStep2EstimateSummary(null);
    applyEstimatePreviewToHiddenFields(null);
  }

  function buildPersistedFunnelState() {
    syncStepOneAnswersFromUI();

    return {
      scope: FUNNEL_STATE_SCOPE,
      currentMicroStep,
      activePanel: getActivePanelKey(),
      latestEstimatePreview,
      fields: {
        ProtectingWho: selectedRadio('ProtectingWho')?.value || '',
        CoverageGoal: selectedRadio('CoverageGoal')?.value || '',
        CoverageAmountOption: selectedRadio('CoverageAmountOption')?.value || '',
        TobaccoUse: selectedRadio('TobaccoUse')?.value || '',
        AgeBracket: getSelectedAgeBand(),
        AgeValue: getSelectedAgeValue(),
        FirstName: asTrimmed(form.querySelector('[name="FirstName"]')?.value || ''),
        LastName: asTrimmed(form.querySelector('[name="LastName"]')?.value || ''),
        Phone: asTrimmed(form.querySelector('[name="Phone"]')?.value || ''),
        Email: asTrimmed(form.querySelector('[name="Email"]')?.value || ''),
        State: asTrimmed(form.querySelector('[name="State"]')?.value || ''),
        MarketingEmailConsent: consentCheckbox?.checked ? 'true' : ''
      },
      timestamp: Date.now()
    };
  }

  function clearPersistedFunnelState() {
    const storage = getSessionStorageSafe();
    if (!storage) return;
    storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
  }

  function persistFunnelState() {
    if (isRestoringFunnelState) {
      return;
    }

    const storage = getSessionStorageSafe();
    if (!storage) {
      return;
    }

    if (postSubmitSuccessActive) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      return;
    }

    const state = buildPersistedFunnelState();
    if (!hasMeaningfulPersistedState(state)) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      return;
    }

    try {
      storage.setItem(FUNNEL_STATE_STORAGE_KEY, JSON.stringify(state));
    } catch {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
    }
  }

  async function restorePersistedFunnelState() {
    const storage = getSessionStorageSafe();
    if (!storage) {
      resetFunnelToMarkupDefaults();
      return false;
    }

    const raw = storage.getItem(FUNNEL_STATE_STORAGE_KEY);
    if (!raw) {
      resetFunnelToMarkupDefaults();
      return false;
    }

    let state = null;
    try {
      state = JSON.parse(raw);
    } catch {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    if (!state || typeof state !== 'object') {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    if (asTrimmed(state.scope) && asTrimmed(state.scope) !== FUNNEL_STATE_SCOPE) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    if (Number.isFinite(state.timestamp) && Date.now() - Number(state.timestamp) > FUNNEL_STATE_MAX_AGE_MS) {
      storage.removeItem(FUNNEL_STATE_STORAGE_KEY);
      resetFunnelToMarkupDefaults();
      return false;
    }

    isRestoringFunnelState = true;

    const fields = state.fields && typeof state.fields === 'object' ? state.fields : {};
    setRadioValue('ProtectingWho', fields.ProtectingWho || '');
    setRadioValue('CoverageGoal', fields.CoverageGoal || '');
    setRadioValue('CoverageAmountOption', fields.CoverageAmountOption || '');
    setRadioValue('TobaccoUse', fields.TobaccoUse || '');
    const restoredAgeValue = resolveStoredAgeValue(fields.AgeValue || fields.AgeBracket || '');
    syncAgePickerUi(restoredAgeValue || AGE_DEFAULT, !!restoredAgeValue);
    setFieldValue('FirstName', fields.FirstName || '');
    setFieldValue('LastName', fields.LastName || '');
    setFieldValue('Phone', fields.Phone || '');
    setFieldValue('Email', fields.Email || '');
    setFieldValue('State', fields.State || '');
    if (consentCheckbox) {
      consentCheckbox.checked = String(fields.MarketingEmailConsent || '').toLowerCase() === 'true';
    }
    form.querySelectorAll('input[name="Phone"]').forEach((input) => {
      if (input instanceof HTMLInputElement) {
        input.value = formatPhoneNumber(input.value);
      }
    });

    latestEstimatePreview = state.latestEstimatePreview || null;
    applyEstimatePreviewToHiddenFields(latestEstimatePreview);
    syncStepOneAnswersFromUI();

    const restoredMicroStep = Number.isFinite(Number(state.currentMicroStep))
      ? Math.max(0, Math.min(microSteps.length - 1, Number(state.currentMicroStep)))
      : resolveInitialMicroStep();

    try {
      if (state.activePanel === 'results') {
        let preview = latestEstimatePreview;
        if (!preview) {
          preview = await ensureEstimatePreview();
        }
        currentMicroStep = restoredMicroStep;
        await showStep2(false, {
          estimatePreview: preview,
          trackView: false,
          trackRecommendationView: false
        });
      } else if (state.activePanel === 'contact') {
        currentMicroStep = restoredMicroStep;
        await showStep2(false, {
          estimatePreview: latestEstimatePreview,
          trackView: false,
          trackRecommendationView: false
        });
      } else if (state.activePanel === 'processing') {
        if (latestEstimatePreview) {
          currentMicroStep = restoredMicroStep;
          await showStep2(false, {
            estimatePreview: latestEstimatePreview,
            trackView: false,
            trackRecommendationView: false
          });
        } else {
          showStep1(restoredMicroStep, false, { trackView: false });
        }
      } else {
        showStep1(restoredMicroStep, false, { trackView: false });
      }
    } finally {
      isRestoringFunnelState = false;
    }

    return true;
  }

