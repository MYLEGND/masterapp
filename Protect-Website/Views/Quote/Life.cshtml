    const focusedFields = fields.filter((fieldName) => contactFieldProgress.get(fieldName)?.focused);
    const lastFocusedField = [...contactFieldProgress.entries()].filter(([, state]) => state.focusedAt).sort((a, b) => b[1].focusedAt - a[1].focusedAt)[0]?.[0] || '';
    const lastCompletedField = [...contactFieldProgress.entries()].filter(([, state]) => state.completedAt).sort((a, b) => b[1].completedAt - a[1].completedAt)[0]?.[0] || '';

    return {
