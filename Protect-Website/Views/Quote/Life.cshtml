.lq-step-progress-wrap .lq-step-progress{ margin-bottom: 0; }
.lq-step-progress-track{
    width: 100%;
    height: 6px;
    border-radius: 999px;
    background: rgba(199,153,49,0.16);
    border: 1px solid rgba(199,153,49,0.30);
    overflow: hidden;
}
.lq-step-progress-fill{
    display: block;
    width: 25%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #be8c25 0%, #efc86f 100%);
    transition: width .18s ease;
}
.lq-micro-step[hidden]{ display:none !important; }
.lq-micro-back{
    margin-top: 6px;
    min-width: 96px;
}
.lq-processing-bridge {
    margin: 14px 0 8px;
}
.lq-processing-track {
    width: 100%;
    height: 10px;
    background: rgba(199,153,49,0.18);
    border: 1px solid rgba(199,153,49,0.42);
    border-radius: 999px;
    overflow: hidden;
    box-shadow: inset 0 1px 3px rgba(0,0,0,0.35);
}
.lq-processing-fill {
    width: 0;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #b8851d 0%, #e6c06b 52%, #f3d78f 100%);
    box-shadow: 0 0 14px rgba(230,192,107,0.45);
}
.lq-processing-note {
    margin-top: 8px;
    color: rgba(248,250,252,0.68);
    font-size: .82rem;
    font-weight: 700;
}
.lq-value-list {
    display: grid;
    gap: 10px;
    margin: 6px 0 14px;
}
.lq-value-item {
    background: rgba(24,39,63,0.76);
    border: 1.4px solid rgba(199,153,49,0.34);
    border-radius: 10px;
    color: #f8fafc;
    font-size: .92rem;
    font-weight: 760;
    line-height: 1.35;
    padding: 11px 12px;
}
.lq-value-item strong {
    color: #f3d78f;
    font-weight: 860;
}
.lq-value-note {
    text-align: center;
    color: rgba(248,250,252,0.8);
    font-size: .9rem;
    font-weight: 700;
    margin-bottom: 4px;
}

/* Step panels — frame layer sits between outer shell and inner surface */
.lq-step-panel {
    max-width: 760px;
    width: 100%;
    margin: 0 auto 12px auto;
    background: #122541;
    border: 1.5px solid rgba(199,153,49,.44);
    border-radius: 12px;
    box-shadow: 0 16px 34px rgba(0,0,0,0.30);
    animation: lqFadeIn 0.22s ease;
    position: relative;
}
.lq-inner-block {
    /* Primary interaction surface — noticeably lighter than the panel frame
       so the eye reads it immediately as the place to act. */
    background: #1c2f4e;
    border: 1.4px solid rgba(199,153,49,0.60);
    border-radius: 12px;
    padding: 20px 18px 16px 18px;
    /* Subtle elevation: modest drop shadow + 1px gold rim at the top edge */
    box-shadow:
        0 8px 24px rgba(0,0,0,0.26),
        inset 0 1px 0 rgba(199,153,49,0.11);
}
.lq-step-title {
    font-size: 1.2rem;
    font-weight: 900;
    color: #c79931;
    margin-bottom: 6px;
}
.lq-step-helper {
    font-size: .94rem;
    color: rgba(248,250,252,0.7);
    margin-bottom: 16px;
}
.lq-step-panel-pad { padding: 14px; }

@@keyframes lqFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
}

.lq-choice-group { margin-bottom: 6px; }
.lq-choice-label {
    font-weight: 800;
    font-size: 1rem;
    color: #f8fafc;
    margin-bottom: 10px;
}
.lq-step-question {
    font-size: 1.28rem;
    font-weight: 940;
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: #fff6d8;
    margin-bottom: 8px;
}
.lq-step-kicker {
    font-size: .82rem;
    font-weight: 820;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: rgba(248,250,252,0.62);
    margin-bottom: 6px;
}
.lq-choice-grid {
    display: grid;
    gap: 9px;
    grid-template-columns: 1fr;
}
.lq-choice-grid.lq-grid-2 { grid-template-columns: 1fr 1fr; }
.lq-choice-grid.lq-step1-twoup .lq-card {
    min-height: 66px;
    padding: 13px 9px;
}
.lq-choice-grid.lq-step1-twoup .lq-card span {
    overflow-wrap: anywhere;
}
.lq-choice-grid.lq-age-grid .lq-age-wide {
    grid-column: 1 / -1;
}
@@media (min-width: 600px) {
    .lq-choice-grid.lq-grid-2 { grid-template-columns: repeat(2, 1fr); }
}
.lq-card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 14px 10px;
    min-height: 58px;
    border: 1.7px solid rgba(223,183,90,0.54);
    border-radius: 10px;
    background:
        linear-gradient(180deg, rgba(42,61,92,0.98) 0%, rgba(30,45,70,0.98) 100%);
    color: #f8fafc;
    font-weight: 800;
    font-size: .95rem;
    cursor: pointer;
    transition: border-color .2s ease, background .2s ease, box-shadow .2s ease, color .2s ease, transform .18s cubic-bezier(0.22, 1, 0.36, 1), filter .2s ease;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    line-height: 1.25;
    position: relative;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.05),
        0 9px 20px rgba(0,0,0,0.19);
}
.lq-card:hover {
    border-color: rgba(244,210,124,0.88);
    background:
        linear-gradient(180deg, rgba(49,70,103,0.99) 0%, rgba(34,51,79,0.99) 100%);
    transform: translateY(-2px) scale(1.012);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.07),
        0 14px 28px rgba(0,0,0,0.25),
        0 0 0 1px rgba(244,210,124,0.16);
    filter: saturate(1.05);
}
.lq-card:active {
    transform: translateY(0) scale(0.992);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.06),
        0 6px 14px rgba(0,0,0,0.24);
    filter: saturate(1.04);
}
.lq-card input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
}
.lq-card.lq-selected,
.lq-card:has(input:checked) {
    border-color: #f4d58b;
    background:
        linear-gradient(180deg, rgba(210,166,62,0.28) 0%, rgba(128,89,20,0.18) 100%),
        linear-gradient(180deg, rgba(45,64,96,0.99) 0%, rgba(32,48,74,0.99) 100%);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.1),
        0 16px 30px rgba(0,0,0,0.28),
        0 0 0 2px rgba(244,210,124,0.56),
        0 0 24px rgba(244,210,124,0.22);
    color: #f8fafc;
    transform: translateY(-3px) scale(1.015);
}
.lq-card.lq-selected:active,
.lq-card:has(input:checked):active {
    transform: translateY(-1px) scale(1.005);
}
.lq-card.lq-invalid { border-color: #ef4444; }
.lq-choice-error {
    color: #f87171;
    font-size: .82rem;
    margin-top: 4px;
    min-height: 18px;
    display: none;
}
.lq-choice-error.visible { display: block; }

.lq-step-actions { margin-top: 16px; }
.lq-step-actions.dual {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}
#step2BackBtn{
    display: block;
    width: auto;
    min-width: 120px;
    margin: 10px auto 0;
}
.lq-reassurance {
    text-align: center;
    font-size: .84rem;
    color: rgba(248,250,252,0.55);
    margin-top: 6px;
}
.lq-contact-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
}
@@media (min-width: 600px) {
    .lq-contact-grid { grid-template-columns: 1fr 1fr; }
    .lq-contact-grid .full { grid-column: 1 / -1; }
}

.lq-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-weight: 800;
    color: #f8fafc;
}
.lq-consent input { width: 18px; height: 18px; margin-top: 3px; flex-shrink: 0; }
.consent-text { display: flex; flex-direction: column; gap: 3px; }
.consent-main { font-size: .97rem; font-weight: 800; color: #f8fafc; line-height: 1.4; }
.consent-sub  { font-size: .85rem; font-weight: 600; color: rgba(248,250,252,0.62); line-height: 1.4; }
.lq-submit-row { margin-top: 14px; }
.lq-reach-note {
    text-align: center;
    color: rgba(248,250,252,0.82);
    font-size: .92rem;
    font-weight: 700;
    margin-bottom: 10px;
    line-height: 1.4;
}
.lq-field-row{
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
}
@@media (min-width: 720px){
    .lq-field-row.two{ grid-template-columns: repeat(2,1fr); }
}
@@media (min-width: 560px) and (max-width: 767.98px){
    .lq-contact-step .lq-field-row.two{ grid-template-columns: repeat(2,1fr); }
}
.lq-field{
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.lq-field label{
    font-weight: 850;
    color: #f8fafc;
    letter-spacing: .01em;
}
.lq-field-help{
    color: rgba(248,250,252,0.68);
    font-size: .8rem;
    font-weight: 700;
    margin-top: -2px;
}
.lq-field-err{
    color: #f87171;
    font-size: .82rem;
    font-weight: 800;
    display: none;
}
.lq-field-err.visible{ display:block; }
.lq-agent-handoff {
    display: grid;
    gap: 12px;
    margin-bottom: 14px;
    padding: 14px;
    border-radius: 14px;
    border: 1.4px solid rgba(199,153,49,0.38);
    background:
        radial-gradient(circle at top right, rgba(199,153,49,0.16), transparent 38%),
        rgba(11,22,39,0.92);
    box-shadow:
        0 16px 28px rgba(0,0,0,0.24),
        inset 0 1px 0 rgba(255,255,255,0.06);
}
.lq-agent-handoff-head {
    display: flex;
    align-items: center;
    gap: 12px;
}
.lq-agent-identity {
    display: grid;
    justify-items: center;
    align-content: start;
    gap: 8px;
    flex-shrink: 0;
    min-width: 92px;
    text-align: center;
}
.lq-agent-avatar {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    border: 2px solid rgba(239,200,111,0.92);
    background: linear-gradient(180deg, #13233f 0%, #0b1529 100%);
    box-shadow: 0 12px 24px rgba(0,0,0,0.28);
}
.lq-agent-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}
.lq-agent-avatar-fallback {
    color: #f3d78f;
    font-size: 1.2rem;
    font-weight: 900;
    letter-spacing: .02em;
}
.lq-agent-name {
    color: #f3d78f;
    font-size: 1.08rem;
    font-weight: 900;
    margin-bottom: 3px;
}
.lq-agent-display-name {
    color: rgba(248,250,252,0.8);
    font-size: .8rem;
    font-weight: 800;
    line-height: 1.2;
}
.lq-agent-bio {
    color: rgba(248,250,252,0.82);
    font-size: .9rem;
    line-height: 1.45;
}
.lq-agent-license {
    color: rgba(248,250,252,0.56);
    font-size: .74rem;
    font-weight: 700;
    line-height: 1.35;
    margin-top: 8px;
}
.lq-error, .lq-success {
    font-weight: 800;
    margin-top: 10px;
    display: none;
}
.lq-error { color: #fca5a5; }
.lq-success { color: #bbf7d0; }

/* ── Mobile / tablet tightening (≤640px) ─────────────────────────────────── */
@@media (max-width: 640px){
