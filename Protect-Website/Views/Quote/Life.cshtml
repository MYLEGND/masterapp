<div class="lq-hero-shell">
<div class="@(isLandingView ? "lq-container" : "container lq-container")">
    <div class="lq-hero-rail">
        <div class="lq-header">
            @if (isLandingView && isContactFirstEducationVariant)
            {
                <div class="lq-contact-first-hero-grid">
                    <div class="lq-contact-first-hero-copy">
                        <h1 class="hero-title">@heroHeadline</h1>
                        @if (!string.IsNullOrWhiteSpace(heroSubheadline))
                        {
                            <div class="lq-subtext">@heroSubheadline</div>
                        }
                        <div class="lq-trust-note">@heroTrustNote</div>
                    </div>
                    <figure class="lq-contact-first-hero-media">
                        <img class="lq-contact-first-hero-image" src="~/images/ads/life-insurance-review-ad.png" asp-append-version="true" alt="Legend Legacy Protection ad showing a family and inviting a personalized life insurance review." loading="eager" />
                    </figure>
                </div>
            }
            else if (isLandingView)
            {
                <div class="lq-landing-brand-row">
                    <div class="lq-landing-brand-copy">
                        <h1 class="hero-title">@heroHeadline</h1>
                    </div>
                    <div class="lq-landing-logo-wrap" aria-hidden="true">
                        <img class="lq-landing-logo" src="~/images/company-icons/legend-protect-transparent.png" asp-append-version="true" alt="" />
                    </div>
                </div>
            }
            else
            {
                <h1 class="hero-title">@heroHeadline</h1>
            }
            @if (!isContactFirstEducationVariant && !string.IsNullOrWhiteSpace(heroSubheadline))
            {
                <div class="lq-subtext">@heroSubheadline</div>
            }
            @if (!isContactFirstEducationVariant)
            {
                <div class="lq-trust-note">@heroTrustNote</div>
            }
        </div>
        @if (!isContactFirstEducationVariant)
        {
            <div class="lq-human-strip@(isEmotionalContinuityVariant ? " lq-human-strip-soft" : string.Empty)" id="lifeHeroTrustStrip" role="note" aria-label="@heroTrustAriaLabel" @(showContactStepByDefault ? "hidden" : "")>
                <div class="lq-human-strip-avatar" aria-hidden="true">
                    @if (!string.IsNullOrWhiteSpace(heroTrustPersonImageUrl))
                    {
                        <img src="@heroTrustPersonImageUrl" alt="" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.hidden=false;" />
                    }
                    <span class="lq-human-strip-fallback" @(!string.IsNullOrWhiteSpace(heroTrustPersonImageUrl) ? "hidden" : null)>@heroTrustPersonInitials</span>
                </div>
                <div class="lq-human-strip-copy">
                    <div class="lq-human-strip-name">@heroTrustPersonName</div>
                    <div class="lq-human-strip-role">@heroTrustPersonRole</div>
                    <div class="lq-human-strip-note">@heroTrustPersonSupport</div>
                </div>
            </div>
        }
    </div>

    <form asp-action="@cfg.PostAction" asp-controller="LifeQuote" method="post" id="lifeWizardForm" data-form-key="@pageKey">
        @Html.AntiForgeryToken()
        @if (!string.IsNullOrWhiteSpace(agentSlug))
        {
            <input type="hidden" name="AgentSlug" value="@agentSlug" />
        }
        <input type="hidden" name="OfferKey" id="OfferKey" value="@cfg.OfferKey" />
        <input type="hidden" name="ProductType" id="ProductType" value="@cfg.ProductType" />
        <input type="hidden" name="PageKey" value="@pageKey" />
        <input type="hidden" name="PageVariant" value="@pageVariant" />
        <input type="hidden" name="PageMode" value="@pageMode" />
        <input type="hidden" name="Age" id="Age" value="@ageValue" />
        <input type="hidden" name="AgeRange" id="AgeRange" value="@selectedAgeBracket" />
        <input type="hidden" name="ProtectFocus" id="ProtectFocus" value="@form.ProtectFocus" />
        <input type="hidden" name="Answer1" id="Answer1" value="@form.Answer1" />
        <input type="hidden" name="Answer2" id="Answer2" value="@form.Answer2" />
        <input type="hidden" name="Answer4" id="Answer4" value="@(string.IsNullOrWhiteSpace(selectedAgeBracket) ? form.Answer4 : selectedAgeBracket)" />
        <input type="hidden" name="SessionId" id="SessionId" />
        <input type="hidden" name="VisitorId" id="VisitorId" />
        <input type="hidden" name="UtmSource" id="UtmSource" />
        <input type="hidden" name="UtmMedium" id="UtmMedium" />
        <input type="hidden" name="UtmCampaign" id="UtmCampaign" />
        <input type="hidden" name="UtmId" id="UtmId" />
        <input type="hidden" name="UtmTerm" id="UtmTerm" />
        <input type="hidden" name="UtmContent" id="UtmContent" />
        <input type="hidden" name="MetaCampaignId" id="MetaCampaignId" />
        <input type="hidden" name="MetaAdSetId" id="MetaAdSetId" />
        <input type="hidden" name="MetaAdId" id="MetaAdId" />
        <input type="hidden" name="Fbclid" id="Fbclid" />
        <input type="hidden" name="ReferrerUrl" id="ReferrerUrl" />
        <input type="hidden" name="LandingPageUrl" id="LandingPageUrl" />
        <input type="hidden" name="MarketingEmailConsent" value="true" />
        <input type="hidden" name="RecommendationPrimaryKey" id="RecommendationPrimaryKey" value="@form.RecommendationPrimaryKey" />
        <input type="hidden" name="RecommendationPrimaryTitle" id="RecommendationPrimaryTitle" value="@form.RecommendationPrimaryTitle" />
        <input type="hidden" name="RecommendationSecondaryKey" id="RecommendationSecondaryKey" value="@form.RecommendationSecondaryKey" />
        <input type="hidden" name="RecommendationSecondaryTitle" id="RecommendationSecondaryTitle" value="@form.RecommendationSecondaryTitle" />

        @if (isContactFirstEducationVariant)
        {
            <div class="lq-education-stack">
                <section class="lq-education-trust-card" id="lifeEducationTrustCard" aria-label="Personal guidance from @contactFirstTrustLabelName">
                    <div class="lq-education-trust-head">
                        <div class="lq-education-trust-avatar" aria-hidden="true">
                            @if (!string.IsNullOrWhiteSpace(contactFirstTrustImageUrl))
                            {
                                <img src="@contactFirstTrustImageUrl" alt="" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.hidden=false;" />
                            }
                            <span class="lq-education-trust-fallback" @(!string.IsNullOrWhiteSpace(contactFirstTrustImageUrl) ? "hidden" : null)>@contactFirstTrustInitials</span>
                        </div>
                        <div class="lq-education-trust-copy">
                            <div class="lq-education-kicker">Personal guidance</div>
                            <div class="lq-education-intro">@contactFirstTrustIntroLine</div>
                            <p class="lq-education-intro-sub">Life insurance can feel confusing. I’ll personally help you understand what may fit your situation. No pressure. No obligation.</p>
                            <div class="lq-education-soft-note">Simple guidance. No pressure.</div>
                        </div>
                    </div>
                </section>

                <section class="lq-step-panel lq-education-panel" id="lifeEducationContactPanel">
                    <div class="lq-education-form-title">Start with a quick conversation</div>
                    <div class="lq-education-form-copy">Share a few details and I’ll reach out personally to help you understand what options may fit. This is a simple conversation, not an application.</div>
                    <div class="lq-field-row two">
                        <div class="lq-field">
                            <label for="FirstName">First Name <span style="color:#f87171">*</span></label>
                            <input type="text" id="FirstName" name="FirstName" class="form-control" autocomplete="given-name" value="@form.FirstName" />
                            <div class="lq-field-err" id="err-FirstName">Please enter your first name.</div>
                        </div>
                        <div class="lq-field">
                            <label for="Phone">Phone <span style="color:#f87171">*</span></label>
                            <input type="tel" id="Phone" name="Phone" class="form-control" placeholder="(555) 555-5555" autocomplete="tel" inputmode="tel" value="@form.Phone" />
                            <div class="lq-field-err" id="err-Phone">Please enter your phone.</div>
                        </div>
                    </div>
                    <div class="lq-field-row full">
                        <div class="lq-field">
                            <label for="Email">Email (optional)</label>
                            <input type="email" id="Email" name="Email" class="form-control" placeholder="you@example.com" autocomplete="email" inputmode="email" value="@form.Email" />
                            <div class="lq-field-err" id="err-Email">Please enter a valid email address.</div>
                        </div>
                    </div>
                    <div class="lq-submit-row">
                        <div class="lq-trust-note">Quick to start. Easy to understand. No obligation.</div>
                        <button type="submit" class="btn-gold w-100" id="submitLife" data-default-label="@finalSubmitButtonText">@finalSubmitButtonText</button>
                    </div>
                    <div class="lq-error" id="lifeError"></div>
                    <div class="lq-success" id="lifeSuccess">Thanks! We received your request.</div>
                </section>

                <section class="lq-education-panel lq-options-summary" aria-labelledby="lifeEducationOptionsTitle">
                    <div class="lq-step-title" id="lifeEducationOptionsTitle">Understanding Your Options</div>
                    <p class="lq-options-summary-copy">These are the three life insurance conversations most people compare first when they want clarity before choosing what to explore more deeply.</p>
                    <div class="lq-options-summary-list">
                        <article class="lq-option-summary-card is-term">
                            <div class="lq-option-summary-top">
                                <span class="lq-option-chip">Common first look</span>
                                <div class="lq-option-visual" aria-hidden="true">
                                    <svg viewBox="0 0 96 96" fill="none">
                                        <path d="M18 60H62" stroke="#E6C36B" stroke-width="7" stroke-linecap="round" />
                                        <circle cx="18" cy="60" r="7" fill="#F5D68E" />
                                        <circle cx="62" cy="60" r="7" fill="#F5D68E" />
                                        <circle cx="72" cy="28" r="15" stroke="#FFF1C9" stroke-width="4" />
                                        <path d="M72 20V29L78 33" stroke="#FFF1C9" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </div>
                            </div>
                            <div class="lq-option-title">Term Life Insurance</div>
                            <p class="lq-option-copy">Often the simplest place to start when the goal is helping protect income, monthly bills, or the people who rely on you during key working years.</p>
                            <ul class="lq-option-bullets">
                                <li>Commonly reviewed when affordability and straightforward protection matter most.</li>
                                <li>Often used to help cover temporary responsibilities like family income or mortgage years.</li>
                                <li>Usually the cleanest starting point when someone wants clarity before comparing more permanent designs.</li>
                            </ul>
                        </article>

                        <article class="lq-option-summary-card is-whole">
                            <div class="lq-option-summary-top">
                                <span class="lq-option-chip">Permanent coverage</span>
                                <div class="lq-option-visual" aria-hidden="true">
                                    <svg viewBox="0 0 96 96" fill="none">
                                        <circle cx="48" cy="48" r="15" fill="#E5BD63" fill-opacity=".18" stroke="#F5D68E" stroke-width="4" />
                                        <circle cx="48" cy="48" r="29" stroke="#D3A448" stroke-width="4" stroke-opacity=".88" />
                                        <circle cx="48" cy="48" r="41" stroke="#7B90B7" stroke-width="2.5" stroke-opacity=".45" />
                                        <path d="M31 52C37 61 57 61 65 38" stroke="#FFF1C9" stroke-width="4" stroke-linecap="round" />
                                    </svg>
                                </div>
                            </div>
                            <div class="lq-option-title">Whole Life Insurance</div>
                            <p class="lq-option-copy">A permanent option people often review when they want coverage designed to stay in place for the long term and build steady value over time.</p>
                            <ul class="lq-option-bullets">
                                <li>Designed for people who care more about lasting protection than simply chasing the lowest monthly cost.</li>
                                <li>Often reviewed when predictability, guarantees, and stable long-term structure matter.</li>
                                <li>Can be a strong fit for people who want a simpler permanent solution without a lot of moving parts.</li>
                            </ul>
                        </article>

                        <article class="lq-option-summary-card is-universal">
                            <div class="lq-option-summary-top">
                                <span class="lq-option-chip">Flexible / IUL options</span>
                                <div class="lq-option-visual" aria-hidden="true">
                                    <svg viewBox="0 0 96 96" fill="none">
                                        <path d="M18 66C28 56 33 47 44 40C55 33 66 31 78 30" stroke="#F2CF82" stroke-width="5" stroke-linecap="round" />
                                        <path d="M46 52C54 58 60 64 71 74" stroke="#9FC4FF" stroke-width="3.5" stroke-linecap="round" />
                                        <path d="M20 76H78" stroke="#597299" stroke-width="4" stroke-linecap="round" stroke-opacity=".72" />
                                        <circle cx="18" cy="66" r="6" fill="#F2CF82" />
                                        <circle cx="44" cy="40" r="6" fill="#F2CF82" />
                                        <circle cx="78" cy="30" r="7" fill="#9FC4FF" />
                                    </svg>
                                </div>
                            </div>
                            <div class="lq-option-title">Universal Life Insurance</div>
                            <p class="lq-option-copy">A more flexible permanent path that can include indexed universal life, or IUL, when someone wants longer-term coverage with structure that may be adjusted over time.</p>
                            <ul class="lq-option-bullets">
                                <li>Often reviewed by people comparing permanent coverage with more flexibility than basic whole life.</li>
                                <li>Can include indexed universal life, or IUL, for people exploring longer-range planning conversations.</li>
                                <li>Usually best reviewed with guidance because the tradeoffs are more nuanced than simple term coverage.</li>
                            </ul>
                        </article>
                    </div>
