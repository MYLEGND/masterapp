    /* Header — reduce nav height and psalms bar */
    body:not(.landing-mode) .navbar { padding: 5px 10px 4px !important; }
    body:not(.landing-mode) .navbar-brand img { max-height: 28px !important; }
    body:not(.landing-mode) .header-bottom { margin-top: 3px !important; font-size: 0.76rem !important; letter-spacing: .6px !important; }
    body:not(.landing-mode) .header-psalms {
        font-size: 0.76rem !important;
        padding: 5px 10px !important;
        letter-spacing: .5px !important;
        gap: 5px !important;
    }

    /* Hero shell */
    .lq-hero-shell {
        padding: 5px 8px 6px !important;
        margin: 1px auto 6px !important;
        border-radius: 12px !important;
    }

    /* Hero header block */
    .lq-header { margin-top: 2px !important; margin-bottom: 3px !important; }
    .lq-header h1 { font-size: 1.18rem !important; letter-spacing: .1px !important; line-height: 1.18 !important; }
    .lq-subtext { font-size: .82rem !important; margin-bottom: 4px !important; line-height: 1.3 !important; }
    .lq-human-strip {
        gap: 7px !important;
        margin: 6px auto 7px !important;
        padding: 6px 8px !important;
        border-radius: 10px !important;
    }
    .lq-human-strip-avatar {
        width: 34px !important;
        height: 34px !important;
    }
    .lq-human-strip-name { font-size: .76rem !important; }
    .lq-human-strip-role { font-size: .63rem !important; }
    .lq-human-strip-note { font-size: .7rem !important; }

    /* Step panel */
    .lq-step-panel-pad { padding: 7px !important; }
    .lq-inner-block { padding: 10px 10px 8px !important; }
    .lq-step-title { font-size: 1rem !important; }
    .lq-step-helper { font-size: .84rem !important; margin-bottom: 7px !important; }
    .lq-step-question {
        font-size: 1.08rem !important;
        margin-bottom: 6px !important;
    }
    .lq-step-kicker {
        font-size: .72rem !important;
        margin-bottom: 4px !important;
    }
    .lq-step-progress-wrap { gap: 6px !important; margin-bottom: 8px !important; }
    .lq-step-progress { font-size: .68rem !important; padding: 3px 7px !important; }
    .lq-step-progress-track { height: 5px !important; }
    .lq-card { min-height: 54px !important; padding: 11px 9px !important; font-size: .86rem !important; }
    .lq-card-rich {
        min-height: 116px !important;
        gap: 8px !important;
        padding: 11px 9px !important;
    }
    .lq-card-rich:has(.lq-card-kicker:empty):has(.lq-card-helper:empty) {
        min-height: 80px !important;
    }
    .lq-card-rich .lq-card-visual {
        width: 42px !important;
        height: 42px !important;
        border-radius: 14px !important;
    }
    .lq-card-rich .lq-card-icon {
        width: 22px !important;
        height: 22px !important;
    }
    .lq-card-rich .lq-card-title { font-size: .91rem !important; }
    .lq-card-rich .lq-card-helper { font-size: .71rem !important; }
    .lq-card-rich .lq-card-kicker { font-size: .64rem !important; }
    .lq-card-rich.no-visual:has(.lq-card-kicker:empty):has(.lq-card-helper:empty) {
        min-height: 64px !important;
    }
    .lq-choice-grid.lq-step1-twoup .lq-card { min-height: 56px !important; }
    .lq-choice-grid { gap: 7px !important; }
    .lq-age-picker {
        gap: 10px !important;
        padding: 12px 12px 11px !important;
    }
    .lq-age-picker-kicker { font-size: .66rem !important; }
    .lq-age-picker-note {
        font-size: .8rem !important;
        line-height: 1.35 !important;
    }
    .lq-age-quick-grid {
        gap: 6px !important;
    }
    .lq-age-quick-btn {
        flex: 1 1 calc(50% - 6px);
        min-height: 36px;
        padding: 8px 10px !important;
        font-size: .78rem !important;
    }
    .lq-age-pill {
        width: 100%;
        min-width: 0;
        padding: 9px 12px !important;
        font-size: 1rem !important;
    }
    .lq-age-slider {
        height: 12px !important;
    }
    .lq-age-slider::-webkit-slider-thumb {
        width: 26px;
        height: 26px;
    }
    .lq-age-slider::-moz-range-thumb {
        width: 26px;
        height: 26px;
    }
    .lq-age-scale {
        font-size: .64rem !important;
        gap: 6px !important;
