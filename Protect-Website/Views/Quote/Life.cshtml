  function resolveAgeBand(ageValue) {
    const parsedAge = Number.parseInt(String(ageValue ?? ''), 10);
    if (!Number.isFinite(parsedAge)) {
      return '';
    }

    if (quoteType === 'finalexpense') {
      if (parsedAge <= 54) return '45-54';
      if (parsedAge <= 64) return '55-64';
      if (parsedAge <= 74) return '65-74';
      return '75+';
    }

    if (parsedAge <= 24) return '18-24';
    if (parsedAge <= 34) return '25-34';
    if (parsedAge <= 44) return '35-44';
    if (parsedAge <= 54) return '45-54';
    return '55+';
  }

  function resolveStoredAgeValue(value) {
    const trimmedValue = String(value ?? '').trim();
    if (!trimmedValue) {
      return '';
    }

    const parsedAge = Number.parseInt(trimmedValue, 10);
    if (Number.isFinite(parsedAge)) {
      return String(Math.max(AGE_MIN, Math.min(AGE_MAX, parsedAge)));
    }

    const mappedAge = AGE_RANGE_TO_NUMERIC[trimmedValue];
    return Number.isFinite(mappedAge) ? String(mappedAge) : '';
  }

  function getCurrentSliderAgeValue() {
    const slider = ageSliders[0];
    return slider instanceof HTMLInputElement ? resolveStoredAgeValue(slider.value) : '';
  }

  function hasExplicitAgeSelectionInUi() {
    return agePickers.some((picker) => picker.dataset.ageSelected === 'true');
  }

  function syncAgePickerUi(ageValue, isSelected) {
    const resolvedAge = resolveStoredAgeValue(ageValue) || String(AGE_DEFAULT);
    const numericAge = Number.parseInt(resolvedAge, 10);
    const progress = Number.isFinite(numericAge) && AGE_MAX > AGE_MIN
      ? ((numericAge - AGE_MIN) / (AGE_MAX - AGE_MIN)) * 100
      : 0;
    const pillText = isSelected ? resolvedAge : 'Select age';
    const resolvedBand = resolveAgeBand(resolvedAge);

    agePickers.forEach((picker) => {
      picker.dataset.ageSelected = isSelected ? 'true' : 'false';
      picker.classList.toggle('is-active', isSelected);
      picker.style.setProperty('--age-progress', `${Math.max(0, Math.min(100, progress))}%`);
    });

    ageSliders.forEach((slider) => {
      slider.value = resolvedAge;
      slider.setAttribute('aria-valuetext', isSelected ? `${resolvedAge} years old` : 'Select your age');
    });

    ageDisplays.forEach((display) => {
      display.textContent = pillText;
    });

    ageQuickButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }

      button.classList.toggle(
        'is-active',
        isSelected && String(button.dataset.ageRange || '').trim() === resolvedBand
      );
    });
  }

  function getSelectedAgeValue() {
    return hasExplicitAgeSelectionInUi() ? getCurrentSliderAgeValue() : '';
