    }
    if (bookingModalStatus instanceof HTMLElement) {
      bookingModalStatus.hidden = false;
      bookingModalStatus.textContent = publicBookingLoadingText;
    }
  }

  function resetPostSubmitSuccessState() {
    postSubmitSuccessActive = false;
    thankYouViewTracked = false;
    publicBookingState = null;
    publicBookingEmbedViewed = false;
    publicBookingBookedConfirmed = false;
    publicBookingConfirmationRequested = false;
    publicBookingSlotSelectedTracked = false;
    publicBookingFallbackClicked = false;
    publicBookingAbandonedTracked = false;
    closeBookingModal({ clearFrame: true });

    if (contactCaptureWrap instanceof HTMLElement) {
      contactCaptureWrap.hidden = false;
