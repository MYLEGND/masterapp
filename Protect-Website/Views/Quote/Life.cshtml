    return dateOfBirthHidden instanceof HTMLInputElement ? dateOfBirthHidden.value : '';
  }

  function getSelectedAgeValue() {
    const age = calculateAgeFromDob(getSelectedDobValue());
    return Number.isFinite(age) ? String(age) : '';
  }

  function getSelectedAgeBand() {
    return resolveAgeBand(getSelectedAgeValue());
