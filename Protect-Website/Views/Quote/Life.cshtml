    if (processingHeading && stage.heading) {
      processingHeading.textContent = stage.heading;
    }
    if (processingHelper && stage.helper) {
      processingHelper.textContent = stage.helper;
    }
    if (processingNote && stage.note) {
      processingNote.textContent = stage.note;
