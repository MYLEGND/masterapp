  function buildProcessingStages() {
    const protectingLabel = selectedRadioLabel('ProtectingWho');
    const goalLabel = selectedRadioLabel('CoverageGoal');
    const coverageLabel = selectedRadioLabel('CoverageAmountOption');
    const tobaccoLabel = selectedRadioLabel('TobaccoUse');
    const ageBand = getSelectedAgeBand();

    return [
      {
        heading: 'Checking your protection priorities...',
        helper: goalLabel && protectingLabel
          ? `Starting with ${goalLabel.toLowerCase()} for ${protectingLabel.toLowerCase()}.`
          : 'Starting with the people and priorities you shared.',
        note: 'Analyzing what matters most...'
      },
      {
        heading: 'Sizing your estimated range...',
        helper: coverageLabel && ageBand
          ? `Adjusting around ${coverageLabel} coverage, age ${ageBand}, and ${tobaccoLabel ? tobaccoLabel.toLowerCase() : 'current'} pricing assumptions.`
          : 'Tightening the estimate around age, tobacco use, and coverage amount.',
        note: 'Refining your projected monthly range...'
      },
      {
        heading: 'Matching your likely starting point...',
