@model Protect_Website.Models.LifeWizardViewModel

@{
    var cfg = Model.Config;
    var form = Model.Form;
    ViewData["Title"] = cfg.PageTitle;
    ViewData["PageKey"] = cfg.PageKey;
    var totalSteps = cfg.Steps.Count + 1; // questions + combined contact step
    var path = Context?.Request?.Path.Value ?? string.Empty;
    var segs = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
    var agentSlug = (segs.Length >= 2 && segs[0].Equals("a", StringComparison.OrdinalIgnoreCase)) ? segs[1] : string.Empty;
}

<style>
/* ================================================================
   Shared Life Wizard — Mobile-first, micro-step, premium styling
   ================================================================ */
body { background-color: #0f172a; color: #f8fafc; }

.form-control,
.form-select {
    border: 1.6px solid #c79931;
    margin-bottom: 10px;
    background: #ffffff;
    color: #0f172a;
    font-size: 0.95rem;
    padding: 10px 12px;
    border-radius: 8px;
}
.form-control::placeholder { color: rgba(15,23,42,0.55); }
.form-control:focus,
.form-select:focus {
    outline: none;
    box-shadow: 0 0 0 0.2rem rgba(199,153,49,0.22);
    border-color: #c79931;
    background: #ffffff;
    color: #0f172a;
}

.btn-gold {
    background: linear-gradient(180deg, #c79931, #a68023);
    color: #fff;
    font-weight: 900;
    padding: 12px 24px;
    border-radius: 10px;
    font-size: 1rem;
    border: 1.4px solid #c79931;
    box-shadow: 0 10px 28px rgba(0,0,0,0.24);
    transition: opacity 0.15s, transform 0.12s;
}
.btn-gold:hover { opacity: 0.93; color: #fff; transform: translateY(-1px); }
.text-gold { color: #c79931; }

.btn-ghost {
    border: 1px solid rgba(199,153,49,0.55);
    background: transparent;
    color: #f8fafc;
    padding: 10px 14px;
    border-radius: 10px;
    font-weight: 850;
    transition: border-color .12s ease, color .12s ease, transform .12s ease, box-shadow .12s ease;
}
.btn-ghost:hover { border-color: #c79931; color: #dfb75a; transform: translateY(-1px); box-shadow: 0 8px 18px rgba(0,0,0,0.18); }
.btn-ghost:focus-visible { outline: 2px solid #dfb75a; outline-offset: 2px; }

.lq-header { margin-top: 18px; margin-bottom: 16px; text-align: center; }
.lq-header h1 {
    font-weight: 900;
    font-size: 2rem;
    color: #a68023;
    letter-spacing: .5px;
    margin-bottom: 6px;
}
.lq-subtext {
    color: #c79931;
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 6px;
}
.lq-trust-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
}
.lq-trust-chip {
    background: #c79931;
    color: #0f172a;
    font-weight: 800;
    border-radius: 10px;
    padding: 6px 12px;
    font-size: .9rem;
}
.lq-helper-intro { color: rgba(248,250,252,0.72); font-size: .96rem; margin-top: 2px; }

.lq-step-meta{ display:none; }

/* Step panels */
.lq-step-panel {
    max-width: 760px;
    width: 100%;
    margin: 0 auto 12px auto;
    background: #0f172a;
    border: 1.6px solid #c79931;
    border-radius: 12px;
    box-shadow: 0 18px 40px rgba(0,0,0,0.22);
    animation: lqFadeIn 0.22s ease;
    position: relative;
}
.lq-inner-block {
    background: #111c32;
    border: 1.4px solid rgba(199,153,49,0.35);
    border-radius: 10px;
    padding: 18px 16px 14px 16px;
}
.lq-step-title {
    font-size: 1.2rem;
    font-weight: 900;
    color: #c79931;
    margin-bottom: 6px;
}
.lq-step-helper {
    font-size: .94rem;
    color: rgba(248,250,252,0.7);
    margin-bottom: 16px;
}
.lq-step-panel-pad { padding: 16px; }

@@keyframes lqFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
}

.lq-choice-group { margin-bottom: 8px; }
.lq-choice-label {
    font-weight: 800;
    font-size: 1rem;
    color: #f8fafc;
    margin-bottom: 12px;
}
.lq-choice-grid {
    display: grid;
    gap: 10px;
    grid-template-columns: 1fr;
}
.lq-choice-grid.lq-grid-2 { grid-template-columns: 1fr 1fr; }
@@media (min-width: 600px) {
    .lq-choice-grid.lq-grid-2 { grid-template-columns: repeat(2, 1fr); }
}
.lq-card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 14px 10px;
    min-height: 58px;
    border: 1.6px solid rgba(199,153,49,0.32);
    border-radius: 10px;
    background: rgba(15,23,42,0.8);
    color: #f8fafc;
    font-weight: 800;
    font-size: .95rem;
    cursor: pointer;
    transition: border-color 0.14s, background 0.14s, box-shadow 0.14s, color 0.14s;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
    line-height: 1.25;
    position: relative;
}
.lq-card:hover { border-color: #c79931; background: rgba(199,153,49,0.08); }
.lq-card input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
}
.lq-card.lq-selected,
.lq-card:has(input:checked) {
    border-color: #c79931;
    background: rgba(199,153,49,0.18);
    box-shadow: 0 0 0 2px rgba(199,153,49,0.32);
    color: #c79931;
}
.lq-card.lq-invalid { border-color: #ef4444; }
.lq-choice-error {
    color: #f87171;
    font-size: .82rem;
    margin-top: 4px;
    min-height: 18px;
    display: none;
}
.lq-choice-error.visible { display: block; }

.lq-step-actions { margin-top: 16px; }
.lq-step-actions.dual {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
}
.lq-reassurance {
    text-align: center;
    font-size: .84rem;
    color: rgba(248,250,252,0.55);
    margin-top: 6px;
}
.lq-contact-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: 1fr;
}
@@media (min-width: 600px) {
    .lq-contact-grid { grid-template-columns: 1fr 1fr; }
    .lq-contact-grid .full { grid-column: 1 / -1; }
}

.lq-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-weight: 800;
    color: #f8fafc;
}
.lq-consent input { width: 18px; height: 18px; margin-top: 3px; flex-shrink: 0; }
.lq-submit-row { margin-top: 14px; }
.lq-field-row{
    display: grid;
    gap: 12px;
    grid-template-columns: 1fr;
}
@@media (min-width: 720px){
    .lq-field-row.two{ grid-template-columns: repeat(2,1fr); }
}
.lq-field{
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.lq-field label{
    font-weight: 850;
    color: #f8fafc;
    letter-spacing: .01em;
}
.lq-field-err{
    color: #f87171;
    font-size: .82rem;
    font-weight: 800;
    display: none;
}
.lq-field-err.visible{ display:block; }
.lq-error, .lq-success {
    font-weight: 800;
    margin-top: 10px;
    display: none;
}
.lq-error { color: #fca5a5; }
.lq-success { color: #bbf7d0; }

@@media (max-width: 640px){
    .lq-header h1 { font-size: 1.5rem; }
    .lq-subtext { font-size: .95rem; }
    .lq-progress-rail { gap: 8px; }
    .lq-pill-step { padding: 10px; }
}
</style>

<div class="container lq-container">
    <div class="lq-header">
        <h1>@cfg.Header</h1>
        <div class="lq-subtext">@cfg.Subheader</div>
        <div class="lq-trust-row">
            <span class="lq-trust-chip">Takes 60 Seconds</span>
            <span class="lq-trust-chip">Private &amp; Secure</span>
        </div>
    </div>

    <form asp-action="@cfg.PostAction" asp-controller="LifeQuote" method="post" id="lifeWizardForm" data-form-key="@cfg.PageKey">
        @Html.AntiForgeryToken()
        @if (!string.IsNullOrWhiteSpace(agentSlug))
        {
            <input type="hidden" name="AgentSlug" value="@agentSlug" />
        }
        <input type="hidden" name="OfferKey" id="OfferKey" value="@cfg.OfferKey" />
        <input type="hidden" name="ProductType" id="ProductType" value="@cfg.ProductType" />
        <input type="hidden" name="PageKey" value="@cfg.PageKey" />
        <input type="hidden" name="AgeRange" id="AgeRange" />
        <input type="hidden" name="ProtectFocus" id="ProtectFocus" />
        <input type="hidden" name="Answer1" id="Answer1" />
        <input type="hidden" name="Answer2" id="Answer2" />
        <input type="hidden" name="Answer3" id="Answer3" />
        <input type="hidden" name="Answer4" id="Answer4" />

        @for (var i = 0; i < cfg.Steps.Count; i++)
        {
            var step = cfg.Steps[i];
            var gridClass = step.Options.Count >= 4 ? "lq-grid-2" : "";
        <div class="lq-step-panel" data-step="@i" data-alias="@step.FieldAlias" @(i == 0 ? "" : "hidden")>
            <div class="lq-step-panel-pad">
                <div class="lq-step-meta">Step @(i + 1) of @totalSteps</div>
                <div class="lq-step-title">@step.Question</div>
                <div class="lq-inner-block">
                    <div class="lq-choice-group">
                        <div class="lq-choice-grid @gridClass">
                            @foreach (var opt in step.Options)
                            {
                                var inputName = $"step-{i}-option";
                                <label class="lq-card">
                                    <input type="radio" name="@inputName" value="@opt.Code" data-label="@opt.Label" />
                                    <span>@opt.Label</span>
                                </label>
                            }
                        </div>
                        <div class="lq-choice-error" id="error-step-@i">Please choose an option.</div>
                    </div>
                    <div class="lq-step-actions dual">
                        @if (i > 0)
                        {
                            <button type="button" class="btn-ghost" data-back="@i">Back</button>
                        }
                        <!-- Auto-advance handles forward navigation; Next button hidden for clarity -->
                    </div>
                </div>
            </div>
        </div>
        }

        <div class="lq-step-panel" data-step="@cfg.Steps.Count" hidden>
            <div class="lq-step-panel-pad">
                <div class="lq-step-meta">Step @totalSteps of @totalSteps</div>
                <div class="lq-step-title">How can we reach you?</div>
                <div class="lq-step-helper">Enter your details to get your personalized review.</div>
                <div class="lq-inner-block">
                    <div class="lq-contact-grid">
                        <div class="lq-field-row two">
                            <div class="lq-field">
                                <label for="FirstName">First Name <span style="color:#f87171">*</span></label>
                                <input type="text" id="FirstName" name="FirstName" class="form-control" autocomplete="given-name" value="@form.FirstName" />
                                <div class="lq-field-err" id="err-FirstName">Please enter your first name.</div>
                            </div>
                            <div class="lq-field">
                                <label for="LastName">Last Name <span style="color:#f87171">*</span></label>
                                <input type="text" id="LastName" name="LastName" class="form-control" autocomplete="family-name" value="@form.LastName" />
                                <div class="lq-field-err" id="err-LastName">Please enter your last name.</div>
                            </div>
                        </div>
                        <div class="lq-field-row two">
                            <div class="lq-field">
                                <label for="Phone">Phone <span style="color:#f87171">*</span></label>
                                <input type="tel" id="Phone" name="Phone" class="form-control" placeholder="(555) 555-5555" autocomplete="tel" inputmode="tel" value="@form.Phone" />
                                <div class="lq-field-err" id="err-Phone">Please enter your phone.</div>
                            </div>
                            <div class="lq-field">
                                <label for="Email">Email <span style="color:#f87171">*</span></label>
                                <input type="email" id="Email" name="Email" class="form-control" placeholder="you@example.com" autocomplete="email" value="@form.Email" />
                                <div class="lq-field-err" id="err-Email">Please enter a valid email.</div>
                            </div>
                        </div>
                        <div class="lq-field-row">
                            <label class="lq-consent full">
                                <input type="checkbox" name="MarketingEmailConsent" value="true" @(form.MarketingEmailConsent ? "checked" : "") required />
                                <span>I authorize the company to contact me regarding this request.</span>
                            </label>
                            <div class="lq-field-err" id="err-Consent">Please authorize contact.</div>
                        </div>
                        <div class="lq-field-row">
                            <div class="lq-field">
                                <label for="State">What state do you live in? <span style="color:#f87171">*</span></label>
                                <select id="State" name="State" class="form-select" autocomplete="address-level1">
                                    <option value="">Select your state</option>
                                    <option value="AL">Alabama</option>
                                    <option value="AK">Alaska</option>
                                    <option value="AZ">Arizona</option>
                                    <option value="AR">Arkansas</option>
                                    <option value="CA">California</option>
                                    <option value="CO">Colorado</option>
                                    <option value="CT">Connecticut</option>
                                    <option value="DE">Delaware</option>
                                    <option value="DC">District of Columbia</option>
                                    <option value="FL">Florida</option>
                                    <option value="GA">Georgia</option>
                                    <option value="HI">Hawaii</option>
                                    <option value="ID">Idaho</option>
                                    <option value="IL">Illinois</option>
                                    <option value="IN">Indiana</option>
                                    <option value="IA">Iowa</option>
                                    <option value="KS">Kansas</option>
                                    <option value="KY">Kentucky</option>
                                    <option value="LA">Louisiana</option>
                                    <option value="ME">Maine</option>
                                    <option value="MD">Maryland</option>
                                    <option value="MA">Massachusetts</option>
                                    <option value="MI">Michigan</option>
                                    <option value="MN">Minnesota</option>
                                    <option value="MS">Mississippi</option>
                                    <option value="MO">Missouri</option>
                                    <option value="MT">Montana</option>
                                    <option value="NE">Nebraska</option>
                                    <option value="NV">Nevada</option>
                                    <option value="NH">New Hampshire</option>
                                    <option value="NJ">New Jersey</option>
                                    <option value="NM">New Mexico</option>
                                    <option value="NY">New York</option>
                                    <option value="NC">North Carolina</option>
                                    <option value="ND">North Dakota</option>
                                    <option value="OH">Ohio</option>
                                    <option value="OK">Oklahoma</option>
                                    <option value="OR">Oregon</option>
                                    <option value="PA">Pennsylvania</option>
                                    <option value="RI">Rhode Island</option>
                                    <option value="SC">South Carolina</option>
                                    <option value="SD">South Dakota</option>
                                    <option value="TN">Tennessee</option>
                                    <option value="TX">Texas</option>
                                    <option value="UT">Utah</option>
                                    <option value="VT">Vermont</option>
                                    <option value="VA">Virginia</option>
                                    <option value="WA">Washington</option>
                                    <option value="WV">West Virginia</option>
                                    <option value="WI">Wisconsin</option>
                                    <option value="WY">Wyoming</option>
                                </select>
                            <div class="lq-field-err" id="err-State">Please select your state.</div>
                            </div>
                        </div>
                    </div>
                    <div class="lq-step-actions">
                        <div class="lq-submit-row">
                            <button type="submit" class="btn-gold w-100" id="submitLife" data-default-label="@cfg.SubmitButtonText">@cfg.SubmitButtonText</button>
                        </div>
                        <div class="lq-error" id="lifeError"></div>
                        <div class="lq-success" id="lifeSuccess">Thanks! We received your request.</div>
                        <button type="button" class="btn-ghost w-100 mt-2" data-back="@cfg.Steps.Count">Back</button>
                    </div>
                    <div class="lq-reassurance">We only use your details to send your personalized review.</div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
(() => {
  const form = document.getElementById('lifeWizardForm');
  const steps = Array.from(document.querySelectorAll('[data-step]'));
  const totalSteps = steps.length;
  const answerHidden = [
    document.getElementById('Answer1'),
    document.getElementById('Answer2'),
    document.getElementById('Answer3'),
    document.getElementById('Answer4'),
  ];
  const ageHidden = document.getElementById('AgeRange');
  const focusHidden = document.getElementById('ProtectFocus');
  const submitBtn = document.getElementById('submitLife');
  const submitLabel = submitBtn?.dataset.defaultLabel || 'Submit';
  const pageKey = form.dataset.formKey || 'quote_life';
  const startEvent = '@cfg.StartEvent';
  const submitEvent = '@cfg.SubmitEvent';

  function setStep(idx) {
    steps.forEach((s, i) => s.hidden = i !== idx);
    const target = steps[idx];
    setTimeout(() => target.scrollIntoView({ behavior: 'smooth', block: 'center' }), 50);
  }

  function storeAnswer(stepIndex, code, label, alias) {
    if (stepIndex < answerHidden.length) {
      answerHidden[stepIndex].value = code;
    }
    if (alias === 'AgeRange') ageHidden.value = label;
    if (alias === 'ProtectFocus') focusHidden.value = label;
  }

  function validateStep(idx) {
    const errorEl = document.getElementById(`error-step-${idx}`);
    const radios = form.querySelectorAll(`input[name=\"step-${idx}-option\"]`);
    if (radios.length === 0) return true; // non-radio step (e.g., name)
    const selected = form.querySelector(`input[name=\"step-${idx}-option\"]:checked`);
    if (!selected) {
      errorEl?.classList.add('visible');
      return false;
    }
    errorEl?.classList.remove('visible');
    return true;
  }

  // wire option clicks
  steps.forEach((stepEl, idx) => {
    if (idx >= totalSteps - 1) return; // skip contact
    const alias = stepEl.dataset.alias;
    stepEl.querySelectorAll('input[type=\"radio\"]').forEach(r => {
      r.addEventListener('change', (e) => {
        const code = r.value;
        const label = r.dataset.label || r.value;
        storeAnswer(idx, code, label, stepEl.getAttribute('data-alias'));
        window.legendTrack?.({ EventType: startEvent, Step: idx + 1, Choice: label, Code: code, PageKey: pageKey });
        setTimeout(() => setStep(idx + 1), 120);
      });
    });
  });

  // back / next buttons
  document.querySelectorAll('[data-back]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const idx = parseInt(btn.getAttribute('data-back'));
      const prev = Math.max(0, idx - 1);
      window.legendTrack?.({ EventType: 'life_quote_back_click', FromStep: idx + 1, PageKey: pageKey });
      setStep(prev);
    });
  });
  document.querySelectorAll('[data-next]').forEach(btn => {
    btn.addEventListener('click', () => {
      const idx = parseInt(btn.getAttribute('data-next'));
      if (!validateStep(idx)) return;
      const selected = form.querySelector(`input[name=\"step-${idx}-option\"]:checked`);
      if (selected) {
        storeAnswer(idx, selected.value, selected.dataset.label || selected.value, steps[idx].getAttribute('data-alias'));
      }
      setStep(Math.min(totalSteps - 1, idx + 1));
    });
  });

  // form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const lifeError = document.getElementById('lifeError');
    const lifeSuccess = document.getElementById('lifeSuccess');
    lifeError.style.display = 'none';
    lifeSuccess.style.display = 'none';
    ['FirstName','LastName','Phone','Email','State'].forEach(id => document.getElementById(`err-${id}`)?.classList.remove('visible'));
    document.getElementById('err-Consent')?.classList.remove('visible');

    // validate all question steps
    for (let i = 0; i < totalSteps - 1; i++) {
      if (!validateStep(i)) { setStep(i); return; }
      const selected = form.querySelector(`input[name=\"step-${i}-option\"]:checked`);
      if (selected) {
        storeAnswer(i, selected.value, selected.dataset.label || selected.value, steps[i].getAttribute('data-alias'));
      }
    }

    // contact validation
    const requiredAll = ['FirstName','LastName','Phone','Email','State'];
    for (const name of requiredAll) {
      const el = form.querySelector(`[name=\"${name}\"]`);
      if (!el || !el.value.trim()) {
        lifeError.textContent = 'Please fill all required contact fields.';
        lifeError.style.display = 'block';
        el?.focus();
        document.getElementById(`err-${name}`)?.classList.add('visible');
        setStep(totalSteps - 1);
        return;
      }
    }
    const state = document.getElementById('State');
    if (state && !state.value) {
        lifeError.textContent = 'Please select your state.';
        lifeError.style.display = 'block';
        state.focus();
        document.getElementById('err-State')?.classList.add('visible');
        setStep(totalSteps - 1);
        return;
    }
    if (state) {
        document.getElementById('Answer4').value = state.value;
    }
    const consent = form.querySelector('input[name=\"MarketingEmailConsent\"]');
    if (!consent?.checked) {
      lifeError.textContent = 'Please authorize contact.';
      lifeError.style.display = 'block';
      consent?.focus();
      document.getElementById('err-Consent')?.classList.add('visible');
      setStep(totalSteps - 1);
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    window.legendTrack?.({ EventType: submitEvent.replace('_submit','_submit_attempt'), PageKey: pageKey, Offer: '@cfg.OfferKey' });

    const thankYouPath = (() => {
      const parts = location.pathname.split('/').filter(Boolean);
      if (parts.length >= 2 && parts[0] === 'a') {
        return `/a/${parts[1]}/ThankYou`;
      }
      return '/ThankYou';
    })();

    try {
      const res = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'X-Requested-With': 'fetch' } });
      if (!res.ok) throw new Error('Network');
      window.legendTrack?.({ EventType: submitEvent, PageKey: pageKey, Offer: '@cfg.OfferKey' });
      window.location.href = thankYouPath;
    } catch (err) {
      lifeError.textContent = 'We could not send this right now. Please try again.';
      lifeError.style.display = 'block';
      window.legendTrack?.({ EventType: submitEvent.replace('_submit','_submit_error'), PageKey: pageKey, Offer: '@cfg.OfferKey' });
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = submitLabel;
    }
  });

  // fire start event once
  window.legendTrack?.({ EventType: startEvent, PageKey: pageKey, Offer: '@cfg.OfferKey' });

  // initial position
  setStep(0);
})();
</script>
