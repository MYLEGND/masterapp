/* ================================================================
   Emergency funnel layout repair — unclipped, flatter, action-led
   ================================================================ */

/* Stop horizontal clipping everywhere */
.lq-container,
.lq-hero-shell,
.lq-step1-panel,
.lq-step-panel-pad,
.lq-contact-first-proof,
.lq-question-shell,
.lq-step-question,
.lq-choice-grid,
.lq-options-grid,
.lq-field-row,
.lq-contact-estimate-wrap,
.lq-contact-estimate-stats {
    max-width: 100% !important;
    min-width: 0 !important;
    box-sizing: border-box !important;
    overflow: visible !important;
}

body,
main.layout-content {
    overflow-x: hidden !important;
}

/* Main shell: one premium container */
.lq-hero-shell {
    max-width: 720px !important;
    width: min(720px, calc(100vw - 24px)) !important;
    padding: 16px !important;
    margin: 10px auto 18px !important;
