  function renderBookingIframe(frameSlot, statusEl, url) {
    if (!(frameSlot instanceof HTMLElement) || !(statusEl instanceof HTMLElement) || !url) {
      return;
    }

    const normalizedUrl = asTrimmed(url);
    const existingIframe = frameSlot.querySelector('iframe.lq-booking-iframe');

    if (existingIframe instanceof HTMLIFrameElement && existingIframe.dataset.bookingSrc === normalizedUrl) {
      statusEl.hidden = true;
      return;
    }

    frameSlot.innerHTML = '';
    statusEl.hidden = false;
    statusEl.textContent = publicBookingLoadingText;

    const iframe = document.createElement('iframe');
    iframe.className = 'lq-booking-iframe';
    iframe.src = normalizedUrl;
    iframe.dataset.bookingSrc = normalizedUrl;
    iframe.loading = 'lazy';
    iframe.referrerPolicy = 'strict-origin-when-cross-origin';
    iframe.title = 'Continue your review';

    let frameLoaded = false;
    const loadTimeout = window.setTimeout(() => {
      if (frameLoaded) {
        return;
      }

      statusEl.hidden = false;
      statusEl.textContent = 'Scheduling is taking longer than expected. Please give the secure booking window another moment.';
    }, 8000);

    iframe.addEventListener('load', () => {
      frameLoaded = true;
      window.clearTimeout(loadTimeout);
      statusEl.hidden = true;
      syncInlineBookingDesktopViewport();
    }, { once: true });

    frameSlot.appendChild(iframe);

    if (frameSlot.id === 'lifeBookingInlineFrameSlot') {
      activeInlineBookingSlot = frameSlot;
      activeInlineBookingFrame = iframe;
      window.requestAnimationFrame(() => syncInlineBookingDesktopViewport());
      window.setTimeout(() => syncInlineBookingDesktopViewport(), 180);
    }
  }

  function markAppointmentEmbedViewed(surface, payload) {
    if (publicBookingEmbedViewed) {
      return;
    }

    publicBookingEmbedViewed = true;
    trackEvent('appointment_embed_viewed', buildAppointmentTrackingMetadata(payload, {
      bookingSurface: surface || resolveRequestedBookingSurface(payload)
    }));

    if (payload?.contextToken) {
      [15000, 45000, 90000].forEach((delayMs) => {
        window.setTimeout(() => {
          if (
            publicBookingBookedConfirmed ||
            publicBookingConfirmationRequested ||
            publicBookingFallbackClicked ||
            !publicBookingState?.contextToken
          ) {
            return;
          }

          publicBookingConfirmationRequested = true;
          void confirmPublicBookingExperience(publicBookingState).then((confirmedState) => {
            publicBookingConfirmationRequested = false;
            publicBookingState = normalizePublicBookingPayload(confirmedState, publicBookingState);
            renderPostSubmitBookingState(publicBookingState);

            if (publicBookingState.confirmationVerified && !publicBookingBookedConfirmed) {
              publicBookingBookedConfirmed = true;
              trackEvent('appointment_booked', buildAppointmentTrackingMetadata(publicBookingState));
            }
          }).catch((error) => {
            publicBookingConfirmationRequested = false;
            console.warn('[LifeQuote] scheduled booking confirmation failed', error);
          });
        }, delayMs);
      });
    }
  }

  async function activatePublicBookingExperience(hint, surfaceOverride = '') {
    if (!hint || typeof hint !== 'object' || !asTrimmed(hint.contextToken)) {
      return buildDisabledBookingState('missing_context');
    }

    const requestSurface = asTrimmed(surfaceOverride) || resolveRequestedBookingSurface(hint);

    try {
      const response = await fetch(bookingExperienceUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'fetch'
        },
        body: JSON.stringify({
          contextToken: hint.contextToken,
          surface: requestSurface
        })
      });

      if (!response.ok) {
        throw new Error('booking_activation_failed');
      }

      const payload = await response.json().catch(() => ({}));
      return normalizePublicBookingPayload(payload, hint);
    } catch (error) {
      console.warn('[LifeQuote] public booking activation failed', error);
      return normalizePublicBookingPayload({
        enabled: Boolean(hint.eligible),
        canEmbed: Boolean(hint.canEmbed),
        canFallback: Boolean(hint.canFallback),
        preferModalOnMobile: Boolean(hint.preferModalOnMobile),
        embedUrl: hint.embedUrl || '',
        fallbackUrl: hint.fallbackUrl || '',
        surface: requestSurface,
        reason: 'activation_failed',
        contextToken: hint.contextToken || ''
      }, hint);
    }
  }

  async function confirmPublicBookingExperience(payload) {
    const normalized = normalizePublicBookingPayload(payload, publicBookingState);
    if (!normalized.contextToken) {
      return normalized;
    }

    try {
      const response = await fetch(bookingConfirmationUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'fetch'
        },
        body: JSON.stringify({
          contextToken: normalized.contextToken,
          surface: normalized.surface || resolveRequestedBookingSurface(normalized)
        })
      });

      if (!response.ok) {
        throw new Error('booking_confirmation_failed');
      }

      const confirmationPayload = await response.json().catch(() => ({}));
      return normalizePublicBookingPayload({
        ...normalized,
        ...confirmationPayload
      }, normalized);
    } catch (error) {
      console.warn('[LifeQuote] public booking confirmation failed', error);
      return normalized;
    }
  }


