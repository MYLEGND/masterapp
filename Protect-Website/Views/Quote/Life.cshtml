</style>

<div class="lq-hero-shell">
<div class="@(isLandingView ? "lq-container" : "container lq-container")">
    <div class="lq-header">
        <h1 class="hero-title">@cfg.Header</h1>
        <div class="lq-subtext">@cfg.Subheader?.Replace(" — before making any decisions.", string.Empty)</div>
        <div class="lq-trust-note">Private • No pressure • Takes less than 30 seconds</div>
    </div>

    <form asp-action="@cfg.PostAction" asp-controller="LifeQuote" method="post" id="lifeWizardForm" data-form-key="@pageKey">
        @Html.AntiForgeryToken()
        @if (!string.IsNullOrWhiteSpace(agentSlug))
        {
            <input type="hidden" name="AgentSlug" value="@agentSlug" />
        }
        <input type="hidden" name="OfferKey" id="OfferKey" value="@cfg.OfferKey" />
        <input type="hidden" name="ProductType" id="ProductType" value="@cfg.ProductType" />
        <input type="hidden" name="PageKey" value="@pageKey" />
        <input type="hidden" name="PageVariant" value="@pageVariant" />
        <input type="hidden" name="PageMode" value="@pageMode" />
        <input type="hidden" name="Age" id="Age" value="@ageValue" />
        <input type="hidden" name="AgeRange" id="AgeRange" value="@selectedAgeBracket" />
        <input type="hidden" name="ProtectFocus" id="ProtectFocus" value="@form.ProtectFocus" />
        <input type="hidden" name="Answer1" id="Answer1" value="@form.Answer1" />
        <input type="hidden" name="Answer2" id="Answer2" value="@form.Answer2" />
        <input type="hidden" name="Answer4" id="Answer4" value="@(string.IsNullOrWhiteSpace(selectedAgeBracket) ? form.Answer4 : selectedAgeBracket)" />
        <input type="hidden" name="SessionId" id="SessionId" />
        <input type="hidden" name="VisitorId" id="VisitorId" />
        <input type="hidden" name="UtmSource" id="UtmSource" />
        <input type="hidden" name="UtmMedium" id="UtmMedium" />
        <input type="hidden" name="UtmCampaign" id="UtmCampaign" />
        <input type="hidden" name="UtmTerm" id="UtmTerm" />
        <input type="hidden" name="UtmContent" id="UtmContent" />
        <input type="hidden" name="Fbclid" id="Fbclid" />
        <input type="hidden" name="ReferrerUrl" id="ReferrerUrl" />
        <input type="hidden" name="LandingPageUrl" id="LandingPageUrl" />
        <input type="hidden" name="MarketingEmailConsent" value="true" />
        <input type="hidden" name="RecommendationPrimaryKey" id="RecommendationPrimaryKey" value="@form.RecommendationPrimaryKey" />
        <input type="hidden" name="RecommendationPrimaryTitle" id="RecommendationPrimaryTitle" value="@form.RecommendationPrimaryTitle" />
        <input type="hidden" name="RecommendationSecondaryKey" id="RecommendationSecondaryKey" value="@form.RecommendationSecondaryKey" />
        <input type="hidden" name="RecommendationSecondaryTitle" id="RecommendationSecondaryTitle" value="@form.RecommendationSecondaryTitle" />

        <div class="lq-step-panel lq-step1-panel" id="lifeStep1Panel" data-funnel-step="1" @(showContactStepByDefault ? "hidden" : "")>
            <div class="lq-step-panel-pad">
                <div class="lq-step-title">If something happened to you tomorrow, would they actually be okay?</div>
                <div class="lq-step-helper">This takes 30 seconds — and helps you see what may actually fit your situation.</div>
                <div class="lq-step-progress-wrap" aria-live="polite">
                    <div class="lq-step-progress" id="lifeStep1Progress">Step 1 of 3</div>
                    <div class="lq-step-progress-track" aria-hidden="true">
                        <span class="lq-step-progress-fill" id="lifeStep1ProgressFill"></span>
                    </div>
                </div>

                <div class="lq-micro-step" data-micro-step="0">
                    <div class="lq-choice-group" role="radiogroup" aria-labelledby="lbl-step1-protect">
                        <div class="lq-choice-label" id="lbl-step1-protect">@protectStep.Question</div>
                        <div class="lq-choice-grid lq-grid-2 lq-step1-twoup">
                            @foreach (var opt in protectStep.Options)
                            {
                                var isChecked =
                                    string.Equals(form.ProtectingWho, opt.Code, StringComparison.OrdinalIgnoreCase) ||
                                    string.Equals(form.Answer1, opt.Code, StringComparison.OrdinalIgnoreCase);
                                <label class="lq-card">
                                    <input type="radio" name="ProtectingWho" value="@opt.Code" data-label="@opt.Label" @(isChecked ? "checked" : null) />
                                    <span>@opt.Label</span>
                                </label>
                            }
                        </div>
                        <div class="lq-choice-error" id="err-step1-protecting-who">Please choose who you want to protect.</div>
                    </div>
                </div>

                <div class="lq-micro-step" data-micro-step="1" hidden>
                    <div class="lq-choice-group" role="radiogroup" aria-labelledby="lbl-step1-goal">
                        <div class="lq-choice-label" id="lbl-step1-goal">@goalStep.Question</div>
                        <div class="lq-choice-grid lq-grid-2 lq-step1-twoup">
                            @foreach (var opt in goalStep.Options)
                            {
                                var isChecked =
                                    string.Equals(form.CoverageGoal, opt.Code, StringComparison.OrdinalIgnoreCase) ||
                                    string.Equals(form.Answer2, opt.Code, StringComparison.OrdinalIgnoreCase);
                                <label class="lq-card">
                                    <input type="radio" name="CoverageGoal" value="@opt.Code" data-label="@opt.Label" @(isChecked ? "checked" : null) />
                                    <span>@opt.Label</span>
                                </label>
                            }
                        </div>
                        <div class="lq-choice-error" id="err-step1-coverage-goal">Please select what matters most right now.</div>
                    </div>
                    <button type="button" class="btn-ghost lq-micro-back" data-step1-back="0">Back</button>
                </div>

                <div class="lq-micro-step" data-micro-step="2" hidden>
                    <div class="lq-choice-label">Let's tailor this to you</div>
                    <div class="lq-choice-group">
                        <div style="font-weight:700;font-size:.9rem;color:rgba(248,250,252,0.72);margin-bottom:8px;" id="lbl-step1-age">@ageStep.Question</div>
                        <div class="lq-choice-grid lq-grid-2 lq-age-grid" role="radiogroup" aria-labelledby="lbl-step1-age">
                            <label class="lq-card">
                                <input type="radio" name="AgeBracket" value="18-24" data-age="21" data-label="18-24" @(selectedAgeBracket == "18-24" ? "checked" : null) />
                                <span>18-24</span>
                            </label>
                            <label class="lq-card">
                                <input type="radio" name="AgeBracket" value="25-34" data-age="30" data-label="25-34" @(selectedAgeBracket == "25-34" ? "checked" : null) />
                                <span>25-34</span>
                            </label>
                            <label class="lq-card">
                                <input type="radio" name="AgeBracket" value="35-44" data-age="40" data-label="35-44" @(selectedAgeBracket == "35-44" ? "checked" : null) />
                                <span>35-44</span>
                            </label>
                            <label class="lq-card">
                                <input type="radio" name="AgeBracket" value="45-54" data-age="50" data-label="45-54" @(selectedAgeBracket == "45-54" ? "checked" : null) />
                                <span>45-54</span>
                            </label>
                            <label class="lq-card lq-age-wide">
                                <input type="radio" name="AgeBracket" value="55+" data-age="60" data-label="55+" @(selectedAgeBracket == "55+" ? "checked" : null) />
                                <span>55+</span>
                            </label>
                        </div>
                        <div class="lq-choice-error" id="err-step1-age">Please choose your age range.</div>
                    </div>
                    <div class="lq-step-actions dual">
                        <button type="button" class="btn-ghost" id="ageStepBackBtn">Back</button>
                        <button type="button" class="btn-gold flex-fill" id="step1Continue">See What Fits Me</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="lq-step-panel" id="lifeProcessingPanel" data-funnel-step="1.5" hidden>
            <div class="lq-step-panel-pad">
                <div class="lq-step-progress">Preparing</div>
                <div class="lq-step-title" id="lifeProcessingHeading" tabindex="-1">Analyzing your situation...</div>
                <div class="lq-step-helper">We’re identifying what actually fits your situation — not guessing.</div>
                <div class="lq-processing-bridge" aria-hidden="true">
                    <div class="lq-processing-track">
                        <div class="lq-processing-fill" id="lifeProcessingFill"></div>
                    </div>
                    <div class="lq-processing-note">Matching you with the right protection strategy...</div>
                </div>
            </div>
        </div>

        <div class="lq-step-panel lq-contact-step" id="lifeStep2Panel" data-funnel-step="2" @(!showContactStepByDefault ? "hidden" : "")>
            <div class="lq-step-panel-pad">
                <div class="lq-step-progress">Final step</div>
                <div class="lq-step-title" id="lifeStep2Heading" tabindex="-1">@finalStepHeading</div>
                @if (!string.IsNullOrWhiteSpace(finalStepHelper))
                {
                    <div class="lq-step-helper">@finalStepHelper</div>
                }
                    <div class="lq-contact-grid">
                        @if (showAgentTrustCard)
                        {
                            <div class="lq-agent-handoff full">
                                <div class="lq-agent-handoff-head">
                                    <div class="lq-agent-identity">
                                        <div class="lq-agent-avatar" aria-hidden="true">
                                            @if (!string.IsNullOrWhiteSpace(agentTrustProfile?.ProfileImageUrl))
                                            {
                                                <img src="@agentTrustProfile.ProfileImageUrl" alt="@agentTrustProfile.DisplayName" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.hidden=false;" />
                                            }
                                            <span class="lq-agent-avatar-fallback" @(!string.IsNullOrWhiteSpace(agentTrustProfile?.ProfileImageUrl) ? "hidden" : null)>@((agentTrustProfile?.FirstName ?? "A").Substring(0, 1).ToUpperInvariant())</span>
                                        </div>
                                        <div class="lq-agent-display-name">@agentDisplayName</div>
                                    </div>
                                    <div>
                                        <div class="lq-agent-name">Hi, I'm @agentGreetingName.</div>
                                        <div class="lq-agent-bio">@agentTrustBio</div>
                                    </div>
                                </div>
                            </div>
                        }
                        <div class="lq-field-row two full">
                            <div class="lq-field">
                                <label for="FirstName">First Name <span style="color:#f87171">*</span></label>
                                <input type="text" id="FirstName" name="FirstName" class="form-control" autocomplete="given-name" value="@form.FirstName" />
                                <div class="lq-field-err" id="err-FirstName">Please enter your first name.</div>
                            </div>
                            <div class="lq-field">
                                <label for="LastName">Last Name <span style="color:#f87171">*</span></label>
                                <input type="text" id="LastName" name="LastName" class="form-control" autocomplete="family-name" value="@form.LastName" />
                                <div class="lq-field-err" id="err-LastName">Please enter your last name.</div>
                            </div>
                        </div>
                        <div class="lq-field-row two full">
                            <div class="lq-field">
                                <label for="Phone">Phone <span style="color:#f87171">*</span></label>
                                <input type="tel" id="Phone" name="Phone" class="form-control" placeholder="(555) 555-5555" autocomplete="tel" inputmode="tel" value="@form.Phone" />
                                <div class="lq-field-err" id="err-Phone">Please enter your phone.</div>
                            </div>
                            <div class="lq-field">
                                <label for="Email">Email <span style="color:#f87171">*</span></label>
                                <input type="email" id="Email" name="Email" class="form-control" placeholder="you@example.com" autocomplete="email" inputmode="email" value="@form.Email" />
                                <div class="lq-field-err" id="err-Email">Please enter your email.</div>
                            </div>
                        </div>
                        @if (!usesLeanContactFields)
                        {
                            <div class="lq-field-row full">
                                <div class="lq-field">
                                    <label for="State">What state do you live in? (Optional) <span style="color:#f87171">*</span></label>
                                    <select id="State" name="State" class="form-select" autocomplete="address-level1" data-selected="@form.State">
                                        <option value="">Select your state</option>
                                        <option value="AL">Alabama</option>
                                        <option value="AK">Alaska</option>
                                        <option value="AZ">Arizona</option>
                                        <option value="AR">Arkansas</option>
                                        <option value="CA">California</option>
                                        <option value="CO">Colorado</option>
                                        <option value="CT">Connecticut</option>
                                        <option value="DE">Delaware</option>
                                        <option value="DC">District of Columbia</option>
                                        <option value="FL">Florida</option>
                                        <option value="GA">Georgia</option>
                                        <option value="HI">Hawaii</option>
                                        <option value="ID">Idaho</option>
                                        <option value="IL">Illinois</option>
                                        <option value="IN">Indiana</option>
                                        <option value="IA">Iowa</option>
                                        <option value="KS">Kansas</option>
                                        <option value="KY">Kentucky</option>
                                        <option value="LA">Louisiana</option>
                                        <option value="ME">Maine</option>
                                        <option value="MD">Maryland</option>
                                        <option value="MA">Massachusetts</option>
                                        <option value="MI">Michigan</option>
                                        <option value="MN">Minnesota</option>
                                        <option value="MS">Mississippi</option>
                                        <option value="MO">Missouri</option>
                                        <option value="MT">Montana</option>
                                        <option value="NE">Nebraska</option>
                                        <option value="NV">Nevada</option>
                                        <option value="NH">New Hampshire</option>
                                        <option value="NJ">New Jersey</option>
                                        <option value="NM">New Mexico</option>
                                        <option value="NY">New York</option>
                                        <option value="NC">North Carolina</option>
                                        <option value="ND">North Dakota</option>
                                        <option value="OH">Ohio</option>
                                        <option value="OK">Oklahoma</option>
                                        <option value="OR">Oregon</option>
                                        <option value="PA">Pennsylvania</option>
                                        <option value="RI">Rhode Island</option>
                                        <option value="SC">South Carolina</option>
                                        <option value="SD">South Dakota</option>
                                        <option value="TN">Tennessee</option>
                                        <option value="TX">Texas</option>
                                        <option value="UT">Utah</option>
                                        <option value="VT">Vermont</option>
                                        <option value="VA">Virginia</option>
                                        <option value="WA">Washington</option>
                                        <option value="WV">West Virginia</option>
                                        <option value="WI">Wisconsin</option>
                                        <option value="WY">Wyoming</option>
                                    </select>
                                    <div class="lq-field-err" id="err-State">Please select your state.</div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="lq-step-actions">
                        <div class="lq-submit-row">
                            <div class="lq-trust-note">Simple review • You decide what happens next</div>
                            <button type="submit" class="btn-gold w-100" id="submitLife" data-default-label="@finalSubmitButtonText">@finalSubmitButtonText</button>
                        </div>
                        <div class="lq-error" id="lifeError"></div>
                        <div class="lq-success" id="lifeSuccess">Thanks! We received your request.</div>
                        <button type="button" class="btn-ghost mt-2" id="step2BackBtn">Back</button>
                    </div>
                    <div class="lq-reassurance" hidden></div>
            </div>
        </div>
    </form>
</div>
</div>

<script>
(() => {
  const form = document.getElementById('lifeWizardForm');
  if (!form) return;

  const step1Panel = document.getElementById('lifeStep1Panel');
  const processingPanel = document.getElementById('lifeProcessingPanel');
  const step2Panel = document.getElementById('lifeStep2Panel');
  const processingHeading = document.getElementById('lifeProcessingHeading');
  const step2Heading = document.getElementById('lifeStep2Heading');
  const processingFill = document.getElementById('lifeProcessingFill');
  const step1Progress = document.getElementById('lifeStep1Progress');
  const step1ProgressFill = document.getElementById('lifeStep1ProgressFill');
  const microSteps = Array.from(document.querySelectorAll('[data-micro-step]'));
  const step1ContinueBtn = document.getElementById('step1Continue');
  const step2BackBtn = document.getElementById('step2BackBtn');
  const showContactStepByDefault = '@(showContactStepByDefault ? "true" : "false")' === 'true';
  const answer1Hidden = document.getElementById('Answer1');
  const answer2Hidden = document.getElementById('Answer2');
  const answer4Hidden = document.getElementById('Answer4');
  const ageHidden = document.getElementById('AgeRange');
  const focusHidden = document.getElementById('ProtectFocus');
  const submitBtn = document.getElementById('submitLife');
  const submitLabel = submitBtn?.dataset.defaultLabel || 'Submit';
  const recPrimaryKeyEl = document.getElementById('RecommendationPrimaryKey');
  const recPrimaryTitleEl = document.getElementById('RecommendationPrimaryTitle');
  const recSecondaryKeyEl = document.getElementById('RecommendationSecondaryKey');
  const recSecondaryTitleEl = document.getElementById('RecommendationSecondaryTitle');
  const pageKey = form.dataset.formKey || 'quote_life';
  const pageVariant = '@pageVariant';
  const pageMode = '@pageMode';
  const startEvent = '@cfg.StartEvent';
  const submitEvent = '@cfg.SubmitEvent';
  const usesLeanContactFields = '@(usesLeanContactFields ? "true" : "false")' === 'true';
  const hasServerErrors = '@(ViewData.ModelState.ErrorCount > 0 ? "true" : "false")' === 'true';
  const hasAgentTrustProfile = '@(showAgentTrustCard ? "true" : "false")' === 'true';
  const agentTrackingSlug = '@agentSlug';
  const agentTrackingProfileId = '@(agentTrustProfile?.AgentTrackingProfileId.ToString() ?? string.Empty)';
  const isLandingMobile = document.body.classList.contains('life-landing') && window.matchMedia('(max-width: 767.98px)').matches;
  const stateSelect = document.getElementById('State');
  const ageInput = document.getElementById('Age');
  const ageRangeInputs = Array.from(form.querySelectorAll('input[name="AgeBracket"]'));
  const requiredContactFields = usesLeanContactFields
    ? ['FirstName', 'LastName', 'Phone', 'Email']
    : ['FirstName', 'LastName', 'Phone', 'Email', 'State'];
  const AGE_RANGE_TO_NUMERIC = Object.freeze({
    '18-24': 21,
    '25-34': 30,
    '35-44': 40,
    '45-54': 50,
    '55+': 60,
  });
  const PROCESSING_BRIDGE_MS = 1500;
  const microStepViewEvents = [
    'life_step1_protecting_view',
    'life_step1_goal_view',
    'life_step1_age_view',
  ];
  let currentMicroStep = 0;
  let autoAdvanceTimer = null;
  let processingTimer = null;

  if (stateSelect?.dataset.selected) {
    stateSelect.value = stateSelect.dataset.selected;
  }

  requiredContactFields.forEach((name) => {
    const el = form.querySelector(`[name="${name}"]`);
    if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement)) {
      return;
    }

    const eventName = el instanceof HTMLSelectElement ? 'change' : 'input';
    el.addEventListener(eventName, () => {
      clearFieldError(name);
      const lifeError = document.getElementById('lifeError');
      if (lifeError) {
        lifeError.style.display = 'none';
      }
    });
  });

  // ── Product content config ────────────────────────────────────────────────
  // 5 core recommendation buckets: term, wholelife, finalexpense, mortgage, iul
  // 'life' is a display-only fallback and is never recommended.
  const PRODUCT_CONTENT = {
    term: {
      title: 'Term Life Insurance',
      desc: 'A lower-cost protection path commonly reviewed when the goal is covering temporary responsibilities like income, family needs, or major bills.',
      bullets: [
        'Often the most affordable way to get more coverage',
        'Commonly reviewed for income protection and family needs',
        'A strong option when straightforward protection is the priority',
      ],
    },
    wholelife: {
      title: 'Whole Life Insurance',
      desc: 'A simple permanent coverage path often reviewed when lifelong protection and steady guarantees matter.',
      bullets: [
        'Designed to stay in place for the long term',
        'Builds cash value over time',
        'Often reviewed when permanent protection matters more than lowest cost',
      ],
    },
    finalexpense: {
      title: 'Final Expense Coverage',
      desc: 'A smaller permanent coverage path commonly reviewed to help with burial and end-of-life expenses.',
      bullets: [
        'Focused on funeral and final-cost needs',
        'Usually reviewed when the coverage purpose is narrow and specific',
        'Often more relevant in older-age planning conversations',
      ],
    },
    mortgage: {
      title: 'Mortgage Protection Review',
      desc: 'A protection path commonly reviewed when the priority is helping protect the home and major monthly obligations.',
      bullets: [
        'Focused on mortgage and household bill protection',
        'Often reviewed alongside term coverage',
        'A strong fit when keeping the home is the main concern',
      ],
    },
    iul: {
      title: 'Indexed Universal Life',
      desc: 'A more flexible permanent coverage option that may be worth reviewing in select long-term planning situations.',
      bullets: [
        'Permanent protection with flexible structure',
        'More advanced than basic term or whole life',
        'Typically worth reviewing only when long-term flexibility is a priority',
      ],
    },
    // Display-only fallback — never recommended by the engine
    life: {
      title: 'Life Insurance',
      desc: 'Comprehensive protection options tailored to your goals — income replacement, legacy planning, or simply peace of mind.',
      bullets: [
        'Options matched to your situation',
        'Flexible coverage amounts and terms',
        'Expert guidance included',
      ],
    },
  };

  // ── Recommendation engine ─────────────────────────────────────────────────
  // Goal-primary dispatch table — no additive scoring.
  //
  // IUL: does NOT appear in any generic page output. The only path to IUL
  //   as primary is the specific /Quote/IUL product page (offerKey = 'iul').
  //   On all other pages IUL is never a recommended secondary either.
  //
  // Final Expense: suppressed as primary for age < 50. Appears as secondary
  //   for age 35–49 on a final_expenses or leave_something goal. Primary only
  //   for age >= 50 on a final_expenses goal.
  //
  // Whole Life: the default permanent / cash-value comparison path.
  //   Replaces IUL as the conservative permanent default for all age bands.
  //
  // Q1 (protectingWho) does not change the primary/secondary output.

  // Pure goal + age dispatch. Returns { primaryKey, secondaryKey }.
  // Q1 does not override these results; it reinforces existing tendencies only.
  function resolveGenericPair(coverageGoal, ageNum) {
    // 1. Replace income for my family
    if (coverageGoal === 'replace_income') {
      return { primaryKey: 'term', secondaryKey: 'wholelife' };
    }

    // 2. Help with mortgage or bills
    if (coverageGoal === 'mortgage_or_bills') {
      return { primaryKey: 'mortgage', secondaryKey: 'term' };
    }

    // 3. Leave something behind
    if (coverageGoal === 'leave_something') {
      if (Number.isFinite(ageNum) && ageNum >= 50) {
        return { primaryKey: 'wholelife', secondaryKey: 'finalexpense' };
      }
      // age < 50 (including unknown age): whole life + term
      return { primaryKey: 'wholelife', secondaryKey: 'term' };
    }

    // 4. Cover final expenses — hard age-banded mapping
    if (coverageGoal === 'final_expenses') {
      if (!Number.isFinite(ageNum) || ageNum < 35) {
        // Young or unknown: whole life is the permanent default; FE not appropriate
        return { primaryKey: 'wholelife', secondaryKey: 'term' };
      }
      if (ageNum < 50) {
        // 35–49: whole life primary, FE as secondary comparison
        return { primaryKey: 'wholelife', secondaryKey: 'finalexpense' };
      }
      // 50+ (both 50–64 and 65+): FE is the right primary
      return { primaryKey: 'finalexpense', secondaryKey: 'wholelife' };
    }

    // 5. Not sure / empty / unknown — conservative default
    return { primaryKey: 'term', secondaryKey: 'wholelife' };
  }

  function computeRecommendations() {
    const coverageGoal  = selectedRadio('CoverageGoal')?.value  || answer2Hidden?.value || '';
    const selectedAgeRange = selectedRadio('AgeBracket')?.value || ageHidden?.value || '';
    const ageFromRange  = normalizedAgeFromRange(selectedAgeRange);
    const age           = asTrimmed(ageInput?.value) || ageFromRange || asTrimmed(answer4Hidden?.value);
    const ageNum        = Number.parseInt(age, 10);
    const offerKey      = '@cfg.OfferKey';
    const isGeneric     = offerKey === 'life';

    let primaryKey, secondaryKey;

    if (!isGeneric) {
      // Specific-product page: primary is always the page's own product.
      // Secondary is the top recommendation from the generic dispatch
      // that isn't the locked primary.
      const pair   = resolveGenericPair(coverageGoal, ageNum);
      primaryKey   = offerKey;
      secondaryKey = pair.primaryKey !== offerKey ? pair.primaryKey : pair.secondaryKey;
    } else {
      const pair   = resolveGenericPair(coverageGoal, ageNum);
      primaryKey   = pair.primaryKey;
      secondaryKey = pair.secondaryKey;
    }

    // ── Safety fallbacks ──────────────────────────────────────────────────
    if (!PRODUCT_CONTENT[primaryKey])   primaryKey   = 'term';
    if (!PRODUCT_CONTENT[secondaryKey]) secondaryKey = 'wholelife';
    if (primaryKey === secondaryKey)    secondaryKey = primaryKey === 'term' ? 'wholelife' : 'term';

    return {
      primary:   { key: primaryKey,   ...(PRODUCT_CONTENT[primaryKey]   || PRODUCT_CONTENT.life) },
      secondary: { key: secondaryKey, ...(PRODUCT_CONTENT[secondaryKey] || PRODUCT_CONTENT.life) },
    };
  }

  function trackEvent(eventType, metadata = {}) {
    window.legendTrack?.({
      EventType: eventType,
      PageKey: pageKey,
      Offer: '@cfg.OfferKey',
      MetadataJson: JSON.stringify({
        pageVariant,
        pageMode,
        pagePath: window.location.pathname,
        hasAgentTrustProfile,
        ...(agentTrackingSlug ? { agentSlug: agentTrackingSlug } : {}),
        ...(agentTrackingProfileId ? { agentProfileId: agentTrackingProfileId } : {}),
        ...metadata
      })
    });
  }

  function selectedRadio(name) {
    return form.querySelector(`input[name="${name}"]:checked`);
  }

  function asTrimmed(value) {
    return typeof value === 'string' ? value.trim() : '';
  }

  function normalizedAgeFromRange(ageRange) {
    const mapped = AGE_RANGE_TO_NUMERIC[ageRange];
    return Number.isFinite(mapped) ? String(mapped) : '';
  }

  function showChoiceError(errorId, show) {
    const el = document.getElementById(errorId);
    if (!el) return;
    el.classList.toggle('visible', !!show);
  }

  function setFieldError(name, message) {
    const el = document.getElementById(`err-${name}`);
    if (!el) return;
    if (!el.dataset.defaultText) {
      el.dataset.defaultText = el.textContent || '';
    }
    el.textContent = message || el.dataset.defaultText;
    el.classList.add('visible');
  }

  function clearFieldError(name) {
    const el = document.getElementById(`err-${name}`);
    if (!el) return;
    if (el.dataset.defaultText) {
      el.textContent = el.dataset.defaultText;
    }
    el.classList.remove('visible');
  }

  function getContactFieldError(name) {
    const el = form.querySelector(`[name="${name}"]`);
    if (!(el instanceof HTMLInputElement || el instanceof HTMLTextAreaElement || el instanceof HTMLSelectElement)) {
      return '';
    }

    const value = asTrimmed(el.value);
    if (!value) {
      return name === 'State'
        ? 'Please select your state.'
        : `Please enter your ${name === 'Email' ? 'email' : name === 'Phone' ? 'phone' : name === 'FirstName' ? 'first name' : 'last name'}.`;
    }

    if (name === 'Email' && el instanceof HTMLInputElement && !el.checkValidity()) {
      return 'Please enter a valid email address.';
    }

    return '';
  }

  function validateContactFields(focusFirst = false) {
    let firstInvalid = null;

    requiredContactFields.forEach((name) => {
      const error = getContactFieldError(name);
      if (error) {
        setFieldError(name, error);
        firstInvalid ??= form.querySelector(`[name="${name}"]`);
      } else {
        clearFieldError(name);
      }
    });

    if (focusFirst && firstInvalid instanceof HTMLElement) {
      firstInvalid.focus();
    }

    return firstInvalid === null;
  }

  function clearAutoAdvanceTimer() {
    if (autoAdvanceTimer) {
      window.clearTimeout(autoAdvanceTimer);
      autoAdvanceTimer = null;
    }
  }

  function clearProcessingTimer(resetBar = false) {
    if (processingTimer) {
      window.clearTimeout(processingTimer);
      processingTimer = null;
    }
    if (processingFill && resetBar) {
      processingFill.style.transition = 'none';
      processingFill.style.width = '0%';
      void processingFill.offsetWidth;
    }
  }

  function setActivePanel(activePanel) {
    const previewPanel = document.getElementById('lifeMiniResultsPanel');
    [step1Panel, processingPanel, step2Panel, previewPanel].forEach((panel) => {
      if (!panel) return;
      panel.hidden = panel !== activePanel;
    });
  }

  function scrollIntoViewAndFocus(target, shouldFocus = false) {
    if (!target) return;
    const scrollBehavior = (isLandingMobile && target === step1Panel) ? 'auto' : 'smooth';
    const scrollBlock = isLandingMobile ? 'nearest' : 'center';
    setTimeout(() => {
      target.scrollIntoView({ behavior: scrollBehavior, block: scrollBlock });
      if (shouldFocus && target instanceof HTMLElement) {
        target.focus({ preventScroll: true });
      }
    }, 40);
  }

  function syncStepOneAnswersFromUI() {
    const protecting = selectedRadio('ProtectingWho');
    const goal = selectedRadio('CoverageGoal');
    const selectedAgeRange = selectedRadio('AgeBracket')?.value || '';
    const ageFromRange = normalizedAgeFromRange(selectedAgeRange);
    const fallbackAgeValue = asTrimmed(ageInput?.value);
    const resolvedAgeValue = ageFromRange || fallbackAgeValue;

    if (protecting) {
      answer1Hidden.value = protecting.value;
    }
    if (goal) {
      answer2Hidden.value = goal.value;
      focusHidden.value = goal.dataset.label || goal.value;
    }
    if (ageInput) {
      ageInput.value = resolvedAgeValue;
    }
    if (answer4Hidden) {
      answer4Hidden.value = selectedAgeRange || resolvedAgeValue;
    }
    if (ageHidden) {
      ageHidden.value = selectedAgeRange;
    }
  }

  function validateAgeOnly() {
    const selectedAgeRange = selectedRadio('AgeBracket')?.value || '';
    const ageFromRange = normalizedAgeFromRange(selectedAgeRange);
    if (ageFromRange) {
      if (ageInput) {
        ageInput.value = ageFromRange;
      }
      showChoiceError('err-step1-age', false);
      return true;
    }
    const ageValue = asTrimmed(ageInput?.value);
    const ageNum = Number.parseInt(ageValue, 10);
    const hasValidAge = Number.isFinite(ageNum) && ageNum >= 18 && ageNum <= 85;
    showChoiceError('err-step1-age', !hasValidAge);
    return hasValidAge;
  }

  function showMicroStep(stepIndex, shouldScroll = false) {
    const bounded = Math.max(0, Math.min(microSteps.length - 1, stepIndex));
    currentMicroStep = bounded;
    microSteps.forEach((stepEl, i) => {
      stepEl.hidden = i !== bounded;
    });

    if (step1Progress) {
      step1Progress.textContent = `Step ${bounded + 1} of 3`;
    }
    if (step1ProgressFill) {
      step1ProgressFill.style.width = `${((bounded + 1) / microSteps.length) * 100}%`;
    }
    trackEvent(microStepViewEvents[bounded], { microStep: bounded + 1 });

    if (shouldScroll) {
      scrollIntoViewAndFocus(step1Panel, false);
    }
  }

  function showStep1(microStepIndex = 0, shouldScroll = false) {
    clearAutoAdvanceTimer();
    clearProcessingTimer(true);
    setActivePanel(step1Panel);
    trackEvent('life_step1_intro_view');
    showMicroStep(microStepIndex, shouldScroll);
  }

  function animateProcessingBar() {
    if (!processingFill) return;
    processingFill.style.transition = 'none';
    processingFill.style.width = '0%';
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        processingFill.style.transition = `width ${PROCESSING_BRIDGE_MS}ms cubic-bezier(0.22, 1, 0.36, 1)`;
        processingFill.style.width = '100%';
      });
    });
  }

  function showProcessingBridge(shouldScroll = true) {
    clearAutoAdvanceTimer();
    clearProcessingTimer(true);
    computeRecommendations();
    setActivePanel(processingPanel);
    trackEvent('life_processing_bridge_view');
    animateProcessingBar();
    if (shouldScroll) {
      scrollIntoViewAndFocus(processingHeading || processingPanel, true);
    }
    processingTimer = window.setTimeout(() => {
      processingTimer = null;
      trackEvent('life_processing_bridge_complete');
      syncStepOneAnswersFromUI();
      showMiniResultsPreview();
    }, PROCESSING_BRIDGE_MS + 80);
  }

  function showMiniResultsPreview() {
    const existing = document.getElementById('lifeMiniResultsPanel');
    if (existing) existing.remove();

    const recs = computeRecommendations();

    const previewHtml = `
      <div class="lq-step-panel" id="lifeMiniResultsPanel">
        <div class="lq-step-panel-pad">
          <div class="lq-step-progress">Your Results</div>
          <div class="lq-step-title">Based on what you told us, here’s what actually makes sense for your situation</div>
          <div class="lq-step-helper">Most people are surprised by this — here’s why:</div>
          <div class="lq-rec-card primary">
            <span class="lq-rec-badge primary">Best Match</span>
            <div class="lq-rec-title">${recs.primary.title}</div>
            <div class="lq-rec-desc">${recs.primary.desc}</div>
          </div>
          <div class="lq-rec-card">
            <span class="lq-rec-badge secondary">Also Worth Looking At</span>
            <div class="lq-rec-title">${recs.secondary.title}</div>
          </div>
          <div class="lq-reach-note" style="margin-top:12px;">
            We'll walk through your options and pricing clearly on the next step.
          </div>
          <div class="lq-step-actions">
            <button type="button" class="btn-gold w-100" id="continueToContactBtn">Continue & Review My Options</button>
          </div>
        </div>
      </div>
    `;

    processingPanel.insertAdjacentHTML('afterend', previewHtml);
    const previewPanel = document.getElementById('lifeMiniResultsPanel');
    setActivePanel(previewPanel);
    trackEvent('mini_results_view');

    document.getElementById('continueToContactBtn')?.addEventListener('click', () => {
      previewPanel.remove();
      showStep2(true);
    });
  }

  function showStep2(shouldScroll = true) {
    clearAutoAdvanceTimer();
    clearProcessingTimer(false);
    setActivePanel(step2Panel);
    trackEvent('life_step2_view', { handoffType: hasAgentTrustProfile ? 'agent' : 'generic' });
    if (shouldScroll) {
      scrollIntoViewAndFocus(step2Heading || step2Panel, true);
    }
  }

  function resolveInitialMicroStep() {
    if (!selectedRadio('ProtectingWho')) return 0;
    if (!selectedRadio('CoverageGoal')) return 1;
    return 2; // age step
  }

  function validateStepOneComplete() {
    const protecting = selectedRadio('ProtectingWho');
    const goal = selectedRadio('CoverageGoal');
    const hasValidAge = validateAgeOnly();

    showChoiceError('err-step1-protecting-who', !protecting);
    showChoiceError('err-step1-coverage-goal', !goal);

    if (!protecting) {
      showStep1(0, true);
      form.querySelector('input[name="ProtectingWho"]')?.focus();
      return false;
    }
    if (!goal) {
      showStep1(1, true);
      form.querySelector('input[name="CoverageGoal"]')?.focus();
      return false;
    }
    if (!hasValidAge) {
      showStep1(2, true);
      form.querySelector('input[name="AgeBracket"]')?.focus();
      return false;
    }
    return true;
  }

  function focusFirstInvalidContactField() {
    validateContactFields(true);
  }

  function queueMicroAdvance(expectedStep, nextStep) {
    if (step1Panel.hidden || currentMicroStep !== expectedStep) return;
    clearAutoAdvanceTimer();
    autoAdvanceTimer = window.setTimeout(() => showMicroStep(nextStep, true), 160);
  }

  function queueProcessingAdvanceFromAgeSelection() {
    if (step1Panel.hidden || currentMicroStep !== 2) return;
    clearAutoAdvanceTimer();
    autoAdvanceTimer = window.setTimeout(() => step1ContinueBtn?.click(), 180);
  }

  function wireAutoAdvanceGroup(groupName, errorId, selectEvent, expectedStep, nextStep) {
    form.querySelectorAll(`input[name="${groupName}"]`).forEach((radio) => {
      radio.addEventListener('change', () => {
        showChoiceError(errorId, false);
        syncStepOneAnswersFromUI();
        trackEvent(selectEvent, { choice: radio.dataset.label || radio.value, code: radio.value });
        queueMicroAdvance(expectedStep, nextStep);
      });
      radio.closest('label')?.addEventListener('click', () => {
        // Allow forward movement when revisiting a step where the choice is already selected.
        setTimeout(() => {
          if (radio.checked) queueMicroAdvance(expectedStep, nextStep);
        }, 0);
      });
    });
  }

  wireAutoAdvanceGroup('ProtectingWho', 'err-step1-protecting-who', 'life_step1_protecting_select', 0, 1);
  form.querySelectorAll('input[name="CoverageGoal"]').forEach((radio) => {
    radio.addEventListener('change', () => {
      showChoiceError('err-step1-coverage-goal', false);
      syncStepOneAnswersFromUI();
      trackEvent('life_step1_goal_select', { choice: radio.dataset.label || radio.value, code: radio.value });
      if (!step1Panel.hidden && currentMicroStep === 1) {
        clearAutoAdvanceTimer();
        autoAdvanceTimer = window.setTimeout(() => showMicroStep(2, true), 160);
      }
    });
  });
  document.getElementById('ageStepBackBtn')?.addEventListener('click', () => {
    showStep1(1, true);
  });

  ageRangeInputs.forEach((radio) => {
    radio.addEventListener('change', () => {
      showChoiceError('err-step1-age', false);
      syncStepOneAnswersFromUI();
      trackEvent('step1_age_entered', { ageRange: radio.value, age: radio.dataset.age || '' });
      queueProcessingAdvanceFromAgeSelection();
    });
    radio.closest('label')?.addEventListener('click', () => {
      setTimeout(() => {
        if (radio.checked) queueProcessingAdvanceFromAgeSelection();
      }, 0);
    });
  });
  document.querySelectorAll('[data-step1-back]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = Number.parseInt(btn.getAttribute('data-step1-back') || '0', 10);
      showMicroStep(Number.isFinite(target) ? target : 0, true);
    });
  });

  step1ContinueBtn?.addEventListener('click', () => {
    clearAutoAdvanceTimer();
    syncStepOneAnswersFromUI();
    if (!validateStepOneComplete()) return;
    syncStepOneAnswersFromUI();
    trackEvent('life_step1_age_continue', {
      protectingWho: answer1Hidden?.value || '',
      coverageGoal: answer2Hidden?.value || '',
      age: answer4Hidden?.value || '',
      ageRange: ageHidden?.value || ''
    });
    showProcessingBridge(true);
  });

  step2BackBtn?.addEventListener('click', () => {
    trackEvent('life_step2_back');
    showStep1(2, true);
  });

  // form submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const recs = computeRecommendations();
    if (recPrimaryKeyEl)     recPrimaryKeyEl.value     = recs.primary.key;
    if (recPrimaryTitleEl)   recPrimaryTitleEl.value   = recs.primary.title;
    if (recSecondaryKeyEl)   recSecondaryKeyEl.value   = recs.secondary.key;
    if (recSecondaryTitleEl) recSecondaryTitleEl.value = recs.secondary.title;
    trackEvent('recommendation_generated', {
      primary: recs.primary.key,
      secondary: recs.secondary.key,
    });

    syncStepOneAnswersFromUI();
    if (!validateStepOneComplete()) {
      form._trackSubmitAttempt?.(false, 1);
      return;
    }

    const lifeError = document.getElementById('lifeError');
    const lifeSuccess = document.getElementById('lifeSuccess');
    if (lifeError) lifeError.style.display = 'none';
    if (lifeSuccess) lifeSuccess.style.display = 'none';
    ['FirstName','LastName','Phone','Email','State'].forEach(clearFieldError);
    showStep2(false);

    // contact validation
    if (!validateContactFields(true)) {
      if (lifeError) {
        lifeError.textContent = 'Please review the highlighted contact fields.';
        lifeError.style.display = 'block';
      }
      showStep2(false);
      form._trackSubmitAttempt?.(false, 1);
      return;
    }

    trackEvent('life_step2_submit_attempt');
    form._trackSubmitAttempt?.(true, 0);
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
    }

    // Populate attribution fields immediately before submit
    (function () {
      var ids = window.legendTrackingIds;
      var p = new URLSearchParams(window.location.search);
      var attr = ids && ids.getAttribution ? (ids.getAttribution() || {}) : {};
      function set(id, v) { var el = document.getElementById(id); if (el && v) el.value = v; }
      set('SessionId',    ids && ids.getSessionId ? ids.getSessionId() : '');
      set('VisitorId',    ids && ids.getVisitorId ? ids.getVisitorId() : '');
      set('UtmSource',    attr.utmSource || p.get('utm_source') || '');
      set('UtmMedium',    attr.utmMedium || p.get('utm_medium') || '');
      set('UtmCampaign',  attr.utmCampaign || p.get('utm_campaign') || '');
      set('UtmTerm',      attr.utmTerm || p.get('utm_term') || '');
      set('UtmContent',   attr.utmContent || p.get('utm_content') || '');
      set('Fbclid',       attr.fbclid || p.get('fbclid') || '');
      set('ReferrerUrl',  document.referrer || '');
      set('LandingPageUrl', window.location.href || '');
    })();

    window.legendTrack?.({
      EventType: 'form_submit',
      FormKey: pageKey,
      PageKey: pageKey,
      SubmitOutcome: 'attempt',
      MetadataJson: JSON.stringify({
        offer: '@cfg.OfferKey',
        step: 'submit_attempt',
        pageVariant,
        pageMode,
        pagePath: window.location.pathname,
        hasAgentTrustProfile,
        ...(agentTrackingSlug ? { agentSlug: agentTrackingSlug } : {}),
        ...(agentTrackingProfileId ? { agentProfileId: agentTrackingProfileId } : {}),
        protectingWho: answer1Hidden?.value || '',
        coverageGoal: answer2Hidden?.value || '',
        age: answer4Hidden?.value || '',
        ageRange: ageHidden.value,
        protectFocus: focusHidden.value
      })
    });

    const thankYouPath = (() => {
      const parts = location.pathname.split('/').filter(Boolean);
      if (parts.length >= 2 && parts[0] === 'a') {
        return `/a/${parts[1]}/ThankYou`;
      }
      return '/ThankYou';
    })();

    try {
      const res = await fetch(form.action, { method: 'POST', body: new FormData(form), headers: { 'X-Requested-With': 'fetch' } });
      if (!res.ok) throw new Error('Network');
      form._trackSubmitSuccess?.();
      trackEvent('life_step2_submit_success');
      trackEvent(submitEvent, { submitOutcome: 'success' });
      trackEvent('results_contact_submit', {
        primaryRec:   recPrimaryKeyEl?.value   || '',
        secondaryRec: recSecondaryKeyEl?.value || '',
      });
      window.legendTrack?.({ EventType: 'form_submit', FormKey: pageKey, PageKey: pageKey,
        SubmitOutcome: 'success', MetadataJson: JSON.stringify({
          offer: '@cfg.OfferKey',
          pageVariant,
          pageMode,
          pagePath: window.location.pathname,
          hasAgentTrustProfile,
          ...(agentTrackingSlug ? { agentSlug: agentTrackingSlug } : {}),
          ...(agentTrackingProfileId ? { agentProfileId: agentTrackingProfileId } : {})
        }) });
      window.location.href = thankYouPath;
    } catch (err) {
      if (lifeError) {
        lifeError.textContent = 'We could not send this right now. Please try again.';
        lifeError.style.display = 'block';
      }
      window.legendTrack?.({ EventType: 'form_submit', FormKey: pageKey, PageKey: pageKey,
        SubmitOutcome: 'error', MetadataJson: JSON.stringify({
          offer: '@cfg.OfferKey',
          pageVariant,
          pageMode,
          pagePath: window.location.pathname,
          hasAgentTrustProfile,
          ...(agentTrackingSlug ? { agentSlug: agentTrackingSlug } : {}),
          ...(agentTrackingProfileId ? { agentProfileId: agentTrackingProfileId } : {})
        }) });
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = submitLabel;
      }
    }
  });

  // fire start event once
  window.legendTrack?.({
    EventType: startEvent,
    PageKey: pageKey,
    Offer: '@cfg.OfferKey',
    MetadataJson: JSON.stringify({
      pageVariant,
      pageMode,
      pagePath: window.location.pathname,
      hasAgentTrustProfile,
      ...(agentTrackingSlug ? { agentSlug: agentTrackingSlug } : {}),
      ...(agentTrackingProfileId ? { agentProfileId: agentTrackingProfileId } : {})
    })
  });

  syncStepOneAnswersFromUI();
  if (showContactStepByDefault) {
    showStep2(false);
  } else {
    const initMicro = resolveInitialMicroStep();
    if (initMicro >= 2) {
      showStep1(2, false);
    } else {
      showStep1(initMicro, false);
    }
  }
  if (showContactStepByDefault && hasServerErrors) {
    setTimeout(() => focusFirstInvalidContactField(), 30);
  }
})();
</script>
