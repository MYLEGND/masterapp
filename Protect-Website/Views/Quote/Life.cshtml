  function formatCoverageFigureForStep2(amount) {
    const numericAmount = Math.max(0, Math.round(Number(amount || 0)));
    if (!numericAmount) {
      return '';
    }

    if (numericAmount >= 2000000) {
      return '$2,000,000+';
    }

    return `$${numericAmount.toLocaleString('en-US')}`;
  }

  function formatCurrencyRangeCompactForStep2(low, high) {
    const lowValue = Math.max(0, Math.round(Number(low || 0)));
    const highValue = Math.max(lowValue, Math.round(Number(high || 0)));
    if (!lowValue && !highValue) {
      return 'Estimate pending';
    }

    return `$${lowValue.toLocaleString('en-US')}-$${highValue.toLocaleString('en-US')}/mo`;
  }

  function resolveCoverageRangeLadderForStep2(preview) {
    switch (String(preview?.primary?.policyKey || preview?.offerKey || '').trim().toLowerCase()) {
      case 'term':
        return [250000, 500000, 1000000, 2000000];
      case 'wholelife':
        return [50000, 100000, 250000, 500000];
      case 'finalexpense':
        return [25000, 50000, 75000, 100000];
      case 'mortgage':
        return [150000, 250000, 500000, 750000];
      case 'iul':
        return [250000, 500000, 1000000, 2000000];
      default:
        return [100000, 250000, 500000, 1000000];
    }
  }

  function buildRecommendedCoverageRangeForStep2(preview) {
    const targetCoverage = Number(preview?.requestedCoverageAmount || preview?.primary?.coverageAmount || 0);
    const ladder = resolveCoverageRangeLadderForStep2(preview);
    if (!Number.isFinite(targetCoverage) || targetCoverage <= 0 || ladder.length === 0) {
      return '';
    }

    const formatRange = (low, high) => {
      const lowDisplay = formatCoverageFigureForStep2(low);
      const highDisplay = formatCoverageFigureForStep2(high);
      if (!lowDisplay || !highDisplay) {
        return lowDisplay || highDisplay;
      }

      return `${lowDisplay}-${highDisplay}`;
    };

    if (ladder.length === 1) {
      return formatRange(ladder[0], ladder[0]);
    }

    if (targetCoverage <= ladder[0]) {
      return formatRange(ladder[0], ladder[1]);
    }

    for (let index = 1; index < ladder.length; index += 1) {
      if (targetCoverage <= ladder[index]) {
        return formatRange(ladder[index - 1], ladder[index]);
      }
    }

    return formatRange(ladder[ladder.length - 2], ladder[ladder.length - 1]);
  }

  function resolveDisplayedOfferKeyForStep2(preview) {
    const normalized = normalizeStep2Preview(preview);
    return String(normalized.primary.policyKey || normalized.offerKey || '').trim().toLowerCase();
