                                    string.Equals(form.CoverageGoal, opt.Code, StringComparison.OrdinalIgnoreCase) ||
                                    string.Equals(form.Answer2, opt.Code, StringComparison.OrdinalIgnoreCase);
                                var choiceMeta = GetChoiceCardMeta("CoverageGoal", opt.Code);
                                <label class="lq-card lq-card-rich @choiceMeta.ToneClass@(string.Equals(choiceMeta.VisualMode, "none", StringComparison.OrdinalIgnoreCase) ? " no-visual" : "")">
