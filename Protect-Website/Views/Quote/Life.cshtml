    margin-bottom: 14px !important;
}

/* Fix clipped option grid */
.lq-choice-grid,
.lq-options-grid {
    display: grid !important;
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    gap: 10px !important;
