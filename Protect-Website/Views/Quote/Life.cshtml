/* Step panels — frame layer sits between outer shell and inner surface */
.lq-step-panel {
    border-radius: 24px !important;
    
background:
    radial-gradient(circle at top center, rgba(33,76,140,.20) 0%, transparent 42%),
    linear-gradient(180deg, #0b2347 0%, #081a36 52%, #071427 100%) !important;
border: 1px solid rgba(59,130,246,.22) !important;
box-shadow:
    0 26px 52px rgba(2,12,27,.26),
    inset 0 1px 0 rgba(255,255,255,.05) !important;


}
.lq-step-panel.lq-panel-spotlight {
    box-shadow:
        0 0 0 2px rgba(244,210,124,0.52),
        0 22px 38px rgba(0,0,0,0.34),
        0 0 28px rgba(244,210,124,0.18);
}
.lq-inner-block {
    /* Primary interaction surface — noticeably lighter than the panel frame
       so the eye reads it immediately as the place to act. */
    background: #1c2f4e;
    border: 1.4px solid rgba(199,153,49,0.60);
    border-radius: 12px;
    padding: 20px 18px 16px 18px;
    /* Subtle elevation: modest drop shadow + 1px gold rim at the top edge */
    box-shadow:
        0 8px 24px rgba(0,0,0,0.26),
        inset 0 1px 0 rgba(199,153,49,0.11);
}
.lq-step-title {
    font-size: 1.2rem;
    font-weight: 900;
    color: #c79931;
    margin-bottom: 6px;
}
.lq-step-helper {
    font-size: .94rem;
    color: rgba(248,250,252,0.7);
    margin-bottom: 16px;
}
.lq-step-panel-pad { padding: 14px; }

@@keyframes lqFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
}

