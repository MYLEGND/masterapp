@{
    ViewData["Title"] = "Get a Quote";
    Layout = "_Layout";
    ViewData["PageKey"] = "quote_index";
    ViewData["SeoTitle"] = "Get a Personalized Insurance Quote";
    ViewData["SeoDescription"] = "Start a personalized insurance review for life, mortgage protection, disability, health, auto, home, or commercial coverage.";
}

<style>
:root{
    --surface:#0f172a;
    --surface-soft:#111c32;
    --surface-deep:#0b1325;
    --ink-light:#f8fafc;
    --muted:rgba(248,250,252,.78);
    --muted-soft:rgba(248,250,252,.62);
    --gold:#a68023;
    --gold-strong:#c79931;
    --gold-bright:#f2cd75;
    --border:rgba(199,153,49,.86);
    --border-soft:rgba(199,153,49,.24);
    --shadow:0 22px 64px rgba(0,0,0,.18);
    --shadow-soft:0 14px 38px rgba(0,0,0,.16);
}

.quote-page,
.quote-page *{
    color-scheme:dark;
    box-sizing:border-box;
}

.quote-page{
    max-width:1160px;
    margin:0 auto;
    padding:24px 18px 72px;
}

.quote-shell{
    background:linear-gradient(180deg,#0f172a 0%, #0b1325 100%) !important;
    color:#f8fafc !important;
    border:1.6px solid var(--border);
    border-radius:24px;
    box-shadow:var(--shadow);
    overflow:hidden;
    position:relative;
}

.quote-shell:before{
    content:"";
    position:absolute;
    inset:0;
    pointer-events:none;
    background:
        radial-gradient(850px 300px at 12% 0%, rgba(199,153,49,.16), transparent 64%),
        radial-gradient(640px 250px at 100% 0%, rgba(199,153,49,.10), transparent 70%);
}

.quote-shell > *{
    position:relative;
    z-index:1;
}

.quote-hero{
    display:grid;
    grid-template-columns:minmax(0,1.12fr) minmax(280px,.68fr);
    gap:20px;
    align-items:center;
    padding:30px 30px 20px;
}



.hero-title{
    margin:0 0 10px;
    color:#e8edf7 !important;
    font-size:clamp(2.1rem,3.35vw,3rem);
    line-height:1.04;
    letter-spacing:-.04em;
    font-weight:950;
}

.hero-title span{
    color:var(--gold-bright) !important;
}

.hero-lead{
    max-width:740px;
    margin:0;
    color:var(--muted) !important;
    font-size:1.05rem;
    line-height:1.58;
}

.hero-actions{
    display:flex;
    gap:12px;
    flex-wrap:wrap;
    margin-top:16px;
}

.btn-gold,
.btn-outline{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    border-radius:14px;
    padding:12px 18px;
    font-weight:950;
    text-decoration:none !important;
    transition:.18s ease;
}

.btn-gold{
    background:linear-gradient(180deg,var(--gold-strong),var(--gold));
    color:#fff !important;
    border:1.5px solid var(--border);
    box-shadow:0 14px 32px rgba(0,0,0,.20);
}

.btn-outline{
    background:#111c32 !important;
    color:#f8fafc !important;
    border:1.5px solid rgba(199,153,49,.78);
}

.btn-gold:hover,
.btn-outline:hover{
    transform:translateY(-2px);
    color:#fff !important;
}

.hero-card{
    border:1px solid var(--border-soft);
    border-radius:20px;
    background:rgba(255,255,255,.045) !important;
    padding:18px;
    box-shadow:inset 0 1px 0 rgba(255,255,255,.06);
}

.hero-card-title{
    margin:0 0 12px;
    color:var(--gold-bright) !important;
    font-weight:950;
    font-size:1rem;
}

.hero-list{
    list-style:none;
    margin:0;
    padding:0;
    display:grid;
    gap:10px;
}

.hero-list li{
    color:var(--muted) !important;
    font-weight:780;
    line-height:1.35;
}

.hero-list li:before{
    content:"✓";
    color:var(--gold-bright);
    font-weight:950;
    margin-right:8px;
}

.quote-picker{
    padding:0 30px 24px;
}

.picker-head{
    border-top:1px solid var(--border-soft);
    padding-top:18px;
    margin-bottom:14px;
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
    gap:18px;
}

.picker-head h2{
    margin:0;
    color:var(--gold-bright) !important;
    font-size:1.45rem;
    font-weight:950;
}

.picker-head p{
    margin:5px 0 0;
    color:var(--muted-soft) !important;
    line-height:1.45;
}

.picker-note{
    white-space:nowrap;
    color:var(--muted-soft) !important;
    font-size:.9rem;
    font-weight:850;
}

.quote-grid{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:12px;
}

.quote-tile{
    position:relative;
    display:grid;
    grid-template-columns:auto 1fr auto;
    align-items:center;
    gap:12px;
    min-height:78px;
    padding:12px 13px;
    border-radius:18px;
    border:1px solid rgba(199,153,49,.48);
    background:rgba(255,255,255,.045) !important;
    color:#f8fafc !important;
    text-decoration:none !important;
    transition:.18s ease;
    cursor:pointer;
    overflow:hidden;
}

.quote-tile:before{
    content:"";
    position:absolute;
    inset:0;
    pointer-events:none;
    background:radial-gradient(420px 150px at 8% 0%, rgba(199,153,49,.11), transparent 66%);
}

.quote-tile > *{
    position:relative;
    z-index:1;
}

.quote-tile:hover{
    transform:translateY(-3px);
    border-color:var(--gold-bright);
    background:rgba(199,153,49,.10) !important;
    color:#fff !important;
}

.life-tile{
    border-color:rgba(242,205,117,.85);
    background:rgba(199,153,49,.085) !important;
}


.tile-icon svg,
.process-svg svg,
.hero-check svg {
    width:22px;
    height:22px;
    stroke:currentColor;
    stroke-width:2;
    fill:none;
    stroke-linecap:round;
    stroke-linejoin:round;
}

.process-svg{
    width:46px;
    height:46px;
    border-radius:16px;
    display:flex;
    align-items:center;
    justify-content:center;
    margin:2px 0 10px;
    border:1px solid rgba(199,153,49,.42);
    background:rgba(199,153,49,.11);
    color:var(--gold-bright);
}

.hero-list li{
    display:flex;
    align-items:flex-start;
    gap:8px;
}

.hero-list li:before{
    display:none;
}

.hero-check{
    width:20px;
    height:20px;
    border-radius:999px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    flex:0 0 auto;
    color:var(--gold-bright);
    border:1px solid rgba(199,153,49,.48);
    background:rgba(199,153,49,.10);
    margin-top:1px;
}

.hero-check svg{
    width:13px;
    height:13px;
    stroke-width:2.4;
}

.tile-icon{
    width:42px;
    height:42px;
    border-radius:15px;
    display:flex;
    align-items:center;
    justify-content:center;
    border:1px solid rgba(199,153,49,.46);
    background:rgba(199,153,49,.15);
    color:var(--gold-bright);
    font-size:1.12rem;
}

.tile-title{
    margin:0 0 2px;
    color:var(--gold-bright) !important;
    font-size:1rem;
    font-weight:950;
}

.tile-sub{
    margin:0;
    color:var(--muted-soft) !important;
    font-size:.86rem;
    line-height:1.32;
}

.tile-arrow{
    width:30px;
    height:30px;
    border-radius:999px;
    display:flex;
    align-items:center;
    justify-content:center;
    border:1px solid rgba(199,153,49,.62);
    color:#f8fafc !important;
    font-weight:950;
}

.process-strip{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    border-top:1px solid var(--border-soft);
    background:rgba(255,255,255,.025) !important;
}

.process-step{
    padding:16px 22px;
    border-right:1px solid rgba(199,153,49,.16);
}

.process-step:last-child{
    border-right:0;
}

.process-num{
    width:28px;
    height:28px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    border-radius:999px;
    border:1px solid rgba(199,153,49,.62);
    color:var(--gold-bright) !important;
    font-weight:950;
    margin-bottom:8px;
}

.process-step h5{
    margin:0 0 4px;
    color:var(--gold-bright) !important;
    font-weight:950;
}

.process-step p{
    margin:0;
    color:var(--muted) !important;
    line-height:1.45;
    font-size:.92rem;
}

.calendar-section{
    margin-top:24px;
    padding:24px 20px;
    background:linear-gradient(180deg,#0f172a 0%, #0b1325 100%) !important;
    border:1.4px solid var(--border);
    border-radius:22px;
    box-shadow:var(--shadow-soft);
    text-align:center;
    color:#f8fafc !important;
}

.calendar-section h2{
    margin:0 0 8px;
    color:var(--gold-strong) !important;
    font-weight:950;
}

.calendar-section p{
    max-width:720px;
    margin:0 auto 16px;
    color:var(--muted) !important;
    line-height:1.6;
}

.calendar-container{
    width:100%;
    height:600px;
    border-radius:16px;
    overflow:hidden;
    border:1px solid var(--border);
    background:#fff;
    position:relative;
}

.calendar-container iframe{
    position:absolute;
    inset:0;
    width:100% !important;
    height:100% !important;
    border:0;
    display:block;
}

.prayer-card{
    background:linear-gradient(180deg,#0f172a 0%, #0b1325 100%) !important;
    border:1px solid var(--border);
    border-radius:22px;
    box-shadow:var(--shadow-soft);
    padding:24px 20px;
    text-align:center;
    margin-top:24px;
    color:#f8fafc !important;
}

.prayer-kicker{
    letter-spacing:.18em;
    text-transform:uppercase;
    font-size:.78rem;
    color:var(--gold-strong) !important;
    font-weight:950;
}

.prayer-text{
    margin:12px auto;
    max-width:820px;
    font-size:1rem;
    line-height:1.75;
    color:var(--muted) !important;
    font-weight:650;
}

.prayer-divider{
    height:2px;
    width:90px;
    background:var(--gold);
    border-radius:999px;
    margin:12px auto;
}

.life-modal{
    position:fixed;
    inset:0;
    background:rgba(8,12,24,.72);
    backdrop-filter:blur(8px);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:10000;
    padding:16px;
}
.life-modal.open{ display:flex; }
.life-modal-card{
    width:min(480px,94vw);
    background:linear-gradient(180deg,#0f172a 0%,#0c1427 100%) !important;
    border:1.6px solid rgba(199,153,49,.8);
    border-radius:16px;
    box-shadow:0 24px 60px rgba(0,0,0,.35);
    color:#f4f6fb !important;
    padding:18px;
    position:relative;
}
.life-modal-card h3{
    margin:0 0 12px;
    font-weight:900;
    font-size:1.2rem;
    text-align:center;
    color:#dfb75a !important;
}
.life-modal-close{
    position:absolute;
    top:10px;
    right:10px;
    background:transparent;
    border:1px solid rgba(244,246,251,.35);
    color:#f4f6fb;
    border-radius:10px;
    width:32px;
    height:32px;
    font-size:1.1rem;
    cursor:pointer;
}
.life-modal-grid{
    display:grid;
    grid-template-columns:1fr;
    gap:10px;
}
@@media (min-width:520px){
    .life-modal-grid{ grid-template-columns:repeat(2,1fr); }
}
.life-option{
    display:block;
    padding:12px 14px;
    border:1px solid rgba(199,153,49,.65);
    border-radius:10px;
    text-decoration:none !important;
    color:#f8fafc !important;
    font-weight:850;
    text-align:center;
    background:rgba(199,153,49,.08);
}
.life-option:hover{
    border-color:#c79931;
    background:rgba(199,153,49,.15);
    color:#dfb75a !important;
}

.reveal{ opacity:0; transform:translateY(14px); transition:.55s ease; }
.reveal.show{ opacity:1; transform:translateY(0); }

@@media (max-width:992px){
    .quote-hero{ grid-template-columns:1fr; }
    .quote-grid{ grid-template-columns:repeat(2,minmax(0,1fr)); }
}
@@media (max-width:700px){
    .quote-page{ padding:16px 12px 56px; }
    .quote-hero{ padding:24px 18px 18px; }
    .quote-picker{ padding:0 18px 22px; }
    .picker-head{ flex-direction:column; align-items:flex-start; }
    .picker-note{ white-space:normal; }
    .quote-grid{ grid-template-columns:1fr; }
    .process-strip{ grid-template-columns:1fr; }
    .process-step{ border-right:0; border-bottom:1px solid rgba(199,153,49,.16); }
    .process-step:last-child{ border-bottom:0; }
    .calendar-container{ height:520px; }
}
</style>

@{
    var path = Context?.Request?.Path.Value ?? string.Empty;
    var segs = path.Split('/', StringSplitOptions.RemoveEmptyEntries);
    var slugPrefix = (segs.Length >= 2 && segs[0].Equals("a", StringComparison.OrdinalIgnoreCase))
        ? $"/a/{segs[1]}"
        : string.Empty;
    string Link(string relative)
    {
        var basePath = Context?.Request?.PathBase.Value ?? string.Empty;
        return $"{basePath}{slugPrefix}{relative}";
    }
}

<div class="quote-page">

    <section class="quote-shell reveal">
        <div class="quote-hero">
            <div>
<h1 class="hero-title">Get covered with <span>clarity.</span></h1>
                <p class="hero-lead">
                    Pick your lane. We’ll guide the next step.
                </p>

                <div class="hero-actions">
                    <a href="#quoteTypes" class="btn-gold" data-cta="hero_start_quote" data-lead-trigger="true" data-lead-interest="quote_general">Start a Quote →</a>
                    <a href="#calendar" class="btn-outline" data-cta="hero_book_call">Talk First ↗</a>
                </div>
            </div>

            <aside class="hero-card">
                <p class="hero-card-title">What happens next</p>
                <ul class="hero-list">
                    <li><span class="hero-check"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg></span><span>Choose the coverage type</span></li>
                    <li><span class="hero-check"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg></span><span>Answer only what matters</span></li>
                    <li><span class="hero-check"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6L9 17l-5-5"/></svg></span><span>Get a clear next move</span></li>
                </ul>
            </aside>
        </div>

        <div class="quote-picker" id="quoteTypes">
            <div class="picker-head">
                <div>
                    <h2>Choose your quote type</h2>
                    <p>Choose a path. We’ll handle the next step.</p>
                </div>
                <div class="picker-note">Fast · Clear · No pressure</div>
            </div>

            <div class="quote-grid">
                <a href="@Link("/Quote/Auto")" class="quote-tile" aria-label="Start Auto Insurance Quote" data-cta="quote_index_auto_start">
                    <span class="tile-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 16h14"/><path d="M7 16l1-5h8l1 5"/><path d="M7 16v2"/><path d="M17 16v2"/><circle cx="8" cy="18" r="1.3"/><circle cx="16" cy="18" r="1.3"/></svg></span>
                    <span>
                        <p class="tile-title">Auto Insurance</p>
                        <p class="tile-sub">Vehicle + liability.</p>
                    </span>
                    <span class="tile-arrow">→</span>
                </a>

                <a href="@Link("/Quote/Home")" class="quote-tile" aria-label="Start Home Insurance Quote" data-cta="quote_index_home_start">
                    <span class="tile-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 11l8-7 8 7"/><path d="M6 10v10h12V10"/><path d="M10 20v-6h4v6"/></svg></span>
                    <span>
                        <p class="tile-title">Home Insurance</p>
                        <p class="tile-sub">Home + property.</p>
                    </span>
                    <span class="tile-arrow">→</span>
                </a>

                <a href="@Link("/Quote/Commercial")" class="quote-tile" aria-label="Start Commercial Insurance Quote" data-cta="quote_index_commercial_start">
                    <span class="tile-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 21V7h7v14"/><path d="M11 21V3h9v18"/><path d="M7 11h1"/><path d="M7 15h1"/><path d="M15 7h1"/><path d="M15 11h1"/><path d="M15 15h1"/></svg></span>
                    <span>
                        <p class="tile-title">Commercial Insurance</p>
                        <p class="tile-sub">Business + income.</p>
                    </span>
                    <span class="tile-arrow">→</span>
                </a>

                <div class="quote-tile life-tile" tabindex="0" role="button" aria-haspopup="dialog" aria-expanded="false" data-cta="quote_index_life_start">
                    <span class="tile-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v5c0 5-3.2 8.5-7 10-3.8-1.5-7-5-7-10V6l7-3z"/><path d="M12 8v7"/><path d="M9.5 11.5h5"/></svg></span>
                    <span>
                        <p class="tile-title">Life Insurance</p>
                        <p class="tile-sub">Family + legacy.</p>
                    </span>
                    <span class="tile-arrow">▾</span>
                </div>

                <a href="@Link("/Quote/Disability")" class="quote-tile" aria-label="Start Disability Insurance Quote" data-cta="quote_index_disability_start">
                    <span class="tile-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 7a3 3 0 1 0 6 0 3 3 0 0 0-6 0z"/><path d="M5 21a7 7 0 0 1 14 0"/><path d="M12 10v5"/></svg></span>
                    <span>
                        <p class="tile-title">Disability Insurance</p>
                        <p class="tile-sub">Income protection.</p>
                    </span>
                    <span class="tile-arrow">→</span>
                </a>

                <a href="@Link("/Quote/Health")" class="quote-tile" aria-label="Start Health Insurance Quote" data-cta="quote_index_health_start">
                    <span class="tile-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 8c0 6-8 11-8 11S4 14 4 8a4 4 0 0 1 7-2.6A4 4 0 0 1 20 8z"/><path d="M8 12h3l1.2-2.5L14 14l1-2h2"/></svg></span>
                    <span>
                        <p class="tile-title">Health Insurance</p>
                        <p class="tile-sub">Health coverage.</p>
                    </span>
                    <span class="tile-arrow">→</span>
                </a>
            </div>
        </div>

        <div class="process-strip" aria-label="What happens next">
            <div class="process-step">
                <span class="process-num">1</span>
                <span class="process-svg"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 4h9l3 3v13H6z"/><path d="M15 4v4h4"/><path d="M9 13h6"/><path d="M9 17h4"/></svg></span>
                <h5>Start</h5>
                <p>Choose your lane.</p>
            </div>
            <div class="process-step">
                <span class="process-num">2</span>
                <span class="process-svg"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 6h13"/><path d="M8 12h13"/><path d="M8 18h13"/><circle cx="4" cy="6" r="1.5"/><circle cx="4" cy="12" r="1.5"/><circle cx="4" cy="18" r="1.5"/></svg></span>
                <h5>Review</h5>
                <p>Review clear options.</p>
            </div>
            <div class="process-step">
                <span class="process-num">3</span>
                <span class="process-svg"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v5c0 5-3.2 8.5-7 10-3.8-1.5-7-5-7-10V6l7-3z"/><path d="M9 12l2 2 4-5"/></svg></span>
                <h5>Decide</h5>
                <p>Move with clarity.</p>
            </div>
        </div>
    </section>

    <div class="calendar-section reveal" id="calendar">
        <h2>Want to talk first?</h2>
        <p>Book a time and we’ll point you to the right path.</p>

        <div class="calendar-container">
            <iframe src="https://outlook.office.com/book/LEGEND@mylegnd.com/?ismsaljsauthenabled=true"></iframe>
        </div>
    </div>

    <section class="prayer-section">
        <div class="prayer-card reveal">
            <div class="prayer-kicker">A Blessing Over You</div>
            <div class="prayer-divider"></div>

            <p class="prayer-text">
                May God strengthen your spirit, guide your steps, and bless your work and well-being.
                May He surround you with safety, peace, healing, and His everlasting love.
            </p>

            <div class="prayer-divider"></div>
        </div>
    </section>

</div>

@{
    var linkBase = Context?.Request?.PathBase.Value + (slugPrefix ?? string.Empty);
    await Html.RenderPartialAsync("_LifeModal", linkBase);
}

<script>
document.addEventListener("DOMContentLoaded", function () {
    const els = document.querySelectorAll(".reveal");
    if ("IntersectionObserver" in window) {
        const io = new IntersectionObserver((entries) => {
            entries.forEach(e => {
                if (e.isIntersecting) e.target.classList.add("show");
            });
        }, { threshold: 0.12 });
        els.forEach(el => io.observe(el));
    } else {
        els.forEach(el => el.classList.add("show"));
    }

    const lifeTile = document.querySelector(".life-tile");
    const lifeModal = document.getElementById("lifeModal");
    const lifeClose = lifeModal ? lifeModal.querySelector(".life-modal-close") : null;

    function closeLife() {
        if (!lifeTile || !lifeModal) return;
        lifeModal.classList.remove("open");
        lifeTile.classList.remove("open");
        lifeTile.setAttribute("aria-expanded", "false");
    }

    function openLife() {
        if (!lifeTile || !lifeModal) return;
        lifeModal.classList.add("open");
        lifeTile.classList.add("open");
        lifeTile.setAttribute("aria-expanded", "true");
        lifeModal.focus();
    }

    if (lifeTile && lifeModal) {
        lifeTile.addEventListener("click", (e) => {
            e.preventDefault();
            lifeTile.classList.contains("open") ? closeLife() : openLife();
        });

        lifeTile.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
                e.preventDefault();
                lifeTile.classList.contains("open") ? closeLife() : openLife();
            } else if (e.key === "Escape") {
                closeLife();
            }
        });

        document.addEventListener("click", (e) => {
            if (!lifeTile || !lifeModal) return;
            if (!(e.target instanceof Element)) return;
            if (!lifeTile.contains(e.target) && !lifeModal.contains(e.target)) closeLife();
        });

        window.addEventListener("scroll", closeLife, { passive: true });
        lifeClose?.addEventListener("click", closeLife);
    }
});
</script>
