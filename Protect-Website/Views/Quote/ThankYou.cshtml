@{
    ViewData["Title"] = "Thank You";
    var bookingLink = "https://outlook.office.com/book/LEGEND@mylegnd.com/?ismsaljsauthenabled=true";

    var quoteKey = TempData["QuoteType"]?.ToString()?.Trim() ?? "";

    var quoteDisplayName = quoteKey switch
    {
        "Life"          => "Life Insurance",
        "Disability"    => "Disability Insurance",
        "Health"        => "Health Insurance",
        "Home"          => "Home Insurance",
        "Auto"          => "Auto Insurance",
        "Commercial"    => "Commercial Insurance",
        "RiskAssessment"=> "Risk Assessment",
        _               => "Insurance"
    };

    var detailMessage = quoteKey == "RiskAssessment"
        ? "Your Risk Assessment form has been securely recorded. Our team will review your responses and build a personalized report to help you understand your risk profile, protection gaps, and next steps."
        : "We're reviewing what you shared and will walk you through the options that fit your situation.";
}

<style>
/* ── Dark navy + gold design system (matches quote wizard) ───────────────── */
body {
    background: radial-gradient(120% 140% at 50% 0%, #12203c 0%, #0b1529 40%, #0a1121 100%);
    color: #f8fafc;
}
main.layout-content,
.thankyou-container { background: transparent !important; }

/* ── Layout ──────────────────────────────────────────────────────────────── */
.thankyou-container {
    min-height: 100vh;
    padding: 48px 16px 64px;
}

.thankyou-card {
    max-width: 660px;
    margin: 0 auto;
    background:
        radial-gradient(ellipse 90% 38% at 50% 0%, rgba(199,153,49,0.07) 0%, transparent 68%),
        linear-gradient(180deg, #0f1d35 0%, #0c1830 100%);
    border: 1.5px solid rgba(199,153,49,0.50);
    border-radius: 18px;
    padding: 40px 36px 44px;
    box-shadow:
        0 32px 60px rgba(0,0,0,0.44),
        inset 0 1px 0 rgba(199,153,49,0.10);
    animation: tyFadeIn 0.45s ease-out;
}

/* ── Header ──────────────────────────────────────────────────────────────── */
.ty-checkmark {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(199,153,49,0.14);
    border: 2px solid rgba(199,153,49,0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 18px;
    font-size: 1.5rem;
}

.ty-headline {
    font-size: 1.65rem;
    font-weight: 900;
    color: #c79931;
    line-height: 1.22;
    margin-bottom: 12px;
    letter-spacing: .2px;
}

.ty-subtext {
    color: rgba(248,250,252,0.80);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.6;
}

/* ── Info box ─────────────────────────────────────────────────────────────── */
.ty-next-box {
    background: rgba(199,153,49,0.07);
    border: 1.4px solid rgba(199,153,49,0.38);
    border-radius: 12px;
    padding: 18px 20px 16px;
}

.ty-next-heading {
    font-size: .85rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: #f3d78f;
    margin-bottom: 12px;
}

.ty-next-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 9px;
    text-align: left;
}

.ty-next-list li {
    font-size: .93rem;
    font-weight: 700;
    color: rgba(248,250,252,0.82);
    padding-left: 1.3em;
    position: relative;
    line-height: 1.45;
}

.ty-next-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #c79931;
    font-weight: 900;
}

/* ── Faster note ─────────────────────────────────────────────────────────── */
.ty-faster-note {
    color: rgba(248,250,252,0.60);
    font-size: .88rem;
    font-weight: 700;
    text-align: center;
    line-height: 1.5;
}

/* ── Verse ───────────────────────────────────────────────────────────────── */
.verse {
    font-style: italic;
    color: rgba(248,250,252,0.60);
    font-size: .97rem;
    line-height: 1.7;
    border-left: 3px solid rgba(199,153,49,0.38);
    padding-left: 16px;
    margin: 0;
    text-align: left;
}
.bible-ref {
    display: block;
    margin-top: 8px;
    font-size: .85rem;
    color: rgba(248,250,252,0.38);
    font-style: normal;
    letter-spacing: .02em;
}

/* ── Divider ─────────────────────────────────────────────────────────────── */
.ty-divider {
    border: none;
    border-top: 1px solid rgba(199,153,49,0.18);
    margin: 28px 0;
}

/* ── Buttons ─────────────────────────────────────────────────────────────── */
.btn-gold {
    background: linear-gradient(175deg, #efc86f, #c08b21);
    color: #1c1303;
    font-weight: 900;
    padding: 13px 28px;
    border-radius: 12px;
    font-size: .98rem;
    border: 2px solid #f1cf80;
    box-shadow: 0 12px 28px rgba(0,0,0,0.26), 0 0 0 2px rgba(241,207,128,0.22);
    transition: opacity 0.15s, transform 0.12s, box-shadow 0.15s ease;
    text-transform: uppercase;
    letter-spacing: .35px;
    text-decoration: none;
    display: block;
    text-align: center;
    cursor: pointer;
}
.btn-gold:hover {
    opacity: .97;
    color: #1c1303;
    transform: translateY(-1px);
    box-shadow: 0 16px 36px rgba(0,0,0,.30), 0 0 0 2px rgba(241,207,128,0.30);
}
.btn-ghost-gold {
    border: 1.5px solid rgba(199,153,49,0.48);
    background: transparent;
    color: #f8fafc;
    padding: 12px 28px;
    font-weight: 800;
    border-radius: 12px;
    font-size: .98rem;
    text-decoration: none;
    transition: border-color 0.12s ease, color 0.12s ease, transform 0.12s ease;
    display: block;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: .35px;
}
.btn-ghost-gold:hover {
    border-color: #c79931;
    color: #dfb75a;
    transform: translateY(-1px);
}

/* ── Footer ──────────────────────────────────────────────────────────────── */
.ty-footer-text {
    color: rgba(248,250,252,0.36);
    font-size: .8rem;
}

/* ── Animation ───────────────────────────────────────────────────────────── */
@@keyframes tyFadeIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ── Responsive ──────────────────────────────────────────────────────────── */
@@media (max-width: 640px) {
    .thankyou-card    { padding: 28px 18px 32px; border-radius: 14px; }
    .ty-headline      { font-size: 1.38rem; }
    .ty-subtext       { font-size: .94rem; }
    .ty-next-box      { padding: 14px 14px 12px; }
    .ty-next-list li  { font-size: .88rem; }
    .verse            { font-size: .9rem; }
    .btn-gold,
    .btn-ghost-gold   { padding: 12px 20px; }
}
@@media (max-width: 480px) {
    .thankyou-container { padding: 28px 12px 48px; }
    .thankyou-card  { padding: 22px 14px 26px; }
    .ty-headline    { font-size: 1.2rem; }
    .ty-checkmark   { width: 44px; height: 44px; font-size: 1.25rem; margin-bottom: 14px; }
}
</style>

<div class="thankyou-container">
    <div class="thankyou-card">

        @* Checkmark icon *@
        <div class="ty-checkmark" aria-hidden="true">✓</div>

        @* Headline *@
        <div class="text-center mb-3">
            <h1 class="ty-headline">You're all set — we'll take it from here</h1>
        </div>

        @* Subtext *@
        <p class="ty-subtext text-center mb-4">@detailMessage</p>

        @* What happens next box *@
        <div class="ty-next-box mb-3">
            <div class="ty-next-heading text-center">What happens next</div>
            <ul class="ty-next-list">
                <li>We’ll reach out to walk you through your options</li>
                <li>We'll keep it simple and focused on what fits you</li>
                <li>We’ll walk through what fits and answer any questions you have</li>
            </ul>
        </div>

        @* Move faster note *@
        <p class="ty-faster-note mb-5">Want to move faster? Book a time that works best for you.</p>

        @* Bible verse — do not remove *@
        <blockquote class="verse mb-5">
            "Trust in the Lord with all your heart and lean not on your own understanding;
            in all your ways submit to Him, and He will make your paths straight."
            <span class="bible-ref">Proverbs 3:5–6 (NIV)</span>
        </blockquote>

        @* Buttons *@
        <div class="mb-4" style="display:grid;gap:12px;">
            <a href="@bookingLink"
               target="_blank"
               rel="noopener noreferrer"
               class="btn-gold">
                Schedule Your Call
            </a>

            @if (quoteKey != "RiskAssessment")
            {
                <a href="@Url.Action("Index", "Quote")"
                   class="btn-gold">
                    Submit Another Request
                </a>
            }

            <a href="/" class="btn-ghost-gold">
                Return Home
            </a>
        </div>

        <hr class="ty-divider" />

        <div class="text-center">
            <p class="ty-footer-text mb-1">Legend Legacy Protection &copy; @DateTime.Now.Year</p>
            <p class="ty-footer-text mb-0">Your privacy matters. All information is handled with care and confidentiality.</p>
        </div>

    </div>
</div>
