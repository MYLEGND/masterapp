@model Protect_Website.Models.QuoteThankYouViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Thank You";

    var quoteKey = Model?.QuoteKey?.Trim() ?? "";
    var metaLeadEventId = TempData.Peek("MetaLeadEventId")?.ToString()?.Trim() ?? "";
    var metaLeadLeadId = TempData.Peek("MetaLeadLeadId")?.ToString()?.Trim() ?? "";
    var metaLeadContentName = quoteKey switch
    {
        "Auto" => "quote_auto",
        "Home" => "quote_home",
        "Health" => "quote_health",
        "Disability" => "quote_disability",
        "Commercial" => "quote_commercial",
        "Life" or "Life Insurance" => "quote_life",
        "Term Life" => "quote_term_life",
        "Whole Life" => "quote_whole_life",
        "Final Expense" => "quote_final_expense",
        "Mortgage Protection" => "quote_mortgage_protection",
        "Indexed Universal Life" => "quote_iul",
        _ => string.Empty
    };
    var metaLeadContentCategory = quoteKey.ToLowerInvariant() switch
    {
        "auto" => "auto",
        "home" => "home",
        "health" => "health",
        "disability" => "disability",
        "commercial" => "commercial",
        "life" or "life insurance" => "life",
        "term life" => "term",
        "whole life" => "wholelife",
        "final expense" => "finalexpense",
        "mortgage protection" => "mortgage",
        "indexed universal life" => "iul",
        _ => string.Empty
    };
    var shouldTrackMetaLead =
        !string.IsNullOrWhiteSpace(metaLeadEventId) &&
        !string.IsNullOrWhiteSpace(metaLeadLeadId) &&
        !string.IsNullOrWhiteSpace(metaLeadContentName) &&
        !string.IsNullOrWhiteSpace(metaLeadContentCategory);

    var quoteDisplayName = quoteKey switch
    {
        "Life" or "Life Insurance" => "Life Insurance",
        "Term Life" => "Term Life Insurance",
        "Whole Life" => "Whole Life Insurance",
        "Final Expense" => "Final Expense Coverage",
        "Mortgage Protection" => "Mortgage Protection",
        "Indexed Universal Life" => "Indexed Universal Life",
        "Disability" => "Disability Insurance",
        "Health" => "Health Insurance",
        "Home" => "Home Insurance",
        "Auto" => "Auto Insurance",
        "Commercial" => "Commercial Insurance",
        "RiskAssessment" => "Risk Assessment",
        _ => string.IsNullOrWhiteSpace(quoteKey) ? "Insurance" : quoteKey
    };

    var agentTrustProfile = Model?.AgentTrustProfile;
    var showAgentTrustCard = agentTrustProfile != null;
    var agentDisplayName = !string.IsNullOrWhiteSpace(agentTrustProfile?.DisplayName)
        ? agentTrustProfile!.DisplayName!.Trim()
        : "Your licensed agent";
    var agentFirstName = !string.IsNullOrWhiteSpace(agentTrustProfile?.FirstName)
        ? agentTrustProfile!.FirstName!.Trim()
        : agentDisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "there";
    var hasCustomAgentBio = !string.IsNullOrWhiteSpace(agentTrustProfile?.ShortBio);
    var agentBio = hasCustomAgentBio
        ? agentTrustProfile!.ShortBio!.Trim()
        : string.Empty;
    var normalizedAgentBio = string.IsNullOrWhiteSpace(agentBio)
        ? string.Empty
        : agentBio.Replace('’', '\'').Trim().ToLowerInvariant();
    var shouldShowAgentBio =
        hasCustomAgentBio &&
        normalizedAgentBio != "i'll personally help you understand what options may fit your situation and answer any questions you have." &&
        normalizedAgentBio != "i will personally help you understand what options may fit your situation and answer any questions you have.";
    var agentNpn = !string.IsNullOrWhiteSpace(agentTrustProfile?.Npn)
        ? agentTrustProfile!.Npn!.Trim()
        : null;
    var bookingLink = !string.IsNullOrWhiteSpace(agentTrustProfile?.SchedulingLink)
        ? agentTrustProfile!.SchedulingLink!.Trim()
        : (Model?.BookingLink ?? string.Empty).Trim();
    var agentCardHeading = $"{agentDisplayName} is your point of contact.";
    var agentCardHelper = $"If you book below, you'll be meeting directly with {agentFirstName}.";
    var headlineText = showAgentTrustCard
        ? "Thanks — I've received your request."
        : "Thanks — we've received your request.";
    var detailMessage = quoteKey == "RiskAssessment"
        ? (showAgentTrustCard
            ? "You'll hear from me soon with the clearest next step and what to focus on first."
            : "You'll hear from us soon with clear next steps based on what you shared.")
        : (showAgentTrustCard
            ? "You'll hear from me soon with the clearest next step for your situation."
            : "You'll hear from us soon with the clearest next step for your situation.");
    var nextSteps = showAgentTrustCard
        ? new[]
        {
            $"I'll review the details you shared about your {quoteDisplayName} request",
            "We’ll review what may fit your situation and answer any questions you have."
        }
        : new[]
        {
            $"A licensed team member will review the details you shared about your {quoteDisplayName} request",
            "We’ll review what may fit your situation and answer any questions you have."
        };
    var fasterNote = showAgentTrustCard
        ? $"If you'd rather choose a time now, you can book directly with {agentFirstName} below."
        : "If you'd rather choose a time now, you can book below.";
    var primaryCtaText = showAgentTrustCard
        ? $"Book Your Review With {agentFirstName}"
        : "Schedule Your Call";
}

<style>
body {
    background: radial-gradient(120% 140% at 50% 0%, #12203c 0%, #0b1529 40%, #0a1121 100%);
    color: #f8fafc;
}
main.layout-content,
.thankyou-container { background: transparent !important; }

.thankyou-container {
    min-height: 100vh;
    padding: 48px 16px 64px;
}

.thankyou-card {
    max-width: 720px;
    margin: 0 auto;
    background:
        radial-gradient(ellipse 90% 38% at 50% 0%, rgba(199,153,49,0.07) 0%, transparent 68%),
        linear-gradient(180deg, #0f1d35 0%, #0c1830 100%);
    border: 1.5px solid rgba(199,153,49,0.50);
    border-radius: 18px;
    padding: 40px 36px 44px;
    box-shadow:
        0 32px 60px rgba(0,0,0,0.44),
        inset 0 1px 0 rgba(199,153,49,0.10);
    animation: tyFadeIn 0.45s ease-out;
}

.ty-checkmark {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(199,153,49,0.14);
    border: 2px solid rgba(199,153,49,0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 18px;
    font-size: 1.5rem;
}

.ty-headline {
    font-size: 1.65rem;
    font-weight: 900;
    color: #c79931;
    line-height: 1.22;
    margin-bottom: 12px;
    letter-spacing: .2px;
}

.ty-subtext {
    color: rgba(248,250,252,0.80);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.6;
}

.ty-agent-card {
    display: grid;
    gap: 12px;
    margin-bottom: 20px;
    padding: 16px;
    border-radius: 14px;
    border: 1.4px solid rgba(199,153,49,0.38);
    background:
        radial-gradient(circle at top right, rgba(199,153,49,0.16), transparent 38%),
        rgba(11,22,39,0.92);
    box-shadow:
        0 16px 28px rgba(0,0,0,0.24),
        inset 0 1px 0 rgba(255,255,255,0.06);
}

.ty-agent-head {
    display: flex;
    align-items: center;
    gap: 12px;
}

.ty-agent-identity {
    display: grid;
    justify-items: center;
    align-content: start;
    gap: 8px;
    flex-shrink: 0;
    min-width: 92px;
    text-align: center;
}

.ty-agent-avatar {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    border: 2px solid rgba(239,200,111,0.92);
    background: linear-gradient(180deg, #13233f 0%, #0b1529 100%);
    box-shadow: 0 12px 24px rgba(0,0,0,0.28);
}

.ty-agent-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.ty-agent-avatar-fallback {
    color: #f3d78f;
    font-size: 1.2rem;
    font-weight: 900;
    letter-spacing: .02em;
}

.ty-agent-name {
    color: #f3d78f;
    font-size: 1.08rem;
    font-weight: 900;
    margin-bottom: 3px;
}

.ty-agent-kicker {
    color: rgba(248,250,252,0.56);
    font-size: .74rem;
    font-weight: 850;
    letter-spacing: .08em;
    text-transform: uppercase;
    margin-bottom: 4px;
}

.ty-agent-display-name {
    color: rgba(248,250,252,0.8);
    font-size: .8rem;
    font-weight: 800;
    line-height: 1.2;
}

.ty-agent-bio {
    color: rgba(248,250,252,0.82);
    font-size: .9rem;
    line-height: 1.45;
}

.ty-agent-note {
    color: rgba(248,250,252,0.72);
    font-size: .84rem;
    font-weight: 760;
    line-height: 1.45;
    margin-top: 4px;
}

.ty-agent-license {
    color: rgba(248,250,252,0.56);
    font-size: .74rem;
    font-weight: 700;
    line-height: 1.35;
    margin-top: 8px;
}

.ty-next-box {
    background: rgba(199,153,49,0.07);
    border: 1.4px solid rgba(199,153,49,0.38);
    border-radius: 12px;
    padding: 18px 20px 16px;
}

.ty-next-heading {
    font-size: .85rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: #f3d78f;
    margin-bottom: 12px;
}

.ty-next-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 9px;
    text-align: left;
}

.ty-next-list li {
    font-size: .93rem;
    font-weight: 700;
    color: rgba(248,250,252,0.82);
    padding-left: 1.3em;
    position: relative;
    line-height: 1.45;
}

.ty-next-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #c79931;
    font-weight: 900;
}

.ty-faster-note {
    color: rgba(248,250,252,0.60);
    font-size: .88rem;
    font-weight: 700;
    text-align: center;
    line-height: 1.5;
}

.verse {
    font-style: italic;
    color: rgba(248,250,252,0.60);
    font-size: .97rem;
    line-height: 1.7;
    border-left: 3px solid rgba(199,153,49,0.38);
    padding-left: 16px;
    margin: 0;
    text-align: left;
}

.bible-ref {
    display: block;
    margin-top: 8px;
    font-size: .85rem;
    color: rgba(248,250,252,0.38);
    font-style: normal;
    letter-spacing: .02em;
}

.ty-divider {
    border: none;
    border-top: 1px solid rgba(199,153,49,0.18);
    margin: 28px 0;
}

.btn-gold {
    display: block;
    text-align: center;
    background: linear-gradient(180deg, #f3d688 0%, #e2ba5d 38%, #c69025 100%);
    color: #211503;
    font-weight: 920;
    padding: 14px 22px;
    border-radius: 14px;
    font-size: 1rem;
    line-height: 1.14;
    border: 1px solid #f1cf80;
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.34),
        0 14px 28px rgba(0,0,0,0.28),
        0 0 0 1px rgba(241,207,128,0.20);
    transition: transform .18s cubic-bezier(0.22, 1, 0.36, 1), box-shadow .18s ease, filter .18s ease, background .18s ease;
    text-transform: none;
    letter-spacing: .01em;
    text-decoration: none;
    cursor: pointer;
    min-height: 56px;
    text-shadow: 0 1px 0 rgba(255,255,255,0.24);
    text-wrap: balance;
    white-space: normal;
    overflow-wrap: anywhere;
}

.btn-gold:hover {
    color: #211503;
    transform: translateY(-2px) scale(1.006);
    box-shadow:
        inset 0 1px 0 rgba(255,255,255,0.40),
        0 18px 34px rgba(0,0,0,.32),
        0 0 0 1px rgba(241,207,128,0.28),
        0 0 22px rgba(226,186,93,0.18);
    filter: saturate(1.03) brightness(1.01);
}

.btn-ghost-gold {
    border: 1.5px solid rgba(199,153,49,0.48);
    background: transparent;
    color: #f8fafc;
    padding: 12px 28px;
    font-weight: 850;
    border-radius: 12px;
    font-size: .98rem;
    text-decoration: none;
    transition: border-color 0.12s ease, color 0.12s ease, transform 0.12s ease, box-shadow 0.12s ease;
    display: block;
    text-align: center;
    text-transform: none;
    letter-spacing: .01em;
}

.btn-ghost-gold:hover {
    border-color: #c79931;
    color: #dfb75a;
    transform: translateY(-1px);
    box-shadow: 0 8px 18px rgba(0,0,0,0.18);
}

.ty-footer-text {
    color: rgba(248,250,252,0.36);
    font-size: .8rem;
}

@@keyframes tyFadeIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
}

@@media (max-width: 640px) {
    .thankyou-card { padding: 28px 18px 32px; border-radius: 14px; }
    .ty-headline { font-size: 1.38rem; }
    .ty-subtext { font-size: .94rem; }
    .ty-agent-card { gap: 10px; padding: 13px; margin-bottom: 16px; }
    .ty-agent-identity { min-width: 84px; gap: 7px; }
    .ty-agent-avatar { width: 60px; height: 60px; }
    .ty-agent-name { font-size: 1rem; }
    .ty-agent-kicker { font-size: .7rem; }
    .ty-agent-display-name { font-size: .75rem; }
    .ty-agent-bio { font-size: .86rem; }
    .ty-agent-note { font-size: .8rem; }
    .ty-agent-license { font-size: .7rem; margin-top: 7px; }
    .ty-next-box { padding: 14px 14px 12px; }
    .ty-next-list li { font-size: .88rem; }
    .verse { font-size: .9rem; }
    .btn-gold, .btn-ghost-gold { padding: 12px 20px; }
}

@@media (max-width: 480px) {
    .thankyou-container { padding: 28px 12px 48px; }
    .thankyou-card { padding: 22px 14px 26px; }
    .ty-checkmark { width: 44px; height: 44px; font-size: 1.25rem; margin-bottom: 14px; }
    .ty-headline { font-size: 1.2rem; }
    .ty-agent-head { align-items: flex-start; }
    .ty-agent-identity { min-width: 76px; gap: 6px; }
    .ty-agent-avatar { width: 56px; height: 56px; }
    .ty-agent-name { font-size: .96rem; }
    .ty-agent-kicker { font-size: .68rem; }
    .ty-agent-display-name { font-size: .72rem; }
    .ty-agent-bio { font-size: .82rem; }
    .ty-agent-note { font-size: .77rem; }
    .ty-agent-license { font-size: .68rem; margin-top: 6px; }
    .btn-gold { padding: 12px 15px; font-size: .93rem; min-height: 54px; border-radius: 13px; }
}
</style>

<div class="thankyou-container">
    <div class="thankyou-card">

        <div class="ty-checkmark" aria-hidden="true">✓</div>

        <div class="text-center mb-3">
            <h1 class="ty-headline">@headlineText</h1>
        </div>

        <p class="ty-subtext text-center @(showAgentTrustCard ? "mb-3" : "mb-4")">@detailMessage</p>

        @if (showAgentTrustCard)
        {
            <div class="ty-agent-card">
                <div class="ty-agent-head">
                    <div class="ty-agent-identity">
                        <div class="ty-agent-avatar" aria-hidden="true">
                            @if (!string.IsNullOrWhiteSpace(agentTrustProfile?.ProfileImageUrl))
                            {
                                <img src="@agentTrustProfile.ProfileImageUrl" alt="@agentDisplayName" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.hidden=false;" />
                            }
                            <span class="ty-agent-avatar-fallback" @(!string.IsNullOrWhiteSpace(agentTrustProfile?.ProfileImageUrl) ? "hidden" : null)>@agentFirstName.Substring(0, 1).ToUpperInvariant()</span>
                        </div>
                        <div class="ty-agent-display-name">@agentDisplayName</div>
                    </div>
                    <div>
                        <div class="ty-agent-kicker">Your licensed agent</div>
                        <div class="ty-agent-name">@agentCardHeading</div>
                        <div class="ty-agent-note">@agentCardHelper</div>
                        @if (shouldShowAgentBio)
                        {
                            <div class="ty-agent-bio">@agentBio</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(agentNpn))
                        {
                            <div class="ty-agent-license">Licensed Insurance Professional • License #: @agentNpn</div>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="ty-next-box mb-3">
            <div class="ty-next-heading text-center">What happens next</div>
            <ul class="ty-next-list">
                @foreach (var step in nextSteps)
                {
                    <li>@step</li>
                }
            </ul>
        </div>

        <p class="ty-faster-note mb-5">@fasterNote</p>

        <blockquote class="verse mb-5">
            "Trust in the Lord with all your heart and lean not on your own understanding;
            in all your ways submit to Him, and He will make your paths straight."
            <span class="bible-ref">Proverbs 3:5–6 (NIV)</span>
        </blockquote>

        <div class="mb-4" style="display:grid;gap:12px;">
            @if (!string.IsNullOrWhiteSpace(bookingLink))
            {
                <a href="@bookingLink"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="btn-gold">
                    @primaryCtaText
                </a>
            }

            @if (quoteKey != "RiskAssessment")
            {
                <a href="@Url.Action("Index", "Quote")"
                   class="btn-gold">
                    Submit Another Request
                </a>
            }

            <a href="/" class="btn-ghost-gold">
                Return Home
            </a>
        </div>

        <hr class="ty-divider" />

        <div class="text-center">
            <p class="ty-footer-text mb-1">Legend Legacy Protection &copy; @DateTime.Now.Year</p>
            <p class="ty-footer-text mb-0">Your privacy matters. All information is handled with care and confidentiality.</p>
        </div>

    </div>
</div>

@if (shouldTrackMetaLead)
{
    <script>
    (() => {
        const browserAckUrl = '/ThankYou/meta-browser-ack';
        const leadId = @Html.Raw(JsonSerializer.Serialize(metaLeadLeadId));
        const eventId = @Html.Raw(JsonSerializer.Serialize(metaLeadEventId));
        const contentName = @Html.Raw(JsonSerializer.Serialize(metaLeadContentName));
        const contentCategory = @Html.Raw(JsonSerializer.Serialize(metaLeadContentCategory));
        const firedKey = `meta_lead_success_${eventId}`;

        function notifyBrowserPixelStatus(status, note = '') {
            if (!leadId || !eventId) {
                return;
            }

            const payload = JSON.stringify({
                leadId,
                eventId,
                status,
                ...(note ? { note } : {})
            });

            try {
                if (navigator.sendBeacon) {
                    const blob = new Blob([payload], { type: 'application/json' });
                    if (navigator.sendBeacon(browserAckUrl, blob)) {
                        return;
                    }
                }
            } catch {
                // Fall through to fetch keepalive below.
            }

            try {
                fetch(browserAckUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: payload,
                    keepalive: true
                }).catch(() => {});
            } catch {
                // Never interrupt the thank-you experience if Meta tracking fails.
            }
        }

        try {
            if (window.sessionStorage?.getItem(firedKey)) {
                notifyBrowserPixelStatus('sent', 'session_storage_dedup');
                return;
            }

            if (typeof window.fbq !== 'function') {
                notifyBrowserPixelStatus('unavailable', 'fbq_unavailable');
                return;
            }

            window.fbq('track', 'Lead', {
                content_name: contentName,
                content_category: contentCategory
            }, {
                eventID: eventId
            });

            window.sessionStorage?.setItem(firedKey, '1');
            notifyBrowserPixelStatus('sent');
        } catch {
            notifyBrowserPixelStatus('error', 'fbq_exception');
            // Never interrupt the thank-you experience if Meta tracking fails.
        }
    })();
    </script>
}
