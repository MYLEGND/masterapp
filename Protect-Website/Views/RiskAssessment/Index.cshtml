@model Protect_Website.Models.RiskAssessmentModel
@{
    ViewData["Title"] = "Risk Assessment";
    ViewData["PageKey"] = "risk_assessment";
    var startStep = Model?.CurrentStep > 0 ? Model.CurrentStep : 1;
    var hasServerErrors = !ViewData.ModelState.IsValid;
    var showAssessmentStartedByDefault = hasServerErrors || startStep > 1;
    IReadOnlyList<string> heroProofChips = new[] { "Clear insights", "Identify gaps", "Explore options" };
    var heroStepIntroTitle = "Start with your protection snapshot";
    var heroStepIntroHelper = "Answer a few questions about income, assets, estate planning, and current coverage so you can see where protection is strong, where gaps may exist, and where a review could help.";
    var primaryStartCtaText = "Build My Protection Snapshot";
    var primaryStartCtaNote = "Takes about 2 minutes. No obligation. See where your protection may be strong, thin, or missing.";
    var formHeadingTitle = "Build your protection review";
    var formHeadingCopy = "Share your household, income, estate, and coverage details so we can help you spot strengths, pressure points, and next-step opportunities.";
}

<partial name="_PropertyCasualtyQuoteStyles" />

<style>
    .ra-shell .stepper {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: center;
        margin: 0 0 18px;
    }

    .ra-shell .step-pill {
        border: 1.35px solid var(--pcq-border-strong);
        border-radius: 999px;
        padding: 10px 14px;
        font-weight: 900;
        font-size: 0.92rem;
        color: rgba(247, 236, 208, 0.76);
        background: var(--pcq-pill-bg);
        cursor: pointer;
        transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
        user-select: none;
        box-shadow:
            0 10px 24px rgba(0, 0, 0, 0.14),
            inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .ra-shell .step-pill:hover {
        transform: translateY(-1px);
        border-color: rgba(255, 244, 211, 0.75);
        box-shadow:
            0 14px 30px rgba(0, 0, 0, 0.18),
            inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .ra-shell .step-pill.active {
        border-color: rgba(255, 244, 211, 0.85);
        color: var(--pcq-ink-contrast);
        background: linear-gradient(180deg, #f7da7a 0%, #deb04a 100%);
        box-shadow:
            0 14px 30px rgba(0, 0, 0, 0.22),
            inset 0 1px 0 rgba(255, 255, 255, 0.34);
    }

    .ra-shell .step-pill.done {
        opacity: 0.9;
    }

    .ra-shell .section-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        position: relative;
        z-index: 1;
    }

    .ra-shell .ra-step-count {
        font-size: 0.95rem;
        color: var(--pcq-text-strong) !important;
        font-weight: 900;
        letter-spacing: 0.01em;
    }

    .ra-shell .nav-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-top: 10px;
        position: relative;
        z-index: 1;
    }

    .ra-shell .nav-row .spacer {
        flex: 1 1 auto;
    }

    .ra-shell .step-wrap {
        display: none;
    }

    .ra-shell .step-wrap.active {
        display: block;
    }

    .ra-shell .input-group {
        position: relative;
    }

    .ra-shell .currency-input {
        padding-right: 36px !important;
    }

    .ra-shell .currency-symbol {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #6d4a05;
        font-weight: 900;
        pointer-events: none;
        opacity: 0.9;
    }

    .ra-shell .mini-hint {
        font-size: 0.9rem;
        color: var(--pcq-text-muted);
        margin-top: -6px;
        margin-bottom: 12px;
        font-weight: 650;
    }

    .ra-shell .ra-subsection-card {
        margin-bottom: 18px;
    }

    .ra-shell .ra-subsection-card:last-child {
        margin-bottom: 0;
    }

    .ra-shell .form-check {
        margin-bottom: 0;
    }

    .ra-shell .form-check-label {
        margin-bottom: 0;
    }

    .ra-shell hr {
        margin: 1.4rem 0;
    }

    @@media (max-width: 575.98px) {
        .ra-shell .step-pill {
            font-size: 0.86rem;
        }

        .ra-shell .nav-row {
            flex-direction: column;
        }

        .ra-shell .nav-row .btn {
            width: 100%;
        }
    }
</style>

<div class="container-narrow">
    <div class="pcq-shell">
        <div class="pcq-surface ra-shell">
            <div class="pcq-hero-entry" id="riskHeroEntryPanel" @((showAssessmentStartedByDefault ? "hidden" : null))>
                <figure class="pcq-hero-banner-wrap">
                    <img class="pcq-hero-banner-image" src="~/images/ads/risk-assessment-top-banner.png" asp-append-version="true" alt="Legend risk assessment banner encouraging clients to understand where their protection stands and plan for where they are going." loading="eager" />
                </figure>

                <div class="pcq-proof-row" aria-label="Risk assessment benefits">
                    <span class="pcq-proof-pill">
                        <svg class="pcq-proof-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M6 18.5h12"></path>
                            <path d="M7.5 15V9.5"></path>
                            <path d="M12 15V6"></path>
                            <path d="M16.5 15v-3"></path>
                            <circle cx="18.4" cy="18.2" r="2.2"></circle>
                            <path d="m20 19.8 2 2"></path>
                        </svg>
                        @heroProofChips[0]
                    </span>
                    <span class="pcq-proof-pill">
                        <svg class="pcq-proof-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <circle cx="12" cy="12" r="8.2"></circle>
                            <circle cx="12" cy="12" r="3.2"></circle>
                            <path d="m14.4 9.6 5-5"></path>
                            <path d="m18.1 4.6 1.3 1.3"></path>
                        </svg>
                        @heroProofChips[1]
                    </span>
                    <span class="pcq-proof-pill">
                        <svg class="pcq-proof-icon" viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M7 17.4c1.45-1.85 3.15-2.95 5.05-3.3 1.45-.25 2.95-.05 4.45.55"></path>
                            <path d="m13.85 10.25 2.35 4.65 4.45-1.9"></path>
                            <circle cx="7.2" cy="17.4" r="1.8"></circle>
                            <circle cx="18.7" cy="13.2" r="1.8"></circle>
                        </svg>
                        @heroProofChips[2]
                    </span>
                </div>

                <div class="pcq-step-copy">
                    <div class="pcq-step-copy-title">@heroStepIntroTitle</div>
                    <p class="pcq-step-copy-helper">@heroStepIntroHelper</p>
                </div>

                <div class="pcq-hero-actions">
                    <button type="button" class="btn btn-gold pcq-primary-start-cta" id="riskHeroStartCta" data-cta="risk_assessment_start" data-primary-cta="hero">@primaryStartCtaText</button>
                    <div class="pcq-start-note"><span>@primaryStartCtaNote</span></div>
                </div>
            </div>

            <div class="pcq-form-shell" id="riskAssessmentFlowShell" @((showAssessmentStartedByDefault ? null : "hidden"))>
                <div class="pcq-form-heading">
                    <h1 class="pcq-form-heading-title">@formHeadingTitle</h1>
                    <p class="pcq-form-heading-copy">@formHeadingCopy</p>
                </div>

                <p class="required-note text-center">
                    <strong>
                        <span class="text-danger">*</span> Fields marked with a red asterisk are required.
                    </strong>
                </p>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger fw-bold">
                        @Html.ValidationSummary(excludePropertyErrors: false)
                    </div>
                }

<form asp-controller="RiskAssessment" asp-action="SubmitRiskAssessment" method="post" class="pcq-form-frame" id="riskAssessmentForm" data-form-key="risk_assessment_form">
    @Html.AntiForgeryToken()

    <!-- keep step on postback -->
    <input asp-for="CurrentStep" type="hidden" id="CurrentStep" />

    <div class="stepper" id="stepper">
        <div class="step-pill" data-step="1">1) Personal</div>
        <div class="step-pill" data-step="2">2) Income</div>
        <div class="step-pill" data-step="3">3) Cash Flow</div>
        <div class="step-pill" data-step="4">4) Estate</div>
        <div class="step-pill" data-step="5">5) Coverage</div>
        <div class="step-pill" data-step="6">6) Review</div>
    </div>

    <!-- ===================== STEP 1 ===================== -->
    <div class="step-wrap" data-step="1">
        <div class="section-card">
            <div class="section-title">
                <span>Personal Information</span>
                <span class="ra-step-count">Step 1 of 6</span>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>First Name<span class="text-danger">*</span></label>
                    <input asp-for="FirstName" class="form-control" required />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Last Name<span class="text-danger">*</span></label>
                    <input asp-for="LastName" class="form-control" required />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label>Email<span class="text-danger">*</span></label>
                    <input asp-for="Email" class="form-control" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>Phone Number</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label>Age</label>
                    <input asp-for="Age" type="number" class="form-control" id="age-input" />
                </div>
                <div class="col-md-4">
                    <label>Marital Status</label>
                    <select asp-for="MaritalStatus" class="form-select">
                        <option value="">--Select--</option>
                        <option>Single</option>
                        <option>Married</option>
                        <option>Domestic Partner</option>
                        <option>Widowed</option>
                        <option>Separated</option>
                        <option>Divorced</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>Household Size</label>
                    <input asp-for="HouseholdSize" type="number" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label>State</label>
                    <select asp-for="State" class="form-control">
                        <option value="">--Select a state--</option>
                        <option>AZ</option>
                        <option>CA</option>
                        <option>IA</option>
                        <option>KS</option>
                        <option>LA</option>
                        <option>MD</option>
                        <option>MS</option>
                        <option>OH</option>
                        <option>SC</option>
                        <option>SD</option>
                        <option>TX</option>
                        <option>WA</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label>Occupation</label>
                    <input asp-for="Occupation" class="form-control" />
                </div>
            </div>

            <div class="nav-row">
                <div class="spacer"></div>
                <button type="button" class="btn btn-gold" id="next-1">Next →</button>
            </div>
        </div>
    </div>

    <!-- ===================== STEP 2 ===================== -->
    <div class="step-wrap" data-step="2">
        <div class="section-card">
            <div class="section-title">
                <span>Income & Work</span>
                <span class="ra-step-count">Step 2 of 6</span>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>Annual Income</label>
                    <input asp-for="AnnualIncome" type="number" class="form-control" id="income-input"/>
                </div>
                <div class="col-md-4">
                    <label>Retirement Age Target</label>
                    <input asp-for="RetirementAgeTarget" type="number" class="form-control" id="retirement-age-input"/>
                </div>
                <div class="col-md-4">
                    <label>Working Years Left</label>
                    <input asp-for="WorkingYearsLeft" type="number" class="form-control" id="working-years-left" readonly />
                    <div class="mini-hint">Auto-calculated from Age and Retirement Age.</div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <label>Self Employed?</label>
                    <select asp-for="SelfEmployed" class="form-select">
                        <option value="">--Select--</option>
                        <option>Yes</option>
                        <option>No</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label>Employer Benefits?</label>
                    <select asp-for="EmployerBenefits" class="form-select">
                        <option value="">--Select--</option>
                        <option>Yes</option>
                        <option>No</option>
                    </select>
                </div>
            </div>

            <div class="nav-row">
                <button type="button" class="btn btn-outline-gold" id="back-2">← Back</button>
                <button type="button" class="btn btn-gold" id="next-2">Next →</button>
            </div>
        </div>
    </div>

    <!-- ===================== STEP 3 ===================== -->
    <div class="step-wrap" data-step="3">
        <div class="section-card">
            <div class="section-title">
                <span>Cash Flow</span>
                <span class="ra-step-count">Step 3 of 6</span>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <label>Monthly Income</label>
                    <div class="input-group">
                        <input asp-for="MonthlyIncome" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Other Income</label>
                    <div class="input-group">
                        <input asp-for="OtherIncome" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Taxes</label>
                    <div class="input-group">
                        <input asp-for="Taxes" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-md-4">
                    <label>Monthly Expenses</label>
                    <div class="input-group">
                        <input asp-for="MonthlyExpenses" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Monthly Debt</label>
                    <div class="input-group">
                        <input asp-for="MonthlyDebt" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Mortgage Payment</label>
                    <div class="input-group">
                        <input asp-for="MortgagePayment" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
            </div>

            <hr />

            <div class="row">
                <div class="col-md-4">
                    <label>Emergency Savings</label>
                    <div class="input-group">
                        <input asp-for="EmergencySavings" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Checking Account</label>
                    <div class="input-group">
                        <input asp-for="CheckingAccount" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Savings Account</label>
                    <div class="input-group">
                        <input asp-for="SavingsAccount" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-md-4">
                    <label>Roth IRA</label>
                    <div class="input-group">
                        <input asp-for="RothIRA" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Traditional IRA</label>
                    <div class="input-group">
                        <input asp-for="TraditionalIRA" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>401k</label>
                    <div class="input-group">
                        <input asp-for="_401k" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-md-4">
                    <label>Brokerage Account</label>
                    <div class="input-group">
                        <input asp-for="BrokerageAccount" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>HSA</label>
                    <div class="input-group">
                        <input asp-for="HSA" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Other Assets</label>
                    <div class="input-group">
                        <input asp-for="OtherPropertyAssets" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
            </div>

            <hr />

            <div class="row">
                <div class="col-md-4">
                    <label>Business Ownership Value</label>
                    <div class="input-group">
                        <input asp-for="BusinessOwnershipValue" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Primary Real Estate</label>
                    <div class="input-group">
                        <input asp-for="RealEstateValue" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Rental Property</label>
                    <div class="input-group">
                        <input asp-for="RentalPropertyValue" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-md-4">
                    <label>Vehicle Value</label>
                    <div class="input-group">
                        <input asp-for="VehicleValue" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Collectibles Value</label>
                    <div class="input-group">
                        <input asp-for="CollectiblesValue" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Mortgage Balance</label>
                    <div class="input-group">
                        <input asp-for="MortgageBalance" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-md-4">
                    <label>Student Loans</label>
                    <div class="input-group">
                        <input asp-for="StudentLoans" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Other Liabilities</label>
                    <div class="input-group">
                        <input asp-for="OtherLiabilities" type="number" class="form-control currency-input" min="0" />
                        <span class="currency-symbol">$</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <label>Net Monthly Cash Flow</label>
                    <div class="input-group">
                        <input asp-for="NetCashFlow" type="number" class="form-control currency-input" readonly />
                        <span class="currency-symbol">$</span>
                    </div>
                    <div class="mini-hint">Auto-calculated from your cash flow inputs.</div>
                </div>
            </div>

            <div class="nav-row">
                <button type="button" class="btn btn-outline-gold" id="back-3">← Back</button>
                <button type="button" class="btn btn-gold" id="next-3">Next →</button>
            </div>
        </div>
    </div>

    <!-- ===================== STEP 4 ===================== -->
    <div class="step-wrap" data-step="4">
        <div class="section-card">
            <div class="section-title">
                <span>Estate Planning</span>
                <span class="ra-step-count">Step 4 of 6</span>
            </div>

            <div class="row">
                <div class="col-md-3">
                    <label>Do you have a Will?</label>
                    <select asp-for="HasWill" class="form-select">
                        <option value="">--Select--</option>
                        <option>Yes</option>
                        <option>No</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label>Trust?</label>
                    <select asp-for="HasTrust" class="form-select">
                        <option value="">--Select--</option>
                        <option>Yes</option>
                        <option>No</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label>Power of Attorney?</label>
                    <select asp-for="HasPOA" class="form-select">
                        <option value="">--Select--</option>
                        <option>Yes</option>
                        <option>No</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label>Health Directive / Living Will?</label>
                    <select asp-for="HasHealthDirective" class="form-select">
                        <option value="">--Select--</option>
                        <option>Yes</option>
                        <option>No</option>
                    </select>
                </div>
            </div>

            <div class="nav-row">
                <button type="button" class="btn btn-outline-gold" id="back-4">← Back</button>
                <button type="button" class="btn btn-gold" id="next-4">Next →</button>
            </div>
        </div>
    </div>

    <!-- ===================== STEP 5 ===================== -->
    <div class="step-wrap" data-step="5">
        <div class="section-card">
            <div class="section-title">
                <span>Coverage</span>
                <span class="ra-step-count">Step 5 of 6</span>
            </div>

            <!-- LIFE -->
            <div class="mini-card ra-subsection-card">
                <h5>Life Insurance</h5>

                <div class="row">
                    <div class="col-md-4">
                        <label>Do you have life insurance?<span class="text-danger">*</span></label>
                        <select asp-for="HasLifeInsurance" class="form-select insurance-toggle" required>
                            <option value="">--Select--</option>
                            <option>Yes</option>
                            <option>No</option>
                        </select>
                        <span asp-validation-for="HasLifeInsurance" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label>Individual Coverage</label>
                        <div class="input-group">
                            <input asp-for="LifeCoverageIndividual" type="number" class="form-control currency-input coverage-field"
                                   data-parent="HasLifeInsurance" min="0" />
                            <span class="currency-symbol">$</span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label>Group Coverage</label>
                        <div class="input-group">
