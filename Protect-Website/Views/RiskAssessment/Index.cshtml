                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <label>Auto Coverage Limit</label>
                        <div class="input-group">
                            <input asp-for="AutoCoverageLimit" type="number" class="form-control currency-input coverage-field"
                                   data-parent="HasAutoInsurance" min="0" />
