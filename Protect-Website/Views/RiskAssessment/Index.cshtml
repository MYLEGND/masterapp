                    <div class="col-md-4">
                        <label>Auto Insurance?</label>
                        <select asp-for="HasAutoInsurance" class="form-select insurance-toggle">
                            <option value="">--Select--</option>
                            <option>Yes</option>
                            <option>No</option>
