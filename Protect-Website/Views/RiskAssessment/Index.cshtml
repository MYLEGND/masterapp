                    <div class="col-md-4">
                        <label>General Liability Limit</label>
                        <div class="input-group">
                            <input asp-for="GeneralLiabilityLimit" type="number" class="form-control currency-input coverage-field"
                                   data-parent="HasGeneralLiability" min="0" />
