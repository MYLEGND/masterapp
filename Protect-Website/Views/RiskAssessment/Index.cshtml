                    <div class="col-md-4">
                        <label>Home Coverage Limit</label>
                        <div class="input-group">
                            <input asp-for="HomeCoverageLimit" type="number" class="form-control currency-input coverage-field"
                                   data-parent="HasHomeInsurance" min="0" />
