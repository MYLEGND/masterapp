                <div class="row">
                    <div class="col-md-4">
                        <label>Professional Liability?</label>
                        <select asp-for="HasProfessionalLiability" class="form-select insurance-toggle">
                            <option value="">--Select--</option>
                            <option>Yes</option>
                            <option>No</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label>Professional Liability Limit</label>
                        <div class="input-group">
                            <input asp-for="ProfessionalLiabilityLimit" type="number" class="form-control currency-input coverage-field"
