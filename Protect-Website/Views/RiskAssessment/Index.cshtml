                <input asp-for="AcknowledgedDisclaimer" class="form-check-input" type="checkbox" required data-original-required="1" />
                <label class="form-check-label" for="AcknowledgedDisclaimer">
                    I acknowledge that by submitting this form, I authorize the company to contact me regarding my risk assessment / legacy review request.<span class="text-danger">*</span>
                </label>
                <span asp-validation-for="AcknowledgedDisclaimer" class="text-danger"></span>
            </div>

            <div class="nav-row">
                <button type="button" class="btn btn-outline-gold" id="back-6">← Back</button>
                <button type="submit" class="btn btn-gold">Submit Risk Assessment</button>
            </div>
        </div>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // ---------- STEP CONTROL ----------
        const stepWraps = Array.from(document.querySelectorAll(".step-wrap"));
        const stepPills = Array.from(document.querySelectorAll(".step-pill"));
        const currentStepInput = document.getElementById("CurrentStep");

        function clampStep(n){
            n = parseInt(n || 1);
            if (isNaN(n) || n < 1) n = 1;
            if (n > 6) n = 6;
            return n;
        }

        function setStep(step){
            step = clampStep(step);
            currentStepInput.value = step;

            stepWraps.forEach(w => w.classList.toggle("active", w.getAttribute("data-step") == step));
            stepPills.forEach(p => {
                const s = parseInt(p.getAttribute("data-step"));
                p.classList.toggle("active", s === step);
                p.classList.toggle("done", s < step);
            });

            window.scrollTo({ top: 0, behavior: "smooth" });
        }

        function validateStep(step){
            const wrap = stepWraps.find(w => w.getAttribute("data-step") == step);
            if (!wrap) return true;

            // validate only visible step required inputs/selects/textarea that are NOT disabled
            const fields = wrap.querySelectorAll("input, select, textarea");
            for (const f of fields){
                if (f.disabled) continue;
                if (!f.hasAttribute("required")) continue;

                // HTML5 constraint validation
                if (!f.checkValidity()){
                    f.reportValidity();
                    return false;
                }
            }
            return true;
        }

        // click step pills (only allow back freely; forward requires current step valid)
        stepPills.forEach(p => {
            p.addEventListener("click", () => {
                const target = parseInt(p.getAttribute("data-step"));
                const current = clampStep(currentStepInput.value);

                if (target <= current) return setStep(target);
                if (validateStep(current)) setStep(target);
            });
        });

        // wire next/back buttons
        function next(step){
            if (!validateStep(step)) return;
            setStep(step + 1);
        }
        function back(step){
            setStep(step - 1);
        }

        document.getElementById("next-1").addEventListener("click", () => next(1));
        document.getElementById("next-2").addEventListener("click", () => next(2));
        document.getElementById("next-3").addEventListener("click", () => next(3));
        document.getElementById("next-4").addEventListener("click", () => next(4));
        document.getElementById("next-5").addEventListener("click", () => next(5));

        document.getElementById("back-2").addEventListener("click", () => back(2));
        document.getElementById("back-3").addEventListener("click", () => back(3));
        document.getElementById("back-4").addEventListener("click", () => back(4));
        document.getElementById("back-5").addEventListener("click", () => back(5));
        document.getElementById("back-6").addEventListener("click", () => back(6));

        // ---------- COVERAGE FIELD TOGGLES ----------
        document.querySelectorAll(".insurance-toggle").forEach(select => {
            const fields = document.querySelectorAll(`[data-parent='${select.name}']`);

            function sync() {
                if (select.value === "No") {
                    fields.forEach(f => {
                        f.value = 0;
                        f.disabled = true;
                        f.removeAttribute("required");
                    });
                } else if (select.value === "Yes") {
                    fields.forEach(f => {
                        f.disabled = false;
                        // keep optional unless you explicitly want required when Yes
                        // f.setAttribute("required", "required");
                        if (f.value == 0) f.value = "";
                    });
                } else {
                    fields.forEach(f => {
                        f.disabled = true;
                        f.value = "";
                    });
                }
            }

            select.addEventListener("change", sync);
            sync();
        });

        // ---------- Working Years Left ----------
        const ageInput = document.getElementById("age-input");
        const retirementInput = document.getElementById("retirement-age-input");
        const workingYearsInput = document.getElementById("working-years-left");

        function updateWorkingYears() {
            const age = parseInt(ageInput?.value) || 0;
            const retirement = parseInt(retirementInput?.value) || 0;
            let yearsLeft = retirement - age;
            if (workingYearsInput) workingYearsInput.value = yearsLeft > 0 ? yearsLeft : 0;
        }

        if (ageInput) ageInput.addEventListener("input", updateWorkingYears);
        if (retirementInput) retirementInput.addEventListener("input", updateWorkingYears);

        // ---------- init step from server ----------
        setStep(@Model.CurrentStep);
        updateWorkingYears();
    </script>
}
