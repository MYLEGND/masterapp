            <!-- PROPERTY & LIABILITY -->
            <div class="mini-card ra-subsection-card">
                <h5>Property & Liability</h5>

                <div class="row">
                    <div class="col-md-4">
                        <label>Home Insurance?</label>
                        <select asp-for="HasHomeInsurance" class="form-select insurance-toggle">
                            <option value="">--Select--</option>
