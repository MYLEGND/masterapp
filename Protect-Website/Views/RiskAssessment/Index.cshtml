            </div>

            <!-- PROPERTY & LIABILITY -->
            <div class="section-card">
                <div class="section-title">Property & Liability</div>

                <div class="row">
                    <div class="col-md-4">
                        <label>Home Insurance?</label>
                        <select asp-for="HasHomeInsurance" class="form-select insurance-toggle">
                            <option value="">--Select--</option>
                            <option>Yes</option>
                            <option>No</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label>Home Coverage Limit</label>
                        <div class="input-group">
                            <input asp-for="HomeCoverageLimit" type="number" class="form-control currency-input coverage-field"
                                   data-parent="HasHomeInsurance" min="0" />
                            <span class="currency-symbol">$</span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label>Auto Insurance?</label>
                        <select asp-for="HasAutoInsurance" class="form-select insurance-toggle">
                            <option value="">--Select--</option>
