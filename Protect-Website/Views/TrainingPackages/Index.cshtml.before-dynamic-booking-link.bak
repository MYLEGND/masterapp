@{
    ViewData["Title"] = "Training Packages";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var prelaunchLink = (string)(ViewBag.SquarePrelaunchLink ?? "#");
    var trainingLink  = (string)(ViewBag.SquareTrainingLink ?? "#");
    var fullLink      = (string)(ViewBag.SquareFullLink ?? "#");
    var gymLink       = (string)(ViewBag.SquareGymLink ?? "#");

    var prelaunchWealthLink = (string)(ViewBag.SquarePrelaunchLinkWealth ?? "#");
    var trainingWealthLink  = (string)(ViewBag.SquareTrainingLinkWealth ?? "#");
    var fullWealthLink      = (string)(ViewBag.SquareFullLinkWealth ?? "#");
    var gymWealthLink       = (string)(ViewBag.SquareGymLinkWealth ?? "#");

    var bookingLink = "https://outlook.office.com/book/LEGEND@mylegnd.com/?ismsaljsauthenabled=true";
}

<div class="container training-page mt-4">

    <!-- HERO (same clean hierarchy style) -->
    <div class="text-center mb-4">
        <h1 class="display-4 fw-bold">Training Packages</h1>
        <p class="lead mb-2">
            Protect your health. Protect your wealth. Protect your legacy.
        </p>
        <hr class="my-3 hero-hr" />
        <p class="hero-subcopy mt-3">
            Built for business owners, entrepreneurs, high achievers, and Kingdom builders —
            and for anyone committed to becoming the best version of themselves.
            This training and planning experience is designed to help you build your legacy,
            protect what matters most, and leave an impact that lasts for generations.
        </p>
    </div>

    <!-- MAIN CARD (Parfait-style container) -->
    <div class="main-gold-card">

        <!-- TOGGLE -->
        <div class="bundle-wrap">
            <div class="bundle-card">
                <div class="bundle-left">
                    <div class="bundle-title">Legacy Bundle Pricing</div>
                    <div class="bundle-sub">
                        Commit to <span class="accent-text">Health + Wealth</span> planning and your training price drops
                        <span class="accent-text">30%</span>.
                        Because the goal isn’t just looking strong — it’s being protected when life hits.
                    </div>
                </div>

                <label class="switch" aria-label="Toggle Legacy Bundle pricing">
                    <input id="bundleToggle" type="checkbox" />
                    <span class="slider"></span>
                </label>
            </div>

            <div class="bundle-proof">
                <span class="dot"></span>
                <span>
                    Legacy Bundle = training + a structured financial plan (protection, priorities, clarity).
                    Clean direction. Real accountability.
                </span>
            </div>
        </div>

        <!-- PACKAGES -->
        <div class="packages-grid">

            <!-- CARD 1 -->
            <div class="package-card">
                <div class="deal-badge">
                    Limited-time deal
                </div>

                <div class="package-top">
                    <div class="package-title">Starter Package</div>

                    <div class="package-priceblock">
                        <div class="package-price">
                            <span class="prev-price"
                                data-prev-standard="$350"
                                data-prev-bundle="$350">$350</span>

                            <span class="price-amount"
                                data-standard="$250"
                                data-bundle="$245">$250</span>


                            <span class="price-term">/month</span>
                        </div>

                        <div class="price-note"
                             data-standard="Standard pricing."
                             data-bundle="Legacy Bundle pricing applied (30% off).">
                            Standard pricing.
                        </div>
                    </div>

                    <ul class="package-list">
                        <li>2–3 training sessions per week</li>
                        <li>Monthly training programming</li>
                        <li>Structured progression + guidance</li>
                        <li>Accountability to keep you consistent</li>
                        <li>Premium onboarding + plan setup</li>
                    </ul>
                </div>

                <div class="package-bottom">
                    <a class="btn-package"
                       data-standard-href="@prelaunchLink"
                       data-bundle-href="@prelaunchWealthLink"
                       href="@prelaunchLink"
                       target="_blank"
                       rel="noopener noreferrer">
                        Subscribe
                    </a>

                    <div class="package-foot">A structured starting point for consistency.</div>
                </div>
            </div>

            <!-- CARD 2 -->
            <div class="package-card featured">
                <div class="deal-badge">
                    Limited-time deal
                </div>

                <div class="package-top">
                    <div class="package-title">Training Membership</div>

                    <div class="package-priceblock">
                        <div class="package-price">
                            <span class="prev-price"
                                data-prev-standard="$550"
                                data-prev-bundle="$550">$550</span>

                            <span class="price-amount"
                                data-standard="$400"
                                data-bundle="$385">$400</span>

                            <span class="price-term">/month</span>
                        </div>

                        <div class="price-note"
                             data-standard="Standard pricing."
                             data-bundle="Legacy Bundle pricing applied (30% off).">
                            Standard pricing.
                        </div>
                    </div>

                    <ul class="package-list">
                        <li>3–4 training sessions per week</li>
                        <li>Monthly training programming</li>
                        <li>Progressive training structure</li>
                        <li>Accountability built into your routine</li>
                        <li>Support focused on consistency + execution</li>
                    </ul>
                </div>

                <div class="package-bottom">
                    <a class="btn-package"
                       data-standard-href="@trainingLink"
                       data-bundle-href="@trainingWealthLink"
                       href="@trainingLink"
                       target="_blank"
                       rel="noopener noreferrer">
                        Subscribe
                    </a>

                    <div class="package-foot">The standard Legend training experience.</div>
                </div>
            </div>

            <!-- CARD 3 -->
            <div class="package-card">
                <div class="deal-badge">
                    Limited-time deal
                </div>

                <div class="package-top">
                    <div class="package-title">Full Coaching</div>

                    <div class="package-priceblock">
                        <div class="package-price">
                            <span class="prev-price"
                                data-prev-standard="$700"
                                data-prev-bundle="$700">$700</span>

                            <span class="price-amount"
                                data-standard="$550"
                                data-bundle="$490">$550</span>

                            <span class="price-term">/month</span>
                        </div>

                        <div class="price-note"
                             data-standard="Standard pricing."
                             data-bundle="Legacy Bundle pricing applied (30% off).">
                            Standard pricing.
                        </div>
                    </div>

                    <ul class="package-list">
                        <li>4–5 training sessions per week</li>
                        <li>Full personal training support</li>
                        <li>Customized nutrition guidance</li>
                        <li>Training + nutrition alignment</li>
                        <li>Higher-touch structure for faster clarity</li>
                    </ul>
                </div>

                <div class="package-bottom">
                    <a class="btn-package"
                       data-standard-href="@fullLink"
                       data-bundle-href="@fullWealthLink"
                       href="@fullLink"
                       target="_blank"
                       rel="noopener noreferrer">
                        Subscribe
                    </a>

                    <div class="package-foot">Best for speed + precision.</div>
                </div>
            </div>

        </div>

        <!-- WHY -->
        <div class="why-mini">
            <div class="why-badge">Why the discount?</div>
            <p class="why-text">
                Because we understand that real progress requires structure — not just in training, but in the finances that support the life you’re building.
                As your health, income, and responsibilities grow, so does the need to protect what you’ve worked so hard to create.
                Without clear financial organization and protection in place, one unexpected event can put everything at risk.
                The last conversation we ever want to have is,
                <em>“Why didn’t anyone bring this to my attention sooner?”</em>
            </p>

            <p class="why-italic">
                Strength is built through discipline. Stability is preserved through preparation.
            </p>
    </div>

    <!-- BOOKINGS (button like the clean navbar buttons — no embedded iframe) -->
    <div class="booking-section mt-5" id="calendar">
        <h2 class="booking-title">Want to talk first?</h2>
        <p class="booking-sub">
            Book a time. We’ll map the right package, then tighten your plan — physically and financially.
        </p>

        <div class="booking-actions">
            <a class="btn-book"
               href="@bookingLink"
               target="_blank"
               rel="noopener noreferrer">
                Book a Call
            </a>
        </div>

        <div class="booking-footnote">
            Prefer action first? Pick a package above — you can still book after.
        </div>
    </div>

</div>

<style>
:root{
    --gold:#a68023;
    --gold-dark:#8f6f1e;

    --ink:#0b0b0c;
    --muted: rgba(11,11,12,.78);
    --subtle: rgba(11,11,12,.10);

    --danger:#d63b3b;
    --danger-soft: rgba(214,59,59,.14);
}

/* Page */
.training-page{
    padding-bottom: 2.75rem;
}

/* Hero */
.hero-hr{
    border-color: var(--gold);
    border-width: 2px;
    max-width: 860px;
    margin: 1rem auto 0;
}
.hero-subcopy{
    max-width: 900px;
    margin: 0 auto;
    color: var(--muted);
    line-height: 1.85;
}
.accent-text{
    color: var(--gold);
    font-weight: 950;
}

/* Main container card */
.main-gold-card{
    max-width: 1020px;
    margin: 0 auto;
    padding: clamp(22px, 4vw, 34px);
    border: 3px solid var(--gold);
    border-radius: 26px;
    background: #fff;
    box-shadow: 0 12px 34px rgba(0,0,0,.08);
}

/* Toggle card */
.bundle-wrap{ margin: 0 auto 18px; }
.bundle-card{
    display:flex;
    align-items:center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px;
    border-radius: 18px;
    border: 1.5px solid var(--subtle);
    box-shadow: 0 10px 26px rgba(0,0,0,.06);
    background:#fff;
}
.bundle-title{
    font-weight: 950;
    color: var(--ink);
    font-size: 1.08rem;
    margin-bottom: 6px;
}
.bundle-sub{
    color: rgba(11,11,12,.78);
    line-height: 1.7;
    max-width: 760px;
}
.bundle-proof{
    margin-top: 10px;
    display:flex;
    gap: 10px;
    align-items:flex-start;
    color: rgba(11,11,12,.74);
    line-height: 1.7;
    font-weight: 650;
}
.bundle-proof .dot{
    width: 8px; height: 8px;
    border-radius: 999px;
    background: var(--gold);
    margin-top: 8px;
}

/* Switch */
.switch{ position: relative; display:inline-block; width: 58px; height: 34px; flex: 0 0 auto; }
.switch input{ opacity:0; width:0; height:0; }
.slider{
    position:absolute; cursor:pointer; inset:0;
    background: rgba(11,11,12,.14);
    transition:.2s ease;
    border-radius: 999px;
    border: 1px solid rgba(11,11,12,.12);
}
.slider:before{
    content:"";
    position:absolute;
    height: 26px; width: 26px;
    left: 4px; top: 3px;
    background:#fff;
    border-radius: 999px;
    transition:.2s ease;
    box-shadow: 0 8px 18px rgba(0,0,0,.18);
}
.switch input:checked + .slider{
    background: rgba(166,128,35,.40);
    border-color: rgba(166,128,35,.55);
}
.switch input:checked + .slider:before{
    transform: translateX(24px);
}

/* Grid */
.packages-grid{
    display:grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-top: 18px;
}

/* Cards */
.package-card{
    position: relative;
    background:#fff;
    border: 2px solid rgba(11,11,12,.10);
    border-radius: 22px;
    padding: 22px;
    box-shadow: 0 10px 26px rgba(0,0,0,.06);
    display:flex;
    flex-direction: column;
    min-height: 565px; /* room for deal badge + alignment */
    overflow:hidden;
}
.package-card.featured{
    border-color: rgba(166,128,35,.55);
    box-shadow: 0 16px 38px rgba(0,0,0,.09);
}

/* Deal badge */
.deal-badge{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    width: fit-content;
    padding: 8px 14px;
    border-radius: 999px;
    font-weight: 950;
    letter-spacing: .02em;
    text-transform: uppercase;
    font-size: .72rem;
    color: var(--danger);
    background: var(--danger-soft);
    border: 1px solid rgba(214,59,59,.30);
    margin-bottom: 14px;
}

/* Top */
.package-top{
    display:flex;
    flex-direction: column;
    flex: 1 1 auto;
    min-height: 0;
}
.package-title{
    font-weight: 950;
    font-size: 1.12rem;
    color: var(--ink);
    margin-bottom: 10px;
}

/* Price block */
.package-priceblock{
    min-height: 96px;
    display:flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 8px;
    margin-bottom: 6px;
}
.package-price{
    display:flex;
    align-items:baseline;
    gap: 10px;
    flex-wrap: wrap;
}
.prev-price{
    font-weight: 950;
    font-size: 1.15rem;
    color: var(--danger);
    text-decoration: line-through;
    text-decoration-thickness: 2px;
    text-decoration-color: var(--danger);
}
.price-amount{
    font-weight: 950;
    font-size: 2.05rem;
    color: var(--ink);
}
.price-term{
    color: rgba(11,11,12,.70);
    font-weight: 800;
}
.price-note{
    color: rgba(11,11,12,.72);
    font-weight: 750;
    line-height: 1.35;
}

/* List */
.package-list{
    margin: 14px 0 0;
    padding-left: 18px;
    color: rgba(11,11,12,.78);
    line-height: 1.85;
    flex: 1 1 auto;
    min-height: 160px;
}

/* Bottom */
.package-bottom{
    padding-top: 18px;
    display:flex;
    flex-direction: column;
    gap: 10px;
}

/* Button */
.btn-package{
    display:inline-block;
    width: 100%;
    padding: 14px 18px;
    border-radius: 999px;
    border: 2px solid var(--gold);
    background: #fff;
    color: var(--ink);
    font-weight: 950;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    text-decoration:none;
    box-shadow: 0 10px 26px rgba(166,128,35,.12);
    transition: all 0.22s ease;
    text-align:center;
}
.btn-package:hover{
    background: var(--gold);
    color:#fff;
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(166,128,35,.22);
}

/* Footnote */
.package-foot{
    min-height: 44px;
    color: rgba(11,11,12,.70);
    font-weight: 650;
    line-height: 1.6;
    text-align:center;
    display:flex;
    align-items:center;
    justify-content:center;
}

/* Why mini */
.why-mini{
    margin-top: 22px;
    padding: 18px 16px;
    border-radius: 18px;
    border: 1.5px solid rgba(11,11,12,.10);
    box-shadow: 0 10px 26px rgba(0,0,0,.05);
    text-align:center;
}
.why-badge{
    display:inline-block;
    background: var(--gold);
    color:#fff;
    padding: 8px 18px;
    border-radius: 999px;
    font-weight: 950;
    letter-spacing: .08em;
    text-transform: uppercase;
    font-size: .78rem;
    margin-bottom: 12px;
}
.why-text{
    max-width: 900px;
    margin: 0 auto;
    color: rgba(11,11,12,.82);
    line-height: 1.85;
    font-weight: 650;
}
.why-divider{
    border:none;
    height: 2px;
    background: var(--gold);
    width: 70%;
    margin: 18px auto;
    border-radius: 2px;
}
.why-italic{
    font-style: italic;
    font-weight: 650;
    color: #444;
    margin: 0;
}

/* Booking section (clean card + pill button, not embedded) */
.booking-section{
    max-width: 1020px;
    margin: 0 auto;
    padding: 22px 18px;
    background:#fff;
    border-radius: 20px;
    box-shadow: 0 10px 26px rgba(0,0,0,.08);
    border: 1.5px solid rgba(11,11,12,.10);
    text-align:center;
}
.booking-title{
    font-size: 1.65rem;
    font-weight: 950;
    color: var(--ink);
    margin-bottom: 8px;
}
.booking-sub{
    font-size: 1.06rem;
    color: rgba(11,11,12,.78);
    max-width: 820px;
    margin: 0 auto 14px;
    line-height: 1.7;
}
.booking-actions{
    display:flex;
    justify-content:center;
    margin-top: 6px;
}
.btn-book{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding: 12px 22px;
    border-radius: 999px;
    border: 2px solid var(--gold);
    background:#fff;
    color: var(--ink);
    font-weight: 950;
    text-transform: uppercase;
    letter-spacing: .4px;
    text-decoration:none;
    transition: all 0.22s ease;
    box-shadow: 0 10px 26px rgba(166,128,35,.12);
}
.btn-book:hover{
    background: var(--gold);
    color:#fff;
    transform: translateY(-2px);
    box-shadow: 0 16px 36px rgba(166,128,35,.22);
}
.booking-footnote{
    margin-top: 12px;
    color: rgba(11,11,12,.66);
    font-weight: 650;
}

/* Responsive */
@@media (max-width: 992px){
    .packages-grid{ grid-template-columns: 1fr; }
    .package-card{ min-height: unset; }
    .package-list{ min-height: unset; }
    .package-priceblock{ min-height: unset; }
    .package-foot{ min-height: unset; }
}
@@media (max-width: 576px){
    .bundle-card{ flex-direction: column; align-items:flex-start; }
    .package-card{ padding: 20px; }
    .price-amount{ font-size: 1.95rem; }
    .prev-price{ font-size: 1.05rem; }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const toggle = document.getElementById("bundleToggle");

    function applyPricing(isBundle){
        // current price
        document.querySelectorAll(".price-amount").forEach(el => {
            el.textContent = isBundle ? el.dataset.bundle : el.dataset.standard;
        });

        // previous (striked) price
        document.querySelectorAll(".prev-price").forEach(el => {
            el.textContent = isBundle ? el.dataset.prevBundle : el.dataset.prevStandard;
        });

        // note line
        document.querySelectorAll(".price-note").forEach(el => {
            el.textContent = isBundle ? el.dataset.bundle : el.dataset.standard;
        });

        // button href
        document.querySelectorAll(".btn-package").forEach(btn => {
            btn.href = isBundle ? btn.dataset.bundleHref : btn.dataset.standardHref;
        });
    }

    toggle.addEventListener("change", () => applyPricing(toggle.checked));
    applyPricing(false);
});
</script>
