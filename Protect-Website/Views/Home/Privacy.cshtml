@{
    ViewData["Title"] = "Privacy & Data Use";
    ViewData["PageKey"] = "privacy";
}

<div class="legal-page-wrap">
    <section class="legal-hero">
        <p class="legal-kicker">Legend™</p>
        <h1 class="legal-title">Privacy &amp; Data Use</h1>
        <p class="legal-intro">Your trust is our priority.</p>
    </section>

    <section class="legal-card legal-prose">
        <p>
            Legend™ respects your privacy and values your trust. We collect personal information only when you
            voluntarily share it with us, for example, when you schedule a session, submit a form, or communicate
            with us directly.
        </p>
        <p>
            This information is used solely to provide our coaching and insurance-related services, respond to
            inquiries, and meet legal or regulatory requirements. We do not sell your information.
        </p>
        <p>
            Some third-party tools we use, like Microsoft Bookings or other scheduling platforms, may store limited
            technical data as part of their normal operation. Legend™ does not access or control this data.
        </p>
        <p class="legal-contact">
            If you have questions about how your data is used, contact us at
            <a href="mailto:connect@mylegnd.com">connect@mylegnd.com</a>.
        </p>
        <p class="legal-updated">Last updated: April 2026</p>
    </section>
</div>
