@inject ProtectWebsite.Services.Booking.IPublicBookingResolver PublicBookingResolver

@{
    ViewData["Title"] = "Home";
    ViewData["PageKey"] = "home";
    ViewData["SeoTitle"] = "Life Insurance, Mortgage Protection & Family Coverage";
    ViewData["SeoDescription"] = "Protect your income, family, and future with personalized life insurance, mortgage protection, final expense, and coverage planning options.";

    var segs = (Context?.Request?.Path.Value ?? string.Empty).Split('/', StringSplitOptions.RemoveEmptyEntries);
    var agentSlug = (segs.Length >= 2 && segs[0].Equals("a", StringComparison.OrdinalIgnoreCase)) ? segs[1] : null;
    var slugPrefix = !string.IsNullOrWhiteSpace(agentSlug) ? $"/a/{agentSlug}" : string.Empty;
    var bookingConfig = PublicBookingResolver.Resolve(agentSlug);
    var bookingLink = bookingConfig.Enabled
        ? bookingConfig.FallbackUrl ?? bookingConfig.EmbedUrl ?? "#"
        : "#";

    string Link(string relative)
    {
        var basePath = Context?.Request?.PathBase.Value ?? string.Empty;
        return $"{basePath}{slugPrefix}{relative}";
    }
}

<style>
:root{
    --surface:#0f172a;
    --surface-soft:#111c32;
    --surface-deep:#0b1325;
    --ink-light:#f8fafc;
    --muted:rgba(248,250,252,.78);
    --muted-soft:rgba(248,250,252,.62);
    --gold:#a68023;
    --gold-strong:#c79931;
    --gold-bright:#f2cd75;
    --border:rgba(199,153,49,.86);
    --border-soft:rgba(199,153,49,.24);
    --shadow:0 22px 64px rgba(0,0,0,.18);
}

.home-page,
.home-page *{
    box-sizing:border-box;
    color-scheme:dark;
}

.home-page{
    max-width:1160px;
    margin:0 auto;
    padding:24px 18px 72px;
}

.home-shell{
    background:linear-gradient(180deg,#0f172a 0%,#0b1325 100%) !important;
    color:#f8fafc !important;
    border:1.6px solid var(--border);
    border-radius:24px;
    box-shadow:var(--shadow);
    overflow:hidden;
    position:relative;
}

.home-shell:before{
    content:"";
    position:absolute;
    inset:0;
    pointer-events:none;
    background:
        radial-gradient(850px 300px at 12% 0%, rgba(199,153,49,.16), transparent 64%),
        radial-gradient(640px 250px at 100% 0%, rgba(199,153,49,.10), transparent 70%);
}

.home-shell > *{
    position:relative;
    z-index:1;
}

.home-hero{
    padding:30px 30px 20px;
    border-bottom:1px solid var(--border-soft);
}

.home-title{
    margin:0 0 10px;
    color:#e8edf7 !important;
    font-size:clamp(2.1rem,3.35vw,3rem);
    line-height:1.04;
    letter-spacing:-.04em;
    font-weight:950;
}

.home-title span{
    color:var(--gold-bright) !important;
}

.home-lead{
    max-width:760px;
    margin:0;
    color:var(--muted) !important;
    font-size:1.05rem;
    line-height:1.55;
}

.home-actions{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:12px;
    padding:22px 30px 24px;
}

.home-action{
    display:grid;
    grid-template-columns:auto 1fr auto;
    align-items:center;
    gap:12px;
    min-height:86px;
    padding:14px;
    border-radius:18px;
    border:1px solid rgba(199,153,49,.48);
    background:rgba(255,255,255,.045);
    text-decoration:none !important;
    color:#f8fafc !important;
    transition:.18s ease;
}

.home-action:hover{
    transform:translateY(-3px);
    border-color:var(--gold-bright);
    background:rgba(199,153,49,.10);
    color:#fff !important;
}

.home-icon{
    width:42px;
    height:42px;
    border-radius:15px;
    display:flex;
    align-items:center;
    justify-content:center;
    border:1px solid rgba(199,153,49,.46);
    background:rgba(199,153,49,.15);
    color:var(--gold-bright);
}

.home-icon svg{
    width:22px;
    height:22px;
    stroke:currentColor;
    stroke-width:2;
    fill:none;
    stroke-linecap:round;
    stroke-linejoin:round;
}

.home-action-title{
    margin:0 0 2px;
    color:var(--gold-bright) !important;
    font-size:1rem;
    font-weight:950;
}

.home-action-sub{
    margin:0;
    color:var(--muted-soft) !important;
    font-size:.86rem;
    line-height:1.32;
}

.home-arrow{
    width:30px;
    height:30px;
    border-radius:999px;
    display:flex;
    align-items:center;
    justify-content:center;
    border:1px solid rgba(199,153,49,.62);
    color:#f8fafc;
    font-weight:950;
}

.home-proof{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    border-top:1px solid var(--border-soft);
    background:rgba(255,255,255,.025);
}

.home-proof-item{
    display:flex;
    align-items:center;
    gap:12px;
    padding:12px 20px;
    border-right:1px solid rgba(199,153,49,.16);
    min-height:62px;
}

.home-proof-item:last-child{
    border-right:0;
}

.home-proof-num{
    width:30px;
    height:30px;
    display:flex;
    align-items:center;
    justify-content:center;
    border-radius:999px;
    border:1px solid rgba(199,153,49,.62);
    color:var(--gold-bright);
    font-weight:950;
    flex:0 0 auto;
}

.home-proof-copy{
    display:flex;
    align-items:center;
    gap:8px;
    min-width:0;
}

.home-proof-copy strong{
    color:var(--gold-bright);
    font-weight:950;
    white-space:nowrap;
}

.home-proof-copy span{
    color:var(--muted);
    font-size:.88rem;
    white-space:nowrap;
    overflow:hidden;
    text-overflow:ellipsis;
}

.home-secondary{
    margin-top:24px;
    background:linear-gradient(180deg,#0f172a 0%,#0b1325 100%);
    border:1.4px solid var(--border);
    border-radius:22px;
    box-shadow:0 14px 38px rgba(0,0,0,.16);
    padding:24px 24px;
    color:#f8fafc;
}

.home-secondary h2{
    margin:0 0 8px;
    color:var(--gold-strong);
    font-weight:950;
    text-align:center;
}

.home-secondary p{
    max-width:740px;
    margin:0 auto 18px;
    text-align:center;
    color:var(--muted);
    line-height:1.55;
}

.home-links{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:10px;
}

.home-link{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    padding:13px 14px;
    border-radius:16px;
    border:1px solid rgba(199,153,49,.38);
    background:rgba(255,255,255,.045);
    color:#f8fafc !important;
    text-decoration:none !important;
    font-weight:850;
}

.home-link span{
    color:var(--gold-bright);
}

.home-footer-cta{
    margin-top:24px;
    display:flex;
    justify-content:center;
    gap:12px;
    flex-wrap:wrap;
}

.home-btn{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    border-radius:14px;
    padding:12px 18px;
    font-weight:950;
    text-decoration:none !important;
    transition:.18s ease;
}

.home-btn-primary{
    background:linear-gradient(180deg,var(--gold-strong),var(--gold));
    color:#fff !important;
    border:1.5px solid var(--border);
}

.home-btn-secondary{
    background:#111c32;
    color:#f8fafc !important;
    border:1.5px solid rgba(199,153,49,.78);
}

.home-btn:hover{
    transform:translateY(-2px);
}

@@media(max-width:900px){
    .home-actions,
    .home-links{
        grid-template-columns:1fr;
    }

    .home-proof{
        grid-template-columns:1fr;
    }

    .home-proof-item{
        border-right:0;
        border-bottom:1px solid rgba(199,153,49,.16);
    }

    .home-proof-item:last-child{
        border-bottom:0;
    }
}

@@media(max-width:640px){
    .home-page{
        padding:16px 12px 56px;
    }

    .home-hero{
        padding:24px 18px 18px;
    }

    .home-actions{
        padding:18px;
    }

    .home-title{
        font-size:clamp(2rem,8vw,2.55rem);
    }
}
</style>

<div class="home-page">

    <section class="home-shell">
        <div class="home-hero">
            <h1 class="home-title">Protect what matters with <span>clarity.</span></h1>
            <p class="home-lead">Start with the right protection path. We’ll help you move from uncertainty to a clean next step.</p>
        </div>

        <div class="home-actions">
            <a href="@Link("/Quote")" class="home-action" data-cta="home_start_quote">
                <span class="home-icon">
                    <svg viewBox="0 0 24 24"><path d="M12 3l7 3v5c0 5-3.2 8.5-7 10-3.8-1.5-7-5-7-10V6l7-3z"/><path d="M9 12l2 2 4-5"/></svg>
                </span>
                <span>
                    <p class="home-action-title">Get a Quote</p>
                    <p class="home-action-sub">Life, income, home, auto, and more.</p>
                </span>
                <span class="home-arrow">→</span>
            </a>

            <a href="@Link("/RiskAssessment")" class="home-action" data-cta="home_start_assessment">
                <span class="home-icon">
                    <svg viewBox="0 0 24 24"><path d="M6 4h9l3 3v13H6z"/><path d="M15 4v4h4"/><path d="M9 13h6"/><path d="M9 17h4"/></svg>
                </span>
                <span>
                    <p class="home-action-title">Start Assessment</p>
                    <p class="home-action-sub">Find gaps before choosing blindly.</p>
                </span>
                <span class="home-arrow">→</span>
            </a>

            @if (bookingLink != "#")
            {
                <a href="@bookingLink" target="_blank" rel="noopener" class="home-action" data-cta="home_book_call">
                    <span class="home-icon">
                        <svg viewBox="0 0 24 24"><path d="M7 3v4"/><path d="M17 3v4"/><path d="M4 8h16"/><path d="M5 5h14v15H5z"/><path d="M8 12h3"/><path d="M13 12h3"/><path d="M8 16h3"/></svg>
                    </span>
                    <span>
                        <p class="home-action-title">Talk First</p>
                        <p class="home-action-sub">Book time before starting.</p>
                    </span>
                    <span class="home-arrow">↗</span>
                </a>
            }
        </div>

        <div class="home-proof">
            <div class="home-proof-item">
                <span class="home-proof-num">1</span>
                <div class="home-proof-copy"><strong>Choose</strong><span>Pick your protection lane.</span></div>
            </div>
            <div class="home-proof-item">
                <span class="home-proof-num">2</span>
                <div class="home-proof-copy"><strong>Review</strong><span>See clear options.</span></div>
            </div>
            <div class="home-proof-item">
                <span class="home-proof-num">3</span>
                <div class="home-proof-copy"><strong>Decide</strong><span>Move with clarity.</span></div>
            </div>
        </div>
    </section>

    <section class="home-secondary">
        <h2>Protection paths</h2>
        <p>Choose where you want to start. Keep it simple. We’ll guide the rest.</p>

        <div class="home-links">
            <a class="home-link" href="@Link("/Quote/Life")">Life Insurance <span>→</span></a>
            <a class="home-link" href="@Link("/Quote/Mortgage-Protection")">Mortgage Protection <span>→</span></a>
            <a class="home-link" href="@Link("/Quote/Disability")">Disability Insurance <span>→</span></a>
            <a class="home-link" href="@Link("/Quote/Term-Life")">Term Life <span>→</span></a>
            <a class="home-link" href="@Link("/Quote/Whole-Life")">Whole Life <span>→</span></a>
            <a class="home-link" href="@Link("/Quote/Final-Expense")">Final Expense <span>→</span></a>
        </div>

        <div class="home-footer-cta">
            <a href="@Link("/Quote")" class="home-btn home-btn-primary" data-cta="home_footer_quote">Start Quote →</a>
            @if (bookingLink != "#")
            {
                <a href="@bookingLink" target="_blank" rel="noopener" class="home-btn home-btn-secondary" data-cta="home_footer_book">Book a Call ↗</a>
            }
        </div>
    </section>

</div>
