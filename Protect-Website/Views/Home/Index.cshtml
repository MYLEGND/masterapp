            <div>
                <div class="kicker">Legend™ Legacy Protection</div>
                <h1 class="hero-title">Bring order to your life before life demands it from you.</h1>
                <p class="hero-copy">A cleaner way to understand your risks, protect your income, and make confident decisions with guidance rooted in clarity and stewardship.</p>

                <div class="hero-actions">
                    <a asp-controller="RiskAssessment" asp-action="Index" class="btn-home btn-primary-home" data-cta="home_start_assessment" data-lead-trigger="true" data-lead-interest="assessment">Start Assessment →</a>
                    <a href="@Link("/Quote")" class="btn-home btn-secondary-home" data-cta="home_get_quote">Get a Quote →</a>
                    @if (bookingLink != "#")
                    {
                        <a href="@bookingLink" target="_blank" rel="noopener" class="btn-home btn-secondary-home" data-cta="home_book_call">Talk First ↗</a>
                    }
                </div>
            </div>

            <aside class="snapshot">
                <h3>What we help organize</h3>
                <ul class="snapshot-list">
                    <li><span class="mini-check">@Icon("check")</span> Income risk</li>
                    <li><span class="mini-check">@Icon("check")</span> Family protection</li>
                    <li><span class="mini-check">@Icon("check")</span> Mortgage and debt exposure</li>
                    <li><span class="mini-check">@Icon("check")</span> Long-term legacy structure</li>
                </ul>
            </aside>
        </div>

        <div class="home-cards">
            <div class="home-card">
                <span class="icon">@Icon("compass")</span>
                <h3>Clarity first</h3>
                <p>See what is exposed, what is covered, and what deserves attention first.</p>
            </div>
            <div class="home-card">
                <span class="icon">@Icon("income")</span>
                <h3>Protection that fits</h3>
                <p>Build around income, family, debt, budget, and real-life priorities.</p>
            </div>
            <div class="home-card">
                <span class="icon">@Icon("legacy")</span>
                <h3>Stewardship over pressure</h3>
                <p>Make decisions with structure, faith, and clear next steps.</p>
            </div>
        </div>

        <div class="home-story-bridge">
            <div class="home-story-divider">A simple next step</div>
        </div>

        <div class="home-journey-shell">
            <div class="home-journey-head">
                <div class="panel-kicker">Your next step</div>
                <h2 class="panel-title">Choose one area first, then follow a simple three-step path.</h2>
                <p class="panel-sub">Choose the part of life that feels most urgent, review a clear next move, and decide with confidence.</p>
            </div>

            <div class="focus-panel">
                <div class="focus-head">
                    <div>
                        <h2>Choose where you want clarity</h2>
                        <p>Start with the area that feels most urgent.</p>
                    </div>
                </div>

                <div class="focus-tabs" role="tablist" aria-label="Protection focus">
                    <button type="button" class="focus-tab active" data-focus="income"><span class="icon">@Icon("income")</span> Income</button>
                    <button type="button" class="focus-tab" data-focus="family"><span class="icon">@Icon("shield")</span> Family</button>
                    <button type="button" class="focus-tab" data-focus="legacy"><span class="icon">@Icon("legacy")</span> Legacy</button>
                </div>

                <div class="focus-content" id="focusContent">
                    <div>
                        <h3>Protect the income that funds everything.</h3>
                        <p>Your income supports the home, family, lifestyle, goals, and future. Start by understanding what happens if that income stops.</p>
                    </div>
                    <a class="focus-link" href="@Link("/RiskAssessment")">Start Assessment →</a>
                </div>
            </div>

            <div class="home-process">
                <div class="process-item">
                    <span class="num">1</span>
                    <span><strong>Assess</strong><span>Find the gaps.</span></span>
                </div>
                <div class="process-item">
                    <span class="num">2</span>
                    <span><strong>Design</strong><span>Review options.</span></span>
                </div>
                <div class="process-item">
                    <span class="num">3</span>
                    <span><strong>Decide</strong><span>Move with clarity.</span></span>
                </div>
            </div>
        </div>

        <div class="home-disclosures-shell">
            <div class="home-disclosures-head">
                <div class="panel-kicker">Need more detail?</div>
                <h2 class="panel-title">Explore more only if it helps.</h2>
                <p class="panel-sub">If you want more context before moving forward, you can review the process, browse protection paths, and read common questions here.</p>
            </div>

            <div class="home-disclosures">
                <details class="home-disclosure">
                    <summary>
                        <div class="home-disclosure-copy">
                            <p class="home-disclosure-kicker">Trust markers</p>
                            <h3 class="home-disclosure-title">Why clients move forward</h3>
                            <p class="home-disclosure-preview">See how the process stays calm, documented, and free from pressure.</p>
                        </div>
                        <span class="home-disclosure-toggle" aria-hidden="true"></span>
                    </summary>
                    <div class="home-disclosure-body">
                        <div class="home-proof-grid">
                            <article class="home-proof-card">
                                <span class="icon">@Icon("file")</span>
                                <h3>Documented next steps</h3>
                                <p>We organize the facts, the gaps, and the action plan so the decision is easy to understand later.</p>
                            </article>
                            <article class="home-proof-card">
                                <span class="icon">@Icon("shield")</span>
                                <h3>No-pressure guidance</h3>
                                <p>You see the tradeoffs, the costs, and the options before anything moves forward.</p>
                            </article>
                            <article class="home-proof-card">
                                <span class="icon">@Icon("compass")</span>
                                <h3>Protection that fits real life</h3>
                                <p>Income, family, mortgage, debts, and long-term goals are all considered together.</p>
                            </article>
                            <article class="home-proof-card">
                                <span class="icon">@Icon("check")</span>
                                <h3>Faithful stewardship</h3>
                                <p>Clients get a process built on clarity, responsibility, and decisions that can actually be maintained.</p>
                            </article>
                        </div>
                    </div>
                </details>

                <details class="home-disclosure">
                    <summary>
                        <div class="home-disclosure-copy">
                            <p class="home-disclosure-kicker">Explore at your pace</p>
                            <h3 class="home-disclosure-title">Protection paths for different starting points</h3>
                            <p class="home-disclosure-preview">Browse life, mortgage protection, disability, and other coverage paths at your own pace.</p>
                        </div>
                        <span class="home-disclosure-toggle" aria-hidden="true"></span>
                    </summary>
                    <div class="home-disclosure-body">
                        <div class="home-coverage-links" aria-label="Protection planning options">
                            <a href="@Link("/Quote/Life")" class="home-coverage-link">Life Insurance Review</a>
                            <a href="@Link("/Quote/Mortgage-Protection")" class="home-coverage-link">Mortgage Protection</a>
                            <a href="@Link("/Quote/Term-Life")" class="home-coverage-link">Term Life</a>
                            <a href="@Link("/Quote/Whole-Life")" class="home-coverage-link">Whole Life</a>
                            <a href="@Link("/Quote/Final-Expense")" class="home-coverage-link">Final Expense</a>
                            <a href="@Link("/Quote/Disability")" class="home-coverage-link">Disability Insurance</a>
                        </div>
                    </div>
                </details>

                <details class="home-disclosure" id="homeFaqs">
                    <summary>
                        <div class="home-disclosure-copy">
                            <p class="home-disclosure-kicker">Common questions</p>
                            <h3 class="home-disclosure-title">Questions people often ask before they begin</h3>
                            <p class="home-disclosure-preview">Open the questions you want answered and skip the rest.</p>
                        </div>
                        <span class="home-disclosure-toggle" aria-hidden="true"></span>
                    </summary>
                    <div class="home-disclosure-body">
                        <div class="home-faq-grid">
                            <details class="home-faq-item">
                                <summary>
                                    <div class="home-faq-summary">
                                        <span class="icon">@Icon("question")</span>
                                        <h3 class="home-faq-question">What happens in the assessment?</h3>
                                    </div>
                                    <span class="home-disclosure-toggle" aria-hidden="true"></span>
                                </summary>
                                <p class="home-faq-answer">We collect your goals, income, obligations, and current coverage so you can see the protection gaps and the next step clearly.</p>
                            </details>
                            <details class="home-faq-item">
                                <summary>
                                    <div class="home-faq-summary">
                                        <span class="icon">@Icon("question")</span>
                                        <h3 class="home-faq-question">Is this just insurance?</h3>
                                    </div>
                                    <span class="home-disclosure-toggle" aria-hidden="true"></span>
                                </summary>
                                <p class="home-faq-answer">No. We start with organization and risk clarity, then match protection options to what your life and budget actually require.</p>
                            </details>
                            <details class="home-faq-item">
                                <summary>
                                    <div class="home-faq-summary">
                                        <span class="icon">@Icon("question")</span>
                                        <h3 class="home-faq-question">Is there pressure to buy?</h3>
                                    </div>
                                    <span class="home-disclosure-toggle" aria-hidden="true"></span>
                                </summary>
                                <p class="home-faq-answer">No. You review the options, the tradeoffs, and the cost structure first. You decide what makes sense and what does not.</p>
                            </details>
                            <details class="home-faq-item">
                                <summary>
                                    <div class="home-faq-summary">
                                        <span class="icon">@Icon("question")</span>
                                        <h3 class="home-faq-question">How fast do I see a plan?</h3>
                                    </div>
                                    <span class="home-disclosure-toggle" aria-hidden="true"></span>
                                </summary>
                                <p class="home-faq-answer">You receive a timely, well-structured recommendation without anything important being rushed or skipped.</p>
                            </details>
                            <details class="home-faq-item">
                                <summary>
                                    <div class="home-faq-summary">
                                        <span class="icon">@Icon("question")</span>
                                        <h3 class="home-faq-question">Can you work with my CPA or attorney?</h3>
                                    </div>
                                    <span class="home-disclosure-toggle" aria-hidden="true"></span>
                                </summary>
                                <p class="home-faq-answer">Yes. We organize the recommendation so the right professionals can review it and everything stays aligned instead of fragmented.</p>
                            </details>
                            <details class="home-faq-item">
                                <summary>
                                    <div class="home-faq-summary">
                                        <span class="icon">@Icon("question")</span>
                                        <h3 class="home-faq-question">Can I talk with someone before I start?</h3>
                                    </div>
                                    <span class="home-disclosure-toggle" aria-hidden="true"></span>
                                </summary>
                                <p class="home-faq-answer">Absolutely. If you prefer to ask questions first, you can book a conversation before beginning the assessment or quote flow.</p>
                            </details>
                        </div>
                    </div>
                </details>
            </div>
        </div>

        <div class="home-closing-shell">
            <div class="home-cta-panel">
                <div>
                    <div class="panel-kicker">Ready when you are</div>
                    <h2 class="panel-title">Start with a clean assessment, review protection paths, and move forward with confidence.</h2>
                    <p class="panel-sub">The best next step is the one that brings clarity. Start the assessment, explore coverage, or talk first if you want a human walkthrough.</p>
                    <div class="home-cta-note">No obligation. No confusion. Just a documented path to better protection.</div>
                </div>

                <div class="home-cta-actions">
                    <a asp-controller="RiskAssessment" asp-action="Index" class="btn-home btn-primary-home" data-cta="home_footer_assessment" data-lead-trigger="true" data-lead-interest="assessment">Start Assessment →</a>
                    <a href="@Link("/Quote")" class="btn-home btn-secondary-home" data-cta="home_footer_quote">Explore Coverage →</a>
                    @if (bookingLink != "#")
                    {
                        <a href="@bookingLink" target="_blank" rel="noopener" class="btn-home btn-secondary-home" data-cta="home_footer_book_call">Talk First ↗</a>
                    }
                </div>
            </div>
        </div>
    </section>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const tabs = Array.from(document.querySelectorAll(".focus-tab"));
    const content = document.getElementById("focusContent");

    const data = {
        income: {
            title: "Protect the income that funds everything.",
            copy: "Your income supports the home, family, lifestyle, goals, and future. Start by understanding what happens if that income stops.",
            href: "@Link("/RiskAssessment")",
            cta: "Start Assessment →"
        },
        family: {
            title: "Protect the people counting on you.",
            copy: "Life insurance, mortgage protection, and final expense planning help keep your family stable when life changes unexpectedly.",
            href: "@Link("/Quote")",
            cta: "Explore Coverage →"
        },
        legacy: {
            title: "Keep what you build aligned and protected.",
            copy: "Beneficiaries, ownership, coverage, and planning decisions should work together — not sit scattered across life.",
            href: "@Link("/RiskAssessment")",
            cta: "Get Organized →"
        }
    };

    tabs.forEach(tab => {
        tab.addEventListener("click", () => {
            tabs.forEach(t => t.classList.remove("active"));
            tab.classList.add("active");
            const item = data[tab.dataset.focus] || data.income;
            content.innerHTML = `
                <div>
                    <h3>${item.title}</h3>
                    <p>${item.copy}</p>
                </div>
                <a class="focus-link" href="${item.href}">${item.cta}</a>
            `;
        });
    });
});
</script>
