@using System.Text.Json
@using Microsoft.AspNetCore.Http
@using Shared.Analytics
@inject IHttpContextAccessor HttpContextAccessor
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{
    var requestPath = HttpContextAccessor.HttpContext?.Request?.Path.Value ?? string.Empty;
    var trackingProfileId = ViewData["TrackingProfileId"]?.ToString();
    var trackingSlug = ViewData["TrackingSlug"]?.ToString();
    var isFounderPath = ViewData["IsFounderPath"] as bool? ?? false;
    var isQuoteLandingRoute =
        requestPath.Contains("/quote/", StringComparison.OrdinalIgnoreCase) &&
        requestPath.Contains("/landing", StringComparison.OrdinalIgnoreCase);
    var isLandingPage = (ViewData["IsLandingPage"] as bool? ?? false) || isQuoteLandingRoute;
    var isStandaloneQuoteLanding = isLandingPage && requestPath.Contains("/quote/", StringComparison.OrdinalIgnoreCase);
    var pageVariant = (ViewData["PageVariant"]?.ToString() ?? (isLandingPage ? "landing" : "website")).Trim();
    var pageMode = (ViewData["PageMode"]?.ToString() ?? (isLandingPage ? "paid_landing" : "site_mode")).Trim();
    var extraBodyClass = ViewData["BodyClass"]?.ToString() ?? string.Empty;
    var variantClass = string.IsNullOrWhiteSpace(pageVariant) ? "website" : pageVariant.Replace(" ", "-").Replace("_", "-").ToLowerInvariant();
    var modeClass = string.IsNullOrWhiteSpace(pageMode) ? "site-mode" : pageMode.Replace(" ", "-").Replace("_", "-").ToLowerInvariant();
    var bodyClasses = $"{extraBodyClass} {(isLandingPage ? "landing-mode" : "site-mode")} page-variant-{variantClass} page-mode-{modeClass} {(isStandaloneQuoteLanding ? "standalone-quote-landing" : string.Empty)}".Trim();
    var mainClasses = isStandaloneQuoteLanding ? "layout-content" : "container layout-content";
    var legalBasePath = !isFounderPath && !string.IsNullOrWhiteSpace(trackingSlug)
        ? $"/a/{trackingSlug}"
        : string.Empty;
    var termsUrl = $"{legalBasePath}/Terms";
    var privacyUrl = $"{legalBasePath}/Privacy";
    var clientPortalBaseUrl =
        (Config["ClientPortalBaseUrl"]
        ?? (Env.IsDevelopment() ? "https://localhost:5221" : "https://client.mylegnd.com"))
        .TrimEnd('/');
    var clientLoginUrl = $"{clientPortalBaseUrl}/Account/AzureLogin";
    var metaPixelId = (ViewData["ResolvedMetaPixelId"]?.ToString() ?? string.Empty).Trim();
    var metaPixelOwnerType = (ViewData["MetaPixelOwnerType"]?.ToString() ?? string.Empty).Trim().ToLowerInvariant();
    var hasMetaPixel = !string.IsNullOrWhiteSpace(metaPixelId);
    var analyticsBrowserConfigJson = JsonSerializer.Serialize(new
    {
        allowedBrowserEvents = AnalyticsEventCatalog.BrowserAllowedEventNames,
        criticalBrowserEvents = AnalyticsEventCatalog.CriticalBrowserEventNames,
        clientTrackingErrorEvent = AnalyticsEventCatalog.ClientTrackingErrorEventName
    });
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
@{
    var seoRawTitle = (ViewData["SeoTitle"] as string) ?? (ViewData["Title"] as string) ?? "Life Insurance & Protection Planning";
    var seoTitle = seoRawTitle.Contains("Legend", StringComparison.OrdinalIgnoreCase)
        ? seoRawTitle
        : seoRawTitle + " | Legend™";

    var seoDescription = (ViewData["SeoDescription"] as string)
        ?? "Get a personalized protection review for life insurance, mortgage protection, final expense, and family coverage options.";

    var seoRequestPath = Context.Request.Path.Value ?? "/";
    var seoCanonicalPath = seoRequestPath.EndsWith("/landing", StringComparison.OrdinalIgnoreCase)
        ? seoRequestPath[..^"/landing".Length]
        : seoRequestPath;

    if (string.IsNullOrWhiteSpace(seoCanonicalPath))
    {
        seoCanonicalPath = "/";
    }

    var seoCanonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{seoCanonicalPath}";
    var seoOgImage = (ViewData["SeoImage"] as string) ?? $"{Context.Request.Scheme}://{Context.Request.Host}/images/legend-social-preview.png";
    var seoRobots = (ViewData["SeoRobots"] as string) ?? "index,follow";
    var seoType = (ViewData["SeoType"] as string) ?? "website";
}
    <title>@seoTitle</title>
    <meta name="description" content="@seoDescription" />
    <meta name="robots" content="@seoRobots" />
    <link rel="canonical" href="@seoCanonicalUrl" />

    <meta property="og:title" content="@seoTitle" />
    <meta property="og:description" content="@seoDescription" />
    <meta property="og:type" content="@seoType" />
    <meta property="og:url" content="@seoCanonicalUrl" />
    <meta property="og:image" content="@seoOgImage" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@seoTitle" />
    <meta name="twitter:description" content="@seoDescription" />
    <meta name="twitter:image" content="@seoOgImage" />


    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="icon" type="image/png" href="~/images/favicon/favicon.png" />
    <script>
        window.AGENT_TRACKING_PROFILE_ID = "@trackingProfileId";
        window.AGENT_TRACKING_SLUG = "@trackingSlug";
        window.IS_FOUNDER_PATH = @isFounderPath.ToString().ToLowerInvariant();
        window.IS_LANDING_PAGE = @isLandingPage.ToString().ToLowerInvariant();
        window.PAGE_VARIANT = "@pageVariant";
        window.PAGE_MODE = "@pageMode";
        window.RESOLVED_META_PIXEL_ID = "@metaPixelId";
        window.RESOLVED_META_PIXEL_OWNER_TYPE = "@metaPixelOwnerType";
    </script>

    <style>
        :root{
            --navy:#080d1a;
            --navy-deep:#060915;
            --ink:#0f172a;
            --muted:#475569;
            --gold:#a68023;
            --gold-strong:#c79931;
            --border: rgba(199,153,49,.95);
        }

        *,
        *::before,
        *::after { box-sizing: border-box; }

        html, body { width: 100%; overflow-x: hidden; }

        body {
            font-family: 'Inter', sans-serif;
            color: var(--ink);
            background: #ffffff;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main.layout-content {
            padding-top: 2rem;
            padding-bottom: 3rem;
            flex-grow: 1;
            width: 100%;
        }

        body.standalone-quote-landing main.layout-content {
            padding-top: .35rem;
            padding-bottom: 2rem;
            background: transparent !important;
            background-color: transparent !important;
        }

        footer.footer {
            background:
                radial-gradient(circle at top center, rgba(199,153,49,0.08), transparent 36%),
                linear-gradient(180deg, rgba(8,14,27,0.94) 0%, rgba(6,11,21,0.98) 100%) !important;
            color: rgba(236,240,247,0.76);
            border-top: 1px solid rgba(199,153,49,0.22);
            text-align: center;
            font-size: 0.95rem;
            font-weight: 500;
            padding: 1.2rem 1rem 1.15rem;
            width: 100%;
            box-shadow:
                0 -18px 34px rgba(0,0,0,0.30),
                inset 0 1px 0 rgba(255,255,255,0.03);
        }

        /* ------------------------ HEADER / NAVBAR ------------------------ */
        header { width: 100%; }

        .navbar {
            background: linear-gradient(160deg, #080d1a, #0a1020);
            border: 2px solid var(--border);
            border-radius: 18px;
            min-height: 110px;
            max-height: none;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
            padding: 0.5rem 1.5rem 2rem;
            box-sizing: border-box;
            position: relative;
            width: 100%;
            box-shadow:
                0 22px 42px rgba(0,0,0,.32),
                inset 0 0 0 1px rgba(255,255,255,.05);
            overflow: visible;
        }

        .navbar-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1.35rem;
            flex: 1 1 auto;
            width: 100%;
        }

        .nav-toggle {
            display: none;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 12px;
            border: 1.4px solid rgba(199,153,49,0.55);
            background: linear-gradient(160deg, #0c1427, #0a1020);
            box-shadow: 0 10px 18px rgba(0,0,0,.26), inset 0 1px 0 rgba(255,255,255,.06);
            cursor: pointer;
            padding: 0;
            transition: transform .12s ease, box-shadow .16s ease, background .16s ease;
        }
        .nav-toggle:focus-visible { outline: 2px solid var(--gold-strong); outline-offset: 3px; }
        .nav-toggle:hover { transform: translateY(-1px); box-shadow: 0 12px 22px rgba(0,0,0,.28); }
        .nav-toggle-bars,
        .nav-toggle-bars::before,
        .nav-toggle-bars::after {
            display: block;
            width: 20px;
            height: 2px;
            background: #f8fafc;
            border-radius: 4px;
            position: relative;
            transition: transform .18s ease, opacity .18s ease;
        }
        .nav-toggle-bars::before,
        .nav-toggle-bars::after {
            content: "";
            position: absolute;
            left: 0;
        }
        .nav-toggle-bars::before { top: -6px; }
        .nav-toggle-bars::after { top: 6px; }
        .navbar.mobile-open .nav-toggle-bars { transform: rotate(45deg); }
        .navbar.mobile-open .nav-toggle-bars::before { transform: rotate(-90deg) translateX(-6px); }
        .navbar.mobile-open .nav-toggle-bars::after { opacity: 0; }

        .navbar-brand img {
            height: auto;
            max-height: 138px;
            width: auto;
            max-width: 100%;
            display: block;
            filter: drop-shadow(0 6px 14px rgba(0,0,0,.35));
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            justify-content: center;
            align-self: center;
            flex: 0 0 auto;
            margin: 0;
        }

        body.landing-mode .navbar {
            height: auto;
            min-height: 88px;
            padding: 8px 16px;
        }
        body.landing-mode .navbar-top {
            justify-content: center;
            gap: 0;
        }
        body.landing-mode .navbar-brand {
            margin: 0 auto;
            pointer-events: none;
        }
        body.landing-mode .navbar-brand img {
            max-height: 68px;
        }

        .nav-links {
            display: flex;
            gap: 0.8rem;
            max-width: 100%;
            margin-left: auto;
            justify-content: flex-end;
        }

        .nav-link {
            font-weight: 800;
            padding: .5rem 1.1rem;
            border-radius: 50px;
            color: #ffffff !important;
            text-decoration: none;
            transition: all .25s ease;
            white-space: nowrap;
            border: 1.4px solid rgba(166,128,35,.42);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
        }

        .nav-link:hover,
        .nav-link.active {
            color: var(--gold-strong) !important;
            background-color: rgba(166,128,35,0.16);
            border-color: var(--border);
            transform: translateY(-2px);
            box-shadow:
                0 14px 24px rgba(0,0,0,.28),
                inset 0 1px 0 rgba(255,255,255,.12);
        }

        .header-bottom {
            position: absolute;
            bottom: 0.45rem;
            width: 100%;
            text-align: center;
            font-weight: 800;
            color: var(--gold-strong);
            font-size: 1.12rem;
            letter-spacing: 1px;
            text-shadow: 0 8px 20px rgba(0,0,0,.35);
        }

        /* Psalms trigger */
        .header-psalms {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 999px;
            border: 1.5px solid rgba(166,128,35,.65);
            background: #0f172a;
            color: var(--gold-strong);
            font-weight: 900;
            letter-spacing: 1.1px;
            font-size: 1.02rem;
            cursor: pointer;
            box-shadow:
                0 10px 22px rgba(0,0,0,.28),
                inset 0 1px 0 rgba(255,255,255,.08);
            transition: transform .16s ease, box-shadow .18s ease, background .18s ease;
        }
        .header-psalms:hover,
        .header-psalms:focus-visible {
            transform: translateY(-1px);
            box-shadow:
                0 14px 30px rgba(0,0,0,.32),
                inset 0 1px 0 rgba(255,255,255,.14);
            background: #111d33;
            outline: none;
        }
        .header-psalms:active {
            transform: translateY(0);
            box-shadow:
                0 8px 16px rgba(0,0,0,.26),
                inset 0 1px 0 rgba(255,255,255,.08);
        }

        /* Scripture modal */
        .scripture-modal {
            position: fixed;
            inset: 0;
            background: rgba(8, 12, 24, 0.72);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .18s ease;
            z-index: 9999;
            padding: 16px;
        }
        .scripture-modal.open { opacity: 1; pointer-events: auto; }

        .scripture-card {
            width: min(720px, 96vw);
            background: linear-gradient(180deg, #0f172a 0%, #0c1427 100%);
            border: 1.5px solid rgba(166,128,35,.55);
            border-radius: 18px;
            box-shadow: 0 22px 55px rgba(0,0,0,.35);
            color: #f4f6fb;
            padding: 22px 22px 24px;
            position: relative;
        }
        .scripture-card-header{
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 10px;
        }
        .scripture-day{
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 800;
            color: rgba(199,153,49,.9);
            font-size: .82rem;
        }
        .scripture-reference{
            font-size: 1.25rem;
            font-weight: 900;
            letter-spacing: .4px;
        }
        .scripture-translation{
            font-size: .9rem;
            color: rgba(244,246,251,.82);
        }
        .scripture-streak-row{
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: .92rem;
            color: rgba(244,246,251,.78);
            margin-bottom: 12px;
        }
        .scripture-streak-label{ font-weight: 800; color: rgba(199,153,49,.9); }
        .scripture-streak-value{ font-weight: 900; }
        .scripture-text{
            font-size: 1.05rem;
            line-height: 1.8;
            color: #e8ecf7;
        }
        .scripture-close{
            background: transparent;
            border: 1px solid rgba(244,246,251,.35);
            color: #f4f6fb;
            border-radius: 10px;
            width: 32px;
            height: 32px;
            font-size: 1.1rem;
            cursor: pointer;
            transition: background .15s ease, transform .15s ease;
        }
        .scripture-close:hover{
            background: rgba(244,246,251,.12);
            transform: translateY(-1px);
        }
        @@media (max-width: 768px){
            .header-psalms{ font-size: 1rem; padding: 8px 14px; }
            .scripture-card{ padding: 18px; }
            .scripture-reference{ font-size: 1.1rem; }
        }

        /* ------------------------ RESPONSIVE ------------------------ */
        @@media (max-width: 820px) {
            .navbar {
                height: auto;
                padding: 10px 12px 8px;
                border-radius: 14px;
            }

            .navbar-top {
                flex-direction: row;
                align-items: center;
                gap: 10px;
            }

            .navbar-brand img {
                max-height: 38px;
                filter: drop-shadow(0 4px 10px rgba(0,0,0,.25));
            }

            body.landing-mode .navbar {
                min-height: 74px;
                padding: 8px 12px;
            }
            body.landing-mode .navbar-brand img {
                max-height: 42px;
            }

            .nav-toggle { display: inline-flex; width: 36px; height: 36px; }

            .nav-links {
                position: absolute;
                left: 12px;
                right: 12px;
                top: 100%;
                margin-top: 10px;
                flex-direction: column;
                gap: 6px;
                background: linear-gradient(175deg, #0b1224, #0c142a);
                border: 1.4px solid rgba(199,153,49,0.55);
                border-radius: 14px;
                padding: 10px;
                box-shadow: 0 20px 32px rgba(0,0,0,.32);
                display: none;
                z-index: 50;
            }

            .navbar.mobile-open .nav-links { display: flex; }

            .nav-link {
                width: 100%;
                text-align: left;
                padding: 0.65rem 0.9rem;
                border-radius: 10px;
            }

            .header-bottom {
                position: static;
                margin-top: 6px;
                font-size: 0.96rem;
            }

            .header-psalms {
                width: 100%;
                justify-content: center;
                font-size: 0.92rem;
                padding: 8px 10px;
            }
        }

        /* ------------------------ LEAD MODAL ------------------------ */
        .lead-modal {
            position: fixed;
            inset: 0;
            background: rgba(8, 12, 24, 0.72);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: flex-start;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .2s ease;
            z-index: 10000;
            padding: calc(env(safe-area-inset-top, 0px) + 10px) 12px 14px;
            overflow-y: auto;
        }
        .lead-modal.open { opacity: 1; pointer-events: auto; }
        .lead-card {
            width: min(720px, 96vw);
            background: linear-gradient(180deg, #0f172a 0%, #0c1427 100%);
            border: 1.6px solid rgba(199,153,49,.75);
            border-radius: 18px;
            box-shadow: 0 24px 60px rgba(0,0,0,.35);
            color: #f4f6fb;
            padding: 22px;
            position: relative;
            max-height: 88vh;
            overflow-y: auto;
        }
        .lead-card h3 {
            margin: 0 0 8px;
            font-size: 1.4rem;
            font-weight: 900;
            letter-spacing: .2px;
            color: #dfe6f0;
        }
        .lead-card p.sub {
            margin: 0 0 14px;
            color: rgba(232,237,247,.85);
            line-height: 1.6;
        }
        .lead-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 12px;
        }
        .lead-card label {
            font-weight: 800;
            color: #f8fafc;
            margin-bottom: 6px;
            display: block;
        }
        .lead-card input,
        .lead-card select,
        .lead-card textarea {
            width: 100%;
            border-radius: 12px;
            border: 1.4px solid rgba(199,153,49,.9);
            padding: 10px 12px;
            background: #ffffff;
            color: #0f172a;
            font-weight: 700;
        }
        .lead-card textarea { resize: vertical; min-height: 90px; }
        .lead-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 14px;
        }
        .lead-btn {
            border-radius: 12px;
            padding: 11px 18px;
            font-weight: 900;
            border: 1.4px solid rgba(199,153,49,.9);
            cursor: pointer;
            transition: transform .15s ease, box-shadow .15s ease;
        }
        .lead-btn.primary {
            background: linear-gradient(180deg, #c79931, #a68023);
            color: #fff;
            box-shadow: 0 12px 30px rgba(0,0,0,.22);
        }
        .lead-btn.secondary {
            background: #0f172a;
            color: #dfe6f0;
        }
        .lead-btn:disabled { opacity: .6; cursor: not-allowed; }
        .lead-error {
            color: #fca5a5;
            font-weight: 800;
            margin-top: 8px;
            display: none;
        }
        .lead-error.show { display: block; }
        .lead-success {
            color: #bbf7d0;
            font-weight: 800;
            margin-top: 8px;
            display: none;
        }
        .lead-success.show { display: block; }
        .lead-close {
            position: sticky;
            top: 4px;
            margin-left: auto;
            background: transparent;
            border: 1px solid rgba(244,246,251,.3);
            color: #f4f6fb;
            border-radius: 10px;
            width: 36px;
            height: 36px;
            font-size: 1.15rem;
            cursor: pointer;
            z-index: 2;
        }
        .lead-consents {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px,1fr));
            gap: 8px;
            margin-top: 8px;
        }
        .lead-consents label {
            color: #dfe6f0;
            font-weight: 700;
            display: flex;
            gap: 8px;
            align-items: center;
        }
        .lead-consents input { width: auto; }
        .lead-required { color: #f87171; }
        @@media (max-width: 640px){
            .lead-card {
                padding: 16px;
                width: 100%;
                max-height: 86vh;
                border-radius: 14px;
            }
            .lead-grid {
                grid-template-columns: 1fr;
                gap: 10px;
            }
            .lead-card h3 { font-size: 1.15rem; line-height: 1.3; }
            .lead-card p.sub { font-size: 0.95rem; }
            .lead-actions { flex-direction: column; }
            .lead-btn { width: 100%; justify-content: center; text-align: center; }
            .lead-close { top: 6px; }
        }
    
        .footer-shell {
            width: min(100%, 1040px);
            margin: 0 auto;
            display: grid;
            justify-items: center;
            gap: .6rem;
        }

        .footer-seo-links {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: .75rem 1rem;
            padding: 0;
            margin: 0;
            font-size: .86rem;
        }

        .footer-seo-links a {
            color: rgba(246,232,195,0.72);
            text-decoration: none;
            transition: color .2s ease, text-decoration-color .2s ease;
        }

        .footer-seo-links a:hover {
            color: #f5dd9c;
            text-decoration: underline;
        }

        .footer-meta {
            display: grid;
            justify-items: center;
            gap: .35rem;
        }

        .footer-copyright {
            color: rgba(236,240,247,0.82);
            font-size: .84rem;
            line-height: 1.35;
        }

        .footer-legal {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            align-items: center;
            gap: .45rem;
            font-size: .96rem;
            line-height: 1.25;
        }

        .footer-link {
            color: #e9c66f !important;
            text-decoration: none;
            font-weight: 700;
            transition: color .2s ease, text-decoration-color .2s ease;
        }

        .footer-link:hover {
            color: #f5dd9c !important;
            text-decoration: underline;
        }

        @@media (max-width: 640px) {
            footer.footer {
                padding: 1rem .9rem .95rem;
            }

            .footer-seo-links {
                gap: .55rem .8rem;
                font-size: .8rem;
            }

            .footer-copyright {
                font-size: .8rem;
            }

            .footer-legal {
                gap: .35rem;
                font-size: .88rem;
            }
        }

</style>

    <!-- ================= META PIXEL ================= -->
    @if (hasMetaPixel)
    {
        <script>
        !function(f,b,e,v,n,t,s)
        {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
        n.callMethod.apply(n,arguments):n.queue.push(arguments)};
        if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
